/// Hash-map build + probe stress — exercises the compact-dict `MutableMap`
/// insert / lookup / delete / grow paths (NOT iteration — `map_iter` already
/// covers that). Each round inserts N distinct keys, looks every one up,
/// deletes half, then probes for survivors, so it hits `put` (with the
/// rehash / grow branch), `get`, `remove` (tombstone + entry-compaction) and
/// `contains_key` under a realistic churn pattern — the shape a compiler's
/// symbol table / interner actually sees.
///
/// Keys are `(i * STRIDE) % KEYSPACE` : STRIDE is coprime to the prime
/// KEYSPACE, so for i in [0, N) with N < KEYSPACE every key is distinct and
/// the set is identical across all four language ports — the checksum stays
/// cross-language comparable. The generator stays below 2^53 so the Bun-TS
/// peer computes it with plain `number` (no BigInt in the hot loop).
///
/// Sized so the natively compiled binary runs in ~30-80 ms.

module "main"

import "std/io"
import "std/collections"

N :: 100_000
ROUNDS :: 8
STRIDE: i64: 131101
KEYSPACE: i64: 200003

main :: fn() -> i32 {
    m :: MutableMap<i32, i32> {}
    chk: i64 = 0
    for r in 0..<ROUNDS {
        // insert / update — value carries the round so overwrites do work
        for i in 0..<N {
            k :: i32((i64(i) * STRIDE) % KEYSPACE)
            m[k] = k + r
        }
        // look every key up — sum the values found
        for i in 0..<N {
            k :: i32((i64(i) * STRIDE) % KEYSPACE)
            v :: m[k]
            if v != null { chk += i64(v) }
        }
        // delete the even-indexed keys
        for i in 0..<N {
            if i % 2 == 0 {
                k :: i32((i64(i) * STRIDE) % KEYSPACE)
                m.remove(k)
            }
        }
        // probe for survivors
        for i in 0..<N {
            k :: i32((i64(i) * STRIDE) % KEYSPACE)
            if k in m { chk += 1 }
        }
    }
    println("hashmap rounds=${ROUNDS} n=${N} size=${m.len()} chk=${chk}")
    return 0
}
