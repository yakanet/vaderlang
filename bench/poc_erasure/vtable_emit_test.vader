/// Minimal user-defined trait + impl, sole purpose: trigger the compiler's
/// vtable emit (Phase 0 of the erasure plan). Compiled by the `verify`
/// target of the POC Makefile ; the resulting `.c` file is grep'd to
/// confirm the per-tag `vader_vtable_t` section is present, then the
/// binary is run to confirm direct dispatch still works (the vtable is
/// dormant — no `Any` receiver yet, dispatch goes through the existing
/// direct-call path).

module "main"

import "std/io" { println }

Greet :: trait { greet :: fn(self) -> string }

Person :: struct { name: string }

Person implements Greet {
    greet :: fn(self) -> string { return self.name }
}

main :: fn() -> i32 {
    p :: Person { .name = "vader" }
    println(p.greet())
    return 0
}
