/// Phase 1 inline-box generalisation — Vader-level test that a multi-
/// field POD struct (`Pair { x: i32, y: i32 }`, 8 bytes) is packed
/// into `vader_box_t.payload.packed[]` rather than heap-allocated.
///
/// Verified by the `verify_packed` Makefile target: greps the emitted
/// C for the mirror struct `vader_packed_*Pair*_t` and confirms the
/// fast path is taken at struct.new + struct.get sites. Then runs the
/// binary to confirm semantic correctness.

module "main"

import "std/io" { println }

Pair :: struct { x: i32, y: i32 }

main :: fn() -> i32 {
    p :: Pair { .x = 3, .y = 4 }
    sum :: p.x + p.y
    println("Pair(${p.x}, ${p.y}) sum=${sum}")
    return 0
}
