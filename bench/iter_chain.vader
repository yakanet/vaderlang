/// Lazy iterator chain — sums the squares of even integers in [0, N) via a
/// `MapIterator(i32, i64)` ∘ `FilterIterator(i32)` ∘ `Range[i32]` pipeline,
/// inlined at the `for-in` call site so the lowerer can fuse the three
/// layers into a single counter loop (per the iterator-chain fusion fast
/// path in `src/lower/passes/for-in.ts`).
///
/// The parentheses around the iter expression are required — Vader bans
/// struct literals in the top-level position of `for` / `if` / `while` /
/// `match` conditions to keep the `for x in <expr> { … }` parse
/// unambiguous (Rust-style restriction).
///
/// Without the inline form (chain bound to a variable), the slow path
/// allocates a Yielded(T) box per yielded item and dispatches three vtable
/// `next()` calls per iteration — see TODO §3.5 for the deferred pistes
/// that would close that gap.

import "std/io" { println }
import "std/iter" { MapIterator, FilterIterator }

N :: 1_000_000

is_even :: fn(x: i32) -> bool { return x % 2 == 0 }

square_i64 :: fn(x: i32) -> i64 { return i64(x) * i64(x) }

main :: fn() -> i32 {
    total: i64 = 0
    for x in (MapIterator(i32, i64) {
        .source = FilterIterator(i32) {
            .source = 0..<N,
            .pred = is_even,
        },
        .f = square_i64,
    }) {
        total = total + x
    }
    println("iter_chain N=${N} total=${total}")
    return 0
}
