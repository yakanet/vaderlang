// Version constants — mirror of `src/version.ts`. Keep the two files in
// lockstep ; the self-host CLI surfaces `CLI_VERSION` via `vader --version`,
// and any future binary-bytecode I/O on the Vader side will read the
// `BYTECODE_VERSION_*` constants.

module "vader/version"

export CLI_VERSION :: "0.0.0-pre-mvp"

export BYTECODE_VERSION_MAJOR :: 0
export BYTECODE_VERSION_MINOR :: 1
export BYTECODE_VERSION_PATCH :: 0
