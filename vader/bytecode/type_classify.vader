// vader/bytecode/type_classify — typecheck `Type` → bytecode shapes.
//
// Shared by `vader/bytecode/emit` (per-decl interning) and any
// future pass that needs to project a `Type` into the bytecode IR
// (e.g. the data-pool encoder, the WASM emit, the LSP type-info
// renderer).
//
// Three helpers :
//   - `type_intern_key(t)` — string used as cache key by `intern_type`.
//     Primitives use the bare name (no allocation) ; every composite
//     shape falls back to `display_type(t)`.
//   - `val_type_of_type(t)` — stack-class of a `Type`. Primitives map
//     by name ; every composite (struct / array / union / ref / fn)
//     collapses to `Ref` so the operand stack carries a uniform
//     reference width.
//   - `bc_type_of(t)` — translate a `Type` to a `BcType`. Phase 1
//     covers primitives ; composite shapes land as
//     `BcPrimitive{.val=Ref}` until the lower-decl walker lands.

module "vader/bytecode"

import "vader/types" {
    Type, PrimitiveType, StructType, EnumType, TraitType, ArrayType,
    UnionType, FnType, TupleType, TypeParamType, TypeMetaType, SelfType,
    UnresolvedType, FreeIntType, FreeFloatType, NeverType,
    display_type,
}

/// Cache key for `intern_type`. Primitives skip the `display_type`
/// allocation by keying directly on the primitive name (already a
/// stable interned string the typechecker passes around).
///
/// @param t  the type to key.
/// @return   the key string ; pass to `MutableMap(string, i32)`.
export type_intern_key :: fn(t: Type) -> string = match t {
    is PrimitiveType as p -> p.name
    is StructType         -> display_type(t)
    is EnumType           -> display_type(t)
    is TraitType          -> display_type(t)
    is ArrayType          -> display_type(t)
    is UnionType          -> display_type(t)
    is FnType             -> display_type(t)
    is TupleType          -> display_type(t)
    is TypeParamType      -> display_type(t)
    is TypeMetaType       -> display_type(t)
    is SelfType           -> display_type(t)
    is UnresolvedType     -> display_type(t)
    is FreeIntType        -> display_type(t)
    is FreeFloatType      -> display_type(t)
    is NeverType          -> display_type(t)
}

/// Stack-class of a `Type`. Primitive types map by name ; every
/// composite shape (struct / array / union / ref / fn) lands in
/// `Ref` so the operand stack carries a uniform reference width.
///
/// @param t  the type to classify.
/// @return   the `ValType` the operand stack carries for this slot.
export val_type_of_type :: fn(t: Type) -> ValType = match t {
    is PrimitiveType as p -> val_type_of_primitive_name(p.name)
    is StructType         -> ValType.Ref
    is EnumType           -> ValType.Ref
    is TraitType          -> ValType.Ref
    is ArrayType          -> ValType.Ref
    is UnionType          -> ValType.Ref
    is FnType             -> ValType.Ref
    is TupleType          -> ValType.Ref
    is TypeParamType      -> ValType.Any
    is TypeMetaType       -> ValType.Any
    is SelfType           -> ValType.Ref
    is UnresolvedType     -> ValType.Any
    is FreeIntType        -> ValType.I32
    is FreeFloatType      -> ValType.F64
    is NeverType          -> ValType.Void
}

/// Translate a `Type` to a `BcType`. Phase 1 covers primitives ;
/// composite shapes (struct / array / union / ref / fn) return a
/// placeholder `BcPrimitive{.val=Ref}` — the runtime sees
/// `vader_box_t` either way, type-table accuracy for those shapes
/// lands in Phase 2 alongside the lower-decl walker.
///
/// Derived from `val_type_of_type` to keep the two classifiers in
/// lock-step ; a previous double-table drifted when one was updated
/// without the other.
///
/// @param t  the type to translate.
/// @return   a `BcType` suitable for the type table.
export bc_type_of :: fn(t: Type) -> BcType = BcPrimitive { .val = val_type_of_type(t) }

/// Recover the static `Type` of a `LoweredExpr`. Every variant
/// carries its result type in a `type` field set by the lowerer —
/// this helper just dispatches on the variant.
///
/// Used by `emit_field_access` (target type → struct id intern) and
/// by future passes that need the type of an arbitrary sub-expression
/// without re-traversing the typed AST.
///
/// @param expr  the lowered expression.
/// @return      its static result type.
export lowered_expr_type :: fn(expr: LoweredExpr) -> Type = match expr {
    is LoweredIntLit as e        -> e.type
    is LoweredFloatLit as e      -> e.type
    is LoweredBoolLit as e       -> e.type
    is LoweredNullLit as e       -> e.type
    is LoweredCharLit as e       -> e.type
    is LoweredStringLit as e     -> e.type
    is LoweredIdent as e         -> e.type
    is LoweredCall as e          -> e.type
    is LoweredVirtualCall as e   -> e.type
    is LoweredFieldAccess as e   -> e.type
    is LoweredIndex as e         -> e.type
    is LoweredUnary as e         -> e.type
    is LoweredBinary as e        -> e.type
    is LoweredIf as e            -> e.type
    is LoweredBlock as e         -> e.type
    is LoweredStructLit as e     -> e.type
    is LoweredArrayLit as e      -> e.type
    is LoweredDataConst as e     -> e.type
    is LoweredCast as e          -> e.type
    is LoweredTypeCheck as e     -> e.type
    is LoweredUnreachable as e   -> e.type
    is LoweredIntrinsicCall as e -> e.type
    is LoweredArrayLen as e      -> e.type
    is LoweredArrayPush as e     -> e.type
    is LoweredArraySlice as e    -> e.type
    is LoweredCellNew as e       -> e.type
    is LoweredCellGet as e       -> e.type
    is LoweredMakeClosure as e   -> e.type
    is LoweredTypeConst as e     -> e.type
}

import "vader/lower" {
    LoweredExpr, LoweredIntLit, LoweredFloatLit, LoweredBoolLit, LoweredNullLit,
    LoweredCharLit, LoweredStringLit, LoweredIdent, LoweredCall,
    LoweredVirtualCall, LoweredFieldAccess, LoweredIndex, LoweredUnary,
    LoweredBinary, LoweredIf, LoweredBlock, LoweredStructLit, LoweredArrayLit,
    LoweredDataConst, LoweredCast, LoweredTypeCheck, LoweredUnreachable,
    LoweredIntrinsicCall, LoweredArrayLen, LoweredArrayPush, LoweredArraySlice,
    LoweredCellNew, LoweredCellGet, LoweredMakeClosure, LoweredTypeConst,
}

/// Map a primitive name to its `ValType`. Unknown names degrade to
/// `Any` so the upstream typechecker has the only say in rejecting
/// the source.
///
/// @param name  the primitive name (`"i32"`, `"string"`, …).
/// @return      the matching `ValType` ; `Any` for unrecognised names.
export val_type_of_primitive_name :: fn(name: string) -> ValType {
    parsed :: parse_val_type(name)
    if parsed is null { return ValType.Any }
    return parsed
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }
import "vader/types" { mk_primitive }

@test test_val_type_of_type_primitive :: fn() -> void {
    v :: val_type_of_type(mk_primitive("i32"))
    match v {
        .I32 -> {}
        _    -> assert_eq("expected I32", "")
    }
}

@test test_val_type_of_type_unknown_primitive_degrades_to_any :: fn() -> void {
    v :: val_type_of_type(mk_primitive("madeup"))
    match v {
        .Any -> {}
        _    -> assert_eq("expected Any", "")
    }
}

@test test_type_intern_key_primitive_uses_name :: fn() -> void {
    key :: type_intern_key(mk_primitive("i32"))
    assert_eq(key, "i32")
}

import "vader/diagnostics" { Position, Span }

@test test_lowered_expr_type_int_literal :: fn() -> void {
    p :: Position { .file = "<test>", .offset = 0, .line = 1, .column = 1 }
    sp :: Span { .start = p, .end = p }
    lit :: LoweredIntLit { .span = sp, .type = mk_primitive("i32"), .value = i64(42) }
    t :: lowered_expr_type(lit)
    match t {
        is PrimitiveType as prim -> assert_eq(prim.name, "i32")
        _ -> assert_eq("expected primitive", "")
    }
}

