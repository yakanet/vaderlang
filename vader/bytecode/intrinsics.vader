// vader/bytecode/intrinsics — mangled name → dedicated bytecode op.
//
// Stdlib `@intrinsic` impl members map to a dedicated bytecode op
// rather than a host-provided import — e.g. `a + b` on `i32` and
// `a.add(b)` both emit the same `i32.add` op ; the `Buffer` byte ops
// (`load_u8` / `store_u8` / `memory_copy` / `intern_string` /
// `write_string`) map to the Target-ABI memory opcodes.
//
// Expanded here as an if-cascade since Vader has no map-literal
// syntax and a per-startup `MutableMap` fill costs the same lookup
// with extra heap traffic.

module "vader/bytecode"

import "vader/resolver/symbol" { Symbol }
import "vader/types" { is_int_name, is_numeric_name, is_primitive_name }

/// True when the call's mangled name resolves to a dedicated
/// bytecode op (e.g. `std_core$i32$Add$add` → `i32.add`). Returns
/// the pre-built op to push, or `null` for non-intrinsic calls.
///
/// @param mangled  the fn's mangled name (from `MonoEntry.mangled`).
/// @return         the matching bytecode op, or `null` when no
///                 intrinsic applies — caller emits a regular `Call`.
export intrinsic_op_for_mangled :: fn(mangled: string) -> Op | null {
    // Numeric arithmetic (Add / Sub / Mul / Div) for every primitive width,
    // routed through op_select's `arith_op` / `div_op` so a method call
    // (`a.add(b)`) emits the SAME op as the operator (`a + b`) : narrow ints
    // alias onto I32*, 64-bit onto I64*, floats onto F64*, and Div is
    // unsigned-aware (U32Div / U64Div). See `primitive_arith_op`.
    arith :: primitive_arith_op(mangled)
    if arith != null { return arith }
    // Equality. `@intrinsic <T> implements Equals` synthesises bodyless `equals`
    // AND `not_equals` members. i32/i64 `equals` inline their op here ; every
    // int `equals`/`not_equals` ALSO routes through `int_equals_method` →
    // PrimIntEquals (erased map-key dispatch). The op-backed NON-int primitives
    // (f32/f64/bool/char/string) go through op_select's `cmp_eq` / `cmp_ne` —
    // the same authority the operator uses — so `.equals()` can't drift from
    // `==` (see `primitive_cmp_op`).
    if mangled == r"std_core$i32$Equals$equals" { return I32Eq {} }
    if mangled == r"std_core$i64$Equals$equals" { return I64Eq {} }
    cmp :: primitive_cmp_op(mangled)
    if cmp != null { return cmp }
    // Target ABI memory opcodes — the abstract `Buffer`'s `@intrinsic` methods
    // (`stdlib/std/core/buffer.vader`). `object_new`'s `type_id` immediate is a
    // placeholder : c-emit always tags the box with the BUFFER sentinel and the
    // VM stores it only as an opaque tag, so a constant `0` is sufficient.
    if mangled == r"std_core$usize$BufferAlloc$new_buffer"  { return ObjectNew { .type_id = 0 } }
    if mangled == r"std_core$Buffer$ByteAccess$load_u8"     { return LoadU8 {} }
    if mangled == r"std_core$Buffer$ByteAccess$store_u8"    { return StoreU8 {} }
    if mangled == r"std_core$Buffer$ByteAccess$memory_copy" { return MemoryCopy {} }
    if mangled == r"std_core$Buffer$ByteAccess$intern_string" { return BufferToString {} }
    if mangled == r"std_core$Buffer$ByteAccess$write_string" { return BufferWriteString {} }
    // Float ↔ raw-bits reinterpret (`stdlib/std/core` FloatBits / BitsFloat).
    // NOT the numeric `f64(x)` / `u64(b)` casts — these return the exact IEEE
    // bit pattern. Lower to a `union` cast in C (no runtime symbol).
    if mangled == r"std_core$f64$FloatBits$to_bits"     { return F64ToBits {} }
    if mangled == r"std_core$u64$BitsFloat$from_bits"   { return BitsToF64 {} }
    if mangled == r"std_core$f32$Float32Bits$to_bits"   { return F32ToBits {} }
    if mangled == r"std_core$u32$Bits32Float$from_bits" { return BitsToF32 {} }
    return null
}

// Add / Sub / Mul / Div for any numeric primitive, resolved through op_select's
// `arith_op` / `div_op` — the SAME authority the operator path uses, so the
// method mangle can never drift from `a + b`'s op. Covers every width (the
// narrow ints i8/i16/u8/u16/u32 + isize/usize and f32, which the explicit arms
// above never listed) ; `div_op` keeps u32/u64 division unsigned.
primitive_arith_op :: fn(mangled: string) -> Op | null {
    add :: strip_core_member(mangled, r"$Add$add")
    if add != null && is_numeric_name(add) { return arith_op(val_type_of_primitive_name(add), "add") }
    sub :: strip_core_member(mangled, r"$Sub$sub")
    if sub != null && is_numeric_name(sub) { return arith_op(val_type_of_primitive_name(sub), "sub") }
    mul :: strip_core_member(mangled, r"$Mul$mul")
    if mul != null && is_numeric_name(mul) { return arith_op(val_type_of_primitive_name(mul), "mul") }
    div :: strip_core_member(mangled, r"$Div$div")
    if div != null && is_numeric_name(div) { return div_op(val_type_of_primitive_name(div)) }
    return null
}

// Equals / NotEquals op for the op-backed NON-int primitives (f32/f64/bool/
// char/string), via op_select's `cmp_eq` / `cmp_ne` — same authority as the
// operator, so `.equals()` / `.not_equals()` can't drift from `==` / `!=`. Int
// widths return null : their Equals stays on the `int_equals_method` →
// PrimIntEquals path (erased map-key dispatch), and i32/i64 `equals` inline
// their op at the call site above.
primitive_cmp_op :: fn(mangled: string) -> Op | null {
    eq :: strip_core_member(mangled, r"$Equals$equals")
    if eq != null && is_op_eq_prim(eq) { return cmp_eq(val_type_of_primitive_name(eq)) }
    ne :: strip_core_member(mangled, r"$Equals$not_equals")
    if ne != null && is_op_eq_prim(ne) { return cmp_ne(val_type_of_primitive_name(ne)) }
    return null
}

// A non-int primitive whose equality lands on a dedicated op rather than the
// PrimIntEquals host dispatch : the floats, bool, char, string.
is_op_eq_prim :: fn(name: string) -> bool = is_primitive_name(name) && !is_int_name(name)

/// `intrinsic_op_for_mangled` keyed on a `Symbol` (the bytecode
/// emit's natural input). Symbol's `name` carries the mangled form
/// for the stdlib `@intrinsic` impl members that this dispatcher
/// recognises.
///
/// @param symbol  the call target's resolver symbol.
/// @return        the matching bytecode op, or `null` when no
///                intrinsic applies.
export intrinsic_op_for_symbol_name :: fn(symbol: Symbol) -> Op | null {
    return intrinsic_op_for_mangled(symbol.name)
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }

@test test_arms_pinned_to_manifest_grammar :: fn() -> void {
    // Every arm's key must equal what `primitive_member_mangle` builds — a
    // drift in the `$` grammar or segment order breaks this test instead of
    // silently de-opting the op back to a plain Call at emit time. Keeps the
    // fast literal cascade above, but pins all 28 arms to the one authority.
    cases :: [
        // arithmetic — every numeric width (routed through op_select)
        ["i8", "Add", "add"], ["i16", "Sub", "sub"], ["i32", "Mul", "mul"],
        ["i64", "Div", "div"], ["isize", "Add", "add"],
        ["u8", "Div", "div"], ["u16", "Mul", "mul"], ["u32", "Div", "div"],
        ["u64", "Sub", "sub"], ["usize", "Add", "add"],
        ["f32", "Add", "add"], ["f32", "Div", "div"],
        ["f64", "Add", "add"], ["f64", "Sub", "sub"], ["f64", "Mul", "mul"],
        ["f64", "Div", "div"],
        // equality (op-backed) — equals + not_equals for the non-int primitives
        ["i32", "Equals", "equals"], ["i64", "Equals", "equals"],
        ["f32", "Equals", "equals"], ["f64", "Equals", "equals"],
        ["bool", "Equals", "equals"], ["char", "Equals", "equals"],
        ["string", "Equals", "equals"],
        ["f32", "Equals", "not_equals"], ["f64", "Equals", "not_equals"],
        ["bool", "Equals", "not_equals"], ["char", "Equals", "not_equals"],
        ["string", "Equals", "not_equals"],
        ["usize", "BufferAlloc", "new_buffer"],
        ["Buffer", "ByteAccess", "load_u8"], ["Buffer", "ByteAccess", "store_u8"],
        ["Buffer", "ByteAccess", "memory_copy"], ["Buffer", "ByteAccess", "intern_string"],
        ["Buffer", "ByteAccess", "write_string"],
        ["f64", "FloatBits", "to_bits"], ["u64", "BitsFloat", "from_bits"],
        ["f32", "Float32Bits", "to_bits"], ["u32", "Bits32Float", "from_bits"],
    ]
    for c in cases {
        m :: primitive_member_mangle(c[0], c[1], c[2])
        assert(intrinsic_op_for_mangled(m) != null, "arm drifted from grammar: ${m}")
    }
}

@test test_intrinsic_op_for_mangled_i32_add :: fn() -> void {
    op :: intrinsic_op_for_mangled(r"std_core$i32$Add$add")
    match op {
        is I32Add -> {}
        _         -> assert_eq("expected I32Add", "")
    }
}

@test test_narrow_and_unsigned_arith_map_correctly :: fn() -> void {
    // Widening + unsigned-aware Div must match the operator path (op_select).
    assert(intrinsic_op_for_mangled(r"std_core$u8$Div$div") is U32Div, "u8 div → U32Div")
    assert(intrinsic_op_for_mangled(r"std_core$u64$Div$div") is U64Div, "u64 div → U64Div")
    assert(intrinsic_op_for_mangled(r"std_core$i8$Add$add") is I32Add, "i8 add → I32Add")
    assert(intrinsic_op_for_mangled(r"std_core$usize$Add$add") is I64Add, "usize add → I64Add")
    assert(intrinsic_op_for_mangled(r"std_core$f32$Mul$mul") is F64Mul, "f32 mul → F64Mul")
    assert(intrinsic_op_for_mangled(r"std_core$f32$Equals$equals") is F64Eq, "f32 equals → F64Eq")
}

@test test_intrinsic_op_for_mangled_unknown_returns_null :: fn() -> void {
    op :: intrinsic_op_for_mangled(r"std_core$Foo$Bar$baz")
    assert_eq(op is null, true)
}

@test test_intrinsic_op_for_mangled_regular_fn_returns_null :: fn() -> void {
    op :: intrinsic_op_for_mangled(r"user_module$main")
    assert_eq(op is null, true)
}
