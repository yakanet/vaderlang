// vader/bytecode/text — `.virt` text writer, the inverse of
// `vader/vm/parser.parse_virt`.
//
// First piece of the self-host bytecode emitter port (TODO §2.3 — the
// rest of `src/bytecode/` will land here over time). Mirrors the
// reference writer in `src/bytecode/text.ts:writeVir`.
//
// Output goal : `parse_virt(write_virt(m)) ≈ m` for any module produced
// by `vader/vm/builder` or `parse_virt` itself. Cross-VM exchange with
// the TypeScript pipeline is **not** a guarantee — the Vader-side
// `op.Module` doesn't track ValType info on import signatures, fn
// signatures, or data-pool element kinds, so the placeholders we emit
// for those slots only need to satisfy `parse_virt`'s much looser
// requirements (it counts commas in `(...)` and treats trailing `void`
// as the `has_return = false` signal).
//
// What's emitted, in order :
//
//   module NAME
//   type N <kind> …
//   string N "..."
//   data N <kind> hex"..."
//   import N name mangled (params) -> ret
//   impl TID TRAIT
//   export main N
//
//   fn N name (params) -> ret
//     local "_" i32
//     <op>
//     …
//   end
//
// What's NOT emitted :
//   - vtable directives : reconstructed by `parser.build_vtables` from
//     mangled fn names, never written.
//   - per-op debug annotations (`; file:line:col`) : the Vader VM
//     doesn't track source spans on ops yet.

module "vader/bytecode"

import "std/string" { byte_len, byte_at, byte_slice }
import "std/string_builder" { StringBuilder, new_builder, append }
op :: import "vader/vm"

/// Render an `op.Module` as a `.virt` text dump. The result is a single
/// trailing-newline-terminated string ; the format matches what
/// `parse_virt` consumes.
///
/// @param module  the source module.
/// @return        the textual dump.
export write_virt :: fn(module: op.Module) -> string {
    out :: new_builder()
    out.append("module main\n")

    write_types_virt(out, module.types)
    write_strings_virt(out, module.strings)
    write_data_pool(out, module.data_pool)
    write_imports_virt(out, module.imports)
    write_impls(out, module.impls)
    write_vtables(out, module.vtables)
    out.append("export main ${module.main_index}\n")

    fn_index: usize = 0
    for fn_index < module.functions.len() {
        out.append("\n")
        write_function_virt(out, module.functions[fn_index], i32(fn_index))
        fn_index += 1
    }

    return "${out}"
}

// ---------------------------------------------------------------- headers

write_types_virt :: fn(out: StringBuilder, types: op.TypeDecl[]) -> void {
    i: usize = 0
    for i < types.len() {
        out.append("type ${i} ${format_type(types[i])}\n")
        i += 1
    }
}

format_type :: fn(t: op.TypeDecl) -> string = match t {
    is op.PrimitiveType as p -> "primitive ${p.kind}"
    is op.StructType    as s -> "struct ${s.name} { ${repeat_with_commas("_:0", s.field_count)} }"
    is op.ArrayType     as a -> "array ${a.element_type_id}"
    is op.UnionType     as u -> "union ${comma_join_i32(u.variant_type_ids)}"
    is op.RefType       as r -> if r.trait_name == "" { "ref _" } else { "ref ${r.trait_name}" }
    is op.FnType        as f -> "fn (${comma_join_i32(f.parameter_type_ids)}) -> ${f.return_type_id}"
}

/// Comma-separate `count` repetitions of `token`. Empty when `count == 0`.
repeat_with_commas :: fn(token: string, count: usize) -> string {
    if count == 0 { return "" }
    out :: new_builder()
    i: usize = 0
    for i < count {
        if i > 0 { out.append(",") }
        out.append(token)
        i += 1
    }
    return "${out}"
}

comma_join_i32 :: fn(items: i32[]) -> string {
    out :: new_builder()
    i: usize = 0
    for i < items.len() {
        if i > 0 { out.append(",") }
        out.append("${items[i]}")
        i += 1
    }
    return "${out}"
}

write_strings_virt :: fn(out: StringBuilder, strings: string[]) -> void {
    i: usize = 0
    for i < strings.len() {
        out.append("string ${i} ${quote_string(strings[i])}\n")
        i += 1
    }
}

/// JSON-style quoting — wraps in `"..."`, escaping `\\`, `\"`, `\n`, `\r`,
/// `\t` and NUL (`\0`). Every other byte — including multi-byte UTF-8 — is
/// copied verbatim so the round-trip is byte-exact. The escape set matches
/// `std/string::decode_escapes` (the decoder `parser.parse_string_decl`
/// reads back through), which understands exactly `\n \t \r \" \\ \0` and is
/// byte-transparent for the rest — it has no `\u` / `\x` form.
export quote_string :: fn(value: string) -> string {
    out :: new_builder()
    out.append("\"")
    n :: value.byte_len()
    i: usize = 0
    for i < n {
        b :: value.byte_at(i)
        if      b == b'\\' { out.append("\\\\") }
        else if b == b'"'  { out.append("\\\"") }
        else if b == b'\n' { out.append("\\n") }
        else if b == b'\r' { out.append("\\r") }
        else if b == b'\t' { out.append("\\t") }
        else if b == 0     { out.append("\\0") }
        else {
            // Copy the raw byte verbatim. `byte_slice(i, i + 1)` yields the
            // single source byte unchanged ; `char(u32(b))` would instead
            // promote the byte to a codepoint and re-encode it as UTF-8,
            // double-encoding any byte ≥ 0x80 (so every non-ASCII character
            // turned into mojibake). `decode_escapes` copies it back
            // byte-transparently — mirror its own verbatim-append path.
            out.append(value.byte_slice(i, i + usize(1)))
        }
        i += 1
    }
    out.append("\"")
    return "${out}"
}

write_data_pool :: fn(out: StringBuilder, data_pool: op.ArrayVal[]) -> void {
    i: usize = 0
    for i < data_pool.len() {
        kind :: data_entry_kind(data_pool[i])
        bytes :: data_entry_bytes(kind, data_pool[i].elements)
        out.append("data ${i} ${kind} hex\"${bytes_to_hex(bytes)}\"\n")
        i += 1
    }
}

/// Infer the array-kind tag of a data-pool entry from its first
/// element's runtime tag. Empty entries default to `i32`. Lossy for
/// integer widths < 32 bits since the parser collapses them to `I32Val` —
/// the round-trip preserves bytes but may pick a wider kind than the
/// original. Brainfuck and other current users don't exercise the data
/// pool, so this is acceptable until a typed-data-pool need surfaces.
data_entry_kind :: fn(entry: op.ArrayVal) -> string {
    if entry.elements.len() == 0 { return "i32" }
    return match entry.elements[0] {
        is op.I32Val    -> "i32"
        is op.I64Val    -> "i64"
        is op.F64Val    -> "f64"
        is op.CharVal   -> "char"
        is op.BoolVal   -> "bool"
        is op.StringVal -> "i32"
        is op.StructVal -> "i32"
        is op.ArrayVal  -> "i32"
        is op.BuilderVal -> "i32"
        is op.FnVal      -> "i32"
        is op.NullVal    -> "i32"
        is op.ErrorVal   -> "i32"
        is op.TypeVal    -> "i32"
    }
}

data_entry_bytes :: fn(kind: string, elements: op.Value[]) -> u8[] {
    out: u8[] = []
    i: usize = 0
    for i < elements.len() {
        write_element_bytes(out, kind, elements[i])
        i += 1
    }
    return out
}

write_element_bytes :: fn(out: u8[], kind: string, value: op.Value) -> void {
    if kind == "i32"  { write_u32_le(out, u32(read_i32_from(value))) return }
    if kind == "i64"  { write_u64_le(out, u64(read_i64_from(value))) return }
    if kind == "char" { write_u32_le(out, u32(read_char_from(value))) return }
    if kind == "bool" { out.push(if read_bool_from(value) { u8(1) } else { u8(0) }) return }
    if kind == "f64"  { /* float bit-cast helper not yet available, emit zero */ write_u64_le(out, u64(0)) return }
}

read_i32_from :: fn(v: op.Value) -> i32 = match v {
    is op.I32Val as i -> i.value
    is op.I64Val as i -> i32(i.value)
    is op.BoolVal as b -> if b.value { 1 } else { 0 }
    is op.CharVal as c -> i32(u32(c.value))
    _                 -> 0
}

read_i64_from :: fn(v: op.Value) -> i64 = match v {
    is op.I64Val as i -> i.value
    is op.I32Val as i -> i64(i.value)
    _                 -> 0
}

read_char_from :: fn(v: op.Value) -> char = match v {
    is op.CharVal as c -> c.value
    is op.I32Val  as i -> char(u32(i.value))
    _                  -> char(u32(0))
}

read_bool_from :: fn(v: op.Value) -> bool = match v {
    is op.BoolVal as b -> b.value
    _                  -> false
}

write_u32_le :: fn(out: u8[], value: u32) -> void {
    out.push(u8(value         & u32(0xff)))
    out.push(u8((value >> 0o10) & u32(0xff)))
    out.push(u8((value >> 0o20) & u32(0xff)))
    out.push(u8((value >> 0o30) & u32(0xff)))
}

write_u64_le :: fn(out: u8[], value: u64) -> void {
    out.push(u8(value         & u64(0xff)))
    out.push(u8((value >> 0o10) & u64(0xff)))
    out.push(u8((value >> 0o20) & u64(0xff)))
    out.push(u8((value >> 0o30) & u64(0xff)))
    out.push(u8((value >> 0o40) & u64(0xff)))
    out.push(u8((value >> 0o50) & u64(0xff)))
    out.push(u8((value >> 0o60) & u64(0xff)))
    out.push(u8((value >> 0o70) & u64(0xff)))
}

HEX_DIGITS :: "0123456789abcdef"

bytes_to_hex :: fn(bytes: u8[]) -> string {
    if bytes.len() == 0 { return "" }
    out :: new_builder()
    i: usize = 0
    for i < bytes.len() {
        b :: bytes[i]
        out.append(HEX_DIGITS.byte_slice(usize(u32(b) >> 0o04), usize(u32(b) >> 0o04) + 1))
        out.append(HEX_DIGITS.byte_slice(usize(u32(b) & u32(0o17)), usize(u32(b) & u32(0o17)) + 1))
        i += 1
    }
    return "${out}"
}

write_imports_virt :: fn(out: StringBuilder, imports: op.ImportInfo[]) -> void {
    i: usize = 0
    for i < imports.len() {
        info :: imports[i]
        param_block :: repeat_with_commas("i32", info.parameter_count)
        ret_text: string = if info.has_return { "i32" } else { "void" }
        out.append("import ${i} ${info.name} ${info.mangled} (${param_block}) -> ${ret_text}\n")
        i += 1
    }
}

write_impls :: fn(out: StringBuilder, impls: op.Impl[]) -> void {
    i: usize = 0
    for i < impls.len() {
        e :: impls[i]
        out.append("impl ${e.type_id} ${e.trait_name}\n")
        i += 1
    }
}

/// Emit `vtable KEY TYPE_ID FN_INDEX` for every entry. Entries are
/// already sorted by build_vtables (key alphabetical, type_id ascending).
write_vtables :: fn(out: StringBuilder, vtables: op.Vtable[]) -> void {
    i: usize = 0
    for i < vtables.len() {
        vt :: vtables[i]
        j: usize = 0
        for j < vt.entries.len() {
            e :: vt.entries[j]
            out.append("vtable ${vt.key} ${e.type_id} ${e.function_index}\n")
            j += 1
        }
        i += 1
    }
}

// --------------------------------------------------------------- functions

/// Emit one function body — header, locals, ops, terminating `end`.
/// Resolves control-flow labels by walking ops once to assign per-pc
/// scope labels (`$L0`, `$L1`, …), then a second pass emits each line
/// with the resolved labels.
write_function_virt :: fn(out: StringBuilder, function: op.BytecodeFunction, fn_index: i32) -> void {
    param_block :: repeat_with_commas("i32", function.parameter_count)
    out.append("fn ${fn_index} ${function.name} (${param_block}) -> i32\n")

    local_index: usize = 0
    for local_index < function.local_count {
        out.append("  local _ i32\n")
        local_index += 1
    }

    labels :: assign_scope_labels(function.ops, function.jump_table)
    pc: usize = 0
    for pc < function.ops.len() {
        out.append("  ")
        write_op_line(out, function.ops[pc], labels, pc)
        out.append("\n")
        pc += 1
    }
    out.append("end\n")
}

/// Per-pc scope-label info computed in a single walk over `ops`. For
/// every control-flow op at pc :
///   - `open_label[pc]`  : the label assigned when this op opens a scope
///                          (block / loop / if / else) ; `""` otherwise.
///   - `close_label[pc]` : the label of the scope this op closes
///                          (end) ; `""` otherwise.
///   - `branch_label[pc]`: the label `br` / `br_if` targets ; `""`
///                          otherwise.
ScopeLabels :: struct {
    open_label:   string[]
    close_label:  string[]
    branch_label: string[]
}

/// Walk `ops` once, tracking a scope stack, and produce a `ScopeLabels`
/// indexed by pc. The branch-target labels are resolved by looking at
/// each `Branch` / `BranchIf`'s `jump_table[pc]` and matching it to a
/// loop's body-start pc or to the end-pc of a block/if/else scope (the
/// latter known once that scope is closed).
assign_scope_labels :: fn(ops: op.Op[], jump_table: i32[]) -> ScopeLabels {
    n :: ops.len()
    open_label: string[]   = []
    close_label: string[]  = []
    branch_label: string[] = []
    i: usize = 0
    for i < n {
        open_label.push("")
        close_label.push("")
        branch_label.push("")
        i += 1
    }

    // Active scope stack — labels and metadata for currently-open scopes.
    // Grow-only arrays + a `sp` cursor for the logical top : avoids the
    // O(depth²) allocation cost of array-rebuild on every End. Same
    // pattern as `FunctionBuilder.scope_sp` and `parser.ParserState`.
    stack_labels: string[] = []
    stack_opener_pc: i32[] = []
    stack_is_loop: bool[] = []
    sp: usize = 0
    label_counter: i32 = 0

    // Deferred branches whose target scope hasn't closed yet. Drained
    // (in-place compacted) when the matching End is seen.
    pending_branch_pc: i32[] = []
    pending_target_label: string[] = []
    pending_sp: usize = 0

    pc: usize = 0
    for pc < n {
        v :: ops[pc]
        if v is op.Block {
            label :: "\$L${label_counter}"
            label_counter += 1
            open_label[pc] = label
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), false)
            sp += 1
        } else if v is op.Loop {
            label :: "\$L${label_counter}"
            label_counter += 1
            open_label[pc] = label
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), true)
            sp += 1
        } else if v is op.If {
            label :: "\$L${label_counter}"
            label_counter += 1
            open_label[pc] = label
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), false)
            sp += 1
        } else if v is op.Else {
            // Reuse the surrounding if's label ; advance the opener_pc
            // to the else's pc so the closing End matches against it.
            open_label[pc] = stack_labels[sp - 1]
            stack_opener_pc[sp - 1] = i32(pc)
        } else if v is op.End {
            label :: stack_labels[sp - 1]
            close_label[pc] = label
            // Resolve any pending branches that named this label —
            // in-place compaction with a write cursor.
            new_psp: usize = 0
            j: usize = 0
            for j < pending_sp {
                if pending_target_label[j] == label {
                    branch_label[usize(pending_branch_pc[j])] = label
                } else {
                    pending_branch_pc[new_psp] = pending_branch_pc[j]
                    pending_target_label[new_psp] = pending_target_label[j]
                    new_psp += 1
                }
                j += 1
            }
            pending_sp = new_psp
            sp -= 1
        } else if v is op.Branch || v is op.BranchIf {
            target_pc :: jump_table[pc]
            // Loop-target : `target_pc == opener_pc + 1` of some loop on the stack.
            target_label :: find_loop_label(stack_labels, stack_opener_pc, stack_is_loop, sp, target_pc)
            if target_label == "" {
                // Block/if/else — record as pending ; the matching End
                // will fill `branch_label[pc]` then. To know which scope
                // owns this target, we use a heuristic : the *innermost*
                // non-loop scope on the stack. Same heuristic as the
                // parser uses when reading text (the bytecode emitter
                // never produces ambiguous targets).
                fallback :: top_non_loop_label(stack_labels, stack_is_loop, sp)
                if fallback != "" {
                    if pending_sp == pending_branch_pc.len() {
                        pending_branch_pc.push(i32(pc))
                        pending_target_label.push(fallback)
                    } else {
                        pending_branch_pc[pending_sp] = i32(pc)
                        pending_target_label[pending_sp] = fallback
                    }
                    pending_sp += 1
                }
            } else {
                branch_label[pc] = target_label
            }
        }
        pc += 1
    }

    return ScopeLabels {
        .open_label   = open_label,
        .close_label  = close_label,
        .branch_label = branch_label,
    }
}

push_scope_entry :: fn(stack_labels: string[], stack_opener_pc: i32[], stack_is_loop: bool[], sp: usize, label: string, opener_pc: i32, is_loop: bool) -> void {
    if sp == stack_labels.len() {
        stack_labels.push(label)
        stack_opener_pc.push(opener_pc)
        stack_is_loop.push(is_loop)
    } else {
        stack_labels[sp] = label
        stack_opener_pc[sp] = opener_pc
        stack_is_loop[sp] = is_loop
    }
}

find_loop_label :: fn(labels: string[], opener_pc: i32[], is_loop: bool[], sp: usize, target_pc: i32) -> string {
    i: i32 = i32(sp) - 1
    for i >= 0 {
        if is_loop[usize(i)] && opener_pc[usize(i)] + 1 == target_pc {
            return labels[usize(i)]
        }
        i -= 1
    }
    return ""
}

top_non_loop_label :: fn(labels: string[], is_loop: bool[], sp: usize) -> string {
    i: i32 = i32(sp) - 1
    for i >= 0 {
        if !is_loop[usize(i)] { return labels[usize(i)] }
        i -= 1
    }
    return ""
}

write_op_line :: fn(out: StringBuilder, v: op.Op, labels: ScopeLabels, pc: usize) -> void {
    // Control-flow ops carry per-pc scope labels (resolved from `labels`),
    // so they render here. Every other op delegates to the single
    // exhaustive op→text renderer `write_op` (dump.vader, same module) —
    // the canonical mnemonic table both the `.virt` writer and the
    // `--stage=bytecode` dump share. A new op without a `write_op` arm
    // trips T3013 there (its match is exhaustive, no wildcard).
    match v {
        is op.Block    -> out.append("block ${labels.open_label[pc]} void")
        is op.Loop     -> out.append("loop ${labels.open_label[pc]} void")
        is op.If       -> out.append("if ${labels.open_label[pc]} void")
        is op.End      -> out.append("end ${labels.close_label[pc]}")
        is op.Branch   -> out.append("br ${labels.branch_label[pc]}")
        is op.BranchIf -> out.append("br_if ${labels.branch_label[pc]}")
        _              -> write_op(out, v)
    }
}
