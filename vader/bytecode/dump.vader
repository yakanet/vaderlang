// vader/bytecode/dump — `BytecodeModule` → text dump.
//
// Phase 6b minimum : produces a readable summary of the module that
// surfaces every fn's name + signature + body op list. Not yet
// byte-for-byte aligned with the TS `writeVir` output ; that
// alignment ships in a follow-up commit alongside the snapshot
// regeneration (`bytecode.snapshot.virt` files will need refresh).
//
// Output shape (per fn) :
//
//     fn N name (params) -> result
//       op
//       op
//       …
//     end
//
// Headers : `module NAME`, `type N <decl>`, `string N "..."`,
// `import N name mangled (params) -> ret`, `export main N`. Data
// pool + vtables + impl table are summarised when non-empty,
// elided otherwise.

module "vader/bytecode"

import "std/string_builder" { StringBuilder, new_builder, append, append_char }
import "std/string" { as_string }

/// Render a `BytecodeModule` as a `.virt`-style text dump. The resulting
/// string carries a trailing newline ; pipe to stdout directly. This is the
/// canonical `.virt` form `parse_virt` consumes and the parity snapshots
/// compare — byte-for-byte stable.
///
/// @param module         the bytecode module to render.
/// @param entry_mangled  mangled name of the entry fn (`<mod>$main`), or `""`
///                       when none — drives the `export main N` directive.
/// @return               the textual dump.
export dump_bytecode :: fn(module: BytecodeModule, entry_mangled: string) -> string =
    dump_bytecode_impl(module, entry_mangled, false)

/// Like `dump_bytecode`, but appends a trailing `; comment` to each op that
/// carries a table index, resolving it inline (the string literal behind
/// `string.const`, the callee mangle behind `call`, the `local.field`'s
/// receiver + field name, the type name behind `ref.cast`, …).
///
/// A human/AI-facing disassembly view — **not** round-trippable through
/// `parse_virt` (the comments aren't part of the grammar), so it's gated
/// behind `dump --stage=bytecode --annotate` and never feeds the VM or the
/// parity snapshots. Every index lookup is bounds-guarded : an out-of-range
/// operand renders `<… #N out of range>` instead of trapping, so the view
/// stays usable on the very invalid bytecode it's meant to help debug.
///
/// @param module         the bytecode module to render.
/// @param entry_mangled  mangled name of the entry fn, or `""`.
/// @return               the annotated textual dump.
export dump_bytecode_annotated :: fn(module: BytecodeModule, entry_mangled: string) -> string =
    dump_bytecode_impl(module, entry_mangled, true)

dump_bytecode_impl :: fn(module: BytecodeModule, entry_mangled: string, annotate: bool) -> string {
    sb :: new_builder()
    sb.append("module ${module.name}\n")
    write_types(sb, module.types)
    write_strings(sb, module.strings)
    write_imports(sb, module.imports)
    write_impl_table(sb, module.impl_table)
    write_vtable_rows(sb, module.vtables)
    write_exports(sb, module.exports, module.functions)
    write_entry_main(sb, module.functions, entry_mangled)
    for i in 0..<module.functions.len() {
        sb.append("\n")
        write_function(sb, module, module.functions[i], i32(i), annotate)
    }
    return "${sb}"
}

write_types :: fn(sb: StringBuilder, types: BcType[]) -> void {
    for i in 0..<types.len() {
        sb.append("type ${i} ${format_bc_type(types[i])}\n")
    }
}

format_bc_type :: fn(t: BcType) -> string = match t {
    is BcPrimitive as p -> "primitive ${val_type_name(p.val)}"
    is BcStruct as s    -> "struct ${quote_ident(s.name)} { ${format_fields(s.fields)} }"
    is BcArray as a     -> "array ${a.element}"
    is BcUnion as u     -> "union ${format_variants(u.variants)}"
    is BcRef as r       -> if r.trait_name == "" { "ref _" } else { "ref ${quote_ident(r.trait_name)}" }
    is BcFn as f        -> "fn (${format_variants(f.params)}) -> ${f.return_type}"
}

/// `name:idx` joined by `,`. Matches TS `formatType` for struct fields.
format_fields :: fn(fields: BcField[]) -> string {
    sb :: new_builder()
    i: usize = 0
    for i < fields.len() {
        if i > 0 { sb.append(",") }
        sb.append("${fields[i].name}:${fields[i].type_index}")
        i += usize(1)
    }
    return "${sb}"
}

/// Type-indices joined by `,`. Used by union and fn param/return formats.
format_variants :: fn(items: i32[]) -> string {
    sb :: new_builder()
    i: usize = 0
    for i < items.len() {
        if i > 0 { sb.append(",") }
        sb.append("${items[i]}")
        i += usize(1)
    }
    return "${sb}"
}

/// Quote `s` when it contains characters outside `[A-Za-z0-9_$.]`.
/// Mirrors `src/bytecode/text.ts::quoteIdent`. The mangled-name space
/// uses `$` and `.` ; user-facing extern names can carry anything.
quote_ident :: fn(s: string) -> string {
    if is_simple_ident(s) { return s }
    return "${json_escape(s)}"
}

is_simple_ident :: fn(s: string) -> bool {
    sb :: s.bytes()
    n :: sb.len()
    if n == 0 { return false }
    i: usize = 0
    for i < n {
        b :: sb[i]
        ok := false
        if b >= 0x41_u8 && b <= 0x5A_u8 { ok = true }     // A-Z
        if b >= 0x61_u8 && b <= 0x7A_u8 { ok = true }     // a-z
        if b >= 0x30_u8 && b <= 0x39_u8 { ok = true }     // 0-9
        if b == 0x5F_u8 { ok = true }                     // _
        if b == 0x24_u8 { ok = true }                     // $
        if b == 0x2E_u8 { ok = true }                     // .
        if !ok { return false }
        i += usize(1)
    }
    return true
}

/// Minimal JSON-style string escape for the quote_ident fallback path.
/// Mirrors `JSON.stringify(s)` for the byte ranges relevant to bytecode
/// dumps (no full Unicode escape — bytecode names stay ASCII-safe in
/// practice).
json_escape :: fn(s: string) -> string {
    sb :: new_builder()
    sb.append_char('"')
    bytes :: s.bytes()
    n :: bytes.len()
    i: usize = 0
    for i < n {
        b :: bytes[i]
        if b == 0x22_u8 { sb.append("\\\"") }
        else if b == 0x5C_u8 { sb.append("\\\\") }
        else { sb.append_char(char(u32(b))) }
        i += usize(1)
    }
    sb.append_char('"')
    return "${sb}"
}

write_strings :: fn(sb: StringBuilder, strings: string[]) -> void {
    for i in 0..<strings.len() {
        sb.append("string ${i} ${quote_string(strings[i])}\n")
    }
}

write_imports :: fn(sb: StringBuilder, imports: BcImport[]) -> void {
    for i in 0..<imports.len() {
        imp :: imports[i]
        prefix :: if imp.is_extern { "extern " } else { "" }
        sb.append("import ${i} ${prefix}${imp.extern_name} ${imp.mangled_name} ")
        write_signature(sb, imp.signature)
        sb.append("\n")
    }
}

write_impl_table :: fn(sb: StringBuilder, impls: ImplEntry[]) -> void {
    for i in 0..<impls.len() {
        row :: impls[i]
        sb.append("impl ${row.struct_type_index} ${row.trait_name}\n")
    }
}

write_vtable_rows :: fn(sb: StringBuilder, vtables: VtableRow[]) -> void {
    for row in vtables {
        for e in row.entries {
            sb.append("vtable ${row.key} ${e.receiver_type_index} ${e.fn_index}\n")
        }
    }
}

// Emit `export main <index>` for the entry function, identified by its
// mangled name (`<entry-module>$main`). The textual `.virt` carries no
// `is_main` flag, so the VM's `parse_virt` recovers the entry from this
// directive — without it, it falls back to "first `$main`-suffixed fn",
// which is emission-order-dependent and picks the wrong module's `main`
// when several modules declare one (e.g. `vader_lsp$main` before
// `vader_cli$main`). `entry_mangled == ""` (no known entry) emits nothing.
write_entry_main :: fn(sb: StringBuilder, functions: BcFunction[], entry_mangled: string) -> void {
    if entry_mangled == "" { return }
    entry_idx := i32(-1)
    for i in 0..<functions.len() {
        if entry_idx < 0 && functions[i].name == entry_mangled { entry_idx = i32(i) }
    }
    if entry_idx >= 0 { sb.append("export main ${entry_idx}\n") }
}

write_exports :: fn(sb: StringBuilder, exports: BcExport[], functions: BcFunction[]) -> void {
    // Mirror TS `writeVir` (`src/bytecode/text.ts:58`) — iterate the
    // emitted exports list only, no implicit `export main`. The host
    // recognises the entry via `BcFunction.is_main`, not via an export
    // directive.
    for i in 0..<exports.len() {
        sb.append("export ${exports[i].extern_name} ${exports[i].fn_index}\n")
    }
}

write_signature :: fn(sb: StringBuilder, signature: BcSignature) -> void {
    sb.append_char('(')
    for i in 0..<signature.params.len() {
        if i > 0 { sb.append(",") }
        sb.append(val_type_name(signature.params[i]))
    }
    sb.append(") -> ")
    sb.append(val_type_name(signature.result))
}

write_function :: fn(sb: StringBuilder, module: BytecodeModule, function_decl: BcFunction, function_index: i32, annotate: bool) -> void {
    sb.append("fn ${function_index} ${function_decl.name} ")
    write_signature(sb, function_decl.signature)
    sb.append("\n")
    for i in 0..<function_decl.locals.len() {
        local :: function_decl.locals[i]
        sb.append("  local ${local.name} ${val_type_name(local.val)}\n")
    }
    write_body_with_scopes(sb, module, function_decl, annotate)
    sb.append("end\n")
}

// Walk the linear op stream and emit each line with the indent that the
// structured-control nesting demands. `if` / `block` / `loop` open a fresh
// `$L<N>` label and indent two more spaces ; `end` closes the innermost
// scope ; `else` lives at the parent indent. `br` / `br_if` rewrite their
// integer depth into the matching `$L<N>` label by walking the label
// stack from the top. Mirrors `src/bytecode/text.ts::writeBodyLines`.
write_body_with_scopes :: fn(sb: StringBuilder, module: BytecodeModule, function_decl: BcFunction, annotate: bool) -> void {
    body        :: function_decl.body
    jump_table  :: function_decl.jump_table
    locals      :: function_decl.locals
    param_count :: i32(function_decl.signature.params.len())
    // Per-active-scope stacks. Grow-only with `sp` cursor for the
    // logical top so closing a scope is a cheap decrement.
    stack_labels:    string[] = []
    stack_opener_pc: i32[]    = []
    stack_is_loop:   bool[]   = []
    sp: usize = 0
    // Pending Branch/BranchIf whose target scope hasn't closed yet
    // (block / if / else falls through to its End). Drained when the
    // matching End is seen ; `branch_target_label[pc]` carries the
    // resolved label string.
    pending_pc:    i32[]    = []
    pending_label: string[] = []
    psp: usize = 0
    // pc → resolved label string (filled lazily for Branch/BranchIf).
    branch_target_label: string[] = []
    init_label: usize = 0
    n :: body.len()
    for init_label < n { branch_target_label.push("")  init_label = init_label + 1 }

    next_label: i32 = 0
    depth: i32 = 1
    for pc in 0..<n {
        op :: body[pc]
        if op is End {
            depth = depth - 1
            label :: stack_labels[sp - 1]
            // Resolve any pending branches whose target scope is this
            // one — they branch to the End's label.
            new_psp: usize = 0
            j: usize = 0
            for j < psp {
                if pending_label[j] == label {
                    branch_target_label[usize(pending_pc[j])] = label
                } else {
                    pending_pc[new_psp]    = pending_pc[j]
                    pending_label[new_psp] = pending_label[j]
                    new_psp = new_psp + 1
                }
                j = j + 1
            }
            psp = new_psp
            sp = sp - 1
            write_indent(sb, depth)
            sb.append("end ${label}\n")
            continue
        }
        if op is Else {
            // `else` shares the parent if's label but its opener_pc
            // advances so the matching End knows where the else opened.
            stack_opener_pc[sp - 1] = i32(pc)
            write_indent(sb, depth - 1)
            sb.append("else\n")
            continue
        }
        if op is If {
            label :: "\$L${next_label}"
            next_label = next_label + 1
            write_indent(sb, depth)
            sb.append("if ${label} void\n")
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), false)
            sp = sp + 1
            depth = depth + 1
            continue
        }
        if op is Block {
            label :: "\$L${next_label}"
            next_label = next_label + 1
            write_indent(sb, depth)
            sb.append("block ${label} void\n")
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), false)
            sp = sp + 1
            depth = depth + 1
            continue
        }
        if op is Loop {
            label :: "\$L${next_label}"
            next_label = next_label + 1
            write_indent(sb, depth)
            sb.append("loop ${label} void\n")
            push_scope_entry(stack_labels, stack_opener_pc, stack_is_loop, sp, label, i32(pc), true)
            sp = sp + 1
            depth = depth + 1
            continue
        }
        if op is Branch || op is BranchIf {
            target_pc :: jump_table[pc]
            // Loop target : `opener_pc + 1` of some loop on the stack.
            target_label :: find_loop_label_local(stack_labels, stack_opener_pc, stack_is_loop, sp, target_pc)
            resolved := target_label
            if target_label == "" {
                // Block / if / else : defer to the matching End.
                fallback :: top_non_loop_label_local(stack_labels, stack_is_loop, sp)
                if fallback != "" {
                    if psp == pending_pc.len() {
                        pending_pc.push(i32(pc))
                        pending_label.push(fallback)
                    } else {
                        pending_pc[psp]    = i32(pc)
                        pending_label[psp] = fallback
                    }
                    psp = psp + 1
                    resolved = fallback
                }
            }
            write_indent(sb, depth)
            if op is BranchIf { sb.append("br_if ${resolved}\n") }
            else              { sb.append("br ${resolved}\n") }
            continue
        }
        write_indent(sb, depth)
        write_op(sb, op)
        if annotate {
            comment :: annotate_op(module, locals, param_count, op)
            if comment != "" { sb.append("   ; ${comment}") }
        }
        sb.append_char('\n')
    }
}

push_scope_entry :: fn(
    labels: string[], opener_pc: i32[], is_loop: bool[],
    sp: usize, label: string, pc: i32, loop_flag: bool,
) -> void {
    if sp == labels.len() {
        labels.push(label)
        opener_pc.push(pc)
        is_loop.push(loop_flag)
    } else {
        labels[sp]    = label
        opener_pc[sp] = pc
        is_loop[sp]   = loop_flag
    }
}

find_loop_label_local :: fn(
    labels: string[], opener_pc: i32[], is_loop: bool[], sp: usize, target_pc: i32,
) -> string {
    i: i32 = i32(sp) - 1
    for i >= 0 {
        if is_loop[usize(i)] && opener_pc[usize(i)] + 1 == target_pc {
            return labels[usize(i)]
        }
        i -= 1
    }
    return ""
}

top_non_loop_label_local :: fn(
    labels: string[], is_loop: bool[], sp: usize,
) -> string {
    i: i32 = i32(sp) - 1
    for i >= 0 {
        if !is_loop[usize(i)] { return labels[usize(i)] }
        i -= 1
    }
    return ""
}

write_indent :: fn(sb: StringBuilder, depth: i32) -> void {
    d := depth
    for d > 0 { sb.append("  ")  d = d - 1 }
}

peek_and_drop_label :: fn(stack: string[]) -> [string, string[]] {
    n :: stack.len()
    if n == 0 { return ["", stack] }
    label :: stack[n - 1]
    shrunk: string[] = []
    for i in 0..<(n - 1) { shrunk.push(stack[i]) }
    return [label, shrunk]
}

peek_label :: fn(stack: string[]) -> string {
    n :: stack.len()
    if n == 0 { return "" }
    return stack[n - 1]
}

// `br N` / `br_if N` carry a wasm-style outward depth — 0 = innermost
// enclosing scope. Translate to the label that scope opened with.
label_at_depth :: fn(stack: string[], depth: i32) -> string {
    n :: stack.len()
    idx :: i32(n) - depth - 1
    if idx < 0 || idx >= i32(n) { return "" }
    return stack[usize(idx)]
}

/// Render an op as its `.virt`-style name + operands (when any).
/// Not yet byte-for-byte aligned with the TS `writeVir` rendering ;
/// good enough for human-readable debug output of the bytecode.
convert_target_name :: fn(t: ConvertTarget) -> string = match t {
    .I32  -> "i32"
    .I64  -> "i64"
    .F64  -> "f64"
    .Char -> "char"
}

// Append an op's `.virt` mnemonic to `out` (no scope labels — control-flow
// ops render bare here ; callers that need labels handle those themselves
// and delegate the rest). A STATEMENT match, not a value-returning one : a
// value match desugars to nested if-expressions whose per-arm result is
// teed up through an `if_res` chain, which makes a 128-arm exhaustive match
// compile ~3.5x larger. Appending in place sidesteps that entirely while
// staying exhaustive (a new op with no arm trips T3013 — no `_` wildcard).
// The single canonical op→text table, shared by `dump_bytecode` and
// `vader/vm/virt_writer` (which imports this).
export write_op :: fn(out: StringBuilder, op: Op) -> void {
    match op {
        is I32Const as c            -> out.append("i32.const ${c.value}")
        is I64Const as c            -> out.append("i64.const ${c.value}")
        is F64Const as c            -> out.append("f64.const ${c.value}")
        is BoolConst as c           -> out.append("bool.const ${c.value}")
        is CharConst as c           -> out.append("char.const ${u32(c.value)}")
        is NullConst                -> out.append("null.const")
        is StringConst as s         -> out.append("string.const ${s.index}")
        is LocalGet as l            -> out.append("local.get ${l.slot}")
        is LocalSet as l            -> out.append("local.set ${l.slot}")
        is LocalTee as l            -> out.append("local.tee ${l.slot}")
        is LocalField as l          -> out.append("local.field ${l.slot} ${l.type_id} ${l.field_index}")
        is Return                   -> out.append("return")
        is ReturnLit as r           -> out.append("return.lit ${format_const_op(r.value)}")
        is Drop                     -> out.append("drop")
        is Call as c                -> out.append("call ${c.function_index}")
        is CallImport as c          -> out.append("call.import ${c.index}")
        is CallIndirect as c        -> out.append("call.indirect ${c.type_id}")
        is VirtualCall as v         -> out.append("virtual.call ${v.parameter_count} ${v.vtable_key}")
        is FnRef as f               -> out.append("fn.ref ${f.function_index} ${f.type_id}")
        is MakeClosure as m         -> out.append("make_closure ${m.function_index} ${m.env_type_id}")
        is If                       -> out.append("if")
        is Else                     -> out.append("else")
        is End                      -> out.append("end")
        is Block                    -> out.append("block")
        is Loop                     -> out.append("loop")
        is Branch                   -> out.append("br")
        is BranchIf                 -> out.append("br_if")
        is BoolNot                  -> out.append("bool.not")
        is StructNew as s           -> if s.stack { out.append("struct.new_stack ${s.type_id}") } else { out.append("struct.new ${s.type_id}") }
        is StructGet as s           -> out.append("struct.get ${s.type_id} ${s.field_index}")
        is StructSet as s           -> if s.stack { out.append("struct.set_stack ${s.type_id} ${s.field_index}") } else { out.append("struct.set ${s.type_id} ${s.field_index}") }
        is ArrayNew as a            -> out.append("array.new ${a.type_id} ${a.length}")
        is ArrayLen                 -> out.append("array.len")
        is ArrayPush as a           -> out.append("array.push ${a.type_id}")
        is ArrayGet as a            -> out.append("array.get ${a.type_id}")
        is ArraySet as a            -> out.append("array.set ${a.type_id}")
        is ArraySlice as a          -> out.append("array.slice ${a.type_id}")
        is DataConst as d           -> out.append("data.const ${d.pool_index} ${d.type_id}")
        is TypeConst as t           -> out.append("type.const ${t.type_id}")
        is TypeCheck as t           -> out.append("type_check ${t.type_id}")
        is RefCast as r             -> out.append("ref.cast ${r.type_id}")
        is Unreachable              -> out.append("unreachable")
        is Convert as c             -> out.append("${c.from_name}.to_${convert_target_name(c.target)}")
        is BuilderNew               -> out.append("intrinsic builder.new")
        is BuilderAppendStr         -> out.append("intrinsic builder.append_str")
        is BuilderAppendDisplay     -> out.append("intrinsic builder.append_display")
        is BuilderFinish            -> out.append("intrinsic builder.finish")
        is SizeOfType               -> out.append("intrinsic size_of.type")
        is I32Add                   -> out.append("i32.add")
        is I32Sub                   -> out.append("i32.sub")
        is I32Mul                   -> out.append("i32.mul")
        is I32Div                   -> out.append("i32.div")
        is I32Mod                   -> out.append("i32.rem")
        is I32Neg                   -> out.append("i32.neg")
        is I32BitNot                -> out.append("i32.bitnot")
        is I32BitAnd                -> out.append("i32.bitand")
        is I32BitOr                 -> out.append("i32.bitor")
        is I32BitXor                -> out.append("i32.bitxor")
        is I32Shl                   -> out.append("i32.shl")
        is I32Shr                   -> out.append("i32.shr")
        is I32ShrU                  -> out.append("u32.shr")
        is I32Eq                    -> out.append("i32.eq")
        is I32Ne                    -> out.append("i32.ne")
        is I32Lt                    -> out.append("i32.lt")
        is I32Le                    -> out.append("i32.le")
        is I32Gt                    -> out.append("i32.gt")
        is I32Ge                    -> out.append("i32.ge")
        is I64Add                   -> out.append("i64.add")
        is I64Sub                   -> out.append("i64.sub")
        is I64Mul                   -> out.append("i64.mul")
        is I64Div                   -> out.append("i64.div")
        is I64Mod                   -> out.append("i64.rem")
        is I64Neg                   -> out.append("i64.neg")
        is I64BitAnd                -> out.append("i64.bitand")
        is I64BitOr                 -> out.append("i64.bitor")
        is I64BitXor                -> out.append("i64.bitxor")
        is I64BitNot                -> out.append("i64.bitnot")
        is I64Shl                   -> out.append("i64.shl")
        is I64Shr                   -> out.append("i64.shr")
        is I64ShrU                  -> out.append("u64.shr")
        is I64Eq                    -> out.append("i64.eq")
        is I64Ne                    -> out.append("i64.ne")
        is I64Lt                    -> out.append("i64.lt")
        is I64Le                    -> out.append("i64.le")
        is I64Gt                    -> out.append("i64.gt")
        is I64Ge                    -> out.append("i64.ge")
        is U32Div                   -> out.append("u32.div")
        is U32Mod                   -> out.append("u32.rem")
        is U32Lt                    -> out.append("u32.lt")
        is U32Le                    -> out.append("u32.le")
        is U32Gt                    -> out.append("u32.gt")
        is U32Ge                    -> out.append("u32.ge")
        is U64Div                   -> out.append("u64.div")
        is U64Mod                   -> out.append("u64.rem")
        is U64Lt                    -> out.append("u64.lt")
        is U64Le                    -> out.append("u64.le")
        is U64Gt                    -> out.append("u64.gt")
        is U64Ge                    -> out.append("u64.ge")
        is F64Add                   -> out.append("f64.add")
        is F64Sub                   -> out.append("f64.sub")
        is F64Mul                   -> out.append("f64.mul")
        is F64Div                   -> out.append("f64.div")
        is F64Neg                   -> out.append("f64.neg")
        is F64Eq                    -> out.append("f64.eq")
        is F64Ne                    -> out.append("f64.ne")
        is F64Lt                    -> out.append("f64.lt")
        is F64Le                    -> out.append("f64.le")
        is F64Gt                    -> out.append("f64.gt")
        is F64Ge                    -> out.append("f64.ge")
        is BoolEq                   -> out.append("bool.eq")
        is BoolNe                   -> out.append("bool.ne")
        is BoolAnd                  -> out.append("bool.and")
        is BoolOr                   -> out.append("bool.or")
        is CharEq                   -> out.append("char.eq")
        is CharNe                   -> out.append("char.ne")
        is CharLt                   -> out.append("char.lt")
        is CharLe                   -> out.append("char.le")
        is CharGt                   -> out.append("char.gt")
        is CharGe                   -> out.append("char.ge")
        is StringEq                 -> out.append("string.eq")
        is StringNe                 -> out.append("string.ne")
        is StringConcat             -> out.append("string.concat")
        is StringSliceCodepoints    -> out.append("string.slice_codepoints")
        is IntToChar                -> out.append("i32.to_char")
        is CharToInt                -> out.append("char.to_i32")
        is RefEq                    -> out.append("ref.eq")
        is RefNe                    -> out.append("ref.ne")
        is DeferPush                -> out.append("defer.push")
        is DeferPopExec as d        -> out.append("defer.pop_exec ${d.count}")
        is ObjectNew as o           -> out.append("object_new ${o.type_id}")
        is LoadU8                   -> out.append("load_u8")
        is LoadI32                  -> out.append("load_i32")
        is LoadI64                  -> out.append("load_i64")
        is LoadF64                  -> out.append("load_f64")
        is StoreU8                  -> out.append("store_u8")
        is StoreI32                 -> out.append("store_i32")
        is StoreI64                 -> out.append("store_i64")
        is StoreF64                 -> out.append("store_f64")
        is LoadSlot                 -> out.append("load_slot")
        is StoreSlot                -> out.append("store_slot")
        is MemoryCopy               -> out.append("memory_copy")
    }
}

/// Render a `ConstOp` in its native text form (e.g. `i32.const 42`).
/// Used by `write_op`'s standalone const arms + its `ReturnLit` inner op.
format_const_op :: fn(c: ConstOp) -> string = match c {
    is I32Const    as v -> "i32.const ${v.value}"
    is I64Const    as v -> "i64.const ${v.value}"
    is F64Const    as v -> "f64.const ${v.value}"
    is BoolConst   as v -> "bool.const ${v.value}"
    is CharConst   as v -> "char.const ${u32(v.value)}"
    is StringConst as v -> "string.const ${v.index}"
    is NullConst        -> "null.const"
}

// ---- annotation (--annotate) ----------------------------------------------

// Resolve an op's table-index operands against the module's side tables into
// a short, human/AI-facing comment — the string literal behind
// `string.const`, the callee mangle behind `call`, the receiver+field behind
// `local.field`, the type name behind `ref.cast`, … — or `""` when the op
// carries nothing worth resolving. Appended as a trailing `; …` by
// `dump_bytecode_annotated` only ; the canonical `.virt` never sees it.
//
// An `if`-`is` chain rather than a `match` on purpose : only ~20 of `Op`'s
// ~128 variants annotate, and a value-returning match over the closed `Op`
// union would demand an arm per variant AND inflate compile time ~3.5x (same
// reason `write_op` is a statement match).
//
// MAINTAINER NOTE : this is a deliberately NON-exhaustive shadow of `write_op`.
// `write_op`'s match trips T3013 when a new `Op` variant is added ; this
// if-chain does NOT — a new index-bearing op (a `call`-like op or one with a
// `*.type_id` operand) will silently get NO annotation until mirrored here.
// Low-severity (debug-only view, off the parity / VM path), but add the arm.
//
// Every lookup is bounds-guarded via the `*_label` helpers, so the annotator
// never traps on an out-of-range index — surfacing it as `<… #N out of range>`
// is itself the signal we want when reading the invalid bytecode this view
// exists to debug.
annotate_op :: fn(module: BytecodeModule, locals: BcLocal[], param_count: i32, op: Op) -> string {
    if op is StringConst as s  { return string_label(module, s.index) }
    if op is ReturnLit as r    { if r.value is StringConst as s { return string_label(module, s.index) } return "" }
    if op is Call as c         { return fn_label(module, c.function_index) }
    if op is CallImport as c   { return import_label(module, c.index) }
    if op is LocalGet as l     { return local_label(locals, param_count, l.slot) }
    if op is LocalSet as l     { return local_label(locals, param_count, l.slot) }
    if op is LocalTee as l     { return local_label(locals, param_count, l.slot) }
    if op is LocalField as l   { return "${local_label(locals, param_count, l.slot)}.${field_label(module, l.type_id, l.field_index)}" }
    if op is StructNew as s    { return type_label(module, s.type_id) }
    if op is StructGet as s    { return "${type_label(module, s.type_id)}.${field_label(module, s.type_id, s.field_index)}" }
    if op is StructSet as s    { return "${type_label(module, s.type_id)}.${field_label(module, s.type_id, s.field_index)}" }
    if op is RefCast as r      { return "-> ${type_label(module, r.type_id)}" }
    if op is TypeConst as t    { return type_label(module, t.type_id) }
    if op is TypeCheck as t    { return type_label(module, t.type_id) }
    if op is ArrayNew as a     { return "${type_label(module, a.type_id)}[]" }
    if op is ArrayGet as a     { return "${type_label(module, a.type_id)}[]" }
    if op is ArraySet as a     { return "${type_label(module, a.type_id)}[]" }
    if op is ArrayPush as a    { return "${type_label(module, a.type_id)}[]" }
    if op is ArraySlice as a   { return "${type_label(module, a.type_id)}[]" }
    if op is CallIndirect as c { return type_label(module, c.type_id) }
    if op is FnRef as f        { return fn_label(module, f.function_index) }
    if op is MakeClosure as m  { return fn_label(module, m.function_index) }
    if op is DataConst as d    { return "pool[${d.pool_index}] : ${type_label(module, d.type_id)}" }
    if op is ObjectNew as o    { return type_label(module, o.type_id) }
    return ""
}

string_label :: fn(module: BytecodeModule, index: i32) -> string {
    if index < 0 || usize(index) >= module.strings.len() { return "<string #${index} out of range>" }
    return quote_string(module.strings[usize(index)])
}

fn_label :: fn(module: BytecodeModule, index: i32) -> string {
    if index < 0 || usize(index) >= module.functions.len() { return "<fn #${index} out of range>" }
    return module.functions[usize(index)].name
}

import_label :: fn(module: BytecodeModule, index: i32) -> string {
    if index < 0 || usize(index) >= module.imports.len() { return "<import #${index} out of range>" }
    return module.imports[usize(index)].mangled_name
}

// Slot numbering is WASM-style : slots `0..param_count` are the function's
// parameters (whose names aren't tracked in the bytecode — rendered
// `arg N`), declared locals follow at `param_count..`. `BcFunction.locals`
// holds only the declared locals, so a body slot indexes it offset by
// `param_count`.
local_label :: fn(locals: BcLocal[], param_count: i32, slot: i32) -> string {
    if slot < 0 { return "<local #${slot} out of range>" }
    if slot < param_count { return "arg ${slot}" }
    li :: usize(slot - param_count)
    if li >= locals.len() { return "<local #${slot} out of range>" }
    return locals[li].name
}

field_label :: fn(module: BytecodeModule, type_id: i32, field_index: i32) -> string {
    if type_id < 0 || usize(type_id) >= module.types.len() { return "<type #${type_id} out of range>" }
    t :: module.types[usize(type_id)]
    if t is BcStruct as s {
        if field_index < 0 || usize(field_index) >= s.fields.len() { return "<field #${field_index} out of range>" }
        return s.fields[usize(field_index)].name
    }
    return "<field #${field_index}>"
}

/// Short display name for a type-table index. Bounded against pathological
/// self-referential arrays by a recursion-depth cap.
type_label :: fn(module: BytecodeModule, type_id: i32) = type_label_at(module, type_id, 0)

type_label_at :: fn(module: BytecodeModule, type_id: i32, depth: i32) -> string {
    if depth > 6 { return "..." }
    if type_id < 0 || usize(type_id) >= module.types.len() { return "<type #${type_id} out of range>" }
    return match module.types[usize(type_id)] {
        is BcPrimitive as p -> val_type_name(p.val)
        is BcStruct    as s -> s.name
        is BcArray     as a -> "${type_label_at(module, a.element, depth + 1)}[]"
        is BcUnion          -> "union"
        is BcRef       as r -> if r.trait_name == "" { "ref" } else { "ref ${r.trait_name}" }
        is BcFn             -> "fn"
    }
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_dump_empty_module :: fn() -> void {
    types: BcType[] = []
    strings: string[] = []
    data_pool: BcDataEntry[] = []
    functions: BcFunction[] = []
    imports: BcImport[] = []
    exports: BcExport[] = []
    impl_table: ImplEntry[] = []
    vtables: VtableRow[] = []
    module :: BytecodeModule {
        .name        = "test",
        .types       = types,
        .strings     = strings,
        .data_pool   = data_pool,
        .functions   = functions,
        .imports     = imports,
        .exports     = exports,
        .impl_table  = impl_table,
        .vtables     = vtables,
    }
    out :: dump_bytecode(module, "")
    assert_eq(out, "module test\n")
}

/// JSON-style quoting — wraps in `"..."`, escaping `\\`, `\"`, `\n`, `\r`,
/// `\t` and NUL (`\0`). Every other byte — including multi-byte UTF-8 — is
/// copied verbatim so the round-trip is byte-exact. Shared by `dump_bytecode`
/// and `vader/vm/virt_writer` (which imports this). The escape set matches
/// `std/string::decode_escapes` (the decoder `virt_reader.parse_string_decl`
/// reads back through), which understands exactly `\n \t \r \" \\ \0` and is
/// byte-transparent for the rest — it has no `\u` / `\x` form.
export quote_string :: fn(value: string) -> string {
    out :: new_builder()
    out.append("\"")
    vb :: value.bytes()
    n :: vb.len()
    i: usize = 0
    for i < n {
        b :: vb[i]
        if      b == b'\\' { out.append("\\\\") }
        else if b == b'"'  { out.append("\\\"") }
        else if b == b'\n' { out.append("\\n") }
        else if b == b'\r' { out.append("\\r") }
        else if b == b'\t' { out.append("\\t") }
        else if b == 0     { out.append("\\0") }
        else {
            // Copy the raw byte verbatim — `char(u32(b))` would re-encode it
            // as UTF-8 and double-encode any byte >= 0x80.
            out.append(vb[i..<i + 1].as_string())
        }
        i += 1
    }
    out.append("\"")
    return "${out}"
}
