// vader/bytecode/intrinsic_manifest â€” single authority on the `@intrinsic`
// host-mangle grammar and host-intrinsic identity.
//
// Two related jobs, both so the host-mangle grammar lives in ONE place:
//
//   1. Primitive-member grammar. The lowerer PRODUCES impl-member mangles
//      (`<module>$<Type>$<Trait>$<method>`, `lower_impl_member.vader`); this is
//      the consumer-side authority the VM re-derivations (`vm/host`, `vm/exec`)
//      route through instead of re-encoding the `std_core$` prefix / `$`
//      separator inline. `primitive_member_mangle` + the strip helpers, pinned
//      to the real mangler by the colocated tests.
//
//   2. Host-intrinsic identity. `intrinsic_id_for` classifies a host import's
//      mangled name into an `IntrinsicId` â€” THE single classification both
//      backends (`vm/host::dispatch_import`, `c_emit/host::import_shim`) dispatch
//      on, so the two can't drift and a new host trips T3013 at both sites.
//
// Still inlined elsewhere (folding through here is a follow-up): the arith /
// buffer bytecode-op table in `intrinsics.vader` (already verify-pinned).

module "vader/bytecode"

import "std/abort" { panic }
import "std/string" { starts_with, ends_with }
import "vader/types" { is_int_name, is_primitive_name }

// Mangled module fragment for `std/core` (`mangle_module_id("std/core")`).
// Pinned against the real mangler by `test_core_module_matches_mangler`.
CORE_MODULE :: "std_core"

// Prefix + member suffixes as module-level literals so the hot recognisers do
// ZERO per-call string building (only the kind slice allocates). Pinned against
// `CORE_MODULE` + `primitive_member_mangle` by the colocated tests, so they
// can't drift from the grammar even though they're spelled out here.
CORE_PREFIX        :: r"std_core$"
EQUALS_SUFFIX      :: r"$Equals$equals"
NOT_EQUALS_SUFFIX  :: r"$Equals$not_equals"
DISPLAY_SUFFIX     :: r"$Display$to_string"

/// The mangle of a `std/core` primitive `@intrinsic` impl member:
/// `("i32", "Equals", "equals")` â†’ `"std_core$i32$Equals$equals"`. THE grammar
/// authority for building a primitive host mangle â€” never inline the `$`
/// separator or the `std_core$` prefix at a call site.
///
/// @param kind    the receiver primitive kind (`"i32"`, `"string"`, â€¦).
/// @param trait_  the trait segment (`"Equals"`, `"Display"`, â€¦).
/// @param method  the method segment (`"equals"`, `"to_string"`, â€¦).
/// @return        the fully mangled host-import name.
export primitive_member_mangle :: fn(kind: string, trait_: string, method: string) -> string =
    "${CORE_MODULE}$${kind}$${trait_}$${method}"

/// `"equals"` / `"not_equals"` when `mangled` is an integer width's bodyless
/// `@intrinsic Equals` member, else `""`. Recognises by prefix/suffix strip â€”
/// no per-call string building, so the hot map-key `key.equals(other)` path
/// stays cheap (one kind-slice allocation, matching the old byte-offset parse).
///
/// @param mangled  the host import's mangled name.
/// @return         `"equals"` / `"not_equals"` for an integer `Equals` member,
///                 `""` otherwise (`string`-Equals has its own arm upstream).
export int_equals_method :: fn(mangled: string) -> string {
    eq :: strip_core_member(mangled, EQUALS_SUFFIX)
    if eq != null && is_int_name(eq) { return "equals" }
    neq :: strip_core_member(mangled, NOT_EQUALS_SUFFIX)
    if neq != null && is_int_name(neq) { return "not_equals" }
    return ""
}

/// True iff `mangled` is a primitive `<T>$Display$to_string` host â€” one of the
/// ten integer widths, plus `f32` / `f64` / `bool` / `char` / `string`.
///
/// @param mangled  the host import's mangled name.
export is_display_to_string :: fn(mangled: string) -> bool {
    kind :: strip_core_member(mangled, DISPLAY_SUFFIX)
    return kind != null && is_primitive_name(kind) && kind != "void" && kind != "null"
}

/// Subset of `is_display_to_string` covering the unsigned widths that overflow
/// the signed `i64` carrier (`u32` / `u64` / `usize`) â€” these need the unsigned
/// reinterpret path. `u8` / `u16` fit the signed carrier losslessly.
///
/// @param mangled  the host import's mangled name.
export is_unsigned_display :: fn(mangled: string) -> bool {
    kind :: strip_core_member(mangled, DISPLAY_SUFFIX)
    return kind != null && (kind == "u32" || kind == "u64" || kind == "usize")
}

// Return the `<kind>` slice of a `std_core$<kind><suffix>` mangle, or null when
// the prefix / suffix don't match. Lengths come from the constant strings â€” no
// hand-counted byte offsets, no per-call string build (both `CORE_PREFIX` and
// `suffix` are module-level literals). Only the returned kind slice allocates.
strip_core_member :: fn(mangled: string, suffix: string) -> string | null {
    if !mangled.starts_with(CORE_PREFIX) || !mangled.ends_with(suffix) { return null }
    b :: mangled.bytes()
    return b[CORE_PREFIX.bytes().len()..<b.len() - suffix.bytes().len()].bytes_to_string()
}

// ---- host intrinsic identity ----------------------------------------------

/// Identity of a recognised host `@intrinsic` import, keyed on the mangled name
/// by `intrinsic_id_for`. THE single classification the two backends
/// (`vm/host::dispatch_import`, `c_emit/host::import_shim`) dispatch on, so the
/// host-mangle grammar lives in one place and the two can't drift. The union of
/// what either backend serves â€” a backend that doesn't serve a variant handles
/// it in a grouped fallthrough arm, but the exhaustive `match` forces that to be
/// a conscious decision (a new variant here trips T3013 at both sites).
export IntrinsicId :: enum(u8) {
    NotIntrinsic,
    // std/io
    IoWrite, IoExists, IoIsDir, IoTempDir, IoReadDir, IoReadFileBytes, IoWriteFileBytes,
    IoReadLine, IoReadStdin, IoPollStdin, IoSetStdinUnbuffered, IoCurrentExecutableLocation,
    // std/core string + bytes
    ByteLen,
    CoreBytes, CoreBytesToString, CoreStringIndexAt, CoreStringHash,
    CoreStringEquals, CoreStringNotEquals,
    // primitive members (recognised via the grammar helpers, any width)
    PrimIntEquals, PrimIntNotEquals, PrimDisplayToString,
    // std/runtime
    RuntimeCollect, RuntimeCollections, RuntimeBytesUsed, RuntimeBytesCopied,
    // std/runtime â€” cooperative async scheduler (std/async backend)
    SchedNow, SchedArm, SchedPark,
    // std/time
    TimeNowUnixMs, TimeMonotonicNs,
    // std/math â€” libm transcendentals + rounding. min/max/abs/clamp are pure
    // Vader (bodied â†’ real fns, never host imports), so they are NOT here.
    MathSqrt, MathSin, MathCos, MathTan, MathFloor, MathCeil, MathRound, MathPow,
    // std/process â€” non-blocking subprocess (backs spawn_async ; spawn = block_on)
    ProcessSpawnStart, ProcessSpawnPoll, ProcessSpawnTakeStdout, ProcessSpawnTakeStderr,
    // std/tty + std/env + std/abort
    TtyIsTty, EnvGetEnv, AbortPanic,
}

/// Classify a host import's mangled name into its `IntrinsicId`, or
/// `NotIntrinsic` when it isn't a recognised host (e.g. an `@extern` symbol or
/// a since-removed one). The primitive-member checks come first: the erased
/// map-key `key.equals` path is the hot one, and each helper bails on the first
/// `starts_with(std_core$)` for the free-function mangles below.
///
/// @param mangled  the import's mangled name (`BcImport.mangled_name`).
export intrinsic_id_for :: fn(mangled: string) -> IntrinsicId {
    eq :: int_equals_method(mangled)
    if eq == "equals"     { return .PrimIntEquals }
    if eq == "not_equals" { return .PrimIntNotEquals }
    if is_display_to_string(mangled) { return .PrimDisplayToString }

    if mangled == r"std_io$write"                        { return .IoWrite }
    if mangled == r"std_io$exists"                       { return .IoExists }
    if mangled == r"std_io$is_dir"                       { return .IoIsDir }
    if mangled == r"std_io$temp_dir"                     { return .IoTempDir }
    if mangled == r"std_io$read_dir"                     { return .IoReadDir }
    if mangled == r"std_io$read_file_bytes"              { return .IoReadFileBytes }
    if mangled == r"std_io$write_file_bytes"             { return .IoWriteFileBytes }
    if mangled == r"std_io$read_line"                    { return .IoReadLine }
    if mangled == r"std_io$read_stdin"                   { return .IoReadStdin }
    if mangled == r"std_io$poll_stdin"                   { return .IoPollStdin }
    if mangled == r"std_io$set_stdin_unbuffered"         { return .IoSetStdinUnbuffered }
    if mangled == r"std_io$current_executable_location"  { return .IoCurrentExecutableLocation }

    if mangled == r"std_core$byte_len"                   { return .ByteLen }

    if mangled == r"std_core$bytes"                      { return .CoreBytes }
    if mangled == r"std_core$bytes_to_string"            { return .CoreBytesToString }
    if mangled == primitive_member_mangle("string", "Index", "at")  { return .CoreStringIndexAt }
    if mangled == primitive_member_mangle("string", "Hash", "hash") { return .CoreStringHash }
    if mangled == r"std_core$string$Equals$equals"       { return .CoreStringEquals }
    if mangled == r"std_core$string$Equals$not_equals"   { return .CoreStringNotEquals }

    if mangled == r"std_runtime$collect"                 { return .RuntimeCollect }
    if mangled == r"std_runtime$collections"             { return .RuntimeCollections }
    if mangled == r"std_runtime$bytes_used"              { return .RuntimeBytesUsed }
    if mangled == r"std_runtime$bytes_copied"            { return .RuntimeBytesCopied }

    if mangled == r"std_runtime$sched_now"               { return .SchedNow }
    if mangled == r"std_runtime$sched_arm"               { return .SchedArm }
    if mangled == r"std_runtime$sched_park"              { return .SchedPark }

    if mangled == r"std_time$now_unix_ms"                { return .TimeNowUnixMs }
    if mangled == r"std_time$monotonic_ns"               { return .TimeMonotonicNs }

    if mangled == r"std_math$sqrt"                       { return .MathSqrt }
    if mangled == r"std_math$sin"                        { return .MathSin }
    if mangled == r"std_math$cos"                        { return .MathCos }
    if mangled == r"std_math$tan"                        { return .MathTan }
    if mangled == r"std_math$floor"                      { return .MathFloor }
    if mangled == r"std_math$ceil"                       { return .MathCeil }
    if mangled == r"std_math$round"                      { return .MathRound }
    if mangled == r"std_math$pow"                        { return .MathPow }

    if mangled == r"std_process$spawn_start"             { return .ProcessSpawnStart }
    if mangled == r"std_process$spawn_poll"              { return .ProcessSpawnPoll }
    if mangled == r"std_process$spawn_take_stdout"       { return .ProcessSpawnTakeStdout }
    if mangled == r"std_process$spawn_take_stderr"       { return .ProcessSpawnTakeStderr }

    if mangled == r"std_tty$is_tty"                      { return .TtyIsTty }
    if mangled == r"std_env$get_env"                     { return .EnvGetEnv }
    if mangled == r"std_abort$panic"                     { return .AbortPanic }
    return .NotIntrinsic
}

/// Fail loud when a bodyless `@intrinsic` host import is not wired into the
/// manifest. Called per-import at emit (`midir/emit.vader::reserve_cfg_extern`).
///
/// A non-`@extern` import whose mangle is served by NEITHER a dedicated
/// bytecode op (`intrinsic_op_for_mangled`) NOR a recognised `IntrinsicId`
/// (`intrinsic_id_for`) would lower to an unbound `call.import` and trap at
/// runtime â€” exactly the cos/tan gap the intrinsic audit surfaced. This closes
/// the host-wiring chain at compile time : bodyless âźą `@intrinsic` (T3062) âźą
/// recognised here âźą served by the VM + c_emit dispatch (T3013 on both matchs).
/// `@extern` imports resolve at link time and are exempt.
///
/// @param mangled    the import's mangled host name.
/// @param is_extern  true for `@extern` foreign symbols (exempt) ; false for
///                   `@intrinsic`-style stdlib host bindings (must be wired).
export assert_host_import_wired :: fn(mangled: string, is_extern: bool) -> void {
    if is_extern { return }
    if intrinsic_op_for_mangled(mangled) != null { return }
    if intrinsic_id_for(mangled) != .NotIntrinsic { return }
    panic("bytecode emit: bodyless `@intrinsic` host `${mangled}` is not wired into intrinsic_manifest â€” add it to `intrinsic_id_for` (+ its `vm/host.vader::dispatch_import` and `c_emit/host.vader::import_shim` arms), or give it a dedicated op in `intrinsic_op_for_mangled`")
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/lower" { mangle_module_id }

@test test_core_module_matches_mangler :: fn() -> void {
    // Pins the manifest's grammar against the real producer â€” if the module
    // mangling scheme changes, this test breaks instead of the backends silently.
    assert_eq(CORE_MODULE, mangle_module_id("std/core"))
}

@test test_grammar_constants_consistent :: fn() -> void {
    // The hoisted literals must equal what `primitive_member_mangle` builds, so
    // the perf hoist can't drift from the grammar.
    assert_eq(CORE_PREFIX, "${CORE_MODULE}$")
    assert_eq("${CORE_PREFIX}i32${EQUALS_SUFFIX}", primitive_member_mangle("i32", "Equals", "equals"))
    assert_eq("${CORE_PREFIX}u64${DISPLAY_SUFFIX}", primitive_member_mangle("u64", "Display", "to_string"))
}

@test test_primitive_member_mangle :: fn() -> void {
    assert_eq(primitive_member_mangle("i32", "Equals", "equals"), r"std_core$i32$Equals$equals")
    assert_eq(primitive_member_mangle("string", "Display", "to_string"), r"std_core$string$Display$to_string")
}

@test test_int_equals_method :: fn() -> void {
    assert_eq(int_equals_method(r"std_core$usize$Equals$not_equals"), "not_equals")
    assert_eq(int_equals_method(r"std_core$i32$Equals$equals"), "equals")
    assert_eq(int_equals_method(r"std_core$string$Equals$equals"), "")   // string â‰  int width
    assert_eq(int_equals_method(r"std_io$write"), "")                    // non-core bails on prefix
    assert_eq(int_equals_method(r"user_mod$Foo$Bar$baz"), "")
}

@test test_display_classifiers :: fn() -> void {
    assert_eq(is_display_to_string(r"std_core$char$Display$to_string"), true)
    assert_eq(is_display_to_string(r"std_core$char$Equals$equals"), false)
    assert_eq(is_unsigned_display(r"std_core$u64$Display$to_string"), true)
    assert_eq(is_unsigned_display(r"std_core$i64$Display$to_string"), false)
}

@test test_intrinsic_id_for :: fn() -> void {
    assert(intrinsic_id_for(r"std_io$write") == .IoWrite, "io write")
    assert(intrinsic_id_for(r"std_math$sqrt") == .MathSqrt, "math sqrt")
    assert(intrinsic_id_for(r"std_core$i32$Equals$equals") == .PrimIntEquals, "int equals")
    assert(intrinsic_id_for(r"std_core$u8$Display$to_string") == .PrimDisplayToString, "display")
    assert(intrinsic_id_for(r"std_core$string$Equals$equals") == .CoreStringEquals, "string equals not int")
    assert(intrinsic_id_for(r"user_mod$foo") == .NotIntrinsic, "unknown â†’ NotIntrinsic")
}
