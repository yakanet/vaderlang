// vader/bytecode/emit_ctx — per-project emit context + interning.
//
// Extracted from `emit.vader` to keep that file under the 800 LoC
// hard cap. Owns `EmitOptions` + `EmitterCtx` (the project-wide
// type / string / fn / import tables) and the two interners
// (`intern_type`, `intern_string`) every per-shape emit fn calls.

module "vader/bytecode"

import "std/collections" { MutableMap }
import "vader/types" { Type }

/// Knobs threaded through the emit. Today only `optimize` matters —
/// when true, the future peephole pass runs over each fn body.
export EmitOptions :: struct {
    optimize: bool
    /// Extra fn mangles to KEEP as roots through the dead-function prune (on
    /// top of main / `@export` / vtable targets). `vader test` passes the
    /// `@test` fn mangles here so they survive to the bytecode and can be run
    /// by name ; empty for normal builds.
    keep_mangles: string[]
}

/// Default options : peephole ON (matches TS default), no extra roots.
/// @return  a fresh `EmitOptions` with `optimize = true`.
export default_emit_options :: fn() -> EmitOptions = EmitOptions { .optimize = true, .keep_mangles = [] }

/// Per-project emit context. Built once at the top of `emit_project`,
/// threaded through every reservation + body-emit call. Carries the
/// type / string / fn / import interning tables plus the inverse
/// lookups (symbol id → fn / import index) downstream phases query.
///
/// Distinct from `EmitOptions` so the constructor stays cheap and the
/// helpers don't need an `opts` parameter when they only touch the
/// shared state.
export EmitterCtx :: struct {
    /// Type table being built. Index 0 is reserved for the `null`
    /// primitive so unboxed nulls have a well-defined tag at runtime
    /// (matches `VADER_BOX_TAG_NULL = 0` in `runtime/c/vader.h`).
    types: BcType[]
    /// `type_intern_key(t)` → index into `types`. Pre-loaded with
    /// `"null"` at index 0 by `new_emitter_ctx`.
    type_key: MutableMap<string, i32>

    /// String literal pool. Deduplicated by content via `string_key`.
    strings: string[]
    /// `string content` → index into `strings`.
    string_key: MutableMap<string, i32>

    /// Function table. Each entry mirrors a top-level `LoweredFnDecl`
    /// (regular fns) ; `is_extern`-flagged decls route to `imports`
    /// instead.
    functions: BcFunction[]
    /// `MonoEntry.symbol.id` → index into `functions`. Lets call sites
    /// resolve target fn slots through the symbol id rather than the
    /// mangled name.
    function_index_by_symbol_id: MutableMap<i32, i32>

    /// Mangled fn name → index into `functions`. Generic-instance call
    /// sites resolve by mangle : multiple instances of one generic share
    /// the generic's `symbol.id`, so `function_index_by_symbol_id` can't
    /// distinguish them — the per-instance mangle can.
    function_index_by_mangle: MutableMap<string, i32>

    /// Host-side import table (`@extern` user decls + stdlib
    /// `@intrinsic` shims). Each entry's `signature` mirrors what the
    /// host expects at the C-ABI boundary.
    imports: BcImport[]
    /// `MonoEntry.symbol.id` → index into `imports`. Same role as
    /// `function_index_by_symbol_id` for the import side.
    import_index_by_symbol_id: MutableMap<i32, i32>
    /// Import mangled-name → index into `imports`. Lets a call whose
    /// callee carries only a mangle (synthetic `id = 0`, e.g. an
    /// intrinsic impl-member call surfaced as a bodyless extern) resolve
    /// to a `CallImport`. Mirror of `function_index_by_mangle` for imports.
    import_index_by_mangle: MutableMap<string, i32>

    /// `@export` decls — exposed to the host linker. C-emit's `main`
    /// shim consults this to pick the program entry point.
    exports: BcExport[]

    /// Type indices that aren't directly referenced by any op or fn
    /// signature but must survive `prune_unused_types`, and that aren't
    /// scoped to a single function (the vtable-receiver pins from the
    /// midir Pass-4 prune setup, already gated on used vtable keys).
    /// Per-call arg/result pins live in `pinned_types_by_fn` instead.
    pinned_types: i32[]

    /// Per-function arg/result type pins, keyed by fn index. Each Call's
    /// arg + dst static types (which TS carries on `op.argTypeIndices`)
    /// are pinned here under the emitting function, so `prune_unused_types`
    /// roots them only for SURVIVING functions — when a function is
    /// pruned, its pins drop with it (matching TS, where the roots live on
    /// the op). A global list would keep dead types (and the impl rows /
    /// monomorphised `Range` types they anchor) alive in every program.
    /// `prune_unused_functions` re-keys this by the post-prune index.
    pinned_types_by_fn: MutableMap<i32, i32[]>
}

/// Construct a fresh `EmitterCtx`. Reserves type-table slot 0 for the
/// `null` primitive (runtime depends on the tag invariant).
///
/// @return  a fresh emitter context ready for `emit_project` to fill.
export new_emitter_ctx :: fn() -> EmitterCtx {
    types: BcType[] = []
    types.push(BcPrimitive { .val = ValType.Null })
    type_key :: MutableMap<string, i32> {}
    type_key["null"] = 0
    return EmitterCtx {
        .types                       = types,
        .type_key                    = type_key,
        .strings                     = [],
        .string_key                  = MutableMap<string, i32> {},
        .functions                   = [],
        .function_index_by_symbol_id = MutableMap<i32, i32> {},
        .function_index_by_mangle    = MutableMap<string, i32> {},
        .imports                     = [],
        .import_index_by_symbol_id   = MutableMap<i32, i32> {},
        .import_index_by_mangle      = MutableMap<string, i32> {},
        .exports                     = [],
        .pinned_types                = [],
        .pinned_types_by_fn          = MutableMap<i32, i32[]> {},
    }
}

/// Intern a `Type` into the module-wide type table, returning its
/// index. Idempotent : repeat calls with structurally-equal types
/// return the same index.
///
/// Primitive types take a fast path keyed on the primitive name (a
/// short interned string the typechecker already passes around), so
/// the common `i32` / `string` / `bool` cases skip the
/// `display_type` allocation entirely. Composite types fall back to
/// the `display_type` key — conservative but stable across the
/// pipeline.
///
/// @param t    the type to intern.
/// @param ctx  the emit context — its `types` + `type_key` get mutated.
/// @return     the type table index.
export intern_type :: fn(t: Type, ctx: EmitterCtx) -> i32 {
    key :: type_intern_key(t)
    existing :: ctx.type_key[key]
    if existing is i32 { return existing }
    // Reserve placeholder so recursive / self types don't loop.
    // Matches `src/bytecode/emit.ts::internType:356-360` exactly :
    // push a `BcRef { trait_name = null }` first, register the index,
    // then overwrite with the proper translation. The placeholder is
    // visible to any nested `intern_type` call that re-enters with the
    // same key.
    new_index :: i32(ctx.types.len())
    placeholder: BcType = BcRef { .trait_name = "" }
    ctx.types.push(placeholder)
    ctx.type_key[key] = new_index
    ctx.types[usize(new_index)] = bc_type_of_with_ctx(t, ctx, new_index)
    return new_index
}

/// Intern a string literal into the module-wide pool. Returns the
/// pool index. Like `intern_type`, idempotent on identical content.
///
/// @param s    the string to intern.
/// @param ctx  the emit context.
/// @return     the pool index.
export intern_string :: fn(s: string, ctx: EmitterCtx) -> i32 {
    existing :: ctx.string_key[s]
    if existing is i32 { return existing }
    new_index :: i32(ctx.strings.len())
    ctx.strings.push(s)
    ctx.string_key[s] = new_index
    return new_index
}

/// Intern a synthetic `$Cell<T>` struct type whose only field is
/// `value: T`. Closure-cell construction / read / write all read this
/// type-index off the `$Cell` slot rather than allocating a one-element
/// array (the earlier shortcut). Idempotent : repeat calls with the
/// same `slot_type` return the same index.
///
/// Keyed under `$Cell<<slot-intern-key>>` so the cache is independent
/// of `intern_type`'s keying (the inner `value` field shares its key
/// with the slot type's regular interning).
///
/// @param slot_type  the captured local's type.
/// @param ctx        the emit context.
/// @return           the type-table index of the `$Cell<T>` struct.
export intern_cell_type :: fn(slot_type: Type, ctx: EmitterCtx) -> i32 {
    slot_index :: intern_type(slot_type, ctx)
    key :: "\$Cell<${type_intern_key(slot_type)}>"
    existing :: ctx.type_key[key]
    if existing is i32 { return existing }
    new_index :: i32(ctx.types.len())
    field :: BcField { .name = "value", .type_index = slot_index }
    fields: BcField[] = []
    fields.push(field)
    // Name keys on the inner type's intern key, not the (volatile) post-
    // DCE slot — so a closure capturing the same T always materialises
    // with the same `$Cell_<T>` name across re-emits and across the TS /
    // Vader pipelines. The slot id approach froze whatever slot the cell
    // happened to land in before DCE remapped it.
    ctx.types.push(BcStruct {
        .name      = "\$Cell_${type_intern_key(slot_type)}",
        .fields    = fields,
        .symbol_id = -1,
    })
    ctx.type_key[key] = new_index
    return new_index
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }
import "vader/types" { mk_primitive }

@test test_new_emitter_ctx_reserves_null_slot :: fn() -> void {
    ctx :: new_emitter_ctx()
    assert_eq(ctx.types.len(), 1)
    null_idx :: ctx.type_key["null"]
    match null_idx {
        is i32 as i -> assert_eq(i, 0)
        _ -> assert_eq("null missing", "")
    }
}

@test test_intern_type_idempotent :: fn() -> void {
    ctx :: new_emitter_ctx()
    a :: intern_type(mk_primitive("i32"), ctx)
    b :: intern_type(mk_primitive("i32"), ctx)
    assert_eq(a, b)
}

@test test_intern_type_distinct_primitives_get_distinct_indices :: fn() -> void {
    ctx :: new_emitter_ctx()
    i32_idx :: intern_type(mk_primitive("i32"), ctx)
    str_idx :: intern_type(mk_primitive("string"), ctx)
    if i32_idx == str_idx { assert_eq("indices should differ", "") }
}

@test test_intern_string_idempotent :: fn() -> void {
    ctx :: new_emitter_ctx()
    a :: intern_string("hello", ctx)
    b :: intern_string("hello", ctx)
    assert_eq(a, b)
}

@test test_intern_string_distinct_strings_get_distinct_indices :: fn() -> void {
    ctx :: new_emitter_ctx()
    a :: intern_string("hello", ctx)
    b :: intern_string("world", ctx)
    if a == b { assert_eq("indices should differ", "") }
}

@test test_default_emit_options :: fn() -> void {
    opts :: default_emit_options()
    assert_eq(opts.optimize, true)
}
