// vader/bytecode/op_select ã `LoweredBinaryOp` / `LoweredUnaryOp`
// ã concrete `Op` variant.
//
// Mirrors `binaryOpFor` / unary handling in `src/bytecode/emit.ts`.
// Per-shape emit fns in `emit_body.vader` call `binary_op_for` /
// `unary_op_for` to pick the right typed op once both operands are
// on the stack.
//
// Width-aliasing : narrow integer widths (`i8`, `i16`, `i32`, `u8`,
// `u16`, `u32`) collapse onto the `I32X` op family ; the wider
// 64-bit widths (`i64`, `u64`, `isize`, `usize`) use `I64X`. The
// VM aliases every integer width to `I32Val` / `I64Val` accordingly
// (see `op.vader` comments on the I32 / I64 op blocks).
//
// Unsigned ops : when the comparison or division would mis-sign on
// the I32 / I64 path (e.g. SHA-256 round constants with the high bit
// set divide negative under signed I32Div), the U32X / U64X variants
// take over. Same width-aliasing rule : narrow unsigned widths use
// U32X, 64-bit unsigned widths use U64X.
//
// `and` / `or` : the lowerer explodes short-circuit binaries into
// if/else, so `binary_op_for` returning `BoolAnd` / `BoolOr` is the
// eager-eval safety net (no short-circuit guarantee here ã diagnose
// at the lower-side if a non-exploded And/Or reaches this fn).

module "vader/bytecode"

import "vader/lower" {
    LoweredBinaryOp, LoweredUnaryOp,
}

/// Pick the bytecode op for a `LoweredBinaryOp` over operands of class
/// `lhs`. `add` over `string` collapses to `StringConcat` ; `eq` /
/// `neq` over reference shapes (`ref` / `any`) reuse the i32 compare
/// since both sides hold the boxed pointer tag.
///
/// @param op   the source-level binary operator.
/// @param lhs  the operand stack class (both operands share it after
///             typecheck-time numeric promotions).
/// @return     the concrete op to push.
export binary_op_for :: fn(op: LoweredBinaryOp, lhs: ValType) -> Op = match op {
    .Add    -> arith_add(lhs)
    .Sub    -> arith_op(lhs, "sub")
    .Mul    -> arith_op(lhs, "mul")
    .Div    -> div_op(lhs)
    .Mod    -> mod_op(lhs)
    .Shl    -> shl_op(lhs)
    .Shr    -> shr_op(lhs)
    .BitAnd -> bit_op(lhs, "and")
    .BitOr  -> bit_op(lhs, "or")
    .BitXor -> bit_op(lhs, "xor")
    .And    -> BoolAnd {}
    .Or     -> BoolOr {}
    .Eq     -> cmp_eq(lhs)
    .Neq    -> cmp_ne(lhs)
    .Lt     -> cmp_lt(lhs)
    .Lte    -> cmp_le(lhs)
    .Gt     -> cmp_gt(lhs)
    .Gte    -> cmp_ge(lhs)
}

/// Pick the bytecode op for a `LoweredUnaryOp` over an operand of
/// class `operand`. `Not` always resolves to `BoolNot` (the lowerer
/// guarantees a bool-typed operand) ; `Neg` / `BitNot` route through
/// the integer / float family helpers.
///
/// @param op       the source-level unary operator.
/// @param operand  the operand stack class.
/// @return         the concrete op to push.
export unary_op_for :: fn(op: LoweredUnaryOp, operand: ValType) -> Op = match op {
    .Neg    -> neg_op(operand)
    .Not    -> BoolNot {}
    .BitNot -> bitnot_op(operand)
}

// ---- arithmetic ----------------------------------------------------------

arith_add :: fn(lhs: ValType) -> Op {
    if lhs == ValType.String { return StringConcat {} }
    return arith_op(lhs, "add")
}

// Generic arith dispatcher : picks the I32 / I64 / F64 family based on
// width-aliasing, then maps the `op` token to the concrete variant.
arith_op :: fn(lhs: ValType, op: string) -> Op {
    if is_float_val(lhs) {
        if op == "add" { return F64Add {} }
        if op == "sub" { return F64Sub {} }
        if op == "mul" { return F64Mul {} }
        return F64Div {}
    }
    if is_64_bit_int_val(lhs) {
        if op == "add" { return I64Add {} }
        if op == "sub" { return I64Sub {} }
        if op == "mul" { return I64Mul {} }
        return I64Div {}
    }
    if op == "add" { return I32Add {} }
    if op == "sub" { return I32Sub {} }
    if op == "mul" { return I32Mul {} }
    return I32Div {}
}

// Division is unsigned-aware : u32 / u64 widths route through `U32Div`
// / `U64Div` so values with the high bit set don't divide as negative.
div_op :: fn(lhs: ValType) -> Op {
    if is_u64_class(lhs) { return U64Div {} }
    if is_u32_class(lhs) { return U32Div {} }
    return arith_op(lhs, "div")
}

mod_op :: fn(lhs: ValType) -> Op {
    if is_u64_class(lhs) { return U64Mod {} }
    if is_u32_class(lhs) { return U32Mod {} }
    if is_64_bit_int_val(lhs) { return I64Mod {} }
    return I32Mod {}
}

// ---- bitwise -------------------------------------------------------------

bit_op :: fn(lhs: ValType, op: string) -> Op {
    if is_64_bit_int_val(lhs) {
        if op == "and" { return I64BitAnd {} }
        if op == "or"  { return I64BitOr {} }
        return I64BitXor {}
    }
    if op == "and" { return I32BitAnd {} }
    if op == "or"  { return I32BitOr {} }
    return I32BitXor {}
}

shl_op :: fn(lhs: ValType) -> Op {
    if is_64_bit_int_val(lhs) { return I64Shl {} }
    return I32Shl {}
}

// Unsigned `shr` is a logical (zero-filling) shift ; signed `shr` is
// arithmetic (sign-extending). The VM distinguishes via the I32Shr /
// I32ShrU op pair (resp. I64Shr / I64ShrU).
shr_op :: fn(lhs: ValType) -> Op {
    unsigned :: is_unsigned_val(lhs)
    if is_64_bit_int_val(lhs) {
        if unsigned { return I64ShrU {} }
        return I64Shr {}
    }
    if unsigned { return I32ShrU {} }
    return I32Shr {}
}

// ---- comparisons ---------------------------------------------------------

cmp_eq :: fn(lhs: ValType) -> Op {
    if lhs == ValType.Bool   { return BoolEq {} }
    if lhs == ValType.Char   { return CharEq {} }
    if lhs == ValType.String { return StringEq {} }
    if is_float_val(lhs)     { return F64Eq {} }
    if is_64_bit_int_val(lhs) { return I64Eq {} }
    // ref / any / null all fall through to the i32 compare ã the boxed
    // pointer identity bits fit a 32-bit word and compare correctly.
    return I32Eq {}
}

cmp_ne :: fn(lhs: ValType) -> Op {
    if lhs == ValType.Bool   { return BoolNe {} }
    if lhs == ValType.Char   { return CharNe {} }
    if lhs == ValType.String { return StringNe {} }
    if is_float_val(lhs)     { return F64Ne {} }
    if is_64_bit_int_val(lhs) { return I64Ne {} }
    return I32Ne {}
}

cmp_lt :: fn(lhs: ValType) -> Op {
    if is_float_val(lhs) { return F64Lt {} }
    if is_u64_class(lhs) { return U64Lt {} }
    if is_u32_class(lhs) { return U32Lt {} }
    if is_64_bit_int_val(lhs) { return I64Lt {} }
    return I32Lt {}
}

cmp_le :: fn(lhs: ValType) -> Op {
    if is_float_val(lhs) { return F64Le {} }
    if is_u64_class(lhs) { return U64Le {} }
    if is_u32_class(lhs) { return U32Le {} }
    if is_64_bit_int_val(lhs) { return I64Le {} }
    return I32Le {}
}

cmp_gt :: fn(lhs: ValType) -> Op {
    if is_float_val(lhs) { return F64Gt {} }
    if is_u64_class(lhs) { return U64Gt {} }
    if is_u32_class(lhs) { return U32Gt {} }
    if is_64_bit_int_val(lhs) { return I64Gt {} }
    return I32Gt {}
}

cmp_ge :: fn(lhs: ValType) -> Op {
    if is_float_val(lhs) { return F64Ge {} }
    if is_u64_class(lhs) { return U64Ge {} }
    if is_u32_class(lhs) { return U32Ge {} }
    if is_64_bit_int_val(lhs) { return I64Ge {} }
    return I32Ge {}
}

// ---- unary ---------------------------------------------------------------

neg_op :: fn(operand: ValType) -> Op {
    if is_float_val(operand)     { return F64Neg {} }
    if is_64_bit_int_val(operand) { return I64Neg {} }
    return I32Neg {}
}

bitnot_op :: fn(operand: ValType) -> Op {
    if is_64_bit_int_val(operand) { return I64BitNot {} }
    return I32BitNot {}
}

// ---- array slot access (Target ABI S5) -----------------------------------

/// Native storage class of an array element ã the single dimension the slot
/// load / store ops dispatch on. `Boxed` is a GC-traced `vader_box_t` slot ;
/// the rest are the element's native byte width (matching
/// `vader_array_element_size`, `vader.h`).
SlotWidth :: enum(u8) { U8, I32, I64, F64, Boxed }

/// Classify an array element's value class into its slot storage width. This
/// is the ONE place the element-kind ã storage-width mapping lives ; both
/// `slot_store_op_for` and `slot_load_op_for` read it. The width is the native
/// byte width ã NOT the arithmetic width-aliasing of `arith_op` (storage cares
/// about the byte width, compute doesn't) ã so the slot-index û stride
/// addressing stays consistent with the reused two-object array layout (D5/D3
/// Option öÝ).
///
/// Returns `null` for element widths without a dedicated opcode yet: `i16`/`u16`
/// (need a 2-byte slot op) and `f32` (needs a 4-byte float slot op ã a 4-byte
/// integer store would mis-type the operand-stack value). The lowerer must not
/// route those element kinds onto the Vader array path until the op lands ;
/// every kind the compiler's own arrays use (`i32`/`i64`/`usize`/`string`/
/// struct/`u8`) is covered.
///
/// @param elem  the array's concrete element value class (from the materialised
///              impl body's element type ã primitives stay concrete per
///              `keep_primitive_or_erase`, so this is never `Any`-erased for a
///              primitive-element array).
/// @return      the storage width, or `null` for a not-yet-supported element.
slot_width_for :: fn(elem: ValType) -> SlotWidth | null = match elem {
    .I8     -> .U8
    .U8     -> .U8
    .Bool   -> .U8
    .I16    -> null
    .U16    -> null
    .I32    -> .I32
    .U32    -> .I32
    .Char   -> .I32
    .F32    -> null
    .I64    -> .I64
    .U64    -> .I64
    .Isize  -> .I64
    .Usize  -> .I64
    .F64    -> .F64
    .String -> .Boxed
    .Null   -> .Boxed
    .Void   -> .Boxed
    .Ref    -> .Boxed
    .Any    -> .Boxed
}

/// Pick the store op for an array element of stack class `elem` (Target ABI S5,
/// Array-over-Buffer). `Boxed` ã `StoreSlot`, which fires the generational write
/// barrier ; primitive widths ã the native-width typed store (no barrier).
/// Delegates the element classification to `slot_width_for`.
///
/// @param elem  the array's concrete element value class.
/// @return      the store op, or `null` for a not-yet-supported element width.
export slot_store_op_for :: fn(elem: ValType) -> Op | null {
    w :: slot_width_for(elem)
    if w == null { return null }
    return match w {
        .U8    -> StoreSlotU8 {}
        .I32   -> StoreSlotI32 {}
        .I64   -> StoreSlotI64 {}
        .F64   -> StoreSlotF64 {}
        .Boxed -> StoreSlot {}
    }
}

/// Symmetric `Load*` op for an array element of stack class `elem` ã same
/// classification as `slot_store_op_for` (via `slot_width_for`), the boxed
/// load traces no barrier (read-only).
///
/// @param elem  the array's concrete element value class.
/// @return      the load op, or `null` for a not-yet-supported element width.
export slot_load_op_for :: fn(elem: ValType) -> Op | null {
    w :: slot_width_for(elem)
    if w == null { return null }
    return match w {
        .U8    -> LoadSlotU8 {}
        .I32   -> LoadSlotI32 {}
        .I64   -> LoadSlotI64 {}
        .F64   -> LoadSlotF64 {}
        .Boxed -> LoadSlot {}
    }
}

/// True when element class `elem` is eligible for the S5 typed-slot access flip
/// (Solution A) ã only the raw-primitive widths `I32`/`I64`/`F64`. Everything
/// else stays on the legacy runtime-dispatched `ArrayGet`/`ArraySet` :
///   - `.Boxed` (ref / string / `Any`) ã an erased `Any[]` struct field may hold
///     a concrete-kind array, so only the kind-dispatched legacy op is sound.
///   - `.U8` ã `const u8[]` byte views are borrowed (`buf == NULL`, atom-backed),
///     which the raw slot op can't address.
///   - sub-word i16/u16/f32 ã no slot opcode yet (`slot_width_for` ã null).
///
/// The single home for the flip policy ; `typed_slot_load_op_for` /
/// `typed_slot_store_op_for` delegate the op shape to `slot_load_op_for` /
/// `slot_store_op_for` and only gate on this.
slot_typed_flippable :: fn(elem: ValType) -> bool {
    w :: slot_width_for(elem)
    if w == null { return false }
    return match w {
        .I32   -> true
        .I64   -> true
        .F64   -> true
        .U8    -> false
        .Boxed -> false
    }
}

/// Slot LOAD op for the S5 access flip ã the typed op when the element is a
/// flippable concrete primitive (`slot_typed_flippable`), else `null` to fall
/// back to the legacy `ArrayGet`.
///
/// @param elem  the array's concrete element value class (the static read type).
/// @return      a typed `LoadSlot*` op, or `null` to fall back to `ArrayGet`.
export typed_slot_load_op_for :: fn(elem: ValType) -> Op | null =
    if slot_typed_flippable(elem) { slot_load_op_for(elem) } else { null }

/// Symmetric typed slot STORE op for the S5 access flip ã typed when flippable,
/// else `null` to fall back to the legacy `ArraySet`.
///
/// @param elem  the array's concrete element value class.
/// @return      a typed `StoreSlot*` op, or `null` to fall back to `ArraySet`.
export typed_slot_store_op_for :: fn(elem: ValType) -> Op | null =
    if slot_typed_flippable(elem) { slot_store_op_for(elem) } else { null }

// ---- tests ---------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_add_i32 :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Add, ValType.I32)
    if op is I32Add { return }
    assert_eq("expected I32Add", "")
}

@test test_add_i64 :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Add, ValType.I64)
    if op is I64Add { return }
    assert_eq("expected I64Add", "")
}

@test test_add_string_collapses_to_concat :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Add, ValType.String)
    if op is StringConcat { return }
    assert_eq("expected StringConcat", "")
}

@test test_div_unsigned_uses_u32div :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Div, ValType.U32)
    if op is U32Div { return }
    assert_eq("expected U32Div", "")
}

@test test_lt_float_uses_f64lt :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Lt, ValType.F64)
    if op is F64Lt { return }
    assert_eq("expected F64Lt", "")
}

@test test_eq_bool_uses_booleq :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Eq, ValType.Bool)
    if op is BoolEq { return }
    assert_eq("expected BoolEq", "")
}

@test test_neg_f64 :: fn() -> void {
    op :: unary_op_for(LoweredUnaryOp.Neg, ValType.F64)
    if op is F64Neg { return }
    assert_eq("expected F64Neg", "")
}

@test test_not_bool :: fn() -> void {
    op :: unary_op_for(LoweredUnaryOp.Not, ValType.Bool)
    if op is BoolNot { return }
    assert_eq("expected BoolNot", "")
}

@test test_bitnot_i64 :: fn() -> void {
    op :: unary_op_for(LoweredUnaryOp.BitNot, ValType.I64)
    if op is I64BitNot { return }
    assert_eq("expected I64BitNot", "")
}

@test test_shr_unsigned_uses_logical_shift :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Shr, ValType.U32)
    if op is I32ShrU { return }
    assert_eq("expected I32ShrU", "")
}

@test test_shr_signed_uses_arithmetic_shift :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Shr, ValType.I32)
    if op is I32Shr { return }
    assert_eq("expected I32Shr", "")
}

@test test_mod_u64_uses_unsigned :: fn() -> void {
    op :: binary_op_for(LoweredBinaryOp.Mod, ValType.U64)
    if op is U64Mod { return }
    assert_eq("expected U64Mod", "")
}

@test test_slot_store_boxed_uses_store_slot :: fn() -> void {
    op :: slot_store_op_for(ValType.String)
    if op is StoreSlot { return }
    assert_eq("expected StoreSlot for string", "")
}

@test test_slot_store_ref_uses_store_slot :: fn() -> void {
    op :: slot_store_op_for(ValType.Ref)
    if op is StoreSlot { return }
    assert_eq("expected StoreSlot for ref", "")
}

@test test_slot_store_i32_native_width :: fn() -> void {
    op :: slot_store_op_for(ValType.I32)
    if op is StoreSlotI32 { return }
    assert_eq("expected StoreSlotI32 for i32", "")
}

@test test_slot_store_i64_and_usize :: fn() -> void {
    op_i64 :: slot_store_op_for(ValType.I64)
    if !(op_i64 is StoreSlotI64) { assert_eq("expected StoreSlotI64 for i64", "") }
    op_usize :: slot_store_op_for(ValType.Usize)
    if op_usize is StoreSlotI64 { return }
    assert_eq("expected StoreSlotI64 for usize", "")
}

@test test_slot_store_f64_uses_store_f64 :: fn() -> void {
    op :: slot_store_op_for(ValType.F64)
    if op is StoreSlotF64 { return }
    assert_eq("expected StoreSlotF64 for f64", "")
}

@test test_slot_store_u8_bool_native_width :: fn() -> void {
    op_u8 :: slot_store_op_for(ValType.U8)
    if !(op_u8 is StoreSlotU8) { assert_eq("expected StoreSlotU8 for u8", "") }
    op_bool :: slot_store_op_for(ValType.Bool)
    if op_bool is StoreSlotU8 { return }
    assert_eq("expected StoreSlotU8 for bool", "")
}

// `i16` / `u16` / `f32` slots have no dedicated opcode yet ã the selector
// returns null so the lowerer keeps those element kinds off the Vader path.
@test test_slot_store_deferred_widths_are_null :: fn() -> void {
    if slot_store_op_for(ValType.I16) != null { assert_eq("expected null for i16", "") }
    if slot_store_op_for(ValType.U16) != null { assert_eq("expected null for u16", "") }
    if slot_store_op_for(ValType.F32) != null { assert_eq("expected null for f32", "") }
}

@test test_slot_load_mirrors_store :: fn() -> void {
    if !(slot_load_op_for(ValType.Any) is LoadSlot) { assert_eq("expected LoadSlot for any", "") }
    if !(slot_load_op_for(ValType.I32) is LoadSlotI32) { assert_eq("expected LoadSlotI32 for i32", "") }
    if !(slot_load_op_for(ValType.F64) is LoadSlotF64) { assert_eq("expected LoadSlotF64 for f64", "") }
    if slot_load_op_for(ValType.F32) != null { assert_eq("expected null for f32", "") }
}
