// vader/c_emit/body — per-function C emit machinery + shared name/type
// helpers used across the C-emit pipeline.
//
// Mirror of `src/c_emit/body.ts` (the `cTypeFor*` / `sanitise` /
// `boxExpr` / `unboxExpr` / `signatureFor` family) plus the per-op /
// per-fn body walker. Phase 2 of the port lands the shared helpers ;
// later phases will fill in `emit_function_body` (per-op emit, label
// table, structured control, B1 prologue / epilogue, …).
//
// Two categories of public helpers :
//
//   1. C identifier / literal escaping :
//        - `sanitise` — replace non-ident chars with `_`, suffix with
//                       `_v` when the result collides with a C keyword.
//        - `c_string_lit` — quote-wrap a string with `\x` escapes for
//                           any byte outside printable ASCII.
//
//   2. `BcType` / `ValType` → C type mapping :
//        - `c_type_for_val_bare` — primitive `ValType` → C type
//                                  (`int32_t`, `vader_string_t`, …).
//        - `c_type_for` — `BcType` → C type ; heap shapes collapse to
//                         `vader_box_t`.
//        - `val_type_of_bc_type` — stack-erased classifier (every heap
//                                  shape lands in `Ref`).
//        - `struct_c_name` — `vader_struct_<sanitised>_t` ; the canonical
//                            C type name for a `BcStruct` slot.

module "vader/c_emit"

import "std/string_builder" { StringBuilder, new_builder, append, append_char }
import "std/numbers" { is_hex_digit }
import "vader/bytecode" {
    BcType, BcPrimitive, BcStruct, BcArray, BcUnion, BcRef, BcFn,
    ValType, ArrayKind,
}

// =========================================================================
// C identifier sanitation
// =========================================================================

/// Replace every non-`[A-Za-z0-9_]` byte in `raw` with `_`. Then, if the
/// result collides with a C11 (or common-extension) keyword, suffix it
/// with `_v` so the emitted C is always valid. Mirrors `sanitise` in
/// `src/c_emit/emit.ts:1033`.
///
/// @param raw  the mangled name from the bytecode (`std_core_i32_Add_add` etc.).
/// @return     a safe C identifier.
export sanitise :: fn(raw: string) -> string {
    sb :: new_builder()
    rawb :: raw.bytes()
    n :: rawb.len()
    i: usize = 0
    for i < n {
        b :: rawb[i]
        if is_ident_byte(b) {
            sb.append_char(char(u32(b)))
        } else {
            sb.append_char('_')
        }
        i += 1
    }
    out :: "${sb}"
    if is_c_reserved(out) {
        return "${out}_v"
    }
    return out
}

/// Predicate matching `[A-Za-z0-9_]`. Bytes outside this class are
/// replaced with `_` by `sanitise`.
is_ident_byte :: fn(b: u8) -> bool {
    if b >= 0x41 && b <= 0x5A { return true }     // A-Z
    if b >= 0x61 && b <= 0x7A { return true }     // a-z
    if b >= 0x30 && b <= 0x39 { return true }     // 0-9
    if b == 0x5F { return true }                     // _
    return false
}

/// C11 reserved words plus a few extensions (`restrict`, `_Atomic`,
/// `_Static_assert`, …) the TS side guards against. Names that collide
/// get `_v` appended.
is_c_reserved :: fn(name: string) -> bool {
    if name == "auto" { return true }
    if name == "break" { return true }
    if name == "case" { return true }
    if name == "char" { return true }
    if name == "const" { return true }
    if name == "continue" { return true }
    if name == "default" { return true }
    if name == "do" { return true }
    if name == "double" { return true }
    if name == "else" { return true }
    if name == "enum" { return true }
    if name == "extern" { return true }
    if name == "float" { return true }
    if name == "for" { return true }
    if name == "goto" { return true }
    if name == "if" { return true }
    if name == "inline" { return true }
    if name == "int" { return true }
    if name == "long" { return true }
    if name == "register" { return true }
    if name == "restrict" { return true }
    if name == "return" { return true }
    if name == "short" { return true }
    if name == "signed" { return true }
    if name == "sizeof" { return true }
    if name == "static" { return true }
    if name == "struct" { return true }
    if name == "switch" { return true }
    if name == "typedef" { return true }
    if name == "union" { return true }
    if name == "unsigned" { return true }
    if name == "void" { return true }
    if name == "volatile" { return true }
    if name == "while" { return true }
    if name == "_Alignas" { return true }
    if name == "_Alignof" { return true }
    if name == "_Atomic" { return true }
    if name == "_Bool" { return true }
    if name == "_Complex" { return true }
    if name == "_Generic" { return true }
    if name == "_Imaginary" { return true }
    if name == "_Noreturn" { return true }
    if name == "_Static_assert" { return true }
    if name == "_Thread_local" { return true }
    return false
}

// =========================================================================
// C string literal escaping
// =========================================================================

/// Quote-wrap `s` with C string-literal escapes — `\\`, `\"`, `\n`,
/// `\r`, `\t` for the printable specials, `\x<hh>` for everything
/// outside printable ASCII. Lower-case hex digits, matching the TS
/// reference's `b.toString(16)`.
///
/// Special case : when a `\x<hh>` escape is followed by a byte that
/// happens to be a hex digit (or a UTF-8 continuation byte), the
/// reader would extend the escape with those digits. We close the
/// escape with an empty `""` quote-pair so the digits start a fresh
/// literal piece.
///
/// @param s  the UTF-8 source string.
/// @return   a C source-text string literal, including the surrounding
///           double quotes.
export c_string_lit :: fn(s: string) -> string {
    sb :: new_builder()
    sb.append_char('"')
    sbytes :: s.bytes()
    n :: sbytes.len()
    i: usize = 0
    for i < n {
        b :: sbytes[i]
        if b == '\\' {
            sb.append("\\\\")
        } else if b == '"' {
            sb.append("\\\"")
        } else if b == '\n' {
            sb.append("\\n")
        } else if b == '\r' {
            sb.append("\\r")
        } else if b == '\t' {
            sb.append("\\t")
        } else if b < 0x20 || b >= 0x7F {
            // `\x<hh>` escape — two-digit lowercase hex appended directly to
            // the outer builder (avoids a per-byte StringBuilder allocation).
            sb.append("\\x")
            sb.append_char(hex_digit_lower(u32(b) >> 4))
            sb.append_char(hex_digit_lower(u32(b) & 0xF))
            // Close the escape so a following hex digit doesn't extend it.
            next_idx :: i + 1
            if next_idx < n {
                next_b :: sbytes[next_idx]
                if is_hex_digit(char(u32(next_b))) {
                    sb.append("\"\"")
                }
            }
        } else {
            sb.append_char(char(u32(b)))
        }
        i += 1
    }
    sb.append_char('"')
    return "${sb}"
}

/// Lower-case hex digit for a value `0..15`. Values out of range
/// fall through to `'0'` — caller validates.
hex_digit_lower :: fn(n: u32) -> char {
    if n <= 9 {
        return char(u32('0') + n)
    }
    return char(u32('a') + n - 10)
}

// =========================================================================
// ValType → C type mapping
// =========================================================================

/// Primitive `ValType` → bare C type spelling. `null` lands in
/// `vader_box_t` because the runtime null is the box variant whose
/// tag identifies it ; `ref` / `any` also collapse to `vader_box_t`.
///
/// Mirrors `cTypeForValBare` in `src/c_emit/body.ts:794`.
///
/// @param v  the stack-machine value class.
/// @return   the C type spelling used at locals, signature slots,
///           struct-field positions.
export c_type_for_val_bare :: fn(v: ValType) -> string = match v {
    .I8 -> "int8_t"
    .I16 -> "int16_t"
    .I32 -> "int32_t"
    .I64 -> "int64_t"
    .U8 -> "uint8_t"
    .U16 -> "uint16_t"
    .U32 -> "uint32_t"
    .U64 -> "uint64_t"
    .Usize -> "size_t"
    .Isize -> "ptrdiff_t"
    .F32 -> "float"
    .F64 -> "double"
    .Bool -> "bool"
    .Char -> "uint32_t"
    .String -> "vader_string_t"
    .Null -> "vader_box_t"
    .Void -> "void"
    .Ref -> "vader_box_t"
    .Any -> "vader_box_t"
}

/// C expression unboxing `name` (a `vader_box_t`) to `target`'s storage —
/// the per-class payload accessor (`.payload.i` for every integer / char,
/// `.payload.f` for floats, `.payload.b` / `.payload.s` for bool / string).
/// `null` / `ref` / `any` pass through (already a box). Mirrors `unboxExpr`
/// in `src/c_emit/body.ts`.
///
/// @param name    the C name of the `vader_box_t` to unbox.
/// @param target  the destination stack value class.
/// @return        a C expression of `target`'s storage type.
export unbox_expr :: fn(name: string, target: ValType) -> string = match target {
    .I8    -> "((int8_t) ${name}.payload.i)"
    .I16   -> "((int16_t) ${name}.payload.i)"
    .I32   -> "((int32_t) ${name}.payload.i)"
    .I64   -> "((int64_t) ${name}.payload.i)"
    .U8    -> "((uint8_t) ${name}.payload.i)"
    .U16   -> "((uint16_t) ${name}.payload.i)"
    .U32   -> "((uint32_t) ${name}.payload.i)"
    .U64   -> "((uint64_t) ${name}.payload.i)"
    .Usize -> "((size_t) ${name}.payload.i)"
    .Isize -> "((ptrdiff_t) ${name}.payload.i)"
    .Char  -> "((uint32_t) ${name}.payload.i)"
    .F32   -> "((float) ${name}.payload.f)"
    .F64   -> "((double) ${name}.payload.f)"
    .Bool  -> "${name}.payload.b"
    .String -> "${name}.payload.s"
    .Null  -> name
    .Void  -> "((void) 0)"
    .Ref   -> name
    .Any   -> name
}

/// C expression boxing `name` (a `val`-typed value) into a `vader_box_t`
/// tagged `type_index` — the inverse of `unbox_expr`. Each width routes to
/// the matching `vader_box_<class>` runtime constructor (unsigned widths
/// re-cast through the signed payload slot). `null` / `ref` / `any` pass
/// through (already boxed) ; `void` boxes to the empty box. Mirrors
/// `boxExpr` in `src/c_emit/body.ts`.
///
/// @param name        the C name / expression of the value to box.
/// @param val         its stack value class.
/// @param type_index  the BcType tag to stamp on the box (the value's own
///                    type, NOT the enclosing container's).
/// @return            a C expression of type `vader_box_t`.
export box_expr :: fn(name: string, val: ValType, type_index: i32) -> string = match val {
    .I8    -> "vader_box_i32(${type_index}u, ${name})"
    .I16   -> "vader_box_i32(${type_index}u, ${name})"
    .I32   -> "vader_box_i32(${type_index}u, ${name})"
    .U8    -> "vader_box_i32(${type_index}u, (int32_t)(uint32_t) ${name})"
    .U16   -> "vader_box_i32(${type_index}u, (int32_t)(uint32_t) ${name})"
    .U32   -> "vader_box_i32(${type_index}u, (int32_t)(uint32_t) ${name})"
    .I64   -> "vader_box_i64(${type_index}u, ${name})"
    .Isize -> "vader_box_i64(${type_index}u, (int64_t) ${name})"
    .U64   -> "vader_box_i64(${type_index}u, (int64_t)(uint64_t) ${name})"
    .Usize -> "vader_box_i64(${type_index}u, (int64_t)(uint64_t) ${name})"
    .F32   -> "vader_box_f64(${type_index}u, (double) ${name})"
    .F64   -> "vader_box_f64(${type_index}u, ${name})"
    .Bool  -> "vader_box_bool(${type_index}u, ${name})"
    .Char  -> "vader_box_i32(${type_index}u, (int32_t) ${name})"
    .String -> "vader_box_string(${type_index}u, ${name})"
    .Null  -> name
    .Void  -> "vader_box_null()"
    .Ref   -> name
    .Any   -> name
}

/// BcType index of the primitive whose stack class is `val`, or `0` when no
/// such primitive is materialised in the type table. Used to tag a box when
/// the call site has no explicit target type-index (`box_expr_unknown`). A
/// missing primitive falls back to tag 0 — the receiver's `type_check` simply
/// misses, exactly as TS. Mirrors the `primitiveTagOf` map in
/// `src/c_emit/emit.ts`.
///
/// @param types  the module type table.
/// @param val    the primitive stack class to find a tag for.
/// @return       the BcType index, or `0` if absent.
export primitive_tag_of :: fn(types: BcType[], val: ValType) -> i32 {
    for i in 0..<types.len() {
        t :: types[i]
        if t is BcPrimitive as p {
            if p.val == val { return i32(i) }
        }
    }
    return 0
}

/// Box `name` to a `vader_box_t` without an explicit target type-index — the
/// tag is the primitive's own BcType index (`primitive_tag_of`). Used by
/// `coerce_expr` when widening a primitive into a `ref` / `any` slot (fn-arg
/// boxing, dispatcher result wrapping). Mirrors `boxExprUnknown` in
/// `src/c_emit/body.ts`.
export box_expr_unknown :: fn(types: BcType[], name: string, val: ValType) -> string =
    box_expr(name, val, primitive_tag_of(types, val))

/// Mangled-name prefix up to the first `__` byte pair occurring *after* the
/// last `$` — the type-arg separator the lowerer emits for monomorphised
/// generics (`std_collections$Entry__i32__i32` → `std_collections$Entry`).
/// A non-generic struct (no such `__`) returns `""` to signal "no sibling
/// family". Mirrors `prefix_before_double_underscore` in
/// `vader/vm/value.vader` — the VM's erasure-aware `type_check` uses the same
/// grouping so a runtime sibling shape (`Entry(i32,i32)`) matches a static
/// erased one (`Entry(Any,Any)`).
export prefix_before_double_underscore :: fn(s: string) -> string {
    sb :: s.bytes()
    n :: sb.len()
    if n < 2 { return "" }
    last_dollar: i32 = -1
    for i in 0..<n {
        if sb[i] == '$' { last_dollar = i32(i) }
    }
    start: usize = if last_dollar < 0 { 0 } else { usize(last_dollar) + 1 }
    j: usize = start
    for j + 1 < n {
        if sb[j] == '_' && sb[j + 1] == '_' {
            return sb[0..<j].bytes_to_string()
        }
        j += 1
    }
    return ""
}

/// True when the type at `type_index` is exactly the primitive of class
/// `slot_val` — the compile-time answer for `type_check` on a primitively-
/// typed value (no runtime tag to inspect). Mirrors `primitiveMatchesType`
/// in `src/c_emit/body.ts`.
export primitive_matches_type :: fn(types: BcType[], slot_val: ValType, type_index: i32) -> bool {
    t :: types[usize(type_index)]
    if t is BcPrimitive as p { return p.val == slot_val }
    return false
}

/// C expression coercing `name` from stack class `from` to `to`. Identity
/// when equal or both boxed ; boxes a primitive into a `ref` / `any` slot ;
/// unboxes a box into a primitive ; otherwise a double-cast (through `from`
/// first, matching `emit_convert`). Mirrors `coerceExpr` in
/// `src/c_emit/body.ts` — B1 nullable-ref slots are deferred to T12.
///
/// @param types  the module type table (for the box tag).
/// @param name   the C name / expression to coerce.
/// @param from   its current stack class.
/// @param to     the destination stack class.
/// @return       a C expression of `to`'s storage type.
export coerce_expr :: fn(types: BcType[], name: string, from: ValType, to: ValType) -> string {
    if from == to { return name }
    if is_ref_val(to) && is_ref_val(from) { return name }
    if is_ref_val(to) { return box_expr_unknown(types, name, from) }
    if is_ref_val(from) { return unbox_expr(name, to) }
    return "(${c_type_for_val_bare(to)}) (${c_type_for_val_bare(from)}) ${name}"
}

/// Coerce a binary / unary OPERAND to the op's class `to`. Only a boxed
/// operand (an erased `any` / `ref` flowing into a primitive op) is converted
/// — it is unboxed via `coerce_expr`. A primitively-typed operand is left
/// verbatim : the op's typed C operator drives any width / signedness
/// conversion implicitly (and re-casting it would add noise without changing
/// behaviour). Used by `push_binop` / `push_cmp` / `push_unop` / `push_eager`.
export coerce_operand :: fn(types: BcType[], name: string, from: ValType, to: ValType) -> string {
    if is_ref_val(from) { return coerce_expr(types, name, from, to) }
    return name
}

/// `BcType` → C type. Heap shapes (struct, array, union, ref, fn)
/// collapse to `vader_box_t` ; primitives delegate to
/// `c_type_for_val_bare`.
///
/// Mirrors `cTypeFor` in `src/c_emit/body.ts:839`.
///
/// @param t  the bytecode type-table entry.
/// @return   the C type spelling for slots of this type.
export c_type_for :: fn(t: BcType) -> string = match t {
    is BcPrimitive as p -> c_type_for_val_bare(p.val)
    is BcStruct -> "vader_box_t"
    is BcArray -> "vader_box_t"
    is BcUnion -> "vader_box_t"
    is BcRef -> "vader_box_t"
    is BcFn -> "vader_box_t"
}

/// Stack-machine value class for a `BcType`. Every heap shape lands in
/// `Ref` ; the value stack itself only ever carries `Ref` slots for
/// these. Mirrors `valTypeOfBcType` in `src/c_emit/body.ts:826`.
///
/// @param t  the bytecode type-table entry.
/// @return   the stack-machine value class — primitive name for
///           `BcPrimitive`, `Ref` for every heap shape.
export val_type_of_bc_type :: fn(t: BcType) -> ValType = match t {
    is BcPrimitive as p -> p.val
    is BcStruct -> ValType.Ref
    is BcArray -> ValType.Ref
    is BcUnion -> ValType.Ref
    is BcRef -> ValType.Ref
    is BcFn -> ValType.Ref
}

/// True for the boxed value classes (`ref` / `any`) — both collapse to
/// `vader_box_t` storage and are GC roots. Mirrors `isRefVal` in
/// `src/c_emit/body.ts`.
export is_ref_val :: fn(v: ValType) -> bool = v == ValType.Ref || v == ValType.Any

/// Stack value class of the field / slot whose `BcType` lives at
/// `type_index` in `types`. Mirrors `valTypeOfField` in
/// `src/c_emit/body.ts` — the field-store / field-read / arg paths use it
/// to spell the C-storage type of a struct field.
export val_type_of_field :: fn(types: BcType[], type_index: i32) -> ValType =
    val_type_of_bc_type(types[usize(type_index)])

/// Canonical C identifier for a `BcStruct` slot. Format matches the TS
/// emit's `vader_struct_<sanitised>_t` so the runtime `vader.h` shim
/// and any hand-written debug printer can spot the type by name.
///
/// @param name  the source-level struct name (post-monomorphization mangle).
/// @return      the C `typedef` identifier, e.g. `vader_struct_Pair_t`.
export struct_c_name :: fn(name: string) -> string {
    return "vader_struct_${sanitise(name)}_t"
}

// =========================================================================
// ArrayKind → C type mapping
// =========================================================================

/// Native C type for a primitive array slot. `Boxed` is invalid here —
/// boxed arrays don't hit the per-kind storage path. Mirrors
/// `cTypeForArrayKind` in `src/c_emit/emit.ts:387`.
///
/// @param k  the array element storage discriminator.
/// @return   the C type spelling for one slot of this kind.
export c_type_for_array_kind :: fn(k: ArrayKind) -> string = match k {
    .U8 -> "uint8_t"
    .U16 -> "uint16_t"
    .U32 -> "uint32_t"
    .U64 -> "uint64_t"
    .I8 -> "int8_t"
    .I16 -> "int16_t"
    .I32 -> "int32_t"
    .I64 -> "int64_t"
    .F32 -> "float"
    .F64 -> "double"
    .Char -> "uint32_t"
    .Bool -> "bool"
    .Boxed -> "vader_box_t"
}
