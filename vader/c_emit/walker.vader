// vader/c_emit/walker — bytecode function-body → C walker.
//
// The per-op emission core of the C emitter : `emit_functions` drives one
// C definition per `BcFunction` ; `emit_function_body` walks the op stream
// against a `FnState` (see `stack.vader`) assembling
// signature → local decls → temp decls → body ; `emit_op` is the
// exhaustive per-op dispatch. Split out of `emit.vader` (which keeps the
// driver + section emitters) per the plan's file decomposition. Same
// module (`vader/c_emit`), so `EmitCtx`, `signature_for`, the `stack.vader`
// model, and the `body.vader` helpers are all in scope without imports.

module "vader/c_emit"

import "std/string" { join }
import "std/string_builder" { StringBuilder, append }
import "std/abort" { todo }
import "vader/bytecode" { BcFunction, BcSignature, BcStruct, BcArray, BcFn, BcRef, BcUnion, BcType, ValType }
import "vader/bytecode" { array_kind_of, array_kind_index, ArrayKind }
// The opcode union pulls in ~120 names ; the namespace form keeps the
// import to one line and tags every op site as `vm.<Op>` at the match.
vm :: import "vader/bytecode"

/// Per-fn body emit — one C function definition per `BcFunction`,
/// separated by a blank line (matching TS `emitFunctions`).
///
/// T0 scope : the constant-return path is emitted ; `emit_op` is already
/// the exhaustive dispatch (every not-yet-ported op calls `todo`). The
/// StackVal model + real per-op bodies land tranche by tranche (T1+).
///
/// T1 note : this walker block (`emit_functions` / `emit_function_body` /
/// `emit_op` / `const_lit_c` + the literal helpers / `signature_for`)
/// moves to `walker.vader` (+ `stack.vader` for the StackVal model) per
/// the plan's file decomposition — do not relocate it into `body.vader`.
///
/// TS reference : `emitFunctions` in `src/c_emit/body.ts`.
emit_functions :: fn(ctx: EmitCtx, out: StringBuilder) -> void {
    fns :: ctx.module.functions
    for i in 0..<fns.len() {
        emit_function_body(ctx, i32(i), fns[i], out)
        out.append("\n")
    }
}

// ---- may-alloc analysis ---------------------------------------------------

/// Callgraph analysis : which fns may trigger a GC allocation
/// (transitively). Drives the `no_frame` decision — a fn outside this set
/// skips the shadow-stack prologue (`inc(x) = x + 1`, accessors,
/// predicates, stack-only struct builders). Direct allocators are the
/// heap `struct.new`, array ops, string concat, the builder family,
/// `make_closure`, and the conservative indirect callers (`call.import` /
/// `call.indirect` / `virtual.call`) ; transitive via any direct `call` to
/// a fn already in the set. Mirrors `computeMayAlloc` in
/// `src/c_emit/emit.ts`.
compute_may_alloc :: fn(fns: BcFunction[]) -> i32[] {
    may_alloc: i32[] = []
    for fi in 0..<fns.len() {
        if fn_has_direct_alloc(fns[fi]) { may_alloc.push(i32(fi)) }
    }
    changed := true
    for changed {
        changed = false
        for fi in 0..<fns.len() {
            if i32(fi) in may_alloc { continue }
            if fn_calls_may_alloc(fns[fi], may_alloc) {
                may_alloc.push(i32(fi))
                changed = true
            }
        }
    }
    return may_alloc
}

/// True when `fn_decl` contains an op that allocates on the GC heap.
fn_has_direct_alloc :: fn(fn_decl: BcFunction) -> bool {
    for i in 0..<fn_decl.body.len() {
        if op_allocates(fn_decl.body[i]) { return true }
    }
    return false
}

/// True when `fn_decl` makes a direct `call` to a fn already known to
/// may-alloc — the transitive propagation step.
fn_calls_may_alloc :: fn(fn_decl: BcFunction, may_alloc: i32[]) -> bool {
    for i in 0..<fn_decl.body.len() {
        op :: fn_decl.body[i]
        if op is vm.Call as c {
            if c.function_index in may_alloc { return true }
        }
    }
    return false
}

/// True for ops that allocate a fresh GC object. `struct.new_stack`
/// (`stack = true`) does NOT — it lands on the C stack. Indirect callers
/// are conservatively included (unknown target). Open-domain filter over
/// a few variants → an `if`-chain, not an exhaustive `match`.
// Drop resolve-CSE cache entries the op invalidates — see `FnState.resolved_arrays`.
// Called before every op is emitted.
invalidate_resolve_cache :: fn(s: FnState, op: vm.Op) -> void {
    if op is vm.LocalSet as ls {
        drop_resolved_for_local(s, ls.slot)
        return
    }
    if op is vm.LocalTee as lt {
        drop_resolved_for_local(s, lt.slot)
        return
    }
    if !is_cache_safe(op) { s.resolved_arrays.clear() }
}

// True when the op provably cannot move/realloc an array buffer, trigger a GC, or
// end the straight-line region the cached `_slotarr` C temps are scoped to — so
// the resolve cache survives it. DEFAULT-DENY : anything NOT listed clears the
// cache. A missing pure op only costs CSE coverage (under-optimised) ; trusting an
// allow-list of *dangerous* ops would turn a missing alloc/call op (e.g. the
// GC-moving `array.slice`) into a stale-pointer use-after-free. New pure value ops
// just get added here. `LocalSet` / `LocalTee` never reach this — they invalidate
// precisely upstream. Slot stores stay safe : a write never reallocs.
is_cache_safe :: fn(op: vm.Op) -> bool {
    if op is vm.LocalGet | vm.LocalField | vm.StructGet { return true }
    if op is vm.LoadSlot | vm.LoadSlotU8 | vm.LoadSlotI32 | vm.LoadSlotI64 | vm.LoadSlotF64 { return true }
    if op is vm.StoreSlot | vm.StoreSlotU8 | vm.StoreSlotI32 | vm.StoreSlotI64 | vm.StoreSlotF64 { return true }
    if op is vm.ArrayGet | vm.ArraySet | vm.ArrayLen { return true }
    if op is vm.LoadI32 | vm.LoadI64 | vm.LoadF64 | vm.LoadU8 { return true }
    if op is vm.StoreI32 | vm.StoreI64 | vm.StoreF64 | vm.StoreU8 { return true }
    if op is vm.I32Const | vm.I64Const | vm.F64Const | vm.BoolConst | vm.CharConst { return true }
    if op is vm.NullConst | vm.StringConst | vm.DataConst | vm.TypeConst | vm.SizeOfType | vm.FnRef { return true }
    if op is vm.I32Add | vm.I32Sub | vm.I32Mul | vm.I32Div | vm.I32Mod | vm.I32Neg { return true }
    if op is vm.I64Add | vm.I64Sub | vm.I64Mul | vm.I64Div | vm.I64Mod | vm.I64Neg { return true }
    if op is vm.F64Add | vm.F64Sub | vm.F64Mul | vm.F64Div | vm.F64Neg { return true }
    if op is vm.U32Div | vm.U32Mod | vm.U64Div | vm.U64Mod { return true }
    if op is vm.I32BitAnd | vm.I32BitOr | vm.I32BitXor | vm.I32BitNot | vm.I32Shl | vm.I32Shr | vm.I32ShrU { return true }
    if op is vm.I64BitAnd | vm.I64BitOr | vm.I64BitXor | vm.I64BitNot | vm.I64Shl | vm.I64Shr | vm.I64ShrU { return true }
    if op is vm.I32Eq | vm.I32Ne | vm.I32Lt | vm.I32Le | vm.I32Gt | vm.I32Ge { return true }
    if op is vm.I64Eq | vm.I64Ne | vm.I64Lt | vm.I64Le | vm.I64Gt | vm.I64Ge { return true }
    if op is vm.F64Eq | vm.F64Ne | vm.F64Lt | vm.F64Le | vm.F64Gt | vm.F64Ge { return true }
    if op is vm.U32Lt | vm.U32Le | vm.U32Gt | vm.U32Ge | vm.U64Lt | vm.U64Le | vm.U64Gt | vm.U64Ge { return true }
    if op is vm.BoolEq | vm.BoolNe | vm.CharEq | vm.CharNe | vm.CharLt | vm.CharLe | vm.CharGt | vm.CharGe { return true }
    if op is vm.StringEq | vm.StringNe | vm.RefEq | vm.RefNe { return true }
    if op is vm.BoolAnd | vm.BoolOr | vm.BoolNot { return true }
    if op is vm.Convert | vm.IntToChar | vm.CharToInt | vm.BitsToF32 | vm.BitsToF64 | vm.F32ToBits | vm.F64ToBits | vm.RefCast { return true }
    if op is vm.Drop { return true }
    return false
}

// Drop cache entries whose array C-expr names local `l<slot>` — it was just
// reassigned, so any `_slotarr` resolved from its old value is stale. The `.`
// after the index keeps `l1.` from matching `l10.…`.
drop_resolved_for_local :: fn(s: FnState, slot: i32) -> void {
    needle :: "l${slot}."
    kept :: MutableMap<string, string> {}
    for [k, v] in s.resolved_arrays {
        if !(needle in k) { kept[k] = v }
    }
    s.resolved_arrays = kept
}

op_allocates :: fn(op: vm.Op) -> bool {
    if op is vm.StructNew as sn { return !sn.stack }
    if op is vm.ObjectNew { return true }
    if op is vm.ArrayNew { return true }
    if op is vm.ArrayPush { return true }
    if op is vm.ArrayRepeat { return true }
    if op is vm.ArrayPushAll { return true }
    if op is vm.StringSliceCodepoints { return true }
    if op is vm.BufferToString { return true }
    if op is vm.MakeClosure { return true }
    if op is vm.CallImport { return true }
    if op is vm.CallIndirect { return true }
    if op is vm.VirtualCall { return true }
    return false
}

/// One C function definition : `static <sig> { <body> }`. Walks the
/// bytecode body op by op, emitting a deduped `#line` directive (debug
/// builds only) before each op whose source position differs from the
/// previous one.
///
/// T0 scope : only `return.lit` / bare `return` op bodies are emitted ;
/// the full StackVal walker (locals, calls, control flow, …) is T1+.
emit_function_body :: fn(ctx: EmitCtx, fn_index: i32, function: BcFunction, out: StringBuilder) -> void {
    no_frame :: !(fn_index in ctx.may_alloc)
    out.append("static ${signature_for(function)} {\n")

    // Walk the body into a separate buffer first : temps are discovered
    // during the walk (materialisation), and their declarations belong in
    // the prelude *above* the body. After the walk, assemble
    // signature → local decls → temp decls → frame → body, matching TS
    // (which splices the prelude in at `preludePos`).
    body :: StringBuilder {}
    s :: new_fn_state(ctx, function, body)
    s.no_frame = no_frame
    s.scopes = precompute_scopes(function)
    bt :: precompute_branch_targets(function, s.scopes)
    s.continue_targets = bt.continue_targets
    s.break_targets = bt.break_targets
    last_line: i32 = -1
    last_file: string = ""
    for i in 0..<function.body.len() {
        if !ctx.release {
            dbg :: function.debug[i]
            if dbg != null {
                if dbg.line != last_line || dbg.file != last_file {
                    body.append("#line ${dbg.line} ${c_string_lit(dbg.file)}\n")
                    last_line = dbg.line
                    last_file = dbg.file
                }
            }
        }
        emit_op(s, i32(i), function.body[i])
    }

    // GC roots : ref-typed params, then locals + temps (collected by the
    // decl emitters). Order is irrelevant to the GC scan. `no_frame` fns
    // skip the whole shadow-stack apparatus.
    root_addrs: string[] = []
    if !no_frame {
        params :: function.signature.params
        for i in 0..<params.len() {
            if is_ref_val(params[i]) { root_addrs.push("&l${i}") }
        }
    }
    emit_local_decls(function, out, root_addrs, no_frame)
    emit_tmp_decls(s, out, root_addrs, no_frame)
    if !no_frame {
        if root_addrs.len() > 0 {
            out.append("    vader_box_t* gc_roots[${root_addrs.len()}] = { ${root_addrs.join(", ")} };\n")
        }
        roots_expr :: if root_addrs.len() > 0 { "gc_roots" } else { "NULL" }
        out.append("    vader_gc_frame_t gc_frame = { vader_gc_top, ${root_addrs.len()}u, 0u, ${roots_expr} };\n")
        out.append("    vader_gc_top = &gc_frame;\n")
    }

    out.append("${body}")

    // Defensive fall-through restore (void / implicit-end fns) ; explicit
    // returns pop the frame themselves.
    if !no_frame { out.append("    vader_gc_top = gc_frame.prev;\n") }
    out.append("}\n")
}

/// Declare every non-param local slot, bucketed by ValType in
/// first-appearance order (`<ctype> lA, lB;` per type). Primitives only
/// in T1b ; ref / any locals gain the `= vader_box_null()` GC-init in T5.
/// PER_LINE chunking (TS caps at 10 names / line) is deferred — it only
/// diverges past 10 locals of one type.
///
/// TS reference : `emitLocalDecls` in `src/c_emit/body.ts`.
emit_local_decls :: fn(function: BcFunction, out: StringBuilder, root_addrs: string[], no_frame: bool) -> void {
    locals :: function.locals
    param_count :: function.signature.params.len()
    vals: ValType[] = []
    names: string[] = []
    for i in 0..<locals.len() {
        if locals[i].val == ValType.Void { continue }
        vals.push(locals[i].val)
        names.push("l${param_count + i}")
    }
    emit_slot_decls(out, vals, names, root_addrs, no_frame)
}

/// Declare the materialised temps `tN`, bucketed like the locals. Reads
/// `s.tmp_types` (index N → ValType of `tN`), populated during the walk.
emit_tmp_decls :: fn(s: FnState, out: StringBuilder, root_addrs: string[], no_frame: bool) -> void {
    names: string[] = []
    for i in 0..<s.tmp_types.len() {
        names.push("t${i}")
    }
    emit_slot_decls(out, s.tmp_types, names, root_addrs, no_frame)
}

/// Declare a group of same-kind C slots (`vals[i]` is the ValType of
/// `names[i]`), bucketed by ValType in first-appearance order :
/// `<ctype> nameA, nameB;` per type. Shared by the local + temp decls.
/// PER_LINE chunking (TS caps at 10 names / line) is deferred — it only
/// diverges past 10 slots of one type.
///
/// TS reference : `emitLocalDecls` in `src/c_emit/body.ts`.
emit_slot_decls :: fn(out: StringBuilder, vals: ValType[], names: string[], root_addrs: string[], no_frame: bool) -> void {
    emitted: ValType[] = []
    for i in 0..<vals.len() {
        val :: vals[i]
        if val in emitted { continue }
        emitted.push(val)
        // Ref / any slots in a framed fn carry `= vader_box_null()` so the
        // GC scan reads a valid root before the first write, and their `&`
        // chains into `gc_roots[]`. No-frame fns (and primitives) get a bare
        // declaration — write-before-read makes the init unobservable.
        rooted :: is_ref_val(val) && !no_frame
        group: string[] = []
        for j in 0..<vals.len() {
            if vals[j] == val {
                if rooted {
                    group.push("${names[j]} = vader_box_null()")
                    root_addrs.push("&${names[j]}")
                } else {
                    group.push(names[j])
                }
            }
        }
        out.append("    ${c_type_for_val_bare(val)} ${group.join(", ")};\n")
    }
}

/// Per-op C emit — the function-body walker's dispatch. Exhaustive over
/// every `Op` variant (no `_`), so adding an opcode trips T3013 here and
/// forces a conscious decision — mirroring
/// `vader/bytecode/dump.vader::write_op`. Ops not yet ported call
/// `todo(...)` ; they are unreachable for the current C-parity allowlist
/// (which only exercises ops that have a real arm) and gain a real body
/// as each tranche lands.
///
/// T1 (scalar core) implements consts, `local.get`, the expr-shaped i32
/// arithmetic, and `return` ; the arm order tracks `write_op` so the two
/// stay diffable.
emit_op :: fn(s: FnState, pc: i32, op: vm.Op) -> void {
    invalidate_resolve_cache(s, op)
    match op {
        is vm.I32Const as c         -> push_const(s, c)
        is vm.I64Const as c         -> push_const(s, c)
        is vm.F64Const as c         -> push_const(s, c)
        is vm.BoolConst as c        -> push_const(s, c)
        is vm.CharConst as c        -> push_const(s, c)
        is vm.NullConst as c        -> push_const(s, c)
        is vm.StringConst as c      -> push_const(s, c)
        is vm.LocalGet as l         -> emit_local_get(s, l)
        is vm.LocalSet as l         -> emit_local_set(s, l.slot, false)
        is vm.LocalTee as l         -> emit_local_set(s, l.slot, true)
        is vm.LocalField as l       -> emit_local_field(s, l)
        is vm.Return                -> emit_return(s)
        is vm.ReturnLit as r        -> emit_return_lit(s, r.value)
        is vm.Drop                  -> drop_top(s)
        is vm.Call as c             -> emit_call(s, c)
        is vm.CallImport as c       -> emit_call_import(s, c)
        is vm.CallIndirect as c     -> emit_call_indirect(s, c)
        is vm.VirtualCall as c      -> emit_virtual_call(s, c)
        is vm.FnRef as fr           -> emit_fn_ref(s, fr)
        is vm.MakeClosure as mc     -> emit_make_closure(s, mc)
        is vm.If                    -> emit_if_open(s)
        is vm.Else                  -> emit_else(s)
        is vm.End                   -> emit_end(s, pc)
        is vm.Block                 -> emit_open_scope(s, pc, .Block)
        is vm.Loop                  -> emit_open_scope(s, pc, .Loop)
        is vm.Branch                -> emit_branch(s, pc, false)
        is vm.BranchIf              -> emit_branch(s, pc, true)
        is vm.BoolNot               -> push_unop(s, "!", .Bool)
        is vm.StructNew as sn       -> emit_struct_new(s, sn)
        is vm.StructGet as sg       -> emit_struct_get(s, sg)
        is vm.StructSet as ss       -> emit_struct_set(s, ss)
        is vm.ArrayNew as a         -> emit_array_new(s, a)
        is vm.ArrayLen              -> emit_array_len(s)
        is vm.ArrayPush as a        -> emit_array_push(s, a)
        is vm.ArrayGet as a         -> emit_array_get(s, a)
        is vm.ArraySet as a         -> emit_array_set(s, a)
        is vm.ArraySlice as a       -> emit_array_slice(s, a)
        is vm.ArrayRepeat           -> emit_array_repeat(s)
        is vm.ArrayPushAll          -> emit_array_push_all(s)
        is vm.ArrayCopy             -> emit_array_copy(s)
        is vm.ArrayRemoveLast       -> emit_array_remove_last(s)
        is vm.ArrayClear            -> emit_array_clear(s)
        is vm.DataConst as dc       -> emit_data_const_op(s, dc)
        is vm.TypeConst as tc       -> emit_type_const(s, tc)
        is vm.TypeCheck as tc       -> emit_type_check(s, tc)
        is vm.RefCast as rc         -> emit_ref_cast(s, rc)
        is vm.Box as bx             -> emit_box_op(s, bx)
        is vm.Unreachable as u      -> line(s, "vader_unreachable(${c_string_lit(u.reason)});")
        is vm.Convert as c          -> emit_convert(s, convert_target_val(c.target), c.from_name)
        is vm.SizeOfType            -> emit_size_of_type(s)
        is vm.I32Add                -> push_binop(s, "+", .I32)
        is vm.I32Sub                -> push_binop(s, "-", .I32)
        is vm.I32Mul                -> push_binop(s, "*", .I32)
        is vm.I32Div                -> push_eager(s, "/", .I32)
        is vm.I32Mod                -> push_eager(s, "%", .I32)
        is vm.I32Neg                -> push_unop(s, "-", .I32)
        is vm.I32BitNot             -> push_unop(s, "~", .I32)
        is vm.I32BitAnd             -> push_binop(s, "&", .I32)
        is vm.I32BitOr              -> push_binop(s, "|", .I32)
        is vm.I32BitXor             -> push_binop(s, "^", .I32)
        is vm.I32Shl                -> push_binop(s, "<<", .I32)
        is vm.I32Shr                -> push_binop(s, ">>", .I32)
        is vm.I32ShrU               -> push_binop(s, ">>", .U32)
        is vm.I32Eq                 -> push_cmp(s, "==", .I32)
        is vm.I32Ne                 -> push_cmp(s, "!=", .I32)
        is vm.I32Lt                 -> push_cmp(s, "<", .I32)
        is vm.I32Le                 -> push_cmp(s, "<=", .I32)
        is vm.I32Gt                 -> push_cmp(s, ">", .I32)
        is vm.I32Ge                 -> push_cmp(s, ">=", .I32)
        is vm.I64Add                -> push_binop(s, "+", .I64)
        is vm.I64Sub                -> push_binop(s, "-", .I64)
        is vm.I64Mul                -> push_binop(s, "*", .I64)
        is vm.I64Div                -> push_eager(s, "/", .I64)
        is vm.I64Mod                -> push_eager(s, "%", .I64)
        is vm.I64Neg                -> push_i64_neg(s)
        is vm.I64BitAnd             -> push_binop(s, "&", .I64)
        is vm.I64BitOr              -> push_binop(s, "|", .I64)
        is vm.I64BitXor             -> push_binop(s, "^", .I64)
        is vm.I64BitNot             -> push_unop(s, "~", .I64)
        is vm.I64Shl                -> push_binop(s, "<<", .I64)
        is vm.I64Shr                -> push_binop(s, ">>", .I64)
        is vm.I64ShrU               -> push_binop(s, ">>", .U64)
        is vm.I64Eq                 -> push_cmp(s, "==", .I64)
        is vm.I64Ne                 -> push_cmp(s, "!=", .I64)
        is vm.I64Lt                 -> push_cmp(s, "<", .I64)
        is vm.I64Le                 -> push_cmp(s, "<=", .I64)
        is vm.I64Gt                 -> push_cmp(s, ">", .I64)
        is vm.I64Ge                 -> push_cmp(s, ">=", .I64)
        is vm.U32Div                -> push_eager(s, "/", .U32)
        is vm.U32Mod                -> push_eager(s, "%", .U32)
        is vm.U32Lt                 -> push_cmp(s, "<", .U32)
        is vm.U32Le                 -> push_cmp(s, "<=", .U32)
        is vm.U32Gt                 -> push_cmp(s, ">", .U32)
        is vm.U32Ge                 -> push_cmp(s, ">=", .U32)
        is vm.U64Div                -> push_eager(s, "/", .U64)
        is vm.U64Mod                -> push_eager(s, "%", .U64)
        is vm.U64Lt                 -> push_cmp(s, "<", .U64)
        is vm.U64Le                 -> push_cmp(s, "<=", .U64)
        is vm.U64Gt                 -> push_cmp(s, ">", .U64)
        is vm.U64Ge                 -> push_cmp(s, ">=", .U64)
        is vm.F64Add                -> push_binop(s, "+", .F64)
        is vm.F64Sub                -> push_binop(s, "-", .F64)
        is vm.F64Mul                -> push_binop(s, "*", .F64)
        is vm.F64Div                -> push_eager(s, "/", .F64)
        is vm.F64Neg                -> push_unop(s, "-", .F64)
        is vm.F64Eq                 -> push_cmp(s, "==", .F64)
        is vm.F64Ne                 -> push_cmp(s, "!=", .F64)
        is vm.F64Lt                 -> push_cmp(s, "<", .F64)
        is vm.F64Le                 -> push_cmp(s, "<=", .F64)
        is vm.F64Gt                 -> push_cmp(s, ">", .F64)
        is vm.F64Ge                 -> push_cmp(s, ">=", .F64)
        is vm.BoolEq                -> push_binop(s, "==", .Bool)
        is vm.BoolNe                -> push_binop(s, "!=", .Bool)
        is vm.BoolAnd               -> push_binop(s, "&&", .Bool)
        is vm.BoolOr                -> push_binop(s, "||", .Bool)
        is vm.CharEq                -> push_cmp(s, "==", .Char)
        is vm.CharNe                -> push_cmp(s, "!=", .Char)
        is vm.CharLt                -> push_cmp(s, "<", .Char)
        is vm.CharLe                -> push_cmp(s, "<=", .Char)
        is vm.CharGt                -> push_cmp(s, ">", .Char)
        is vm.CharGe                -> push_cmp(s, ">=", .Char)
        is vm.StringEq              -> push_cmp(s, "==", .String)
        is vm.StringNe              -> push_cmp(s, "!=", .String)
        is vm.StringSliceCodepoints -> emit_string_slice(s)
        is vm.IntToChar             -> emit_convert(s, .Char, "")
        is vm.CharToInt             -> emit_convert(s, .I32, "")
        is vm.RefEq                 -> push_binop_any(s, "==", .Bool)
        is vm.RefNe                 -> push_binop_any(s, "!=", .Bool)
        is vm.DeferPush             -> emit_defer_push(s)
        is vm.DeferPopExec as d     -> emit_defer_pop_exec(s, d)
        // ---- memory opcodes (Target ABI) -----------------------------------
        // Bytes-only Buffer (S2b). object_new allocates a `vader_buffer_t`; the
        // typed load/store + memory_copy go through the `static inline
        // vader_buffer_*` helpers in vader.h, re-deriving the buffer pointer
        // from its rooted box on every op (G1 — no caching across an allocating
        // op). The boxed-slot path (`load_slot` / `store_slot`, with the
        // old->young write barrier) lands with Array (S5) — trap until then.
        is vm.ObjectNew as o        -> emit_object_new(s, o)
        is vm.LoadU8                -> emit_buffer_load(s, "vader_buffer_load_u8", .I32)
        is vm.LoadI32               -> emit_buffer_load(s, "vader_buffer_load_i32", .I32)
        is vm.LoadI64               -> emit_buffer_load(s, "vader_buffer_load_i64", .I64)
        is vm.LoadF64               -> emit_buffer_load(s, "vader_buffer_load_f64", .F64)
        is vm.StoreU8               -> emit_buffer_store(s, "vader_buffer_store_u8", "(uint8_t)")
        is vm.StoreI32              -> emit_buffer_store(s, "vader_buffer_store_i32", "(int32_t)")
        is vm.StoreI64              -> emit_buffer_store(s, "vader_buffer_store_i64", "(int64_t)")
        is vm.StoreF64              -> emit_buffer_store(s, "vader_buffer_store_f64", "(double)")
        is vm.LoadSlot              -> emit_slot_load_boxed(s)
        is vm.LoadSlotU8            -> emit_slot_load_prim(s, "uint8_t", .I32)
        is vm.LoadSlotI32           -> emit_slot_load_prim(s, "int32_t", .I32)
        is vm.LoadSlotI64           -> emit_slot_load_prim(s, "int64_t", .I64)
        is vm.LoadSlotF64           -> emit_slot_load_prim(s, "double", .F64)
        is vm.StoreSlot             -> emit_slot_store_boxed(s)
        is vm.StoreSlotU8           -> emit_slot_store_prim(s, "uint8_t", .I32)
        is vm.StoreSlotI32          -> emit_slot_store_prim(s, "int32_t", .I32)
        is vm.StoreSlotI64          -> emit_slot_store_prim(s, "int64_t", .I64)
        is vm.StoreSlotF64          -> emit_slot_store_prim(s, "double", .F64)
        is vm.MemoryCopy            -> emit_memory_copy(s)
        is vm.BufferToString        -> emit_buffer_to_string(s)
        is vm.BufferWriteString     -> emit_buffer_write_string(s)
        is vm.F64ToBits             -> emit_f64_to_bits(s)
        is vm.BitsToF64             -> emit_bits_to_f64(s)
        is vm.F32ToBits             -> emit_f32_to_bits(s)
        is vm.BitsToF32             -> emit_bits_to_f32(s)
    }
}

/// C source for a constant op — the `return.lit` payload today, the
/// const-push path in T1. Exhaustive over the closed `ConstOp` union.
///
/// TS reference : `constLitC` in `src/c_emit/body.ts`.
///
/// @param ctx  emit context — supplies the null primitive tag and the
///             string-literal atom ids.
/// @param c    the constant op to render.
/// @return     a C expression (no trailing `;`).
const_lit_c :: fn(ctx: EmitCtx, c: vm.ConstOp) -> string = match c {
    is vm.I32Const as v    -> i32_lit_c(v.value)
    is vm.I64Const as v    -> i64_lit_c(v.value)
    is vm.F64Const as v    -> float_lit(v.value)
    is vm.BoolConst as v   -> if v.value { "true" } else { "false" }
    is vm.CharConst as v   -> "${u32(v.value)}u"
    is vm.NullConst        -> "vader_box_obj(${ctx.null_tag}u, NULL)"
    is vm.StringConst as v -> "${ctx.atom_ids[usize(v.index)]}u"
}

/// C literal for an i32 value. `INT32_MIN` can't be spelled
/// `INT32_C(-2147483648)` — that parses as unary minus on an
/// out-of-range magnitude (UB on strict toolchains) — so emit the
/// stdint macro. The TS `(int32_t)UINT32_C(N)` out-of-range branch is
/// unreachable here : `value` is already typed `i32`.
i32_lit_c :: fn(value: i32) -> string {
    if value == i32(-2147483647) - 1 { return "INT32_MIN" }
    return "INT32_C(${value})"
}

/// C literal for an i64 value. Same `INT64_MIN` caveat as `i32_lit_c`.
i64_lit_c :: fn(value: i64) -> string {
    if value == i64(-9223372036854775807) - 1 { return "INT64_MIN" }
    return "INT64_C(${value})"
}

/// C literal for an f64 value. T1 will add inf / nan handling
/// (`(1.0/0.0)` etc.) and the f32 `f` suffix ; T0 only needs the finite
/// f64 path. A `.0` suffix is appended when the rendered value has no
/// `.`/`e`, so the C literal stays a `double`.
float_lit :: fn(value: f64) -> string {
    s :: "${value}"
    if "." in s || "e" in s { return s }
    return "${s}.0"
}

/// Push a constant op as a `StackLit` — `const_val` gives the stack
/// ValType, `const_lit_c` the C literal text.
push_const :: fn(s: FnState, c: vm.ConstOp) -> void = push_lit(s, const_val(c), const_lit_c(s.ctx, c))

/// Stack ValType produced by a constant op. Exhaustive over `ConstOp`.
/// `NullConst` boxes to `.Any` on the C stack (matching TS `constLitC`) —
/// a deliberate divergence from `bytecode::const_val_type`, which wants
/// `.Null` for its const-propagation slot typing.
const_val :: fn(c: vm.ConstOp) -> ValType = match c {
    is vm.I32Const    -> .I32
    is vm.I64Const    -> .I64
    is vm.F64Const    -> .F64
    is vm.BoolConst   -> .Bool
    is vm.CharConst   -> .Char
    is vm.NullConst   -> .Any
    is vm.StringConst -> .String
}

/// `local.get` — push a snapshot of slot `l.slot` (spelled `lN`). A
/// `void` slot carries nothing on the stack, so it is a no-op.
emit_local_get :: fn(s: FnState, l: vm.LocalGet) -> void {
    val :: slot_val_type(s.function, l.slot)
    if val == ValType.Void { return }
    push_local_ref(s, l.slot, val)
}

/// Push a binary op result as a `StackExpr`. Equality (`==` / `!=`) stays
/// paren-free so `if (${expr})` doesn't trip `-Wparentheses-equality` ;
/// every other operator is parenthesised for precedence safety.
push_binop :: fn(s: FnState, op: string, val: ValType) -> void =
    push_expr(s, val, binop_text(s, op, val))

/// Push a comparison as a `StackExpr` of class `.Bool`. The operands carry
/// the op's numeric class (`operand_val`), distinct from the `.Bool` result —
/// so an erased operand (an `any` flowing into `i32.lt` etc.) is unboxed to
/// the right class before the C compare.
push_cmp :: fn(s: FnState, op: string, operand_val: ValType) -> void =
    push_expr(s, .Bool, binop_text(s, op, operand_val))

/// Pop the two operands, coerce each to `operand_val` (the op's operand class
/// — identity when already that class, an unbox when an erased `any` reaches
/// the op), and build the infix C text. Equality stays paren-free so
/// `if (${expr})` doesn't trip `-Wparentheses-equality` ; every other operator
/// is parenthesised for precedence safety.
binop_text :: fn(s: FnState, op: string, operand_val: ValType) -> string {
    r :: pop(s)
    l :: pop(s)
    lc :: coerce_operand(s.ctx.module.types, name_of(l), val_of(l), operand_val)
    rc :: coerce_operand(s.ctx.module.types, name_of(r), val_of(r), operand_val)
    if op == "==" || op == "!=" { return "${lc} ${op} ${rc}" }
    return "(${lc} ${op} ${rc})"
}

/// Push a unary op result as a `StackExpr`. The operand is coerced to `val`
/// (unbox an erased `any`) and wrapped in parens — unary binds tighter than
/// the comparisons, so e.g. `~l0 == 0` would otherwise mis-parse.
push_unop :: fn(s: FnState, op: string, val: ValType) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), val)
    push_expr(s, val, "${op}(${vc})")
}

/// `i64.neg`. Special-cases `-(INT64_MIN)` : the source most-negative
/// literal `-9223372036854775808` reaches the emitter as
/// `i64.const INT64_MIN ; i64.neg`, and spelling that `-(INT64_MIN)`
/// overflows `int64_t` (UB ; trips `-Woverflow` on gcc). Since
/// `-INT64_MIN` wraps back to `INT64_MIN` on two's-complement — exactly
/// the value the source denotes — fold the pair to a bare `INT64_MIN`,
/// identical to how a plain `i64.const INT64_MIN` is spelled. Mirror of
/// the TS i64-neg fold. Any other operand negates
/// normally.
push_i64_neg :: fn(s: FnState) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), .I64)
    if vc == "INT64_MIN" {
        push_lit(s, .I64, "INT64_MIN")
    } else {
        push_expr(s, .I64, "-(${vc})")
    }
}

/// `f64.to_bits` — reinterpret an f64 as its raw IEEE u64 bits. Emits a C99
/// compound-literal union (well-defined type-punning in C ; the optimiser folds
/// it to a bit-move) so there is NO runtime symbol. The u64 result rides in the
/// `.I64` stack slot (same 64 bits).
emit_f64_to_bits :: fn(s: FnState) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), .F64)
    push_expr(s, .I64, "(int64_t)(((union { double __vd; uint64_t __vu; }){ .__vd = ${vc} }).__vu)")
}

/// `u64.from_bits` — the inverse : reinterpret a u64 bit pattern (in the `.I64`
/// slot) as an f64. Same compound-literal-union technique, no runtime symbol.
emit_bits_to_f64 :: fn(s: FnState) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), .I64)
    push_expr(s, .F64, "(((union { uint64_t __vu; double __vd; }){ .__vu = (uint64_t)(${vc}) }).__vd)")
}

/// `f32.to_bits` — the 32-bit analogue. The u32 result rides in the `.I32`
/// stack slot.
emit_f32_to_bits :: fn(s: FnState) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), .F32)
    push_expr(s, .I32, "(int32_t)(((union { float __vf; uint32_t __vb; }){ .__vf = ${vc} }).__vb)")
}

/// `u32.from_bits` — the inverse : reinterpret a u32 bit pattern (in the `.I32`
/// slot) as an f32. Same compound-literal-union technique, no runtime symbol.
emit_bits_to_f32 :: fn(s: FnState) -> void {
    v :: pop(s)
    vc :: coerce_operand(s.ctx.module.types, name_of(v), val_of(v), .I32)
    push_expr(s, .F32, "(((union { uint32_t __vb; float __vf; }){ .__vb = (uint32_t)(${vc}) }).__vf)")
}

/// Emit an eager binary op into a fresh temp : `tN = l <op> r;`. Used for
/// `div` / `rem` (every width, incl. f64) — TS materialises these
/// unconditionally so an integer divide-by-zero trap fires whether or not
/// the result is consumed. Operands are coerced to `val` (unbox an erased
/// `any`). Note : no parens around `l <op> r` (matches TS).
push_eager :: fn(s: FnState, op: string, val: ValType) -> void {
    r :: pop(s)
    l :: pop(s)
    lc :: coerce_operand(s.ctx.module.types, name_of(l), val_of(l), val)
    rc :: coerce_operand(s.ctx.module.types, name_of(r), val_of(r), val)
    push_into_tmp(s, "${lc} ${op} ${rc}", val)
}

/// Reinterpret the top value into `target_val` (`Convert` / `IntToChar` /
/// `CharToInt`). Same type → pass-through ; else a `((to)(from) v)`
/// double-cast where the inner cast pins the *source* signedness (mirrors
/// the TS emitter, which casts through the op's `from` type).
///
/// The bytecode collapses every integer ≤ 32 bits onto the `I32` stack
/// class, so a `u32` source rides as `.I32` and `val_of(v)` alone would
/// sign-extend it on a widen to 64 bits. When the op records an unsigned
/// source (`from_name` starts with `"u"`) widening to `i64`, reinterpret
/// through `uint32_t` so the bits zero-extend — a `u32` carries a magnitude,
/// not a signed value.
///
/// Kept deliberately narrow to exactly the `i32`-class → `i64` widen. A
/// broader rule (reinterpret *every* unsigned source through its stack-width
/// unsigned type, incl. the `.I64` class → `uint64_t`) regresses the
/// bootstrap : it changes how the compiler's own 64-bit literal rendering
/// compiles and miscompiles large `i64`/`u64` constants (fixed point breaks,
/// `INT64_MAX` emits as `4294967295`). u8/u16 are always < 2^31, so sign- and
/// zero-extension coincide ; u64/usize are already `.I64` and never widen.
///
/// @param target_val  the result stack class (`I32`/`I64`/`F64`/`Char`).
/// @param from_name   the op's recorded source type name (`"u32"`, `"i64"`,
///                    …) ; `""` for `IntToChar`/`CharToInt` (never 64-bit).
emit_convert :: fn(s: FnState, target_val: ValType, from_name: string) -> void {
    v :: pop(s)
    stack_val :: val_of(v)
    from_val :: if target_val == .I64 && stack_val == .I32 && from_name.starts_with("u") {
        ValType.U32
    } else {
        stack_val
    }
    if is_ref_val(stack_val) {
        // The value is still BOXED (an erased `any`/`ref` slot — e.g. a
        // `Distinct | null` field narrowed to its raw member) flowing into a
        // numeric convert. Unbox it to the target primitive, like `coerce_expr`
        // — a plain `(int64_t)(vader_box_t)x` cast of a box is invalid C.
        push_expr(s, target_val, unbox_expr(name_of(v), target_val))
    } else if from_val == target_val {
        push_expr(s, target_val, name_of(v))
    } else {
        push_expr(s, target_val, "((${c_type_for_val_bare(target_val)}) (${c_type_for_val_bare(from_val)}) ${name_of(v)})")
    }
}

/// `ConvertTarget` enum → its `ValType`.
convert_target_val :: fn(t: vm.ConvertTarget) -> ValType = match t {
    .I32  -> .I32
    .I64  -> .I64
    .F64  -> .F64
    .Char -> .Char
}

/// `return` — `return;` for a void result, else pop the value and emit
/// `return <value>;`. Scalar fns never allocate, so there is no GC frame
/// to pop here ; the framed path lands in T5.
///
/// The deferral is self-guarding : if the popped value's ValType differs
/// from the result type, a coercion is required (the lowerer inserts
/// `Convert` for every T1 width change, so this never fires on the scalar
/// subset) and `todo` fires loudly rather than emitting a type-mismatched
/// `return` — coercion + B1 wire-downgrade are owned by T1b / T12.
emit_return :: fn(s: FnState) -> void {
    result :: s.function.signature.result
    if result == ValType.Void {
        emit_return_stmt(s, "return;")
        return
    }
    // Dead trailing return : when an exhaustive-returning match (or any
    // earlier terminator) has already returned on every path, the lowerer's
    // implicit fn-terminator return is unreachable and carries no value on
    // the stack. The walker tracks no reachability (T2 — the CFG lowering is
    // fall-through-oriented), so detect it by the empty stack and emit a
    // noreturn trap (a reachable non-void return always has its value here).
    if s.stack.len() == 0 {
        line(s, "vader_unreachable(\"unreachable return in ${s.function.name}\");")
        return
    }
    v :: pop(s)
    rv :: coerce_expr(s.ctx.module.types, name_of(v), val_of(v), result)
    if s.no_frame {
        line(s, "return ${rv};")
    } else {
        // Snapshot the value before popping the frame : it may read a
        // frame-pinned local, so capturing first keeps the order safe.
        line(s, "{ ${c_type_for_val_bare(result)} __vret = ${rv}; vader_gc_top = gc_frame.prev; return __vret; }")
    }
}

/// `return.lit` — the fused `<T>.const X ; return`. A const can't read a
/// frame-pinned local, so the framed form pops the frame inline (no
/// `__vret` snapshot needed).
emit_return_lit :: fn(s: FnState, value: vm.ConstOp) -> void {
    // Coerce the literal to the fn's result class : a boxed-result fn (e.g. an
    // enum / union returned as `any`) needs the const boxed, not returned raw.
    rv :: coerce_expr(s.ctx.module.types, const_lit_c(s.ctx, value), const_val(value), s.function.signature.result)
    emit_return_stmt(s, "return ${rv};")
}

/// Emit a self-contained `return` statement (`ret`), wrapping it in the
/// GC-frame pop for framed fns. For a value return whose expression may
/// read a frame-pinned local, `emit_return` uses the `__vret` snapshot
/// form instead.
emit_return_stmt :: fn(s: FnState, ret: string) -> void {
    if s.no_frame {
        line(s, ret)
    } else {
        line(s, "{ vader_gc_top = gc_frame.prev; ${ret} }")
    }
}

/// `local.set` / `local.tee` — materialise any stack entry the write
/// would invalidate, pop the value, emit `lN = <value>;`, and (for
/// `tee`) re-push the slot. A `void` slot is a no-op. Value coercion
/// (slot type ≠ value type) is self-guarded with `todo` ; the lowerer
/// inserts `Convert` for every T1 width change, so it never fires on the
/// scalar subset.
emit_local_set :: fn(s: FnState, slot: i32, tee: bool) -> void {
    slot_val :: slot_val_type(s.function, slot)
    if slot_val == ValType.Void { return }
    materialize_stack_for_slot(s, slot)
    v :: pop(s)
    rv :: coerce_expr(s.ctx.module.types, name_of(v), val_of(v), slot_val)
    line(s, "l${slot} = ${rv};")
    if tee {
        push_local_ref(s, slot, slot_val)
    }
}

// ---- control flow ---------------------------------------------------------

/// Kind of a structured-control scope. Unlike `vader/bytecode`'s
/// emitter `ScopeKind` (Block / Loop only), the C walker also tracks
/// `If` so `end` knows to close a plain `}` (if / loop) versus a labelled
/// `} end_<opener>: ;` (block — a `br` destination).
ScopeKind :: enum(u8) {
    Block,
    Loop,
    If,
}

/// One structured-control scope, paired by `precompute_scopes`. `opener_pc`
/// is the `block` / `loop` / `if` op index ; `end_pc` its matching `end`.
/// The C-side labels derive from `opener_pc` : `loop_<opener>` (continue
/// target) and `end_<opener>` (break target).
ScopeInfo :: struct {
    opener_pc: i32
    kind:      ScopeKind
    end_pc:    i32
}

/// Pair every `block` / `loop` / `if` with its matching `end` in one
/// forward pass (the Vader bytecode carries no nesting depth on the op —
/// scopes are reconstructed structurally, like `dump.vader`). `else` is
/// not a scope of its own ; it is handled at emit time. Branch targets
/// live in `function.jump_table`, resolved against this table by
/// `branch_target`.
precompute_scopes :: fn(function: BcFunction) -> ScopeInfo[] {
    scopes: ScopeInfo[] = []
    open_pc:   i32[]       = []
    open_kind: ScopeKind[] = []
    body :: function.body
    for pc in 0..<body.len() {
        op :: body[pc]
        if op is vm.Block {
            open_pc.push(i32(pc))
            open_kind.push(.Block)
        } else if op is vm.Loop {
            open_pc.push(i32(pc))
            open_kind.push(.Loop)
        } else if op is vm.If {
            open_pc.push(i32(pc))
            open_kind.push(.If)
        } else if op is vm.End {
            n :: open_pc.len()
            if n > 0 {
                scopes.push(ScopeInfo {
                    .opener_pc = open_pc[n - 1],
                    .kind      = open_kind[n - 1],
                    .end_pc    = i32(pc),
                })
                open_pc   = open_pc.slice(0, n - 1)
                open_kind = open_kind.slice(0, n - 1)
            }
        }
    }
    return scopes
}

/// The two label families a fn needs : `continue_targets` (loop back-edge,
/// `loop_<o>:`) and `break_targets` (forward exit past a scope's `end`,
/// `end_<o>:`). Kept separate so a loop targeted only by a continue doesn't
/// emit an unused `end_` label (and vice versa).
BranchTargets :: struct {
    continue_targets: i32[]
    break_targets:    i32[]
}

/// One pass over the body collecting both label families from the resolved
/// `br` / `br_if` targets (`function.jump_table` via `branch_target`), so a
/// C label is emitted only where referenced (an unused label warns).
precompute_branch_targets :: fn(function: BcFunction, scopes: ScopeInfo[]) -> BranchTargets {
    continue_t: i32[] = []
    break_t:    i32[] = []
    body :: function.body
    jump_table :: function.jump_table
    for pc in 0..<body.len() {
        op :: body[pc]
        if op is vm.Branch || op is vm.BranchIf {
            target :: jump_table[pc]
            found :: branch_target(scopes, target)
            if found is ScopeInfo as sc {
                if is_continue_branch(sc, target) {
                    if !(sc.opener_pc in continue_t) { continue_t.push(sc.opener_pc) }
                } else {
                    if !(sc.opener_pc in break_t) { break_t.push(sc.opener_pc) }
                }
            }
        }
    }
    return BranchTargets { .continue_targets = continue_t, .break_targets = break_t }
}

/// True when `target` is the continue back-edge of loop `sc` (its body top,
/// `opener_pc + 1`). The other resolvable target is a forward exit past a
/// scope's `end` (`end_pc + 1`, a break).
is_continue_branch :: fn(sc: ScopeInfo, target: i32) -> bool =
    sc.kind == .Loop && sc.opener_pc + 1 == target

/// Resolve a `jump_table` target pc to the scope it lands in : the continue
/// back-edge of a `loop` (`opener + 1`), or the forward exit past ANY scope's
/// `end` (`end + 1` — break out of a block / loop, or jump past an `if`).
/// Continue wins when a pc is ambiguously both. Returns `null` for an
/// unresolved target (malformed bytecode).
branch_target :: fn(scopes: ScopeInfo[], target: i32) -> ScopeInfo | null {
    for i in 0..<scopes.len() {
        if is_continue_branch(scopes[i], target) { return scopes[i] }
    }
    for i in 0..<scopes.len() {
        if scopes[i].end_pc + 1 == target { return scopes[i] }
    }
    return null
}

/// The scope closed by the `end` op at `pc`, or `null` if none (malformed
/// bytecode — every `end` pairs with an opener in `precompute_scopes`).
scope_ending_at :: fn(scopes: ScopeInfo[], pc: i32) -> ScopeInfo | null {
    for i in 0..<scopes.len() {
        if scopes[i].end_pc == pc { return scopes[i] }
    }
    return null
}

/// `block` / `loop` — open a C compound statement. A `loop` that some
/// `br` continues to gets a `loop_<pc>:` label before the brace (the
/// backward-jump target) ; everything else is a bare `{`. `block` close
/// labels are emitted by `emit_end`.
emit_open_scope :: fn(s: FnState, pc: i32, kind: ScopeKind) -> void {
    if kind == .Loop && (pc in s.continue_targets) {
        line(s, "loop_${pc}: {")
    } else {
        line(s, "{")
    }
    indent_push(s)
}

/// `if` — pop the condition and open `if (<cond>) {`.
emit_if_open :: fn(s: FnState) -> void {
    cond :: pop(s)
    line(s, "if (${name_of(cond)}) {")
    indent_push(s)
}

/// `else` — close the then-arm and open the else-arm. Block results are
/// already materialised into locals by the lowerer (every scope is
/// `void`), so there is nothing to hoist across the boundary.
emit_else :: fn(s: FnState) -> void {
    indent_pop(s)
    line(s, "} else {")
    indent_push(s)
}

/// `end` — close the scope opened earlier. Any scope (block / loop / if)
/// that a `br` exits past gets its `end_<opener>: ;` label after the brace ;
/// untargeted scopes close with a bare `}`.
emit_end :: fn(s: FnState, pc: i32) -> void {
    sc :: scope_ending_at(s.scopes, pc)
    if sc is ScopeInfo as scope {
        indent_pop(s)
        if scope.opener_pc in s.break_targets {
            line(s, "} end_${scope.opener_pc}: ;")
        } else {
            line(s, "}")
        }
    } else {
        todo("emit_end: no scope ends at pc ${pc}")
    }
}

/// `br` / `br_if` — a `goto` to the resolved scope label (`loop_<opener>`
/// for a continue back-edge, `end_<opener>` for a break forward-exit).
/// `br_if` pops its i32 condition and guards the jump. Block results are
/// local-materialised by the lowerer, so no value is hoisted before the
/// jump.
emit_branch :: fn(s: FnState, pc: i32, conditional: bool) -> void {
    target :: s.function.jump_table[pc]
    found :: branch_target(s.scopes, target)
    if found is ScopeInfo as sc {
        dest :: if is_continue_branch(sc, target) { "loop_${sc.opener_pc}" } else { "end_${sc.opener_pc}" }
        if conditional {
            cond :: pop(s)
            line(s, "if (${name_of(cond)}) goto ${dest};")
        } else {
            line(s, "goto ${dest};")
        }
    } else {
        todo("emit_branch: unresolved target at pc ${pc} (jump_table=${target})")
    }
}

// ---- calls ----------------------------------------------------------------

/// `call` — direct call of a Vader function by index. Resolves the callee
/// in `module.functions`, derives its C name the same way the forward decl
/// / definition do (`sanitise(name)`, see `signature_for`), and delegates
/// to the shared `emit_call_to`.
emit_call :: fn(s: FnState, op: vm.Call) -> void {
    callee :: s.ctx.module.functions[usize(op.function_index)]
    emit_call_to(s, sanitise(callee.name), callee.signature)
}

/// `call.import` — call a host fn through its generated `vader_import_N`
/// shim (see `host.vader`). Reuses the shared `emit_call_to` with
/// the import's signature.
emit_call_import :: fn(s: FnState, op: vm.CallImport) -> void {
    imp :: s.ctx.module.imports[usize(op.index)]
    emit_call_to(s, "vader_import_${op.index}", imp.signature)
}

/// Shared direct-call path (own fns now ; imports reuse it in T3b). Pops
/// `sig`'s params off the operand stack in reverse, reassembles them in
/// source order, and routes the result through `emit_call_result`. Scalar
/// subset only : an arg whose ValType differs from the param self-guards
/// with `todo` — the lowerer inserts `Convert` for width changes, and
/// ref / erasure / B1 reshaping is T3+ / T12, so it never fires here.
emit_call_to :: fn(s: FnState, callee_name: string, sig: BcSignature) -> void {
    n :: i32(sig.params.len())
    // Top-of-stack is the last argument, so pop into `args` back-to-front :
    // pop #k lands in slot `n-1-k`, restoring source order for the join.
    args: string[] = []
    for _ in 0..<n { args.push("") }
    for k in 0..<n {
        v :: pop(s)
        slot :: n - 1 - k
        args[usize(slot)] = coerce_expr(s.ctx.module.types, name_of(v), val_of(v), sig.params[usize(slot)])
    }
    emit_call_result(s, "${callee_name}(${args.join(", ")})", sig.result)
}

/// Capture a call's result : a `void` call is a bare statement ; otherwise
/// materialise into a fresh `tN` (calls are eager — they may have side
/// effects, so the result is forced even when unused) and push it. B1 /
/// erasure return reshaping is T12.
emit_call_result :: fn(s: FnState, call_expr: string, result: ValType) -> void {
    if result == ValType.Void {
        line(s, "${call_expr};")
        return
    }
    push_into_tmp(s, call_expr, result)
}

// ---- closures + dispatch --------------------------------------------------
//
// Fn values flow as `vader_box_obj(tag, fn_ptr)`. A bare `fn.ref` boxes a
// pointer to the fn's static trampoline ; `make_closure` heap-allocates a
// `vader_fn_t` carrying the lifted-fn wrapper + captured env ; `call.indirect`
// invokes either through the canonical erased ABI (`vader_fn_erased_sig_N_t`),
// boxing every arg so a concrete-typed closure flows through an erased call
// site. `virtual.call` routes through the per-key dispatcher (`dispatch.vader`)
// switching on the receiver's runtime tag. The wrappers themselves are emitted
// once per module by `emit_fn_trampolines` below.

/// Pop `count` args off the operand stack (top is the last arg), box each to
/// the erased `any` ABI, and return them in source order — pop #k lands in
/// slot `count-1-k`. Shared by the erased-call sites (`call.indirect` args,
/// `virtual.call` tail).
pop_args_boxed :: fn(s: FnState, count: i32) -> string[] {
    types :: s.ctx.module.types
    args: string[] = []
    for _ in 0..<count { args.push("") }
    for k in 0..<count {
        v :: pop(s)
        slot :: count - 1 - k
        args[usize(slot)] = coerce_expr(types, name_of(v), val_of(v), .Any)
    }
    return args
}

/// `fn.ref` — box a pointer to the fn's static trampoline value. The
/// trampoline (`vader_fn_static_N`) is emitted by `emit_fn_trampolines`.
emit_fn_ref :: fn(s: FnState, op: vm.FnRef) -> void {
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${op.type_id}u, &vader_fn_static_${op.function_index});")
    push_tmp(s, name, .Ref)
}

/// `make_closure` — pop the captured env (a boxed struct), heap-allocate a
/// `vader_fn_t` with `code` = the lifted-fn wrapper + `env` = the env ptr,
/// box it with the closure's fn-type tag. `env_type_id` carries the closure's
/// own BcFn type (a lowerer misnomer — see `bytecode/emit_body.vader`).
emit_make_closure :: fn(s: FnState, op: vm.MakeClosure) -> void {
    env :: pop(s)
    fn_obj :: aux(s, "closure")
    line(s, "vader_fn_t* ${fn_obj} = (vader_fn_t*) vader_gc_alloc(sizeof(vader_fn_t));")
    line(s, "vader_obj_header_init(${fn_obj}, ${op.env_type_id}u);")
    line(s, "${fn_obj}->code = (void*) &vader_fn_lift_${op.function_index};")
    line(s, "${fn_obj}->env = ${name_of(env)}.payload.obj;")
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${op.env_type_id}u, ${fn_obj});")
    push_tmp(s, name, .Ref)
}

/// `call.indirect` — invoke a `vader_fn_t` value through the canonical erased
/// signature. Every arg is boxed to `vader_box_t` and the `code` pointer cast
/// to `vader_fn_erased_sig_N_t`, so a concrete-typed closure flows through an
/// erased call site without a calling-convention mismatch ; the wrapper unboxes
/// per the underlying fn's concrete sig. The wrapper returns the erased box —
/// coerce it back to the static return class for direct readers.
emit_call_indirect :: fn(s: FnState, op: vm.CallIndirect) -> void {
    types :: s.ctx.module.types
    t :: types[usize(op.type_id)]
    if t is BcFn as fnt {
        // `fn_val` is on top — pop it before the args.
        fn_val :: pop(s)
        n :: i32(fnt.params.len())
        args :: pop_args_boxed(s, n)
        fn_obj :: aux(s, "fnobj")
        line(s, "vader_fn_t* ${fn_obj} = (vader_fn_t*) ${name_of(fn_val)}.payload.obj;")
        call_args :: if n == 0 { "${fn_obj}->env" } else { "${fn_obj}->env, ${args.join(", ")}" }
        call_expr :: "((vader_fn_erased_sig_${n}_t) ${fn_obj}->code)(${call_args})"
        ret_val :: val_type_of_bc_type(types[usize(fnt.return_type)])
        if ret_val == ValType.Void {
            line(s, "${call_expr};")
            return
        }
        any_tmp :: fresh_tmp(s, .Any)
        line(s, "${any_tmp} = ${call_expr};")
        if ret_val == ValType.Ref || ret_val == ValType.Any {
            push_tmp(s, any_tmp, ret_val)
            return
        }
        result :: fresh_tmp(s, ret_val)
        line(s, "${result} = ${coerce_expr(types, any_tmp, .Any, ret_val)};")
        push_tmp(s, result, ret_val)
    } else {
        todo("call.indirect on non-fn type ${op.type_id}")
    }
}

/// `virtual.call` — trait-method dispatch. Pop the receiver (top of stack),
/// then the tail args below it (source order), box everything to the erased
/// ABI, and call the per-key dispatcher (`vader_vt_<key>`, emitted in
/// `dispatch.vader`) which switches on `recv.tag`. The Vader op carries no
/// result-type index, so there is no erasure-boundary repack here — a
/// following `ref.cast` / `convert` handles any per-tag reshape (cleaner than
/// the TS in-op conversion ; full erasure boundary is T12).
emit_virtual_call :: fn(s: FnState, op: vm.VirtualCall) -> void {
    row :: find_vtable_row(s.ctx, op.vtable_key)
    if row == null {
        line(s, "vader_unreachable(\"no vtable for ${op.vtable_key}\");")
        return
    }
    types :: s.ctx.module.types
    // Receiver is on top, popped first ; the tail args sit below in source
    // order (`pop_args_boxed` restores it).
    recv :: pop(s)
    recv_boxed :: coerce_expr(types, name_of(recv), val_of(recv), .Any)
    boxed :: pop_args_boxed(s, op.parameter_count - 1)
    sig :: vtable_sig_for_row(s.ctx, row)
    all_args: string[] = [recv_boxed]
    for a in boxed { all_args.push(a) }
    call_expr :: "${vtable_helper_name(op.vtable_key)}(${all_args.join(", ")})"
    if sig.result == ValType.Void {
        line(s, "${call_expr};")
        return
    }
    push_into_tmp(s, call_expr, sig.result)
}

// ---- fn-value wrappers (whole-module scan) --------------------------------

/// Per-fn `fn.ref` trampoline + `make_closure` lift wrappers. Walks every fn
/// body to discover which fns are taken by reference (need a static
/// `vader_fn_t` + a wrapper dropping env) and which are lifted into closures
/// (need a wrapper boxing env). Both expose the canonical erased ABI
/// (`vader_box_t` per arg + return) so one `code` pointer is castable at any
/// `call.indirect` site. Gated on the ops actually appearing — a fn-typed
/// field can exist with no fn-value op. Mirrors `emitFnTrampolines` in
/// `src/c_emit/emit.ts`.
emit_fn_trampolines :: fn(ctx: EmitCtx, out: StringBuilder) -> void {
    fns :: ctx.module.functions
    n :: fns.len()
    fn_ref_type: i32[] = []     // BcFn type tag per fn.ref target, -1 = none
    is_closure: bool[] = []     // true when a make_closure lifts this fn
    for _ in 0..<n {
        fn_ref_type.push(-1)
        is_closure.push(false)
    }
    any := false
    for f in fns {
        for op in f.body {
            if op is vm.FnRef as fr {
                fn_ref_type[usize(fr.function_index)] = fr.type_id
                any = true
            } else if op is vm.MakeClosure as mc {
                is_closure[usize(mc.function_index)] = true
                any = true
            }
        }
    }
    if !any { return }

    for i in 0..<n {
        if fn_ref_type[i] >= 0 { emit_fn_ref_tramp(ctx, out, i32(i), fn_ref_type[i]) }
    }
    for i in 0..<n {
        if is_closure[i] { emit_closure_lift(ctx, out, i32(i)) }
    }
    out.append("\n")
}

/// Emit the `fn.ref` trampoline (drops env, unboxes args to the fn's concrete
/// sig, boxes the result) + the static `vader_fn_t` value pointing at it.
emit_fn_ref_tramp :: fn(ctx: EmitCtx, out: StringBuilder, fn_index: i32, type_id: i32) -> void {
    fn_decl :: ctx.module.functions[usize(fn_index)]
    cname :: sanitise(fn_decl.name)
    sig :: fn_decl.signature
    head :: if sig.params.len() == 0 { "void* env" } else { "void* env, ${tramp_box_params(sig.params.len())}" }
    out.append("static vader_box_t vader_fn_tramp_${fn_index}(${head}) {\n")
    out.append("    (void) env;\n")
    unboxed :: tramp_unbox_args(sig.params)
    if sig.result == ValType.Void {
        out.append("    ${cname}(${unboxed});\n")
        out.append("    return vader_box_null();\n")
    } else {
        out.append("    return ${tramp_box_result(cname, unboxed, sig)};\n")
    }
    out.append("}\n")
    out.append("static vader_fn_t vader_fn_static_${fn_index} = { { ${type_id}u, 0u, 0u, 0u, NULL }, (void*) &vader_fn_tramp_${fn_index}, NULL };\n")
}

/// Emit the `make_closure` lift wrapper : takes `void* env` + the tail args
/// boxed, re-boxes env into the `vader_box_t` the lifted fn's first param
/// expects, unboxes the tail to the concrete sig, boxes the result.
emit_closure_lift :: fn(ctx: EmitCtx, out: StringBuilder, fn_index: i32) -> void {
    fn_decl :: ctx.module.functions[usize(fn_index)]
    cname :: sanitise(fn_decl.name)
    sig :: fn_decl.signature
    if sig.params.len() == 0 { return }
    tail :: i32(sig.params.len()) - 1
    head :: if tail == 0 { "void* env" } else { "void* env, ${tramp_box_params(usize(tail))}" }
    out.append("static vader_box_t vader_fn_lift_${fn_index}(${head}) {\n")
    out.append("    vader_box_t env_box; env_box.tag = 0u; env_box._pad = 0u; env_box.payload.obj = env;\n")
    unboxed_tail :: lift_unbox_tail(sig.params)
    call_args :: if unboxed_tail == "" { "env_box" } else { "env_box, ${unboxed_tail}" }
    if sig.result == ValType.Void {
        out.append("    ${cname}(${call_args});\n")
        out.append("    return vader_box_null();\n")
    } else {
        out.append("    return ${tramp_box_result(cname, call_args, sig)};\n")
    }
    out.append("}\n")
}

/// `vader_box_t a0, vader_box_t a1, …` — `count` erased-ABI tail params.
tramp_box_params :: fn(count: usize) -> string {
    sb :: StringBuilder {}
    for j in 0..<count {
        if j > 0 { sb.append(", ") }
        sb.append("vader_box_t a${j}")
    }
    return "${sb}"
}

/// Unbox `a0..a<n-1>` to the concrete `params` classes, comma-joined — the
/// `fn.ref` trampoline's argument list (params map 1:1 to `a<j>`).
tramp_unbox_args :: fn(params: ValType[]) -> string {
    parts: string[] = []
    for j in 0..<params.len() {
        parts.push(unbox_expr("a${j}", params[j]))
    }
    return parts.join(", ")
}

/// Unbox the lift wrapper's tail `a0..` to `params[1..]` (param 0 is the env
/// slot, supplied as `env_box`), comma-joined.
lift_unbox_tail :: fn(params: ValType[]) -> string {
    parts: string[] = []
    for j in 1..<params.len() {
        parts.push(unbox_expr("a${j - 1}", params[j]))
    }
    return parts.join(", ")
}

/// The wrapper's boxed return expression : `<fn>(<args>)`, boxed unless the
/// result is already a box (`ref` / `any`).
tramp_box_result :: fn(cname: string, args: string, sig: BcSignature) -> string {
    call_expr :: "${cname}(${args})"
    if sig.result == ValType.Ref || sig.result == ValType.Any { return call_expr }
    return box_expr(call_expr, sig.result, sig.result_type)
}

// ---- type ops + defer -----------------------------------------------------

/// `type.const` — box `type_id` into the payload pointer via `(uintptr_t)` so
/// `@size_of` can recover the BcType slot at runtime (decoded by
/// `emit_size_of_type`). Tagged `null` keeps GC + display off the synthetic
/// pointer. A pure literal — push as a lit so a direct `size_of.type` reader
/// inlines it. Mirrors the `type.const` arm in `src/c_emit/body.ts`.
emit_type_const :: fn(s: FnState, op: vm.TypeConst) -> void =
    push_lit(s, .Any, "vader_box_obj(${s.ctx.null_tag}u, (void*)(uintptr_t)${op.type_id}u)")

/// `size_of.type` — decode the `type.const` payload back to a BcType slot and
/// index the `vader_type_size[]` table (emitted by `emit_type_info_table`).
/// Mirrors the `sizeOfType` intrinsic in `src/c_emit/ops.ts`.
emit_size_of_type :: fn(s: FnState) -> void {
    tv :: pop(s)
    push_into_tmp(s, "vader_type_size[(int32_t)(uintptr_t)${name_of(tv)}.payload.obj]", .Usize)
}

/// `type_check` — runtime `x is T`. A boxed value compares its tag (a trait
/// ref expands to a disjunction over every implementing struct's tag, plus the
/// ref type itself) ; a primitively-typed value resolves at compile time
/// (`primitive_matches_type`). Pushed as an expression so a downstream `if` /
/// `br_if` / boolean combinator inlines it. Mirrors `emitTypeCheck` in
/// `src/c_emit/ops.ts`.
emit_type_check :: fn(s: FnState, op: vm.TypeCheck) -> void {
    v :: pop(s)
    val :: val_of(v)
    if is_ref_val(val) {
        target :: s.ctx.module.types[usize(op.type_id)]
        if target is BcUnion as u {
            // `x is (A | B)` — a boxed value never carries a union's own tag, so
            // OR the per-variant checks (mirrors the VM's `union_matches`). This
            // makes `is <union>` correct on native, matching the VM.
            parts: string[] = []
            for vid in u.variants { parts.push(one_variant_check(s, name_of(v), vid)) }
            push_expr(s, .Bool, "(${parts.join(" || ")})")
            return
        }
        push_expr(s, .Bool, one_variant_check(s, name_of(v), op.type_id))
    } else {
        matches :: primitive_matches_type(s.ctx.module.types, val, op.type_id)
        push_lit(s, .Bool, if matches { "true" } else { "false" })
    }
}

// The C bool expr for `v_name is <single type_id>` : a trait ref expands to a
// disjunction over its implementers, a struct compares its sibling-aware tag,
// anything else is a plain tag compare.
one_variant_check :: fn(s: FnState, v_name: string, type_id: i32) -> string {
    target :: s.ctx.module.types[usize(type_id)]
    if target is BcRef as r {
        if r.trait_name != "" { return trait_check_expr(s.ctx, v_name, r.trait_name, type_id) }
    }
    if target is BcStruct as st {
        return struct_check_expr(s.ctx.module.types, v_name, type_id, st.name)
    }
    return "${v_name}.tag == ${type_id}u"
}

/// The C boolean expression testing whether `v_name`'s tag matches struct type
/// `target_id` — its own tag OR any **sibling** struct's tag (same generic
/// source, by `prefix_before_double_underscore`). Mirrors the VM's
/// `struct_siblings_match` : an erased generic flows a runtime sibling shape
/// (`Entry(i32,i32)`, a distinct tag) into a `type_check` typed against the
/// erased one (`Entry(Any,Any)`) — exact-tag equality would miss it (and trip
/// the dead-return guard on the match fall-through). A non-generic struct
/// (empty prefix) has no siblings → a bare tag compare.
struct_check_expr :: fn(types: BcType[], v_name: string, target_id: i32, target_name: string) -> string {
    base :: "${v_name}.tag == ${target_id}u"
    prefix :: prefix_before_double_underscore(target_name)
    if prefix == "" { return base }
    parts: string[] = [base]
    for i in 0..<types.len() {
        if i32(i) == target_id { continue }
        if types[i] is BcStruct as st {
            if prefix_before_double_underscore(st.name) == prefix {
                parts.push("${v_name}.tag == ${i}u")
            }
        }
    }
    if parts.len() == 1 { return base }
    return "(${parts.join(" || ")})"
}

/// The C boolean expression testing whether `v_name`'s tag matches the trait
/// `trait_name` — an OR over the ref type index itself (built-in trait refs
/// like `Error` carry their own tag) plus every struct implementing the trait
/// (the module's `impl_table`). Mirrors `traitCheckExpr` in `src/c_emit/ops.ts`.
trait_check_expr :: fn(ctx: EmitCtx, v_name: string, trait_name: string, ref_type_index: i32) -> string {
    parts: string[] = ["(${v_name}.tag == ${ref_type_index}u)"]
    for entry in ctx.module.impl_table {
        if entry.trait_name == trait_name {
            parts.push("(${v_name}.tag == ${entry.struct_type_index}u)")
        }
    }
    return parts.join(" || ")
}

/// `defer.push` — register the deferred closure (on top of the stack, built by
/// a preceding `make_closure`) on the runtime defer stack.
emit_defer_push :: fn(s: FnState) -> void {
    closure :: pop(s)
    line(s, "vader_defer_push(${name_of(closure)});")
}

/// `defer.pop_exec` — run + pop the top `count` deferred closures at a scope
/// exit. Mirrors the `defer.pop_exec` arm in `src/c_emit/body.ts`.
emit_defer_pop_exec :: fn(s: FnState, op: vm.DeferPopExec) -> void =
    line(s, "vader_defer_pop_exec(${op.count}u);")

// ---- structs --------------------------------------------------------------
//
// Body representation only (no inline-rep / B1 packing — that is T12) :
// every struct value flows as a boxed `vader_box_t` whose `payload.obj`
// points at the storage, and field access derefs `((T*) box.payload.obj)`.
// T4a covers stack-allocated structs (`struct.new_stack`) ; the heap path
// (`struct.new`) needs the GC-frame prologue and lands in T4b.

/// `struct.new` / `struct.new_stack` — allocate, header-init, store each
/// field, box. T4a handles the stack variant only (escape-proven
/// non-escaping) : storage is a C local, no GC. Fields pop right-to-left
/// then store in declaration order ; an incoming value whose ValType
/// differs from the field self-guards with `todo` (the lowerer + `ref.cast`
/// align them on the scalar/struct subset ; B1 nullable-ref fields are T12).
emit_struct_new :: fn(s: FnState, op: vm.StructNew) -> void {
    t :: s.ctx.module.types[usize(op.type_id)]
    if t is BcStruct as st {
        cname :: s.ctx.struct_c_names[usize(op.type_id)]
        n :: i32(st.fields.len())
        // Pop top-to-bottom : pop #k is the value for field `n-1-k`.
        field_vals: string[] = []
        for _ in 0..<n { field_vals.push("") }
        for k in 0..<n {
            v :: pop(s)
            fi :: n - 1 - k
            f :: st.fields[usize(fi)]
            field_vals[usize(fi)] = coerce_expr(s.ctx.module.types, name_of(v), val_of(v), val_type_of_field(s.ctx.module.types, f.type_index))
        }
        // Storage : a C local for the escape-proven stack variant, a GC heap
        // block otherwise. The popped field values live in ref temps that
        // the frame roots, so a GC during `vader_gc_alloc` can't strand them.
        obj :: if op.stack {
            storage :: aux(s, "storage")
            o :: aux(s, "obj")
            line(s, "${cname} ${storage};")
            line(s, "${cname}* ${o} = &${storage};")
            o
        } else {
            o :: aux(s, "obj")
            line(s, "${cname}* ${o} = (${cname}*) vader_gc_alloc(sizeof(${cname}));")
            o
        }
        line(s, "vader_obj_header_init(${obj}, ${op.type_id}u);")
        for i in 0..<n {
            f :: st.fields[usize(i)]
            line(s, "${obj}->f_${sanitise(f.name)} = ${field_vals[usize(i)]};")
        }
        name :: fresh_tmp(s, .Ref)
        line(s, "${name} = vader_box_obj(${op.type_id}u, ${obj});")
        push_tmp(s, name, .Ref)
    } else {
        todo("struct.new on non-struct type ${op.type_id}")
    }
}

/// `struct.get` — pop the receiver box, push field `field_index` as an
/// inlined dereference expression.
emit_struct_get :: fn(s: FnState, op: vm.StructGet) -> void {
    obj :: pop(s)
    push_struct_field(s, op.type_id, op.field_index, name_of(obj))
}

/// `local.field` — the fused `local.get N ; struct.get`. Push field
/// `field_index` of the struct in slot `slot`.
emit_local_field :: fn(s: FnState, op: vm.LocalField) -> void {
    push_struct_field(s, op.type_id, op.field_index, "l${op.slot}")
}

/// Push field `field_index` of struct type `type_index` read off `recv`
/// (a `vader_box_t` C expression) as a `StackExpr` — the body-rep
/// dereference `((T*) recv.payload.obj)->f_<name>`. B1 / inline-rep field
/// reps are T12.
push_struct_field :: fn(s: FnState, type_index: i32, field_index: i32, recv: string) -> void {
    types :: s.ctx.module.types
    t :: types[usize(type_index)]
    if t is BcStruct as st {
        cname :: s.ctx.struct_c_names[usize(type_index)]
        f :: st.fields[usize(field_index)]
        fval :: val_type_of_field(types, f.type_index)
        concrete :: "((${cname}*) ${recv}.payload.obj)->f_${sanitise(f.name)}"
        // Erasure boundary (T12). An erased-generic producer (e.g. a generic
        // `zip` / `enumerate`) returns an erased sibling layout (some or all
        // fields boxed) ; Vader erases the carrying array / result to a bare
        // `ref`, so the concrete element type only resurfaces HERE, at the field
        // read (the `local.field` / `struct.get` op carries the concrete
        // `type_id`). Dispatch on the runtime tag : a concrete value reads the
        // concrete layout directly ; an erased sibling reads the sibling's field
        // and box/unboxes it to the concrete field's storage. Self-gating — a
        // concrete value never matches a sibling tag, so non-erased reads are
        // unaffected. (The TS backend reshapes the whole array eagerly at the
        // call, where it keeps the concrete array type ; Vader's array is erased
        // to `ref`, so the per-read form is the Vader-appropriate equivalent.)
        sibs :: find_erased_siblings(types, type_index)
        if sibs.len() == 0 {
            push_expr(s, fval, concrete)
        } else {
            // One tag test per erased sibling, falling back to the concrete
            // read (a value tagged as the concrete type — or anything
            // unexpected — matches no sibling tag, so it lands on `concrete`).
            acc := concrete
            for k in 0..<sibs.len() {
                sib :: sibs[sibs.len() - 1 - k]
                read :: erased_sibling_field_read(s, sib, field_index, fval, recv)
                acc = "(${recv}.tag == ${sib}u ? ${read} : ${acc})"
            }
            push_expr(s, fval, acc)
        }
    } else {
        todo("struct field access on non-struct type ${type_index}")
    }
}

/// True for the boxed-storage value classes (a `vader_box_t` slot). Drives the
/// erasure read's copy (both boxed) vs unbox (concrete target) decision.
is_ref_like_val :: fn(v: ValType) -> bool = v == ValType.Ref || v == ValType.Any || v == ValType.Null

/// True when every field of `st` is an open `ref` — the erased all-`Any` form
/// an erased-generic body materialises.
struct_all_ref :: fn(types: BcType[], st: BcStruct) -> bool {
    if st.fields.len() == 0 { return false }
    for f in st.fields {
        if usize(f.type_index) >= types.len() { return false }
        if !(types[usize(f.type_index)] is BcRef) { return false }
    }
    return true
}

/// Find every erased sibling layout of concrete struct `struct_idx` : same
/// generic group (a shared `symbol_id` for named generics, or both anonymous
/// `__Tuple_*`), same arity, and each field either identical to the concrete's
/// or an open `ref` — with at least one `ref` (else it is the same layout, not
/// a sibling). Covers both the all-`Any` form (`zip` erases every field →
/// `[Any, Any]`) and partial erasure (`enumerate` keeps the concrete `usize`
/// index, erases only the element → `[usize, Any]`). Returns [] when
/// `struct_idx` is itself the erased form.
find_erased_siblings :: fn(types: BcType[], struct_idx: i32) -> i32[] {
    out: i32[] = []
    et :: types[usize(struct_idx)]
    if et is BcStruct as exp {
        if struct_all_ref(types, exp) { return out }
        nfields :: exp.fields.len()
        // Anonymous tuples carry no source symbol — they group by the reserved
        // `__Tuple` name marker ; named generics group by a shared `symbol_id`.
        is_tuple :: "__Tuple" in exp.name
        for i in 0..<types.len() {
            if i32(i) == struct_idx { continue }
            if types[i] is BcStruct as cand {
                if cand.fields.len() != nfields { continue }
                same_group :: (exp.symbol_id >= 0 && cand.symbol_id == exp.symbol_id) ||
                              (is_tuple && ("__Tuple" in cand.name))
                if same_group {
                    ok := true
                    any_ref := false
                    for fi in 0..<nfields {
                        ef :: exp.fields[fi]
                        cf :: cand.fields[fi]
                        if types[usize(cf.type_index)] is BcRef {
                            any_ref = true
                        } else if cf.type_index != ef.type_index {
                            ok = false
                        }
                    }
                    if ok && any_ref { out.push(i32(i)) }
                }
            }
        }
    }
    return out
}

/// Read field `field_index` of the erased sibling struct `sib_idx` off `recv`,
/// converting it to the concrete field's storage `target_val` : unbox a boxed
/// sibling field into a primitive / string, box a concrete sibling field into a
/// ref slot, or copy when both are boxed.
erased_sibling_field_read :: fn(s: FnState, sib_idx: i32, field_index: i32, target_val: ValType, recv: string) -> string {
    types :: s.ctx.module.types
    st :: types[usize(sib_idx)]
    if st is BcStruct as sib {
        sib_cname :: s.ctx.struct_c_names[usize(sib_idx)]
        sf :: sib.fields[usize(field_index)]
        sf_val :: val_type_of_field(types, sf.type_index)
        raw :: "((${sib_cname}*) ${recv}.payload.obj)->f_${sanitise(sf.name)}"
        if target_val == sf_val { return raw }
        if is_ref_like_val(target_val) { return box_expr(raw, sf_val, sf.type_index) }
        if is_ref_like_val(sf_val) { return unbox_expr(raw, target_val) }
        return raw
    }
    return "0"
}

/// `struct.set` / `struct.set_stack` — pop the field value then the
/// receiver, write the body slot in place, then fire the generational write
/// barrier so a later minor rescans this object's slots. Value-type mismatch
/// self-guards with `todo` (B1 nullable-ref fields are T12).
///
/// The barrier is mandatory on `struct.set`: mutating an old object's field to
/// reference a young object creates an old→young edge whose card must be marked
/// dirty, else `scan_old_dirty_cards` skips the object and the young referent
/// goes stale when the next minor moves it. `struct.set_stack` opts out — the
/// lowerer's escape analysis proved the receiver is stack-allocated, so the
/// macro's `in old?` test would always be false anyway.
emit_struct_set :: fn(s: FnState, op: vm.StructSet) -> void {
    t :: s.ctx.module.types[usize(op.type_id)]
    if t is BcStruct as st {
        cname :: s.ctx.struct_c_names[usize(op.type_id)]
        value :: pop(s)
        obj :: pop(s)
        f :: st.fields[usize(op.field_index)]
        rv :: coerce_expr(s.ctx.module.types, name_of(value), val_of(value), val_type_of_field(s.ctx.module.types, f.type_index))
        line(s, "((${cname}*) ${name_of(obj)}.payload.obj)->f_${sanitise(f.name)} = ${rv};")
        if !op.stack {
            line(s, "VADER_WRITE_BARRIER((${cname}*) ${name_of(obj)}.payload.obj);")
        }
    } else {
        todo("struct.set on non-struct type ${op.type_id}")
    }
}

/// `ref.cast` — re-tag the top value to `type_id`'s storage class :
/// unbox when the source is a boxed `ref` / `any`, else a plain C cast.
/// Materialised into a fresh temp (the lowerer emits it after `local.field`
/// to pin a field's type).
emit_ref_cast :: fn(s: FnState, op: vm.RefCast) -> void {
    v :: pop(s)
    target_val :: val_type_of_bc_type(s.ctx.module.types[usize(op.type_id)])
    expr :: if val_of(v) == ValType.Ref || val_of(v) == ValType.Any {
        unbox_expr(name_of(v), target_val)
    } else {
        "(${c_type_for_val_bare(target_val)}) ${name_of(v)}"
    }
    push_into_tmp(s, expr, target_val)
}

/// Box a concrete primitive on the stack into a `vader_box_t` tagged with the
/// op's SEMANTIC `type_id`. Unlike the implicit return-coercion (which only has
/// the coarse `ValType` and picks `primitive_tag_of`), this uses the precise
/// type so a downstream `is usize` / `is i64` narrowing matches. A value that
/// is already a ref (the erased-field case) is left as-is.
emit_box_op :: fn(s: FnState, op: vm.Box) -> void {
    v :: pop(s)
    if val_of(v) == ValType.Ref || val_of(v) == ValType.Any {
        push_into_tmp(s, name_of(v), ValType.Ref)
        return
    }
    push_into_tmp(s, box_expr(name_of(v), val_of(v), op.type_id), ValType.Ref)
}

// ---- arrays ---------------------------------------------------------------
//
// Arrays are heap `vader_array_t` (so an array-bearing fn is may-alloc →
// framed, T4b). Elements are stored BOXED : `vader_array_new` records the
// element's storage kind + tag, and each slot holds a `vader_box_t`. So
// `array.get` pushes an `.Any` box that the lowerer's following `ref.cast`
// unboxes ; `array.new` / `set` / `push` box the value with the ELEMENT
// type's tag (not the array's) so virtual dispatch on a value read back
// sees the right tag.

/// `array.new` — allocate a `vader_array_t` of `op.length` elements, store
/// each (boxed with the element tag), box the buffer. Pops elements
/// right-to-left into source order.
// ---- memory opcodes (Target ABI, bytes-only Buffer) ----------------------

/// `object_new` — allocate a fresh zeroed `vader_buffer_t` of the popped byte
/// size, push the boxed reference. The `type_id` immediate tags the box
/// (informational — the heap object always carries the BUFFER sentinel). The
/// size operand is a primitive, so there is no in-flight reference to root
/// across the allocation.
emit_object_new :: fn(s: FnState, op: vm.ObjectNew) -> void {
    size :: pop(s)
    name :: fresh_tmp(s, .Ref)
    // Tag the box with the BUFFER sentinel — NOT `op.type_id`. The box tag must
    // equal the heap object's header type_index, because the GC forwards a
    // boxed reference via `boxp->tag` (vader_runtime.c, vader_gc_forward) to
    // size the copy. A mismatch sizes the move off the wrong type and corrupts
    // the bytes across a collection (G1). `vader_buffer_new` inits the header to
    // the same sentinel.
    line(s, "${name} = vader_box_obj(VADER_TYPE_INDEX_BUFFER, vader_buffer_new((size_t) ${name_of(size)}));")
    push_tmp(s, name, .Ref)
}

/// Shared body of the typed byte loads (`load_u8` / `load_i32` / `load_i64` /
/// `load_f64`). Pops `obj` + `off`, re-derives the buffer pointer from its
/// rooted box (G1 — never cached across an allocating op), reads via `helper`,
/// pushes the result with stack class `result`.
/// `(vader_buffer_t*) <box>.payload.obj` — the buffer pointer behind a popped
/// reference, shared by the load / store / copy emitters.
buf_ptr :: fn(v: StackVal) = "(vader_buffer_t*) ${name_of(v)}.payload.obj"

emit_buffer_load :: fn(s: FnState, helper: string, result: ValType) -> void {
    off :: pop(s)
    obj :: pop(s)
    name :: fresh_tmp(s, result)
    line(s, "${name} = ${helper}(${buf_ptr(obj)}, (size_t) ${name_of(off)});")
    push_tmp(s, name, result)
}

/// Shared body of the typed byte stores. Pops `obj` + `off` + `value` and
/// writes `value` (cast to the byte width by `cast`) via `helper`. No write
/// barrier — the byte region holds no references.
emit_buffer_store :: fn(s: FnState, helper: string, cast: string) -> void {
    value :: pop(s)
    off :: pop(s)
    obj :: pop(s)
    line(s, "${helper}(${buf_ptr(obj)}, (size_t) ${name_of(off)}, ${cast} ${name_of(value)});")
}

/// `memory_copy` — pop `dst, dst_off, src, src_off, n` and copy `n` bytes
/// (memmove semantics, overlap-safe).
emit_memory_copy :: fn(s: FnState) -> void {
    n :: pop(s)
    src_off :: pop(s)
    src :: pop(s)
    dst_off :: pop(s)
    dst :: pop(s)
    line(s, "vader_buffer_memory_copy(${buf_ptr(dst)}, (size_t) ${name_of(dst_off)}, ${buf_ptr(src)}, (size_t) ${name_of(src_off)}, (size_t) ${name_of(n)});")
}

/// `buffer_to_string` — pop buffer + `len`, intern the buffer's leading `len`
/// bytes as a string in a single copy (no read-back). Verbatim-bytes intern,
/// identical semantics to `bytes_to_string` over a `u8[]` (neither validates
/// UTF-8). The buffer pointer is re-derived from its rooted box (G1) ;
/// `vader_string_new` interns via host `malloc`, so no GC move occurs in the call.
emit_buffer_to_string :: fn(s: FnState) -> void {
    len :: pop(s)
    obj :: pop(s)
    push_into_tmp(s, "vader_buffer_intern_string(${buf_ptr(obj)}, (size_t) ${name_of(len)})", .String)
}

/// `buffer_write_string` — pop buffer + `off` + string, memcpy the string's
/// bytes into the buffer at `off` (no push). The string operand is coerced to a
/// `vader_string_t` (unboxed when it arrives as an erased `any`).
emit_buffer_write_string :: fn(s: FnState) -> void {
    str :: pop(s)
    off :: pop(s)
    obj :: pop(s)
    src :: coerce_operand(s.ctx.module.types, name_of(str), val_of(str), .String)
    line(s, "vader_buffer_write_string(${buf_ptr(obj)}, (size_t) ${name_of(off)}, ${src});")
}

// ---- array slot access (Target ABI S5) -----------------------------------

// `((vader_array_t*) <box>.payload.obj)` — the array header behind a popped
// `T[]` reference. The slot ops receive the ARRAY (the `@intrinsic`s are impl'd
// on `T[]`, which knows the element type) and deref `->buf` + apply `->offset`
// internally, so slice views (offset > 0) address the parent's slots correctly.
// Slot ops are INDEX-addressed (the `[i]` cast applies the element stride),
// distinct from the byte-offset bytes-Buffer ops. Outer parens bind `->buf`.
array_hdr_ptr :: fn(v: StackVal) = "((vader_array_t*) ${name_of(v)}.payload.obj)"

// The absolute slot index into the array's buf : `arr->offset + i`.
slot_index :: fn(arr: string, idx: StackVal) = "${arr}->offset + (size_t) ${name_of(idx)}"

/// `load_slot` (boxed) — pop array + slot index, push the boxed `Value` at that
/// slot. The result is a traced reference (stack class `.Ref`).
emit_slot_load_boxed :: fn(s: FnState) -> void {
    idx :: pop(s)
    obj :: pop(s)
    arr :: array_hdr_ptr(obj)
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_array_box_slots(${arr}->buf)[${slot_index(arr, idx)}];")
    push_tmp(s, name, .Ref)
}

/// `store_slot` (boxed) — pop array + slot index + value box ; store it and fire
/// the generational write barrier (G2) on the buf (the object that owns the
/// slot) — the boxed slot may record an old→young edge the minor collector
/// must see.
emit_slot_store_boxed :: fn(s: FnState) -> void {
    value :: pop(s)
    idx :: pop(s)
    obj :: pop(s)
    arr :: array_hdr_ptr(obj)
    line(s, "vader_array_box_slots(${arr}->buf)[${slot_index(arr, idx)}] = ${name_of(value)};")
    line(s, "VADER_WRITE_BARRIER(${arr}->buf);")
}

/// Bind a `vader_array_t*` C local to `obj` and emit the access guards shared by
/// the primitive slot load/store : the G1 buf-forwarding resolve (the array box
/// is a gc_root so the array itself is current, but a minor may have relocated
/// its buf — follow the forward pointer like `vader_array_get`) and the D7
/// always-on bounds check (trap on out-of-range). Returns the local's name.
emit_slot_array_local :: fn(s: FnState, obj: StackVal, idx: StackVal) -> string {
    key :: array_hdr_ptr(obj)
    cached :: s.resolved_arrays[key]
    arr := ""
    if cached is string as c {
        // Reuse the resolve from an earlier access on this array in this
        // straight-line region : skip the buf-forward walk + the array_t* extract
        // (cc -O3 then CSEs the `->buf->slots` derefs — the arr_rw native win). The
        // cache is dropped at any GC safepoint / control-flow op / reassignment of
        // the array's local.
        arr = c
    } else {
        arr = aux(s, "slotarr")
        line(s, "vader_array_t* ${arr} = ${key};")
        line(s, "while (${arr}->buf != NULL && ${arr}->buf->header.forward != NULL) { ${arr}->buf = (vader_array_buf_t*) ${arr}->buf->header.forward; }")
        s.resolved_arrays[key] = arr
    }
    // Bounds is always per-access (the reused resolve only shares the buffer walk).
    line(s, "if ((size_t) ${name_of(idx)} >= ${arr}->length) { vader_trap(\"array index out of bounds\"); }")
    return arr
}

/// Primitive slot load — pop array + slot index, read the `cty`-typed element
/// at `arr->buf->slots[arr->offset + i]`, push it with stack class `result`.
/// Bounds-checked + buf-forward-resolved (see `emit_slot_array_local`).
emit_slot_load_prim :: fn(s: FnState, cty: string, result: ValType) -> void {
    idx :: pop(s)
    obj :: pop(s)
    a :: emit_slot_array_local(s, obj, idx)
    name :: fresh_tmp(s, result)
    line(s, "${name} = ((${cty}*) ${a}->buf->slots)[${slot_index(a, idx)}];")
    push_tmp(s, name, result)
}

/// Emit one typed (non-boxed) slot store : `((cty*) a->buf->slots)[a->offset + i]
/// = (cty) <coerced value>`. Shared by the `StoreSlot*` opcode handler
/// (`emit_slot_store_prim`) and the open-coded array set (`emit_array_set`) — both
/// reach the same `(a, idx, value, cty, val)` state after their own pop +
/// `emit_slot_array_local`. No write barrier (a primitive slot holds no reference).
/// The value is coerced to `val` first (unboxing an erased `Any` box).
emit_typed_slot_write :: fn(s: FnState, a: string, idx: StackVal, value: StackVal, cty: string, val: ValType) -> void {
    vc :: coerce_expr(s.ctx.module.types, name_of(value), val_of(value), val)
    line(s, "((${cty}*) ${a}->buf->slots)[${slot_index(a, idx)}] = (${cty}) ${vc};")
}

/// Primitive slot store — pop array + slot index + value ; write the `cty`-typed
/// element. No write barrier (the primitive region holds no references).
/// Bounds-checked + buf-forward-resolved (see `emit_slot_array_local`).
emit_slot_store_prim :: fn(s: FnState, cty: string, val: ValType) -> void {
    value :: pop(s)
    idx :: pop(s)
    obj :: pop(s)
    a :: emit_slot_array_local(s, obj, idx)
    emit_typed_slot_write(s, a, idx, value, cty, val)
}

/// C type + coerce-target stack class for a typed (non-boxed) array slot store.
/// The `cty` is the element's native storage type ; `val` is the stack class the
/// stored value is coerced to before the `(cty)` cast. Returns `null` for the
/// `Boxed` kind ONLY — every primitive width (flippable AND sub-word) stores raw
/// here, so `typed_array_fill_for(k) == null` is the canonical "is this array
/// boxed?" test shared by construction (`emit_array_new`) and access
/// (`emit_array_get`/`emit_array_set`). The flippable widths keep their A2/C2
/// shape (`u32`/`char` store as `int32_t`, same bytes, so the typed read reads
/// back identical bits) ; the sub-word widths use the signedness-correct C type
/// (`uint16_t`/`int16_t`/`float`/…) so a later typed read zero/sign-extends right.
SlotFill :: struct { cty: string, val: ValType }

typed_array_fill_for :: fn(k: ArrayKind) -> SlotFill | null = match k {
    .I32   -> SlotFill { .cty = "int32_t",  .val = .I32 }
    .U32   -> SlotFill { .cty = "int32_t",  .val = .I32 }
    .Char  -> SlotFill { .cty = "int32_t",  .val = .I32 }
    .I64   -> SlotFill { .cty = "int64_t",  .val = .I64 }
    .U64   -> SlotFill { .cty = "int64_t",  .val = .I64 }
    .F64   -> SlotFill { .cty = "double",   .val = .F64 }
    .U8    -> SlotFill { .cty = "uint8_t",  .val = .I32 }
    .I8    -> SlotFill { .cty = "int8_t",   .val = .I32 }
    .Bool  -> SlotFill { .cty = "uint8_t",  .val = .Bool }
    .U16   -> SlotFill { .cty = "uint16_t", .val = .I32 }
    .I16   -> SlotFill { .cty = "int16_t",  .val = .I32 }
    .F32   -> SlotFill { .cty = "float",    .val = .F32 }
    .Boxed -> null
}

// `data.const N` — push a zero-copy box over the immortal `.rodata` array
// `vader_data_N` (emitted by `emit_data_pool`). Re-stamps the call-site type_id
// onto the box, mirroring the VM's `DataConst` arm + the static-fn-ref box.
emit_data_const_op :: fn(s: FnState, op: vm.DataConst) -> void {
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${op.type_id}u, (void*) &vader_data_${op.pool_index});")
    push_tmp(s, name, .Ref)
}

emit_array_new :: fn(s: FnState, op: vm.ArrayNew) -> void {
    types :: s.ctx.module.types
    elem_tag :: array_element_tag(types, op.type_id)
    kind :: array_kind_of(types[usize(elem_tag)])
    kind_idx :: array_kind_index(kind)
    n :: op.length
    arr_buf :: aux(s, "arr")
    line(s, "vader_array_t* ${arr_buf} = vader_array_new(${op.type_id}u, ${n}u, ${kind_idx}u, ${elem_tag}u);")
    // Pop top-to-bottom : pop #k fills slot `n-1-k` (distinct indices, so reverse
    // emission is fine). Two strategies keyed on `typed_array_fill_for(kind)` : a
    // typed raw store for any primitive width (flippable C2 + sub-word Inc2), else
    // (Boxed) an inline box-slot write — op-B's access store minus the barrier (a
    // fresh-young construction buf can't alias a promoted-old one). No store can
    // GC, so the raw `arr_buf` survives the loop and no barrier is ever needed.
    fill :: typed_array_fill_for(kind)
    for k in 0..<n {
        v :: pop(s)
        slot :: n - 1 - k
        if fill != null {
            vc :: coerce_expr(types, name_of(v), val_of(v), fill.val)
            line(s, "((${fill.cty}*) ${arr_buf}->buf->slots)[${arr_buf}->offset + ${slot}u] = (${fill.cty}) ${vc};")
        } else {
            line(s, "vader_array_box_slots(${arr_buf}->buf)[${arr_buf}->offset + ${slot}u] = ${box_expr(name_of(v), val_of(v), elem_tag)};")
        }
    }
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${op.type_id}u, ${arr_buf});")
    push_tmp(s, name, .Ref)
}

/// `array.get` — pop index + array, push the element as a boxed `.Any` (the
/// lowerer's following `ref.cast` re-tags / unboxes it). Fully open-coded over
/// the kept `vader_array_t` layout, no `vader_array_get` call. Three read paths,
/// keyed off `typed_array_fill_for(kind)` + the kind :
///   - Boxed → an inline box-slot read (op B).
///   - `u8` → the borrowed-aware `vader_array_read_u8` inline (a `bytes()` view,
///     `buf == NULL`, reads the atom table with the runtime borrowed tag ; a real
///     `u8[]` reads its slots). It is `static inline`, so no `vader_*` symbol is
///     added and the read inlines at -O3 (§5 C-emit convention).
///   - any other sub-word width → an inline typed read, re-boxed via `box_expr`
///     (the uint/int/float promotion mirrors `vader_array_load_slot`).
/// `emit_slot_array_local` (G1 forward-resolve + D7 bounds) is hoisted before the
/// branch — borrowed-safe (its forward loop is guarded on `buf != NULL` and the
/// bounds check reads the header). Flippable widths never reach here (midir
/// routes them to `LoadSlot*`).
emit_array_get :: fn(s: FnState, op: vm.ArrayGet) -> void {
    idx :: pop(s)
    arr :: pop(s)
    types :: s.ctx.module.types
    elem_tag :: array_element_tag(types, op.type_id)
    kind :: array_kind_of(types[usize(elem_tag)])
    fill :: typed_array_fill_for(kind)
    a :: emit_slot_array_local(s, arr, idx)
    name :: fresh_tmp(s, .Any)
    if fill == null {
        line(s, "${name} = vader_array_box_slots(${a}->buf)[${slot_index(a, idx)}];")
    } else if kind == .U8 {
        line(s, "${name} = vader_array_read_u8(${a}, ${slot_index(a, idx)}, ${elem_tag}u);")
    } else {
        line(s, "${name} = ${box_expr("((${fill.cty}*) ${a}->buf->slots)[${slot_index(a, idx)}]", fill.val, elem_tag)};")
    }
    push_tmp(s, name, .Any)
}

/// `array.set` — pop value + index + array, store the value in place. A Boxed
/// element stores the slot inline (`box_expr` tags `string`, no-op for already-
/// boxed refs) + fires the G2 write barrier ; a typed (sub-word) element stores
/// the native width raw (no barrier — primitives hold no refs). Flippable widths
/// never reach here (midir routes them to `StoreSlot*`). Borrowed `bytes()` views
/// are read-only (T3042), so `a->buf` is never NULL on this path.
emit_array_set :: fn(s: FnState, op: vm.ArraySet) -> void {
    value :: pop(s)
    idx :: pop(s)
    arr :: pop(s)
    types :: s.ctx.module.types
    elem_tag :: array_element_tag(types, op.type_id)
    kind :: array_kind_of(types[usize(elem_tag)])
    fill :: typed_array_fill_for(kind)
    a :: emit_slot_array_local(s, arr, idx)
    if fill == null {
        line(s, "vader_array_box_slots(${a}->buf)[${slot_index(a, idx)}] = ${box_expr(name_of(value), val_of(value), elem_tag)};")
        line(s, "VADER_WRITE_BARRIER(${a}->buf);")
    } else {
        emit_typed_slot_write(s, a, idx, value, fill.cty, fill.val)
    }
}

/// `array.push` — pop value + array, append the value (boxed). Here
/// `op.type_id` is the ELEMENT type directly (not the array type).
emit_array_push :: fn(s: FnState, op: vm.ArrayPush) -> void {
    value :: pop(s)
    arr :: pop(s)
    line(s, "vader_array_push((vader_array_t*) ${name_of(arr)}.payload.obj, ${box_expr(name_of(value), val_of(value), op.type_id)});")
}

/// `array.len` — pop array, push its `usize` length.
///
/// Target ABI S5 (inc-3) : reads the `length` header field inline instead of
/// calling the runtime accessor — `vader_array_len` is `a->length`, so the
/// open-coded read is byte-equivalent (no buf deref, no forward-resolve : the
/// length lives on the array header, which is the live gc_root). Drops the
/// codegen dependency on `vader_array_len`.
emit_array_len :: fn(s: FnState) -> void {
    arr :: pop(s)
    name :: fresh_tmp(s, .Usize)
    line(s, "${name} = ${array_hdr_ptr(arr)}->length;")
    push_tmp(s, name, .Usize)
}

/// `array.slice` — pop array + lo + hi, push a fresh array header over the
/// `[lo, hi)` range (the C runtime views ; the VM copies).
emit_array_slice :: fn(s: FnState, op: vm.ArraySlice) -> void {
    hi :: pop(s)
    lo :: pop(s)
    arr :: pop(s)
    arr_buf :: aux(s, "arr")
    line(s, "vader_array_t* ${arr_buf} = vader_array_slice((vader_array_t*) ${name_of(arr)}.payload.obj, (size_t) ${name_of(lo)}, (size_t) ${name_of(hi)});")
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${op.type_id}u, ${arr_buf});")
    push_tmp(s, name, .Ref)
}

/// `[lhs] * n` — pop `n` then the source array ; push a fresh array repeating
/// the source's elements n times (`[] * n` reserves n slots, length 0). The
/// result is boxed with the runtime array's OWN `header.type_index` (set by the
/// runtime from the source), so no static element type_id is threaded through
/// the op. Allocating + GC-coupled, hence a runtime call (not open-coded).
emit_array_repeat :: fn(s: FnState) -> void {
    n :: pop(s)
    src :: pop(s)
    arr_buf :: aux(s, "arr")
    line(s, "vader_array_t* ${arr_buf} = vader_array_repeat((vader_array_t*) ${name_of(src)}.payload.obj, (size_t) ${name_of(n)});")
    name :: fresh_tmp(s, .Ref)
    line(s, "${name} = vader_box_obj(${arr_buf}->header.type_index, ${arr_buf});")
    push_tmp(s, name, .Ref)
}

/// `dst.push_all(src)` — pop `src` then `dst` ; append every element of `src` to
/// `dst`. Statement-form, no value pushed back. Runtime call (grows + GC).
emit_array_push_all :: fn(s: FnState) -> void {
    src :: pop(s)
    dst :: pop(s)
    line(s, "vader_array_push_all((vader_array_t*) ${name_of(dst)}.payload.obj, (vader_array_t*) ${name_of(src)}.payload.obj);")
}

/// `src.copy_to(src_start, dst, dst_start, len)` — pop `len` / `dst_start` /
/// `dst` / `src_start` / `src` (top-to-bottom) ; overlap-safe positional copy.
/// Statement-form. No allocation in the runtime fn, but a plain runtime call.
emit_array_copy :: fn(s: FnState) -> void {
    len :: pop(s)
    dst_start :: pop(s)
    dst :: pop(s)
    src_start :: pop(s)
    src :: pop(s)
    line(s, "vader_array_copy((vader_array_t*) ${name_of(src)}.payload.obj, (size_t) ${name_of(src_start)}, (vader_array_t*) ${name_of(dst)}.payload.obj, (size_t) ${name_of(dst_start)}, (size_t) ${name_of(len)});")
}

/// `arr.remove_last()` — pop an array ; push the removed last element as a boxed
/// `T | null` (the runtime returns `vader_box_null()` when empty, else a box
/// pre-tagged with the element's static tag — so `.Any`, no follow-up cast).
emit_array_remove_last :: fn(s: FnState) -> void {
    arr :: pop(s)
    name :: fresh_tmp(s, .Any)
    line(s, "${name} = vader_array_remove_last((vader_array_t*) ${name_of(arr)}.payload.obj);")
    push_tmp(s, name, .Any)
}

/// `arr.clear()` — pop an array ; set its length to 0. Statement-form.
emit_array_clear :: fn(s: FnState) -> void {
    arr :: pop(s)
    line(s, "vader_array_clear((vader_array_t*) ${name_of(arr)}.payload.obj);")
}

/// Element BcType index of array type `type_index` (the `BcArray.element`),
/// or `type_index` itself when it isn't an array (defensive — the lowerer
/// only emits these ops on array types).
array_element_tag :: fn(types: BcType[], type_index: i32) -> i32 {
    t :: types[usize(type_index)]
    if t is BcArray as a { return a.element }
    return type_index
}

// ---- strings --------------------------------------------------------------
//
// Strings are interned atoms (`vader_string_t` = `u32`), so `string.eq` / `.ne`
// are plain `==` / `!=` (atom identity == value equality). Codepoint slicing
// (`s[lo..<hi]`) routes to `vader_string_slice_codepoints` (a kept zero-copy
// atom-slice primitive ; `emit_string_slice`). Concatenation (`+`), `Display`,
// and `${…}` interpolation are now pure Vader (StringBuilder over a byte
// `Buffer`) — no string/builder runtime family here anymore. `ref.eq` compares
// boxed `ref` / `any` via `vader_box_eq`.

/// Push a boxed-reference equality (`ref.eq` / `ref.ne`). C can't compare
/// `vader_box_t` with `==`, so route through `vader_box_eq` (tag + payload
/// word) ; `!=` negates it.
push_binop_any :: fn(s: FnState, op: string, result_val: ValType) -> void {
    r :: pop(s)
    l :: pop(s)
    neg :: if op == "!=" { "!" } else { "" }
    push_expr(s, result_val, "${neg}vader_box_eq(${name_of(l)}, ${name_of(r)})")
}

/// `string.slice_codepoints` — pop string + lo + hi, push the codepoint
/// substring (a fresh interned string).
emit_string_slice :: fn(s: FnState) -> void {
    hi :: pop(s)
    lo :: pop(s)
    str :: pop(s)
    push_into_tmp(s, "vader_string_slice_codepoints(${name_of(str)}, ${name_of(lo)}, ${name_of(hi)})", .String)
}

