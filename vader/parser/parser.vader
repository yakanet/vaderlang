// vader/parser/parser — recursive-descent parser + Pratt expression parser.
// Public entry : parse_source(source, file) -> ParsedSource { program, errors }.
// Errors flow into the parser's `errors` array ; after an error the parser
// synchronises on `}` / top-level keywords / NEWLINE so it can keep going.

module "vader/parser"

import "std/string" { byte_at, byte_len, byte_slice, starts_with, chars, is_digit }
import "vader/lexer" {
    tokenize, Token, TokenKind, Lexer, empty_span, make_token, kind_name,
}
import "vader/diagnostics" { Diagnostic, Position, parser_error }
import "vader/diagnostics" { ParserCode }

// ============================================================================
// Public entry
// ============================================================================

export ParsedSource :: struct {
    program:    Program
    tokens:     Token[]
    errors:     Diagnostic[]
    /// Carries the factory state after the post-parse ID walk so
    /// downstream cloners (e.g. `materialize.vader`) can mint
    /// non-colliding IDs in the same namespace.
    id_factory: NodeIdFactory
}

export parse_source :: fn(source: string, file: string) -> ParsedSource {
    l :: tokenize(source, file)
    p := new_parser(l.tokens, file)
    // Carry lexer diagnostics through so the snapshot shows both phases.
    for e in l.errors { p.errors.push(e) }
    program :: parse_program(p)
    // Mint stable IDs for every node — downstream side-tables key on
    // `node.id` rather than on stringified spans (which collide when
    // materialise clones default-method bodies). See `assign_ids.vader`.
    id_factory :: new_node_id_factory()
    assign_program_ids(program, id_factory)
    return ParsedSource {
        .program    = program,
        .tokens     = l.tokens,
        .errors     = p.errors,
        .id_factory = id_factory,
    }
}

/// Header-only parse : byte-scan the file's prologue for the
/// `module "<name>"` decl. The full lexer + parser are too expensive
/// to run on every file under the scoped roots (the Vader self-host's
/// GC arenas can't hold ~170 tokenized Token[] arrays at once) ; this
/// hand-rolled scanner only reads the prologue, skipping shebang +
/// line comments + block comments + whitespace, then matches the
/// soft-keyword `module` followed by a double-quoted string.
///
/// Returns null when no decl is found (the caller treats that as
/// R2020 territory). The returned span carries only the file path —
/// a precise span would require char-by-char position tracking
/// across the scanner, which isn't worth the cost for diagnostics
/// the resolver re-resolves at its own pass anyway.
export ModuleHeader :: struct {
    name:      string
    name_span: Span
}

export parse_module_header :: fn(source: string, file: string) -> ModuleHeader | null {
    n :: source.byte_len()
    i: usize = 0
    // Optional shebang on first line.
    if i + usize(1) < n && source.byte_at(i) == u8(0x23) && source.byte_at(i + usize(1)) == u8(0x21) {
        i = skip_to_eol(source, i, n)
    }
    // Skip whitespace + line/block comments until we hit the first
    // non-trivial token. Bail out early past a reasonable header-size
    // budget to avoid scanning the entire file when no decl exists.
    budget :: header_budget(n)
    for i < budget {
        c :: source.byte_at(i)
        if c == u8(0x20) || c == u8(0x09) || c == u8(0x0A) || c == u8(0x0D) {
            i = i + usize(1)
            continue
        }
        // Line comment `// ...`
        if c == u8(0x2F) && i + usize(1) < n && source.byte_at(i + usize(1)) == u8(0x2F) {
            i = skip_to_eol(source, i, n)
            continue
        }
        // Block comment `/* ... */`
        if c == u8(0x2F) && i + usize(1) < n && source.byte_at(i + usize(1)) == u8(0x2A) {
            i = skip_block_comment(source, i + usize(2), n)
            continue
        }
        break
    }
    // Match `module "<name>"` at the current position. Anything else
    // means no header decl (callers may still treat it as a tolerant
    // pre-Phase-7 file).
    if i + usize(7) > n { return null }
    if source.byte_at(i)     != u8(0x6D) { return null }     // m
    if source.byte_at(i + usize(1)) != u8(0x6F) { return null }     // o
    if source.byte_at(i + usize(2)) != u8(0x64) { return null }     // d
    if source.byte_at(i + usize(3)) != u8(0x75) { return null }     // u
    if source.byte_at(i + usize(4)) != u8(0x6C) { return null }     // l
    if source.byte_at(i + usize(5)) != u8(0x65) { return null }     // e
    i = i + usize(6)
    // Whitespace between `module` and the string literal.
    for i < n {
        c :: source.byte_at(i)
        if c == u8(0x20) || c == u8(0x09) {
            i = i + usize(1)
            continue
        }
        break
    }
    if i >= n || source.byte_at(i) != u8(0x22) { return null }      // opening "
    i = i + usize(1)
    name_start :: i
    for i < n && source.byte_at(i) != u8(0x22) { i = i + usize(1) }
    if i >= n { return null }                                       // unterminated
    name :: byte_slice(source, name_start, i)
    return ModuleHeader { .name = name, .name_span = empty_span(file) }
}

// Scan budget — most module decls land in the first 1 KB ; bail past
// 4 KB to stay O(1) memory regardless of file size when the prologue
// looks malformed.
header_budget :: fn(n: usize) -> usize {
    cap :: usize(4096)
    if n < cap { return n }
    return cap
}

skip_to_eol :: fn(source: string, from: usize, n: usize) -> usize {
    i := from
    for i < n && source.byte_at(i) != u8(0x0A) { i = i + usize(1) }
    if i < n { i = i + usize(1) }
    return i
}

skip_block_comment :: fn(source: string, from: usize, n: usize) -> usize {
    i := from
    depth: i32 = 1
    for i + usize(1) < n && depth > 0 {
        c0 :: source.byte_at(i)
        c1 :: source.byte_at(i + usize(1))
        if c0 == u8(0x2F) && c1 == u8(0x2A) {
            depth = depth + 1
            i = i + usize(2)
            continue
        }
        if c0 == u8(0x2A) && c1 == u8(0x2F) {
            depth = depth - 1
            i = i + usize(2)
            continue
        }
        i = i + usize(1)
    }
    return i
}

// ============================================================================
// Parser state
// ============================================================================

export Parser :: struct {
    tokens: Token[]
    file:   string
    pos:    i32
    errors: Diagnostic[]
    // True except inside the immediate condition expression of if/for/match.
    allow_struct_lit: bool
}

new_parser :: fn(tokens: Token[], file: string) = Parser {
    .tokens           = tokens,
    .file             = file,
    .pos              = 0,
    .errors           = [],
    .allow_struct_lit = true,
}

// ----------------------------------------------------------- token helpers

peek :: fn(p: Parser) -> Token {
    n :: i32(p.tokens.len())
    if p.pos < n { return p.tokens[usize(p.pos)] }
    return p.tokens[usize(n - 1)]
}

peek_at :: fn(p: Parser, offset: i32) -> Token {
    n :: i32(p.tokens.len())
    i :: p.pos + offset
    if i < 0 { return p.tokens[0] }
    if i < n { return p.tokens[usize(i)] }
    return p.tokens[usize(n - 1)]
}

check :: fn(p: Parser, kind: TokenKind) -> bool {
    return p.peek().kind == kind
}

check_at :: fn(p: Parser, kind: TokenKind, offset: i32) -> bool {
    return p.peek_at(offset).kind == kind
}

advance :: fn(p: Parser) -> Token {
    t :: p.peek()
    if p.pos < i32(p.tokens.len()) - 1 {
        p.pos = p.pos + 1
    }
    return t
}

/// Consume if matches ; return the consumed token or `null`. Callers
/// check `!= null` for the boolean path ; sites that need the token
/// bind to a local first so the narrowing flow kicks in
/// (`t :: match_kind(...) ; if t != null { use(t) }`).
match_kind :: fn(p: Parser, kind: TokenKind) -> Token | null {
    if p.check(kind) { return p.advance() }
    return null
}

/// Consume the next token if it matches `kind`, else return the current
/// token without advancing. Used by callers that need a span / position
/// fallback for a missing-but-tolerated terminator (e.g. an unterminated
/// string's `StringEnd`) without bothering with explicit null narrowing.
match_or_peek :: fn(p: Parser, kind: TokenKind) -> Token {
    matched :: p.match_kind(kind)
    if matched != null { return matched }
    return p.peek()
}

// `expect` emits a diagnostic on mismatch but does NOT advance ; mirrors TS.
expect :: fn(p: Parser, kind: TokenKind, what: string) -> Token {
    if p.check(kind) { return p.advance() }
    t :: p.peek()
    p.error(.ExpectedToken, t.span, "expected ${what} (got ${describe_token(t)})")
    return t
}

skip_newlines :: fn(p: Parser) -> void {
    for p.check(.Newline) { p.pos = p.pos + 1 }
}

// Tokens that mark the boundary of a top-level item — used for recovery.
at_top_level_start :: fn(p: Parser) -> bool {
    t :: p.peek()
    if t.kind == .KwImport || t.kind == .KwExport { return true }
    if t.kind == .Ident {
        next :: p.peek_at(1)
        if next.kind == .DeclConst || next.kind == .KwImplements { return true }
    }
    if t.kind == .At { return true }
    return false
}

sync_to_top_level :: fn(p: Parser) -> void {
    for p.peek().kind != .Eof && !p.at_top_level_start() {
        p.advance()
    }
}

// -------------------------------------------------------- error reporting

error :: fn(p: Parser, code: ParserCode, span: Span, detail: string) -> void {
    p.errors.push(parser_error(code, span, detail))
}

span_of :: fn(p: Parser, start: Token, end: Token) -> Span {
    return Span { .start = start.span.start, .end = end.span.end }
}

// ----------------------------------------------------------- describe_token

export describe_token :: fn(t: Token) -> string {
    if t.kind == .Ident { return "`${t.text}`" }
    if t.kind == .IntLit || t.kind == .FloatLit { return t.text }
    if t.kind == .Newline { return "newline" }
    if t.kind == .Eof { return "end of file" }
    if !t.text.is_empty() { return "`${t.text}`" }
    return kind_name(t.kind)
}

// ============================================================================
// Program
// ============================================================================

parse_program :: fn(p: Parser) -> Program {
    start_tok :: p.peek()
    decls: Decl[] = []
    p.skip_newlines()
    module :: p.parse_optional_module_decl()
    p.skip_newlines()
    for !p.check(.Eof) {
        d :: p.parse_decl()
        match d {
            is null           -> { p.advance() }
            is ImportDecl     -> { decls.push(d) }
            is FnDecl         -> { decls.push(d) }
            is StructDecl     -> { decls.push(d) }
            is EnumDecl       -> { decls.push(d) }
            is TraitDecl      -> { decls.push(d) }
            is ImplDecl       -> { decls.push(d) }
            is TypeAliasDecl  -> { decls.push(d) }
            is ConstDecl      -> { decls.push(d) }
            is AssertDecl     -> { decls.push(d) }
        }
        p.skip_newlines()
    }
    end_tok :: p.peek()
    return Program {
        .file   = p.file,
        .span   = Span { .start = start_tok.span.start, .end = end_tok.span.end },
        .module = module,
        .decls  = decls,
    }
}

// `module` is a *soft* keyword : it stays an `Ident` token at the
// lexer level and is only recognised here when the prologue position
// has `ident("module") + StringBegin`. Every other occurrence (struct
// field name, field-access target) keeps the regular identifier
// semantics. Parser stays tolerant ; resolver enforces presence.
parse_optional_module_decl :: fn(p: Parser) -> ModuleDecl | null {
    t :: p.peek()
    if t.kind != .Ident { return null }
    if t.text != "module" { return null }
    if !p.check_at(.StringBegin, 1) { return null }
    start :: p.advance() // consume `module`
    lit :: p.expect_string_literal("module name")
    if !is_valid_module_name(lit.text) {
        p.error(.InvalidModuleName, lit.span, "")
    }
    end_tok :: p.peek_at(-1)
    return ModuleDecl {
        .span      = p.span_of(start, end_tok),
        .name      = lit.text,
        .name_span = lit.span,
    }
}

// Hand-rolled grammar check : mirrors the TS regex
// `/^[a-z][a-z0-9_]*(\/[a-z][a-z0-9_]*)*$/` from
// `src/parser/passes/program.ts`. Avoiding `std/regex` keeps the
// parser dependency surface minimal. Predicates take `char` to align
// with the lexer's `is_ident_start` / `is_ident_continue` idiom.
is_valid_module_name :: fn(name: string) -> bool {
    expect_segment_start := true
    seen_any := false
    for c in name.chars() {
        seen_any = true
        if expect_segment_start {
            if !c.is_module_segment_start() { return false }
            expect_segment_start = false
        } else {
            if c == '/' {
                expect_segment_start = true
            } else {
                if !c.is_module_segment_continue() { return false }
            }
        }
    }
    if !seen_any { return false }
    return !expect_segment_start
}

is_module_segment_start :: fn(c: char) = c in 'a'..='z'

is_module_segment_continue :: fn(c: char) = c in 'a'..='z' || c.is_digit() || c == '_'

// ============================================================================
// Declarations
// ============================================================================

parse_decl :: fn(p: Parser) -> Decl | null {
    decorators :: p.parse_decorators()
    visibility: Visibility = .Private
    if p.match_kind(.KwExport) != null {
        visibility = .Public
    }

    // `@assert(condition)` is a "decorator-statement" that stands on its
    // own at the top level rather than annotating a following decl. Mirrors
    // `src/parser/passes/decl.ts::parseDecl` ; only the lone-decorator form
    // promotes — mixing `@comptime @assert(...)` would be ambiguous.
    if decorators.len() == 1 && decorators[0].name == "assert" {
        dec :: decorators[0]
        if dec.args.len() < 1 || dec.args.len() > 2 {
            p.error(.UnknownDecoratorPlacement, dec.span,
                "`@assert` expects 1 or 2 arguments : `@assert(cond)` or `@assert(cond, \"message\")`")
            return null
        }
        message: string | null = null
        if dec.args.len() == 2 {
            msg_arg :: dec.args[1]
            // Optional second arg : a *static* string literal (no
            // interpolation). Extract its decoded text from the single
            // `StringLitText` part, otherwise surface P1014.
            match msg_arg {
                is StringLitExpr as s -> {
                    if s.parts.len() == 1 {
                        match s.parts[0] {
                            is StringLitText as t -> { message = t.value }
                            _ -> {
                                p.error(.UnknownDecoratorPlacement, msg_arg.span,
                                    "`@assert` message must be a static string literal (no interpolation)")
                                return null
                            }
                        }
                    } else {
                        p.error(.UnknownDecoratorPlacement, msg_arg.span,
                            "`@assert` message must be a static string literal (no interpolation)")
                        return null
                    }
                }
                _ -> {
                    p.error(.UnknownDecoratorPlacement, msg_arg.span,
                        "`@assert` message must be a static string literal (no interpolation)")
                    return null
                }
            }
        }
        return AssertDecl {
            .span       = dec.span,
            .condition  = dec.args[0],
            .message    = message,
            .decorators = [],
        }
    }

    if p.check(.KwImport) {
        return p.parse_import_decl(decorators)
    }
    if p.is_impl_decl() {
        return p.parse_impl_decl(decorators)
    }
    // Generic type alias : `Name[T] :: <body>`. The `[...]` between ident
    // and `::` is unambiguous (no other decl form puts brackets there).
    if p.check(.Ident) && p.check_at(.LBracket, 1) && p.peek_is_lhs_generic_alias_head() {
        return p.parse_lhs_generic_alias_decl(decorators, visibility)
    }
    if p.check(.Ident) && p.check_at(.DeclConst, 1) {
        return p.parse_named_decl(decorators, visibility)
    }
    // Odin-style typed top-level const : `name : Type : value`.
    if p.check(.Ident) && p.check_at(.Colon, 1) {
        return p.parse_typed_const_decl(decorators, visibility)
    }
    t :: p.peek()
    p.error(.ExpectedDeclaration, t.span, "got ${describe_token(t)}")
    p.sync_to_top_level()
    return null
}

parse_decorators :: fn(p: Parser) -> Decorator[] {
    out: Decorator[] = []
    for p.check(.At) {
        at :: p.advance()
        name_tok :: p.expect(.Ident, "decorator name after `@`")
        args: Expr[] = []
        if p.match_kind(.LParen) != null {
            if !p.check(.RParen) {
                first := true
                for {
                    if !first {
                        if p.match_kind(.Comma) == null { break }
                        if p.check(.RParen) { break }
                    }
                    first = false
                    args.push(p.parse_expr(0))
                }
            }
            p.expect(.RParen, "`)` after decorator arguments")
        }
        out.push(Decorator {
            .span = p.span_of(at, p.peek_at(-1)),
            .name = name_tok.text,
            .args = args,
        })
        p.skip_newlines()
    }
    return out
}

/// Statement-position `import "..." { a, b }`. Rejects the legacy bare
/// `import "..."` (implicit-last-segment) and `import "..." as name`
/// forms — both are now spelled `name :: import "..."`.
parse_import_decl :: fn(p: Parser, decorators: Decorator[]) -> ImportDecl {
    start :: p.advance()  // `import`
    path_info :: p.expect_string_literal("import path")

    if p.check(.KwAs) {
        as_tok :: p.peek()
        p.error(.ExpectedDeclaration, as_tok.span,
            "the `import \"...\" as name` form was removed ; write `name :: import \"...\"` instead")
        p.advance()
        if p.check(.Ident) { p.advance() }
    }

    names: ImportName[] = []
    if p.match_kind(.LBrace) == null {
        p.error(.ExpectedDeclaration, p.peek().span,
            "the bare `import \"...\"` form was removed ; use either `name :: import \"...\"` for a namespace binding or `import \"...\" { a, b }` to destructure")
    } else {
        names = p.parse_import_name_list_rest()
    }
    return ImportDecl {
        .span       = p.span_of(start, p.peek_at(-1)),
        .path       = path_info.text,
        .binding    = DestructureImport { .names = names },
        .decorators = decorators,
    }
}

/// Named-decl-position `name :: import "..."` (with optional scoped
/// `{ a, b, c }`). Routed from `parse_named_decl` when the RHS keyword
/// after `::` is `import`.
parse_named_import_decl :: fn(p: Parser, decorators: Decorator[], name_tok: Token) -> ImportDecl {
    p.advance()  // `import`
    path_info :: p.expect_string_literal("import path")
    restricted: ImportName[] | null = null
    if p.match_kind(.LBrace) != null {
        // `name :: import "..." { a, b }` — scoped namespace. Only the
        // listed names are reachable via `name.X`.
        restricted = p.parse_import_name_list_rest()
    }
    return ImportDecl {
        .span       = p.span_of(name_tok, p.peek_at(-1)),
        .path       = path_info.text,
        .binding    = NamedNamespaceImport { .name = name_tok.text, .restricted = restricted },
        .decorators = decorators,
    }
}

/// Parse `a, b as c` …` with the leading `{` already consumed. Closes
/// on the matching `}`.
parse_import_name_list_rest :: fn(p: Parser) -> ImportName[] {
    names: ImportName[] = []
    p.skip_newlines()
    if !p.check(.RBrace) {
        first := true
        for {
            if !first {
                if p.match_kind(.Comma) == null { break }
            }
            first = false
            p.skip_newlines()
            if p.check(.RBrace) { break }
            name :: p.expect(.Ident, "imported name")
            alias_str: string | null = null
            if p.match_kind(.KwAs) != null {
                alias_str = p.expect(.Ident, "alias after `as`").text
            }
            names.push(ImportName {
                .name  = name.text,
                .alias = alias_str,
                .span  = p.span_of(name, p.peek_at(-1)),
            })
            p.skip_newlines()
        }
    }
    p.skip_newlines()
    p.expect(.RBrace, "`}` to close import list")
    return names
}

StringLitInfo :: struct { text: string, span: Span }

expect_string_literal :: fn(p: Parser, what: string) -> StringLitInfo {
    if !p.check(.StringBegin) {
        t :: p.peek()
        p.error(.ExpectedToken, t.span, "expected ${what} (got ${describe_token(t)})")
        return StringLitInfo { .text = "", .span = t.span }
    }
    begin :: p.advance()
    sb := new_builder()
    for !p.check(.StringEnd) && !p.check(.Eof) {
        t :: p.advance()
        if t.kind == .StringPart {
            // Lexer stores the decoded text in `value` for StringPart tokens.
            // Bind to a local so match-narrowing applies, and use a wildcard
            // arm — the runtime can't reliably dispatch a primitive-only
            // union via individual `is X` arms.
            v :: t.value
            match v {
                is string -> { sb.append(v) }
                _         -> { sb.append(t.text) }
            }
        }
        if t.kind == .InterpOpen {
            p.error(.UnexpectedToken, t.span, "interpolation not allowed in import path")
            for !p.check(.InterpClose) && !p.check(.Eof) { p.advance() }
        }
    }
    end_tok :: p.match_or_peek(.StringEnd)
    return StringLitInfo { .text = sb.to_string(), .span = p.span_of(begin, end_tok) }
}

is_impl_decl :: fn(p: Parser) -> bool {
    i := p.pos
    depth := 0
    n :: i32(p.tokens.len())
    for i < n {
        t :: p.tokens[usize(i)]
        if t.kind == .Eof || t.kind == .Newline { return false }
        if t.kind == .KwImplements && depth == 0 { return true }
        if t.kind == .LParen || t.kind == .LBracket || t.kind == .LBrace { depth = depth + 1 }
        if t.kind == .RParen || t.kind == .RBracket || t.kind == .RBrace { depth = depth - 1 }
        if depth < 0 { return false }
        i = i + 1
    }
    return false
}

// Lookahead : starting on the leading ident, is the shape `ident [ ... ] ::` ?
// Walks a balanced bracket pair and checks the next token is `::`. Lets the
// dispatcher pick the generic-alias path without committing.
peek_is_lhs_generic_alias_head :: fn(p: Parser) -> bool {
    // Caller already verified ident + `[`.
    i := p.pos + 2     // skip ident, skip `[`
    depth := 1
    n :: i32(p.tokens.len())
    for i < n {
        t :: p.tokens[usize(i)]
        if t.kind == .Eof || t.kind == .Newline { return false }
        if t.kind == .LBracket {
            depth = depth + 1
        } else if t.kind == .RBracket {
            depth = depth - 1
            if depth == 0 {
                if i + 1 < n {
                    return p.tokens[usize(i + 1)].kind == .DeclConst
                }
                return false
            }
        } else if t.kind == .LParen || t.kind == .LBrace {
            depth = depth + 1
        } else if t.kind == .RParen || t.kind == .RBrace {
            depth = depth - 1
        }
        if depth < 0 { return false }
        i = i + 1
    }
    return false
}

parse_lhs_generic_alias_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility) -> TypeAliasDecl {
    name_tok :: p.advance()  // ident
    type_params :: p.parse_bracketed_type_params()
    p.advance()  // `::`
    aliased :: p.parse_expr(0)
    return TypeAliasDecl {
        .span        = p.span_of(name_tok, p.peek_at(-1)),
        .name        = name_tok.text,
        .name_span   = name_tok.span,
        .visibility  = visibility,
        .type_params = type_params,
        .aliased     = aliased,
        .decorators  = decorators,
    }
}

parse_impl_decl :: fn(p: Parser, decorators: Decorator[]) -> ImplDecl {
    start_tok :: p.peek()
    for_type :: p.parse_type()
    p.expect(.KwImplements, "`implements` keyword")
    // Optional bounded-generic typeParam list immediately after `implements` :
    // `Foo[T] implements[T: Bound] Trait[T] { … }`. Mirrors the TS parser ;
    // [T] always follows the keyword that introduces a typeParam scope
    // (`fn[T]`, `struct[T]`, `trait[T]`, `implements[T]`).
    type_params: TypeParam[] = []
    if p.check(.LBracket) {
        type_params = p.parse_bracketed_type_params()
    }
    trait_tok :: p.expect(.Ident, "trait name")

    // Trait-args — `Iterator(T)` and `Iterator[T]` both accepted.
    trait_args: TypeExpr[] = []
    if p.match_kind(.LBracket) != null {
        trait_args = p.parse_type_list_until(.RBracket)
        p.expect(.RBracket, "`]` to close trait argument list")
    } else if p.match_kind(.LParen) != null {
        trait_args = p.parse_type_list_until(.RParen)
        p.expect(.RParen, "`)` to close trait argument list")
    }

    // `@intrinsic Type implements Trait` (no body) — resolver synthesises
    // body-less members from the trait's methods.
    is_intrinsic := false
    for deco in decorators {
        if deco.name == "intrinsic" { is_intrinsic = true }
    }

    members: FnDecl[] = []
    end_tok: Token = trait_tok
    if p.check(.Arrow) {
        members.push(p.parse_sam_arrow_member())
        end_tok = p.peek_at(-1)
    } else if p.check(.LBrace) && p.peek_is_classic_impl_body() {
        p.advance()  // `{`
        p.skip_newlines()
        for !p.check(.RBrace) && !p.check(.Eof) {
            fn_opt :: p.parse_fn_decl_inside_trait()
            match fn_opt {
                is FnDecl -> { members.push(fn_opt) }
                is null   -> {}
            }
            p.skip_newlines()
        }
        end_tok = p.expect(.RBrace, "`}` to close impl body")
    } else if p.check(.LBrace) {
        members.push(p.parse_sam_block_member())
        end_tok = p.peek_at(-1)
    } else if is_intrinsic {
        end_tok = p.peek_at(-1)
    } else {
        t :: p.peek()
        p.error(.ExpectedDeclaration, t.span, "expected `->` or `{` after trait reference (got ${describe_token(t)})")
        end_tok = t
    }
    return ImplDecl {
        .span            = p.span_of(start_tok, end_tok),
        .type_params     = type_params,
        .for_type        = for_type,
        .trait_name      = trait_tok.text,
        .trait_name_span = trait_tok.span,
        .trait_args      = trait_args,
        .members         = members,
        .decorators      = decorators,
    }
}

peek_is_classic_impl_body :: fn(p: Parser) -> bool {
    // Past the `{` ; skip newlines, decorators, and an optional `export`,
    // then look for `ident :: fn` (the unified member-decl shape).
    i := 1
    for p.peek_at(i).kind == .Newline { i = i + 1 }
    looping := true
    for looping {
        tk :: p.peek_at(i).kind
        if tk == .At {
            i = i + 1
            if p.peek_at(i).kind == .Ident { i = i + 1 }
            if p.peek_at(i).kind == .LParen {
                depth := 1
                i = i + 1
                for depth > 0 && p.peek_at(i).kind != .Eof {
                    k :: p.peek_at(i).kind
                    if k == .LParen { depth = depth + 1 }
                    if k == .RParen { depth = depth - 1 }
                    i = i + 1
                }
            }
            for p.peek_at(i).kind == .Newline { i = i + 1 }
        } else {
            if tk == .KwExport {
                i = i + 1
                for p.peek_at(i).kind == .Newline { i = i + 1 }
            } else {
                looping = false
            }
        }
    }
    return p.peek_at(i).kind == .Ident && p.peek_at(i + 1).kind == .DeclConst && p.peek_at(i + 2).kind == .KwFn
}

parse_sam_arrow_member :: fn(p: Parser) -> FnDecl {
    arrow_tok :: p.expect(.Arrow, "`->` to introduce a SAM impl body")
    expr :: p.parse_expr(0)
    span :: p.span_of(arrow_tok, p.peek_at(-1))
    body :: BlockExpr {
        .span     = span,
        .stmts    = [],
        .trailing = expr,
    }
    return FnDecl {
        .span                 = span,
        .name                 = "",
        .name_span            = arrow_tok.span,
        .visibility           = .Public,
        .type_params          = [],
        .params               = [],
        .return_type          = null,
        .body                 = body,
        .decorators           = [],
        .sam_synthetic        = true,
        .is_expression_bodied = false,
        .materialized         = false,
    }
}

parse_sam_block_member :: fn(p: Parser) -> FnDecl {
    block :: p.parse_block()
    return FnDecl {
        .span                 = block.span,
        .name                 = "",
        .name_span            = block.span,
        .visibility           = .Public,
        .type_params          = [],
        .params               = [],
        .return_type          = null,
        .body                 = block,
        .decorators           = [],
        .sam_synthetic        = true,
        .is_expression_bodied = false,
        .materialized         = false,
    }
}

parse_named_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility) -> Decl {
    name_tok :: p.advance()  // ident
    p.advance()              // `::`

    if p.check(.KwFn)     { return p.parse_fn_decl(decorators, visibility, name_tok) }
    if p.check(.KwStruct) { return p.parse_struct_decl(decorators, visibility, name_tok) }
    if p.check(.KwEnum)   { return p.parse_enum_decl(decorators, visibility, name_tok) }
    if p.check(.KwTrait)  { return p.parse_trait_decl(decorators, visibility, name_tok) }
    if p.check(.KwImport) { return p.parse_named_import_decl(decorators, name_tok) }
    return p.parse_const_decl(decorators, visibility, name_tok)
}

parse_fn_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility, name_tok: Token) -> FnDecl {
    p.advance()  // `fn`
    // Bracketed type-params `fn[T: Bound](...)` are merged with legacy
    // dollar-prefixed introductions collected from the value-arg types.
    bracketed :: p.parse_bracketed_type_params()
    sig :: p.parse_fn_signature_params()
    type_params :: merge_type_params(bracketed, sig.type_params)
    return_type: TypeExpr | null = null
    if p.match_kind(.Arrow) != null { return_type = p.parse_type() }
    tail :: p.parse_fn_body_tail(return_type)
    return FnDecl {
        .span                 = p.span_of(name_tok, p.peek_at(-1)),
        .name                 = name_tok.text,
        .name_span            = name_tok.span,
        .visibility           = visibility,
        .type_params          = type_params,
        .params               = sig.params,
        .return_type          = return_type,
        .body                 = tail.body,
        .decorators           = decorators,
        .sam_synthetic        = false,
        .is_expression_bodied = tail.is_expression_bodied,
        .materialized         = false,
    }
}

FnBodyTail :: struct {
    body:                 BlockExpr | null
    is_expression_bodied: bool
}

parse_fn_body_tail :: fn(p: Parser, return_type: TypeExpr | null) -> FnBodyTail {
    if p.check(.Assign) {
        p.advance()  // `=`
        expr :: p.parse_expr(0)
        body :: BlockExpr {
            .span     = expr.span,
            .stmts    = [],
            .trailing = expr,
        }
        return FnBodyTail { .body = body, .is_expression_bodied = true }
    }
    if p.check(.LBrace) {
        return FnBodyTail { .body = p.parse_block(), .is_expression_bodied = false }
    }
    return FnBodyTail { .body = null, .is_expression_bodied = false }
}

parse_fn_decl_inside_trait :: fn(p: Parser) -> FnDecl | null {
    decorators :: p.parse_decorators()
    visibility: Visibility = .Private
    if p.match_kind(.KwExport) != null { visibility = .Public }
    // Unified syntax: `name :: fn(...)` — same shape as top-level fns.
    is_member :: p.check(.Ident) && p.peek_at(1).kind == .DeclConst && p.peek_at(2).kind == .KwFn
    if !is_member {
        t :: p.peek()
        if t.kind == .KwFn {
            p.error(.ExpectedDeclaration, t.span, "trait/impl members must use the `name :: fn(...)` form (the bare `fn name(...)` form was retired)")
        } else {
            p.error(.ExpectedDeclaration, t.span, "expected member declaration `name :: fn(...)` (got ${describe_token(t)})")
        }
        for !p.check(.RBrace) && !p.check(.Eof) {
            if p.check(.Ident) && p.peek_at(1).kind == .DeclConst && p.peek_at(2).kind == .KwFn { break }
            p.advance()
        }
        return null
    }
    name_tok :: p.advance()  // ident
    p.advance()              // `::`
    p.advance()              // `fn`
    bracketed :: p.parse_bracketed_type_params()
    sig :: p.parse_fn_signature_params()
    type_params :: merge_type_params(bracketed, sig.type_params)
    return_type: TypeExpr | null = null
    if p.match_kind(.Arrow) != null { return_type = p.parse_type() }
    tail :: p.parse_fn_body_tail(return_type)
    return FnDecl {
        .span                 = p.span_of(name_tok, p.peek_at(-1)),
        .name                 = name_tok.text,
        .name_span            = name_tok.span,
        .visibility           = visibility,
        .type_params          = type_params,
        .params               = sig.params,
        .return_type          = return_type,
        .body                 = tail.body,
        .decorators           = decorators,
        .sam_synthetic        = false,
        .is_expression_bodied = tail.is_expression_bodied,
        .materialized         = false,
    }
}

FnSignature :: struct {
    params:      FnParam[]
    type_params: TypeParam[]
}

parse_fn_signature_params :: fn(p: Parser) -> FnSignature {
    type_params: TypeParam[] = []
    params:      FnParam[]   = []
    p.expect(.LParen, "`(` after function name")
    p.skip_newlines()
    if !p.check(.RParen) {
        first := true
        for {
            p.skip_newlines()
            if p.check(.RParen) || p.check(.Eof) { break }
            if !first {
                if p.match_kind(.Comma) == null { break }
                p.skip_newlines()
                if p.check(.RParen) { break }
            }
            first = false

            start_tok :: p.peek()
            is_variadic := false
            if p.check(.Dot) && p.check_at(.Dot, 1) && p.check_at(.Dot, 2) {
                p.advance()
                p.advance()
                p.advance()
                is_variadic = true
            }

            param_name_tok: Token = empty_token()
            has_name := false
            if p.check(.KwSelf) || p.check(.Ident) {
                param_name_tok = p.advance()
                has_name = true
            } else {
                t :: p.peek()
                p.error(.ExpectedToken, t.span, "expected parameter name (got ${describe_token(t)})")
                for !p.check(.Comma) && !p.check(.RParen) && !p.check(.Eof) { p.advance() }
                continue
            }

            ty: TypeExpr | null = null
            if p.match_kind(.Colon) != null {
                p.skip_newlines()
                ty = p.parse_type()
            }
            default_value: Expr | null = null
            if p.match_kind(.Assign) != null {
                default_value = p.parse_expr(0)
            }

            // Legacy dollar-prefixed types are auto-promoted to type
            // parameters (the canonical surface is bracketed `fn[T](...)`).
            collect_type_params(ty, type_params)

            params.push(FnParam {
                .span          = p.span_of(start_tok, p.peek_at(-1)),
                .name          = param_name_tok.text,
                .ty            = ty,
                .default_value = default_value,
                .variadic      = is_variadic,
            })
        }
    }
    p.expect(.RParen, "`)` to close parameter list")
    return FnSignature { .params = params, .type_params = type_params }
}

empty_token :: fn() = make_token(.Eof, "", empty_span(""))

parse_struct_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility, name_tok: Token) -> StructDecl {
    p.advance()  // `struct`
    type_params :: p.parse_struct_type_param_list()
    p.expect(.LBrace, "`{` to open struct body")
    p.skip_newlines()
    fields: StructField[] = []
    for !p.check(.RBrace) && !p.check(.Eof) {
        field_visibility: Visibility = .Private
        if p.match_kind(.KwExport) != null { field_visibility = .Public }
        start :: p.peek()
        fname :: p.expect(.Ident, "field name")
        p.expect(.Colon, "`:` after field name")
        ftype :: p.parse_type()
        fdefault: Expr | null = null
        if p.match_kind(.Assign) != null {
            p.skip_newlines()
            fdefault = p.parse_expr(0)
        }
        fields.push(StructField {
            .span       = p.span_of(start, p.peek_at(-1)),
            .name       = fname.text,
            .ty         = ftype,
            .visibility = field_visibility,
            .default    = fdefault,
        })
        if !p.check(.RBrace) {
            p.match_kind(.Comma)
            p.skip_newlines()
        }
    }
    end_tok :: p.expect(.RBrace, "`}` to close struct body")
    return StructDecl {
        .span          = p.span_of(name_tok, end_tok),
        .name          = name_tok.text,
        .name_span     = name_tok.span,
        .visibility    = visibility,
        .type_params   = type_params,
        .fields        = fields,
        .decorators    = decorators,
    }
}

parse_struct_type_param_list :: fn(p: Parser) -> TypeParam[] {
    // Bracketed `[T, U: Bound]` is canonical ; falls back to the legacy
    // paren form when no `[` is present (still needed for the comptime-
    // value head shape `(N: i32)` which the bracketed form doesn't express).
    if p.check(.LBracket) { return p.parse_bracketed_type_params() }
    if p.match_kind(.LParen) == null { return [] }
    out: TypeParam[] = []
    p.skip_newlines()
    for !p.check(.RParen) && !p.check(.Eof) {
        // Each iteration parses one (possibly $-prefixed) type-param. After
        // the first iteration we require a leading `,` ; we detect this via
        // the parser position rather than a `!first` flag (the lowerer +
        // bytecode runtime trip on a `!bool` op in this hot path — see
        // TODO §1.13c).
        if out.len() > 0 {
            if p.match_kind(.Comma) == null { break }
            p.skip_newlines()
            if p.check(.RParen) { break }
        }

        has_dollar :: p.match_kind(.Dollar) != null
        start :: p.peek()
        name :: p.expect(.Ident, "type parameter name")
        bound: TypeExpr | null = null
        if p.match_kind(.Colon) != null { bound = p.parse_type() }

            if !has_dollar {
                hint :: match bound {
                    is null -> "`${name.text}` must be written `\$${name.text}`"
                    _       -> "`${name.text}` must be prefixed with `\$`"
                }
                p.error(.TypeParamMustBePrefixedWithDollar, p.span_of(start, p.peek_at(-1)), hint)
            } else {
                // `: type` bound is redundant — drop it after diagnosing.
                bnd :: bound
                match bnd {
                    is null      -> {}
                    is IdentExpr -> {
                        if bnd.name == "type" {
                            p.error(.TypeBoundRedundant, p.span_of(start, p.peek_at(-1)),
                                "`${name.text}` is already a type parameter")
                            bound = null
                        }
                    }
                    _            -> {}
                }
            }
            is_comptime_value := bound != null
        out.push(TypeParam {
            .span              = p.span_of(start, p.peek_at(-1)),
            .name              = name.text,
            .bound             = bound,
            .is_comptime_value = is_comptime_value,
        })
    }
    p.expect(.RParen, "`)` to close type parameter list")
    return out
}

// Bracketed type-param list `[T, U: Bound, ...]`. Each entry is `name`
// or `name: bound`. The bound parses as a type expression so trait bounds
// (`[T: Hash & Eq]`) work via the same parser. Always returns
// non-comptime-value entries — comptime-value params keep the legacy
// paren form `(N: i32)` for now.
parse_bracketed_type_params :: fn(p: Parser) -> TypeParam[] {
    if p.match_kind(.LBracket) == null { return [] }
    out: TypeParam[] = []
    p.skip_newlines()
    for !p.check(.RBracket) && !p.check(.Eof) {
        if out.len() > 0 {
            if p.match_kind(.Comma) == null { break }
            p.skip_newlines()
            if p.check(.RBracket) { break }
        }
        start :: p.peek()
        name :: p.expect(.Ident, "type-param name")
        bound: TypeExpr | null = null
        if p.match_kind(.Colon) != null {
            p.skip_newlines()
            bound = p.parse_type()
        }
        out.push(TypeParam {
            .span              = p.span_of(start, p.peek_at(-1)),
            .name              = name.text,
            .bound             = bound,
            .is_comptime_value = false,
        })
    }
    p.expect(.RBracket, "`]` to close type-param list")
    return out
}

// Combine bracketed type-params with inline introductions collected from
// the value-arg types (legacy dollar-prefixed form). The bracketed list
// takes precedence — a name already declared explicitly is not re-added
// from the inline list.
merge_type_params :: fn(bracketed: TypeParam[], inlined: TypeParam[]) -> TypeParam[] {
    if bracketed.len() == 0 { return inlined }
    if inlined.len() == 0   { return bracketed }
    merged: TypeParam[] = []
    for bracketed_param in bracketed { merged.push(bracketed_param) }
    for inline_param in inlined {
        already_present := false
        for existing in merged {
            if existing.name == inline_param.name {
                already_present = true
                break
            }
        }
        if !already_present { merged.push(inline_param) }
    }
    return merged
}

parse_trait_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility, name_tok: Token) -> TraitDecl {
    p.advance()  // `trait`
    type_params :: p.parse_struct_type_param_list()
    // Trait composition. Two forms :
    //   `Foo :: trait[T] = A & B`            (alias, no own methods)
    //   `Foo :: trait[T] : A & B { ... }`    (composes A & B + own methods)
    requires: TypeExpr | null = null
    members: FnDecl[] = []
    if p.match_kind(.Assign) != null {
        requires = p.parse_type()
        return TraitDecl {
            .span        = p.span_of(name_tok, p.peek_at(-1)),
            .name        = name_tok.text,
            .name_span   = name_tok.span,
            .visibility  = visibility,
            .type_params = type_params,
            .requires    = requires,
            .members     = members,
            .decorators  = decorators,
        }
    }
    if p.match_kind(.Colon) != null {
        requires = p.parse_type()
    }
    p.expect(.LBrace, "`{` to open trait body")
    p.skip_newlines()
    for !p.check(.RBrace) && !p.check(.Eof) {
        fn_opt :: p.parse_fn_decl_inside_trait()
        match fn_opt {
            is FnDecl -> { members.push(fn_opt) }
            is null   -> {}
        }
        p.skip_newlines()
    }
    end_tok :: p.expect(.RBrace, "`}` to close trait body")
    return TraitDecl {
        .span        = p.span_of(name_tok, end_tok),
        .name        = name_tok.text,
        .name_span   = name_tok.span,
        .visibility  = visibility,
        .type_params = type_params,
        .requires    = requires,
        .members     = members,
        .decorators  = decorators,
    }
}

parse_enum_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility, name_tok: Token) -> EnumDecl {
    p.advance()  // `enum`
    repr: TypeExpr | null = null
    if p.match_kind(.LParen) != null {
        repr = p.parse_type()
        p.expect(.RParen, "`)` after enum backing type")
    }
    p.expect(.LBrace, "`{` to open enum body")
    p.skip_newlines()
    variants: EnumVariant[] = []
    for !p.check(.RBrace) && !p.check(.Eof) {
        v_tok :: p.expect(.Ident, "variant name")
        value: i64 | null = null
        value_span: Span | null = null
        if p.match_kind(.Assign) != null {
            lit_tok :: p.expect(.IntLit, "integer literal after `=`")
            val :: lit_tok.value
            // u64 → i64 wraps the high bit for values ≥ 2^63. Out-of-range
            // explicit variant values are surfaced downstream by T3030
            // ("enum variant value out of range for backing type"), so we
            // don't validate here.
            match val {
                is u64 -> { value = i64(val) }
                _      -> { value = 0i64 }
            }
            value_span = lit_tok.span
        }
        variants.push(EnumVariant {
            .span       = v_tok.span,
            .name       = v_tok.text,
            .value      = value,
            .value_span = value_span,
        })
        p.match_kind(.Comma)
        p.skip_newlines()
    }
    end_tok :: p.expect(.RBrace, "`}` to close enum body")
    return EnumDecl {
        .span       = p.span_of(name_tok, end_tok),
        .name       = name_tok.text,
        .name_span  = name_tok.span,
        .visibility = visibility,
        .repr       = repr,
        .variants   = variants,
        .decorators = decorators,
    }
}

// `name :: value` — untyped top-level const. The typed shape uses the
// Odin-style `name : Type : value` form parsed by `parse_typed_const_decl`.
parse_const_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility, name_tok: Token) -> ConstDecl {
    // Multi-line union with a leading pipe :
    //   T ::
    //       | A
    //       | B
    //       | C
    // The lexer's `suppresses_newline_before` drops the newlines before
    // each `|`, so the token stream looks like `T :: | A | B | C`.
    // Consume the optional leading `|` so the infix-Pratt path picks up
    // the rest as a left-associative `bitor` chain.
    p.match_kind(.Pipe)
    value :: p.parse_expr(0)
    return ConstDecl {
        .span       = p.span_of(name_tok, p.peek_at(-1)),
        .name       = name_tok.text,
        .name_span  = name_tok.span,
        .visibility = visibility,
        .ty         = null,
        .value      = value,
        .decorators = decorators,
    }
}

// `name : Type : value` — typed top-level const, mirrors the local
// `name : Type : value` immutable-let form for surface uniformity.
parse_typed_const_decl :: fn(p: Parser, decorators: Decorator[], visibility: Visibility) -> ConstDecl {
    name_tok :: p.advance()  // name
    p.advance()  // first `:`
    ty :: p.parse_type()
    p.expect(.Colon, "`:` between type annotation and value")
    value :: p.parse_expr(0)
    return ConstDecl {
        .span       = p.span_of(name_tok, p.peek_at(-1)),
        .name       = name_tok.text,
        .name_span  = name_tok.span,
        .visibility = visibility,
        .ty         = ty,
        .value      = value,
        .decorators = decorators,
    }
}

// ============================================================================
// Type expressions
// ============================================================================

// Build a plain `IdentExpr` with both flag fields off — most call sites
// don't need the implicit-dot or type-param-intro variants.
ident_expr :: fn(span: Span, name: string) -> IdentExpr {
    return IdentExpr {
        .span                = span,
        .name                = name,
        .implicit_dot        = false,
        .is_type_param_intro = false,
    }
}

parse_type :: fn(p: Parser) -> TypeExpr {
    // Precedence : `const` prefix (qualifies the array type), postfix
    // `[]` `!` (tightest), then `&` intersection, then `|` union
    // (loosest). Mirrors the value-side Pratt table.
    // Optional leading `|` lets multi-line unions read cleanly in the
    // Haskell / Rust style. The lexer's `suppresses_newline_before` on
    // `Pipe` drops the newline before each leading `|` so the tokens
    // look identical to `T :: | A | B | C`.
    p.match_kind(.Pipe)
    const_tok :: p.match_kind(.KwConst)
    head := p.parse_type_intersection()
    if const_tok != null {
        if head is ArrayTypeExpr {
            head_span :: head.span
            head = ArrayTypeExpr {
                .span      = Span { .start = const_tok.span.start, .end = head_span.end },
                .element   = head.element,
                .immutable = true,
            }
        } else {
            p.error(.InvalidConstQualifierPlacement, const_tok.span, "`const` qualifier only applies to array types (`const T[]`)")
        }
    }
    // `T | U | V` — left-associative `bitor` chain.
    if p.check(.Pipe) {
        head_span :: head.span
        for p.match_kind(.Pipe) != null {
            next :: p.parse_type_intersection()
            next_span :: next.span
            head = BinaryExpr {
                .span  = Span { .start = head_span.start, .end = next_span.end },
                .op    = .BitOr,
                .left  = head,
                .right = next,
            }
        }
    }
    return head
}

// `T & U & V` — left-associative `bitand` chain, tighter than `|` and
// looser than the postfix operators. Same node shape as value-side trait
// composition (e.g. `[T: Hash & Eq]`).
parse_type_intersection :: fn(p: Parser) -> TypeExpr {
    head := p.parse_type_postfix()
    if p.check(.Amp) {
        head_span :: head.span
        for p.match_kind(.Amp) != null {
            next :: p.parse_type_postfix()
            next_span :: next.span
            head = BinaryExpr {
                .span  = Span { .start = head_span.start, .end = next_span.end },
                .op    = .BitAnd,
                .left  = head,
                .right = next,
            }
        }
    }
    return head
}

parse_type_postfix :: fn(p: Parser) -> TypeExpr {
    head := p.parse_type_primary()
    // Postfix `T[]` loop : `T[]`, `T[][]`, ... wraps `head` into an
    // ArrayTypeExpr. Two-token lookahead `[ ]` keeps us from consuming a `[`
    // that belongs to something else.
    for p.check(.LBracket) && p.check_at(.RBracket, 1) {
        p.advance()              // [
        rb :: p.advance()        // ]
        head_span :: head.span
        head = ArrayTypeExpr {
            .span    = Span { .start = head_span.start, .end = rb.span.end },
            .element = head,
        }
    }
    // `T!` desugars to `T | Error` (or `null | Error` for `void!`).
    if p.match_kind(.Bang) != null {
        bang_end :: p.peek_at(-1).span.end
        head_span :: head.span
        success: TypeExpr = match head {
            is IdentExpr -> {
                if head.name == "void" { ident_expr(head_span, "null") }
                else { head }
            }
            _ -> head
        }
        error_ident :: IdentExpr {
            .span = Span { .start = bang_end, .end = bang_end },
            .name = "Error",
            .implicit_dot = false,
            .is_type_param_intro = false,
        }
        head = BinaryExpr {
            .span  = Span { .start = head_span.start, .end = bang_end },
            .op    = .BitOr,
            .left  = success,
            .right = error_ident,
        }
    }
    return head
}

parse_type_primary :: fn(p: Parser) -> TypeExpr {
    t :: p.peek()
    if t.kind == .Dollar {
        p.advance()
        name :: p.expect(.Ident, "type parameter name after `\$`")
        return IdentExpr {
            .span                = p.span_of(t, name),
            .name                = name.text,
            .implicit_dot        = false,
            .is_type_param_intro = true,
        }
    }
    if t.kind == .KwFn {
        return p.parse_fn_type()
    }
    // Parenthesised type — used for grouping when postfix precedence would
    // otherwise bind too tightly. e.g. `(T | U)[]` to mean "array of union".
    if t.kind == .LParen {
        p.advance()
        p.skip_newlines()
        inner :: p.parse_type()
        p.skip_newlines()
        p.expect(.RParen, "`)` to close parenthesised type")
        return inner
    }
    if t.kind == .LBracket {
        // Bracketed type form. Two readings :
        //   `[T1, T2, ...]`  → tuple type (≥ 2 elements), encoded as `SeqLitExpr`
        //   `[T]` / `[T,]`   → 1-tuple — forbidden (P1021), recovered as
        //                      ArrayTypeExpr so the user-likely-meant-array
        //                      flow keeps working downstream.
        start :: p.advance()
        elements: TypeExpr[] = []
        p.skip_newlines()
        if p.check(.RBracket) {
            p.error(.ExpectedType, t.span, "empty `[]` is not a valid type")
            end :: p.advance()
            return SeqLitExpr {
                .span     = p.span_of(start, end),
                .elements = elements,
            }
        }
        elements.push(p.parse_type())
        p.skip_newlines()
        for p.match_kind(.Comma) != null {
            p.skip_newlines()
            if p.check(.RBracket) { break }
            elements.push(p.parse_type())
            p.skip_newlines()
        }
        end :: p.expect(.RBracket, "`]` to close bracketed type")
        if elements.len() == 1 {
            p.error(.OneTupleNotAllowed, p.span_of(start, end),
                "use postfix `T[]` for an array, or a plain value if you meant the element")
            return ArrayTypeExpr {
                .span    = p.span_of(start, end),
                .element = elements[0],
            }
        }
        return SeqLitExpr {
            .span     = p.span_of(start, end),
            .elements = elements,
        }
    }
    if t.kind == .KwNull {
        p.advance()
        return ident_expr(t.span, "null")
    }
    if t.kind == .Ident {
        name :: p.advance()
        head: Expr = ident_expr(name.span, name.text)
        // Qualified namespace : `module.Type` — applies when the leading
        // ident is an `import "X" as alias` (or destructured-namespace)
        // binding. The resolver follows the chain to the exported type in
        // the target module. Built as a `FieldExpr` so the existing
        // field-resolution machinery (which already handles `module.value`
        // for call expressions) serves type-position lookups too.
        for p.check(.Dot) {
            p.advance()
            field :: p.expect(.Ident, "field name after `.` in qualified type")
            head = FieldExpr {
                .span       = Span { .start = head.span.start, .end = field.span.end },
                .target     = head,
                .field      = field.text,
                .field_span = field.span,
                .is_numeric = false,
            }
        }
        // Generic instantiation : `Foo[i32]` (canonical) or `Foo(i32)`
        // (legacy paren). `Foo[]` (empty brackets) is the postfix array
        // shape, handled by the outer postfix loop — fall through.
        if p.check(.LBracket) && p.check_at(.RBracket, 1) { return head }
        if p.match_kind(.LBracket) != null {
            args :: p.parse_type_list_until(.RBracket)
            end :: p.expect(.RBracket, "`]` to close generic argument list")
            return GenericInstExpr {
                .span      = p.span_of(name, end),
                .callee    = head,
                .type_args = args,
            }
        }
        if p.match_kind(.LParen) != null {
            args :: p.parse_type_list_until(.RParen)
            end :: p.expect(.RParen, "`)` to close generic argument list")
            return GenericInstExpr {
                .span      = p.span_of(name, end),
                .callee    = head,
                .type_args = args,
            }
        }
        return head
    }
    p.error(.ExpectedType, t.span, "got ${describe_token(t)}")
    p.advance()
    return ident_expr(t.span, "?")
}

parse_fn_type :: fn(p: Parser) -> FnTypeExpr {
    start :: p.advance()  // `fn`
    p.expect(.LParen, "`(` after `fn` in function type")
    params :: p.parse_type_list_until(.RParen)
    p.expect(.RParen, "`)` after function parameter types")
    return_type: TypeExpr | null = null
    if p.match_kind(.Arrow) != null { return_type = p.parse_type() }
    return FnTypeExpr {
        .span        = p.span_of(start, p.peek_at(-1)),
        .params      = params,
        .return_type = return_type,
    }
}

// Comma-separated `parse_type` list up to (but not consuming) `close`.
// Skips leading newlines around commas. Caller is responsible for
// expecting the close token.
parse_type_list_until :: fn(p: Parser, close: TokenKind) -> TypeExpr[] {
    out: TypeExpr[] = []
    p.skip_newlines()
    if p.check(close) { return out }
    for {
        p.skip_newlines()
        if p.check(close) { break }
        out.push(p.parse_type())
        p.skip_newlines()
        if p.match_kind(.Comma) == null { break }
    }
    return out
}

// Walk a type expression and collect any inline type-param introductions
// (the legacy dollar-prefixed form). Only the `Expr` variants the parser
// actually produces in type position need to be traversed. Accepts `null`
// so call sites with optional type-bearing slots can dispatch directly
// without an outer match.
collect_type_params :: fn(t: TypeExpr | null, out: TypeParam[]) -> void {
    match t {
        is null -> {}
        is IdentExpr -> {
            if !t.is_type_param_intro { return }
            // Dedupe by name.
            seen := false
            for tp in out {
                if tp.name == t.name {
                    seen = true
                    break
                }
            }
            if !seen {
                out.push(TypeParam {
                    .span              = t.span,
                    .name              = t.name,
                    .bound             = null,
                    .is_comptime_value = false,
                })
            }
        }
        is BinaryExpr -> {
            collect_type_params(t.left, out)
            collect_type_params(t.right, out)
        }
        is FnTypeExpr -> {
            for pp in t.params { collect_type_params(pp, out) }
            collect_type_params(t.return_type, out)
        }
        is ArrayTypeExpr  -> { collect_type_params(t.element, out) }
        is SeqLitExpr     -> {
            for e in t.elements { collect_type_params(e, out) }
        }
        is GenericInstExpr -> {
            for a in t.type_args { collect_type_params(a, out) }
        }
        // Other Expr variants never appear in the subset that `parse_type`
        // produces, so they're effective no-ops here.
        _ -> {}
    }
}

// ============================================================================
// Statements / blocks
// ============================================================================

parse_block :: fn(p: Parser) -> BlockExpr {
    lb :: p.expect(.LBrace, "`{` to open block")
    p.skip_newlines()
    raw: Stmt[] = []
    trailing: Expr | null = null
    for !p.check(.RBrace) && !p.check(.Eof) {
        s_opt :: p.parse_stmt()
        match s_opt {
            is null         -> {}
            is LetStmt      -> { raw.push(s_opt) }
            is AssignStmt   -> { raw.push(s_opt) }
            is ExprStmt     -> { raw.push(s_opt) }
            is ReturnStmt   -> { raw.push(s_opt) }
            is ForStmt      -> { raw.push(s_opt) }
            is BreakStmt    -> { raw.push(s_opt) }
            is ContinueStmt -> { raw.push(s_opt) }
            is DeferStmt    -> { raw.push(s_opt) }
        }
        p.skip_newlines()
    }
    // Promote a trailing ExprStmt into the block's implicit return value
    // by rebuilding `stmts` without the last element (no `pop` on arrays).
    stmts: Stmt[] = []
    n :: raw.len()
    last_is_expr := false
    last_expr: Expr | null = null
    if n > 0 {
        last :: raw[n - 1]
        match last {
            is ExprStmt -> {
                last_is_expr = true
                last_expr = last.expr
            }
            is LetStmt      -> {}
            is AssignStmt   -> {}
            is ReturnStmt   -> {}
            is ForStmt      -> {}
            is BreakStmt    -> {}
            is ContinueStmt -> {}
            is DeferStmt    -> {}
        }
    }
    keep :: if last_is_expr { n - 1 } else { n }
    for i in 0..<keep {
        stmts.push(raw[i])
    }
    if last_is_expr {
        match last_expr {
            is null -> {}
            _       -> { trailing = last_expr }
        }
    }
    rb :: p.expect(.RBrace, "`}` to close block")
    return BlockExpr {
        .span     = p.span_of(lb, rb),
        .stmts    = stmts,
        .trailing = trailing,
    }
}

parse_stmt :: fn(p: Parser) -> Stmt | null {
    if p.check(.KwReturn)   { return p.parse_return() }
    if p.check(.KwFor)      { return p.parse_for(null, false) }
    // `@comptime for x in <arr> { body }` — Layer 6 unroll. The TS parser
    // accepts the same form ; only `@comptime` on `for` is recognised as
    // a decorator-on-stmt here.
    if p.check(.At) && p.peek_at(1).kind == .Ident && p.peek_at(1).text == "comptime" && p.check_at(.KwFor, 2) {
        p.advance()  // @
        p.advance()  // comptime
        return p.parse_for(null, true)
    }
    if p.check(.KwBreak)    { return p.parse_break() }
    if p.check(.KwContinue) { return p.parse_continue() }
    if p.check(.KwDefer)    { return p.parse_defer() }
    // `label: for ...`
    if p.check(.Ident) && p.check_at(.Colon, 1) && p.check_at(.KwFor, 2) {
        label_tok :: p.advance()
        p.advance()  // `:`
        return p.parse_for(label_tok.text, false)
    }
    // Tuple-destructure let : `[a, b] := expr`, `[a, b] :: expr`, or
    // `[a, b]: [int, string] = expr`. Detected by the `[` whose matching `]`
    // is followed by `:=`, `::`, or `:` (typed form).
    if p.check(.LBracket) && p.peek_tuple_let_start() {
        return p.parse_tuple_let()
    }
    // `name :: expr` or `name := expr`
    if p.check(.Ident) && (p.check_at(.DeclConst, 1) || p.check_at(.DeclVar, 1)) {
        return p.parse_let()
    }
    // `name: Type = expr` — typed mutable
    if p.check(.Ident) && p.check_at(.Colon, 1) {
        return p.parse_typed_let()
    }
    // Expression statement (with optional `=` or compound assignment).
    start :: p.peek()
    expr :: p.parse_expr(0)
    if p.match_kind(.Assign) != null {
        value :: p.parse_expr(0)
        return AssignStmt {
            .span   = p.span_of(start, p.peek_at(-1)),
            .target = expr,
            .value  = value,
        }
    }
    // Compound assignment — `lhs += rhs` desugars to `lhs = lhs <op> rhs`.
    compound :: p.peek().kind.compound_op()
    if compound.matched {
        p.advance()
        rhs :: p.parse_expr(0)
        sp  :: p.span_of(start, p.peek_at(-1))
        return AssignStmt {
            .span   = sp,
            .target = expr,
            .value  = BinaryExpr { .span = sp, .op = compound.op, .left = expr, .right = rhs },
        }
    }
    return ExprStmt { .span = expr.span, .expr = expr }
}

/** Maps a `*Assign` token kind to the underlying `BinaryOp` ; returns
 *  `{ matched = false }` when the kind isn't a compound assignment. */
CompoundOpResult :: struct { matched: bool, op: BinaryOp }

compound_op :: fn(k: TokenKind) = match k {
    .PlusAssign    -> CompoundOpResult { .matched = true, .op = .Add }
    .MinusAssign   -> CompoundOpResult { .matched = true, .op = .Sub }
    .StarAssign    -> CompoundOpResult { .matched = true, .op = .Mul }
    .SlashAssign   -> CompoundOpResult { .matched = true, .op = .Div }
    .PercentAssign -> CompoundOpResult { .matched = true, .op = .Mod }
    _              -> CompoundOpResult { .matched = false, .op = .Add }
}

parse_typed_let :: fn(p: Parser) -> LetStmt {
    name_tok :: p.advance()  // ident
    p.advance()              // `:`
    ty :: p.parse_type()
    // `=` → mutable binding ; `:` → immutable binding (echoes the second `:`
    // of the untyped `::` form, with `:=` ↔ `=` on the mutable side).
    sep :: p.peek()
    mutable := true
    if sep.kind == .Colon {
        p.advance()
        mutable = false
    } else {
        p.expect(.Assign, "`=` or `:` after type annotation")
    }
    value :: p.parse_expr(0)
    binding :: SimpleBinding {
        .span      = name_tok.span,
        .name      = name_tok.text,
        .name_span = name_tok.span,
    }
    return LetStmt {
        .span    = p.span_of(name_tok, p.peek_at(-1)),
        .mutable = mutable,
        .binding = binding,
        .ty      = ty,
        .value   = value,
    }
}

parse_let :: fn(p: Parser) -> LetStmt {
    name_tok :: p.advance()
    decl_tok :: p.advance()  // `::` or `:=`
    mutable :: decl_tok.kind == .DeclVar
    value :: p.parse_expr(0)
    binding :: SimpleBinding {
        .span      = name_tok.span,
        .name      = name_tok.text,
        .name_span = name_tok.span,
    }
    return LetStmt {
        .span    = p.span_of(name_tok, p.peek_at(-1)),
        .mutable = mutable,
        .binding = binding,
        .ty      = null,
        .value   = value,
    }
}

// Lookahead : after the leading `[`, scan past the matching `]` and check
// whether the next significant token starts a let-destructure (`::`, `:=`, or
// `:` for the typed form). Returns false otherwise.
peek_tuple_let_start :: fn(p: Parser) -> bool {
    depth := 1
    j := p.pos + 1
    n :: i32(p.tokens.len())
    for j < n && depth > 0 {
        k :: p.tokens[usize(j)].kind
        if k == .Eof { return false }
        if k == .LBracket { depth = depth + 1 }
        else if k == .RBracket {
            depth = depth - 1
            if depth == 0 { break }
        }
        j = j + 1
    }
    if depth != 0 { return false }
    i := j + 1
    for i < n && p.tokens[usize(i)].kind == .Newline { i = i + 1 }
    if i >= n { return false }
    next :: p.tokens[usize(i)].kind
    return next == .DeclConst || next == .DeclVar || next == .Colon
}

parse_tuple_let :: fn(p: Parser) -> LetStmt {
    start :: p.peek()
    binding :: p.parse_let_binding()
    ty: TypeExpr | null = null
    mutable := true
    if p.check(.Colon) {
        p.advance()
        ty = p.parse_type()
        sep :: p.peek()
        if sep.kind == .Colon {
            p.advance()
            mutable = false
        } else {
            p.expect(.Assign, "`=` or `:` after type annotation")
        }
    } else {
        decl_tok :: p.peek()
        if decl_tok.kind == .DeclConst || decl_tok.kind == .DeclVar {
            p.advance()
            mutable = decl_tok.kind == .DeclVar
        } else {
            p.expect(.DeclVar, "`:=`, `::`, or `:` after destructure pattern")
        }
    }
    value :: p.parse_expr(0)
    return LetStmt {
        .span    = p.span_of(start, p.peek_at(-1)),
        .mutable = mutable,
        .binding = binding,
        .ty      = ty,
        .value   = value,
    }
}

parse_let_binding :: fn(p: Parser) -> LetBinding {
    if p.check(.LBracket) {
        start :: p.advance()
        p.skip_newlines()
        elements: LetBinding[] = []
        if !p.check(.RBracket) {
            for {
                p.skip_newlines()
                if p.check(.RBracket) { break }
                sub_start :: p.peek()
                if p.match_kind(.DotDotDot) != null {
                    name_tok :: p.expect(.Ident, "name after `...` in destructure pattern")
                    elements.push(RestBinding {
                        .span      = p.span_of(sub_start, name_tok),
                        .name      = name_tok.text,
                        .name_span = name_tok.span,
                    })
                } else {
                    elements.push(p.parse_let_binding())
                }
                p.skip_newlines()
                if p.match_kind(.Comma) == null { break }
                p.skip_newlines()
            }
        }
        end :: p.expect(.RBracket, "`]` to close destructure pattern")
        if elements.len() < 2 {
            p.error(.LetDestructureRequiresTwoElements, p.span_of(start, end), "")
        }
        return TupleBinding {
            .span     = p.span_of(start, end),
            .elements = elements,
        }
    }
    if p.check(.Ident) && p.peek().text == "_" {
        tok :: p.advance()
        return WildcardBinding { .span = tok.span }
    }
    tok :: p.expect(.Ident, "binding name in destructure pattern")
    return SimpleBinding {
        .span      = tok.span,
        .name      = tok.text,
        .name_span = tok.span,
    }
}

parse_return :: fn(p: Parser) -> ReturnStmt {
    start :: p.advance()  // `return`
    value: Expr | null = null
    if !p.check(.Newline) && !p.check(.RBrace) && !p.check(.Eof) {
        value = p.parse_expr(0)
    }
    return ReturnStmt {
        .span  = p.span_of(start, p.peek_at(-1)),
        .value = value,
    }
}

parse_for :: fn(p: Parser, label: string | null, is_comptime: bool) -> ForStmt {
    start :: p.advance()  // `for`

    if p.check(.LBrace) {
        body :: p.parse_block()
        return ForStmt {
            .span  = Span { .start = start.span.start, .end = body.span.end },
            .label = label,
            .form  = InfiniteFor {},
            .body  = body,
            .is_comptime = is_comptime,
        }
    }

    saved_allow :: p.allow_struct_lit
    p.allow_struct_lit = false

    if p.check(.Ident) && p.check_at(.KwIn, 1) {
        bind_tok :: p.advance()
        p.advance()  // `in`
        iter :: p.parse_expr(0)
        p.allow_struct_lit = saved_allow
        body :: p.parse_block()
        return ForStmt {
            .span  = Span { .start = start.span.start, .end = body.span.end },
            .label = label,
            .form  = InFor { .binding = bind_tok.text, .binding_span = bind_tok.span, .iter = iter },
            .body  = body,
            .is_comptime = is_comptime,
        }
    }

    // Tuple destructure : `for [a, b] in iter { body }`. Bracket-match the
    // opening `[` ; if the matching `]` is followed by `in`, parse a let
    // binding, then desugar by introducing a synthetic name and prepending a
    // `let <pattern> := <synth>` to the body — downstream passes see a
    // regular single-binding for-in.
    if p.looks_like_for_destructure() {
        binding :: p.parse_let_binding()
        binding_span :: binding.span
        p.expect(.KwIn, "`in` after for-loop binding")
        iter :: p.parse_expr(0)
        p.allow_struct_lit = saved_allow
        body :: p.parse_block()
        // Encoding-invariant synth name : line/column are codepoint-based
        // on both lexers (TS / self-host), whereas `offset` diverges (UTF-16
        // units vs UTF-8 bytes) — see stmt.ts comment for the parity reason.
        synth :: "__for_${start.span.start.line}_${start.span.start.column}"
        synth_ident :: ident_expr(binding_span, synth)
        desugared :: LetStmt {
            .span    = binding_span,
            .mutable = false,
            .binding = binding,
            .ty      = null,
            .value   = synth_ident,
        }
        new_stmts: Stmt[] = []
        new_stmts.push(desugared)
        for s in body.stmts { new_stmts.push(s) }
        wrapped_body :: BlockExpr {
            .span     = body.span,
            .stmts    = new_stmts,
            .trailing = body.trailing,
        }
        return ForStmt {
            .span  = Span { .start = start.span.start, .end = body.span.end },
            .label = label,
            .form  = InFor { .binding = synth, .binding_span = binding_span, .iter = iter },
            .body  = wrapped_body,
            .is_comptime = is_comptime,
        }
    }

    cond :: p.parse_expr(0)
    p.allow_struct_lit = saved_allow
    body :: p.parse_block()
    // `for <range>` desugars to `for _ in <range>` ; without this
    // `for 0..<n` would type-error as a while condition. The synth
    // `binding_span` is zero-width so the formatter can tell sugar
    // apart from an explicit `for _ in`.
    if cond is RangeExpr {
        synth_span :: Span { .start = cond.span.start, .end = cond.span.start }
        return ForStmt {
            .span  = Span { .start = start.span.start, .end = body.span.end },
            .label = label,
            .form  = InFor { .binding = "_", .binding_span = synth_span, .iter = cond },
            .body  = body,
            .is_comptime = is_comptime,
        }
    }
    return ForStmt {
        .span  = Span { .start = start.span.start, .end = body.span.end },
        .label = label,
        .form  = WhileFor { .cond = cond },
        .body  = body,
        .is_comptime = is_comptime,
    }
}

// Lookahead : `[ ... ]` followed by `in`. Bracket-aware so nested patterns
// (`[a, [b, c]]`) are detected correctly. Bounded to keep pathological
// inputs from scanning the whole token stream.
looks_like_for_destructure :: fn(p: Parser) -> bool {
    if !p.check(.LBracket) { return false }
    depth := 0
    i := 0
    for {
        if i > 256 { return false }
        t :: p.peek_at(i)
        if t.kind == .Eof { return false }
        if t.kind == .LBracket { depth = depth + 1 }
        else if t.kind == .RBracket {
            depth = depth - 1
            if depth == 0 {
                return p.check_at(.KwIn, i + 1)
            }
        }
        i = i + 1
    }
}

parse_break :: fn(p: Parser) -> BreakStmt {
    start :: p.advance()
    label: string | null = null
    if p.check(.Ident) {
        label = p.advance().text
    }
    return BreakStmt {
        .span  = p.span_of(start, p.peek_at(-1)),
        .label = label,
    }
}

parse_continue :: fn(p: Parser) -> ContinueStmt {
    start :: p.advance()
    label: string | null = null
    if p.check(.Ident) {
        label = p.advance().text
    }
    return ContinueStmt {
        .span  = p.span_of(start, p.peek_at(-1)),
        .label = label,
    }
}

parse_defer :: fn(p: Parser) -> DeferStmt {
    start :: p.advance()
    body: DeferBody = DeferStmtBody { .stmt = ExprStmt { .span = start.span, .expr = NullLitExpr { .span = start.span } } }
    if p.check(.LBrace) {
        body = DeferBlockBody { .block = p.parse_block() }
    } else {
        inner :: p.parse_stmt()
        if inner != null {
            body = DeferStmtBody { .stmt = inner }
        }
    }
    body_span :: match body {
        is DeferStmtBody  -> body.stmt.span
        is DeferBlockBody -> body.block.span
    }
    return DeferStmt {
        .span = Span { .start = start.span.start, .end = body_span.end },
        .body = body,
    }
}

// ============================================================================
// Expressions — Pratt + prefix + postfix
// ============================================================================

// Precedence levels (mirror src/parser/passes/expr.ts:25-53).
//   logical : or 10/11, and 12/13
//   compare : 20 (non-assoc)
//   range   : 30 (non-assoc, encoded as Lt/Lte for snapshot parity)
//   bitwise : pipe 40, caret 50, amp 60
//   shift   : 70
//   add     : 80
//   mul     : 90
//   postfix : 100

InfixOpDescr :: struct {
    has:        bool
    left_bp:    i32
    right_bp:   i32
    op:         BinaryOp
    non_assoc:  bool
}

no_infix :: fn() = InfixOpDescr { .has = false, .left_bp = 0, .right_bp = 0, .op = .Add, .non_assoc = false }

// Range expressions don't fit BinaryOp ; we surface them via `op = Lt|Lte` on
// the descriptor and let the caller swap to a RangeExpr at the right kind.
infix_for :: fn(k: TokenKind) = match k {
    .OrOr      -> InfixOpDescr { .has = true, .left_bp = 10, .right_bp = 11, .op = .Or,     .non_assoc = false }
    .AndAnd    -> InfixOpDescr { .has = true, .left_bp = 12, .right_bp = 13, .op = .And,    .non_assoc = false }
    .Eq        -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Eq,     .non_assoc = true  }
    .Neq       -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Neq,    .non_assoc = true  }
    .Lt        -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Lt,     .non_assoc = true  }
    .Lte       -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Lte,    .non_assoc = true  }
    .Gt        -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Gt,     .non_assoc = true  }
    .Gte       -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Gte,    .non_assoc = true  }
    .KwIs      -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .Is,     .non_assoc = true  }
    .KwIn      -> InfixOpDescr { .has = true, .left_bp = 20, .right_bp = 20, .op = .In,     .non_assoc = true  }
    .RangeExcl -> InfixOpDescr { .has = true, .left_bp = 30, .right_bp = 30, .op = .Lt,     .non_assoc = true  }
    .RangeIncl -> InfixOpDescr { .has = true, .left_bp = 30, .right_bp = 30, .op = .Lte,    .non_assoc = true  }
    .DotDotDot    -> no_infix()
    .Pipe      -> InfixOpDescr { .has = true, .left_bp = 40, .right_bp = 41, .op = .BitOr,  .non_assoc = false }
    .Caret     -> InfixOpDescr { .has = true, .left_bp = 50, .right_bp = 51, .op = .BitXor, .non_assoc = false }
    .Amp       -> InfixOpDescr { .has = true, .left_bp = 60, .right_bp = 61, .op = .BitAnd, .non_assoc = false }
    .Shl       -> InfixOpDescr { .has = true, .left_bp = 70, .right_bp = 71, .op = .Shl,    .non_assoc = false }
    .Shr       -> InfixOpDescr { .has = true, .left_bp = 70, .right_bp = 71, .op = .Shr,    .non_assoc = false }
    .Plus      -> InfixOpDescr { .has = true, .left_bp = 80, .right_bp = 81, .op = .Add,    .non_assoc = false }
    .Minus     -> InfixOpDescr { .has = true, .left_bp = 80, .right_bp = 81, .op = .Sub,    .non_assoc = false }
    .Star      -> InfixOpDescr { .has = true, .left_bp = 90, .right_bp = 91, .op = .Mul,    .non_assoc = false }
    .Slash     -> InfixOpDescr { .has = true, .left_bp = 90, .right_bp = 91, .op = .Div,    .non_assoc = false }
    .Percent   -> InfixOpDescr { .has = true, .left_bp = 90, .right_bp = 91, .op = .Mod,    .non_assoc = false }
    .Eof          -> no_infix()
    .Newline      -> no_infix()
    .Ident        -> no_infix()
    .IntLit       -> no_infix()
    .FloatLit     -> no_infix()
    .CharLit      -> no_infix()
    .StringBegin  -> no_infix()
    .StringPart   -> no_infix()
    .StringEnd    -> no_infix()
    .InterpOpen   -> no_infix()
    .InterpClose  -> no_infix()
    .Tilde        -> no_infix()
    .Bang         -> no_infix()
    .Assign       -> no_infix()
    .PlusAssign   -> no_infix()
    .MinusAssign  -> no_infix()
    .StarAssign   -> no_infix()
    .SlashAssign  -> no_infix()
    .PercentAssign -> no_infix()
    .DeclConst    -> no_infix()
    .DeclVar      -> no_infix()
    .Question     -> no_infix()
    .Arrow        -> no_infix()
    .FatArrow     -> no_infix()
    .At           -> no_infix()
    .Dollar       -> no_infix()
    .LParen       -> no_infix()
    .RParen       -> no_infix()
    .LBracket     -> no_infix()
    .RBracket     -> no_infix()
    .LBrace       -> no_infix()
    .RBrace       -> no_infix()
    .Comma        -> no_infix()
    .Dot          -> no_infix()
    .Colon        -> no_infix()
    .KwFn         -> no_infix()
    .KwStruct     -> no_infix()
    .KwTrait      -> no_infix()
    .KwImplements -> no_infix()
    .KwEnum       -> no_infix()
    .KwIf         -> no_infix()
    .KwElse       -> no_infix()
    .KwMatch      -> no_infix()
    .KwFor        -> no_infix()
    .KwReturn     -> no_infix()
    .KwDefer      -> no_infix()
    .KwBreak      -> no_infix()
    .KwContinue   -> no_infix()
    .KwImport     -> no_infix()
    .KwAs         -> no_infix()
    .KwExport     -> no_infix()
    .KwTrue       -> no_infix()
    .KwFalse      -> no_infix()
    .KwNull       -> no_infix()
    .KwSelf       -> no_infix()
    .KwConst      -> no_infix()
}

// Postfix BP : `?` / `(` / `[` / `.` all bind at 100.
postfix_bp :: fn(k: TokenKind) = match k {
    .Question -> 100
    .LParen   -> 100
    .LBracket -> 100
    .Dot      -> 100
    .Eof          -> -1
    .Newline      -> -1
    .Ident        -> -1
    .IntLit       -> -1
    .FloatLit     -> -1
    .CharLit      -> -1
    .StringBegin  -> -1
    .StringPart   -> -1
    .StringEnd    -> -1
    .InterpOpen   -> -1
    .InterpClose  -> -1
    .Plus         -> -1
    .Minus        -> -1
    .Star         -> -1
    .Slash        -> -1
    .Percent      -> -1
    .Amp          -> -1
    .Pipe         -> -1
    .Caret        -> -1
    .Tilde        -> -1
    .Shl          -> -1
    .Shr          -> -1
    .Eq           -> -1
    .Neq          -> -1
    .Lt           -> -1
    .Lte          -> -1
    .Gt           -> -1
    .Gte          -> -1
    .AndAnd       -> -1
    .OrOr         -> -1
    .Bang         -> -1
    .Assign       -> -1
    .PlusAssign   -> -1
    .MinusAssign  -> -1
    .StarAssign   -> -1
    .SlashAssign  -> -1
    .PercentAssign -> -1
    .DeclConst    -> -1
    .DeclVar      -> -1
    .RangeExcl    -> -1
    .RangeIncl    -> -1
    .DotDotDot    -> -1
    .Arrow        -> -1
    .FatArrow     -> -1
    .At           -> -1
    .Dollar       -> -1
    .RParen       -> -1
    .RBracket     -> -1
    .LBrace       -> -1
    .RBrace       -> -1
    .Comma        -> -1
    .Colon        -> -1
    .KwFn         -> -1
    .KwStruct     -> -1
    .KwTrait      -> -1
    .KwImplements -> -1
    .KwEnum       -> -1
    .KwIf         -> -1
    .KwElse       -> -1
    .KwMatch      -> -1
    .KwIs         -> -1
    .KwFor        -> -1
    .KwIn         -> -1
    .KwReturn     -> -1
    .KwDefer      -> -1
    .KwBreak      -> -1
    .KwContinue   -> -1
    .KwImport     -> -1
    .KwAs         -> -1
    .KwExport     -> -1
    .KwTrue       -> -1
    .KwFalse      -> -1
    .KwNull       -> -1
    .KwSelf       -> -1
    .KwConst      -> -1
}

parse_expr :: fn(p: Parser, min_bp: i32) -> Expr {
    left := p.parse_prefix()

    // Single-param lambda sugar: `x -> expr`. Only fires when prefix
    // parse returned a bare IdentExpr (no postfix consumed) and an
    // `arrow` follows immediately. Multi-param / typed-param lambdas
    // go through the `(params) -> body` path in parse_prefix.
    match left {
        is IdentExpr as id -> {
            if p.check(.Arrow) {
                left = p.parse_single_param_lambda_tail(id)
            }
        }
        _ -> {}
    }

    last_non_assoc_level := -1

    for {
        t :: p.peek()
        pbp :: postfix_bp(t.kind)
        if pbp >= 0 && pbp >= min_bp {
            // Block-tail expressions (`if { … }`, `match { … }`, bare
            // `{ … }`) don't auto-chain index / call postfix : the next
            // statement could legitimately start with `[` (tuple-let
            // destructure) or `(`, and the free-form whitespace can't
            // tell the two cases apart. Force parens for inline
            // chaining. `.field` postfix stays unambiguous.
            // Test `t.kind` first so non-bracket postfix tokens (the
            // common case : `.field`, `?`, ...) skip the union check.
            bracketish :: t.kind == .LBracket || t.kind == .LParen
            if bracketish && (left is IfExpr || left is MatchExpr || left is BlockExpr) { break }
            left = p.parse_postfix(left, t)
            last_non_assoc_level = -1
            continue
        }

        // `!in` — two-token compound at comparison level.
        if t.kind == .Bang && p.peek_at(1).kind == .KwIn && 20 >= min_bp {
            if last_non_assoc_level == 20 {
                p.error(.NonAssocChained, t.span, "chained `!in`")
                break
            }
            p.advance()
            p.advance()
            right :: p.parse_expr(21)
            left = BinaryExpr {
                .span  = Span { .start = left.span.start, .end = right.span.end },
                .op    = .NotIn,
                .left  = left,
                .right = right,
            }
            last_non_assoc_level = 20
            continue
        }

        // `!is` desugars to `Not(BinaryExpr.Is)` ; the narrower already
        // flips then/else on `Not`, and the formatter restores the
        // spelling. `as` is rejected because the binding has no live
        // then-branch when the check is negated.
        if t.kind == .Bang && p.peek_at(1).kind == .KwIs && 20 >= min_bp {
            if last_non_assoc_level == 20 {
                p.error(.NonAssocChained, t.span, "chained `!is`")
                break
            }
            bang_tok :: p.advance()
            p.advance()  // KwIs
            right :: p.parse_expr(21)
            if p.peek().kind == .KwAs {
                as_tok :: p.advance()
                if p.peek().kind == .Ident { p.advance() }
                p.error(.UnexpectedToken, as_tok.span,
                    "`as` binding not allowed after `!is`: the binding would have no live then-branch since the type-check is negated")
            }
            is_expr :: BinaryExpr {
                .span  = Span { .start = left.span.start, .end = right.span.end },
                .op    = .Is,
                .left  = left,
                .right = right,
            }
            left = UnaryExpr {
                .span    = Span { .start = bang_tok.span.start, .end = right.span.end },
                .op      = .Not,
                .operand = is_expr,
            }
            last_non_assoc_level = 20
            continue
        }

        infix :: infix_for(t.kind)
        if infix.has && infix.left_bp >= min_bp {
            if infix.non_assoc && last_non_assoc_level == infix.left_bp {
                p.error(.NonAssocChained, t.span, "chained `${describe_token(t)}`")
                break
            }
            p.advance()
            right_bp :: if infix.non_assoc { infix.right_bp + 1 } else { infix.right_bp }
            right :: p.parse_expr(right_bp)
            if t.kind == .RangeExcl || t.kind == .RangeIncl {
                left = RangeExpr {
                    .span      = Span { .start = left.span.start, .end = right.span.end },
                    .inclusive = t.kind == .RangeIncl,
                    .lower     = left,
                    .upper     = right,
                }
            } else {
                // `is T as <ident>` — binds the narrowed RHS in the
                // enclosing if's then-branch. Mirrors `parse_pattern`'s
                // `IsPattern.bind_as` for match arms.
                bind_as := ""
                end_pos := right.span.end
                if infix.op == .Is && p.peek().kind == .KwAs {
                    p.advance()
                    name_tok :: p.expect(.Ident, "binding name after `as`")
                    bind_as = name_tok.text
                    end_pos = name_tok.span.end
                }
                left = BinaryExpr {
                    .span    = Span { .start = left.span.start, .end = end_pos },
                    .op      = infix.op,
                    .left    = left,
                    .right   = right,
                    .bind_as = bind_as,
                }
            }
            last_non_assoc_level = if infix.non_assoc { infix.left_bp } else { -1 }
            continue
        }

        break
    }

    return left
}

parse_prefix :: fn(p: Parser) -> Expr {
    t :: p.peek()
    if t.kind == .IntLit {
        p.advance()
        v: u64 = u64(0)
        val :: t.value
        if val is u64 { v = val }
        suffix: string | null = if !t.numeric_suffix.is_empty() { t.numeric_suffix } else { null }
        return IntLitExpr { .span = t.span, .value = v, .suffix = suffix }
    }
    if t.kind == .FloatLit {
        p.advance()
        v: f64 = 0.0
        val :: t.value
        if val is f64 { v = val }
        suffix: string | null = if !t.numeric_suffix.is_empty() { t.numeric_suffix } else { null }
        return FloatLitExpr { .span = t.span, .value = v, .suffix = suffix }
    }
    if t.kind == .CharLit {
        p.advance()
        v: u32 = 0u32
        val :: t.value
        if val is u32 { v = val }
        return CharLitExpr { .span = t.span, .value = v }
    }
    if t.kind == .KwTrue {
        p.advance()
        return BoolLitExpr { .span = t.span, .value = true }
    }
    if t.kind == .KwFalse {
        p.advance()
        return BoolLitExpr { .span = t.span, .value = false }
    }
    if t.kind == .KwNull {
        p.advance()
        return NullLitExpr { .span = t.span }
    }
    if t.kind == .StringBegin { return p.parse_string_lit() }
    if t.kind == .Ident       { return p.parse_ident_or_struct_lit() }
    if t.kind == .LParen {
        if p.peek_lambda_without_fn() { return p.parse_lambda_without_fn() }
        return p.parse_paren()
    }
    if t.kind == .LBracket    { return p.parse_seq_lit() }
    if t.kind == .LBrace      { return p.parse_block() }
    if t.kind == .Minus || t.kind == .Bang || t.kind == .Tilde {
        p.advance()
        op: UnaryOp = .Neg
        if t.kind == .Bang  { op = .Not    }
        if t.kind == .Tilde { op = .BitNot }
        operand :: p.parse_expr(95)
        return UnaryExpr {
            .span    = Span { .start = t.span.start, .end = operand.span.end },
            .op      = op,
            .operand = operand,
        }
    }
    if t.kind == .KwIf    { return p.parse_if_expr() }
    if t.kind == .KwMatch { return p.parse_match_expr(false) }
    if t.kind == .KwFn    { return p.parse_lambda() }
    if t.kind == .KwSelf {
        p.advance()
        return ident_expr(t.span, "self")
    }
    // Two expression-position `@` forms :
    //   `@partial match x { ... }`  — opt-out of exhaustiveness for a match
    //   `@<intrinsic>(args)`        — compiler reflection / introspection call
    //                                 (`@size_of`, `@type_name`, `@file`, …).
    //                                 The set of recognised names lives in
    //                                 `vader/parser/intrinsics.vader`.
    // Anything else is P1014.
    if t.kind == .At {
        at_tok :: p.advance()
        name_tok :: p.expect(.Ident, "decorator name after `@`")
        if name_tok.text == "partial" {
            if !p.check(.KwMatch) {
                p.error(.UnknownDecoratorPlacement, name_tok.span,
                    "`@${name_tok.text}` must precede a `match` expression")
            }
            return p.parse_match_expr(true)
        }
        spec :: intrinsic_spec(name_tok.text)
        match spec {
            is null -> {
                p.error(.UnknownDecoratorPlacement,
                    p.span_of(at_tok, name_tok),
                    "`@${name_tok.text}` is not allowed in expression position")
                // Fall through to recover with the same shape — consume a
                // trailing `(...)` if present so we don't cascade errors.
                if p.check(.LParen) {
                    p.advance()  // (
                    for !p.check(.RParen) && !p.check(.Eof) { p.advance() }
                    if p.check(.RParen) { p.advance() }
                }
                return ident_expr(p.span_of(at_tok, name_tok), name_tok.text)
            }
            is IntrinsicSpec as sp -> {
                p.expect(.LParen, "`(` after `@${sp.name}`")
                args: Expr[] = []
                p.skip_newlines()
                if !p.check(.RParen) {
                    for {
                        p.skip_newlines()
                        if p.check(.RParen) { break }
                        idx :: args.len()
                        // Type-shape args go through parse_type so postfix
                        // `[]`, `|` etc. parse with type semantics ;
                        // value-shape args go through the regular expr
                        // parser.
                        is_type := false
                        if idx < sp.args.len() && sp.args[idx] == IntrinsicArgKind.Type {
                            is_type = true
                        }
                        if is_type {
                            args.push(p.parse_type())
                        } else {
                            args.push(p.parse_expr(0))
                        }
                        p.skip_newlines()
                        if p.match_kind(.Comma) == null { break }
                    }
                }
                end :: p.expect(.RParen, "`)` to close `@${sp.name}(...)`")
                return IntrinsicCallExpr {
                    .span      = p.span_of(at_tok, end),
                    .name      = sp.name,
                    .name_span = name_tok.span,
                    .args      = args,
                }
            }
        }
    }
    if t.kind == .Dot {
        p.advance()
        v_tok :: p.expect(.Ident, "variant name after `.`")
        return DotVariantExpr {
            .span         = Span { .start = t.span.start, .end = v_tok.span.end },
            .variant      = v_tok.text,
            .variant_span = v_tok.span,
        }
    }
    p.error(.ExpectedExpression, t.span, "got ${describe_token(t)}")
    p.advance()
    return NullLitExpr { .span = t.span }
}

parse_postfix :: fn(p: Parser, left: Expr, t: Token) -> Expr {
    if t.kind == .Question {
        p.advance()
        return TryExpr {
            .span  = Span { .start = left.span.start, .end = t.span.end },
            .inner = left,
        }
    }
    if t.kind == .Dot {
        p.advance()
        // Numeric tuple-index access `t.0`, `t.1`, ... — the lowerer rewrites
        // these to synthetic field names `_0`, `_1`, ...
        if p.check(.IntLit) {
            num_tok :: p.advance()
            return FieldExpr {
                .span       = Span { .start = left.span.start, .end = num_tok.span.end },
                .target     = left,
                .field      = num_tok.text,
                .field_span = num_tok.span,
                .is_numeric = true,
            }
        }
        name :: p.expect(.Ident, "field name after `.`")
        field_expr :: FieldExpr {
            .span       = Span { .start = left.span.start, .end = name.span.end },
            .target     = left,
            .field      = name.text,
            .field_span = name.span,
            .is_numeric = false,
        }
        // Qualified struct literal : `module.Type { .field = …, … }`. The
        // bare-ident path goes through `parse_ident_or_struct_lit` at
        // prefix time ; the qualified form lands here because `module` was
        // already consumed as the prefix expression and `.Type` is a
        // postfix `dot`. Same struct-lit gate as the bare path.
        if p.allow_struct_lit && p.check(.LBrace) && looks_like_struct_lit_body(p.tokens, p.pos) {
            p.advance()
            items :: p.parse_struct_lit_fields()
            rb :: p.expect(.RBrace, "`}` to close struct literal")
            return StructLitExpr {
                .span      = Span { .start = left.span.start, .end = rb.span.end },
                .type_name = field_expr,
                .items     = items,
            }
        }
        return field_expr
    }
    if t.kind == .LParen {
        p.advance()
        args :: p.parse_call_args()
        p.expect(.RParen, "`)` to close argument list")
        return CallExpr {
            .span   = Span { .start = left.span.start, .end = p.peek_at(-1).span.end },
            .callee = left,
            .args   = args,
        }
    }
    // .LBracket — two readings :
    //   `T[]`  (empty brackets) → ArrayTypeExpr ; type-only construct,
    //                             typechecker rejects it in value position.
    //   `T[i]` (with index)     → IndexExpr (ordinary value-level indexing).
    if p.check_at(.RBracket, 1) {
        p.advance()  // [
        rb :: p.advance()  // ]
        return ArrayTypeExpr {
            .span    = Span { .start = left.span.start, .end = rb.span.end },
            .element = left,
        }
    }
    p.advance()
    index :: p.parse_expr(0)
    p.expect(.RBracket, "`]` to close index")
    return IndexExpr {
        .span   = Span { .start = left.span.start, .end = p.peek_at(-1).span.end },
        .target = left,
        .index  = index,
    }
}

parse_call_args :: fn(p: Parser) -> CallArg[] {
    out: CallArg[] = []
    p.skip_newlines()
    if p.check(.RParen) { return out }
    for {
        p.skip_newlines()
        if p.check(.RParen) { break }
        start :: p.peek()
        if p.check(.Ident) && p.check_at(.Assign, 1) {
            name_tok :: p.advance()
            p.advance()  // `=`
            value :: p.parse_expr(0)
            out.push(CallArg {
                .span   = p.span_of(start, p.peek_at(-1)),
                .name   = name_tok.text,
                .value  = value,
                .spread = false,
            })
        } else {
            value :: p.parse_expr(0)
            out.push(CallArg {
                .span   = value.span,
                .name   = null,
                .value  = value,
                .spread = false,
            })
        }
        p.skip_newlines()
        if p.match_kind(.Comma) == null { break }
    }
    return out
}

parse_ident_or_struct_lit :: fn(p: Parser) -> Expr {
    t :: p.advance()
    // Generic struct literal `Foo(T) { .field = ... }`.
    if p.allow_struct_lit && p.peek_is_generic_struct_lit() {
        p.advance()  // `(`
        args: TypeExpr[] = []
        p.skip_newlines()
        if !p.check(.RParen) {
            for {
                p.skip_newlines()
                if p.check(.RParen) { break }
                args.push(p.parse_type())
                p.skip_newlines()
                if p.match_kind(.Comma) == null { break }
            }
        }
        rp :: p.expect(.RParen, "`)` to close generic argument list")
        p.expect(.LBrace, "`{` to open generic struct literal")
        items :: p.parse_struct_lit_fields()
        rb :: p.expect(.RBrace, "`}` to close struct literal")
        return StructLitExpr {
            .span      = p.span_of(t, rb),
            .type_name = GenericInstExpr {
                .span      = p.span_of(t, rp),
                .callee    = ident_expr(t.span, t.text),
                .type_args = args,
            },
            .items     = items,
        }
    }

    if p.allow_struct_lit && p.check(.LBrace) && looks_like_struct_lit_body(p.tokens, p.pos) {
        p.advance()
        items :: p.parse_struct_lit_fields()
        rb :: p.expect(.RBrace, "`}` to close struct literal")
        return StructLitExpr {
            .span      = p.span_of(t, rb),
            .type_name = ident_expr(t.span, t.text),
            .items     = items,
        }
    }
    return ident_expr(t.span, t.text)
}

// Lookahead : `( <bal> ) {` followed by a `.<field>` struct-lit body?
peek_is_generic_struct_lit :: fn(p: Parser) -> bool {
    n :: i32(p.tokens.len())
    if p.pos >= n { return false }
    if p.tokens[usize(p.pos)].kind != .LParen { return false }
    depth := 1
    j := p.pos + 1
    closing := -1
    for j < n && depth > 0 {
        t :: p.tokens[usize(j)]
        if t.kind == .Eof { return false }
        if t.kind == .LParen { depth = depth + 1 }
        else if t.kind == .RParen {
            depth = depth - 1
            if depth == 0 {
                closing = j
                break
            }
        }
        j = j + 1
    }
    if closing < 0 || depth != 0 { return false }
    k := closing + 1
    for k < n && p.tokens[usize(k)].kind == .Newline { k = k + 1 }
    if k >= n || p.tokens[usize(k)].kind != .LBrace { return false }
    return looks_like_struct_lit_body(p.tokens, k)
}

looks_like_struct_lit_body :: fn(tokens: Token[], pos_at_lbrace: i32) -> bool {
    n :: i32(tokens.len())
    i := pos_at_lbrace + 1
    for i < n {
        t :: tokens[usize(i)]
        if t.kind == .Newline {
            i = i + 1
            continue
        }
        return t.kind == .Dot || t.kind == .DotDotDot || t.kind == .RBrace
    }
    return false
}

parse_struct_lit_fields :: fn(p: Parser) -> (StructLitField | StructLitSpread)[] {
    out: (StructLitField | StructLitSpread)[] = []
    p.skip_newlines()
    for !p.check(.RBrace) && !p.check(.Eof) {
        start :: p.peek()
        if p.match_kind(.DotDotDot) != null {
            spread_expr :: p.parse_expr(0)
            out.push(StructLitSpread {
                .span = p.span_of(start, p.peek_at(-1)),
                .expr = spread_expr,
            })
        } else {
            p.expect(.Dot, "`.` before struct literal field name")
            name :: p.expect(.Ident, "struct literal field name")
            p.expect(.Assign, "`=` after struct literal field name")
            value :: p.parse_expr(0)
            out.push(StructLitField {
                .span      = p.span_of(start, p.peek_at(-1)),
                .name      = name.text,
                .name_span = name.span,
                .value     = value,
            })
        }
        p.skip_newlines()
        if p.match_kind(.Comma) == null { break }
        p.skip_newlines()
    }
    p.skip_newlines()
    return out
}

parse_paren :: fn(p: Parser) -> Expr {
    p.advance()  // `(`
    p.skip_newlines()
    saved_allow :: p.allow_struct_lit
    p.allow_struct_lit = true
    expr :: p.parse_expr(0)
    p.allow_struct_lit = saved_allow
    p.skip_newlines()
    p.expect(.RParen, "`)` to close parenthesised expression")
    return expr
}

// True when the upcoming `( … )` is followed by `->`, i.e. the shape opens
// a lambda without the `fn` keyword. Balanced-paren scan, then skip newlines.
peek_lambda_without_fn :: fn(p: Parser) -> bool {
    if p.peek().kind != .LParen { return false }
    depth: i32 = 1
    i: i32 = 1
    for depth > 0 {
        k :: p.peek_at(i).kind
        if k == .Eof { return false }
        if k == .LParen { depth = depth + 1 }
        else if k == .RParen {
            depth = depth - 1
            if depth == 0 { break }
        }
        i = i + 1
    }
    // skip newlines after the matching `)`
    i = i + 1
    for p.peek_at(i).kind == .Newline { i = i + 1 }
    return p.peek_at(i).kind == .Arrow
}

// Parse `(params) -> body` as a lambda (no `fn` keyword). The opening `(`
// is still on the parser ; `parse_fn_signature_params` consumes it.
parse_lambda_without_fn :: fn(p: Parser) -> LambdaExpr {
    start :: p.peek()
    sig :: p.parse_fn_signature_params()
    p.expect(.Arrow, "`->` between lambda params and body")
    body_expr :: p.parse_expr(0)
    body :: wrap_as_block(body_expr)
    return LambdaExpr {
        .span        = Span { .start = start.span.start, .end = body.span.end },
        .params      = sig.params,
        .return_type = null,
        .body        = body,
    }
}

// Tail-parse `-> body` after a bare IdentExpr consumed by parse_prefix.
// Builds the single-param lambda with the ident as a typeless FnParam.
parse_single_param_lambda_tail :: fn(p: Parser, param_ident: IdentExpr) -> LambdaExpr {
    p.advance()  // ->
    param :: FnParam {
        .span          = param_ident.span,
        .name          = param_ident.name,
        .ty            = null,
        .default_value = null,
        .variadic      = false,
    }
    body_expr :: p.parse_expr(0)
    body :: wrap_as_block(body_expr)
    return LambdaExpr {
        .span        = Span { .start = param_ident.span.start, .end = body.span.end },
        .params      = [param],
        .return_type = null,
        .body        = body,
    }
}

// Wrap a body expression in a synthetic BlockExpr if it is not already
// one. Keeps the AST shape `LambdaExpr.body: BlockExpr` stable for
// downstream consumers.
wrap_as_block :: fn(body: Expr) -> BlockExpr {
    if body is BlockExpr { return body }
    return BlockExpr {
        .span     = body.span,
        .stmts    = [],
        .trailing = body,
    }
}

parse_seq_lit :: fn(p: Parser) -> SeqLitExpr {
    lb :: p.advance()
    elements: Expr[] = []
    p.skip_newlines()
    if !p.check(.RBracket) {
        for {
            p.skip_newlines()
            if p.check(.RBracket) { break }
            elements.push(p.parse_expr(0))
            p.skip_newlines()
            if p.match_kind(.Comma) == null { break }
            p.skip_newlines()
        }
    }
    rb :: p.expect(.RBracket, "`]` to close seq literal")
    return SeqLitExpr {
        .span     = p.span_of(lb, rb),
        .elements = elements,
    }
}

parse_string_lit :: fn(p: Parser) -> StringLitExpr {
    begin :: p.advance()  // string_begin
    parts: StringLitPart[] = []
    for !p.check(.StringEnd) && !p.check(.Eof) {
        t :: p.peek()
        if t.kind == .StringPart {
            p.advance()
            text: string = t.text
            val :: t.value
            match val {
                is string -> { text = val }
                _         -> {}
            }
            parts.push(StringLitText { .value = text, .span = t.span })
            continue
        }
        if t.kind == .InterpOpen {
            interp_start :: p.advance()
            expr :: p.parse_expr(0)
            close_match :: p.match_kind(.InterpClose)
            close_span :: if close_match != null { close_match.span } else { expr.span }
            parts.push(StringLitInterp {
                .expr = expr,
                .span = Span { .start = interp_start.span.start, .end = close_span.end },
            })
            continue
        }
        p.error(.UnexpectedToken, t.span, "inside string literal")
        p.advance()
    }
    end_tok :: p.match_or_peek(.StringEnd)
    return StringLitExpr {
        .span  = p.span_of(begin, end_tok),
        .parts = parts,
    }
}

parse_if_expr :: fn(p: Parser) -> IfExpr {
    start :: p.advance()  // `if`
    saved_allow :: p.allow_struct_lit
    p.allow_struct_lit = false

    cond: Expr = NullLitExpr { .span = start.span }
    if p.match_kind(.LParen) != null {
        p.allow_struct_lit = true
        cond = p.parse_expr(0)
        p.expect(.RParen, "`)` to close `if` condition")
    } else {
        cond = p.parse_expr(0)
    }
    p.allow_struct_lit = saved_allow

    then_block :: p.parse_block()
    else_branch: IfElse | null = null
    p.skip_newlines()
    if p.match_kind(.KwElse) != null {
        p.skip_newlines()
        if p.check(.KwIf) {
            else_branch = IfElseIf { .branch = p.parse_if_expr() }
        } else {
            else_branch = IfElseBlock { .block = p.parse_block() }
        }
    }
    end_span :: match else_branch {
        is IfElseIf    -> else_branch.branch.span
        is IfElseBlock -> else_branch.block.span
        is null        -> then_block.span
    }
    return IfExpr {
        .span        = Span { .start = start.span.start, .end = end_span.end },
        .cond        = cond,
        .then_block  = then_block,
        .else_branch = else_branch,
    }
}

parse_match_expr :: fn(p: Parser, partial: bool) -> MatchExpr {
    start :: p.advance()  // `match`
    saved_allow :: p.allow_struct_lit
    p.allow_struct_lit = false
    scrutinee :: p.parse_expr(0)
    p.allow_struct_lit = saved_allow

    p.expect(.LBrace, "`{` to open match arms")
    p.skip_newlines()
    arms: MatchArm[] = []
    for !p.check(.RBrace) && !p.check(.Eof) {
        arms.push(p.parse_match_arm())
        p.skip_newlines()
        if p.match_kind(.Comma) != null { p.skip_newlines() }
    }
    end :: p.expect(.RBrace, "`}` to close match")
    return MatchExpr {
        .span      = Span { .start = start.span.start, .end = end.span.end },
        .scrutinee = scrutinee,
        .arms      = arms,
        .partial   = partial,
    }
}

parse_match_arm :: fn(p: Parser) -> MatchArm {
    start :: p.peek()
    pattern :: p.parse_pattern()
    guard: Expr | null = null
    if p.match_kind(.KwIf) != null {
        saved_allow :: p.allow_struct_lit
        p.allow_struct_lit = false
        guard = p.parse_expr(0)
        p.allow_struct_lit = saved_allow
    }
    p.expect(.Arrow, "`->` between pattern and arm body")
    body :: p.parse_expr(0)
    return MatchArm {
        .span    = Span { .start = start.span.start, .end = body.span.end },
        .pattern = pattern,
        .guard   = guard,
        .body    = body,
    }
}

parse_lambda :: fn(p: Parser) -> LambdaExpr {
    start :: p.advance()  // `fn`
    sig :: p.parse_fn_signature_params()
    return_type: TypeExpr | null = null
    if p.match_kind(.Arrow) != null { return_type = p.parse_type() }
    body :: p.parse_block()
    return LambdaExpr {
        .span        = Span { .start = start.span.start, .end = body.span.end },
        .params      = sig.params,
        .return_type = return_type,
        .body        = body,
    }
}

// ============================================================================
// Patterns
// ============================================================================

parse_pattern :: fn(p: Parser) -> Pattern {
    t :: p.peek()
    if t.kind == .Dot {
        p.advance()
        v_tok :: p.expect(.Ident, "variant name after `.`")
        return EnumVariantPattern {
            .span    = Span { .start = t.span.start, .end = v_tok.span.end },
            .variant = v_tok.text,
        }
    }
    if t.kind == .KwIs {
        p.advance()
        ty: TypeExpr = if p.check(.Dot) {
            // `is .Foo` — implicit-dot variant, resolved against the
            // match scrutinee at typecheck. Plain `parse_type` would
            // reject the leading dot, so we synthesise a flagged
            // `IdentExpr` directly.
            dot_tok :: p.advance()
            v_tok :: p.expect(.Ident, "variant name after `.`")
            IdentExpr {
                .span                = p.span_of(dot_tok, v_tok),
                .name                = v_tok.text,
                .implicit_dot        = true,
                .is_type_param_intro = false,
            }
        } else {
            p.parse_type()
        }
        inner: Pattern | null = null
        if p.check(.LBrace) {
            inner = p.parse_struct_pattern()
        }
        bind_as: string | null = null
        if p.match_kind(.KwAs) != null {
            bind_as = p.expect(.Ident, "binding name after `as`").text
        }
        return IsPattern {
            .span    = p.span_of(t, p.peek_at(-1)),
            .ty      = ty,
            .inner   = inner,
            .bind_as = bind_as,
        }
    }
    if t.kind == .Ident && t.text == "_" {
        p.advance()
        return WildcardPattern { .span = t.span }
    }
    if t.kind == .Ident {
        p.advance()
        return BindingPattern { .span = t.span, .name = t.text }
    }
    if t.kind == .LBracket {
        return p.parse_tuple_pattern()
    }
    if is_literal_start(t) {
        // `'a' -> …` / `42 -> …` / `true -> …` / `null -> …` / `-1 -> …`.
        // Delegate to the regular expression parser so each literal flavour
        // (int / float / char / string / bool / null / unary-neg) is recognised
        // exactly once. `parse_expr` stops at `->` because the arrow isn't an
        // infix op — the arm's predicate stays the literal alone.
        value :: p.parse_expr(0)
        return LiteralPattern {
            .span  = p.span_of(t, p.peek_at(-1)),
            .value = value,
        }
    }
    p.error(.ExpectedPattern, t.span, "got ${describe_token(t)}")
    p.advance()
    return WildcardPattern { .span = t.span }
}

parse_tuple_pattern :: fn(p: Parser) -> TuplePattern {
    start :: p.advance()  // `[`
    p.skip_newlines()
    elements: Pattern[] = []
    if !p.check(.RBracket) {
        for {
            p.skip_newlines()
            if p.check(.RBracket) { break }
            elements.push(p.parse_pattern())
            p.skip_newlines()
            if p.match_kind(.Comma) == null { break }
            p.skip_newlines()
        }
    }
    end :: p.expect(.RBracket, "`]` to close tuple pattern")
    if elements.len() < 2 {
        p.error(.TuplePatternRequiresTwoElements, p.span_of(start, end), "")
    }
    return TuplePattern {
        .span     = p.span_of(start, end),
        .elements = elements,
    }
}

parse_struct_pattern :: fn(p: Parser) -> StructPattern {
    start :: p.expect(.LBrace, "`{` to open struct pattern")
    p.skip_newlines()
    fields: StructPatternField[] = []
    for !p.check(.RBrace) && !p.check(.Eof) {
        f_start :: p.peek()
        name :: p.expect(.Ident, "field name in struct pattern")
        value: PatternFieldValue = PatternBinding { .name = name.text, .span = name.span }
        if p.match_kind(.Colon) != null {
            // either rebinding `field: name` or literal `field: <expr>`
            if p.check(.Ident) && !is_literal_start(p.peek_at(1)) {
                bind_tok :: p.advance()
                value = PatternBinding { .name = bind_tok.text, .span = bind_tok.span }
            } else {
                value = PatternLiteral { .value = p.parse_expr(0) }
            }
        }
        fields.push(StructPatternField {
            .span      = p.span_of(f_start, p.peek_at(-1)),
            .name      = name.text,
            .name_span = name.span,
            .value     = value,
        })
        p.skip_newlines()
        if p.match_kind(.Comma) == null { break }
        p.skip_newlines()
    }
    end :: p.expect(.RBrace, "`}` to close struct pattern")
    return StructPattern {
        .span   = Span { .start = start.span.start, .end = end.span.end },
        .fields = fields,
    }
}

is_literal_start :: fn(t: Token) -> bool {
    return (t.kind == .IntLit) || (t.kind == .FloatLit) || (t.kind == .CharLit) || (t.kind == .StringBegin) || (t.kind == .KwTrue) || (t.kind == .KwFalse) || (t.kind == .KwNull) || (t.kind == .Minus)
}
