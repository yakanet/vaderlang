// vader/parser/dump тАФ AST тЖТ JSON pretty-printer that mirrors the TS
// `formatProgram` (`tests/snapshot.ts`).
//
// Snapshot format : `# AST\n` header + 2-space-indented JSON. Spans are
// stripped (they're noisy and span numbers shift across tiny edits) ; ints
// land as quoted decimal strings with a trailing `n` so the snapshot stays
// stable when the same value is parsed by the TS BigInt-based parser. The
// helpers below walk every variant explicitly тАФ no reflection.

import "std/string" { byte_len, chars, is_empty, pad_start }
import "std/string_builder" { StringBuilder, new_builder, append, append_char, append_repeated }
import "std/numbers" { to_hex, to_compact_str }

export dump_program :: fn(prog: Program) -> string {
    sb := new_builder()
    sb.append("# AST\n")
    sb.write_program(prog, 0)
    // The CLI wrapper adds the trailing newline via `println`. Returning a
    // value without one keeps the snapshot byte-for-byte with TS where
    // `formatProgram` returns `# AST\n<json>\n`.
    return sb.to_string()
}

// ============================================================================
// JSON primitives (raw strings, indentation, key-value helpers)
// ============================================================================

// Local indentation helper тАФ wraps `append_repeated` so existing call sites
// that pass `level` (rather than the absolute space count) don't have to
// multiply themselves. The 2-space stride matches the TS dumper.
indent :: fn(sb: StringBuilder, level: i32) -> void {
    sb.append_repeated(' ', level * 2)
}

write_string :: fn(sb: StringBuilder, s: string) -> void {
    sb.append_char('"')
    // Walk by codepoint so multi-byte sequences emit cleanly (a byte
    // walk would surface FFFD on continuation bytes).
    for c in s.chars() {
        if c == '"'  { sb.append("\\\"") }
        else if c == '\\' { sb.append("\\\\") }
        else if c == '\n' { sb.append("\\n") }
        else if c == '\r' { sb.append("\\r") }
        else if c == '\t' { sb.append("\\t") }
        else if c < ' ' {
            // Vader's char-literal grammar doesn't expose \b/\f, so every
            // remaining control char goes out as \u00XX. `to_hex` already
            // handles the lowercase digit table.
            sb.append("\\u00")
            sb.append(u64(u32(c)).to_hex().pad_start(2, '0'))
        } else {
            sb.append_char(c)
        }
    }
    sb.append_char('"')
}

// Bigint rendering : matches the TS `bigintReplacer` shape тАФ quoted decimal
// with a trailing `n`. `${v}` invokes `Display` on i64.
write_bigint :: fn(sb: StringBuilder, v: i64) -> void {
    sb.append("\"${v}n\"")
}

// Match JS `JSON.stringify` : integer-valued floats serialise without `.0`
// (`10.0` тЖТ `"10"`). Delegates to `f64.to_compact_str` from std/numbers.
write_f64 :: fn(sb: StringBuilder, v: f64) -> void {
    sb.append(v.to_compact_str())
}

write_null :: fn(sb: StringBuilder) -> void { sb.append("null") }
write_bool :: fn(sb: StringBuilder, v: bool) -> void {
    if v { sb.append("true") } else { sb.append("false") }
}

// Begin/end helpers reduce indent bookkeeping noise at call sites.
open_obj :: fn(sb: StringBuilder) -> void { sb.append_char('{') }
close_obj :: fn(sb: StringBuilder, level: i32) -> void {
    sb.append_char('\n')
    indent(sb, level)
    sb.append_char('}')
}

open_arr :: fn(sb: StringBuilder) -> void { sb.append_char('[') }
close_arr_empty :: fn(sb: StringBuilder) -> void { sb.append("[]") }
close_arr :: fn(sb: StringBuilder, level: i32) -> void {
    sb.append_char('\n')
    indent(sb, level)
    sb.append_char(']')
}

// Emit `<comma><newline><indent>"key": ` for object entries. Pass `first =
// true` for the very first entry (no leading comma).
entry :: fn(sb: StringBuilder, first: bool, level: i32, key: string) -> void {
    if !first { sb.append_char(',') }
    sb.append_char('\n')
    indent(sb, level)
    sb.append_char('"')
    sb.append(key)
    sb.append("\": ")
}

kind_entry :: fn(sb: StringBuilder, level: i32, kind: string) -> void {
    entry(sb, true, level, "kind")
    write_string(sb, kind)
}

// ============================================================================
// Program / Decl
// ============================================================================

write_program :: fn(sb: StringBuilder, prog: Program, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "Program")
    entry(sb, false, level + 1, "decls")
    write_decls(sb, prog.decls, level + 1)
    close_obj(sb, level)
}

write_decls :: fn(sb: StringBuilder, decls: Decl[], level: i32) -> void {
    if decls.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for d in decls {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_decl(sb, d, level + 1)
    }
    close_arr(sb, level)
}

write_decl :: fn(sb: StringBuilder, d: Decl, level: i32) -> void {
    match d {
        is ImportDecl    -> { write_import_decl(sb, d, level) }
        is FnDecl        -> { write_fn_decl(sb, d, level) }
        is StructDecl    -> { write_struct_decl(sb, d, level) }
        is EnumDecl      -> { write_enum_decl(sb, d, level) }
        is TraitDecl     -> { write_trait_decl(sb, d, level) }
        is ImplDecl      -> { write_impl_decl(sb, d, level) }
        is TypeAliasDecl -> { write_type_alias_decl(sb, d, level) }
        is ConstDecl     -> { write_const_decl(sb, d, level) }
        is AssertDecl    -> { write_assert_decl(sb, d, level) }
    }
}

// ---- ImportDecl -----------------------------------------------------------

write_import_decl :: fn(sb: StringBuilder, d: ImportDecl, level: i32) -> void {
    sb.open_obj()
    sb.kind_entry(level + 1, "ImportDecl")
    sb.entry(false, level + 1, "path")
    sb.write_string(d.path)
    sb.entry(false, level + 1, "binding")
    sb.write_import_binding(d.binding, level + 1)
    sb.entry(false, level + 1, "decorators")
    sb.write_decorators(d.decorators, level + 1)
    sb.close_obj(level)
}

write_import_binding :: fn(sb: StringBuilder, b: ImportBinding, level: i32) -> void {
    open_obj(sb)
    match b {
        is NamespaceImport -> {
            sb.kind_entry(level + 1, "namespace")
        }
        is AliasImport -> {
            sb.kind_entry(level + 1, "alias")
            sb.entry(false, level + 1, "alias")
            sb.write_string(b.alias)
        }
        is DestructureImport -> {
            sb.kind_entry(level + 1, "destructure")
            sb.entry(false, level + 1, "names")
            sb.write_import_names(b.names, level + 1)
        }
    }
    sb.close_obj(level)
}

write_import_names :: fn(sb: StringBuilder, names: ImportName[], level: i32) -> void {
    if names.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for n in names {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        write_string(sb, n.name)
        entry(sb, false, level + 2, "alias")
        alias :: n.alias

        match alias {
            is null      -> { write_null(sb) }
            is string -> { write_string(sb, alias) }
        }
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

// ---- FnDecl ---------------------------------------------------------------

write_fn_decl :: fn(sb: StringBuilder, d: FnDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "FnDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "typeParams")
    write_type_params(sb, d.type_params, level + 1)
    entry(sb, false, level + 1, "params")
    write_fn_params(sb, d.params, level + 1)
    entry(sb, false, level + 1, "returnType")
    write_optional_type(sb, d.return_type, level + 1)
    entry(sb, false, level + 1, "body")
    body :: d.body

    match body {
        is null              -> { write_null(sb) }
        is BlockExpr -> { write_block_expr(sb, body, level + 1) }
    }
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    if d.sam_synthetic {
        entry(sb, false, level + 1, "samSynthetic")
        write_bool(sb, true)
    }
    if d.is_expression_bodied {
        entry(sb, false, level + 1, "isExpressionBodied")
        write_bool(sb, true)
    }
    close_obj(sb, level)
}

write_fn_params :: fn(sb: StringBuilder, params: FnParam[], level: i32) -> void {
    if params.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for pp in params {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_fn_param(sb, pp, level + 1)
    }
    close_arr(sb, level)
}

write_fn_param :: fn(sb: StringBuilder, p: FnParam, level: i32) -> void {
    open_obj(sb)
    entry(sb, true, level + 1, "name")
    write_string(sb, p.name)
    entry(sb, false, level + 1, "type")
    write_optional_type(sb, p.ty, level + 1)
    entry(sb, false, level + 1, "defaultValue")
    write_optional_expr(sb, p.default_value, level + 1)
    entry(sb, false, level + 1, "variadic")
    write_bool(sb, p.variadic)
    close_obj(sb, level)
}

// ---- StructDecl -----------------------------------------------------------

write_struct_decl :: fn(sb: StringBuilder, d: StructDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "StructDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "typeParams")
    write_type_params(sb, d.type_params, level + 1)
    entry(sb, false, level + 1, "fields")
    write_struct_fields(sb, d.fields, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_struct_fields :: fn(sb: StringBuilder, fields: StructField[], level: i32) -> void {
    if fields.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for f in fields {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        write_string(sb, f.name)
        entry(sb, false, level + 2, "type")
        write_type(sb, f.ty, level + 2)
        entry(sb, false, level + 2, "visibility")
        write_visibility(sb, f.visibility)
        entry(sb, false, level + 2, "default")
        write_optional_expr(sb, f.default, level + 2)
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

// ---- EnumDecl -------------------------------------------------------------

write_enum_decl :: fn(sb: StringBuilder, d: EnumDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "EnumDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "repr")
    write_optional_type(sb, d.repr, level + 1)
    entry(sb, false, level + 1, "variants")
    if d.variants.len() == 0 { close_arr_empty(sb) }
    else {
        open_arr(sb)
        first := true
        for v in d.variants {
            if !first { sb.append_char(',') }
            first = false
            sb.append_char('\n')
            indent(sb, level + 2)
            open_obj(sb)
            entry(sb, true, level + 3, "name")
            write_string(sb, v.name)
            entry(sb, false, level + 3, "value")
            mv :: v.value

            match mv {
                is null    -> { write_null(sb) }
                is i64 -> { write_bigint(sb, mv) }
            }
            close_obj(sb, level + 2)
        }
        close_arr(sb, level + 1)
    }
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

// ---- TraitDecl / ImplDecl / TypeAliasDecl / ConstDecl --------------------

write_trait_decl :: fn(sb: StringBuilder, d: TraitDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "TraitDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "typeParams")
    write_type_params(sb, d.type_params, level + 1)
    entry(sb, false, level + 1, "requires")
    write_optional_type(sb, d.requires, level + 1)
    entry(sb, false, level + 1, "members")
    write_fn_decls(sb, d.members, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_impl_decl :: fn(sb: StringBuilder, d: ImplDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "ImplDecl")
    entry(sb, false, level + 1, "typeParams")
    write_type_params(sb, d.type_params, level + 1)
    entry(sb, false, level + 1, "forType")
    write_type(sb, d.for_type, level + 1)
    entry(sb, false, level + 1, "traitName")
    write_string(sb, d.trait_name)
    entry(sb, false, level + 1, "traitArgs")
    write_types(sb, d.trait_args, level + 1)
    entry(sb, false, level + 1, "members")
    write_fn_decls(sb, d.members, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_type_alias_decl :: fn(sb: StringBuilder, d: TypeAliasDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "TypeAliasDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "typeParams")
    write_type_params(sb, d.type_params, level + 1)
    entry(sb, false, level + 1, "aliased")
    write_type(sb, d.aliased, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_const_decl :: fn(sb: StringBuilder, d: ConstDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "ConstDecl")
    entry(sb, false, level + 1, "name")
    write_string(sb, d.name)
    entry(sb, false, level + 1, "visibility")
    write_visibility(sb, d.visibility)
    entry(sb, false, level + 1, "type")
    write_optional_type(sb, d.ty, level + 1)
    entry(sb, false, level + 1, "value")
    write_expr(sb, d.value, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_assert_decl :: fn(sb: StringBuilder, d: AssertDecl, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "AssertDecl")
    entry(sb, false, level + 1, "condition")
    write_expr(sb, d.condition, level + 1)
    entry(sb, false, level + 1, "decorators")
    write_decorators(sb, d.decorators, level + 1)
    close_obj(sb, level)
}

write_fn_decls :: fn(sb: StringBuilder, ds: FnDecl[], level: i32) -> void {
    if ds.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for d in ds {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_fn_decl(sb, d, level + 1)
    }
    close_arr(sb, level)
}

// ---- Visibility / decorators / type-params -------------------------------

write_visibility :: fn(sb: StringBuilder, v: Visibility) -> void {
    match v {
        .Public  -> { write_string(sb, "public")  }
        .Private -> { write_string(sb, "private") }
    }
}

write_decorators :: fn(sb: StringBuilder, ds: Decorator[], level: i32) -> void {
    if ds.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for d in ds {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        write_string(sb, d.name)
        entry(sb, false, level + 2, "args")
        write_exprs(sb, d.args, level + 2)
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

write_type_params :: fn(sb: StringBuilder, tps: TypeParam[], level: i32) -> void {
    if tps.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for tp in tps {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        write_string(sb, tp.name)
        entry(sb, false, level + 2, "bound")
        write_optional_type(sb, tp.bound, level + 2)
        entry(sb, false, level + 2, "isComptimeValue")
        write_bool(sb, tp.is_comptime_value)
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

// ============================================================================
// Type expressions
// ============================================================================

write_types :: fn(sb: StringBuilder, ts: TypeExpr[], level: i32) -> void {
    if ts.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for t in ts {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_type(sb, t, level + 1)
    }
    close_arr(sb, level)
}

// `TypeExpr` is an alias for `Expr` ; type-position dumps forward to
// `write_expr` directly.
write_optional_type :: fn(sb: StringBuilder, t: TypeExpr | null, level: i32) -> void {
    write_expr(sb, t, level)
}

write_type :: fn(sb: StringBuilder, t: TypeExpr, level: i32) -> void {
    write_expr(sb, t, level)
}

// ============================================================================
// Statements
// ============================================================================

write_stmts :: fn(sb: StringBuilder, ss: Stmt[], level: i32) -> void {
    if ss.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for s in ss {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_stmt(sb, s, level + 1)
    }
    close_arr(sb, level)
}

write_stmt :: fn(sb: StringBuilder, s: Stmt, level: i32) -> void {
    match s {
        is LetStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "LetStmt")
            entry(sb, false, level + 1, "mutable")
            write_bool(sb, s.mutable)
            entry(sb, false, level + 1, "binding")
            write_let_binding(sb, s.binding, level + 1)
            entry(sb, false, level + 1, "type")
            write_optional_type(sb, s.ty, level + 1)
            entry(sb, false, level + 1, "value")
            write_expr(sb, s.value, level + 1)
            close_obj(sb, level)
        }
        is AssignStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "AssignStmt")
            entry(sb, false, level + 1, "target")
            write_expr(sb, s.target, level + 1)
            entry(sb, false, level + 1, "value")
            write_expr(sb, s.value, level + 1)
            close_obj(sb, level)
        }
        is ExprStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "ExprStmt")
            entry(sb, false, level + 1, "expr")
            write_expr(sb, s.expr, level + 1)
            close_obj(sb, level)
        }
        is ReturnStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "ReturnStmt")
            entry(sb, false, level + 1, "value")
            write_optional_expr(sb, s.value, level + 1)
            close_obj(sb, level)
        }
        is ForStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "ForStmt")
            entry(sb, false, level + 1, "label")
            label :: s.label

            match label {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, label) }
            }
            entry(sb, false, level + 1, "form")
            write_for_form(sb, s.form, level + 1)
            entry(sb, false, level + 1, "body")
            write_block_expr(sb, s.body, level + 1)
            close_obj(sb, level)
        }
        is BreakStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "BreakStmt")
            entry(sb, false, level + 1, "label")
            label :: s.label

            match label {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, label) }
            }
            close_obj(sb, level)
        }
        is ContinueStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "ContinueStmt")
            entry(sb, false, level + 1, "label")
            label :: s.label

            match label {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, label) }
            }
            close_obj(sb, level)
        }
        is DeferStmt -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "DeferStmt")
            entry(sb, false, level + 1, "body")
            body :: s.body

            match body {
                is DeferStmtBody -> { write_stmt(sb, body.stmt, level + 1) }
                is DeferBlockBody -> { write_block_expr(sb, body.block, level + 1) }
            }
            close_obj(sb, level)
        }
    }
}

write_for_form :: fn(sb: StringBuilder, f: ForForm, level: i32) -> void {
    open_obj(sb)
    match f {
        is InfiniteFor -> { kind_entry(sb, level + 1, "infinite") }
        is WhileFor -> {
            kind_entry(sb, level + 1, "while")
            entry(sb, false, level + 1, "cond")
            write_expr(sb, f.cond, level + 1)
        }
        is InFor -> {
            kind_entry(sb, level + 1, "in")
            entry(sb, false, level + 1, "binding")
            write_string(sb, f.binding)
            entry(sb, false, level + 1, "iter")
            write_expr(sb, f.iter, level + 1)
        }
    }
    close_obj(sb, level)
}

// ============================================================================
// Expressions
// ============================================================================

write_optional_expr :: fn(sb: StringBuilder, e: Expr | null, level: i32) -> void {
    write_expr(sb, e, level)
}

write_exprs :: fn(sb: StringBuilder, es: Expr[], level: i32) -> void {
    if es.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for e in es {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_expr(sb, e, level + 1)
    }
    close_arr(sb, level)
}

write_expr :: fn(sb: StringBuilder, e: Expr | null, level: i32) -> void {
    match e {
        is null -> { write_null(sb) }
        is IntLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IntLitExpr")
            entry(sb, false, level + 1, "value")
            write_bigint(sb, e.value)
            entry(sb, false, level + 1, "suffix")
            suffix :: e.suffix

            match suffix {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, suffix) }
            }
            close_obj(sb, level)
        }
        is FloatLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "FloatLitExpr")
            entry(sb, false, level + 1, "value")
            write_f64(sb, e.value)
            entry(sb, false, level + 1, "suffix")
            suffix :: e.suffix

            match suffix {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, suffix) }
            }
            close_obj(sb, level)
        }
        is BoolLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "BoolLitExpr")
            entry(sb, false, level + 1, "value")
            write_bool(sb, e.value)
            close_obj(sb, level)
        }
        is NullLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "NullLitExpr")
            close_obj(sb, level)
        }
        is CharLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "CharLitExpr")
            entry(sb, false, level + 1, "value")
            sb.append("${e.value}")
            close_obj(sb, level)
        }
        is StringLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "StringLitExpr")
            entry(sb, false, level + 1, "parts")
            write_string_parts(sb, e.parts, level + 1)
            close_obj(sb, level)
        }
        is IdentExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IdentExpr")
            entry(sb, false, level + 1, "name")
            write_string(sb, e.name)
            // Mirror TS : both flags are emitted only when set, since the
            // TS dumper drops `undefined`-valued optional fields via
            // `JSON.stringify`.
            if e.implicit_dot {
                entry(sb, false, level + 1, "implicitDot")
                sb.append("true")
            }
            if e.is_type_param_intro {
                entry(sb, false, level + 1, "isTypeParamIntro")
                sb.append("true")
            }
            close_obj(sb, level)
        }
        is CallExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "CallExpr")
            entry(sb, false, level + 1, "callee")
            write_expr(sb, e.callee, level + 1)
            entry(sb, false, level + 1, "args")
            write_call_args(sb, e.args, level + 1)
            close_obj(sb, level)
        }
        is FieldExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "FieldExpr")
            entry(sb, false, level + 1, "target")
            write_expr(sb, e.target, level + 1)
            entry(sb, false, level + 1, "field")
            write_string(sb, e.field)
            // Mirror TS : `isNumeric` is emitted only when true (TS treats it
            // as an optional that's undefined-by-default).
            if e.is_numeric {
                entry(sb, false, level + 1, "isNumeric")
                write_bool(sb, true)
            }
            close_obj(sb, level)
        }
        is IndexExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IndexExpr")
            entry(sb, false, level + 1, "target")
            write_expr(sb, e.target, level + 1)
            entry(sb, false, level + 1, "index")
            write_expr(sb, e.index, level + 1)
            close_obj(sb, level)
        }
        is UnaryExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "UnaryExpr")
            entry(sb, false, level + 1, "op")
            write_string(sb, unary_op_name(e.op))
            entry(sb, false, level + 1, "operand")
            write_expr(sb, e.operand, level + 1)
            close_obj(sb, level)
        }
        is BinaryExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "BinaryExpr")
            entry(sb, false, level + 1, "op")
            write_string(sb, binary_op_name(e.op))
            entry(sb, false, level + 1, "left")
            write_expr(sb, e.left, level + 1)
            entry(sb, false, level + 1, "right")
            write_expr(sb, e.right, level + 1)
            close_obj(sb, level)
        }
        is IfExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IfExpr")
            entry(sb, false, level + 1, "cond")
            write_expr(sb, e.cond, level + 1)
            entry(sb, false, level + 1, "then")
            write_block_expr(sb, e.then_block, level + 1)
            entry(sb, false, level + 1, "else")
            else_branch :: e.else_branch

            match else_branch {
                is null         -> { write_null(sb) }
                is IfElseIf -> { write_expr(sb, else_branch.branch, level + 1) }
                is IfElseBlock -> { write_block_expr(sb, else_branch.block, level + 1) }
            }
            close_obj(sb, level)
        }
        is MatchExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "MatchExpr")
            entry(sb, false, level + 1, "scrutinee")
            write_expr(sb, e.scrutinee, level + 1)
            entry(sb, false, level + 1, "arms")
            write_match_arms(sb, e.arms, level + 1)
            if e.partial {
                entry(sb, false, level + 1, "partial")
                sb.append("true")
            }
            close_obj(sb, level)
        }
        is BlockExpr -> { write_block_expr(sb, e, level) }
        is LambdaExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "LambdaExpr")
            entry(sb, false, level + 1, "params")
            write_fn_params(sb, e.params, level + 1)
            entry(sb, false, level + 1, "returnType")
            write_optional_type(sb, e.return_type, level + 1)
            entry(sb, false, level + 1, "body")
            write_block_expr(sb, e.body, level + 1)
            close_obj(sb, level)
        }
        is StructLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "StructLitExpr")
            entry(sb, false, level + 1, "typeName")
            write_type(sb, e.type_name, level + 1)
            entry(sb, false, level + 1, "items")
            write_struct_lit_items(sb, e.items, level + 1)
            close_obj(sb, level)
        }
        is SeqLitExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "SeqLitExpr")
            entry(sb, false, level + 1, "elements")
            write_exprs(sb, e.elements, level + 1)
            close_obj(sb, level)
        }
        is RangeExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "RangeExpr")
            entry(sb, false, level + 1, "inclusive")
            write_bool(sb, e.inclusive)
            entry(sb, false, level + 1, "lower")
            write_expr(sb, e.lower, level + 1)
            entry(sb, false, level + 1, "upper")
            write_expr(sb, e.upper, level + 1)
            close_obj(sb, level)
        }
        is TryExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "TryExpr")
            entry(sb, false, level + 1, "inner")
            write_expr(sb, e.inner, level + 1)
            close_obj(sb, level)
        }
        is CastExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "CastExpr")
            entry(sb, false, level + 1, "target")
            write_type(sb, e.target, level + 1)
            entry(sb, false, level + 1, "value")
            write_expr(sb, e.value, level + 1)
            close_obj(sb, level)
        }
        is GenericInstExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "GenericInstExpr")
            entry(sb, false, level + 1, "callee")
            write_expr(sb, e.callee, level + 1)
            entry(sb, false, level + 1, "typeArgs")
            write_types(sb, e.type_args, level + 1)
            close_obj(sb, level)
        }
        is IntrinsicCallExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IntrinsicCallExpr")
            entry(sb, false, level + 1, "name")
            write_string(sb, e.name)
            entry(sb, false, level + 1, "args")
            write_exprs(sb, e.args, level + 1)
            close_obj(sb, level)
        }
        is DotVariantExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "DotVariantExpr")
            entry(sb, false, level + 1, "variant")
            write_string(sb, e.variant)
            close_obj(sb, level)
        }
        is FnTypeExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "FnTypeExpr")
            entry(sb, false, level + 1, "params")
            write_types(sb, e.params, level + 1)
            entry(sb, false, level + 1, "returnType")
            write_optional_type(sb, e.return_type, level + 1)
            close_obj(sb, level)
        }
        is ArrayTypeExpr -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "ArrayTypeExpr")
            entry(sb, false, level + 1, "element")
            write_expr(sb, e.element, level + 1)
            close_obj(sb, level)
        }
    }
}

write_block_expr :: fn(sb: StringBuilder, b: BlockExpr, level: i32) -> void {
    open_obj(sb)
    kind_entry(sb, level + 1, "BlockExpr")
    entry(sb, false, level + 1, "stmts")
    write_stmts(sb, b.stmts, level + 1)
    entry(sb, false, level + 1, "trailing")
    write_optional_expr(sb, b.trailing, level + 1)
    close_obj(sb, level)
}

write_string_parts :: fn(sb: StringBuilder, parts: StringLitPart[], level: i32) -> void {
    if parts.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for pp in parts {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        match pp {
            is StringLitText -> {
                kind_entry(sb, level + 2, "text")
                entry(sb, false, level + 2, "value")
                write_string(sb, pp.value)
            }
            is StringLitInterp -> {
                kind_entry(sb, level + 2, "interp")
                entry(sb, false, level + 2, "expr")
                write_expr(sb, pp.expr, level + 2)
            }
        }
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

write_call_args :: fn(sb: StringBuilder, args: CallArg[], level: i32) -> void {
    if args.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for a in args {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        mv :: a.name

        match mv {
            is null        -> { write_null(sb) }
            is string -> { write_string(sb, mv) }
        }
        entry(sb, false, level + 2, "value")
        write_expr(sb, a.value, level + 2)
        entry(sb, false, level + 2, "spread")
        write_bool(sb, a.spread)
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

write_struct_lit_items :: fn(sb: StringBuilder, items: (StructLitField | StructLitSpread)[], level: i32) -> void {
    if items.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for it in items {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        match it {
            is StructLitField -> {
                kind_entry(sb, level + 2, "field")
                entry(sb, false, level + 2, "name")
                write_string(sb, it.name)
                entry(sb, false, level + 2, "value")
                write_expr(sb, it.value, level + 2)
            }
            is StructLitSpread -> {
                kind_entry(sb, level + 2, "spread")
                entry(sb, false, level + 2, "expr")
                write_expr(sb, it.expr, level + 2)
            }
        }
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

write_match_arms :: fn(sb: StringBuilder, arms: MatchArm[], level: i32) -> void {
    if arms.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for a in arms {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "pattern")
        write_pattern(sb, a.pattern, level + 2)
        entry(sb, false, level + 2, "guard")
        write_optional_expr(sb, a.guard, level + 2)
        entry(sb, false, level + 2, "body")
        write_expr(sb, a.body, level + 2)
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

write_let_binding :: fn(sb: StringBuilder, b: LetBinding, level: i32) -> void {
    match b {
        is SimpleBinding -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "SimpleBinding")
            entry(sb, false, level + 1, "name")
            write_string(sb, b.name)
            close_obj(sb, level)
        }
        is TupleBinding -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "TupleBinding")
            entry(sb, false, level + 1, "elements")
            write_let_bindings(sb, b.elements, level + 1)
            close_obj(sb, level)
        }
        is WildcardBinding -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "WildcardBinding")
            close_obj(sb, level)
        }
        is RestBinding -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "RestBinding")
            entry(sb, false, level + 1, "name")
            write_string(sb, b.name)
            close_obj(sb, level)
        }
    }
}

write_let_bindings :: fn(sb: StringBuilder, bs: LetBinding[], level: i32) -> void {
    if bs.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for b in bs {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_let_binding(sb, b, level + 1)
    }
    close_arr(sb, level)
}

write_patterns :: fn(sb: StringBuilder, ps: Pattern[], level: i32) -> void {
    if ps.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for p in ps {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        write_pattern(sb, p, level + 1)
    }
    close_arr(sb, level)
}

write_pattern :: fn(sb: StringBuilder, p: Pattern, level: i32) -> void {
    match p {
        is IsPattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "IsPattern")
            entry(sb, false, level + 1, "type")
            write_type(sb, p.ty, level + 1)
            entry(sb, false, level + 1, "inner")
            inner :: p.inner

            match inner {
                is null                  -> { write_null(sb) }
                is IsPattern -> { write_pattern(sb, inner, level + 1) }
                is StructPattern -> { write_pattern(sb, inner, level + 1) }
                is TuplePattern -> { write_pattern(sb, inner, level + 1) }
                is WildcardPattern -> { write_pattern(sb, inner, level + 1) }
                is BindingPattern -> { write_pattern(sb, inner, level + 1) }
                is EnumVariantPattern -> { write_pattern(sb, inner, level + 1) }
            }
            entry(sb, false, level + 1, "bindAs")
            bind_as :: p.bind_as

            match bind_as {
                is null        -> { write_null(sb) }
                is string -> { write_string(sb, bind_as) }
            }
            close_obj(sb, level)
        }
        is StructPattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "StructPattern")
            entry(sb, false, level + 1, "fields")
            write_struct_pattern_fields(sb, p.fields, level + 1)
            close_obj(sb, level)
        }
        is TuplePattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "TuplePattern")
            entry(sb, false, level + 1, "elements")
            write_patterns(sb, p.elements, level + 1)
            close_obj(sb, level)
        }
        is WildcardPattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "WildcardPattern")
            close_obj(sb, level)
        }
        is BindingPattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "BindingPattern")
            entry(sb, false, level + 1, "name")
            write_string(sb, p.name)
            close_obj(sb, level)
        }
        is EnumVariantPattern -> {
            open_obj(sb)
            kind_entry(sb, level + 1, "EnumVariantPattern")
            entry(sb, false, level + 1, "variant")
            write_string(sb, p.variant)
            close_obj(sb, level)
        }
    }
}

write_struct_pattern_fields :: fn(sb: StringBuilder, fields: StructPatternField[], level: i32) -> void {
    if fields.len() == 0 {
        close_arr_empty(sb)
        return
    }
    open_arr(sb)
    first := true
    for f in fields {
        if !first { sb.append_char(',') }
        first = false
        sb.append_char('\n')
        indent(sb, level + 1)
        open_obj(sb)
        entry(sb, true, level + 2, "name")
        write_string(sb, f.name)
        entry(sb, false, level + 2, "value")
        mv :: f.value

        match mv {
            is PatternBinding -> {
                open_obj(sb)
                kind_entry(sb, level + 3, "binding")
                entry(sb, false, level + 3, "name")
                write_string(sb, mv.name)
                close_obj(sb, level + 2)
            }
            is PatternLiteral -> {
                open_obj(sb)
                kind_entry(sb, level + 3, "literal")
                entry(sb, false, level + 3, "value")
                write_expr(sb, mv.value, level + 3)
                close_obj(sb, level + 2)
            }
        }
        close_obj(sb, level + 1)
    }
    close_arr(sb, level)
}

unary_op_name :: fn(op: UnaryOp) = match op {
    .Neg    -> "neg"
    .Not    -> "not"
    .BitNot -> "bitnot"
}

binary_op_name :: fn(op: BinaryOp) = match op {
    .Add    -> "add"
    .Sub    -> "sub"
    .Mul    -> "mul"
    .Div    -> "div"
    .Mod    -> "mod"
    .Shl    -> "shl"
    .Shr    -> "shr"
    .BitAnd -> "bitand"
    .BitOr  -> "bitor"
    .BitXor -> "bitxor"
    .And    -> "and"
    .Or     -> "or"
    .Eq     -> "eq"
    .Neq    -> "neq"
    .Lt     -> "lt"
    .Lte    -> "lte"
    .Gt     -> "gt"
    .Gte    -> "gte"
    .Is     -> "is"
    .In     -> "in"
    .NotIn  -> "not_in"
}
