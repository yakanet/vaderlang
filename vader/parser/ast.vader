// vader/parser/ast — AST node types.
//
// Layout note : the resolver requires every `:: type` union alias to be
// declared *before* the struct that references it, so all aliases live at
// the top of the file and the concrete structs follow. `type` is a Vader
// keyword, so type-bearing fields are renamed `ty` ; the dumper emits the
// JSON key as `"type"` so snapshots stay byte-identical with TS.

import "vader/diagnostics/diagnostic" { Span }

// ============================================================================
// Type aliases (declared first — see header)
// ============================================================================

Decl :: type ImportDecl | FnDecl | StructDecl | EnumDecl | TraitDecl | ImplDecl | TypeAliasDecl | ConstDecl

ImportBinding :: type NamespaceImport | AliasImport | DestructureImport

Stmt :: type LetStmt | AssignStmt | ExprStmt | ReturnStmt | ForStmt | BreakStmt | ContinueStmt | DeferStmt

ForForm :: type InfiniteFor | WhileFor | InFor

DeferBody :: type DeferStmtBody | DeferBlockBody

Expr :: type IntLitExpr | FloatLitExpr | BoolLitExpr | NullLitExpr | CharLitExpr | StringLitExpr | IdentExpr | CallExpr | FieldExpr | IndexExpr | UnaryExpr | BinaryExpr | IfExpr | MatchExpr | BlockExpr | LambdaExpr | StructLitExpr | ArrayLitExpr | RangeExpr | TryExpr | CastExpr | GenericInstExpr | DotVariantExpr

StringLitPart :: type StringLitText | StringLitInterp

IfElse :: type IfElseIf | IfElseBlock

Pattern :: type IsPattern | StructPattern | WildcardPattern | BindingPattern | EnumVariantPattern

PatternFieldValue :: type PatternBinding | PatternLiteral

TypeExpr :: type NamedType | UnionType | FnTypeExpr | ArrayTypeExpr | GenericInstType | TypeParamType

// ============================================================================
// Visibility / shared shapes
// ============================================================================

Visibility :: enum(u8) {
    Public,
    Private,
}

// ============================================================================
// Top-level
// ============================================================================

Program :: struct {
    file:  string
    span:  Span
    decls: [Decl]
}

// ============================================================================
// Generics / Decorators
// ============================================================================

TypeParam :: struct {
    span:               Span
    name:               string
    bound:              TypeExpr | null
    is_comptime_value:  bool
}

WhereClause :: struct {
    span:        Span
    type_name:   string
    trait_name:  string
}

Decorator :: struct {
    span: Span
    name: string
    args: [Expr]
}

// ============================================================================
// Declarations
// ============================================================================

// ---- Import ---------------------------------------------------------------

ImportDecl :: struct {
    span:       Span
    path:       string
    binding:    ImportBinding
    decorators: [Decorator]
}

NamespaceImport  :: struct {}
AliasImport      :: struct { alias: string }
DestructureImport :: struct { names: [ImportName] }

ImportName :: struct {
    name:  string
    alias: string | null
    span:  Span
}

// ---- Fn -------------------------------------------------------------------

// `sam_synthetic` and `is_expression_bodied` are `bool` (defaults `false`)
// rather than `bool | null` — Vader has no optional fields. The dumper emits
// them only when `true` to match the TS shape.
FnDecl :: struct {
    span:                  Span
    name:                  string
    name_span:             Span
    visibility:            Visibility
    type_params:           [TypeParam]
    params:                [FnParam]
    return_type:           TypeExpr | null
    where_clauses:         [WhereClause]
    body:                  BlockExpr | null
    decorators:            [Decorator]
    sam_synthetic:         bool
    is_expression_bodied:  bool
}

FnParam :: struct {
    span:          Span
    name:          string
    // Optional in lambdas.
    ty:            TypeExpr | null
    default_value: Expr | null
    variadic:      bool
}

// ---- Struct ---------------------------------------------------------------

StructDecl :: struct {
    span:          Span
    name:          string
    name_span:     Span
    visibility:    Visibility
    type_params:   [TypeParam]
    fields:        [StructField]
    where_clauses: [WhereClause]
    decorators:    [Decorator]
}

StructField :: struct {
    span:       Span
    name:       string
    ty:         TypeExpr
    visibility: Visibility
}

// ---- Enum -----------------------------------------------------------------

EnumDecl :: struct {
    span:       Span
    name:       string
    name_span:  Span
    visibility: Visibility
    // `null` means default `i32` — typechecker resolves the backing type.
    repr:       TypeExpr | null
    variants:   [EnumVariant]
    decorators: [Decorator]
}

EnumVariant :: struct {
    span:        Span
    name:        string
    // `null` means "previous + 1" (or 0 for the first variant). Stored as i64
    // so the parser can carry the parsed literal verbatim until the
    // typechecker reduces it to the final integer.
    value:       i64 | null
    value_span:  Span | null
}

// ---- Trait ----------------------------------------------------------------

TraitDecl :: struct {
    span:        Span
    name:        string
    name_span:   Span
    visibility:  Visibility
    type_params: [TypeParam]
    members:     [FnDecl]
    decorators:  [Decorator]
}

// ---- Impl -----------------------------------------------------------------

ImplDecl :: struct {
    span:             Span
    for_type:         TypeExpr
    trait_name:       string
    trait_name_span:  Span
    trait_args:       [TypeExpr]
    members:          [FnDecl]
    decorators:       [Decorator]
}

// ---- TypeAlias ------------------------------------------------------------

TypeAliasDecl :: struct {
    span:        Span
    name:        string
    name_span:   Span
    visibility:  Visibility
    type_params: [TypeParam]
    aliased:     TypeExpr
    decorators:  [Decorator]
}

// ---- Const ----------------------------------------------------------------

ConstDecl :: struct {
    span:       Span
    name:       string
    name_span:  Span
    visibility: Visibility
    ty:         TypeExpr | null
    value:      Expr
    decorators: [Decorator]
}

// ============================================================================
// Statements
// ============================================================================

LetStmt :: struct {
    span:      Span
    mutable:   bool
    name:      string
    name_span: Span
    ty:        TypeExpr | null
    value:     Expr
}

AssignStmt :: struct {
    span:   Span
    target: Expr
    value:  Expr
}

ExprStmt :: struct {
    span: Span
    expr: Expr
}

ReturnStmt :: struct {
    span:  Span
    value: Expr | null
}

ForStmt :: struct {
    span:  Span
    label: string | null
    form:  ForForm
    body:  BlockExpr
}

InfiniteFor :: struct {}
WhileFor    :: struct { cond: Expr }
InFor       :: struct {
    binding:      string
    binding_span: Span
    iter:         Expr
}

BreakStmt :: struct {
    span:  Span
    label: string | null
}

ContinueStmt :: struct {
    span:  Span
    label: string | null
}

DeferStmt :: struct {
    span: Span
    body: DeferBody
}

DeferStmtBody  :: struct { stmt: Stmt }
DeferBlockBody :: struct { block: BlockExpr }

// ============================================================================
// Expressions
// ============================================================================

// ---- literals -------------------------------------------------------------

IntLitExpr :: struct {
    span:   Span
    // i64 carries every parsed literal up to 9.2e18 ; u64 literals beyond
    // that lose top bits (matches the TS BigInt mapping inside the snapshot
    // format which renders bigints as decimal strings).
    value:  i64
    suffix: string | null
}

FloatLitExpr :: struct {
    span:   Span
    value:  f64
    suffix: string | null
}

BoolLitExpr :: struct {
    span:  Span
    value: bool
}

NullLitExpr :: struct {
    span: Span
}

CharLitExpr :: struct {
    span:  Span
    value: u32
}

StringLitExpr :: struct {
    span:  Span
    parts: [StringLitPart]
}

StringLitText   :: struct { value: string, span: Span }
StringLitInterp :: struct { expr:  Expr,   span: Span }

// ---- naming / access ------------------------------------------------------

IdentExpr :: struct {
    span: Span
    name: string
}

CallExpr :: struct {
    span:   Span
    callee: Expr
    args:   [CallArg]
}

CallArg :: struct {
    span:   Span
    name:   string | null
    value:  Expr
    spread: bool
}

FieldExpr :: struct {
    span:       Span
    target:     Expr
    field:      string
    field_span: Span
}

IndexExpr :: struct {
    span:   Span
    target: Expr
    index:  Expr
}

// ---- operators ------------------------------------------------------------

UnaryOp :: enum(u8) {
    Neg,
    Not,
    BitNot,
}

UnaryExpr :: struct {
    span:    Span
    op:      UnaryOp
    operand: Expr
}

BinaryOp :: enum(u8) {
    Add, Sub, Mul, Div, Mod,
    Shl, Shr, BitAnd, BitOr, BitXor,
    And, Or,
    Eq, Neq, Lt, Lte, Gt, Gte,
    Is, In, NotIn,
}

BinaryExpr :: struct {
    span:  Span
    op:    BinaryOp
    left:  Expr
    right: Expr
}

// ---- control-flow expressions --------------------------------------------

IfExpr :: struct {
    span:        Span
    cond:        Expr
    then_block:  BlockExpr
    else_branch: IfElse | null
}

IfElseIf    :: struct { branch: IfExpr }
IfElseBlock :: struct { block:  BlockExpr }

MatchExpr :: struct {
    span:      Span
    scrutinee: Expr
    arms:      [MatchArm]
}

MatchArm :: struct {
    span:    Span
    pattern: Pattern
    guard:   Expr | null
    body:    Expr
}

BlockExpr :: struct {
    span:     Span
    stmts:    [Stmt]
    trailing: Expr | null
}

// ---- lambdas / literals --------------------------------------------------

LambdaExpr :: struct {
    span:        Span
    params:      [FnParam]
    return_type: TypeExpr | null
    body:        BlockExpr
}

StructLitExpr :: struct {
    span:      Span
    type_name: TypeExpr
    fields:    [StructLitField]
}

StructLitField :: struct {
    span:      Span
    name:      string
    name_span: Span
    value:     Expr
}

ArrayLitExpr :: struct {
    span:     Span
    elements: [Expr]
}

RangeExpr :: struct {
    span:      Span
    inclusive: bool
    lower:     Expr
    upper:     Expr
}

// ---- error / cast / generic / variant -----------------------------------

TryExpr :: struct {
    span:  Span
    inner: Expr
}

CastExpr :: struct {
    span:   Span
    target: TypeExpr
    value:  Expr
}

GenericInstExpr :: struct {
    span:      Span
    callee:    Expr
    type_args: [TypeExpr]
}

DotVariantExpr :: struct {
    span:         Span
    variant:      string
    variant_span: Span
}

// ============================================================================
// Patterns (for `match`)
// ============================================================================

IsPattern :: struct {
    span:    Span
    ty:      TypeExpr
    inner:   Pattern | null
    bind_as: string | null
}

StructPattern :: struct {
    span:   Span
    fields: [StructPatternField]
}

StructPatternField :: struct {
    span:      Span
    name:      string
    name_span: Span
    value:     PatternFieldValue
}

PatternBinding :: struct { name: string, span: Span }
PatternLiteral :: struct { value: Expr }

WildcardPattern :: struct { span: Span }

BindingPattern :: struct {
    span: Span
    name: string
}

EnumVariantPattern :: struct {
    span:    Span
    variant: string
}

// ============================================================================
// Type expressions
// ============================================================================

NamedType :: struct {
    span: Span
    name: string
}

UnionType :: struct {
    span:     Span
    variants: [TypeExpr]
}

FnTypeExpr :: struct {
    span:        Span
    params:      [TypeExpr]
    return_type: TypeExpr | null
}

ArrayTypeExpr :: struct {
    span:    Span
    element: TypeExpr
}

GenericInstType :: struct {
    span: Span
    base: NamedType
    args: [TypeExpr]
}

TypeParamType :: struct {
    span: Span
    name: string
}
