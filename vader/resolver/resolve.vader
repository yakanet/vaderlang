// vader/resolver/resolve — top-level decl walk.
//
// MVP : visit the top-level decls of a Program and mint a Symbol for each.
// Imports, nested scopes (fn bodies, match arms, ...), type resolution and
// generic-param tracking are deferred to follow-ups. The output is enough
// to drive `dump --stage=resolved-ast` with a per-module symbol summary
// matching the TS resolver dump's first half.

import "std/string" { compare_ascending }
import "std/sort" { sort }
import "vader/parser" { Program, Decl, ImportDecl, FnDecl, StructDecl, EnumDecl, TraitDecl, ImplDecl, TypeAliasDecl, ConstDecl, AssertDecl, Visibility, ImportBinding, AliasImport, DestructureImport, NamespaceImport }
import "vader/resolver/symbol" { Symbol, SymbolKind, SymbolFactory, new_factory, make }

// One resolver output entry per source module. `path` mirrors the TS
// `displayPath` ; `symbols` is sorted by name so the dump is stable
// regardless of decl order.
export ResolvedModule :: struct {
    path:    string
    symbols: Symbol[]
}

export ResolvedProject :: struct {
    modules: ResolvedModule[]
}

// Single-module entry point. The parser produces one Program per file ; the
// CLI passes its display path so symbol records carry it. Multi-file
// modules are merged at the layout level (not yet — TODO when we wire
// the loader).
export resolve_module :: fn(program: Program, module_path: string, factory: SymbolFactory) -> ResolvedModule {
    syms: Symbol[] = []
    for d in program.decls {
        s :: collect_decl(d, module_path, factory)
        match s {
            is Symbol -> { syms.push(s) }
            is null   -> {}     // assert / impl decls don't introduce a name
        }
    }
    return ResolvedModule { .path = module_path, .symbols = sort_by_name(syms) }
}

// Returns a Symbol when the decl introduces a name at the module's top
// level, null otherwise. ImplDecl is intentionally handled as null — its
// methods become per-impl entries the typechecker walks separately.
collect_decl :: fn(d: Decl, module_path: string, factory: SymbolFactory) -> Symbol | null = match d {
    is ImportDecl    -> collect_import(d, module_path, factory)
    is FnDecl        -> factory.make(.Fn,        d.name, module_path, d.visibility, d.name_span)
    is StructDecl    -> factory.make(.Struct,    d.name, module_path, d.visibility, d.name_span)
    is EnumDecl      -> factory.make(.Enum,      d.name, module_path, d.visibility, d.name_span)
    is TraitDecl     -> factory.make(.Trait,     d.name, module_path, d.visibility, d.name_span)
    is ImplDecl      -> null
    is TypeAliasDecl -> factory.make(.TypeAlias, d.name, module_path, d.visibility, d.name_span)
    is ConstDecl     -> factory.make(.Const,     d.name, module_path, d.visibility, d.name_span)
    is AssertDecl    -> null
}

// Imports introduce one local-name binding each. Namespace and alias
// imports yield a single name ; destructure imports yield one per `name`.
// MVP : only the *first* binding of a destructure is returned to keep the
// signature simple. Full coverage lands when the loader wires real
// multi-name handling.
collect_import :: fn(d: ImportDecl, module_path: string, factory: SymbolFactory) -> Symbol | null {
    b :: d.binding
    return match b {
        is AliasImport       -> factory.make(.ImportBinding, b.alias, module_path, .Private, d.span)
        is DestructureImport -> destructure_first(b, module_path, factory)
        is NamespaceImport   -> null
    }
}

destructure_first :: fn(b: DestructureImport, module_path: string, factory: SymbolFactory) -> Symbol | null {
    if b.names.len() == 0 { return null }
    n0 :: b.names[0]
    a :: n0.alias
    local_name := match a {
        is string -> a
        is null   -> n0.name
    }
    return factory.make(.ImportBinding, local_name, module_path, .Private, n0.span)
}

sort_by_name :: fn(syms: Symbol[]) -> Symbol[] {
    return sort(syms, (a: Symbol, b: Symbol) -> compare_ascending(a.name, b.name))
}
