// vader/resolver/discover — module index types.
//
// Shared records for module resolution : `DiscoveredModule` (a resolved
// module's name + folder + file paths) and `FolderBucket` (the per-folder
// accumulator `lazy::scan_folder` builds while header-parsing a folder's
// `.vader` files). The eager scoped-root scanner that once lived here was
// replaced by `lazy.vader`'s import-driven (path-mapping) resolution.

module "vader/resolver"

import "vader/diagnostics" { Span }

/// A resolved module : its declared name, its folder, and its `.vader` file
/// paths. Files are parsed lazily by the loader on visit — not stashed as
/// ASTs (the self-host GC arenas can't hold ~170 parsed programs at once).
export DiscoveredModule :: struct {
    name:   string
    folder: string
    files:  string[]
}

/// Per-folder accumulator built by `lazy::scan_folder`. `name` is "" until the
/// first file declares its module ; later files in the same folder must match
/// it (else R2022).
FolderBucket :: struct {
    name:            string
    first_decl_span: Span
    files:           string[]
}
