// vader/resolver/module — module discovery + path resolution.
//
// A `Module` represents one resolved-on-disk unit. Imports resolve by
// *name* against an ordered set of include-path roots (GCC `-I` style),
// never relative to the importing file. SPEC §11 disavows relative imports :
// `import "./foo"` / `import "../foo"` are not a language form and are
// rejected (R2025).
//
//   - `import "std/foo"`  — resolves against the stdlib root (probed
//     next to the executable, then `<cwd>/stdlib` — see `resolve_sidecar`).
//   - `import "vader/parser"` — a bare name resolved against the project
//     root and each `includePaths` entry, first match wins.
//
// Each candidate path is probed first as a directory (multi-file
// module : every `*.vader` inside contributes), then as a single
// `*.vader` file. The `displayPath` is what shows up in diagnostics
// and dumps — for stdlib this is the raw `std/...` text ; for a project
// module it's the module's declared `module "..."` name.

module "vader/resolver"

import "std/io" { exists, is_dir, read_dir, read_file_string, current_executable_location }
import "std/path" { Path, to_path, as_string, parent }
import "std/sort" { sort }
import "std/string" { trim_prefix, compare_ascending, ends_with, starts_with }
import "vader/parser" { NodeIdFactory, Program, parse_source }

/// `import "std/..."` and stdlib display paths share this prefix.
export STDLIB_PREFIX :: "std/"

/// Project-root marker file. `find_manifest_root` walks up looking
/// for this name to anchor bare-name imports.
export MANIFEST_FILENAME :: "vader.json"

/// True when `display_path` falls within the dump scope `scope` — it equals a
/// scope entry or is a submodule of one (`M` or `M/...`). The IR dumps
/// (`dump --stage=…`) render only in-scope modules ; the scope defaults to the
/// entry module's subtree and is overridable with `--module`. This replaced the
/// stdlib-vs-user heuristic : a dump now shows the modules under inspection,
/// treating stdlib and any other dependency uniformly (out of scope by default).
///
/// @param display_path  the module's user-declared name (`module "..."`).
/// @param scope         the in-scope module ids / prefixes.
export module_in_scope :: fn(display_path: string, scope: string[]) -> bool {
    for m in scope {
        if display_path == m { return true }
        if display_path.starts_with("${m}/") { return true }
    }
    return false
}

/// A loaded source file in a module — raw text plus its parsed AST.
/// `id_factory` is the post-parse factory state for this file, threaded
/// to `LoadedModule` so cloned default-method bodies inserted by
/// `materialize.vader` mint IDs in the same namespace as parse-time IDs.
export SourceFile :: struct {
    path:       string
    content:    string
    program:    Program
    id_factory: NodeIdFactory
}

/// A resolved module : `id` is its canonical absolute root path,
/// `display_path` is what users see in the dump, `module_name` is
/// the declared `module "..."` identifier used as the key for
/// `import "..."` lookups, `files` is every file participating in
/// the module (one for single-file, N for folders).
export Module :: struct {
    id:           string
    display_path: string
    module_name:  string
    root_dir:     string
    files:        SourceFile[]
}

// ---------------------------------------------------------------- discovery

/// Walk up from `start` looking for `MANIFEST_FILENAME`. Returns
/// the containing directory, or null if no manifest is found up to
/// the filesystem root. Used to anchor `import "vader/parser"`
/// style bare-name imports.
export find_manifest_root :: fn(start: string) -> string | null {
    // Accept either a file or a directory as the start point ; for
    // a file, walk-up begins at its parent.
    dir := start
    if exists(dir) {
        if !is_dir(dir) { dir = dir_of(dir) }
    } else {
        dir = dir_of(dir)
    }
    for {
        candidate :: join_path(dir, MANIFEST_FILENAME)
        if exists(candidate) { return dir }
        parent_dir :: dir_of(dir)
        if parent_dir == dir { return null }
        dir = parent_dir
    }
}


/// Canonical module id : just the resolved root path. Same physical
/// location always maps to the same id.
export module_id_from_root :: fn(root: string) -> string { return root }

// ----------------------------------------------------- source-file loading

/// Read every `.vader` file under `root_path` (sorted by filename),
/// parse each, and return the resulting `SourceFile` list.
export load_module_files :: fn(root_path: string) -> SourceFile[] {
    out: SourceFile[] = []
    files :: list_vader_files(root_path)
    for f in files {
        content :: try_read(f)
        if content is null { continue }
        parsed :: parse_source(content, f)
        out.push(SourceFile {
            .path       = f,
            .content    = content,
            .program    = parsed.program,
            .id_factory = parsed.id_factory,
        })
    }
    return out
}

export list_vader_files :: fn(root_path: string) -> string[] {
    if !exists(root_path) { return [] }
    if !is_dir(root_path) {
        if ends_with(root_path, ".vader") { return [root_path] }
        return []
    }
    raw :: try_read_dir(root_path)
    if raw is null { return [] }
    files: string[] = []
    for name in raw {
        if !ends_with(name, ".vader") { continue }
        files.push(join_path(root_path, name))
    }
    return sort(files, (a: string, b: string) -> compare_ascending(a, b))
}

try_read :: fn(path: string) -> string | null {
    result :: read_file_string(path)
    if result is string as s { return s }
    return null
}

try_read_dir :: fn(path: string) -> string[] | null {
    result :: read_dir(path)
    if result is string[] as ss { return ss }
    return null
}

// ---------------------------------------------------------------- path utils

/// Join two path segments with a `/` separator (no normalization).
/// `base` "" yields `seg` unchanged. Doesn't strip trailing `/` from
/// `base` ; callers are expected to pass clean inputs.
export join_path :: fn(base: string, seg: string) -> string {
    // Strip a leading `./` from the relative segment so module ids
    // stay normalised — `from/./mod_a` would render as `## from/./mod_a`
    // in the typecheck dump.
    s :: trim_prefix(seg, "./")
    if base == "" { return s }
    baseb :: base.bytes()
    if baseb[baseb.len() - 1] == '/' {
        return "${base}${s}"
    }
    return "${base}/${s}"
}

/// Directory portion of `path` (everything before the last `/`).
/// Returns "" when no separator is present. Uses `std/path::parent`.
export dir_of :: fn(path: string) -> string { return path.to_path().parent().as_string() }

/// Resolve a resource directory `<base>/subdir` next to the executable, falling
/// back to the bare cwd-relative `subdir`. The sidecar candidate wins only when
/// it holds `marker`. Lets a `dist/` bundle find its stdlib + C runtime next to
/// the binary, while a repo checkout still resolves via the cwd.
///
/// The fallback returns the *relative* `subdir`, never an absolutised cwd path:
/// the resolved root becomes a module-id prefix, and an absolute root reshuffles
/// map-keyed insertion order (the comptime generic-instance collection), drifting
/// snapshots. Relative keeps the historical cwd-relative ids.
export resolve_sidecar :: fn(subdir: string, marker: string) -> string {
    exe_root :: join_path(current_executable_location().dir_of(), subdir)
    if exists(join_path(exe_root, marker)) { return exe_root }
    return subdir
}

/// Stdlib root, resolved next to the executable (then cwd) — see `resolve_sidecar`.
/// The marker is `std/io/io.vader` : `std/io` is a folder module, so the bare
/// `std/io.vader` file no longer exists — a stale marker silently defeated the
/// exe-sidecar branch, forcing every binary onto the `<cwd>/stdlib` fallback
/// (so a `dist/` bundle could never find its own stdlib unless run from a dir
/// that happened to hold one).
export default_stdlib_root :: fn() = resolve_sidecar("stdlib", "std/io/io.vader")

import "std/json" { parse, JsonValue, JsonObject, JsonArray, JsonString }

/// The loader-relevant fields of a project `vader.json`, read in one pass.
export Manifest :: struct {
    /// Extra module search roots (`includePaths` key), each relative to the
    /// project root. Joined onto the project root and searched (after the
    /// manifest dir itself) by lazy resolution — GCC `-I` style. E.g.
    /// `["stdlib"]` makes `module "std/io"` resolve at `<root>/stdlib/std/io`.
    include_paths: string[]
}

/// Read `vader.json` at `project_root` and extract its `includePaths` in one
/// read + parse. Returns an empty `Manifest` when the file is missing /
/// malformed / lacks the field.
///
/// One pass matters : the LSP re-loads the project on every didOpen / didChange,
/// so re-reading + re-parsing the manifest per field would double the I/O.
export read_manifest :: fn(project_root: string) -> Manifest {
    include_paths: string[] = []
    manifest_path :: join_path(project_root, MANIFEST_FILENAME)
    if !exists(manifest_path) { return Manifest { .include_paths = include_paths } }
    content :: try_read(manifest_path)
    raw :: if content == null { "" } else { content }
    if raw == "" { return Manifest { .include_paths = include_paths } }
    parsed :: parse(raw)
    if parsed is JsonObject as obj {
        entry :: obj.entries["includePaths"]
        if entry is JsonArray as arr {
            for item in arr.items {
                if item is JsonString as s { include_paths.push(s.value) }
            }
        }
    }
    return Manifest { .include_paths = include_paths }
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }

@test
test_read_manifest_reads_repo_include_paths :: fn() -> void {
    // Tests run with the repo root as cwd, so `""` joins to `"vader.json"`.
    // The Vader repo declares its stdlib root via `"includePaths": ["stdlib"]`
    // — guards against a renamed key or a regressed parse silently dropping the
    // search roots (which would break every `std/*` import).
    m :: read_manifest("")
    assert(m.include_paths.len() > 0, "repo manifest lists includePaths")
    found_stdlib := false
    for p in m.include_paths {
        if p == "stdlib" { found_stdlib = true }
    }
    assert(found_stdlib, "repo includePaths contains `stdlib`")
}

@test
test_read_manifest_missing_is_empty :: fn() -> void {
    m :: read_manifest("/no/such/project/root")
    assert(m.include_paths.len() == 0, "absent manifest yields no include-paths")
}
