// vader/resolver/materialize — synthetic trait method injection.
//
// Mirror of `src/resolver/materialize.ts`. Three entry points each
// expand an `ImplDecl.members` array with synthesised method declarations
// drawn from the trait :
//
//   1. `materialize_intrinsic_members` — @intrinsic impl with an empty
//      body : push one stub FnDecl per trait method, signature only.
//   2. `materialize_default_members`   — trait methods with a default
//      body : inject for any name the impl didn't override. *Body
//      cloning is not yet ported* — `body` stays null pending a
//      consumer in the self-host typechecker. Signature substitution
//      runs end-to-end.
//   3. `materialize_sam_members`       — single-abstract-method sugar
//      (`Foo implements Trait -> expr`) : fill name/params/return_type
//      on the parser-fabricated synthetic FnDecl(s) from the trait's
//      single required method.
//
// All three share the `Self → impl_.for_type` + trait type-param →
// impl trait-arg substitution wired through `substitute.vader`.

module "vader/resolver"

import "std/collections" { MutableMap, MutableSet, add }
import "std/iter" { is_empty }
import "std/math" { min }
import "std/testing" { assert, assert_eq }
import "vader/diagnostics" { Span, Position }
import "vader/parser" { parse_source, mint }
AST :: import "vader/parser"

/// `@intrinsic impl ... {}` carries an empty body : fill it with one
/// stub FnDecl per trait method so downstream phases see the impl's
/// full surface. No-op when the impl already has members.
export materialize_intrinsic_members :: fn(impl_: AST.ImplDecl, trait_: AST.TraitDecl) -> void {
    if !is_intrinsic(impl_.decorators) { return }
    if impl_.members.len() > 0 { return }
    subst :: build_subst(impl_, trait_)
    // Each materialised member needs a name_span unique per (impl, method) :
    // `impl_method_decl_types` is name-span-keyed, so anchoring every member at
    // the shared `impl_.trait_name_span` collapses a multi-method trait's return
    // types onto the last method's (e.g. `Buffer implements ByteAccess`'s
    // `load_u8 -> u8` degraded to `memory_copy`'s `void`). A per-impl `StampCtx`
    // (base keyed to the impl, counter per method) keeps members distinct within
    // the impl AND across sibling impls of one trait — mirrors the default-method
    // path (`materialize_default_members`). Single-method intrinsic traits are
    // unaffected (their lone member was already unique).
    impl_pos :: impl_.trait_name_span.start
    stamp :: StampCtx { .base_line = impl_pos.line * 1024 + impl_pos.column, .counter = 0, .file = "<clone>:${impl_pos.file}" }
    for method in trait_.members {
        impl_.members.push(synth_signature(method, next_clone_span(stamp), subst, intrinsic_decorator(impl_.span)))
    }
}

/// Trait default methods → inject deep-cloned copies into impls that
/// didn't override the method. Clones bodies via
/// `substitute_block_materialized` so cloned nodes carry the
/// materialised-span marker (rendered as `undefined:undefined` in the
/// typecheck dump — matches TS's accidental shape for substituted
/// leaves). Then `assign_block_ids` mints fresh IDs in the host
/// module's namespace so id-keyed `expr_types` / `expr_kinds` slots
/// don't collide with the impl module's pre-existing nodes.
export materialize_default_members :: fn(
    impl_: AST.ImplDecl, trait_: AST.TraitDecl, host_factory: NodeIdFactory,
) -> void {
    if !any_has_body(trait_.members) { return }
    provided :: provided_names(impl_.members)
    subst :: build_subst(impl_, trait_)
    // One deterministic span allocator per impl : `base_line` = the impl's
    // source line (stable + unique per impl), `counter` accumulates across
    // every cloned member so each node gets a distinct `<clone>` span. The
    // determinism is load-bearing — std/core's bodies are materialised twice
    // (typecheck + lower phases, distinct ImplDecl copies) and node ids
    // differ between the two, so the clone spans must NOT depend on them or
    // the resolver's span-keyed `idents` records and the lower-phase reads
    // land on different keys. Same source + same traversal ⇒ same spans.
    // `base_line` keys the `<clone>` spans to THIS impl. Fold in the column
    // so two impls on the same source line (rare, but not forbidden) don't
    // share a base and collide their cloned-node spans. `line * 1024 + column`
    // is collision-free for realistic positions (columns « 1024) and stable
    // across the typecheck/lower materialisation generations.
    impl_pos :: impl_.trait_name_span.start
    stamp :: StampCtx { .base_line = impl_pos.line * 1024 + impl_pos.column, .counter = 0, .file = "<clone>:${impl_pos.file}" }
    for method in trait_.members {
        body :: method.body
        match body {
            is null         -> {}     // not a default method
            is AST.BlockExpr as b -> {
                if method.name in provided { continue }
                no_decorators: AST.Decorator[] = []
                cloned :: substitute_block_materialized(b, subst, host_factory, stamp)
                impl_.members.push(synth_with_body(method, subst, no_decorators, cloned, stamp))
            }
        }
    }
}

synth_with_body :: fn(
    method: AST.FnDecl, subst: Subst,
    decorators: AST.Decorator[], body: AST.BlockExpr, stamp: StampCtx,
) -> AST.FnDecl {
    return AST.FnDecl {
        .span = method.span,
        .id = AST.UNASSIGNED_NODE_ID,
        .name = method.name,
        // Key the clone on the trait method's name span (distinct per
        // default method), not the shared `impl_.trait_name_span` —
        // `impl_method_decl_types` is name-span-keyed, so a shared span
        // would collapse is_empty / count / last onto one return type.
        .name_span = method.name_span,
        .visibility = .Public,
        .type_params = [],
        // EVERY param (including `self`) gets a deterministic `<clone>` span
        // from the SAME `StampCtx` as the body. This is load-bearing : the
        // resolver mints the param's Symbol at the param span AND records the
        // body's `self`/`other` use-sites' Symbols by name, so `build_impl_
        // member_params` (lower, span-keyed `idents` lookup) and the body's
        // idents must agree on the param span. The trait method's
        // `name_span` is SHARED across the N primitive impls of one trait
        // (i8 … char `Comparable`), so anchoring `self` there made
        // `build_impl_member_params` read the LAST impl's `self` Symbol — the
        // body's `self` resolved to the right one → CFG-build failed with
        // `unresolved ident self`. Deterministic per-impl spans fix both the
        // cross-impl collision and the param↔body Symbol agreement.
        .params = substitute_params_stamped(method.params, subst, stamp),
        .return_type = substitute_opt_type(method.return_type, subst),
        .body = body,
        .decorators = decorators,
        .sam_synthetic = false,
        .is_expression_bodied = method.is_expression_bodied,
        .materialized = true,
    }
}

/// Substitute params, anchoring each at a deterministic `<clone>` span from
/// `stamp` (shared with the cloned body). Used for default-method clones so
/// the param Symbols agree with the body's span-keyed `idents` entries.
substitute_params_stamped :: fn(params: AST.FnParam[], subst: Subst, stamp: StampCtx) -> AST.FnParam[] {
    out: AST.FnParam[] = []
    for p in params {
        out.push(AST.FnParam {
            .span = next_clone_span(stamp),
            .id = AST.UNASSIGNED_NODE_ID,
            .name = p.name,
            .ty = substitute_opt_type(p.ty, subst),
            .default_value = p.default_value,
            .variadic = p.variadic,
        })
    }
    return out
}

/// Mint a fresh, globally-unique synthetic span for a materialised clone's
/// non-self param (or body node). `line = 0` keeps it clear of any real
/// source span (real spans are 1-based) ; the minted factory id rides in
/// `column` so each call yields a distinct `Span.hash()`.
synth_clone_span :: fn(factory: NodeIdFactory) -> Span {
    pos :: Position { .file = "", .offset = usize(0), .line = 0, .column = i32(factory.mint()) }
    return Span { .start = pos, .end = pos }
}

/// `substitute_params` but `self` re-anchors at `self_span` (its type is
/// contextual, so a shared span is fine) while every non-self param gets a
/// fresh minted span — so a two-arg default (`Comparable.gt(self, other:
/// Self)`) doesn't collide `other` across sibling impls in the span-keyed
/// `param_types` table.
substitute_params_disambiguated :: fn(
    params: AST.FnParam[], subst: Subst, self_span: Span, factory: NodeIdFactory,
) -> AST.FnParam[] {
    out: AST.FnParam[] = []
    for p in params {
        span :: if p.name == "self" { self_span } else { synth_clone_span(factory) }
        out.push(AST.FnParam {
            .span = span,
            .id = AST.UNASSIGNED_NODE_ID,
            .name = p.name,
            .ty = substitute_opt_type(p.ty, subst),
            .default_value = p.default_value,
            .variadic = p.variadic,
        })
    }
    return out
}

import "vader/parser" { NodeIdFactory, new_node_id_factory }

/// SAM-synthetic members come out of the parser with a placeholder
/// name and an empty param list ; the trait's lone required method
/// supplies the canonical name + signature. Mutates each synthetic
/// member in place. *Doesn't emit R2016 yet* — diagnostics for SAM
/// shape mismatches surface from the TS resolver until `ResolverCode`
/// is ported.
export materialize_sam_members :: fn(impl_: AST.ImplDecl, trait_: AST.TraitDecl, factory: NodeIdFactory) -> void {
    syn_count :: count_sam_synthetics(impl_.members)
    if syn_count == 0 { return }
    required :: required_methods(trait_.members)
    if required.is_empty() { return }
    // Pick the first required method as the SAM target. When the trait
    // has >1 required method, R2016 already fired ; renaming under the
    // first one still lets the T3036 "missing method" loop find at
    // least the SAM-named method instead of flagging both as missing
    // (mirrors TS's surface).
    method :: required[0]
    subst :: build_subst(impl_, trait_)
    for i in 0..<impl_.members.len() {
        m :: impl_.members[i]
        if !m.sam_synthetic { continue }
        m.name = method.name
        // `self` re-anchors at the synthetic member's own span (unique per
        // impl) ; non-self params get fresh minted spans so a two-arg SAM
        // method (`Comparable.compare(self, other: Self)`) doesn't collide
        // `self` / `other` on one span-keyed `param_types` slot.
        m.params = substitute_params_disambiguated(method.params, subst, m.name_span, factory)
        m.return_type = substitute_opt_type(method.return_type, subst)
    }
}

// ---- helpers --------------------------------------------------------------

is_intrinsic :: fn(decs: AST.Decorator[]) -> bool {
    for d in decs {
        if d.name == "intrinsic" { return true }
    }
    return false
}

any_has_body :: fn(members: AST.FnDecl[]) -> bool {
    for m in members {
        match m.body {
            is AST.BlockExpr -> { return true }
            is null          -> {}
        }
    }
    return false
}

provided_names :: fn(members: AST.FnDecl[]) -> MutableSet<string> {
    set :: MutableSet<string> {}
    for m in members { set.add(m.name) }
    return set
}

export count_sam_synthetics :: fn(members: AST.FnDecl[]) -> usize {
    n: usize = 0
    for m in members {
        if m.sam_synthetic { n = n + 1 }
    }
    return n
}

export required_methods :: fn(members: AST.FnDecl[]) -> AST.FnDecl[] {
    out: AST.FnDecl[] = []
    for m in members {
        match m.body {
            is null          -> { out.push(m) }
            is AST.BlockExpr -> {}     // default-bodied — not a "required" method
        }
    }
    return out
}

build_subst :: fn(impl_: AST.ImplDecl, trait_: AST.TraitDecl) -> Subst {
    subst :: new_subst()
    bind(subst, "Self", impl_.for_type)
    n :: min(trait_.type_params.len(), impl_.trait_args.len())
    for i in 0..<n {
        bind(subst, trait_.type_params[i].name, impl_.trait_args[i])
    }
    return subst
}

synth_signature :: fn(
    method: AST.FnDecl, name_span: Span, subst: Subst, decorators: AST.Decorator[],
) -> AST.FnDecl {
    return AST.FnDecl {
        .span = method.span,
        .id = AST.UNASSIGNED_NODE_ID,
        .name = method.name,
        .name_span = name_span,
        .visibility = .Public,
        .type_params = [],
        .params = substitute_params(method.params, subst),
        .return_type = substitute_opt_type(method.return_type, subst),
        .body = null,
        .decorators = decorators,
        .sam_synthetic = false,
        .is_expression_bodied = method.is_expression_bodied,
        .materialized = true,
    }
}

substitute_params :: fn(params: AST.FnParam[], subst: Subst) -> AST.FnParam[] {
    out: AST.FnParam[] = []
    for p in params {
        out.push(AST.FnParam {
            .span = p.span,
            .id = AST.UNASSIGNED_NODE_ID,
            .name = p.name,
            .ty = substitute_opt_type(p.ty, subst),
            .default_value = p.default_value,
            .variadic = p.variadic,
        })
    }
    return out
}

substitute_opt_type :: fn(t: AST.TypeExpr | null, subst: Subst) -> AST.TypeExpr | null {
    match t {
        is null -> { return null }
        _       -> { return substitute_type_expr(t, subst) }
    }
}

intrinsic_decorator :: fn(span: Span) -> AST.Decorator[] {
    args: AST.Expr[] = []
    return [AST.Decorator { .span = span, .id = AST.UNASSIGNED_NODE_ID, .name = "intrinsic", .args = args }]
}

// ---- tests ----------------------------------------------------------------

@test
test_materialize_sam_fills_name_and_signature :: fn() -> void {
    src :: """
Equals :: trait {
    equals :: fn(self, other: Self) -> bool
}

Point :: struct {
    x: i32
}

Point implements Equals -> true
"""
    parsed :: parse_source(src, "t.vader")
    trait_decl :: find_trait(parsed.program.decls, "Equals")
    impl_decl  :: find_impl(parsed.program.decls)
    match trait_decl {
        is null -> { assert(false, "Equals trait should be parsed") }
        is AST.TraitDecl as t -> {
            match impl_decl {
                is null -> { assert(false, "Point implements Equals should be parsed") }
                is AST.ImplDecl as im -> {
                    materialize_sam_members(im, t, new_node_id_factory())
                    found := false
                    for m in im.members {
                        if m.name == "equals" { found = true }
                    }
                    assert(found, "SAM-synthetic member should be named after the trait's method")
                }
            }
        }
    }
}

@test
test_materialize_intrinsic_fills_empty_body :: fn() -> void {
    // `@intrinsic <T> implements <Trait>` is the bare-impl form ; the
    // parser leaves `members` empty, and materialize pushes one stub
    // FnDecl per trait method.
    src :: """
Iter :: trait {
    next :: fn(self) -> i32
}

@intrinsic i32 implements Iter
"""
    parsed :: parse_source(src, "t.vader")
    trait_decl :: find_trait(parsed.program.decls, "Iter")
    impl_decl  :: find_impl(parsed.program.decls)
    match trait_decl {
        is null -> { assert(false, "Iter trait should be parsed") }
        is AST.TraitDecl as t -> {
            match impl_decl {
                is null -> { assert(false, "i32 implements Iter should be parsed") }
                is AST.ImplDecl as im -> {
                    before :: im.members.len()
                    assert_eq(before, usize(0))
                    materialize_intrinsic_members(im, t)
                    after :: im.members.len()
                    assert_eq(after, usize(1))
                    assert_eq(im.members[0].name, "next")
                }
            }
        }
    }
}

find_trait :: fn(decls: AST.Decl[], name: string) -> AST.TraitDecl | null {
    for d in decls {
        match d {
            is AST.TraitDecl as t -> { if t.name == name { return t } }
            _ -> {}
        }
    }
    return null
}

find_impl :: fn(decls: AST.Decl[]) -> AST.ImplDecl | null {
    for d in decls {
        match d {
            is AST.ImplDecl as im -> { return im }
            _ -> {}
        }
    }
    return null
}
