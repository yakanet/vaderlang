// vader/resolver/loader — module graph loader.
//
// Mirror of `src/resolver/loader.ts`. Discovers every module under the
// scoped roots up-front via `discover_modules` (header-only parse, no
// AST held in memory), then BFS-walks the import graph by name-lookup
// against that index. Each visited module pays a full `parse_source`
// once ; unreached modules' files are never read past their header.
//
// Scope :
//   - stdlib (always — `default_stdlib_root`).
//   - `vader.json::modules` when a manifest is found.
//   - The entry file's containing folder (CLI fallback) when it lies
//     outside the whitelist.

module "vader/resolver"

import "std/collections" { MutableMap, keys }
import "std/io" { exists, is_dir, read_file }
import "std/string" { byte_at, byte_len, ends_with, slice, starts_with }
import "vader/diagnostics" { Diagnostic }
import "vader/parser" { NodeIdFactory, new_node_id_factory, parse_source }
import "vader/resolver/symbol" { SymbolFactory, new_factory }

/// Output of one project load : the entry module's id, the full set
/// of modules keyed by id, and the shared symbol factory used to
/// mint every Symbol across modules (so ids stay globally unique).
export LoadedProject :: struct {
    entry:        string
    modules:      MutableMap(string, LoadedModule)
    factory:      SymbolFactory
    project_root: string | null
}

/// One module after parse + collect (top-level symbols minted but
/// body-walker / typecheck haven't run yet). `node_id_factory` is
/// shared with `materialize.vader` so cloned default-method bodies
/// inserted into this module's impls get IDs that don't collide
/// with the IDs minted at parse time.
export LoadedModule :: struct {
    module:          Module
    collected:       CollectedModule
    node_id_factory: NodeIdFactory
}

/// Build the module graph rooted at `entry_path`. Returns the loaded
/// project ; callers feed it to `resolve_project` / `check_project`.
export load_project :: fn(entry_path: string) -> LoadedProject {
    factory :: new_factory()
    modules :: MutableMap(string, LoadedModule) { .buckets = [], .size = 0 }
    stdlib_root :: default_stdlib_root()
    project_root :: find_manifest_root(entry_path)
    entry_folder :: entry_folder_of(entry_path)

    // Scoped roots : stdlib + manifest::modules + CLI fallback when the
    // entry sits outside the whitelist.
    scoped_roots: string[] = [stdlib_root]
    match project_root {
        is null -> {}
        is string as pr -> {
            for m in read_manifest_modules(pr) {
                scoped_roots.push(join_path(pr, m))
            }
        }
    }
    if !is_under_any_root(entry_folder, scoped_roots) {
        scoped_roots.push(entry_folder)
    }

    // Header-only scan : index every module under scope by its
    // declared name. The parsed Programs are NOT retained — full
    // parsing happens below, lazily, only for modules the BFS visits.
    discard_diags: Diagnostic[] = []
    index: MutableMap(string, DiscoveredModule) = discover_modules(scoped_roots, discard_diags)

    entry_module :: find_by_folder(index, entry_folder)
    match entry_module {
        is null -> {
            return LoadedProject {
                .entry = entry_folder, .modules = modules, .factory = factory,
                .project_root = project_root,
            }
        }
        is DiscoveredModule as em -> {
            queue: DiscoveredModule[] = [em]
            core :: index["std/core"]
            match core {
                is DiscoveredModule as cm -> {
                    if cm.folder != em.folder { queue.push(cm) }
                }
                _ -> {}
            }
            cursor: usize = 0
            for cursor < queue.len() {
                m :: queue[cursor]
                cursor = cursor + usize(1)
                id :: m.folder
                if has_module(modules, id) { continue }
                ingest_module(m, stdlib_root, modules, factory)
                ingested :: modules[id]
                match ingested {
                    is null -> {}
                    is LoadedModule as lm -> {
                        for raw in lm.collected.import_paths {
                            target :: index[raw]
                            match target {
                                is DiscoveredModule as t -> {
                                    if !has_module(modules, t.folder) { queue.push(t) }
                                }
                                _ -> {}
                            }
                        }
                    }
                }
            }
            return LoadedProject {
                .entry = em.folder, .modules = modules, .factory = factory,
                .project_root = project_root,
            }
        }
    }
}

// Full-parse + collect each file the BFS pulls in. Mirrors the legacy
// `load_one` / `collect_files` path : the header-only index records
// the file *paths*, so we re-read + re-parse here to produce the
// SourceFile + CollectedModule the resolver / typechecker downstream
// expect.
ingest_module :: fn(
    m: DiscoveredModule, stdlib_root: string,
    modules: MutableMap(string, LoadedModule), factory: SymbolFactory,
) -> void {
    if m.files.len() == 0 { return }
    sources :: parse_module_files(m.files)
    if sources.len() == 0 { return }
    collected :: collect_files(sources, m.folder, factory)
    modules[m.folder] = LoadedModule {
        .module = Module {
            .id = m.folder, .display_path = display_path_for(m.folder, stdlib_root),
            .root_dir = m.folder, .files = sources,
        },
        .collected       = collected,
        .node_id_factory = sources[0].id_factory,
    }
}

parse_module_files :: fn(paths: string[]) -> SourceFile[] {
    out: SourceFile[] = []
    for path in paths {
        content_opt :: read_file(path)
        content :: match content_opt { is string as s -> s, _ -> "" }
        if content == "" { continue }
        parsed :: parse_source(content, path)
        out.push(SourceFile {
            .path       = path,
            .content    = content,
            .program    = parsed.program,
            .id_factory = parsed.id_factory,
        })
    }
    return out
}

find_by_folder :: fn(index: MutableMap(string, DiscoveredModule), folder: string) -> DiscoveredModule | null {
    for name in index.keys() {
        m :: index[name]
        match m {
            is DiscoveredModule as dm -> {
                if dm.folder == folder { return dm }
            }
            _ -> {}
        }
    }
    return null
}

entry_folder_of :: fn(path: string) -> string {
    if exists(path) && is_dir(path) { return path }
    return dir_of(path)
}

is_under_any_root :: fn(folder: string, roots: string[]) -> bool {
    for r in roots {
        norm :: trim_trailing_slash(r)
        if folder == norm { return true }
        if folder.starts_with("${norm}/") { return true }
    }
    return false
}

trim_trailing_slash :: fn(s: string) -> string {
    n :: s.byte_len()
    if n == usize(0) { return s }
    if s.byte_at(n - usize(1)) == u8(0x2F) { return slice(s, usize(0), n - usize(1)) }
    return s
}

has_module :: fn(modules: MutableMap(string, LoadedModule), id: string) -> bool {
    return !(modules[id] is null)
}

collect_files :: fn(files: SourceFile[], module_id: string, factory: SymbolFactory) -> CollectedModule {
    // Multi-file collect : merge every file's collected view into one
    // module-wide table. Each file mints fresh Symbol ids through the
    // shared factory, so the maps just need their entries union'd.
    merged :: collect_module(files[0].program, module_id, factory)
    for i in 1..<files.len() {
        per_file :: collect_module(files[i].program, module_id, factory)
        merge_collected(merged, per_file)
    }
    return merged
}

merge_collected :: fn(dst: CollectedModule, src: CollectedModule) -> void {
    for name in src.symbols.keys() {
        sym :: src.symbols[name]
        if sym is null { continue }
        dst.symbols[name] = sym
    }
    for name in src.fn_overloads.keys() {
        bucket :: src.fn_overloads[name]
        if bucket is null { continue }
        existing :: dst.fn_overloads[name]
        match existing {
            is null -> { dst.fn_overloads[name] = bucket }
            _ -> {
                for s in bucket { existing.push(s) }
                dst.fn_overloads[name] = existing
            }
        }
    }
    for id in src.imports.keys() {
        info :: src.imports[id]
        if info is null { continue }
        dst.imports[id] = info
    }
    for p in src.import_paths { dst.import_paths.push(p) }
}

/// When `root` lives under `stdlib_root`, strip the prefix and the
/// `.vader` extension so `stdlib/std/io` renders as `std/io`.
display_path_for :: fn(root: string, stdlib_root: string) -> string {
    if root.starts_with("${stdlib_root}/") {
        rel :: slice(root, stdlib_root.byte_len() + usize(1), root.byte_len())
        if rel.ends_with(".vader") {
            return slice(rel, usize(0), rel.byte_len() - usize(6))
        }
        return rel
    }
    return root
}
