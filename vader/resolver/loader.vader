// vader/resolver/loader — module graph loader.
//
// Seeds the entry module from its own folder, then BFS-walks the import graph,
// resolving each import lazily by path-mapping against the include-paths
// (`lazy.vader`) — no up-front filesystem scan. Each visited module pays a full
// `parse_source` once. Load order is the import BFS, so symbol-id assignment is
// independent of discovery.
//
// Include-paths (search order, first match wins ; GCC `-I` style) :
//   - the entry folder, rooted at its declared module name ;
//   - the manifest dir + each `vader.json includePaths` entry (project modules
//     + stdlib) when a manifest is found ;
//   - the binary-adjacent stdlib default (so a deployed binary finds its
//     bundled stdlib).

module "vader/resolver"

import "std/collections" { MutableMap }
import "std/io" { exists, is_dir, read_file }
import "std/path" { to_posix }
import "vader/diagnostics" { Diagnostic, Position, Span, resolver_error }
import "vader/parser" { NodeIdFactory, new_node_id_factory, parse_source, assign_program_ids }
import "vader/resolver/symbol" { Symbol, SymbolKind, SymbolFactory, new_factory }

/// Synthetic 1:1 span anchored on a file path. Used by R2001 when the
/// entry folder lies outside every scoped root — there is no source-
/// level token to point at, so the span just records the file.
///
/// TODO consolidate with `vader/lexer/token::empty_span(file)` and
/// `vader/diagnostics::empty_span()` (no-arg, synthetic file). Same
/// shape, three callers, no shared definition — Vader's overload
/// resolution picks the no-arg variant when both are in scope which
/// blocks naive reuse. Land a single `empty_span(file: string)` in
/// `vader/diagnostics/` and migrate every caller.
zero_span :: fn(path: string) = Span {
    .start = Position { .file = path, .offset = usize(0), .line = 1, .column = 1 },
    .end   = Position { .file = path, .offset = usize(0), .line = 1, .column = 1 },
}

/// Output of one project load : the entry module's id, the full set
/// of modules keyed by id, and the shared symbol factory used to
/// mint every Symbol across modules (so ids stay globally unique).
///
/// `diags` collects loader-time diagnostics : R2020/R2022/R2023 from
/// discover, R2001/R2024/R2025/R2028 from import-path resolution,
/// R2002/R2004/R2011 from collect, R2005 from cycle detection. CLI
/// consumers merge these into their `# Diagnostics` block.
export LoadedProject :: struct {
    entry:        string
    modules:      MutableMap<string, LoadedModule>
    factory:      SymbolFactory
    project_root: string | null
    diags:        Diagnostic[]
}

/// Empty placeholder — used by test fixtures that construct downstream
/// project contexts without going through `load_project`.
export empty_loaded_project :: fn() -> LoadedProject {
    return LoadedProject {
        .entry        = "",
        .modules      = MutableMap<string, LoadedModule> {},
        .factory      = new_factory(),
        .project_root = null,
        .diags        = [],
    }
}

/// One module after parse + collect (top-level symbols minted but
/// body-walker / typecheck haven't run yet). `node_id_factory` is
/// shared with `materialize.vader` so cloned default-method bodies
/// inserted into this module's impls get IDs that don't collide
/// with the IDs minted at parse time.
export LoadedModule :: struct {
    module:          Module
    collected:       CollectedModule
    node_id_factory: NodeIdFactory
}

/// Build the module graph rooted at `entry_path`. Returns the loaded
/// project ; callers feed it to `resolve_project` / `check_project`.
/// Reads every module from disk.
export load_project :: fn(entry_path: string, include_path_flags: string[]) -> LoadedProject {
    return load_project_with_overlay(entry_path, MutableMap<string, string> {}, include_path_flags)
}

/// Like `load_project`, but consults an in-memory `overlay` (filesystem path
/// → current source text) before the disk for every module file. The LSP
/// passes its didOpen/didChange buffer so typed features (hover, diagnostics,
/// …) reflect unsaved edits instead of the last-saved file ; the CLI calls
/// `load_project` (empty overlay, disk-only).
///
/// Scope: the overlay is consulted only by the loader's *content* read
/// (`parse_module_files`), NOT by module *discovery* (`discover.vader`, which
/// scans the disk via `read_dir` + a header-only `read_file`). So an unsaved
/// edit to a SAVED file's body is reflected, but (a) a never-saved file is not
/// enumerated, and (b) an unsaved edit to a file's `module "..."` header is
/// bucketed by the stale on-disk header. Threading the overlay into discovery
/// (both the dir enumeration and the header read) is a follow-up.
///
/// @param entry_path  the entry file's path.
/// @param overlay     filesystem path → current source text ; consulted
///                    before the disk in `parse_module_files`.
export load_project_with_overlay :: fn(entry_path: string, overlay: MutableMap<string, string>, include_path_flags: string[]) -> LoadedProject {
    factory :: new_factory()
    // ONE node-id factory for the whole project so AST node ids are globally
    // unique across modules (see `parse_module_files`). Threaded into every
    // module's parse + carried as each module's `node_id_factory`.
    node_factory :: new_node_id_factory()
    // Windows hands the entry path with `\` separators ; the resolver keeps `/`
    // as its single internal separator (join_path, the module index, std/path
    // are all `/`-based), so normalise once at this boundary. POSIX paths are
    // unchanged. Everything downstream derives the entry folder + manifest root
    // from this normalised form.
    entry :: entry_path.to_posix()
    modules :: MutableMap<string, LoadedModule> {}
    loader_diags: Diagnostic[] = []
    project_root :: find_manifest_root(entry)
    // Read the project manifest once (the LSP re-loads on every didOpen).
    manifest :: match project_root {
        is string as pr -> read_manifest(pr)
        is null          -> Manifest { .include_paths = [] }
    }
    entry_folder :: entry_folder_of(entry)
    plain_roots :: project_include_paths(project_root, manifest, include_path_flags)

    // Lazy import-driven resolution (see `lazy.vader`). No eager scan : `index`
    // is a cache filled on demand by `resolve_lazy`, which path-maps each module
    // name to a folder under the include-paths. Load ORDER — and thus symbol-id
    // assignment — is driven solely by the import BFS in `drain_load_queue`, not
    // by discovery, so the self-compile is byte-identical regardless of how the
    // include-paths are sourced. The include-paths (built once the entry's
    // namespace is known) are : the entry folder rooted at its declared module
    // name, then `plain_roots` (manifest dir + `vader.json includePaths` +
    // binary-adjacent stdlib default ; GCC `-I` style, first match wins).
    index: MutableMap<string, DiscoveredModule> = MutableMap<string, DiscoveredModule> {}

    entry_module :: seed_entry(entry_folder, index, loader_diags)
    match entry_module {
        is null -> {
            loader_diags.push(resolver_error(.ModuleNotFound, zero_span(entry),
                "entry file's folder declares no module"))
            return LoadedProject {
                .entry = entry_folder, .modules = modules, .factory = factory,
                .project_root = project_root, .diags = loader_diags,
            }
        }
        is DiscoveredModule as em -> {
            bases :: include_paths(em.name, em.folder, plain_roots)
            queue: DiscoveredModule[] = [em]
            core :: resolve_lazy("std/core", bases, index, loader_diags)
            match core {
                is DiscoveredModule as cm -> {
                    if cm.folder != em.folder { queue.push(cm) }
                }
                _ -> {}
            }
            drain_load_queue(queue, bases, modules, factory, index, loader_diags, overlay, node_factory)
            // Force-load `std/string_builder` AFTER the natural BFS (Target ABI
            // S4): string interpolation `"${...}"` desugars to its `new_builder`/
            // `append`/`to_string` calls in the lowerer, a dependency not visible
            // as a source import. Appending it last (rather than seeding it early)
            // keeps the natural module load order — and thus symbol-id assignment
            // — identical to a build without the force-load, so it never perturbs
            // materialisation for entries that already load it (e.g.
            // bootstrap.vader strands `build_stmt` if string_builder is seeded
            // early). Unused-when-no-interp code is DCE'd.
            string_builder :: resolve_lazy("std/string_builder", bases, index, loader_diags)
            match string_builder {
                is DiscoveredModule as sbm -> {
                    if !has_module(modules, sbm.folder) {
                        sb_queue: DiscoveredModule[] = [sbm]
                        drain_load_queue(sb_queue, bases, modules, factory, index, loader_diags, overlay, node_factory)
                    }
                }
                _ -> {}
            }
            return LoadedProject {
                .entry = em.folder, .modules = modules, .factory = factory,
                .project_root = project_root, .diags = loader_diags,
            }
        }
    }
}

// Full-parse + collect each file the BFS pulls in. Mirrors the legacy
// `load_one` / `collect_files` path : the header-only index records
// the file *paths*, so we re-read + re-parse here to produce the
// SourceFile + CollectedModule the resolver / typechecker downstream
// expect. `index` lets `collect_files` resolve each import path and
// emit R2001/R2024/R2025/R2028 with the right span.
// BFS-drain a work-queue of discovered modules: ingest each not-yet-loaded
// module, then enqueue its imports. Shared by the entry BFS and the
// std/string_builder force-load so both follow identical ingestion logic
// (and so the force-load can run as a separate, order-preserving pass).
drain_load_queue :: fn(
    queue: DiscoveredModule[], bases: IncludePath[],
    modules: MutableMap<string, LoadedModule>, factory: SymbolFactory,
    index: MutableMap<string, DiscoveredModule>, diags: Diagnostic[],
    overlay: MutableMap<string, string>, node_factory: NodeIdFactory,
) -> void {
    cursor: usize = 0
    for cursor < queue.len() {
        m :: queue[cursor]
        cursor = cursor + 1
        id :: m.folder
        if has_module(modules, id) { continue }
        ingest_module(m, bases, modules, factory, index, diags, overlay, node_factory)
        ingested :: modules[id]
        match ingested {
            is null -> {}
            is LoadedModule as lm -> {
                for raw in lm.collected.import_paths {
                    target :: index[raw]
                    match target {
                        is DiscoveredModule as t -> {
                            if !has_module(modules, t.folder) { queue.push(t) }
                        }
                        _ -> {}
                    }
                }
            }
        }
    }
}

ingest_module :: fn(
    m: DiscoveredModule, bases: IncludePath[],
    modules: MutableMap<string, LoadedModule>, factory: SymbolFactory,
    index: MutableMap<string, DiscoveredModule>, diags: Diagnostic[],
    overlay: MutableMap<string, string>, node_factory: NodeIdFactory,
) -> void {
    if m.files.len() == 0 { return }
    sources :: parse_module_files(m.files, diags, overlay, node_factory)
    if sources.len() == 0 { return }
    // Pre-resolve this module's imports into the cache so `collect_files`'
    // `diagnose_import_path` finds them instead of firing a spurious R2001 —
    // the failure mode that reverted the earlier lazy attempt.
    preresolve_imports(sources, bases, index, diags)
    collected :: collect_files(sources, m.folder, m.name, factory, index, diags)
    modules[m.folder] = LoadedModule {
        .module = Module {
            .id           = m.folder,
            // Display path mirrors TS `src/resolver/loader.ts:94` —
            // the module's declared name (`module "..."`), NOT the
            // filesystem folder. Keeps `# Lower` / `# Comptime` /
            // `# Typecheck` dumps byte-identical with TS snapshots.
            .display_path = m.name,
            .module_name  = m.name,
            .root_dir     = m.folder,
            .files        = sources,
        },
        .collected       = collected,
        // Same project-global factory every module's parse used (each
        // `SourceFile.id_factory` is `node_factory`) ; carried here so
        // materialised clones mint past the project-global max.
        .node_id_factory = node_factory,
    }
}

// Read `path`'s source, consulting the in-memory `overlay` (filesystem path →
// current text) before the disk. The LSP populates the overlay from its
// didChange buffer so unsaved edits are parsed ; an empty overlay falls
// straight through to `read_file`. Returns "" when neither the overlay nor
// the disk has the file (the caller skips empty content) — same handling the
// pre-overlay code gave `read_file`'s error case.
read_with_overlay :: fn(overlay: MutableMap<string, string>, path: string) -> string {
    buffered :: overlay[path]
    if buffered != null { return buffered }
    disk :: read_file(path)
    if disk is string { return disk }
    return ""
}

parse_module_files :: fn(paths: string[], diags: Diagnostic[], overlay: MutableMap<string, string>, node_factory: NodeIdFactory) -> SourceFile[] {
    // ONE factory threaded across the WHOLE project, so AST node ids are
    // globally unique — not just module-unique. Per-module factories (each
    // restarting at 1) overlapped, and the side-tables keyed by raw node id
    // (`expr_types` / `expr_kinds` / `node_spans`) then collided whenever one
    // module's typecheck recorded a FOREIGN node — e.g. std/core's primitive
    // `Comparable` default-method clones, materialised via `node_id_factory`
    // and typed into a consumer module (the `expand_tilde` return-array
    // miscompile). A global factory makes that collision impossible (mirrors
    // globally-unique Symbol ids).
    out: SourceFile[] = []
    for path in paths {
        content :: read_with_overlay(overlay, path)
        if content == "" { continue }
        parsed :: parse_source(content, path)
        for e in parsed.errors { diags.push(e) }
        assign_program_ids(parsed.program, node_factory)
        out.push(SourceFile {
            .path       = path,
            .content    = content,
            .program    = parsed.program,
            .id_factory = node_factory,
        })
    }
    return out
}

// Assemble the plain (unrooted) include-paths for a project — GCC `-I` style,
// first-match-wins : the manifest dir itself (so a project's own modules resolve
// by their folder-relative name), then each `vader.json includePaths` entry
// joined onto it (e.g. `"stdlib"` → `<root>/stdlib`, hosting `std/*`), then the
// binary-adjacent stdlib default (so a deployed binary finds its bundled stdlib
// when the entry has no manifest). The `--include-paths` flag entries come first
// (highest precedence).
project_include_paths :: fn(
    project_root: string | null, manifest: Manifest, flag_paths: string[],
) -> string[] {
    roots: string[] = []
    for p in flag_paths { roots.push(p) }
    match project_root {
        is string as pr -> {
            roots.push(pr)
            for p in manifest.include_paths { roots.push(join_path(pr, p)) }
        }
        is null -> {}
    }
    roots.push(default_stdlib_root())
    return roots
}

entry_folder_of :: fn(path: string) -> string {
    if exists(path) && is_dir(path) { return path }
    return dir_of(path)
}

has_module :: fn(modules: MutableMap<string, LoadedModule>, id: string) -> bool {
    return !(modules[id] is null)
}

collect_files :: fn(
    files: SourceFile[], module_id: string, module_name: string,
    factory: SymbolFactory,
    index: MutableMap<string, DiscoveredModule>, diags: Diagnostic[],
) -> CollectedModule {
    // Multi-file collect : merge every file's collected view into one
    // module-wide table. Each file mints fresh Symbol ids through the
    // shared factory, so the maps just need their entries union'd.
    merged :: collect_module(files[0].program, module_id, module_name, factory, index, diags)
    for i in 1..<files.len() {
        per_file :: collect_module(files[i].program, module_id, module_name, factory, index, diags)
        merge_collected(merged, per_file, diags)
    }
    return merged
}

merge_collected :: fn(dst: CollectedModule, src: CollectedModule, diags: Diagnostic[]) -> void {
    for [name, sym] in src.symbols {
        existing :: dst.symbols[name]
        match existing {
            is null -> { dst.symbols[name] = sym }
            is Symbol as e -> {
                // Fn-vs-fn collisions are handled by `fn_overloads`
                // below — the primary slot keeps its first-wins binding
                // (mirrors `add_fn_symbol`'s policy) while every
                // overload still lands in the bucket.
                //
                // ImportBinding-vs-ImportBinding (same name imported in
                // multiple sibling files) is normal Vader usage : two
                // files of the same module can independently import
                // `MutableMap` from `std/collections`. Per-file scope
                // is what `bind_import` already checks ; the merged
                // module-wide table only needs one slot to carry the
                // binding through to the wire pass.
                //
                // Cross-file duplicates of any other non-fn kind
                // (struct / enum / trait / const / type-alias) violate
                // the module-system invariant that one module owns one
                // declaration of a given name ; fire R2026 per
                // decision #28 of the module redesign.
                fn_kind :: i32(SymbolKind.Fn)
                import_kind :: i32(SymbolKind.ImportBinding)
                e_kind :: i32(e.kind)
                s_kind :: i32(sym.kind)
                fn_pair     :: e_kind == fn_kind && s_kind == fn_kind
                import_pair :: e_kind == import_kind && s_kind == import_kind
                if !fn_pair && !import_pair {
                    span :: match sym.defined_at {
                        is Span as s -> s
                        is null      -> zero_span("")
                    }
                    diags.push(resolver_error(.DuplicateNonFnDeclInModule, span,
                        "`${name}` already declared in a sibling file of this module"))
                }
            }
        }
    }
    for [name, bucket] in src.fn_overloads {
        existing :: dst.fn_overloads[name]
        match existing {
            is null -> { dst.fn_overloads[name] = bucket }
            _ -> {
                for s in bucket { existing.push(s) }
                dst.fn_overloads[name] = existing
            }
        }
    }
    for [id, info] in src.imports {
        dst.imports[id] = info
    }
    for p in src.import_paths { dst.import_paths.push(p) }
}

