build_make_closure :: fn(fn_ctx: FnCtx, e: LoweredMakeClosure) -> LocalId | null {
    env :: build_expr(fn_ctx, e.env)
    if env is null { return null }
    dst :: fresh_tmp(fn_ctx, "closure", e.type)
    emit(fn_ctx, InstrMakeClosure {
        .dst = dst, .fn_symbol = e.fn_symbol, .env = env,
        .env_type = type_of(e.env), .type = e.type, .span = e.span,
    })
    return dst
}

// ============================================================================
// Bookkeeping helpers
// ============================================================================

emit :: fn(fn_ctx: FnCtx, instr: Instruction) -> void {
    if fn_ctx.current is null { return }
    fn_ctx.blocks[usize(fn_ctx.current)].instructions.push(instr)
}

emit_const :: fn(fn_ctx: FnCtx, type: Type, value: ConstValue, span: Span) -> LocalId {
    dst :: fresh_tmp(fn_ctx, "k", type)
    emit(fn_ctx, InstrConst { .dst = dst, .value = value, .type = type, .span = span })
    return dst
}

terminate :: fn(fn_ctx: FnCtx, t: Terminator) -> void {
    if fn_ctx.current is null { return }
    cur :: fn_ctx.blocks[usize(fn_ctx.current)]
    if cur.terminator is null { cur.terminator = t }
    fn_ctx.current = null
}

new_block :: fn(fn_ctx: FnCtx, span: Span) -> BlockId {
    id :: i32(fn_ctx.blocks.len())
    fn_ctx.blocks.push(MutableBlock {
        .id = id, .instructions = [], .terminator = null, .span = span,
    })
    return id
}

declare_local :: fn(fn_ctx: FnCtx, name: string, type: Type, symbol: Symbol | null) -> LocalId {
    id :: i32(fn_ctx.locals.len())
    fn_ctx.locals.push(CFGLocal { .name = name, .type = type, .symbol = symbol })
    return id
}

fresh_tmp :: fn(fn_ctx: FnCtx, hint: string, type: Type) -> LocalId {
    return declare_local(fn_ctx, "\$${hint}_${fn_ctx.locals.len()}", type, null)
}

is_void :: fn(t: Type) -> bool {
    if t is PrimitiveType as p { return p.name == "void" }
    return false
}

