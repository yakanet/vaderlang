// vader/midir/emit — CFG → bytecode emitter (Phase 2 of the Mid-IR refactor).
//
// Reuses the LoweredAST → bytecode
// emitter's project context (`EmitterCtx`) for everything *outside*
// the function body. Function bodies come from the CFG : we run a
// recursive structurer that recovers WASM-style `block` / `loop` /
// `if` nesting from basic blocks + terminators.
//
// Reducibility is guaranteed by construction (the converter only ever
// produces patterns derived from structured source — no user-visible
// `goto`). The structurer relies on dominators + immediate post-
// dominators computed once per fn (both via the simple iterative
// algorithm — Cooper, Harvey, Kennedy "A Simple, Fast Dominance
// Algorithm" — already ported in `analyses.vader`).
//
// This is the canonical CFG → bytecode emitter : every `dump --stage`
// consumer, `vader run`, the C backend, the bootstrap, and the comptime
// VM route their bytecode through `emit_bytecode_from_cfg`. `emit_instr`
// covers the full `Instruction` set ; unresolved callees / materialisation
// gaps panic loudly (GATE B1) rather than degrade silently.

module "vader/midir"

import "std/collections" { MutableMap, MutableSet, remove }
import "std/abort" { panic }
