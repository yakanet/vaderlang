// vader/fmt/format â€” top-level entry points for the formatter.

module "vader/fmt"

import "vader/parser" { parse_source, Program }
import "vader/diagnostics" { Diagnostic }

/// Outcome of a `format_source` call : either the formatted output or the
/// list of parser diagnostics that prevented formatting. Callers
/// pattern-match on the union to decide whether to write back / print to
/// stdout / forward errors.
export FormatResult :: ParseFailure | Formatted

/// The parser emitted at least one error ; formatting was skipped because
/// round-trip parity can't hold on a partial AST.
export ParseFailure :: struct {
    diagnostics: Diagnostic[]
}

/// Successful format â€” `output` is the canonical text of the input source.
export Formatted :: struct {
    output: string
}

/// Parse `source`, build a `CommentMap`, run the printer, and return the
/// formatted source string. The result is idempotent
/// (`format_source(format_source(s).output, p) == s` for any clean
/// `format_source(s, p)` result) and parse-equivalent to the input.
///
/// @param source  the raw `.vader` source bytes.
/// @param path    informational â€” used as the `Program.file` field for
///                diagnostic provenance ; reading is done from `source`.
/// @return        `Formatted` on success, `ParseFailure` carrying every
///                parser diagnostic otherwise.
/// @example
///   r :: format_source("export x :: 42", "demo.vader")
///   match r {
///       is Formatted    as f -> println(f.output)
///       is ParseFailure as e -> for d in e.diagnostics { eprintln(d.render()) }
///   }
export format_source :: fn(source: string, path: string) -> FormatResult {
    pr :: parse_source(source, path)
    if pr.errors.len() > 0 {
        // Don't format files with parse errors â€” round-trip parity cannot
        // hold when the AST is partial.
        return ParseFailure { .diagnostics = pr.errors }
    }
    cm :: scan_comments(source)
    pp :: new_printer(source, cm)
    output :: pp.emit_program(pr.program)
    return Formatted { .output = output }
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert }

@test
test_roundtrip_preserves_postfix_and_await_parens :: fn() -> void {
    // `?` is postfix and `await` binds looser than postfix, so these parens must
    // survive the round-trip or the operator re-binds onto a sub-expression
    // (`(await x).f` â†’ `await x.f`, `(a + b)?` â†’ `a + (b?)`).
    fmt_keeps("f :: fn(x: i32) -> i32 = (await g(x))?", "(await g(x))?")
    fmt_keeps("h :: fn() -> i32 = (await m()).value", "(await m()).value")
    fmt_keeps("j :: fn(a: i32, b: i32) -> i32 = (a + b)?", "(a + b)?")
    fmt_keeps("k :: fn(a: i32, b: i32) -> i32 = await (a + b)", "await (a + b)")
}

fmt_keeps :: fn(decl: string, needle: string) -> void {
    r :: format_source("module \"t\"\n${decl}\n", "t.vader")
    match r {
        is Formatted    as f -> { assert(needle in f.output, "fmt must keep `${needle}`") }
        is ParseFailure     -> { assert(false, "must parse: ${decl}") }
    }
}
