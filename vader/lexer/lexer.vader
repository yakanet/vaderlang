// vader/lexer/lexer — first cut of the Vader-in-Vader lexer.
//
// Scope of this jet (kept deliberately small to validate the porting path):
//   - whitespace, // line comments, /* block comments */ (nested)
//   - identifiers + keyword recognition
//   - decimal int literals with `_` separators and optional suffix
//   - float literals (digits.digits, optional exponent) with optional suffix
//   - one- and two-char operators, range ops `..<` `..=`
//   - brackets, punctuation
//   - newlines with the SUPPRESS_AFTER rules from SPEC §3
//
// Deferred (will land in subsequent passes, not blocked):
//   - char literals + escape sequences
//   - string literals, raw strings, triple strings, interpolation

import "std/string" { byte_at, byte_len, is_empty, slice, parse_float, is_alpha, is_alnum, is_digit, contains }
import "std/utf8" { codepoint_byte_len }

import "std/string_builder" { StringBuilder, new_builder, append, append_char }
import "std/iter" { slice as slice_array }
import "std/numbers" { hex_digit_value, is_hex_digit, is_digit_in_base, parse_int_in_base, is_int_suffix, is_float_suffix }
import "vader/diagnostics/diagnostic" { Diagnostic, error }
import "vader/diagnostics/codes" { LexerCode }
// Position/Span are re-imported transparently via token.vader (same module);
// no need to import them again here — that would trigger R2011.

// ---- driver state ---------------------------------------------------------

// One per active `${...}` interpolation. `brace_depth` counts unclosed `{`s
// inside the current interp expression so we know when a `}` closes the
// interp (depth 0) vs an inner expression (depth > 0). `triple` records
// which string mode to resume on close.
export InterpFrame :: struct {
    brace_depth: i32
    triple: bool
}

export Lexer :: struct {
    src: string
    file: string
    pos: usize
    line: i32
    col: i32
    paren_depth: i32          // unclosed `(` and `[` (NOT `{`)
    last_kind: TokenKind      // initialised to .Newline so first-token rules fire correctly
    tokens: Token[]
    errors: Diagnostic[]
    interp_stack: InterpFrame[]
}

new_lexer :: fn(source: string, file: string) = Lexer {
    .src = source,
    .file = file,
    .pos = 0,
    .line = 1,
    .col = 1,
    .paren_depth = 0,
    .last_kind = .Newline,
    .tokens = [],
    .errors = [],
    .interp_stack = [],
}

// ---- predicates -----------------------------------------------------------

// Local helpers : "identifier start" is letter or underscore, "continue"
// extends with digits. Layered on top of the universal `is_alpha`/`is_alnum`
// from std/string.
is_ident_start :: fn(c: char) = c.is_alpha() || c == '_'

is_ident_continue :: fn(c: char) = c.is_alnum() || c == '_'

// SPEC §3 newline-suppression set — operators / separators after which a
// physical newline is NOT a statement terminator.
suppresses_newline_after :: fn(k: TokenKind) = match k {
    .Plus      -> true
    .Minus     -> true
    .Star      -> true
    .Slash     -> true
    .Percent   -> true
    .Amp       -> true
    .Pipe      -> true
    .Caret     -> true
    .Shl       -> true
    .Shr       -> true
    .Eq        -> true
    .Neq       -> true
    .Lt        -> true
    .Lte       -> true
    .Gt        -> true
    .Gte       -> true
    .AndAnd    -> true
    .OrOr      -> true
    .RangeExcl -> true
    .RangeIncl -> true
    .DotDotDot -> true
    .Assign        -> true
    .PlusAssign    -> true
    .MinusAssign   -> true
    .StarAssign    -> true
    .SlashAssign   -> true
    .PercentAssign -> true
    .Colon     -> true
    .Arrow     -> true
    .FatArrow  -> true
    .Comma     -> true
    _          -> false
}

// ---- cursor helpers -------------------------------------------------------

at_end :: fn(l: Lexer) = l.pos >= l.src.byte_len()

peek :: fn(l: Lexer) -> char {
    if l.pos >= l.src.byte_len() {
        return '\0'
    }
    return l.src[l.pos]
}

peek_at :: fn(l: Lexer, n: usize) -> char {
    p := l.pos + n
    if p >= l.src.byte_len() {
        return '\0'
    }
    return l.src[p]
}

position_here :: fn(l: Lexer) =
    Position { .file = l.file, .offset = l.pos, .line = l.line, .column = l.col }

// Advance `pos` by `n` raw bytes. Column counts **codepoints** (matching
// the TS lexer's UTF-16 code-unit count for BMP source) — UTF-8
// continuation bytes (0x80..0xBF) don't increment the column, only leading
// bytes do. Newlines reset col to 1 as usual.
advance :: fn(l: Lexer, n: usize) -> void {
    for 0..<n {
        if l.pos >= l.src.byte_len() {
            return
        }
        b :: i32(u32(l.src.byte_at(l.pos)))
        if b == 10 {                       // '\n' (0x0A)
            l.line = l.line + 1
            l.col = 1
        } else if b < 128 || b >= 192 {    // ASCII or UTF-8 leading byte
            l.col = l.col + 1
        }
        // UTF-8 continuation bytes (0x80..0xBF) leave col unchanged.
        l.pos = l.pos + 1
    }
}

// ---- token emission -------------------------------------------------------

emit :: fn(l: Lexer, t: Token) -> void {
    l.tokens.push(t)
    l.last_kind = t.kind
}

push_simple :: fn(l: Lexer, kind: TokenKind, text: string, start: Position) -> void {
    span := Span { .start = start, .end = l.position_here() }
    l.emit(make_token(kind, text, span))
}

push_error :: fn(l: Lexer, code: LexerCode, span: Span, detail: string) -> void {
    l.errors.push(error(code, span, detail))
}

// Convenience: most lexer errors take a single-token span anchored at `start`
// up to the current position.
error_span :: fn(l: Lexer, start: Position) =
    Span { .start = start, .end = l.position_here() }

// ---- whitespace + comments -----------------------------------------------

skip_horizontal :: fn(l: Lexer) -> void {
    in_interp :: l.interp_stack.len() > 0
    for !l.at_end() {
        c := l.peek()
        if c == ' ' || c == '\t' {
            l.advance(1)
        } else if in_interp && (c == '\n' || c == '\r') {
            // Newlines inside `${...}` are absorbed so the resumed string
            // body keeps its anchor position in the source.
            l.advance(1)
        } else {
            return
        }
    }
}

lex_block_comment :: fn(l: Lexer) -> void {
    start := l.position_here()
    l.advance(2)  // consume `/*`
    depth := 1
    for !l.at_end() && depth > 0 {
        if l.peek() == '/' && l.peek_at(1) == '*' {
            l.advance(2)
            depth = depth + 1
            continue
        }
        if l.peek() == '*' && l.peek_at(1) == '/' {
            l.advance(2)
            depth = depth - 1
            continue
        }
        l.advance(1)
    }
    if depth > 0 {
        l.push_error(.UnterminatedBlockComment, l.error_span(start), "")
    }
}

// ---- newlines -------------------------------------------------------------

handle_newline :: fn(l: Lexer) -> void {
    // Consume the line terminator (CRLF or LF or lone CR).
    if l.peek() == '\r' {
        l.advance(1)
    }
    if l.peek() == '\n' {
        l.advance(1)
    }
    if l.paren_depth > 0 { return }
    if l.last_kind.suppresses_newline_after() { return }
    if l.last_kind == .Newline { return }

    here := l.position_here()
    span := Span { .start = here, .end = here }
    l.emit(make_token(.Newline, "\n", span))
}

// ---- identifiers ----------------------------------------------------------

lex_ident :: fn(l: Lexer) -> void {
    start := l.position_here()
    for !l.at_end() && l.peek().is_ident_continue() {
        l.advance(1)
    }
    text := l.src.slice(start.offset, l.pos)
    kw := lookup_keyword(text)
    l.push_simple(kw, text, start)
}

// ---- numbers --------------------------------------------------------------

// Read trailing identifier-shaped text after a digit run. Returns "" if no
// suffix is present. Accepts both forms `42i32` and `42_i32`.
read_numeric_suffix :: fn(l: Lexer) -> string {
    start := l.pos
    if l.peek() == '_' && l.peek_at(1).is_ident_start() {
        l.advance(1)
        suff_start := l.pos
        for !l.at_end() && l.peek().is_ident_continue() {
            l.advance(1)
        }
        return l.src.slice(suff_start, l.pos)
    }
    if l.peek().is_ident_start() {
        for !l.at_end() && l.peek().is_ident_continue() {
            l.advance(1)
        }
        return l.src.slice(start, l.pos)
    }
    return ""
}

// Consume a digit run in the given base with `_` separators. Validates that
// underscores don't appear consecutively or trail. `start_anchor` is for
// diagnostic spans. Returns void — callers detecting "no digits after base
// prefix" should compare `l.pos` before and after the call.
consume_digits :: fn(l: Lexer, base: i32, start_anchor: Position) -> void {
    last_was_underscore := false
    first := true
    for !l.at_end() {
        c := l.peek()
        if c == '_' {
            // If the next char starts an identifier and isn't a digit in this
            // base, the underscore belongs to the suffix (`42_i32`, `0xFF_u8`).
            // A second `_` is consumed in-place so `1__0` surfaces as the
            // canonical "underscore not allowed here" error rather than being
            // misclassified as a suffix start.
            next := l.peek_at(1)
            if next != '_' && next.is_ident_start() && !is_digit_in_base(next, base) {
                return
            }
            if first || last_was_underscore {
                l.push_error(.MalformedNumericLiteral, l.error_span(start_anchor), "underscore not allowed here")
            }
            last_was_underscore = true
            first = false
            l.advance(1)
            continue
        }
        if is_digit_in_base(c, base) {
            last_was_underscore = false
            first = false
            l.advance(1)
            continue
        }
        return
    }
}

lex_number :: fn(l: Lexer) -> void {
    start := l.position_here()
    is_float := false

    // Detect base prefix: `0x` / `0X` (hex), `0b` / `0B` (binary),
    // `0o` / `0O` (octal). Anything else is base-10 (including `0` alone or
    // `00.5`). Hex/bin/oct cannot be float and reject suffixed `e`/`E`.
    base: i32 = 10
    if l.peek() == '0' {
        next := l.peek_at(1)
        if next == 'x' || next == 'X' { base = 16 }
        else if next == 'b' || next == 'B' { base = 2 }
        else if next == 'o' || next == 'O' { base = 8 }
    }
    if base != 10 {
        l.advance(2)
        digits_start := l.pos
        l.consume_digits(base, start)
        if l.pos == digits_start {
            l.push_error(.MalformedNumericLiteral, l.error_span(start), "expected digits after base prefix")
        }
    } else {
        l.consume_digits(10, start)

        // `.<digit>` introduces a fractional part. A trailing `.` alone is reserved
        // for member access / range, so we require the next char to be a digit.
        if l.peek() == '.' && l.peek_at(1).is_digit() {
            is_float = true
            l.advance(1)
            l.consume_digits(10, start)
        }

        // Optional exponent.
        if l.peek() == 'e' || l.peek() == 'E' {
            is_float = true
            l.advance(1)
            if l.peek() == '+' || l.peek() == '-' {
                l.advance(1)
            }
            if !l.peek().is_digit() {
                l.push_error(.MalformedNumericLiteral, l.error_span(start), "exponent has no digits")
            }
            l.consume_digits(10, start)
        }
    }

    suffix := l.read_numeric_suffix()
    has_suffix := !suffix.is_empty()

    if has_suffix && !suffix.is_int_suffix() && !suffix.is_float_suffix() {
        l.push_error(.MalformedNumericLiteral, l.error_span(start), "unknown numeric suffix \"${suffix}\"")
    }
    if has_suffix && suffix.is_float_suffix() {
        is_float = true
    }
    if has_suffix && suffix.is_int_suffix() && is_float {
        l.push_error(.MalformedNumericLiteral, l.error_span(start), "integer suffix \"${suffix}\" on a float literal")
    }

    text := l.src.slice(start.offset, l.pos)
    span := Span { .start = start, .end = l.position_here() }
    kind: TokenKind = .IntLit
    if is_float {
        kind = .FloatLit
    }
    t := make_token(kind, text, span)
    if has_suffix {
        t.numeric_suffix = suffix
    }
    if is_float {
        t.value = decode_float_literal(text, suffix)
    } else {
        t.value = decode_int_literal(text, base, suffix)
    }
    l.emit(t)
}

// Strip the lexer-specific decoration off a numeric literal's source slice :
// the optional `0x`/`0b`/`0o` prefix on the left, the suffix (and its
// optional `_` separator) on the right, then the underscores in between.
// Returns digits-only text, ready to be fed to `parse_int_in_base` /
// `parse_float`.
strip_numeric_text :: fn(text: string, base: i32, suffix: string) -> string {
    start: usize = if base == 10 { 0 } else { 2 }
    has_suffix :: !suffix.is_empty()
    end_no_suffix :: text.byte_len() - suffix.byte_len()
    end :: if has_suffix && end_no_suffix > start && text[end_no_suffix - 1] == '_' {
        end_no_suffix - 1
    } else {
        end_no_suffix
    }
    // Fast path: nothing to strip → return the slice without builder churn.
    // `text.contains` is byte-search ; cheap relative to a builder + char loop.
    if start == 0 && end == text.byte_len() && !text.contains("_") {
        return text
    }
    sb := new_builder()
    for i in start..<end {
        c :: text[i]
        if c != '_' { sb.append_char(c) }
    }
    return sb.to_string()
}

// Decode an integer literal's text → `i64`. Defers digit parsing to
// `std/numbers.parse_int_in_base` after stripping prefix/suffix/underscores.
decode_int_literal :: fn(text: string, base: i32, suffix: string) -> i64 {
    parsed :: parse_int_in_base(strip_numeric_text(text, base, suffix), base)
    return match parsed {
        is i64 -> parsed
        is Error -> i64(0)
    }
}

// Decode a float literal's text → `f64`. Underscores and suffix are stripped
// here ; digit parsing defers to `std/string.parse_float`.
decode_float_literal :: fn(text: string, suffix: string) -> f64 {
    parsed :: strip_numeric_text(text, 10, suffix).parse_float()
    return match parsed {
        is f64 -> parsed
        is Error -> 0.0
    }
}

// ---- escape decoding ------------------------------------------------------

// Decode `\X`. Caller must have positioned the cursor at the leading `\`.
// Returns the decoded codepoint. Emits L0004 / L0009 on malformed input.
lex_escape :: fn(l: Lexer) -> u32 {
    esc_start :: l.position_here()
    l.advance(1)  // consume `\`
    if l.at_end() {
        l.push_error(.InvalidEscapeSequence, l.error_span(esc_start), "incomplete escape sequence")
        return u32(0)
    }
    c :: l.peek()
    l.advance(1)
    if c == 'n'  { return u32(0x0A) }
    if c == 't'  { return u32(0x09) }
    if c == 'r'  { return u32(0x0D) }
    if c == '\\' { return u32(0x5C) }
    if c == '\'' { return u32(0x27) }
    if c == '"'  { return u32(0x22) }
    if c == '$'  { return u32(0x24) }
    if c == '0'  { return u32(0x00) }
    if c == 'u'  { return l.lex_unicode_escape(esc_start) }
    l.push_error(.InvalidEscapeSequence, l.error_span(esc_start), "unknown escape \\${c}")
    return u32(c)
}

// Decode `\u{HEX}` — caller has already consumed `\u`. Up to 6 hex digits,
// codepoint must fit in U+10FFFF.
lex_unicode_escape :: fn(l: Lexer, esc_start: Position) -> u32 {
    if l.peek() != '{' {
        l.push_error(.InvalidUnicodeCodepointEscape, l.error_span(esc_start), "expected '{' after \\u")
        return u32(0)
    }
    l.advance(1)  // consume `{`
    hex_start :: l.pos
    for !l.at_end() && l.peek() != '}' {
        if hex_digit_value(l.peek()) < 0 {
            l.push_error(.InvalidUnicodeCodepointEscape, l.error_span(esc_start), "invalid hex digit in codepoint escape")
            // Skip to the closing brace (or EOL) for recovery.
            for !l.at_end() && l.peek() != '}' && l.peek() != '\n' {
                l.advance(1)
            }
            // Fall through to closing-brace consumption below.
            break
        }
        l.advance(1)
    }
    hex_len :: l.pos - hex_start
    if l.peek() == '}' {
        l.advance(1)
    }
    if hex_len == 0 || hex_len > 6 {
        l.push_error(.InvalidUnicodeCodepointEscape, l.error_span(esc_start),
            "codepoint escape must have 1–6 hex digits")
        return u32(0)
    }
    cp: u32 = u32(0)
    for i in 0..<hex_len {
        d :: hex_digit_value(l.src[hex_start + i])
        cp = cp * u32(16) + u32(d)
    }
    if cp > u32(0x10FFFF) {
        l.push_error(.InvalidUnicodeCodepointEscape, l.error_span(esc_start),
            "codepoint exceeds U+10FFFF")
        return u32(0)
    }
    return cp
}

// ---- char literals --------------------------------------------------------

lex_char :: fn(l: Lexer) -> void {
    start :: l.position_here()
    l.advance(1)  // consume opening `'`

    if l.peek() == '\'' {
        l.advance(1)
        l.push_error(.InvalidCharacterLiteral, l.error_span(start), "character literal cannot be empty")
        text :: l.src.slice(start.offset, l.pos)
        t := make_token(.CharLit, text, l.error_span(start))
        t.value = u32(0)
        l.emit(t)
        return
    }

    cp: u32 = u32(0)
    if l.peek() == '\\' {
        cp = l.lex_escape()
    } else if l.peek() == '\n' || l.at_end() {
        l.push_error(.InvalidCharacterLiteral, l.error_span(start), "unterminated character literal")
        text :: l.src.slice(start.offset, l.pos)
        t := make_token(.CharLit, text, l.error_span(start))
        t.value = u32(0)
        l.emit(t)
        return
    } else {
        c :: l.peek()
        cp = u32(c)
        // Advance by the codepoint's UTF-8 byte width so multi-byte literals
        // ('é', '你', …) leave `pos` at the closing quote, not in the middle
        // of a continuation sequence.
        l.advance(codepoint_byte_len(c))
    }

    if l.peek() != '\'' {
        l.push_error(.InvalidCharacterLiteral, l.error_span(start),
            "character literal must contain exactly one codepoint")
        // Recovery: scan to the next `'` or end of line.
        for !l.at_end() && l.peek() != '\'' && l.peek() != '\n' {
            l.advance(1)
        }
        if l.peek() == '\'' {
            l.advance(1)
        }
    } else {
        l.advance(1)  // consume closing `'`
    }

    text :: l.src.slice(start.offset, l.pos)
    t := make_token(.CharLit, text, l.error_span(start))
    t.value = cp
    l.emit(t)
}

// ---- string literals ------------------------------------------------------

// Top of the interp stack, or null when not currently inside an interpolation.
top_interp :: fn(l: Lexer) -> InterpFrame | null {
    n :: l.interp_stack.len()
    if n == 0 { return null }
    return l.interp_stack[n - 1]
}

// Drop the current top frame (called at `}` matching depth 0).
pop_interp :: fn(l: Lexer) -> void {
    n :: l.interp_stack.len()
    if n == 0 { return }
    // `0` because FreeInt repinning doesn't cross the `slice as
    // slice_array` import alias — the literal stays i32 and the VM traps
    // on the i32-vs-usize comparison inside iter.slice's body.
    l.interp_stack = l.interp_stack.slice_array(0, n - 1) // FIXME: use `pop`
}

// Open a `"` / `r"` / `"""` / `r"""` literal. Emits StringBegin, then drives
// the body. Caller must have already verified the leading `"` (and optional
// `r` prefix) via `lex_one`.
lex_string :: fn(l: Lexer, raw: bool) -> void {
    start :: l.position_here()
    if raw {
        l.advance(1)  // consume `r`
    }
    l.advance(1)  // consume opening `"`

    triple := false
    if l.peek() == '"' && l.peek_at(1) == '"' {
        triple = true
        l.advance(2)
        // Triple-quoted strings swallow the optional immediately-following
        // newline so `"""\n  hello"""` doesn't include the leading blank line.
        if l.peek() == '\r' && l.peek_at(1) == '\n' {
            l.advance(2)
        } else if l.peek() == '\n' {
            l.advance(1)
        }
    }

    text :: l.src.slice(start.offset, l.pos)
    span :: Span { .start = start, .end = l.position_here() }
    l.emit(make_token(.StringBegin, text, span))
    l.lex_string_body(triple, raw)
}

// Emit a StringPart token if the builder accumulated any content — no-op
// otherwise so we don't generate empty parts between back-to-back interps.
flush_string_part :: fn(l: Lexer, sb: StringBuilder, part_start: Position, has_part: bool) -> void {
    if !has_part { return }
    text :: sb.to_string()
    span :: Span { .start = part_start, .end = l.position_here() }
    t := make_token(.StringPart, text, span)
    t.value = text
    l.emit(t)
}

// Drive the body of a string literal. Handles raw vs. interpolated input,
// emits StringPart / InterpOpen / StringEnd as needed. When the body opens
// an interpolation we push onto `interp_stack` and return — `lex_one` will
// resume the body when the matching `}` closes the interp.
lex_string_body :: fn(l: Lexer, triple: bool, raw: bool) -> void {
    part_start := l.position_here()
    sb := new_builder()
    has_part := false

    for !l.at_end() {
        c :: l.peek()

        // Closing quote: `"""` for triple, `"` otherwise.
        is_close := false
        if triple {
            if c == '"' && l.peek_at(1) == '"' && l.peek_at(2) == '"' {
                is_close = true
            }
        } else if c == '"' {
            is_close = true
        }
        if is_close {
            flush_string_part(l, sb, part_start, has_part)
            close_start :: l.position_here()
            close_text: string = "\""
            if triple {
                l.advance(3)
                close_text = "\"\"\""
            } else {
                l.advance(1)
            }
            close_span :: Span { .start = close_start, .end = l.position_here() }
            l.emit(make_token(.StringEnd, close_text, close_span))
            return
        }

        // Plain (non-triple) strings forbid raw newlines.
        if !triple && c == '\n' {
            l.push_error(.UnterminatedStringLiteral,
                Span { .start = part_start, .end = l.position_here() }, "")
            flush_string_part(l, sb, part_start, has_part)
            here :: l.position_here()
            l.emit(make_token(.StringEnd, "", Span { .start = here, .end = here }))
            return
        }

        // `${expr}` — interp open, push frame, return so `lex_one` takes over.
        if !raw && c == '$' && l.peek_at(1) == '{' {
            flush_string_part(l, sb, part_start, has_part)
            op_start :: l.position_here()
            l.advance(2)
            op_span :: Span { .start = op_start, .end = l.position_here() }
            l.emit(make_token(.InterpOpen, "\${", op_span))
            l.interp_stack.push(InterpFrame { .brace_depth = 0, .triple = triple })
            return
        }

        // `$ident` — single-identifier interp, no `{}` brackets.
        if !raw && c == '$' && l.peek_at(1).is_ident_start() {
            flush_string_part(l, sb, part_start, has_part)
            op_start :: l.position_here()
            l.advance(1)
            op_span :: Span { .start = op_start, .end = l.position_here() }
            l.emit(make_token(.InterpOpen, "$", op_span))
            l.lex_ident()
            here :: l.position_here()
            l.emit(make_token(.InterpClose, "", Span { .start = here, .end = here }))
            // Resume body in-place ; reset `part_start` so the next StringPart's
            // span starts after the interpolated identifier.
            part_start = l.position_here()
            sb = new_builder()
            has_part = false
            continue
        }

        // Escapes (only outside raw mode).
        if !raw && c == '\\' {
            cp :: l.lex_escape()
            sb.append_char(char(cp))
            has_part = true
            continue
        }

        // Plain content codepoint — advance by its UTF-8 width so the
        // builder gets one codepoint per iteration (not one per byte, which
        // would synthesise FFFD on continuation bytes).
        sb.append_char(c)
        has_part = true
        l.advance(codepoint_byte_len(c))
    }

    // Reached EOF without closing — emit the diagnostic at the current part.
    l.push_error(.UnterminatedStringLiteral,
        Span { .start = part_start, .end = l.position_here() }, "")
    flush_string_part(l, sb, part_start, has_part)
    here :: l.position_here()
    l.emit(make_token(.StringEnd, "", Span { .start = here, .end = here }))
}

// ---- operators ------------------------------------------------------------

// Return true if dispatched. The dispatch order matters: 3-char ops first,
// then 2-char, then 1-char.
try_lex_operator :: fn(l: Lexer) -> bool {
    c := l.peek()
    c2 := l.peek_at(1)

    // Range ops: `..<` and `..=`. Spread: `...`.
    if c == '.' && c2 == '.' {
        c3 := l.peek_at(2)
        if c3 == '<' { return l.emit_and_advance(.RangeExcl, "..<") }
        if c3 == '=' { return l.emit_and_advance(.RangeIncl, "..=") }
        if c3 == '.' { return l.emit_and_advance(.DotDotDot, "...") }
    }

    // Two-char ops.
    if c == '=' && c2 == '=' { return l.emit_and_advance(.Eq, "==") }
    if c == '!' && c2 == '=' { return l.emit_and_advance(.Neq, "!=") }
    if c == '<' && c2 == '=' { return l.emit_and_advance(.Lte, "<=") }
    if c == '>' && c2 == '=' { return l.emit_and_advance(.Gte, ">=") }
    if c == '&' && c2 == '&' { return l.emit_and_advance(.AndAnd, "&&") }
    if c == '|' && c2 == '|' { return l.emit_and_advance(.OrOr, "||") }
    if c == '<' && c2 == '<' { return l.emit_and_advance(.Shl, "<<") }
    if c == '>' && c2 == '>' { return l.emit_and_advance(.Shr, ">>") }
    if c == '-' && c2 == '>' { return l.emit_and_advance(.Arrow, "->") }
    if c == '=' && c2 == '>' { return l.emit_and_advance(.FatArrow, "=>") }
    if c == ':' && c2 == ':' { return l.emit_and_advance(.DeclConst, "::") }
    if c == ':' && c2 == '=' { return l.emit_and_advance(.DeclVar, ":=") }
    if c == '+' && c2 == '=' { return l.emit_and_advance(.PlusAssign, "+=") }
    if c == '-' && c2 == '=' { return l.emit_and_advance(.MinusAssign, "-=") }
    if c == '*' && c2 == '=' { return l.emit_and_advance(.StarAssign, "*=") }
    if c == '/' && c2 == '=' { return l.emit_and_advance(.SlashAssign, "/=") }
    if c == '%' && c2 == '=' { return l.emit_and_advance(.PercentAssign, "%=") }

    // One-char ops.
    if c == '+' { return l.emit_and_advance(.Plus, "+") }
    if c == '-' { return l.emit_and_advance(.Minus, "-") }
    if c == '*' { return l.emit_and_advance(.Star, "*") }
    if c == '/' { return l.emit_and_advance(.Slash, "/") }
    if c == '%' { return l.emit_and_advance(.Percent, "%") }
    if c == '&' { return l.emit_and_advance(.Amp, "&") }
    if c == '|' { return l.emit_and_advance(.Pipe, "|") }
    if c == '^' { return l.emit_and_advance(.Caret, "^") }
    if c == '~' { return l.emit_and_advance(.Tilde, "~") }
    if c == '<' { return l.emit_and_advance(.Lt, "<") }
    if c == '>' { return l.emit_and_advance(.Gt, ">") }
    if c == '!' { return l.emit_and_advance(.Bang, "!") }
    if c == '=' { return l.emit_and_advance(.Assign, "=") }
    if c == '?' { return l.emit_and_advance(.Question, "?") }
    if c == '@' { return l.emit_and_advance(.At, "@") }
    if c == '$' { return l.emit_and_advance(.Dollar, "$") }
    if c == ':' { return l.emit_and_advance(.Colon, ":") }
    if c == ',' { return l.emit_and_advance(.Comma, ",") }
    if c == '.' { return l.emit_and_advance(.Dot, ".") }

    // Brackets — `(` and `[` raise paren_depth, `{` does not (blocks separate
    // statements with newlines).
    if c == '(' {
        start := l.position_here()
        l.advance(1)
        l.paren_depth = l.paren_depth + 1
        l.push_simple(.LParen, "(", start)
        return true
    }
    if c == '[' {
        start := l.position_here()
        l.advance(1)
        l.paren_depth = l.paren_depth + 1
        l.push_simple(.LBracket, "[", start)
        return true
    }
    if c == ')' {
        start := l.position_here()
        l.advance(1)
        if l.paren_depth > 0 { l.paren_depth = l.paren_depth - 1 }
        l.push_simple(.RParen, ")", start)
        return true
    }
    if c == ']' {
        start := l.position_here()
        l.advance(1)
        if l.paren_depth > 0 { l.paren_depth = l.paren_depth - 1 }
        l.push_simple(.RBracket, "]", start)
        return true
    }
    if c == '{' {
        // Track unclosed `{` on the active interp frame so the matching `}`
        // closes the inner expression rather than the interp itself.
        top :: l.top_interp()
        match top {
            is InterpFrame -> { top.brace_depth = top.brace_depth + 1 }
            is null -> { }
        }
        return l.emit_and_advance(.LBrace, "{")
    }
    if c == '}' {
        top :: l.top_interp()
        match top {
            is InterpFrame -> {
                if top.brace_depth > 0 {
                    top.brace_depth = top.brace_depth - 1
                }
            }
            is null -> { }
        }
        return l.emit_and_advance(.RBrace, "}")
    }

    return false
}

// Capture the current position, advance past `text`, push a simple token
// spanning [start, current). Returns `true` so call sites in `try_lex_operator`
// can `return l.emit_and_advance(...)` directly.
emit_and_advance :: fn(l: Lexer, kind: TokenKind, text: string) -> bool {
    start := l.position_here()
    l.advance(text.byte_len())
    l.push_simple(kind, text, start)
    return true
}

// ---- main loop ------------------------------------------------------------

lex_one :: fn(l: Lexer) -> void {
    l.skip_horizontal()
    if l.at_end() { return }

    // Closing `}` for the active `${...}` interpolation. Must run BEFORE
    // `try_lex_operator` would emit a regular `rbrace` token. Inner `{...}`
    // expressions inside the interp are still emitted normally — the brace
    // tracking on the frame disambiguates.
    top :: l.top_interp()
    match top {
        is InterpFrame -> {
            if l.peek() == '}' && top.brace_depth == 0 {
                close_start :: l.position_here()
                l.advance(1)
                l.push_simple(.InterpClose, "}", close_start)
                triple :: top.triple
                l.pop_interp()
                l.lex_string_body(triple, false)
                return
            }
        }
        is null -> { }
    }

    c := l.peek()

    if c == '\n' || c == '\r' {
        l.handle_newline()
        return
    }
    if c == '/' && l.peek_at(1) == '/' {
        // Line comment: skip to (but not past) the newline.
        for !l.at_end() && l.peek() != '\n' {
            l.advance(1)
        }
        return
    }
    if c == '/' && l.peek_at(1) == '*' {
        l.lex_block_comment()
        return
    }
    // Raw strings: `r"..."` — must be checked before `is_ident_start` since
    // `r` is otherwise an identifier start.
    if c == 'r' && l.peek_at(1) == '"' {
        l.lex_string(true)
        return
    }
    if c.is_ident_start() {
        l.lex_ident()
        return
    }
    if c.is_digit() {
        l.lex_number()
        return
    }
    if c == '\'' {
        l.lex_char()
        return
    }
    if c == '"' {
        l.lex_string(false)
        return
    }
    if l.try_lex_operator() {
        return
    }

    // Anything else is an unexpected character — record and skip one byte.
    start := l.position_here()
    l.advance(1)
    l.push_error(.UnexpectedCharacter, l.error_span(start), "")
}

// ---- public entry ---------------------------------------------------------

export tokenize :: fn(source: string, file: string) -> Lexer {
    l := new_lexer(source, file)
    // UTF-8 BOM (EF BB BF) — if present, must be the very first thing.
    if l.src.byte_len() >= 3 &&
        l.src[0] == char(u32(0xEF)) &&
        l.src[1] == char(u32(0xBB)) &&
        l.src[2] == char(u32(0xBF)) {
        l.advance(3)
    }
    // Shebang: only allowed on line 1 and silently dropped.
    if l.line == 1 && l.peek() == '#' && l.peek_at(1) == '!' {
        for !l.at_end() && l.peek() != '\n' {
            l.advance(1)
        }
    }
    for !l.at_end() {
        l.lex_one()
    }
    here := l.position_here()
    eof_span := Span { .start = here, .end = here }
    l.emit(make_token(.Eof, "", eof_span))
    return l
}
