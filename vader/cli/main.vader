import "vader/resolver" { dump_project }
import "vader/typecheck" { check_module_with_bodies, check_project_with_bodies, check_file }
import "vader/typecheck" { CheckResult }
import "vader/typecheck" { TypedProject, new_typed_project }
import "vader/resolver" { load_project, resolve_sidecar }
