// vader/lsp/state ‚Äî open-document tracking.
//
// The client pushes the file content via `didOpen` / `didChange` /
// `didClose` notifications. Semantic tokens read from the doc table ;
// goto-def + hover read from the per-document index built in parallel.

module "vader/lsp/analysis"

import "std/json"
import "std/collections"
import "vader/resolver"
import "vader/typecheck"
import "vader/diagnostics"
import "vader/lsp/protocol"
import "std/io"

/// Cached load+typecheck of one project, keyed by the entry file path it was
/// built for. Reused across typed requests (hover, diagnostics, inlay,
/// signature) within a quiescent edit window ‚Äî `load_project` + the multi-
/// module typecheck re-parse ~30 stdlib modules each, so without this a burst
/// of requests between two edits pays that cost per request. Invalidated on
/// every didOpen / didChange / didClose (any doc change can alter any project
/// the overlay feeds).
export ProjectCache :: struct {
    entry_path: string
    project:    LoadedProject
    result:     CheckResult
    diags:      Diagnostic[]
    /// Module-name ‚Üí `LoadedModule` map (`module_index_by_name`), built once per
    /// cache entry so per-request consumers (wildcard completion) don't rebuild
    /// it. Keyed by the logical `module "..."` name ‚Äî the string an `import`
    /// uses ‚Äî not the resolved filesystem path.
    module_name_index: MutableMap<string, LoadedModule>
}

/// One LSP server instance's document table. The single shared state is
/// passed to every handler ; no globals.
export ServerState :: struct {
    /// uri ‚Üí current document text. Empty string for closed documents.
    docs:                       MutableMap<string, string>
    /// Last load+typecheck, reused across typed requests. `null` after didOpen /
    /// didClose and after `flush_dirty_diagnostics` rebuilds it ; deliberately
    /// KEPT (stale) across a didChange, so the typed requests that arrive
    /// mid-edit-burst don't each re-typecheck the project ‚Äî the burst's single
    /// rebuild happens once it settles. See `typed_project_for` +
    /// `flush_dirty_diagnostics`.
    cache:                      ProjectCache | null
    /// uri ‚Üí per-document goto-def + hover index. Rebuilt on every
    /// didOpen / didChange ; entry is removed (not just emptied) on
    /// didClose so a stale index never serves a closed-doc request.
    indices:                    MutableMap<string, DocIndex>
    /// uri ‚Üí "diagnostics need a (re)publish". Set `true` by `handle_did_change`,
    /// `false` by `handle_did_close` (suppresses a closed doc), drained by
    /// `flush_dirty_diagnostics` once an edit burst settles (see
    /// vader/lsp/main.vader). Decouples the per-keystroke typecheck from the
    /// quiescent-window typecheck ‚Äî the whole point of the debounce.
    dirty:                      MutableMap<string, bool>
    /// Absolute path to the standard-library root (the dir that
    /// contains `std/io/io.vader` etc.). Empty when the host didn't
    /// supply `--stdlib-root` ‚Äî cross-file goto-def on `std/*`
    /// imports degrades to `null` then.
    stdlib_root:                string
    /// Absolute path to the self-host Vader source root (the dir that
    /// contains `lsp/`, `parser/`, `fmt/`, ‚Ä¶). Empty when missing.
    vader_root:                 string
    /// True when the client advertised
    /// `capabilities.textDocument.definition.linkSupport = true` in
    /// `initialize`. Drives the definition response shape ‚Äî `LocationLink[]`
    /// when supported (lets the editor underline the exact origin
    /// range on Ctrl/Cmd-hover), `Location` otherwise.
    definition_link_support:    bool
    /// The `character` counting unit negotiated at `initialize`
    /// (`general.positionEncodings`). Every byte ‚Üî (line, character)
    /// conversion routes through a `LineIndex` built with this. Defaults to
    /// `Utf16` ‚Äî the LSP protocol default when the client offers nothing.
    position_encoding:          PositionEncoding
}

export new_state :: fn(stdlib_root: string, vader_root: string) -> ServerState {
    return ServerState {
        .docs                    = MutableMap<string, string> {},
        .cache                   = null,
        .indices                 = MutableMap<string, DocIndex> {},
        .dirty                   = MutableMap<string, bool> {},
        .stdlib_root             = stdlib_root,
        .vader_root              = vader_root,
        .definition_link_support = false,
        .position_encoding       = .Utf16,
    }
}

/// Look up the current text of `uri`, or `null` if the client never
/// opened it (or closed it since).
export source_for :: fn(self: ServerState, uri: string) -> string | null {
    return self.docs[uri]
}

/// Text of the file at `path`, preferring the open-document overlay (so unsaved
/// edits win) and falling back to reading it from disk. Empty string when the
/// file is neither open nor readable ‚Äî the LineIndex then clamps every offset to
/// 0, degrading gracefully rather than crashing. Used to encode ranges for
/// cross-file results (goto-def / references targets in other modules).
export source_for_path :: fn(self: ServerState, path: string) -> string {
    open :: self.docs[path_to_uri(path)]
    if open is string as s { return s }
    disk :: read_file_string(path)
    if disk is string as s { return s }
    return ""
}

/// A `LineIndex` for the file at `path` in the negotiated encoding, built from
/// the overlay-or-disk source. The single resolution point for encoding a
/// cross-file span's `character` offsets.
export line_index_for_path :: fn(self: ServerState, path: string) -> LineIndex =
    new_line_index(self.source_for_path(path), self.position_encoding)

/// Look up the per-document index for `uri`. Returns `null` when the
/// document was never opened, or after didClose. The two callers
/// (definition + hover) both swallow `null` into a JsonNull response.
export index_for :: fn(self: ServerState, uri: string) -> DocIndex | null {
    return self.indices[uri]
}

/// Load + typecheck the project rooted at `file_path`, reusing the cache when
/// no document changed since (the cache is cleared on every didOpen /
/// didChange / didClose). Module files are read through the in-memory `docs`
/// overlay first, so the result reflects unsaved edits, not the last-saved
/// file. The four typed handlers (hover, diagnostics, inlay, signature) all
/// route through here, so a burst of requests between two edits pays a single
/// load+typecheck.
///
/// @param self       the server state (carries the overlay + the cache).
/// @param file_path  the entry file's filesystem path (from `uri_to_path`).
/// @return           the cached-or-freshly-built project, typecheck result,
///                   and diagnostics.
export typed_project_for :: fn(self: ServerState, file_path: string) -> ProjectCache {
    cached :: self.cache
    if cached != null {
        if cached.entry_path == file_path { return cached }
    }
    // dump_types = false : the LSP reads expr_types (hover/defs) but never the
    // dump-only expr_kinds / node_spans tables.
    fc :: check_file(file_path, doc_overlay(self), [], false)
    entry :: ProjectCache {
        .entry_path = file_path, .project = fc.project, .result = fc.result, .diags = fc.diags,
        .module_name_index = module_index_by_name(fc.project),
    }
    self.cache = entry
    return entry
}

/// Pick the `SourceFile` of `files` whose `path` matches the requested
/// document. A module can span several files (a folder module ‚Äî every
/// `vader/lower/*.vader` shares `module "vader/lower"`), so a per-document
/// request must walk the file the user actually opened, NOT `files[0]`.
/// Walking `files[0]` surfaces another file's AST nodes : hints / hovers /
/// signatures land at that file's positions with that file's types, both
/// wrong (the `dce.vader` inlay hints showing `closure_analysis.vader`'s
/// bindings). Falls back to the sole file for a single-file module (whose
/// path always matches anyway) ; returns null for a multi-file module with
/// no match, so the handler yields nothing rather than another file's data.
export source_file_for_path :: fn(files: SourceFile[], file_path: string) -> SourceFile | null {
    for f in files {
        if f.path == file_path { return f }
    }
    if files.len() == 1 { return files[0] }
    return null
}

/// Build a filesystem-path ‚Üí current-text overlay from every open document,
/// for the resolver to consult before the disk. `docs` is keyed by uri ; the
/// loader reads by path, so convert each key via `uri_to_path`. Closed
/// documents (stored as "") are skipped.
doc_overlay :: fn(self: ServerState) -> MutableMap<string, string> {
    overlay :: MutableMap<string, string> {}
    for [uri, text] in self.docs {
        if text != "" { overlay[uri_to_path(uri)] = text }
    }
    return overlay
}

/// `textDocument/didOpen` handler. Params shape :
///   { textDocument: { uri, languageId, version, text } }
export handle_did_open :: fn(self: ServerState, params: JsonValue) -> void {
    td :: get_field(params, "textDocument")
    uri :: get_string(td, "uri")
    if uri.bytes().len() == 0 { return }
    text :: get_string(td, "text")
    self.docs[uri] = text
    self.indices[uri] = build_index(uri, text, self.position_encoding)
    self.cache = null
    publish_diagnostics_for_uri(self, uri)
}

/// `textDocument/didChange` handler. With full-document sync the params
/// look like :
///   { textDocument: { uri, version }, contentChanges: [ { text } ] }
/// ‚Äî we take the first contentChange's `text` as the new source.
export handle_did_change :: fn(self: ServerState, params: JsonValue) -> void {
    td :: get_field(params, "textDocument")
    uri :: get_string(td, "uri")
    if uri.bytes().len() == 0 { return }
    changes :: get_field(params, "contentChanges")
    match changes {
        is JsonArray as a -> {
            if a.items.len() > 0 {
                first :: a.items[0]
                text :: get_string(first, "text")
                self.docs[uri] = text
                self.indices[uri] = build_index(uri, text, self.position_encoding)
                // Debounced (see vader/lsp/main.vader). Keep the now-stale typed
                // cache so requests during the edit burst don't each re-typecheck ;
                // just mark diagnostics dirty. The single rebuild + publish fires
                // at the burst settle point via `flush_dirty_diagnostics`.
                self.dirty[uri] = true
            }
        }
        _ -> {}
    }
}

/// `textDocument/didClose` handler. MutableMap has no remove ; overwrite
/// with empty and treat empty as "closed" downstream. Push an empty
/// diagnostics array so the client clears any squiggles.
export handle_did_close :: fn(self: ServerState, params: JsonValue) -> void {
    td :: get_field(params, "textDocument")
    uri :: get_string(td, "uri")
    if uri.bytes().len() == 0 { return }
    self.docs[uri] = ""
    self.cache = null
    // Suppress any pending debounced publish for this now-closed doc ‚Äî a later
    // flush must not re-squiggle a file we just cleared. MutableMap has no
    // remove ; `false` is the "don't publish" marker `flush_dirty_diagnostics`
    // skips.
    self.dirty[uri] = false
    // Indices map carries the parsed AST + tokens ‚Äî drop the entry so
    // a stale index never serves a closed-doc request. MutableMap has
    // no remove ; rebuilding an empty index would still pin memory, so
    // we substitute a tiny placeholder built from "".
    self.indices[uri] = build_index(uri, "", self.position_encoding)
    clear_diagnostics_for_uri(self, uri)
}

/// Recompute + publish diagnostics for every document a didChange marked dirty
/// since the last flush, then clear the dirty set. The event loop
/// (vader/lsp/main.vader) calls this once an edit burst settles ‚Äî so the project
/// is type-checked once per quiescent window instead of once per keystroke.
/// Nulls the cache before each publish so diagnostics reflect the current text,
/// not the stale typed project served during the burst. Entries marked `false`
/// (a doc closed mid-burst) are skipped.
export flush_dirty_diagnostics :: fn(self: ServerState) -> void {
    for [uri, needs_publish] in self.dirty {
        if needs_publish {
            self.cache = null
            publish_diagnostics_for_uri(self, uri)
        }
    }
    self.dirty.clear()
}

/// True iff a didChange has left some document's diagnostics pending a publish.
/// Drives the debounce gate in the event loop. Walks the map because closed
/// docs leave `false` markers that don't count as dirty.
export has_dirty :: fn(self: ServerState) -> bool {
    for [_, needs_publish] in self.dirty {
        if needs_publish { return true }
    }
    return false
}

