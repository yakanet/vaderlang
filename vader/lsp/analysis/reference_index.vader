// vader/lsp/analysis/reference_index — project-wide Symbol → reference-spans index.
//
// Shared infrastructure behind find-references (`handlers/references`) and rename
// (`handlers/rename`). Builds a `Symbol → use-spans` index by walking every
// module's AST (via the typed-project cache's per-module resolution) and binding
// each identifier span — both `IdentExpr` use-sites and the *declaration*
// name-spans of locals / params / type-params / for- and pattern-bindings — to
// the Symbol the body-walker recorded for it in `idents`. Top-level declarations
// come from each module's symbol table (`defined_at`). Import bindings are
// followed to their export target (`wire_imports` + `resolve_import_redirect`),
// so a use of an imported name unifies with the declaration and every other use
// across files — the project-wide behaviour find-references and rename require.
//
// Why both decl name-spans AND uses: the body-walker indexes a local's / param's
// name_span into `idents` (body.vader), but those symbols are NOT in
// `resolved.symbols` (top-level only). Collecting just `IdentExpr`s would miss
// every local declaration, so renaming a local would rewrite its uses but not
// its `::` / `:=` binding. Sites are deduped by span hash so a rename never emits
// two edits for one range.
//
// Symbols are globally unique (one factory across modules), so `Symbol.id` is a
// stable cross-module key. v1 scope: identifiers in value + type position +
// local/param/binding decl names. Field/method accesses (`.field`) carry no
// `IdentExpr` (resolved separately) and are a follow-up. The index is rebuilt
// per request; caching it on `ProjectCache` is a follow-up.

module "vader/lsp/analysis"

import "std/collections" { MutableMap }
import "vader/diagnostics" { Span, Position }
import "vader/resolver" { LoadedProject, wire_imports, resolve_import_redirect }
import "vader/resolver/symbol" { Symbol }
import "vader/typecheck" { CheckResult }
AST :: import "vader/parser"

/// One recorded reference : a source span + the (import-resolved) Symbol id it
/// refers to. `is_decl` marks a top-level declaration site (so
/// `includeDeclaration` can exclude it) ; import-binding sites and local/param
/// decl names count as uses here.
export RefSite :: struct {
    span:      Span
    symbol_id: i32
    is_decl:   bool
}

/// Project-wide reference table : a flat list of every recorded use / decl
/// site. Flat (not a map) — a references query does two linear passes (find the
/// symbol under the cursor, then collect its sites), both bounded by project
/// size, which is fine for an on-demand request.
export ReferenceIndex :: struct {
    sites: RefSite[]
}

/// True when the 1-based (line, col) falls inside the half-open span
/// [start, end). Shared by the references `symbol_at` and the rename `site_at`.
export cursor_in_span :: fn(sp: Span, line: i32, col: i32) -> bool {
    if line < sp.start.line { return false }
    if line == sp.start.line && col < sp.start.column { return false }
    if line > sp.end.line { return false }
    if line == sp.end.line && col >= sp.end.column { return false }
    return true
}

// ---- index construction --------------------------------------------------

/// Walk every module's resolution + AST into a flat reference table. Each
/// identifier span (use or local/param decl name) and each top-level
/// `Symbol.defined_at` is keyed by the import-resolved Symbol id so uses unify
/// across files. Deduped by span hash.
///
/// @param project  the loaded project (carries every module's AST + the import
///                 wiring resolved by `wire_imports`).
/// @param result   the typecheck result (carries per-module `resolved`).
/// @return         a flat `ReferenceIndex` ready for `symbol_at` / `site_at`.
export build_reference_index :: fn(project: LoadedProject, result: CheckResult) -> ReferenceIndex {
    table :: wire_imports(project)
    sites: RefSite[] = []
    seen :: MutableMap<u64, bool> {}
    for [id, typed] in result.all_modules {
        mod :: project.modules[id]
        if mod == null { continue }

        // Top-level declaration + import sites from the module's symbol table.
        for sym in typed.resolved.symbols {
            da :: sym.defined_at
            if da == null { continue }
            h :: da.hash()
            if seen[h] != null { continue }
            seen[h] = true
            canon :: resolve_import_redirect(sym, table)
            sites.push(RefSite { .span = da, .symbol_id = canon.id, .is_decl = sym.kind != .ImportBinding })
        }

        // Identifier spans (uses + local/param/binding decl names) the body
        // walker bound to a Symbol in `idents`.
        for f in mod.module.files {
            spans: Span[] = []
            for d in f.program.decls { collect_decl_idents(d, spans) }
            for sp in spans {
                h :: sp.hash()
                if seen[h] != null { continue }
                sym :: typed.resolved.idents[h]
                if sym == null { continue }
                seen[h] = true
                canon :: resolve_import_redirect(sym, table)
                sites.push(RefSite { .span = sp, .symbol_id = canon.id, .is_decl = false })
            }
        }
    }
    return ReferenceIndex { .sites = sites }
}

// ---- identifier-span collectors (mirror ast_tokens.vader coverage) --------
//
// Accumulate every identifier-bearing span : `IdentExpr` use-sites AND the
// name_spans of declarations the body-walker records in `idents` — local lets,
// params, type-params, for-bindings, pattern bindings. Top-level decl names are
// NOT pushed here (they come from `resolved.symbols`).

collect_decl_idents :: fn(d: AST.Decl, out: Span[]) -> void {
    match d {
        is AST.ImportDecl    as x -> { collect_decorators(x.decorators, out) }
        is AST.FnDecl        as x -> { collect_fn(x, out) }
        is AST.StructDecl    as x -> {
            collect_decorators(x.decorators, out)
            collect_type_params(x.type_params, out)
            for fld in x.fields {
                collect_type(fld.ty, out)
                collect_opt_expr(fld.default, out)
            }
        }
        is AST.EnumDecl      as x -> {
            collect_decorators(x.decorators, out)
            collect_opt_type(x.repr, out)
        }
        is AST.TraitDecl     as x -> {
            collect_decorators(x.decorators, out)
            collect_type_params(x.type_params, out)
            collect_opt_type(x.requires, out)
            for m in x.members { collect_fn(m, out) }
        }
        is AST.ImplDecl      as x -> {
            collect_decorators(x.decorators, out)
            collect_type_params(x.type_params, out)
            collect_type(x.for_type, out)
            for ta in x.trait_args { collect_type(ta, out) }
            for m in x.members { collect_fn(m, out) }
        }
        is AST.TypeAliasDecl as x -> {
            collect_decorators(x.decorators, out)
            collect_type_params(x.type_params, out)
            collect_type(x.aliased, out)
        }
        is AST.ConstDecl     as x -> {
            collect_decorators(x.decorators, out)
            collect_opt_type(x.ty, out)
            collect_expr(x.value, out)
        }
        is AST.AssertDecl    as x -> {
            collect_decorators(x.decorators, out)
            collect_expr(x.condition, out)
        }
    }
}

collect_decorators :: fn(ds: AST.Decorator[], out: Span[]) -> void {
    for deco in ds {
        for a in deco.args { collect_expr(a, out) }
    }
}

// Type-param + fn-param DECL names aren't collected : `FnParam.span` /
// `TypeParam.span` cover the whole `name: Type` slot (wide), so they're neither
// a clean rename target nor a precise reference range. Their uses (IdentExpr)
// are still collected. Param / type-param rename is a follow-up needing a
// name-only span.
collect_type_params :: fn(ps: AST.TypeParam[], out: Span[]) -> void {
    for p in ps { collect_opt_type(p.bound, out) }
}

collect_fn :: fn(d: AST.FnDecl, out: Span[]) -> void {
    collect_decorators(d.decorators, out)
    collect_type_params(d.type_params, out)
    for p in d.params {
        collect_opt_type(p.ty, out)
        collect_opt_expr(p.default_value, out)
    }
    collect_opt_type(d.return_type, out)
    collect_opt_block(d.body, out)
}

collect_binding :: fn(b: AST.LetBinding, out: Span[]) -> void {
    match b {
        is AST.SimpleBinding   as x -> { out.push(x.name_span) }
        is AST.TupleBinding    as x -> { for e in x.elements { collect_binding(e, out) } }
        is AST.WildcardBinding -> {}
        is AST.RestBinding     as x -> { out.push(x.span) }
    }
}

collect_stmt :: fn(s: AST.Stmt, out: Span[]) -> void {
    match s {
        is AST.LetStmt      as x -> {
            collect_binding(x.binding, out)
            collect_opt_type(x.ty, out)
            collect_expr(x.value, out)
        }
        is AST.AssignStmt   as x -> {
            collect_expr(x.target, out)
            collect_expr(x.value, out)
        }
        is AST.ExprStmt     as x -> { collect_expr(x.expr, out) }
        is AST.ReturnStmt   as x -> { collect_opt_expr(x.value, out) }
        is AST.ForStmt      as x -> {
            match x.form {
                is AST.InfiniteFor -> {}
                is AST.WhileFor as w -> { collect_expr(w.cond, out) }
                is AST.InFor    as f -> {
                    out.push(f.binding_span)
                    collect_expr(f.iter, out)
                }
            }
            collect_block(x.body, out)
        }
        is AST.BreakStmt    -> {}
        is AST.ContinueStmt -> {}
        is AST.DeferStmt    as x -> {
            match x.body {
                is AST.DeferStmtBody  as b -> { collect_stmt(b.stmt, out) }
                is AST.DeferBlockBody as b -> { collect_block(b.block, out) }
            }
        }
    }
}

collect_block :: fn(b: AST.BlockExpr, out: Span[]) -> void {
    for s in b.stmts { collect_stmt(s, out) }
    collect_opt_expr(b.trailing, out)
}

collect_expr :: fn(e: AST.Expr, out: Span[]) -> void {
    match e {
        is AST.IdentExpr         as x -> { out.push(x.span) }
        is AST.CallExpr          as x -> {
            collect_expr(x.callee, out)
            for a in x.args { collect_expr(a.value, out) }
        }
        is AST.FieldExpr         as x -> { collect_expr(x.target, out) }
        is AST.IndexExpr         as x -> {
            collect_expr(x.target, out)
            collect_expr(x.index, out)
        }
        is AST.UnaryExpr         as x -> { collect_expr(x.operand, out) }
        is AST.BinaryExpr        as x -> {
            collect_expr(x.left, out)
            collect_expr(x.right, out)
        }
        is AST.IfExpr            as x -> {
            collect_expr(x.cond, out)
            collect_block(x.then_block, out)
            match x.else_branch {
                is null                 -> {}
                is AST.IfElseIf    as b -> { collect_expr(b.branch, out) }
                is AST.IfElseBlock as b -> { collect_block(b.block, out) }
            }
        }
        is AST.MatchExpr         as x -> {
            collect_expr(x.scrutinee, out)
            for arm in x.arms {
                collect_pattern(arm.pattern, out)
                collect_opt_expr(arm.guard, out)
                collect_expr(arm.body, out)
            }
        }
        is AST.BlockExpr         as x -> { collect_block(x, out) }
        is AST.LambdaExpr        as x -> {
            for p in x.params {
                collect_opt_type(p.ty, out)
                collect_opt_expr(p.default_value, out)
            }
            collect_opt_type(x.return_type, out)
            collect_block(x.body, out)
        }
        is AST.StructLitExpr     as x -> {
            collect_type(x.type_name, out)
            for it in x.items {
                match it {
                    is AST.StructLitField  as f  -> { collect_expr(f.value, out) }
                    is AST.StructLitSpread as sp -> { collect_expr(sp.expr, out) }
                }
            }
        }
        is AST.SeqLitExpr        as x -> { for it in x.elements { collect_expr(it, out) } }
        is AST.RangeExpr         as x -> {
            collect_expr(x.lower, out)
            collect_expr(x.upper, out)
        }
        is AST.TryExpr           as x -> { collect_expr(x.inner, out) }
        is AST.CastExpr          as x -> {
            collect_expr(x.value, out)
            collect_type(x.target, out)
        }
        is AST.GenericInstExpr   as x -> {
            collect_type(x.callee, out)
            for a in x.type_args { collect_type(a, out) }
        }
        is AST.IntrinsicCallExpr as x -> { for a in x.args { collect_expr(a, out) } }
        is AST.DotVariantExpr    -> {}
        is AST.FnTypeExpr        as x -> {
            for p in x.params { collect_type(p, out) }
            collect_opt_type(x.return_type, out)
        }
        is AST.ArrayTypeExpr     as x -> { collect_type(x.element, out) }
        is AST.IntLitExpr    -> {}
        is AST.FloatLitExpr  -> {}
        is AST.BoolLitExpr   -> {}
        is AST.NullLitExpr   -> {}
        is AST.CharLitExpr   -> {}
        is AST.StringLitExpr -> {}
    }
}

collect_pattern :: fn(p: AST.Pattern, out: Span[]) -> void {
    match p {
        is AST.IsPattern as x -> {
            collect_type(x.ty, out)
            collect_opt_pattern(x.inner, out)
        }
        is AST.StructPattern as x -> {
            for f in x.fields {
                match f.value {
                    is AST.PatternBinding        -> {}
                    is AST.PatternLiteral as lit -> { collect_expr(lit.value, out) }
                }
            }
        }
        is AST.TuplePattern       as x -> { for el in x.elements { collect_pattern(el, out) } }
        is AST.WildcardPattern         -> {}
        is AST.BindingPattern     as x -> { out.push(x.span) }
        is AST.EnumVariantPattern      -> {}
        is AST.LiteralPattern     as x -> { collect_expr(x.value, out) }
    }
}

// Type-position identifiers (`x: Foo`, `Map(K, V)`, `A | B`). The topmost ident
// names a type that the body walker resolves into `idents`, so it's a reference.
collect_type :: fn(e: AST.Expr, out: Span[]) -> void {
    match e {
        is AST.IdentExpr       as x -> { out.push(x.span) }
        is AST.GenericInstExpr as x -> {
            collect_type(x.callee, out)
            for a in x.type_args { collect_type(a, out) }
        }
        is AST.CallExpr        as x -> {
            collect_type(x.callee, out)
            for a in x.args { collect_type(a.value, out) }
        }
        is AST.FieldExpr       as x -> { collect_expr(x.target, out) }
        is AST.BinaryExpr      as x -> {
            collect_type(x.left, out)
            collect_type(x.right, out)
        }
        is AST.FnTypeExpr      as x -> {
            for p in x.params { collect_type(p, out) }
            collect_opt_type(x.return_type, out)
        }
        is AST.ArrayTypeExpr   as x -> { collect_type(x.element, out) }
        _ -> { collect_expr(e, out) }
    }
}

collect_opt_type :: fn(e: AST.Expr | null, out: Span[]) -> void {
    match e {
        is null -> {}
        _       -> { collect_type(e, out) }
    }
}

collect_opt_expr :: fn(e: AST.Expr | null, out: Span[]) -> void {
    match e {
        is null -> {}
        _       -> { collect_expr(e, out) }
    }
}

collect_opt_block :: fn(b: AST.BlockExpr | null, out: Span[]) -> void {
    match b {
        is null -> {}
        _       -> { collect_block(b, out) }
    }
}

collect_opt_pattern :: fn(p: AST.Pattern | null, out: Span[]) -> void {
    match p {
        is null -> {}
        _       -> { collect_pattern(p, out) }
    }
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }

// Count the identifier spans the walker collects from a parsed source — guards
// the walker's coverage (parse-only, no resolution needed).
collect_count :: fn(src: string) -> usize {
    parsed :: AST.parse_source(src, "t.vader")
    out: Span[] = []
    for d in parsed.program.decls { collect_decl_idents(d, out) }
    return out.len()
}

// Count collected spans whose source text equals `name`.
idents_named :: fn(src: string, name: string) -> i32 {
    parsed :: AST.parse_source(src, "t.vader")
    out: Span[] = []
    for d in parsed.program.decls { collect_decl_idents(d, out) }
    sb :: src.bytes()
    count := 0
    for sp in out {
        if sp.start.offset < sp.end.offset && sp.end.offset <= sb.len() {
            if sb[sp.start.offset..<sp.end.offset].bytes_to_string() == name { count = count + 1 }
        }
    }
    return count
}

@test
test_collect_idents_includes_decls_and_uses :: fn() -> void {
    // `total` : the `::` local binding name + 2 uses = 3 (collecting the decl
    // name is what lets rename rewrite a local's declaration, not only its
    // uses). `a` : the param decl span is wide so isn't collected — only its 1
    // use. `println` : 1 callee use.
    src :: "module \"t\"\nsum :: fn(a: i32, b: i32) -> i32 {\n    total :: a + b\n    println(total)\n    return total\n}\n"
    assert(idents_named(src, "total") == 3, "local binding name + two uses of total")
    assert(idents_named(src, "a") == 1, "param uses only (decl span is wide)")
    assert(idents_named(src, "println") == 1, "callee ident collected")
}

@test
test_collect_idents_skips_literals :: fn() -> void {
    // Top-level const : its name comes from resolved.symbols, not the walker ;
    // the body is only literals, so the walker collects nothing.
    src :: "module \"t\"\nc :: 1 + 2\n"
    assert_eq(collect_count(src), usize(0))
}

@test
test_cursor_in_span_half_open :: fn() -> void {
    sp :: Span {
        .start = Position { .file = "t", .offset = usize(0), .line = 3, .column = 5 },
        .end   = Position { .file = "t", .offset = usize(0), .line = 3, .column = 10 },
    }
    assert(cursor_in_span(sp, 3, 5), "start column is inside")
    assert(cursor_in_span(sp, 3, 9), "last column is inside")
    assert(!cursor_in_span(sp, 3, 10), "end column is exclusive")
    assert(!cursor_in_span(sp, 3, 4), "before start is outside")
    assert(!cursor_in_span(sp, 2, 7), "earlier line is outside")
}
