// vader/lsp/cli — `vader lsp` entry point.
//
// Spawned by editors (VSCode `vscode-languageclient`, IntelliJ via
// `intellij-platform-lsp`) ; communicates over stdin/stdout using the
// JSON-RPC framing defined by the Language Server Protocol. MVP scope :
// semantic-tokens highlighting only — initialize / shutdown / didOpen /
// didChange / didClose / textDocument/semanticTokens/full. Hover, go-to-
// definition, completion come later.

module "vader/lsp"


/// Entry point invoked from `vader/cli/main.vader::cmd_lsp`. Delegates
/// to the event-loop in `vader/lsp/main.vader`.
/// @param args  argv tail (everything after `vader lsp`). No flags
///              defined yet ; reserved for `--log <path>`, `--stdio`,
///              `--port N`, etc.
/// @return      OS exit code (0 on clean shutdown, 1 on error).
export run_lsp :: fn(args: string[]) -> i32 {
    return run_server(args)
}
