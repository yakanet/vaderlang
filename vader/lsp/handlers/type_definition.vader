// vader/lsp/handlers/type_definition — `textDocument/typeDefinition` handler.
//
// Where goto-`definition` jumps to a name's *binding*, typeDefinition jumps to
// the declaration of the value's *type*. Cursor over a local, field or call
// result → resolve its inferred `Type` from the typed-project cache, pull the
// declaring `Symbol` off the type (struct / enum / trait / type-param), and
// return that symbol's `defined_at` span as a `Location`.
//
// Reuses the typed cache + the `find_expr_at` expr-finder that powers hover
// (`handlers/hover`, same folder module) and the `location_json` encoder from
// `vader/lsp/protocol`. A `T | null` nullable unwraps to `T`. Types with no
// single declaration to jump to — primitives, tuples/arrays, function types,
// genuine multi-member unions — yield no result. (A named union alias collapses
// to a structural `UnionType` in the type IR, so the alias itself has no symbol
// to target; that's a known limitation, not handled here.)

module "vader/lsp/handlers"

import "std/json" { JsonValue, JsonNull }
import "vader/types" {
    Type, StructType, EnumType, TraitType, TypeParamType, UnionType, PrimitiveType,
    DistinctType, TY_VOID, mk_struct, mk_primitive, mk_union, mk_distinct,
}
import "vader/resolver/symbol" { Symbol }
import "vader/lsp/protocol" { position_uri, uri_to_path, cursor_field, location_json, span_to_range_json, path_to_uri }
import "vader/lsp/analysis" { ServerState, typed_project_for, source_file_for_path, find_expr_at }

/// Resolve typeDefinition for the position carried in `params`. Returns a
/// `Location` (the type's declaration), or `JsonNull` when the cursor isn't on
/// a typed value or the value's type has no declaration to jump to.
export handle_type_definition :: fn(state: ServerState, params: JsonValue) -> JsonValue {
    uri :: position_uri(params)
    if uri == "" { return JsonNull {} }
    file_path :: uri_to_path(uri)
    if file_path == "" { return JsonNull {} }

    cached :: typed_project_for(state, file_path)
    entry :: cached.project.modules[cached.project.entry]
    if entry is null { return JsonNull {} }
    sf :: source_file_for_path(entry.module.files, file_path)
    if sf is null { return JsonNull {} }

    // LSP positions are 0-based ; the Vader AST is 1-based.
    found :: find_expr_at(
        sf.program.decls, cursor_field(params, "line") + 1,
        cursor_field(params, "character") + 1, cached.result.typed,
    )
    if found is null { return JsonNull {} }
    ty :: cached.result.typed.expr_types[found.id]
    if ty is null { return JsonNull {} }

    sym :: type_symbol(ty)
    if sym == null { return JsonNull {} }
    da :: sym.defined_at
    if da == null { return JsonNull {} }
    li :: state.line_index_for_path(da.start.file)
    return location_json(path_to_uri(da.start.file), da.span_to_range_json(li))
}

// The declaring `Symbol` carried by a named type, or null for types with no
// declaration site (primitives, structural composites, fn types). A distinct
// (newtype) jumps to its `Name :: <primitive>` decl, not the backing. TypeParam
// is included so jumping to a generic param's introduction site works too. A
// `T | null`-style union unwraps to its single non-null member — the common
// nullable case — so the cursor still jumps to `T`'s declaration.
type_symbol :: fn(t: Type) -> Symbol | null {
    if t is StructType    as s  { return s.symbol }
    if t is EnumType      as e  { return e.symbol }
    if t is DistinctType  as d  { return d.symbol }
    if t is TraitType     as tr { return tr.symbol }
    if t is TypeParamType as tp { return tp.symbol }
    if t is UnionType     as u  { return union_symbol(u) }
    return null
}

// Resolve the single non-null member of a union to its symbol. `T | null`
// (one non-null member) → `T`'s symbol ; a genuine multi-member sum type has
// no single declaration to jump to → null.
union_symbol :: fn(u: UnionType) -> Symbol | null {
    named: Type[] = []
    for v in u.variants {
        if !is_null_primitive(v) { named.push(v) }
    }
    if named.len() != 1 { return null }
    return type_symbol(named[0])
}

is_null_primitive :: fn(t: Type) -> bool {
    if t is PrimitiveType as p { return p.name == "null" }
    return false
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }

@test
test_type_symbol_extracts_named_type :: fn() -> void {
    sym :: Symbol {
        .id = 1, .kind = .Struct, .name = "Box", .module = "t",
        .visibility = .Private, .defined_at = null,
    }
    no_args: Type[] = []
    extracted :: type_symbol(mk_struct(sym, no_args))
    if extracted == null { assert(false, "struct type must carry a symbol") }
    else { assert_eq(extracted.name, "Box") }
}

@test
test_type_symbol_null_for_primitive :: fn() -> void {
    // Primitives have no declaration to jump to.
    assert(type_symbol(TY_VOID) == null, "primitive yields no type definition")
}

@test
test_type_symbol_unwraps_nullable :: fn() -> void {
    // `User | null` resolves to `User`'s symbol — the common nullable case.
    sym :: Symbol {
        .id = 2, .kind = .Struct, .name = "User", .module = "t",
        .visibility = .Private, .defined_at = null,
    }
    no_args: Type[] = []
    members: Type[] = [mk_struct(sym, no_args), mk_primitive("null")]
    extracted :: type_symbol(mk_union(members))
    if extracted == null { assert(false, "T | null must resolve to T's symbol") }
    else { assert_eq(extracted.name, "User") }
}

@test
test_type_symbol_distinct_jumps_to_newtype :: fn() -> void {
    // Go-to-type-definition on a distinct (`Mass :: i64`) jumps to the newtype
    // decl, not the backing primitive (which has no declaration site).
    sym :: Symbol {
        .id = 3, .kind = .TypeAlias, .name = "Mass", .module = "t",
        .visibility = .Private, .defined_at = null,
    }
    extracted :: type_symbol(mk_distinct(sym, mk_primitive("i64")))
    if extracted == null { assert(false, "distinct type must carry its newtype symbol") }
    else { assert_eq(extracted.name, "Mass") }
}
