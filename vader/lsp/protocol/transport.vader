// vader/lsp/transport — JSON-RPC framing over stdin/stdout.
//
// LSP wraps every JSON message in :
//
//   Content-Length: <bytes>\r\n
//   \r\n
//   {…JSON body…}
//
// Other headers may appear before `\r\n\r\n` (notably `Content-Type`) ;
// we read until the blank line, capture `Content-Length`, then read
// exactly that many bytes for the body. Both directions use the same
// framing.

module "vader/lsp/protocol"

import "std/io" { read_stdin, print, eprintln, poll_stdin, set_stdin_unbuffered, IOError }
import "std/string" { char_at_byte, starts_with, parse_int, ParseError }
import "std/string_builder" { StringBuilder, append }

export TransportError :: struct {
    msg: string
}

TransportError implements Error {
    message :: fn(self) -> string { return self.msg }
}

is_ascii_space :: fn(c: char) -> bool { return c == ' ' || c == '\t' }

/// Read one JSON-RPC frame from stdin. Returns the raw JSON body as a
/// UTF-8 string ; the caller parses it. Blocks until a complete frame
/// arrives. Returns `TransportError` on malformed headers, missing
/// `Content-Length`, or EOF.
/// @return  the JSON body (UTF-8, exactly `Content-Length` bytes).
/// @error   `TransportError` on malformed frame or EOF.
export read_frame :: fn() -> string | TransportError {
    content_length: isize = -1
    // Read header lines until the blank `\r\n`. Each line ends with
    // `\r\n` so we read 1 byte at a time looking for the terminator —
    // header lines are short (typically < 100 bytes) so the per-byte
    // overhead is negligible compared to the body payload.
    line_buf := StringBuilder {}
    finished := false
    for !finished {
        b :: read_stdin(1)
        match b {
            is IOError -> { return TransportError { .msg = "EOF in header" } }
            is string as s -> {
                if s == "\r" {
                    nl :: read_stdin(1)
                    match nl {
                        is IOError -> { return TransportError { .msg = "EOF after CR" } }
                        is string as t -> {
                            if t != "\n" {
                                return TransportError { .msg = "expected LF after CR in header" }
                            }
                            line :: line_buf.to_string()
                            line_bytes :: line.bytes()
                            if line_bytes.len() == 0 {
                                // Blank line = end of headers.
                                finished = true
                            } else {
                                if line.starts_with("Content-Length:") {
                                    raw :: line_bytes[15..<line_bytes.len()].bytes_to_string()
                                    trimmed :: trim_ascii(raw)
                                    parsed :: trimmed.parse_int()
                                    match parsed {
                                        is ParseError -> { return TransportError { .msg = "malformed Content-Length: ${trimmed}" } }
                                        is i32 as n -> { content_length = isize(n) }
                                    }
                                }
                                // Other headers (`Content-Type`, etc.) are
                                // silently ignored — LSP allows them but
                                // doesn't require them.
                                line_buf = StringBuilder {}
                            }
                        }
                    }
                } else {
                    line_buf.append(s)
                }
            }
        }
    }
    if content_length < 0 {
        return TransportError { .msg = "missing Content-Length header" }
    }
    body :: read_stdin(usize(content_length))
    match body {
        is IOError -> { return TransportError { .msg = "EOF in body" } }
        is string as s -> { return s }
    }
}

/// Trim leading + trailing ASCII whitespace (space, tab). Inlined here
/// rather than imported from `std/string` because `std/string.trim`
/// recognises additional codepoints we don't care about for HTTP-style
/// header values.
trim_ascii :: fn(s: string) -> string {
    sb :: s.bytes()
    n :: sb.len()
    start: usize = 0
    end := n
    for start < end {
        if is_ascii_space(s.char_at_byte(start)) { start = start + 1 } else { break }
    }
    for end > start {
        if is_ascii_space(s.char_at_byte(end - 1)) { end = end - 1 } else { break }
    }
    return sb[start..<end].bytes_to_string()
}

/// Make stdin unbuffered — call once at server startup, **before any
/// `read_frame`**, so `poll_pending` reflects the bytes actually queued on the
/// pipe rather than being fooled by `read_stdin`'s readahead buffer. Thin
/// wrapper over the `std/io` intrinsic, kept here so the LSP reaches all stdin
/// plumbing through this one module.
export unbuffer_stdin :: fn() -> void = set_stdin_unbuffered()

/// True iff a frame's first byte is already available within `timeout_ms`
/// (`0` = non-blocking probe). The event loop uses it twice : `poll_pending(0)`
/// to drain a burst of queued frames, and `poll_pending(DEBOUNCE_MS)` to wait
/// out a quiescent edit window before the debounced typecheck. Requires
/// `unbuffer_stdin` first. A `true` only guarantees the first byte is ready —
/// `read_frame` may still block briefly to finish a partially-arrived frame,
/// which is fine (the remainder is already in flight).
/// @param timeout_ms  max wait in milliseconds ; `0` polls without blocking.
/// @return            `true` if `read_frame` won't block on the first byte
///                    (data ready, or peer hangup so the read sees EOF).
export poll_pending :: fn(timeout_ms: i32) -> bool = poll_stdin(timeout_ms)

/// Write one JSON-RPC frame to stdout. Encodes the `Content-Length`
/// header from the body's byte length, emits the `\r\n\r\n` separator,
/// then the body. Flushes via `print` (which calls `fflush(stdout)`).
/// @param body  the JSON-encoded message to send.
export write_frame :: fn(body: string) -> void {
    n :: body.bytes().len()
    sb := StringBuilder {}
    sb.append("Content-Length: ")
    sb.append("${n}")
    sb.append("\r\n\r\n")
    sb.append(body)
    print(sb.to_string())
}
