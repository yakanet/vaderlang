// vader/lower/lower_expr — expression dispatch + leaf-expression lowering.
//
// Central `lower_expr` dispatcher plus the leaf-expression families that
// stay with it: ident / const folding, comptime-value materialization,
// type-meta, union-field narrowing, `if`-expressions, and the op-code
// translation tables. Heavier families live in sibling files of this same
// `vader/lower` module : call dispatch (lower_call), generic calls
// (lower_generic_call), UFCS (lower_ufcs), impl-member resolution
// (lower_impl_member), string/display (lower_string_lit), operators
// (lower_binary), struct/array/tuple literals (lower_struct_lit),
// intrinsics (lower_intrinsic), statements/blocks (lower_stmt), tuple/array
// destructuring (lower_destructure), and assignment/index (lower_assign).

module "vader/lower"

import "std/collections" { MutableMap, values, keys }
import "std/sort" { sort }
import "std/string" { compare_ascending }

import "vader/parser" { Expr, IntLitExpr, FloatLitExpr, BoolLitExpr, NullLitExpr, CharLitExpr, StringLitExpr, IdentExpr, CallExpr, FieldExpr, IndexExpr, UnaryExpr, UnaryOp, BinaryExpr, BinaryOp, IfExpr, BlockExpr, MatchExpr, LambdaExpr, StructLitExpr, SeqLitExpr, RangeExpr, TryExpr, CastExpr, GenericInstExpr, IntrinsicCallExpr, DotVariantExpr, IfElse, IfElseIf, IfElseBlock, FnTypeExpr, ArrayTypeExpr, ExprStmt, Decl, ConstDecl }
import "vader/diagnostics" { Span }
import "vader/typecheck" { primitive_from_name, default_if_free, equals_type, substitute, new_substitution }
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/types" { Type, UnionType, ArrayType, TypeMetaType, TY_BOOL, TY_VOID, TY_UNRESOLVED, mk_primitive, is_primitive_name, StructType }
import "vader/comptime" { ComptimeValue, IntValue, FloatValue, BoolValue, CharValue, StringValue, NullValue, VoidValue, ArrayValue, StructValue, TypeValue }

/// Lower an `AST.Expr` to its `LoweredExpr` form.
/// @param ctx   the fn-body context.
/// @param expr  the source expression.
/// @return      the lowered expression.
export lower_expr :: fn(ctx: FnLowerCtx, expr: Expr) -> LoweredExpr {
    type :: ctx.types.expr_type(expr)
    match expr {
        is IntLitExpr     as e -> { return LoweredIntLit { .span = e.span, .type = default_if_free(type), .value = i64(e.value) } }
        is FloatLitExpr   as e -> { return LoweredFloatLit { .span = e.span, .type = default_if_free(type), .value = e.value } }
        is BoolLitExpr    as e -> { return LoweredBoolLit { .span = e.span, .type = TY_BOOL, .value = e.value } }
        is NullLitExpr    as e -> { return LoweredNullLit { .span = e.span, .type = mk_primitive("null") } }
        is CharLitExpr    as e -> { return LoweredCharLit { .span = e.span, .type = mk_primitive("char"), .value = e.value } }
        is StringLitExpr  as e -> { return lower_string_lit(ctx, e, type) }
        is IdentExpr      as e -> { return lower_ident(ctx, e, type) }
        is CallExpr       as e -> { return lower_call(ctx, e, type) }
        is FieldExpr      as e -> {
            // `Enum.Variant` — the target is the enum's type name in
            // value position. Lower to the variant's integer index
            // (matches `lower_dot_variant`'s context-resolved path).
            enum_variant :: try_lower_enum_field(ctx, e, type)
            if enum_variant != null { return enum_variant }
            // `alias.CONST` — a const reached through a namespace import
            // (`AST.UNASSIGNED_NODE_ID`). The `alias` ident is an ImportBinding,
            // so the FieldExpr never resolves as a value field ; fold it like a
            // bare const reference instead, else the `alias` ident is unresolved
            // and the enclosing expression (a struct literal `.id = AST.UNASSIGNED_
            // NODE_ID`, …) degrades to a drop.
            ns_const :: try_lower_namespace_const(ctx, e, type)
            if ns_const != null { return ns_const }
            // Tuple `t.0` → `_0` : tuple types are backed by an anonymous
            // struct whose slots are named `_0`, `_1`, … — mirror the TS
            // lowerer's `isNumeric` rewrite so the dump shows `._0`.
            field_name :: if e.is_numeric { "_${e.field}" } else { e.field }
            // Union-typed receiver with a common field (every variant
            // carries `f` at the same offset+type) — emit a single cast
            // to the first variant, then a regular field access. The
            // boxed values share `ref` ValType so the cast is free at the
            // bytecode level. Mirror of `lowerUnionFieldAccess`'s
            // `sameOffsetShortcutApplies` short-circuit in
            // `src/lower/passes/expr.ts:1072-1080`.
            target_type :: ctx.types.expr_type(e.target)
            shortcut :: try_lower_common_union_field(ctx, e, type, target_type, field_name)
            match shortcut {
                is null -> {}
                _ -> { return shortcut }
            }
            lowered_target :: lower_expr(ctx, e.target)
            // Comptime fold : `<LoweredStructLit>.field` resolves to
            // the field's value when the struct lit was synthesised
            // at lower time (typically via @comptime for substitution
            // of `f` to a `Field { name, type }` literal). Mirror of
            // TS's `LoweredFieldAccess` shortcut in
            // `src/lower/passes/expr.ts:445-455`.
            //
            // Skip the fold when the target is a *comptime const* baked
            // to a compound struct/array : TS defers that struct-lit
            // substitution to its `inlineConsts` pass, so the fold guard
            // never sees it and `DIM.0` keeps a real `LoweredFieldAccess`
            // over the re-materialised tuple lit (`._0 :i32`). Only
            // `@comptime`-substituted loop-var lits fold.
            if lowered_target is LoweredStructLit as sl {
                if !field_target_is_comptime_const(ctx, e.target) {
                    for f in sl.fields {
                        if f.name == field_name { return f.value }
                    }
                }
            }
            return LoweredFieldAccess {
                .span = e.span, .type = type,
                .target = lowered_target, .field = field_name,
            }
        }
        is IndexExpr      as e -> { return lower_index(ctx, e, type) }
        is UnaryExpr      as e -> {
            return LoweredUnary {
                .span = e.span, .type = type,
                .op = lower_unary_op(e.op),
                .operand = lower_expr(ctx, e.operand),
            }
        }
        is BinaryExpr     as e -> { return lower_binary(ctx, e, type) }
        is IfExpr         as e -> { return lower_if(ctx, e, type) }
        is BlockExpr      as e -> { return lower_block(ctx, e, false, false) }
        is StructLitExpr  as e -> { return lower_struct_lit(ctx, e, type) }
        is SeqLitExpr     as e -> { return lower_seq_lit(ctx, e, type) }
        is CastExpr       as e -> {
            return LoweredCast { .span = e.span, .type = type, .value = lower_expr(ctx, e.value) }
        }
        is IntrinsicCallExpr as e -> { return lower_intrinsic(ctx, e, type) }
        // Match / try / lambda / range / for-in are deferred to phases
        // 4 / 5. Until then, emit an unreachable so the dump shape is
        // consistent and downstream phases can spot the gap.
        is MatchExpr     as e -> { return lower_match(ctx, e, type, lower_expr) }
        is TryExpr       as e -> { return lower_try(ctx, e, type, lower_expr) }
        is LambdaExpr    as e -> { return lower_lambda(ctx, e, lower_block) }
        is RangeExpr     as e -> { return lower_range_expr(ctx, e, type, lower_expr) }
        is GenericInstExpr  as e -> { return stub(e.span, type, "generic-inst expression not lowered") }
        is DotVariantExpr   as e -> { return lower_dot_variant(ctx, e, type) }
        // Type-position expressions in value position — earlier phases
        // emit T3035 ; the lowerer just emits a stub.
        is FnTypeExpr    as e -> { return stub(e.span, type, "type-valued slot not lowered") }
        is ArrayTypeExpr as e -> { return stub(e.span, type, "type-valued slot not lowered") }
    }
}

stub :: fn(span: Span, type: Type, reason: string) -> LoweredExpr {
    return LoweredUnreachable { .span = span, .type = type, .reason = reason }
}

// ============================================================================
// Per-kind expression lowerers
// ============================================================================

lower_ident :: fn(ctx: FnLowerCtx, ident: IdentExpr, type: Type) -> LoweredExpr {
    symbol :: ctx.typed.resolved.idents[ident.span.hash()]
    match symbol {
        is null -> { return stub(ident.span, type, "unresolved ident ${ident.name}") }
        is Symbol as resolved -> {
            // `@comptime for x in arr { ... }` substitution : every
            // reference to the loop var inside the unrolled body
            // resolves to the per-iter literal. Checked before the
            // regular paths so the binding "wins" over any captured-
            // cell / lifted-env handling for the same symbol.
            // Mirror of `lowerIdent`'s `comptimeBindings` check in
            // `src/lower/passes/expr.ts:542-543`.
            // Size short-circuit : `comptime_bindings` is empty for
            // every fn that doesn't use `@comptime for`, so skip the
            // hash probe in the 99% case. Per-ident hot path.
            if ctx.comptime_bindings.size > 0 {
                comptime_val :: ctx.comptime_bindings[resolved.id]
                if !(comptime_val is null) { return comptime_val }
            }
            // TypeMeta-typed ident in value position — reify the
            // underlying Type so the bytecode emit can lower it to
            // `type.const N`. Mirror of `lowerIdent`'s TypeMeta branch in
            // `src/lower/passes/expr.ts:533-538`.
            if type is TypeMetaType {
                meta :: resolve_type_meta_symbol(ctx, resolved)
                if !(meta is null) {
                    return LoweredTypeConst {
                        .span = ident.span, .type = type, .value = arg_ty_or_unresolved(meta),
                    }
                }
            }
            // When we're lowering inside a lifted lambda body, captured
            // outer symbols don't have a local slot — read them off the
            // env-struct param via `env.cap_N`.
            via_env :: try_route_through_env(ctx, resolved, ident.span, type)
            if via_env != null { return via_env }
            // Local captured by an inner lambda : the slot stores a cell
            // ref, the value lives behind a `LoweredCellGet`. Mirror of
            // `lowerIdent`'s captured-symbol path in `expr.ts:559-561`.
            if ctx.project.closures.captured_symbols.contains(resolved.id) {
                cell_ref :: LoweredIdent {
                    .span = ident.span, .type = type, .symbol = resolved,
                }
                return LoweredCellGet {
                    .span = ident.span, .type = type,
                    .target = cell_ref, .value_type = type,
                }
            }
            // Scalar const inlining : when a `const` decl carries a
            // comptime-baked scalar (int / float / bool / char / string /
            // null), substitute its value at every use site. Mirror of
            // the TS `inlineConsts` pass's scalar bucket. Compound values
            // (arrays, structs) are deferred — they'd need data-pool /
            // fn-wrap routing for byte-parity. Also covers param /
            // import-binding symbols when the resolver chained the
            // ident to the original const symbol via aliasing.
            folded :: fold_const_symbol(ctx, resolved, type, ident.span)
            if folded != null { return folded }
            // Match-arm narrowing : the slot stores the declared union
            // (e.g. `Error | string`), the typed-AST narrows this use to a
            // concrete variant (e.g. `string`) — emit a `LoweredCast` so the
            // dump and the runtime unbox via the variant layout instead of
            // the union slot. Mirror of `lowerIdent` in `expr.ts:563-573`.
            declared :: declared_type_of_symbol(ctx, resolved)
            if declared is UnionType {
                if !equals_type(declared, type) {
                    return LoweredCast {
                        .span = ident.span, .type = type,
                        .value = LoweredIdent {
                            .span = ident.span, .type = declared, .symbol = resolved,
                        },
                    }
                }
            }
            // Named import-binding redirect : `import "p" { foo as bar }`
            // means every `bar` reference dumps with the target's
            // identity. Mirror of TS's `resolveImportRedirect` (
            // `src/resolver/resolve.ts:809-815`) applied at idents.set time.
            final_sym :: follow_import_binding(ctx, resolved)
            // A fn used as a VALUE (passed as a `fn(...)` arg, stored, etc.)
            // lowers to a `FnRef`. If it's a non-generic stdlib free fn,
            // harvest it so `materialize_nongeneric_stdlib_fns` emits its body —
            // otherwise the FnRef emit can't resolve the symbol and silently
            // drops it. Mirror of the direct-call harvest in `lower_call`.
            // Self-guards : no-op unless `final_sym` is a non-generic stdlib Fn.
            register_nongeneric_stdlib_fn(ctx, final_sym)
            return LoweredIdent { .span = ident.span, .type = type, .symbol = final_sym }
        }
    }
}

// `CellInit` and the cell-init wrapper now live in `vader/lower/helpers.vader`
// (single source of truth — same module, same shape). Callers below
// reach for `lower_cell_init` directly.

// True when `target` is a bare ident resolving to a `@comptime` const
// whose baked value is a compound struct / array. Such references keep
// a real field access at the use site (the tuple lit rides as the
// access target) rather than folding to the projected element — mirror
// of TS deferring const substitution to `inlineConsts`.
field_target_is_comptime_const :: fn(ctx: FnLowerCtx, target: Expr) -> bool {
    if target is IdentExpr as id {
        symbol :: ctx.typed.resolved.idents[id.span.hash()]
        if symbol is Symbol as resolved {
            baked :: lookup_const_baked_value(ctx, resolved)
            return baked is StructValue || baked is ArrayValue
        }
    }
    return false
}

lookup_const_baked_value :: fn(ctx: FnLowerCtx, symbol: Symbol) -> ComptimeValue | null {
    // The const symbol may live in this module or in an imported one.
    // `comptime_value_by_symbol_id` was flattened at lower-project entry
    // so this lookup is O(1) instead of walking every loaded module's
    // `comptime_decls` map per call (this fn fires on every IdentExpr).
    return ctx.project.comptime_value_by_symbol_id[symbol.id]
}

// Fold a reference to an UNBAKED module-level const to its value. The
// comptime const-bake runs entry-only (`populate_comptime_value_index` reads
// `evaluated.modules[*].comptime_decls`), so a const declared in an IMPORTED
// module — e.g. `MANIFEST_FILENAME :: "vader.json"` referenced from its own
// module's `find_manifest_root` — never lands in `comptime_value_by_symbol_id`.
// The scalar-const fold in `lower_ident` then misses and the bare const ident
// reaches `midir/build.vader::build_ident`, which has no const case → it emits
// `unreachable`, truncating the function. Recover by lowering the const decl's
// value directly via `lower_const_value` (whose own bake-miss path lowers the
// RHS), keyed off the const's OWNING module so cross-module refs work too.
// Caller gates on `resolved.kind == Const` (the hot-path read of every
// local / param shouldn't pay the module lookups below). Returns null when the
// decl can't be located or its RHS isn't foldable (caller keeps its path).
try_fold_unbaked_const :: fn(ctx: FnLowerCtx, resolved: Symbol, type: Type) -> LoweredExpr | null {
    owner_loaded :: ctx.project.loaded.modules[resolved.module]
    if owner_loaded is null { return null }
    owner_typed :: ctx.project.evaluated.typed.modules[resolved.module]
    if owner_typed is null { return null }
    const_decl :: find_const_decl_by_name(module_decls(owner_loaded), resolved.name)
    if const_decl is null { return null }
    // Only fold a LITERAL-RHS const. A computed RHS (`B + 1`) may depend on
    // other unbaked consts, so folding it here would (a) bypass comptime
    // cycle detection — a `@comptime A :: B + 1 ; B :: A + 1` must still
    // surface C4009 — and (b) risk recursion through this same path. Those
    // consts keep their existing route ; the comptime evaluator owns their
    // value and diagnostics. A literal RHS has neither hazard and matches the
    // scalar-only shape of the baked-value fold above.
    if !is_scalar_literal_expr(const_decl.value) { return null }
    entry :: stub_entry(const_decl, owner_typed)
    fn_ctx :: new_fn_lower_ctx(ctx.project, entry, owner_typed, new_substitution(), type, null)
    return lower_const_value(const_decl, owner_typed, ctx.project, fn_ctx, type)
}

find_const_decl_by_name :: fn(decls: Decl[], name: string) -> ConstDecl | null {
    for d in decls {
        if d is ConstDecl as cd {
            if cd.name == name { return cd }
        }
    }
    return null
}

// True when `e` is a scalar literal (int / float / bool / null / char /
// string). Gates `try_fold_unbaked_const` to RHS shapes that fold without
// touching other consts. Shape predicate (`_ -> false`), mirroring
// `fmt/printer.vader::is_bitor_chain` — a non-literal Expr is correctly false.
// @partial: only the literal-shaped Expr forms are scalar literals; every other Expr is not.
is_scalar_literal_expr :: fn(e: Expr) -> bool = @partial match e {
    is IntLitExpr    -> true
    is FloatLitExpr  -> true
    is BoolLitExpr   -> true
    is NullLitExpr   -> true
    is CharLitExpr   -> true
    is StringLitExpr -> true
    // `usize(0)` / `i32(N)` — a primitive numeric conversion of a scalar
    // literal parses as a CallExpr. It folds just as safely (the arg is a
    // literal, so no dependency on another unbaked const), so a const like
    // `UNASSIGNED_NODE_ID :: usize(0)` resolves at its use sites in imported
    // bodies instead of degrading to an unresolved ident.
    is CallExpr as c -> is_numeric_conversion_of_literal(c)
    _                -> false
}

is_numeric_conversion_of_literal :: fn(c: CallExpr) -> bool {
    if !(c.callee is IdentExpr) { return false }
    if !is_primitive_name(c.callee.name) { return false }
    if c.args.len() != 1 { return false }
    return is_scalar_literal_expr(c.args[0].value)
}

/// Materialise a `ComptimeValue` as a `LoweredExpr` literal. Compound
/// values (arrays, structs) recurse field-by-field. Mirror of
/// `comptimeValueToLowered` in `src/lower/lower.ts:245-275`.
export comptime_value_to_lowered :: fn(v: ComptimeValue, type_hint: Type, span: Span) -> LoweredExpr {
    match v {
        is IntValue    as iv -> { return LoweredIntLit { .span = span, .type = type_hint, .value = iv.value } }
        is FloatValue  as fv -> { return LoweredFloatLit { .span = span, .type = type_hint, .value = fv.value } }
        is BoolValue   as bv -> { return LoweredBoolLit { .span = span, .type = TY_BOOL, .value = bv.value } }
        is CharValue   as cv -> { return LoweredCharLit { .span = span, .type = mk_primitive("char"), .value = cv.value } }
        is StringValue as sv -> { return LoweredStringLit { .span = span, .type = mk_primitive("string"), .value = sv.value } }
        is NullValue         -> { return LoweredNullLit { .span = span, .type = mk_primitive("null") } }
        is VoidValue         -> { return LoweredUnreachable { .span = span, .type = type_hint, .reason = "comptime void value" } }
        is ArrayValue as av -> {
            element_type :: array_element_type(type_hint)
            elements: LoweredExpr[] = []
            for e in av.elements { elements.push(comptime_value_to_lowered(e, element_type, span)) }
            return LoweredArrayLit { .span = span, .type = type_hint, .elements = elements }
        }
        is StructValue as sv -> {
            // `sv.fields.keys()` iterates in MutableMap hash-bucket
            // order, which doesn't match the field declaration order
            // tuples / structs rely on for dump parity. Sort the
            // names alphabetically — for tuples (`_0`, `_1`, `_2`)
            // that matches the positional order ; for named structs
            // the same ordering is what TS' dump uses.
            sorted_names :: sort(sv.fields.keys(), (a: string, b: string) -> compare_ascending(a, b))
            fields: LoweredStructLitField[] = []
            for name in sorted_names {
                val :: sv.fields[name]
                match val {
                    is null -> {}
                    _ -> {
                        fields.push(LoweredStructLitField {
                            .name = name,
                            .value = comptime_value_to_lowered(val, TY_UNRESOLVED, span),
                        })
                    }
                }
            }
            return LoweredStructLit { .span = span, .type = type_hint, .fields = fields }
        }
        is TypeValue -> { return LoweredUnreachable { .span = span, .type = type_hint, .reason = "comptime type-value lowering deferred" } }
    }
}

// Element type of an array, or `unresolved` when `t` isn't a concrete array
// (an un-hinted comptime array literal hits this with a `?` hint — the
// elements then resolve from their own values). Single-case `if`, not a
// `match` with a `_ ->` degraded arm.
array_element_type :: fn(t: Type) -> Type {
    if t is ArrayType as at { return at.element }
    return TY_UNRESOLVED
}

is_scalar_comptime :: fn(v: ComptimeValue) -> bool {
    match v {
        is IntValue    -> { return true }
        is FloatValue  -> { return true }
        is BoolValue   -> { return true }
        is CharValue   -> { return true }
        is StringValue -> { return true }
        is NullValue   -> { return true }
        // Small tuple / struct values inline at use sites — TS'
        // `inlineConsts` pass keeps these as `LoweredStructLit` /
        // `LoweredArrayLit` at every reference. Vader doesn't have a
        // size gate yet (TS' data-pool / fn-wrap split kicks in at
        // ≥ 4 elements) ; small tuple consts are the dominant pattern
        // that hits this path so blind inlining matches the snapshot
        // shape. Revisit when data-pool / fn-wrap lands.
        is StructValue -> { return true }
        is ArrayValue  -> { return true }
        _              -> { return false }
    }
}

/// Reify a TypeMeta-typed symbol's underlying Type. Mirror of
/// `resolveTypeMetaSymbol` in `src/lower/passes/expr.ts:646-657`.
/// Sources: `@comptime const X :: Type` aliases land in
/// `resolved.alias_types`; primitive builtins reconstruct from their
/// name. Returns null for shapes we can't reify yet (e.g. type-params).
resolve_type_meta_symbol :: fn(ctx: FnLowerCtx, symbol: Symbol) -> Type | null {
    aliased :: ctx.typed.resolved.alias_types[symbol.id]
    if !(aliased is null) { return aliased }
    if i32(symbol.kind) == i32(SymbolKind.BuiltinType) {
        return primitive_from_name(symbol.name)
    }
    return null
}

declared_type_of_symbol :: fn(ctx: FnLowerCtx, symbol: Symbol) -> Type | null {
    // Most idents (Fn, Const, ImportBinding, …) can't be narrowed —
    // bail before paying the `span_key` allocation on the hot path.
    match symbol.kind {
        .Param   -> {}
        .Local   -> {}
        .Binding -> {}
        _        -> { return null }
    }
    defined_at :: symbol.defined_at
    if defined_at is null { return null }
    key :: defined_at.hash()
    // Apply the entry substitution so the narrowing comparison sees the
    // erased declared type (`Any | null`), matching the erased read-site
    // type — otherwise an unerased `T | null` declared type spuriously
    // differs from the read type and injects a redundant cast in
    // generic-impl default-method bodies.
    raw :: if i32(symbol.kind) == i32(SymbolKind.Param) {
        ctx.typed.param_types[key]
    } else {
        ctx.typed.local_types[key]
    }
    if raw is null { return null }
    return ctx.types.apply(raw)
}

try_lower_common_union_field :: fn(
    ctx: FnLowerCtx, expr: FieldExpr, expr_type: Type, target_type: Type, field_name: string,
) -> LoweredExpr | null {
    if !(target_type is UnionType) { return null }
    match target_type {
        is UnionType as u -> {
            if u.variants.len() == 0 { return null }
            first_variant :: u.variants[0]
            if !(first_variant is StructType) { return null }
            // Every variant must be a struct exposing the same field
            // name with the same resolved type. Bail out otherwise — the
            // general per-variant cascade isn't ported yet.
            for v in u.variants {
                if !(v is StructType) { return null }
            }
            cast_target :: LoweredCast {
                .span = expr.span, .type = first_variant,
                .value = lower_expr(ctx, expr.target),
            }
            return LoweredFieldAccess {
                .span = expr.span, .type = expr_type,
                .target = cast_target, .field = field_name,
            }
        }
        _ -> { return null }
    }
}

try_route_through_env :: fn(
    ctx: FnLowerCtx, symbol: Symbol, span: Span, type: Type,
) -> LoweredExpr | null {
    lifted :: ctx.lifted_context
    if lifted is null { return null }
    field_name :: lifted.capture_fields[symbol.id]
    match field_name {
        is null -> { return null }
        is string as name -> {
            env_ident :: LoweredIdent {
                .span = span, .type = lifted.env_type, .symbol = lifted.env_symbol,
            }
            // The env slot stores a `Cell<T>` ref, not a `T` ; type the
            // field access as `Unresolved` (≡ ref ValType) so downstream
            // bytecode emit doesn't synthesise a primitive-typed
            // `ref.cast` over what is in fact an opaque cell pointer.
            cell_ref :: LoweredFieldAccess {
                .span = span, .type = TY_UNRESOLVED, .target = env_ident, .field = name,
            }
            // The env-struct slot holds a cell ref ; unwrap via
            // `LoweredCellGet` to materialise the value. Mirror of
            // `lowerIdent`'s lifted-context branch in `expr.ts:550-555`.
            return LoweredCellGet {
                .span = span, .type = type,
                .target = cell_ref, .value_type = type,
            }
        }
    }
}

lower_if :: fn(ctx: FnLowerCtx, if_expr: IfExpr, type: Type) -> LoweredExpr {
    cond :: lower_expr(ctx, if_expr.cond)
    then_block :: lower_then_with_binding(ctx, if_expr)
    else_block :: lower_if_else(ctx, if_expr.else_branch)
    // Else-less `if` : the body's value is unobservable (the typechecker
    // widens to `T | void`, but `void` has no representation), so force
    // the if to `void` and convert the then-block's trailing expression
    // into an `ExprStmt`. Mirror of `lowerIf`'s else-null branch in
    // `src/lower/passes/expr.ts:1005-1010`.
    if else_block is null {
        then_void :: voidify_block(then_block)
        return LoweredIf {
            .span = if_expr.span, .type = TY_VOID,
            .cond = cond, .then_block = then_void, .else_block = null,
        }
    }
    return LoweredIf {
        .span = if_expr.span, .type = type,
        .cond = cond, .then_block = then_block, .else_block = else_block,
    }
}

voidify_block :: fn(block: LoweredBlock) -> LoweredBlock {
    return LoweredBlock {
        .span = block.span, .type = TY_VOID,
        .stmts = block_stmts_with_trailing(block), .trailing = null,
    }
}

/// Prepend a `let <bind_as> = cast → T (scrut)` when the if-condition is
/// `<scrut> is T as <bind_as>`. The binding only lives inside the
/// then-block ; the lowering site materialises its slot once and every
/// downstream read sees the narrowed type. Mirror of `lowerThenWithBinding`
/// in `src/lower/passes/expr.ts:1020-1044`.
lower_then_with_binding :: fn(ctx: FnLowerCtx, if_expr: IfExpr) -> LoweredBlock {
    block :: lower_block(ctx, if_expr.then_block, false, false)
    cond :: if_expr.cond
    if !(cond is BinaryExpr) { return block }
    if cond is BinaryExpr as bin {
        if i32(bin.op) != i32(BinaryOp.Is) { return block }
        if bin.bind_as == "" { return block }
        scrut_type :: ctx.types.expr_type(bin.left)
        inner_type :: resolve_pattern_type(ctx, bin.right)
        scrut_value :: lower_expr(ctx, bin.left)
        cast_value: LoweredExpr = if scrut_type is UnionType {
            LoweredCast { .span = bin.span, .type = inner_type, .value = scrut_value }
        } else {
            scrut_value
        }
        // Reuse the binding symbol the resolver minted for `as a` (keyed by
        // the type expr's span, matching `walk_if`'s `if_bind_as_span` =
        // `cond.right.span`), so references to `a` inside the then-block —
        // which `resolved.idents` wires to THAT symbol — resolve to this
        // slot. A `fresh_synthetic_symbol` here mints a different id, leaving
        // every `a` reference unresolved (build_ident → unreachable). Mirror
        // of `lower_match`'s `resolve_pattern_symbol` on its `is T as a` arm.
        symbol :: resolve_pattern_symbol(ctx, bin.right.span, bin.bind_as)
        let_stmt: LoweredStmt = LoweredLet {
            .span = bin.span, .name = bin.bind_as, .symbol = symbol,
            .type = inner_type, .value = cast_value,
        }
        new_stmts: LoweredStmt[] = []
        new_stmts.push(let_stmt)
        for s in block.stmts { new_stmts.push(s) }
        return LoweredBlock {
            .span = block.span, .type = block.type,
            .stmts = new_stmts, .trailing = block.trailing,
        }
    }
    return block
}

lower_if_else :: fn(ctx: FnLowerCtx, branch: IfElse | null) -> LoweredBlock | null {
    match branch {
        is null -> { return null }
        is IfElseIf as if_else_if -> {
            chained :: lower_if(ctx, if_else_if.branch, ctx.types.expr_type(if_else_if.branch))
            return LoweredBlock {
                .span = if_else_if.branch.span, .type = type_of(chained),
                .stmts = [], .trailing = chained,
            }
        }
        is IfElseBlock as if_else_block -> { return lower_block(ctx, if_else_block.block, false, false) }
    }
}

lower_unary_op :: fn(op: UnaryOp) -> LoweredUnaryOp = match op {
    .Neg    -> LoweredUnaryOp.Neg
    .Not    -> LoweredUnaryOp.Not
    .BitNot -> LoweredUnaryOp.BitNot
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_lower_unary_op_table :: fn() -> void {
    assert_eq(i32(lower_unary_op(UnaryOp.Neg)),    i32(LoweredUnaryOp.Neg))
    assert_eq(i32(lower_unary_op(UnaryOp.Not)),    i32(LoweredUnaryOp.Not))
    assert_eq(i32(lower_unary_op(UnaryOp.BitNot)), i32(LoweredUnaryOp.BitNot))
}

@test test_lower_binary_op_basic_arithmetic :: fn() -> void {
    assert_eq(i32(lower_binary_op(BinaryOp.Add)), i32(LoweredBinaryOp.Add))
    assert_eq(i32(lower_binary_op(BinaryOp.Eq)),  i32(LoweredBinaryOp.Eq))
    // `Is` is routed through the dedicated lowerer ; the table maps it
    // to `Eq` to keep the match exhaustive without firing.
    assert_eq(i32(lower_binary_op(BinaryOp.Is)),  i32(LoweredBinaryOp.Eq))
}

lower_binary_op :: fn(op: BinaryOp) -> LoweredBinaryOp = match op {
    .Add    -> LoweredBinaryOp.Add
    .Sub    -> LoweredBinaryOp.Sub
    .Mul    -> LoweredBinaryOp.Mul
    .Div    -> LoweredBinaryOp.Div
    .Mod    -> LoweredBinaryOp.Mod
    .Shl    -> LoweredBinaryOp.Shl
    .Shr    -> LoweredBinaryOp.Shr
    .BitAnd -> LoweredBinaryOp.BitAnd
    .BitOr  -> LoweredBinaryOp.BitOr
    .BitXor -> LoweredBinaryOp.BitXor
    .And    -> LoweredBinaryOp.And
    .Or     -> LoweredBinaryOp.Or
    .Eq     -> LoweredBinaryOp.Eq
    .Neq    -> LoweredBinaryOp.Neq
    .Lt     -> LoweredBinaryOp.Lt
    .Lte    -> LoweredBinaryOp.Lte
    .Gt     -> LoweredBinaryOp.Gt
    .Gte    -> LoweredBinaryOp.Gte
    // Is / In / NotIn are routed through dedicated lowerers above ;
    // mapping them to `Eq` keeps `match` exhaustive without firing.
    .Is     -> LoweredBinaryOp.Eq
    .In     -> LoweredBinaryOp.Eq
    .NotIn  -> LoweredBinaryOp.Eq
}
