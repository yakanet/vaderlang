// vader/lower/lower_expr — expression + block + statement lowerer.
//
// Mirror of `src/lower/passes/expr.ts` + `block.ts`. Vader's module
// system rejects the TS-style mutual import between an "expr" and a
// "block" file (block contains stmts contains exprs contains blocks),
// so the two layers live together here.
//
// Phase 3 scope : literals, ident, binop / unop, field, index, cast,
// if-expr, block, struct lit, array lit, intrinsic call, plain string
// lit, let / assign / return / expr-stmt / break / continue, plus
// `while`-style for loops. Match / try / lambda / range / for-in /
// string interp / defer / tuple destructure stay at stub level until
// the dedicated module ports in Phase 4 / 5.

module "vader/lower"

import "std/collections" { MutableMap, values, keys }
import "vader/parser" {
    Expr, IntLitExpr, FloatLitExpr, BoolLitExpr, NullLitExpr, CharLitExpr,
    StringLitExpr, StringLitText, StringLitInterp, IdentExpr, CallExpr,
    FieldExpr, IndexExpr, UnaryExpr, UnaryOp, BinaryExpr, BinaryOp, IfExpr,
    BlockExpr, MatchExpr, LambdaExpr, StructLitExpr, StructLitField,
    StructLitSpread, SeqLitExpr, RangeExpr, TryExpr, CastExpr,
    GenericInstExpr, IntrinsicCallExpr, DotVariantExpr, IfElse, IfElseIf,
    IfElseBlock, CallArg, FnTypeExpr, ArrayTypeExpr,
    Stmt, LetStmt, AssignStmt, ExprStmt, ReturnStmt, ForStmt,
    BreakStmt, ContinueStmt, DeferStmt, ForForm, InfiniteFor, WhileFor, InFor,
    LetBinding, SimpleBinding, TupleBinding, WildcardBinding, RestBinding,
    Visibility,
}
import "vader/diagnostics" { Span, Diagnostic }
import "vader/typecheck" { type_from_expr, primitive_from_name }
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/types" {
    Type, FnType, PrimitiveType, FreeIntType, FreeFloatType, UnionType, TraitType,
    TypeParamType, ArrayType, TupleType, TypeMetaType, AnyType, SelfType, NeverType,
    TY_BOOL, TY_VOID, TY_NEVER, TY_UNRESOLVED, TY_TYPE, mk_primitive, mk_fn, is_primitive_name,
}
import "vader/typecheck" { default_if_free, equals_type, type_list_equals, is_assignable, lookup_struct_trait_args }
import "vader/typecheck" { TypedProgram }
import "vader/comptime" {
    ComptimeValue, IntValue, FloatValue, BoolValue, CharValue, StringValue,
    NullValue, VoidValue, ArrayValue, StructValue, TypeValue,
}
import "vader/comptime" { EvaluatedProgram }
import "vader/comptime" { byte_size, byte_align }
import "vader/comptime" { mangle_type_arg }
import "vader/typecheck" { type_to_target_symbol, has_user }
import "vader/resolver" { ImportTargetTable, SymbolTarget }
import "vader/parser" { ConstDecl, ImplDecl, StructDecl }
import "vader/typecheck" { substitute_by_name }
import "vader/typecheck" { substitute }
import "vader/typecheck" { new_substitution }
import "vader/types" { display_type, STRUCT_FIELD }
import "vader/types" { STRUCT_ARRAY_ITERATOR }

// ============================================================================
// Expression dispatcher
// ============================================================================

/// Lower an `AST.Expr` to its `LoweredExpr` form.
/// @param ctx   the fn-body context.
/// @param expr  the source expression.
/// @return      the lowered expression.
export lower_expr :: fn(ctx: FnLowerCtx, expr: Expr) -> LoweredExpr {
    type :: ctx.types.expr_type(expr)
    match expr {
        is IntLitExpr     as e -> { return LoweredIntLit { .span = e.span, .type = default_if_free(type), .value = i64(e.value) } }
        is FloatLitExpr   as e -> { return LoweredFloatLit { .span = e.span, .type = default_if_free(type), .value = e.value } }
        is BoolLitExpr    as e -> { return LoweredBoolLit { .span = e.span, .type = TY_BOOL, .value = e.value } }
        is NullLitExpr    as e -> { return LoweredNullLit { .span = e.span, .type = mk_primitive("null") } }
        is CharLitExpr    as e -> { return LoweredCharLit { .span = e.span, .type = mk_primitive("char"), .value = e.value } }
        is StringLitExpr  as e -> { return lower_string_lit(ctx, e, type) }
        is IdentExpr      as e -> { return lower_ident(ctx, e, type) }
        is CallExpr       as e -> { return lower_call(ctx, e, type) }
        is FieldExpr      as e -> {
            // `Enum.Variant` — the target is the enum's type name in
            // value position. Lower to the variant's integer index
            // (matches `lower_dot_variant`'s context-resolved path).
            enum_variant :: try_lower_enum_field(ctx, e, type)
            match enum_variant {
                is null -> {}
                _ -> { return enum_variant }
            }
            // Tuple `t.0` → `_0` : tuple types are backed by an anonymous
            // struct whose slots are named `_0`, `_1`, … — mirror the TS
            // lowerer's `isNumeric` rewrite so the dump shows `._0`.
            field_name :: if e.is_numeric { "_${e.field}" } else { e.field }
            // Union-typed receiver with a common field (every variant
            // carries `f` at the same offset+type) — emit a single cast
            // to the first variant, then a regular field access. The
            // boxed values share `ref` ValType so the cast is free at the
            // bytecode level. Mirror of `lowerUnionFieldAccess`'s
            // `sameOffsetShortcutApplies` short-circuit in
            // `src/lower/passes/expr.ts:1072-1080`.
            target_type :: ctx.types.expr_type(e.target)
            shortcut :: try_lower_common_union_field(ctx, e, type, target_type, field_name)
            match shortcut {
                is null -> {}
                _ -> { return shortcut }
            }
            lowered_target :: lower_expr(ctx, e.target)
            // Comptime fold : `<LoweredStructLit>.field` resolves to
            // the field's value when the struct lit was synthesised
            // at lower time (typically via @comptime for substitution
            // of `f` to a `Field { name, type }` literal). Mirror of
            // TS's `LoweredFieldAccess` shortcut in
            // `src/lower/passes/expr.ts:445-455`.
            //
            // Skip the fold when the target is a *comptime const* baked
            // to a compound struct/array : TS defers that struct-lit
            // substitution to its `inlineConsts` pass, so the fold guard
            // never sees it and `DIM.0` keeps a real `LoweredFieldAccess`
            // over the re-materialised tuple lit (`._0 :i32`). Only
            // `@comptime`-substituted loop-var lits fold.
            if lowered_target is LoweredStructLit as sl {
                if !field_target_is_comptime_const(ctx, e.target) {
                    for f in sl.fields {
                        if f.name == field_name { return f.value }
                    }
                }
            }
            return LoweredFieldAccess {
                .span = e.span, .type = type,
                .target = lowered_target, .field = field_name,
            }
        }
        is IndexExpr      as e -> { return lower_index(ctx, e, type) }
        is UnaryExpr      as e -> {
            return LoweredUnary {
                .span = e.span, .type = type,
                .op = lower_unary_op(e.op),
                .operand = lower_expr(ctx, e.operand),
            }
        }
        is BinaryExpr     as e -> { return lower_binary(ctx, e, type) }
        is IfExpr         as e -> { return lower_if(ctx, e, type) }
        is BlockExpr      as e -> { return lower_block(ctx, e, false, false) }
        is StructLitExpr  as e -> { return lower_struct_lit(ctx, e, type) }
        is SeqLitExpr     as e -> { return lower_seq_lit(ctx, e, type) }
        is CastExpr       as e -> {
            return LoweredCast { .span = e.span, .type = type, .value = lower_expr(ctx, e.value) }
        }
        is IntrinsicCallExpr as e -> { return lower_intrinsic(ctx, e, type) }
        // Match / try / lambda / range / for-in are deferred to phases
        // 4 / 5. Until then, emit an unreachable so the dump shape is
        // consistent and downstream phases can spot the gap.
        is MatchExpr     as e -> { return lower_match(ctx, e, type, lower_expr) }
        is TryExpr       as e -> { return lower_try(ctx, e, type, lower_expr) }
        is LambdaExpr    as e -> { return lower_lambda(ctx, e, lower_block) }
        is RangeExpr     as e -> { return lower_range_expr(ctx, e, type, lower_expr) }
        is GenericInstExpr  as e -> { return stub(e.span, type, "generic-inst expression not lowered") }
        is DotVariantExpr   as e -> { return lower_dot_variant(ctx, e, type) }
        // Type-position expressions in value position — earlier phases
        // emit T3035 ; the lowerer just emits a stub.
        is FnTypeExpr    as e -> { return stub(e.span, type, "type-valued slot not lowered") }
        is ArrayTypeExpr as e -> { return stub(e.span, type, "type-valued slot not lowered") }
    }
}

stub :: fn(span: Span, type: Type, reason: string) -> LoweredExpr {
    return LoweredUnreachable { .span = span, .type = type, .reason = reason }
}

// ============================================================================
// Per-kind expression lowerers
// ============================================================================

lower_ident :: fn(ctx: FnLowerCtx, ident: IdentExpr, type: Type) -> LoweredExpr {
    symbol :: ctx.typed.resolved.idents[ident.span.hash()]
    match symbol {
        is null -> { return stub(ident.span, type, "unresolved ident ${ident.name}") }
        is Symbol as resolved -> {
            // `@comptime for x in arr { ... }` substitution : every
            // reference to the loop var inside the unrolled body
            // resolves to the per-iter literal. Checked before the
            // regular paths so the binding "wins" over any captured-
            // cell / lifted-env handling for the same symbol.
            // Mirror of `lowerIdent`'s `comptimeBindings` check in
            // `src/lower/passes/expr.ts:542-543`.
            // Size short-circuit : `comptime_bindings` is empty for
            // every fn that doesn't use `@comptime for`, so skip the
            // hash probe in the 99% case. Per-ident hot path.
            if ctx.comptime_bindings.size > 0 {
                comptime_val :: ctx.comptime_bindings[resolved.id]
                if !(comptime_val is null) { return comptime_val }
            }
            // TypeMeta-typed ident in value position — reify the
            // underlying Type so the bytecode emit can lower it to
            // `type.const N`. Mirror of `lowerIdent`'s TypeMeta branch in
            // `src/lower/passes/expr.ts:533-538`.
            if type is TypeMetaType {
                meta :: resolve_type_meta_symbol(ctx, resolved)
                if !(meta is null) {
                    return LoweredTypeConst {
                        .span = ident.span, .type = type, .value = arg_ty_or_unresolved(meta),
                    }
                }
            }
            // When we're lowering inside a lifted lambda body, captured
            // outer symbols don't have a local slot — read them off the
            // env-struct param via `env.cap_N`.
            via_env :: try_route_through_env(ctx, resolved, ident.span, type)
            if via_env != null { return via_env }
            // Local captured by an inner lambda : the slot stores a cell
            // ref, the value lives behind a `LoweredCellGet`. Mirror of
            // `lowerIdent`'s captured-symbol path in `expr.ts:559-561`.
            if ctx.project.closures.captured_symbols.contains(resolved.id) {
                cell_ref :: LoweredIdent {
                    .span = ident.span, .type = type, .symbol = resolved,
                }
                return LoweredCellGet {
                    .span = ident.span, .type = type,
                    .target = cell_ref, .value_type = type,
                }
            }
            // Scalar const inlining : when a `const` decl carries a
            // comptime-baked scalar (int / float / bool / char / string /
            // null), substitute its value at every use site. Mirror of
            // the TS `inlineConsts` pass's scalar bucket. Compound values
            // (arrays, structs) are deferred — they'd need data-pool /
            // fn-wrap routing for byte-parity. Also covers param /
            // import-binding symbols when the resolver chained the
            // ident to the original const symbol via aliasing.
            baked :: lookup_const_baked_value(ctx, resolved)
            if baked == null {
                // Bake missed. For a Const symbol this is most often an
                // imported-module const (the comptime bake is entry-only) —
                // recover by lowering the const decl's value at the use site
                // instead of leaving a bare const ident the CFG builder can't
                // resolve. Gate on Const kind here so the common baked-miss —
                // every local / param read — skips try_fold_unbaked_const's
                // module lookups entirely.
                if i32(resolved.kind) == i32(SymbolKind.Const) {
                    unbaked :: try_fold_unbaked_const(ctx, resolved, type)
                    if unbaked != null { return unbaked }
                }
            } else if is_scalar_comptime(baked) {
                return comptime_value_to_lowered(baked, type, ident.span)
            }
            // Match-arm narrowing : the slot stores the declared union
            // (e.g. `Error | string`), the typed-AST narrows this use to a
            // concrete variant (e.g. `string`) — emit a `LoweredCast` so the
            // dump and the runtime unbox via the variant layout instead of
            // the union slot. Mirror of `lowerIdent` in `expr.ts:563-573`.
            declared :: declared_type_of_symbol(ctx, resolved)
            if declared is UnionType {
                if !equals_type(declared, type) {
                    return LoweredCast {
                        .span = ident.span, .type = type,
                        .value = LoweredIdent {
                            .span = ident.span, .type = declared, .symbol = resolved,
                        },
                    }
                }
            }
            // Named import-binding redirect : `import "p" { foo as bar }`
            // means every `bar` reference dumps with the target's
            // identity. Mirror of TS's `resolveImportRedirect` (
            // `src/resolver/resolve.ts:809-815`) applied at idents.set time.
            final_sym :: follow_import_binding(ctx, resolved)
            // A fn used as a VALUE (passed as a `fn(...)` arg, stored, etc.)
            // lowers to a `FnRef`. If it's a non-generic stdlib free fn,
            // harvest it so `materialize_nongeneric_stdlib_fns` emits its body —
            // otherwise the FnRef emit can't resolve the symbol and silently
            // drops it. Mirror of the direct-call harvest in `lower_call`.
            // Self-guards : no-op unless `final_sym` is a non-generic stdlib Fn.
            register_nongeneric_stdlib_fn(ctx, final_sym)
            return LoweredIdent { .span = ident.span, .type = type, .symbol = final_sym }
        }
    }
}

// `CellInit` and the cell-init wrapper now live in `vader/lower/helpers.vader`
// (single source of truth — same module, same shape). Callers below
// reach for `lower_cell_init` directly.

// True when `target` is a bare ident resolving to a `@comptime` const
// whose baked value is a compound struct / array. Such references keep
// a real field access at the use site (the tuple lit rides as the
// access target) rather than folding to the projected element — mirror
// of TS deferring const substitution to `inlineConsts`.
field_target_is_comptime_const :: fn(ctx: FnLowerCtx, target: Expr) -> bool {
    if target is IdentExpr as id {
        symbol :: ctx.typed.resolved.idents[id.span.hash()]
        if symbol is Symbol as resolved {
            baked :: lookup_const_baked_value(ctx, resolved)
            return baked is StructValue || baked is ArrayValue
        }
    }
    return false
}

lookup_const_baked_value :: fn(ctx: FnLowerCtx, symbol: Symbol) -> ComptimeValue | null {
    // The const symbol may live in this module or in an imported one.
    // `comptime_value_by_symbol_id` was flattened at lower-project entry
    // so this lookup is O(1) instead of walking every loaded module's
    // `comptime_decls` map per call (this fn fires on every IdentExpr).
    return ctx.project.comptime_value_by_symbol_id[symbol.id]
}

// Fold a reference to an UNBAKED module-level const to its value. The
// comptime const-bake runs entry-only (`populate_comptime_value_index` reads
// `evaluated.modules[*].comptime_decls`), so a const declared in an IMPORTED
// module — e.g. `MANIFEST_FILENAME :: "vader.json"` referenced from its own
// module's `find_manifest_root` — never lands in `comptime_value_by_symbol_id`.
// The scalar-const fold in `lower_ident` then misses and the bare const ident
// reaches `midir/build.vader::build_ident`, which has no const case → it emits
// `unreachable`, truncating the function. Recover by lowering the const decl's
// value directly via `lower_const_value` (whose own bake-miss path lowers the
// RHS), keyed off the const's OWNING module so cross-module refs work too.
// Caller gates on `resolved.kind == Const` (the hot-path read of every
// local / param shouldn't pay the module lookups below). Returns null when the
// decl can't be located or its RHS isn't foldable (caller keeps its path).
try_fold_unbaked_const :: fn(ctx: FnLowerCtx, resolved: Symbol, type: Type) -> LoweredExpr | null {
    owner_loaded :: ctx.project.loaded.modules[resolved.module]
    if owner_loaded is null { return null }
    owner_typed :: ctx.project.evaluated.typed.modules[resolved.module]
    if owner_typed is null { return null }
    const_decl :: find_const_decl_by_name(module_decls(owner_loaded), resolved.name)
    if const_decl is null { return null }
    // Only fold a LITERAL-RHS const. A computed RHS (`B + 1`) may depend on
    // other unbaked consts, so folding it here would (a) bypass comptime
    // cycle detection — a `@comptime A :: B + 1 ; B :: A + 1` must still
    // surface C4009 — and (b) risk recursion through this same path. Those
    // consts keep their existing route ; the comptime evaluator owns their
    // value and diagnostics. A literal RHS has neither hazard and matches the
    // scalar-only shape of the baked-value fold above.
    if !is_scalar_literal_expr(const_decl.value) { return null }
    entry :: stub_entry(const_decl, owner_typed)
    fn_ctx :: new_fn_lower_ctx(ctx.project, entry, owner_typed, new_substitution(), type, null)
    return lower_const_value(const_decl, owner_typed, ctx.project, fn_ctx, type)
}

find_const_decl_by_name :: fn(decls: Decl[], name: string) -> ConstDecl | null {
    for d in decls {
        if d is ConstDecl as cd {
            if cd.name == name { return cd }
        }
    }
    return null
}

// True when `e` is a scalar literal (int / float / bool / null / char /
// string). Gates `try_fold_unbaked_const` to RHS shapes that fold without
// touching other consts. Shape predicate (`_ -> false`), mirroring
// `fmt/printer.vader::is_bitor_chain` — a non-literal Expr is correctly false.
is_scalar_literal_expr :: fn(e: Expr) -> bool = match e {
    is IntLitExpr    -> true
    is FloatLitExpr  -> true
    is BoolLitExpr   -> true
    is NullLitExpr   -> true
    is CharLitExpr   -> true
    is StringLitExpr -> true
    // `usize(0)` / `i32(N)` — a primitive numeric conversion of a scalar
    // literal parses as a CallExpr. It folds just as safely (the arg is a
    // literal, so no dependency on another unbaked const), so a const like
    // `UNASSIGNED_NODE_ID :: usize(0)` resolves at its use sites in imported
    // bodies instead of degrading to an unresolved ident.
    is CallExpr as c -> is_numeric_conversion_of_literal(c)
    _                -> false
}

is_numeric_conversion_of_literal :: fn(c: CallExpr) -> bool {
    if !(c.callee is IdentExpr) { return false }
    if !is_primitive_name(c.callee.name) { return false }
    if c.args.len() != 1 { return false }
    return is_scalar_literal_expr(c.args[0].value)
}

/// Materialise a `ComptimeValue` as a `LoweredExpr` literal. Compound
/// values (arrays, structs) recurse field-by-field. Mirror of
/// `comptimeValueToLowered` in `src/lower/lower.ts:245-275`.
export comptime_value_to_lowered :: fn(v: ComptimeValue, type_hint: Type, span: Span) -> LoweredExpr {
    match v {
        is IntValue    as iv -> { return LoweredIntLit { .span = span, .type = type_hint, .value = iv.value } }
        is FloatValue  as fv -> { return LoweredFloatLit { .span = span, .type = type_hint, .value = fv.value } }
        is BoolValue   as bv -> { return LoweredBoolLit { .span = span, .type = TY_BOOL, .value = bv.value } }
        is CharValue   as cv -> { return LoweredCharLit { .span = span, .type = mk_primitive("char"), .value = cv.value } }
        is StringValue as sv -> { return LoweredStringLit { .span = span, .type = mk_primitive("string"), .value = sv.value } }
        is NullValue         -> { return LoweredNullLit { .span = span, .type = mk_primitive("null") } }
        is VoidValue         -> { return LoweredUnreachable { .span = span, .type = type_hint, .reason = "comptime void value" } }
        is ArrayValue as av -> {
            element_type :: array_element_type(type_hint)
            elements: LoweredExpr[] = []
            for e in av.elements { elements.push(comptime_value_to_lowered(e, element_type, span)) }
            return LoweredArrayLit { .span = span, .type = type_hint, .elements = elements }
        }
        is StructValue as sv -> {
            // `sv.fields.keys()` iterates in MutableMap hash-bucket
            // order, which doesn't match the field declaration order
            // tuples / structs rely on for dump parity. Sort the
            // names alphabetically — for tuples (`_0`, `_1`, `_2`)
            // that matches the positional order ; for named structs
            // the same ordering is what TS' dump uses.
            sorted_names :: sort(sv.fields.keys(), (a: string, b: string) -> compare_ascending(a, b))
            fields: LoweredStructLitField[] = []
            for name in sorted_names {
                val :: sv.fields[name]
                match val {
                    is null -> {}
                    _ -> {
                        fields.push(LoweredStructLitField {
                            .name = name,
                            .value = comptime_value_to_lowered(val, TY_UNRESOLVED, span),
                        })
                    }
                }
            }
            return LoweredStructLit { .span = span, .type = type_hint, .fields = fields }
        }
        is TypeValue -> { return LoweredUnreachable { .span = span, .type = type_hint, .reason = "comptime type-value lowering deferred" } }
    }
}

// Element type of an array, or `unresolved` when `t` isn't a concrete array
// (an un-hinted comptime array literal hits this with a `?` hint — the
// elements then resolve from their own values). Single-case `if`, not a
// `match` with a `_ ->` degraded arm.
array_element_type :: fn(t: Type) -> Type {
    if t is ArrayType as at { return at.element }
    return TY_UNRESOLVED
}

is_scalar_comptime :: fn(v: ComptimeValue) -> bool {
    match v {
        is IntValue    -> { return true }
        is FloatValue  -> { return true }
        is BoolValue   -> { return true }
        is CharValue   -> { return true }
        is StringValue -> { return true }
        is NullValue   -> { return true }
        // Small tuple / struct values inline at use sites — TS'
        // `inlineConsts` pass keeps these as `LoweredStructLit` /
        // `LoweredArrayLit` at every reference. Vader doesn't have a
        // size gate yet (TS' data-pool / fn-wrap split kicks in at
        // ≥ 4 elements) ; small tuple consts are the dominant pattern
        // that hits this path so blind inlining matches the snapshot
        // shape. Revisit when data-pool / fn-wrap lands.
        is StructValue -> { return true }
        is ArrayValue  -> { return true }
        _              -> { return false }
    }
}

/// Reify a TypeMeta-typed symbol's underlying Type. Mirror of
/// `resolveTypeMetaSymbol` in `src/lower/passes/expr.ts:646-657`.
/// Sources: `@comptime const X :: Type` aliases land in
/// `resolved.alias_types`; primitive builtins reconstruct from their
/// name. Returns null for shapes we can't reify yet (e.g. type-params).
resolve_type_meta_symbol :: fn(ctx: FnLowerCtx, symbol: Symbol) -> Type | null {
    aliased :: ctx.typed.resolved.alias_types[symbol.id]
    if !(aliased is null) { return aliased }
    if i32(symbol.kind) == i32(SymbolKind.BuiltinType) {
        return primitive_from_name(symbol.name)
    }
    return null
}

declared_type_of_symbol :: fn(ctx: FnLowerCtx, symbol: Symbol) -> Type | null {
    // Most idents (Fn, Const, ImportBinding, …) can't be narrowed —
    // bail before paying the `span_key` allocation on the hot path.
    match symbol.kind {
        .Param   -> {}
        .Local   -> {}
        .Binding -> {}
        _        -> { return null }
    }
    defined_at :: symbol.defined_at
    if defined_at is null { return null }
    key :: defined_at.hash()
    // Apply the entry substitution so the narrowing comparison sees the
    // erased declared type (`Any | null`), matching the erased read-site
    // type — otherwise an unerased `T | null` declared type spuriously
    // differs from the read type and injects a redundant cast in
    // generic-impl default-method bodies.
    raw :: if i32(symbol.kind) == i32(SymbolKind.Param) {
        ctx.typed.param_types[key]
    } else {
        ctx.typed.local_types[key]
    }
    if raw is null { return null }
    return ctx.types.apply(raw)
}

try_lower_common_union_field :: fn(
    ctx: FnLowerCtx, expr: FieldExpr, expr_type: Type, target_type: Type, field_name: string,
) -> LoweredExpr | null {
    if !(target_type is UnionType) { return null }
    match target_type {
        is UnionType as u -> {
            if u.variants.len() == 0 { return null }
            first_variant :: u.variants[0]
            if !(first_variant is StructType) { return null }
            // Every variant must be a struct exposing the same field
            // name with the same resolved type. Bail out otherwise — the
            // general per-variant cascade isn't ported yet.
            for v in u.variants {
                if !(v is StructType) { return null }
            }
            cast_target :: LoweredCast {
                .span = expr.span, .type = first_variant,
                .value = lower_expr(ctx, expr.target),
            }
            return LoweredFieldAccess {
                .span = expr.span, .type = expr_type,
                .target = cast_target, .field = field_name,
            }
        }
        _ -> { return null }
    }
}

try_route_through_env :: fn(
    ctx: FnLowerCtx, symbol: Symbol, span: Span, type: Type,
) -> LoweredExpr | null {
    lifted :: ctx.lifted_context
    if lifted is null { return null }
    field_name :: lifted.capture_fields[symbol.id]
    match field_name {
        is null -> { return null }
        is string as name -> {
            env_ident :: LoweredIdent {
                .span = span, .type = lifted.env_type, .symbol = lifted.env_symbol,
            }
            // The env slot stores a `Cell<T>` ref, not a `T` ; type the
            // field access as `Unresolved` (≡ ref ValType) so downstream
            // bytecode emit doesn't synthesise a primitive-typed
            // `ref.cast` over what is in fact an opaque cell pointer.
            cell_ref :: LoweredFieldAccess {
                .span = span, .type = TY_UNRESOLVED, .target = env_ident, .field = name,
            }
            // The env-struct slot holds a cell ref ; unwrap via
            // `LoweredCellGet` to materialise the value. Mirror of
            // `lowerIdent`'s lifted-context branch in `expr.ts:550-555`.
            return LoweredCellGet {
                .span = span, .type = type,
                .target = cell_ref, .value_type = type,
            }
        }
    }
}

// Plain text-only string lit becomes a single `LoweredStringLit`. Any
// `${expr}` segment routes through a builder-chain : `builder.new` +
// per-part `builder.append_str` / `builder.append_display` +
// `builder.finish`. Primitive-typed segments take the
// `builder.append_display` fast path ; non-primitive segments emit an
// `append_display` call too (the bytecode emitter resolves the right
// `<T>.Display.to_string` impl via the impl table once it lands —
// today this means the lowered IR carries the call shape but the impl
// lookup is deferred).
lower_string_lit :: fn(ctx: FnLowerCtx, expr: StringLitExpr, type: Type) -> LoweredExpr {
    if !has_interp_part(expr) {
        body := ""
        for part in expr.parts {
            match part {
                is StringLitText as text -> { body = body + text.value }
                _ -> {}
            }
        }
        return LoweredStringLit { .span = expr.span, .type = mk_primitive("string"), .value = body }
    }
    builder_symbol :: fresh_synthetic_symbol(ctx, "sb")
    string_type :: mk_primitive("string")
    stmts: LoweredStmt[] = []
    stmts.push(LoweredLet {
        .span = expr.span, .name = builder_symbol.name, .symbol = builder_symbol,
        .type = TY_UNRESOLVED,
        .value = LoweredIntrinsicCall {
            .span = expr.span, .type = TY_UNRESOLVED,
            .name = INTRINSIC_BUILDER_NEW, .args = [], .display_for = null,
        },
    })
    for part in expr.parts {
        match part {
            is StringLitText as text -> {
                builder_ref :: LoweredIdent {
                    .span = text.span, .type = TY_UNRESOLVED, .symbol = builder_symbol,
                }
                literal :: LoweredStringLit {
                    .span = text.span, .type = string_type, .value = text.value,
                }
                args: LoweredExpr[] = []
                args.push(builder_ref)
                args.push(literal)
                stmts.push(LoweredExprStmt {
                    .span = text.span,
                    .expr = LoweredIntrinsicCall {
                        .span = text.span, .type = TY_VOID,
                        .name = INTRINSIC_BUILDER_APPEND_STR, .args = args, .display_for = null,
                    },
                })
            }
            is StringLitInterp as interp -> {
                inner :: lower_expr(ctx, interp.expr)
                inner_type :: type_of(inner)
                builder_ref :: LoweredIdent {
                    .span = interp.span, .type = TY_UNRESOLVED, .symbol = builder_symbol,
                }
                if is_primitive_for_display(inner_type) {
                    args: LoweredExpr[] = []
                    args.push(builder_ref)
                    args.push(inner)
                    stmts.push(LoweredExprStmt {
                        .span = interp.span,
                        .expr = LoweredIntrinsicCall {
                            .span = interp.span, .type = TY_VOID,
                            .name = INTRINSIC_BUILDER_APPEND_DISPLAY,
                            .args = args, .display_for = inner_type,
                        },
                    })
                } else {
                    // Non-primitive segment : route through `<T>.Display
                    // .to_string(value)` then feed the string into
                    // `builder.append_str`. Mirrors TS's `wrapAsDisplay`
                    // path. The `to_string` symbol is synthesised here ;
                    // the bytecode emit resolves it via the impl-member
                    // mangling once that wiring lands.
                    str_call :: build_display_to_string_call(ctx, inner, interp.span)
                    args: LoweredExpr[] = []
                    args.push(builder_ref)
                    args.push(str_call)
                    stmts.push(LoweredExprStmt {
                        .span = interp.span,
                        .expr = LoweredIntrinsicCall {
                            .span = interp.span, .type = TY_VOID,
                            .name = INTRINSIC_BUILDER_APPEND_STR,
                            .args = args, .display_for = null,
                        },
                    })
                }
            }
        }
    }
    finish_args: LoweredExpr[] = []
    finish_args.push(LoweredIdent { .span = expr.span, .type = TY_UNRESOLVED, .symbol = builder_symbol })
    return LoweredBlock {
        .span = expr.span, .type = string_type,
        .stmts = stmts,
        .trailing = LoweredIntrinsicCall {
            .span = expr.span, .type = string_type,
            .name = INTRINSIC_BUILDER_FINISH, .args = finish_args, .display_for = null,
        },
    }
}

// Primitive integer/float/bool/char/string types take the fast
// `builder.append_display` path ; the bytecode emit has dedicated ops
// per width. FreeInt / FreeFloat (un-defaulted lit types) also count —
// they default to `i32` / `f64` at codegen time. Wide unsigned widths
// (u32, u64, usize) are an exception : the VM collapses every integer
// onto `I32Val` / `I64Val` which are signed carriers, so a bit pattern
// outside the signed-i64 range would print negative. Routing them
// through `<u32>.Display.to_string` gives the VM a mangled-name hook
// to pick the unsigned stringifier ; the C target inlines via the
// @intrinsic impl so this is free at native codegen.
is_primitive_for_display :: fn(t: Type) -> bool {
    match t {
        is PrimitiveType as p -> {
            if p.name == "u32"   { return false }
            if p.name == "u64"   { return false }
            if p.name == "usize" { return false }
            return true
        }
        is FreeIntType -> { return true }
        is FreeFloatType -> { return true }
        _ -> { return false }
    }
}

// Build a `<T>.Display.to_string(value)` call shape. Prefers a direct
// `LoweredCall` to the per-receiver impl member when the impl is
// statically resolvable (concrete struct / enum types) — mirrors TS
// `wrapAsDisplay` in `src/lower/passes/display-coerce.ts`. Falls back
// to `LoweredVirtualCall` for primitives / generic-T receivers where
// the impl exists per-instantiation but isn't reachable at lower-time.
build_display_to_string_call :: fn(ctx: FnLowerCtx, value: LoweredExpr, span: Span) -> LoweredExpr {
    string_type :: mk_primitive("string")
    no_args: LoweredExpr[] = []
    direct :: try_direct_display_call(ctx, value, span)
    match direct {
        is null -> {}
        _ -> { return direct }
    }
    return LoweredVirtualCall {
        .span       = span,
        .type       = string_type,
        .trait_name = "Display",
        .method     = "to_string",
        .receiver   = value,
        .args       = no_args,
    }
}

// Look up `<sourceType>.Display.to_string` statically. Returns a
// `LoweredCall` whose callee is the impl-member's mangled fn symbol
// when reachable ; null otherwise. The mangling matches what
// `lower_impl_members` registers in `lower.vader`.
try_direct_display_call :: fn(ctx: FnLowerCtx, value: LoweredExpr, span: Span) -> LoweredExpr | null {
    string_type :: mk_primitive("string")
    source_type :: type_of(value)
    // Resolve `<T>.Display.to_string` through the canonical UFCS path. This
    // mangles via the IMPL's owning module (`std_core$usize$Display$to_string`,
    // not the caller's) AND records the mangle in `referenced_impl_mangles`, so
    // the post-lowering pass surfaces the bodyless intrinsic member as an import
    // and the call resolves to its `$vt` wrapper. A previous hand-rolled scan
    // here emitted a bare `to_string` callee with no recorded reference, so the
    // call fell through to the emit's defensive `Return` (e.g. every `${usize}`
    // interpolation silently mis-compiled). `null` (no concrete Display impl:
    // generic-T / trait receiver) falls back to a `LoweredVirtualCall`.
    member :: find_impl_member_for(ctx, source_type, "to_string")
    if member is null { return null }
    call_args: LoweredExpr[] = []
    call_args.push(value)
    return LoweredCall {
        .span = span, .type = string_type,
        .callee = LoweredIdent { .span = span, .type = string_type, .symbol = member.symbol },
        .args = call_args,
    }
}

has_interp_part :: fn(expr: StringLitExpr) -> bool {
    for part in expr.parts {
        match part {
            is StringLitInterp -> { return true }
            _ -> {}
        }
    }
    return false
}

// Basic call lowering — no direct-call overload overrides, no UFCS
// rewrites, no generic-fn instance lookups. Lowers the callee + every
// arg directly. Phase 4 extends this with the typecheck's
// `directCallOverloads` table once the equivalent surfaces in Vader.
// Special cases :
// - `arr.push(x)` / `arr.len()` route to the dedicated
//   `LoweredArrayPush` / `LoweredArrayLen` ops when the receiver is
//   an array.
// - `<namespace>.foo(args)` where `<namespace>` is an `ImportBinding`
//   ident collapses to a direct `foo(args)` call ; the surrounding
//   namespace prefix is purely a source-level concept.
lower_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr {
    array_form :: try_lower_array_op(ctx, call, type)
    match array_form {
        is null -> {}
        _ -> { return array_form }
    }
    namespace_form :: try_lower_namespace_call(ctx, call, type)
    match namespace_form {
        is null -> {}
        _ -> { return namespace_form }
    }
    cast_form :: try_lower_cast_call(ctx, call, type)
    match cast_form {
        is null -> {}
        _ -> { return cast_form }
    }
    vcall_form :: try_lower_virtual_call(ctx, call, type)
    match vcall_form {
        is null -> {}
        _ -> { return vcall_form }
    }
    ufcs_form :: try_lower_ufcs_call(ctx, call, type)
    match ufcs_form {
        is null -> {}
        _ -> { return ufcs_form }
    }
    generic_form :: try_lower_generic_fn_call(ctx, call, type)
    match generic_form {
        is null -> {}
        _ -> { return generic_form }
    }
    raw_callee :: lower_expr(ctx, call.callee)
    // Widen literal args to the matching param's union type so the dump
    // shows `int(42) :i32 | null` for `describe(42)` against
    // `describe(x: i32 | null)`. Mirror of the TS typer's
    // context-propagation that records the wide type at the literal.
    // Widening reads the picked overload's fn-type, so take params off
    // `raw_callee` before any result-type retype below.
    param_types :: param_types_of(type_of(raw_callee))
    args: LoweredExpr[] = []
    for i in 0..<call.args.len() {
        arg :: lower_expr(ctx, call.args[i].value)
        if i < param_types.len() {
            widened :: widen_literal_to_context(arg, param_types[i])
            coerced :: try_emit_into_coercion(ctx, widened, type_of(widened), param_types[i], call.args[i].value.span)
            match coerced {
                is null -> { args.push(widened) }
                _ -> { args.push(coerced) }
            }
        } else {
            args.push(arg)
        }
    }
    callee :: retype_overload_callee(ctx, call.callee, raw_callee, type)
    // Direct calls to non-generic stdlib free fns (`new_builder()`,
    // `byte_len(s)`) : harvest so `materialize_nongeneric_stdlib_fns`
    // emits the body — the UFCS path harvests its own, this covers the
    // bare-ident-callee form.
    if callee is LoweredIdent as direct_callee {
        register_nongeneric_stdlib_fn(ctx, direct_callee.symbol)
    }
    return LoweredCall { .span = call.span, .type = type, .callee = callee, .args = args }
}

// Non-primary overload picks display the call's *result* type on the
// callee ident (TS `calleeSym !== resolverSym`,
// `src/lower/passes/expr.ts:101`). The typer flagged these in
// `overload_result_callees` ; rebuild the lowered ident with the
// result type AND re-point its symbol at the picked overload.
//
// The resolver binds an overloaded ident to the PRIMARY (first-declared)
// overload ; `pick_overload` then patches the callee's expr-type to the
// chosen overload and sets the flag, but leaves the resolver SYMBOL on the
// primary. Without re-pointing it the emitter mangles the call to the
// primary body — e.g. `min(usize, usize)` would call the `min(f64, f64)`
// body, which the VM traps as `f64.lt expected f64, got i32`. Re-pointing
// also drives `register_nongeneric_stdlib_fn` (back in `lower_call`) to
// materialise the picked overload's body.
retype_overload_callee :: fn(
    ctx: FnLowerCtx, callee_ast: Expr, lowered: LoweredExpr, result_type: Type,
) -> LoweredExpr {
    if callee_ast is IdentExpr as id {
        if ctx.typed.overload_result_callees[id.id] is null { return lowered }
        if lowered is LoweredIdent as li {
            symbol := li.symbol
            // The picked overload's signature is the callee ident's patched
            // type. Match it back to a Symbol so the emitted call resolves
            // to the right body.
            if li.type is FnType as picked {
                found :: find_picked_overload_symbol(ctx, id.name, picked)
                if found != null { symbol = found }
            }
            return LoweredIdent { .span = li.span, .type = result_type, .symbol = symbol }
        }
    }
    return lowered
}

// Find the overload SYMBOL whose param list matches `picked` — the FnType
// `pick_overload` selected for an overloaded direct call. Mirror of TS
// `directCallOverloads` (the chosen Symbol). Matches on PARAMS only :
// imported overloads' return types are frequently unsettled (`?`) at lower
// time, but param lists are always concrete (straight from the decl
// signature) and uniquely identify an overload (the resolver rejects two
// overloads with identical params). The module being lowered is tried first,
// then the cross-module scan mirrors `find_free_fn_ufcs` — every loaded
// module's bucket carries the candidates.
//
// @param name    the callee identifier name.
// @param picked  the overload FnType typecheck selected.
// @return        the matching overload Symbol, or null when none matches —
//                the caller then keeps the resolver primary.
find_picked_overload_symbol :: fn(ctx: FnLowerCtx, name: string, picked: FnType) -> Symbol | null {
    local :: match_overload_in_bucket(ctx.typed, name, picked)
    if local != null { return local }
    for module_id in ctx.project.evaluated.modules.keys() {
        program :: ctx.project.evaluated.modules[module_id]
        if program is null { continue }
        if program is EvaluatedProgram as ep {
            found :: match_overload_in_bucket(ep.typed, name, picked)
            if found != null { return found }
        }
    }
    return null
}

// The overload symbol in `typed`'s `fn_overloads[name]` bucket whose declared
// param list matches `picked` (return type ignored — see caller). Null when
// the bucket is absent or no overload matches.
match_overload_in_bucket :: fn(typed: TypedProgram, name: string, picked: FnType) -> Symbol | null {
    bucket :: typed.resolved.fn_overloads[name]
    if bucket is Symbol[] as syms {
        for sym in syms {
            dt :: typed.decl_types[sym.id]
            if dt is FnType as ft {
                if type_list_equals(ft.params, picked.params) { return sym }
            }
        }
    }
    return null
}

param_types_of :: fn(callee_type: Type) -> Type[] {
    match callee_type {
        is FnType as ft -> { return ft.params }
        _ -> {
            empty: Type[] = []
            return empty
        }
    }
}

/// `recv.method(args)` against a trait-typed receiver lowers to a
/// `LoweredVirtualCall` — the bytecode emit dispatches in O(1) via the
/// per-(trait, method) vtable. Detection : the callee is a `FieldExpr`
/// and the lowered receiver's runtime type is a `TraitType` (the typer
/// already narrowed unions / cast-call sites so the lowered tree carries
/// the dispatch type at the surface). Mirror of `lowerVirtualDispatch`
/// in `src/lower/passes/expr.ts:957-989`.
try_lower_virtual_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    callee_field :: as_field_expr(call.callee)
    if callee_field is null { return null }
    if callee_field is FieldExpr as field_expr {
        receiver :: lower_expr(ctx, field_expr.target)
        if type_of(receiver) is TraitType as tt {
            args: LoweredExpr[] = []
            for call_arg in call.args { args.push(lower_expr(ctx, call_arg.value)) }
            return LoweredVirtualCall {
                .span = call.span, .type = type,
                .trait_name = tt.symbol.name, .method = field_expr.field,
                .receiver = receiver, .args = args,
            }
        }
        // TypeParam-bounded receiver erased to Any : typer recorded
        // the resolving trait name in `bounded_dispatch_trait` ; route
        // through the runtime vtable so the boxed value's tag picks
        // the right impl at runtime. Mirror of TS' `lowerVirtualDispatch`
        // path on `concreteRecv.kind === "Any"`
        // (`src/lower/passes/expr.ts:199-204`).
        if type_of(receiver) is AnyType {
            trait_name :: ctx.typed.bounded_dispatch_trait[field_expr.id]
            if trait_name is string as tname {
                args: LoweredExpr[] = []
                for call_arg in call.args { args.push(lower_expr(ctx, call_arg.value)) }
                return LoweredVirtualCall {
                    .span = call.span, .type = type,
                    .trait_name = tname, .method = field_expr.field,
                    .receiver = receiver, .args = args,
                }
            }
        }
        // Concrete primitive receiver with a bounded-trait method : a generic
        // instance concretised on a primitive K (e.g. `key.equals(other)` in
        // `MutableMap<i32,_>`). `Equals` is `@intrinsic` on primitives, so
        // devirtualise straight to the comparison primop instead of a
        // `virtual.call` / thunk. Other trait methods (Hash / Comparable have
        // materialised bodies) fall through to the UFCS direct-call path.
        if type_of(receiver) is PrimitiveType {
            tname_opt :: ctx.typed.bounded_dispatch_trait[field_expr.id]
            if tname_opt is string as tname {
                // `equals` is `@intrinsic` on primitives ; `not_equals` is the
                // trait default `!self.equals(...)`, which on a primitive is
                // exactly `!=` — both reduce to a comparison primop here.
                if tname == "Equals" && call.args.len() > 0 {
                    if field_expr.field == "equals" || field_expr.field == "not_equals" {
                        cmp_op :: if field_expr.field == "equals" { LoweredBinaryOp.Eq } else { LoweredBinaryOp.Neq }
                        return LoweredBinary {
                            .span = call.span, .type = type, .op = cmp_op,
                            .left = receiver, .right = lower_expr(ctx, call.args[0].value),
                        }
                    }
                }
            }
        }
    }
    return null
}

/// `fn[T, U](a, b)` call to a top-level generic fn lowers to a direct
/// call against the monomorphized instance. Detection : callee is an
/// IdentExpr resolving to a Fn symbol whose source FnDecl has
/// `type_params.len() > 0`. Type args come from the args' inferred
/// types — for `identity(42)` the FnType has param `T`, arg has type
/// `i32`, so `T = i32`. The synth monomorphic decl is registered
/// with the project ctx ; dedup is by `(fn_symbol.id, args_key)`.
/// Chase an `ImportBinding` symbol through `import_targets.symbol_targets`
/// to its concrete export target. Returns the original symbol when it
/// isn't an ImportBinding, or when the target lookup fails (let the
/// caller's kind-check filter the wrong shape).
follow_import_binding :: fn(ctx: FnLowerCtx, sym: Symbol) -> Symbol {
    if i32(sym.kind) != i32(SymbolKind.ImportBinding) { return sym }
    targets :: ctx.typed.import_targets
    if targets is null { return sym }
    if targets is ImportTargetTable as t {
        st :: t.symbol_targets[sym.id]
        if st is null { return sym }
        if st is SymbolTarget as found { return found.symbol }
    }
    return sym
}

try_lower_generic_fn_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    // Explicit-args generic call : `identity<i32>(42)`. The callee
    // is a GenericInstExpr whose inner callee is the fn IdentExpr.
    // Type args come from the GenericInstExpr's type_args slot,
    // bypassing the inference step the bare-ident path uses. Mirror
    // of TS' `expr.callee.kind === "GenericInstExpr"` handling
    // (`src/lower/passes/expr.ts:110-127`).
    if call.callee is GenericInstExpr as gi {
        if gi.callee is IdentExpr as inner_id {
            sym_or_null :: ctx.typed.resolved.idents[inner_id.span.hash()]
            if sym_or_null is Symbol as raw_sym {
                fn_sym :: follow_import_binding(ctx, raw_sym)
                if i32(fn_sym.kind) == i32(SymbolKind.Fn) {
                    type_args: Type[] = []
                    for ta in gi.type_args {
                        resolved :: ctx.types.type_expr_type(ta)
                        if resolved is UnresolvedType {
                            type_args.push(type_from_expr(ta, ctx.typed.resolved, []))
                        } else {
                            type_args.push(resolved)
                        }
                    }
                    if all_concrete(type_args) {
                        return register_and_emit_generic_call(ctx, call, type, fn_sym, type_args, inner_id.span)
                    }
                }
            }
        }
    }
    callee_ident :: as_ident(call.callee)
    if callee_ident is null { return null }
    if callee_ident is IdentExpr as id {
        raw_sym :: ctx.typed.resolved.idents[id.span.hash()]
        if raw_sym is null { return null }
        if raw_sym is Symbol as raw_resolved {
            fn_sym :: follow_import_binding(ctx, raw_resolved)
            if i32(fn_sym.kind) != i32(SymbolKind.Fn) { return null }
            // Probe `decl_types` to find the fn's signature. Generic fns
            // record their type-param-bearing signature here.
            callee_ty :: ctx.types.expr_type(id)
            if !(callee_ty is FnType) { return null }
            if callee_ty is FnType as ft {
                if !type_has_param(ft) { return null }
                // Resolve concrete type args by unifying each
                // `ft.params[i]` (which carries the generic shape) with
                // the call arg's inferred concrete type. Each unique
                // TypeParam symbol in the fn's signature contributes one
                // entry to `concrete_args` in source-declared order.
                concrete_args :: infer_type_args(ft, call, ctx)
                if !all_concrete(concrete_args) { return null }
                // `owner_module` is the fn's defining module, NOT the
                // caller's (see `register_and_emit_generic_call` for the
                // rationale). Cross-module generic calls (snippet's
                // `main` invoking `println` from std/io) need the fn's
                // module so `build_fn_instance_decl` finds the AST decl.
                module_id :: fn_sym.module
                display :: lookup_module_display_path(ctx, module_id)
                mod_mangle :: mangle_module_id_local(if display == null { module_id } else { display })
                suffix :: mono_suffix(concrete_args)
                mangled :: "${mod_mangle}$${mod_mangle}$${fn_sym.name}${suffix}"
                // Register the instance for materialisation at the end
                // of `lower_project`. Dedup by `<symbol.id>::<suffix>` ;
                // `fn_instances_order` preserves insertion order for
                // deterministic dump output.
                inst_key :: "${fn_sym.id}::${suffix}"
                if ctx.project.fn_instances[inst_key] is null {
                    new_inst :: GenericFnInstance {
                        .fn_symbol    = fn_sym,
                        .type_args    = concrete_args,
                        .mangled      = mangled,
                        .owner_module = module_id,
                    }
                    ctx.project.fn_instances[inst_key] = new_inst
                    ctx.project.fn_instances_order.push(new_inst)
                }
                // Build args first ; the callee's mangled symbol is the
                // monomorphic instance. A raw array flowing into an
                // `Iterator(T)` param coerces through `into` (→
                // `ArrayIterator(T)`), mirroring the non-generic arg path.
                lowered_args: LoweredExpr[] = []
                for i in 0..<call.args.len() {
                    arg_lowered :: lower_expr(ctx, call.args[i].value)
                    if i >= ft.params.len() {
                        lowered_args.push(arg_lowered)
                    } else {
                        coerced :: try_emit_into_coercion(ctx, arg_lowered, type_of(arg_lowered), ft.params[i], call.args[i].value.span)
                        if coerced == null { lowered_args.push(arg_lowered) } else { lowered_args.push(coerced) }
                    }
                }
                // The callee must carry `fn_sym.id` : the materialised
                // instance registers in `function_index_by_symbol_id` under
                // its origin symbol (= `fn_sym`), so a call keyed on a
                // placeholder id (`0`) misses and the call is silently
                // dropped. (Single-instance resolution ; multi-instance of
                // the same generic still collapses to the last-registered
                // instance — needs per-instance keying, separate.)
                mono_sym :: Symbol {
                    .id         = fn_sym.id,
                    .kind       = SymbolKind.Fn,
                    .name       = mangled,
                    .module     = module_id,
                    .visibility = Visibility.Private,
                    .defined_at = null,
                }
                return LoweredCall {
                    .span = call.span, .type = type,
                    .callee = LoweredIdent {
                        .span = id.span, .type = type, .symbol = mono_sym,
                    },
                    .args = lowered_args,
                }
            }
        }
    }
    return null
}

// Shared emit for both bare-ident generic calls and explicit-args
// `fn<T>(args)` GenericInstExpr calls. Registers the GenericFnInstance
// and emits the LoweredCall pointing at the monomorphic mangled symbol.
register_and_emit_generic_call :: fn(
    ctx: FnLowerCtx, call: CallExpr, type: Type,
    fn_sym: Symbol, concrete_args: Type[], callee_span: Span,
) -> LoweredExpr {
    // `owner_module` is the fn's defining module, NOT the caller's —
    // `build_fn_instance_decl` looks up the AST decl in
    // `loaded.modules[owner_module]`, so picking the caller's module
    // for cross-module generic calls (`println` from a snippet's
    // `main`) sends the lookup to the wrong module → returns null →
    // instance never materialises → `emit_call_to_symbol` misses and
    // the call drops. Mirrors the harvest path at line 1372.
    module_id :: fn_sym.module
    display :: lookup_module_display_path(ctx, module_id)
    mod_mangle :: mangle_module_id_local(if display == null { module_id } else { display })
    suffix :: mono_suffix(concrete_args)
    mangled :: "${mod_mangle}$${mod_mangle}$${fn_sym.name}${suffix}"
    inst_key :: "${fn_sym.id}::${suffix}"
    if ctx.project.fn_instances[inst_key] is null {
        new_inst :: GenericFnInstance {
            .fn_symbol    = fn_sym,
            .type_args    = concrete_args,
            .mangled      = mangled,
            .owner_module = module_id,
        }
        ctx.project.fn_instances[inst_key] = new_inst
        ctx.project.fn_instances_order.push(new_inst)
    }
    lowered_args: LoweredExpr[] = []
    for ca in call.args { lowered_args.push(lower_expr(ctx, ca.value)) }
    mono_sym :: Symbol {
        .id         = fn_sym.id,
        .kind       = SymbolKind.Fn,
        .name       = mangled,
        .module     = module_id,
        .visibility = Visibility.Private,
        .defined_at = null,
    }
    return LoweredCall {
        .span = call.span, .type = type,
        .callee = LoweredIdent {
            .span = callee_span, .type = type, .symbol = mono_sym,
        },
        .args = lowered_args,
    }
}

infer_type_args :: fn(ft: FnType, call: CallExpr, ctx: FnLowerCtx) -> Type[] {
    // For each fn-param's generic shape, walk it and the matching
    // call-arg's concrete type in lock-step. The first time we see a
    // TypeParam symbol on the pattern side, record its concrete-side
    // counterpart. Repeated bindings of the same symbol must agree.
    bindings :: MutableMap<i32, Type> { .buckets = [], .size = 0 }
    order: i32[] = []
    n :: ft.params.len()
    if n > call.args.len() { return [] }
    for i in 0..<n {
        pattern :: ft.params[i]
        concrete :: default_if_free(ctx.types.expr_type(call.args[i].value))
        unify_params(pattern, concrete, bindings, order, ctx)
    }
    out: Type[] = []
    for id in order {
        v :: bindings[id]
        match v {
            is null -> {}
            // Apply the enclosing fn's substitution so a transitive
            // call inside an erased generic body (`outer<T>` calling
            // `inner_count(arr)`) resolves the inner type-arg through
            // `T -> Any`, yielding `inner_count__Any` rather than a
            // dangling `inner_count__T`. Mirror of TS' transitive mono
            // which substitutes call-site args under the outer subst.
            _ -> { out.push(substitute(v, ctx.subst)) }
        }
    }
    return out
}

unify_params :: fn(pattern: Type, concrete: Type, bindings: MutableMap<i32, Type>, order: i32[], ctx: FnLowerCtx) -> void {
    if pattern is TypeParamType as tp {
        existing :: bindings[tp.symbol.id]
        match existing {
            is null -> {
                bindings[tp.symbol.id] = concrete
                order.push(tp.symbol.id)
            }
            _ -> {}
        }
        return
    }
    if pattern is StructType as ps {
        if concrete is StructType as cs {
            n :: ps.args.len()
            for i in 0..<n {
                if i >= cs.args.len() { break }
                unify_params(ps.args[i], cs.args[i], bindings, order, ctx)
            }
        }
    }
    // Trait param vs concrete arg : recover the trait's generic args by
    // walking the impl table, then unify them with the pattern's args.
    // Mirror of TS `unifyTraitParamWithConcrete` (`unify.ts:101`). Drives
    // monomorphisation of `fn[T](it: Iterator(T))` etc. from any arg that
    // implements the trait (struct, primitive, raw array, or a value
    // already boxed into the trait type).
    if pattern is TraitType as ptr {
        trait_args :: trait_concrete_args(ptr, concrete, ctx)
        if trait_args != null {
            n :: ptr.args.len()
            for i in 0..<n {
                if i >= trait_args.len() { break }
                unify_params(ptr.args[i], trait_args[i], bindings, order, ctx)
            }
        }
    }
    if pattern is ArrayType as pa {
        if concrete is ArrayType as ca {
            unify_params(pa.element, ca.element, bindings, order, ctx)
        }
    }
    if pattern is FnType as pft {
        if concrete is FnType as cft {
            n :: pft.params.len()
            for i in 0..<n {
                if i >= cft.params.len() { break }
                unify_params(pft.params[i], cft.params[i], bindings, order, ctx)
            }
            unify_params(pft.return_type, cft.return_type, bindings, order, ctx)
        }
    }
    if pattern is TupleType as ptup {
        if concrete is TupleType as ctup {
            n :: ptup.elements.len()
            for i in 0..<n {
                if i >= ctup.elements.len() { break }
                unify_params(ptup.elements[i], ctup.elements[i], bindings, order, ctx)
            }
        }
    }
}

// Recover the concrete trait args for `concrete` viewed as `tt` (the
// trait pattern). Three sources, in order :
//   1. `concrete` is already the same trait (a boxed value) → its args.
//   2. A concrete `implements` recorded in `struct_trait_args`
//      (`Hello implements Greeter(i32)`, `i32 implements Doubler(i32)`).
//   3. The builtin `Iterator(T)` element : the first type-arg of a struct
//      iterator (`Range(i32)`, `ArrayIterator(i32)`) or a raw array's
//      element — covers generic impls whose recorded args are still
//      type-params, plus the `T[] → Iterator(T)` coercion that has no
//      impl decl. Returns `null` when no source resolves.
trait_concrete_args :: fn(tt: TraitType, concrete: Type, ctx: FnLowerCtx) -> Type[] | null {
    if concrete is TraitType as ct {
        if ct.symbol.name == tt.symbol.name { return ct.args }
        return null
    }
    recorded :: lookup_struct_trait_args(concrete, tt.symbol.name, ctx.typed)
    if recorded != null {
        if all_concrete(recorded) { return recorded }
    }
    if tt.symbol.name == "Iterator" && tt.args.len() == 1 {
        if concrete is StructType as st {
            if st.args.len() > 0 { return [st.args[0]] }
        }
        if concrete is ArrayType as ar {
            return [ar.element]
        }
    }
    return null
}

type_has_param :: fn(ft: FnType) -> bool {
    for p in ft.params {
        if type_contains_param(p) { return true }
    }
    return type_contains_param(ft.return_type)
}

type_contains_param :: fn(t: Type) -> bool {
    match t {
        is TypeParamType -> { return true }
        is StructType as s -> {
            for a in s.args { if type_contains_param(a) { return true } }
            return false
        }
        is TraitType as tr -> {
            for a in tr.args { if type_contains_param(a) { return true } }
            return false
        }
        is ArrayType as ar -> { return type_contains_param(ar.element) }
        is FnType as ft -> { return type_has_param(ft) }
        is TupleType as tup -> {
            for e in tup.elements { if type_contains_param(e) { return true } }
            return false
        }
        _ -> { return false }
    }
}

all_concrete :: fn(args: Type[]) -> bool {
    for a in args {
        if type_contains_param(a) { return false }
        if a is UnresolvedType { return false }
    }
    return true
}

mono_suffix :: fn(args: Type[]) -> string {
    sb := new_builder_for_mangle()
    for a in args {
        sb.append("__")
        sb.append(mangle_type_arg(a))
    }
    return sb.to_string()
}

mangle_module_id_local :: fn(module_id: string) -> string {
    sb := new_builder_for_mangle()
    for c in module_id {
        if c == '/' { sb.append_char('_') }
        else if c == '.' { sb.append_char('_') }
        else { sb.append_char(c) }
    }
    return sb.to_string()
}

as_field_expr :: fn(expr: Expr) -> FieldExpr | null {
    match expr {
        is FieldExpr as f -> { return f }
        _ -> { return null }
    }
}

/// `recv.method(args)` against a concrete-typed receiver (primitive,
/// struct, enum) lowers to a direct call when an impl member with the
/// matching name exists. The receiver becomes the first arg.
/// Mirror of `lowerUfcsCall` in `src/lower/passes/expr.ts` — runs after
/// the trait-virtual probe so virtual dispatch wins for trait-typed
/// receivers and UFCS picks up the concrete-type residue.
try_lower_ufcs_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    callee_field :: as_field_expr(call.callee)
    if callee_field is null { return null }
    if callee_field is FieldExpr as field_expr {
        receiver :: lower_expr(ctx, field_expr.target)
        recv_type :: type_of(receiver)
        // Trait-typed receivers route through vcall (handled above).
        if recv_type is TraitType { return null }
        // Impl-member path first (e.g. `x.to_string()` over
        // `i32 implements Display { to_string }`).
        member :: find_impl_member_for(ctx, recv_type, field_expr.field)
        if !(member is null) {
            if member is UfcsMember as found {
                args: LoweredExpr[] = []
                args.push(receiver)
                for call_arg in call.args { args.push(lower_expr(ctx, call_arg.value)) }
                return LoweredCall {
                    .span = call.span, .type = type,
                    .callee = LoweredIdent {
                        .span = field_expr.span, .type = type, .symbol = found.symbol,
                    },
                    .args = args,
                }
            }
        }
        // Free-fn UFCS : look in `resolved.fn_overloads` for a fn whose
        // first param's nominal type matches the receiver's surface name.
        // Covers `a.inc()` over an `inc :: fn(self: A) -> i32` free fn.
        free :: find_free_fn_ufcs(ctx, recv_type, field_expr.field)
        if !(free is null) {
            if free is UfcsMember as found_free {
                args: LoweredExpr[] = []
                args.push(receiver)
                for call_arg in call.args { args.push(lower_expr(ctx, call_arg.value)) }
                // UFCS-on-generic-fn instance harvest : when the target
                // is `fn[T](x: T) -> T`, register a `GenericFnInstance` so
                // `materialize_generic_fn_instances` emits the body, and point
                // the callee at the resulting monomorphic mangle (mirror of
                // `register_and_emit_generic_call`'s ident path). A non-generic
                // target returns null → keep the plain resolver symbol.
                mangled :: harvest_ufcs_fn_instance(ctx, found_free.symbol, recv_type, call.args)
                callee_sym :: if mangled == null { found_free.symbol } else {
                    Symbol {
                        .id         = found_free.symbol.id,
                        .kind       = SymbolKind.Fn,
                        .name       = mangled,
                        .module     = found_free.symbol.module,
                        .visibility = Visibility.Private,
                        .defined_at = null,
                    }
                }
                return LoweredCall {
                    .span = call.span, .type = type,
                    .callee = LoweredIdent {
                        .span = field_expr.span, .type = type, .symbol = callee_sym,
                    },
                    .args = args,
                }
            }
        }
    }
    return null
}

find_free_fn_ufcs :: fn(ctx: FnLowerCtx, recv_type: Type, name: string) -> UfcsMember | null {
    // Unions have no nominal surface name ; they still dispatch UFCS to a
    // free fn whose first param is the same union (`shape.describe()` ->
    // `describe(shape: Shape)`). `first_param_matches` handles both the
    // name and the structural-union case, so don't bail on empty name
    // unless the receiver is neither nominal nor a union.
    recv_name :: type_surface_name(recv_type)
    if recv_name == "" && !(recv_type is UnionType) { return null }
    overloads :: ctx.typed.resolved.fn_overloads[name]
    if overloads is Symbol[] as symbols {
        for sym in symbols {
            if first_param_matches(ctx, sym, recv_type) {
                return UfcsMember { .symbol = sym }
            }
        }
    }
    // Imported free fn — `import "p" { name }` registers `name` in
    // `symbols` as an ImportBinding but not in `fn_overloads`. Follow
    // the import target to the source symbol and probe its signature.
    for candidate in ctx.typed.resolved.symbols {
        if candidate.name != name { continue }
        if i32(candidate.kind) != i32(SymbolKind.ImportBinding) { continue }
        target :: follow_import_binding(ctx, candidate)
        if i32(target.kind) == i32(SymbolKind.Fn) {
            if first_param_matches(ctx, target, recv_type) {
                return UfcsMember { .symbol = target }
            }
        }
    }
    // Cross-module free fn — `s.len()` against `MutableSet`'s
    // `len :: fn[T](self: MutableSet(T)) -> usize` defined in
    // `stdlib/std/collections.vader` even though the user file never
    // `import`s `len`. Mirror of TS's `inferField` which scans every
    // loaded module's exports via `fieldRefs` (`ufcs-free` ref).
    for module_id in ctx.project.evaluated.modules.keys() {
        program :: ctx.project.evaluated.modules[module_id]
        if program is null { continue }
        if program is EvaluatedProgram as ep {
            bucket :: ep.typed.resolved.fn_overloads[name]
            if bucket is Symbol[] as bucket_syms {
                for sym in bucket_syms {
                    if first_param_matches(ctx, sym, recv_type) {
                        return UfcsMember { .symbol = sym }
                    }
                }
            }
        }
    }
    return null
}

first_param_matches :: fn(ctx: FnLowerCtx, sym: Symbol, recv_type: Type) -> bool {
    // Match the fn's first param against the receiver. A `TypeParam`
    // first param matches any receiver (`identity[T](x: T)`) ; a union
    // receiver matches via `is_assignable` (mirrors the typer's
    // `receiver_fits_first_param`, so lower agrees with what typecheck
    // accepted) ; otherwise match by nominal surface name.
    fn_ty :: lookup_fn_type_anywhere(ctx, sym)
    if fn_ty is FnType as ft {
        if ft.params.len() == 0 { return false }
        first :: ft.params[0]
        if first is TypeParamType { return true }
        if recv_type is UnionType { return is_assignable(recv_type, first, null) }
        // Trait-typed first param (`filter(it: Iterator<T>, …)`) matches a
        // concrete receiver that implements the trait (`StringChars`
        // implements `Iterator<char>`). Consult the project-wide impl
        // registry so cross-module stdlib impls are reachable.
        if first is TraitType as tt {
            return find_impl_for(ctx.project, recv_type, tt.symbol.name) != null
        }
        return type_surface_name(first) == type_surface_name(recv_type)
    }
    return false
}

/// Record a non-generic stdlib free fn for end-of-project
/// materialization. No-op for user-module fns (already lowered) and for
/// fns already harvested. Dedup by `fn_symbol.id`.
register_nongeneric_stdlib_fn :: fn(ctx: FnLowerCtx, fn_sym: Symbol) -> void {
    if i32(fn_sym.kind) != i32(SymbolKind.Fn) { return }
    if !is_stdlib_path(fn_sym.module) { return }
    if ctx.project.nongeneric_stdlib_fns[fn_sym.id] != null { return }
    // Generic fns route through the GenericFnInstance harvest instead.
    fn_ty :: lookup_fn_type_anywhere(ctx, fn_sym)
    if fn_ty is FnType as ft {
        if type_has_param(ft) { return }
    }
    ctx.project.nongeneric_stdlib_fns[fn_sym.id] = true
    ctx.project.nongeneric_stdlib_order.push(fn_sym)
}

/// Register a `GenericFnInstance` for a UFCS-resolved generic free fn.
/// Mirrors the harvest in `try_lower_generic_fn_call` for the
/// ident-call path. The receiver type binds the first param ; the
/// remaining call args bind subsequent params. Idempotent on the
/// `<symbol.id>::<args_suffix>` key.
// Harvest a UFCS call's generic-fn instance and return the monomorphic
// mangle the call site must point at (`null` when the target is non-generic,
// so the caller keeps the plain resolver symbol). Without returning the
// mangle the UFCS call site would emit a bare resolver-symbol callee that
// resolves to no fn-table entry — the emit drops it to its defensive
// `Return` (every `recv.generic_fn()` call silently mis-compiled).
harvest_ufcs_fn_instance :: fn(
    ctx: FnLowerCtx, fn_sym: Symbol, recv_type: Type, ast_args: CallArg[],
) -> string | null {
    // Locate the fn's FnType — UFCS resolution tolerates fns defined
    // in foreign modules (e.g. stdlib's `len`).
    fn_ty :: lookup_fn_type_anywhere(ctx, fn_sym)
    if fn_ty is null { return null }
    if fn_ty is FnType as ft {
        if !type_has_param(ft) {
            // Non-generic free fn. User-module ones are lowered by
            // `lower_module` already ; stdlib ones have their bodies
            // skipped (`is_stdlib_path`), so harvest them for
            // `materialize_nongeneric_stdlib_fns` — otherwise the call
            // is dropped (no fn-table entry).
            register_nongeneric_stdlib_fn(ctx, fn_sym)
            return null
        }
        if ft.params.len() == 0 { return null }
        bindings :: MutableMap<i32, Type> { .buckets = [], .size = 0 }
        order: i32[] = []
        unify_params(ft.params[0], default_if_free(recv_type), bindings, order, ctx)
        n :: ft.params.len()
        for i in 1..<n {
            ai :: i - 1
            if ai >= ast_args.len() { break }
            concrete :: default_if_free(ctx.types.expr_type(ast_args[ai].value))
            unify_params(ft.params[i], concrete, bindings, order, ctx)
        }
        concrete_args: Type[] = []
        for id in order {
            v :: bindings[id]
            match v {
                is null -> { return null }
                _ -> { concrete_args.push(v) }
            }
        }
        if !all_concrete(concrete_args) { return null }
        suffix :: mono_suffix(concrete_args)
        inst_key :: "${fn_sym.id}::${suffix}"
        owner_module :: fn_sym.module
        // Use the owning module's *display* path (the declared
        // `module "..."` name) for the mangle, not its filesystem
        // id. Matches the direct-call path at line 775 and TS'
        // `program.module.displayPath` in `src/comptime/specialize.ts:384`.
        // Falls back to fn_sym.module when the lookup misses (defensive).
        display :: lookup_module_display_path(ctx, owner_module)
        mod_mangle :: mangle_module_id_local(if display == null { owner_module } else { display })
        mangled :: "${mod_mangle}$${mod_mangle}$${fn_sym.name}${suffix}"
        // Record the instance once ; return the mangle on every call so the
        // call site can target it even when a sibling call already harvested.
        if ctx.project.fn_instances[inst_key] is null {
            new_inst :: GenericFnInstance {
                .fn_symbol    = fn_sym,
                .type_args    = concrete_args,
                .mangled      = mangled,
                .owner_module = owner_module,
            }
            ctx.project.fn_instances[inst_key] = new_inst
            ctx.project.fn_instances_order.push(new_inst)
        }
        return mangled
    }
    return null
}

// Look up an evaluated module's `display_path` (the declared
// `module "..."` name) from its module id. Returns null when the
// module isn't in the evaluated project — callers default to the
// raw module id in that case.
lookup_module_display_path :: fn(ctx: FnLowerCtx, module_id: string) -> string | null {
    program :: ctx.project.evaluated.modules[module_id]
    if program is EvaluatedProgram as ep { return ep.typed.resolved.display_path }
    return null
}

// Find a field's static type on a struct receiver. Used by the
// `@field(target, "name")` fold to refine the result type when the
// typer left it Unresolved (`@comptime for f in @fields(T)` paths
// where the field name is only known post-substitution). Walks the
// receiver's struct decl, applies the struct's type-arg substitution
// to the field's TypeExpr.
resolve_field_type :: fn(ctx: FnLowerCtx, target_arg: Expr, field_name: string) -> Type {
    recv_ty :: ctx.types.expr_type(target_arg)
    if recv_ty is StructType as st {
        decl :: ctx.typed.struct_decls[st.symbol.id]
        if decl is null { return TY_UNRESOLVED }
        if decl is StructDecl as sd {
            for f in sd.fields {
                if f.name != field_name { continue }
                raw :: type_from_expr(f.ty, ctx.typed.resolved, [])
                return substitute_by_name(raw, sd.type_params, st.args)
            }
        }
    }
    return TY_UNRESOLVED
}

lookup_fn_type_anywhere :: fn(ctx: FnLowerCtx, sym: Symbol) -> Type | null {
    // `Symbol.module` carries the owning module id — direct lookup
    // beats walking every evaluated module per UFCS call site.
    program :: ctx.project.evaluated.modules[sym.module]
    if program is null { return null }
    if program is EvaluatedProgram as ep { return ep.typed.decl_types[sym.id] }
    return null
}

UfcsMember :: struct {
    symbol: Symbol
}

find_impl_member_for :: fn(ctx: FnLowerCtx, target_type: Type, method_name: string) -> UfcsMember | null {
    target_name :: type_surface_name(target_type)
    if target_name == "" { return null }
    for entry in ctx.project.impls.all {
        decl :: entry.decl
        if !impl_targets_name(decl.for_type, target_name) { continue }
        for m in decl.members {
            if m.name != method_name { continue }
            // Synthesise a Fn symbol carrying the member's deterministic
            // mangle so the call site resolves to the synth decl's mangle
            // index (`function_index_by_mangle`, consulted first in the CFG
            // call emit). The `id = 0` placeholder is harmless : the mangle
            // path resolves before the symbol-id lookup ever runs.
            //
            // The module prefix is the IMPL's owning module (`entry.module`),
            // NOT the caller's (`ctx`). For an intrinsic like `string
            // implements Display` reached from `println` in std/io, the
            // mangle must read `std_core$…`, matching where the impl is
            // declared / its surfaced decl is registered (GATE B). Same-module
            // user impls are unaffected (entry.module == ctx's module).
            //
            // NOTE : this mangle omits the overload `${suffix}` that
            // `impl_member_mangled` (lower.vader) appends to disambiguate
            // multiple impls of the same trait/method on one type. Calls to
            // such overloaded impl members would miss — see audit follow-up.
            //
            // Suffix : a generic-struct receiver picks up the materialised
            // member's instance suffix. The materialiser erases the args to
            // `Any` for generic impls (`Range<i32>` → `count__Any`) so the
            // shared erased body's sibling self-calls resolve to one name ;
            // concrete-instantiation impls keep the concrete suffix
            // (`Wrapper<i32>` → `count__i32`). Primitive receivers
            // (`string implements Display`) have no args → empty suffix.
            recv_suffix :: match target_type {
                is StructType as s -> {
                    // Generic impl : structure-free `__Any` × arity so the
                    // call-site name matches the single deduped body
                    // regardless of the receiver's concrete args (see
                    // `flat_any_suffix`). Concrete-instantiation impls keep
                    // their concrete args.
                    if entry.is_generic {
                        mixed_any_suffix(s.args)
                    } else {
                        args_suffix(s.args)
                    }
                }
                // Blanket array impl (`T[] implements Contains`) : materialise
                // one CONCRETE body per element type (`contains__i32`) so the
                // member's `==` devirtualises to the element primop — distinct
                // from the struct generic-erasure path (`__Any`).
                is ArrayType as a -> args_suffix([a.element])
                _ -> ""
            }
            mangled :: "${mangle_module_id(entry.module)}$${target_name}$${decl.trait_name}$${m.name}${recv_suffix}"
            // Record the call so the post-lowering pass surfaces referenced
            // stdlib impl members : bodyless (`@intrinsic`) → import ; with-body
            // (e.g. `i32 implements Hash -> u64(self)`) → materialised real fn.
            ctx.project.referenced_impl_mangles.add(mangled)
            // Blanket array impl (`T[] implements Contains`) : the generic-impl
            // materialiser is struct-instance-driven and never reaches an array
            // receiver, so record the element type keyed by this call-site
            // mangle. `surface_array_contains_members` materialises one concrete
            // body per element (substituting `T → element` so `==` devirtualises).
            if target_type is ArrayType as arr_ty {
                ctx.project.array_contains_elems[mangled] = arr_ty.element
            }
            return UfcsMember {
                .symbol = Symbol {
                    .id         = i32(0),
                    .kind       = SymbolKind.Fn,
                    .name       = mangled,
                    .module     = ctx.typed.resolved.path,
                    .visibility = Visibility.Private,
                    .defined_at = null,
                },
            }
        }
    }
    return null
}

// Nominal token a receiver type registers UFCS impls under. Exhaustive over
// `Type` (no `_`) : the non-nominal shapes (fn / union / trait / type-param /
// meta / self / unresolved / free-numeric / never / any) have no single
// surface name and resolve through other paths, so they map to "" explicitly —
// listing them trips T3013 if a new *nominal* Type variant is added that ought
// to carry a UFCS surface.
type_surface_name :: fn(t: Type) -> string = match t {
    is PrimitiveType as p -> p.name
    is StructType    as s -> s.symbol.name
    is EnumType      as e -> e.symbol.name
    // Generic-shape pattern + concrete receiver agree on a canonical token :
    // `T[]` and `i32[]` both surface as `[]` for UFCS lookup.
    is ArrayType          -> "[]"
    is TupleType          -> "()"
    is FnType             -> ""
    is UnionType          -> ""
    is TraitType          -> ""
    is TypeParamType      -> ""
    is TypeMetaType       -> ""
    is SelfType           -> ""
    is UnresolvedType     -> ""
    is FreeIntType        -> ""
    is FreeFloatType      -> ""
    is NeverType          -> ""
    is AnyType            -> ""
}


impl_targets_name :: fn(for_type: Expr, name: string) -> bool {
    match for_type {
        is IdentExpr        as e -> { return e.name == name }
        is GenericInstExpr  as gi -> {
            match gi.callee {
                is IdentExpr as inner -> { return inner.name == name }
                _ -> { return false }
            }
        }
        // Blanket array impl (`T[] implements ...`) — its for_type is an
        // ArrayTypeExpr ; `type_surface_name` maps every array to `"[]"`.
        is ArrayTypeExpr -> { return name == "[]" }
        _ -> { return false }
    }
}

mangle_module_id :: fn(module_id: string) -> string {
    sb := new_builder_for_mangle()
    for c in module_id {
        if c == '/' { sb.append_char('_') }
        else if c == '.' { sb.append_char('_') }
        else { sb.append_char(c) }
    }
    return sb.to_string()
}

import "std/string_builder" { new_builder as new_builder_for_mangle, append_char, append }
import "std/sort" { sort }
import "std/string" { compare_ascending }

/// `T(value)` cast-call detector. Returns a `LoweredCast` when the callee
/// is a type-shaped symbol (builtin primitive, struct, or type alias) with
/// a single arg. For non-numeric targets the typer already routed the arg
/// through `tryInto` ; we emit the lowered arg verbatim. Mirror of
/// `lowerCall`'s cast branch in `src/lower/passes/expr.ts:62-83`.
try_lower_cast_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    if call.args.len() != usize(1) { return null }
    callee_ident :: as_ident(call.callee)
    if callee_ident is null { return null }
    callee_symbol :: ctx.typed.resolved.idents[callee_ident.span.hash()]
    if callee_symbol is null { return null }
    is_type_shaped :: match callee_symbol.kind {
        .BuiltinType -> true
        .Struct      -> true
        .TypeAlias   -> true
        _            -> false
    }
    if !is_type_shaped { return null }
    arg :: lower_expr(ctx, call.args[0].value)
    arg_type :: type_of(arg)
    // `Target(value)` probes for `value : Source` where
    // `Source implements Into[Target]`. When the Into impl exists, the
    // typer's `tryInto` lifts `value` to `into(value)` ; we recreate
    // that lift at lower time. The numeric-primitive cast then wraps
    // the lifted call for byte-parity (`cast → i32 / call into(u)`).
    coerced :: try_emit_into_coercion(ctx, arg, arg_type, type, call.span)
    inner :: match coerced {
        is null -> arg
        _ -> coerced
    }
    if type is PrimitiveType as pt {
        if pt.name == "string" || pt.name == "bool" || pt.name == "void" || pt.name == "null" {
            return inner
        }
        return LoweredCast { .span = call.span, .type = type, .value = inner }
    }
    return inner
}

// Build a `into(arg)` call whose callee is the synthetic `into`
// fn-symbol. Shared by the array→Iterator coercion and the user-`Into`
// impl path ; they differ only in the result `type` and the arg.
mk_into_call :: fn(ctx: FnLowerCtx, arg: LoweredExpr, result_type: Type, span: Span) -> LoweredCall {
    return LoweredCall {
        .span = span, .type = result_type,
        .callee = LoweredIdent {
            .span = span, .type = result_type,
            .symbol = Symbol {
                .id = i32(0), .kind = SymbolKind.Fn, .name = "into",
                .module = ctx.typed.resolved.path,
                .visibility = Visibility.Private, .defined_at = null,
            },
        },
        .args = [arg],
    }
}

// `T[] -> Iterator<T>` value-slot coercion. Returns `into(arr)` typed
// `ArrayIterator<T>`, or null when the shapes don't match / ArrayIterator
// isn't loaded. The `into` symbol routes to std/core's blanket
// `T[] implements Into<Iterator<T>>` member at codegen. The for-in path
// inlines an `ArrayIterator` struct lit instead ; value slots take this
// call shape (mirror of TS' arrayIter coercion).
try_array_iter_coercion :: fn(
    ctx: FnLowerCtx, arg: LoweredExpr, arg_type: Type, target_type: Type, span: Span,
) -> LoweredExpr | null {
    if arg_type is ArrayType as arr {
        if target_type is TraitType as tt {
            if tt.symbol.name != "Iterator" { return null }
            if tt.args.len() != usize(1) { return null }
            result_type :: find_core_type(ctx, STRUCT_ARRAY_ITERATOR, [arr.element])
            if result_type != null { return mk_into_call(ctx, arg, result_type, span) }
        }
    }
    return null
}

/// `Target(value)` where `value : Source` and `Source implements Into[Target]`
/// emits `LoweredCall { callee: into, args: [value] }`. Mirror of the typer's
/// `tryInto` coercion path in TS.
try_emit_into_coercion :: fn(
    ctx: FnLowerCtx, arg: LoweredExpr, arg_type: Type, target_type: Type, span: Span,
) -> LoweredExpr | null {
    // Built-in array→Iterator coercion ; arrays have no nominal surface
    // name, so it must precede the name-keyed impl scan below.
    array_iter :: try_array_iter_coercion(ctx, arg, arg_type, target_type, span)
    if array_iter != null { return array_iter }
    src_name :: type_surface_name(arg_type)
    if src_name == "" { return null }
    // Find `Source implements Into[Target] { into }`. The decl carries
    // `trait_name = "Into"` and a single trait_arg the surface name of
    // which must equal target_type's surface name.
    target_name :: type_surface_name(target_type)
    if target_name == "" { return null }
    // Identity-coercion guard : `T(value)` where `value: T` is a no-op
    // ; never inject `into(self)` against the surrounding type.
    if src_name == target_name { return null }
    for entry in ctx.project.impls.all {
        decl :: entry.decl
        if decl.trait_name != "Into" { continue }
        if !impl_targets_name(decl.for_type, src_name) { continue }
        if !impl_trait_first_arg_is(decl, target_name) { continue }
        for m in decl.members {
            if m.name != "into" { continue }
            return mk_into_call(ctx, arg, target_type, span)
        }
    }
    return null
}

impl_trait_first_arg_is :: fn(decl: ImplDecl, name: string) -> bool {
    if decl.trait_args.len() == 0 { return false }
    arg :: decl.trait_args[0]
    return impl_targets_name(arg, name)
}

// Detect `<namespace_ident>.<member>(args)`. The target ident's
// resolved symbol has kind `ImportBinding` (namespace import). Emit
// a direct call to the imported member by name — the dump format
// shows just the bare callee name, matching TS's behaviour for
// namespace-prefixed calls.
try_lower_namespace_call :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    callee :: call.callee
    match callee {
        is FieldExpr as field_expr -> {
            target_ident :: as_ident(field_expr.target)
            if target_ident is null { return null }
            namespace_symbol :: ctx.typed.resolved.idents[target_ident.span.hash()]
            if namespace_symbol is null { return null }
            if i32(namespace_symbol.kind) != i32(SymbolKind.ImportBinding) { return null }
            member_symbol :: synth_namespace_member(ctx, field_expr.field, type)
            args: LoweredExpr[] = []
            for call_arg in call.args { args.push(lower_expr(ctx, call_arg.value)) }
            return LoweredCall {
                .span = call.span, .type = type,
                .callee = LoweredIdent {
                    .span = field_expr.span, .type = type, .symbol = member_symbol,
                },
                .args = args,
            }
        }
        _ -> { return null }
    }
}

as_ident :: fn(expr: Expr) -> IdentExpr | null {
    match expr {
        is IdentExpr as ident -> { return ident }
        _ -> { return null }
    }
}

synth_namespace_member :: fn(ctx: FnLowerCtx, name: string, type: Type) -> Symbol {
    return Symbol {
        .id         = i32(0),
        .kind       = SymbolKind.Fn,
        .name       = name,
        .module     = ctx.typed.resolved.path,
        .visibility = Visibility.Private,
        .defined_at = null,
    }
}


// `s.bytes().len()` → `byte_len(s)`. Returns the rewritten call when
// `target` is a direct `std/string::bytes` call (a bound view is a
// `LoweredIdent` and doesn't match), else null so the caller falls back to
// `LoweredArrayLen`. The internal `byte_len` host fn is resolved from
// std/string's symbol table.
fold_bytes_len :: fn(ctx: FnLowerCtx, target: LoweredExpr, span: Span) -> LoweredExpr | null {
    // Cheap structural gate first — short-circuits the vast majority of
    // `.len()` sites (plain arrays) before touching the symbol table.
    if target is LoweredCall as lc {
        if lc.callee is LoweredIdent as ci {
            if lc.args.len() == 1 {
                strs :: ctx.project.string_symbols
                if strs == null { return null }
                bytes_sym :: strs["bytes"]
                byte_len_sym :: strs["byte_len"]
                if bytes_sym == null { return null }
                if byte_len_sym == null { return null }
                // The call site may carry an import-binding symbol ; resolve
                // it to the canonical std/string `bytes` before comparing.
                resolved_callee :: follow_import_binding(ctx, ci.symbol)
                if resolved_callee.id == bytes_sym.id {
                    return LoweredCall {
                        .span = span, .type = mk_primitive("usize"),
                        .callee = LoweredIdent {
                            .span = span,
                            .type = mk_fn([mk_primitive("string")], mk_primitive("usize")),
                            .symbol = byte_len_sym,
                        },
                        .args = [lc.args[0]],
                    }
                }
            }
        }
    }
    return null
}

// Detect `arr.push(x)` / `arr.len()` and emit the dedicated op. Returns
// null when the receiver isn't an array or the field isn't a recognised
// array intrinsic — caller falls back to the generic call path.
try_lower_array_op :: fn(ctx: FnLowerCtx, call: CallExpr, type: Type) -> LoweredExpr | null {
    callee :: call.callee
    match callee {
        is FieldExpr as field_expr -> {
            target_type :: ctx.types.expr_type(field_expr.target)
            match target_type {
                is ArrayType -> {
                    if field_expr.field == "len" && call.args.len() == 0 {
                        len_target :: lower_expr(ctx, field_expr.target)
                        // `s.bytes().len()` → `byte_len(s)` : fold the inline
                        // form to the O(1) host primitive so it doesn't alloc a
                        // borrowed-view header just to read the length. Held
                        // views (`bs.len()`) have a `LoweredIdent` target and
                        // don't match.
                        folded :: fold_bytes_len(ctx, len_target, call.span)
                        if folded != null { return folded }
                        return LoweredArrayLen {
                            .span = call.span, .type = mk_primitive("usize"),
                            .target = len_target,
                        }
                    }
                    if field_expr.field == "push" && call.args.len() == 1 {
                        return LoweredArrayPush {
                            .span = call.span, .type = mk_primitive("void"),
                            .target = lower_expr(ctx, field_expr.target),
                            .value  = lower_expr(ctx, call.args[0].value),
                        }
                    }
                    return null
                }
                _ -> { return null }
            }
        }
        _ -> { return null }
    }
}

lower_binary :: fn(ctx: FnLowerCtx, binary: BinaryExpr, type: Type) -> LoweredExpr {
    // `expr is T` lowers to a runtime tag check ; the RHS is a type
    // expression, not a value. The `bind_as` parsing is handled inside
    // `if x is T as alias` where the if's then-branch consumes the
    // alias — that path lives in the typechecker's narrowing logic
    // and lowers to a regular `LoweredCast` reaching the alias slot.
    if i32(binary.op) == i32(BinaryOp.Is) {
        return LoweredTypeCheck {
            .span = binary.span, .type = TY_BOOL,
            .value = lower_expr(ctx, binary.left),
            .check_type = ctx.types.expr_type(binary.right),
        }
    }
    if i32(binary.op) == i32(BinaryOp.In) || i32(binary.op) == i32(BinaryOp.NotIn) {
        // `x in coll` → `coll.contains(x)`. `x !in coll` → `!coll.contains(x)`.
        // The Contains impl on `coll`'s type provides the `contains`
        // member ; the existing `find_impl_member_for` UFCS lookup
        // covers struct receivers (`MutableMap`, `MutableSet`, …) and
        // primitive ones (`Range<T> implements Contains<T>` via the
        // intrinsic decl in std/core). Mirror of TS' `lowerInOp`
        // (`src/lower/passes/expr.ts:927`).
        coll_type :: ctx.types.expr_type(binary.right)
        member :: find_impl_member_for(ctx, coll_type, "contains")
        if member is UfcsMember as found {
            args: LoweredExpr[] = []
            args.push(lower_expr(ctx, binary.right))
            args.push(lower_expr(ctx, binary.left))
            call :: LoweredCall {
                .span = binary.span, .type = TY_BOOL,
                .callee = LoweredIdent {
                    .span = binary.span, .type = TY_BOOL, .symbol = found.symbol,
                },
                .args = args,
            }
            if i32(binary.op) == i32(BinaryOp.NotIn) {
                return LoweredUnary {
                    .span = binary.span, .type = TY_BOOL,
                    .op = LoweredUnaryOp.Not, .operand = call,
                }
            }
            return call
        }
        return stub(binary.span, type, "`in` / `not in` lowering deferred")
    }
    // `<union>` `==` / `!=` `null` reduces to a tag-only `LoweredTypeCheck`.
    // The C/VM emit can't compare two `vader_box_t` directly anyway and
    // the type-check is the operation we actually want. Mirror of
    // `lowerBinary`'s null-eq branch in `expr.ts:677-693`.
    if i32(binary.op) == i32(BinaryOp.Eq) || i32(binary.op) == i32(BinaryOp.Neq) {
        null_rewrite :: try_lower_null_eq(ctx, binary)
        match null_rewrite {
            is null -> {}
            _ -> { return null_rewrite }
        }
    }
    // Arithmetic + / − / × / ÷ on a user struct with a matching impl
    // (`Vec implements Add { add(self, other) }` etc.) lowers to a
    // direct call `add(a, b)`. Mirror of TS's `binaryOpResolutions`
    // dispatch in `src/lower/passes/expr.ts:715-738`.
    op_call :: try_lower_op_overload(ctx, binary, type)
    match op_call {
        is null -> {}
        _ -> { return op_call }
    }
    return LoweredBinary {
        .span = binary.span, .type = type,
        .op    = lower_binary_op(binary.op),
        .left  = lower_expr(ctx, binary.left),
        .right = lower_expr(ctx, binary.right),
    }
}

try_lower_op_overload :: fn(ctx: FnLowerCtx, binary: BinaryExpr, type: Type) -> LoweredExpr | null {
    info :: op_trait_method(binary.op)
    if info is null { return null }
    if info is OpTraitInfo as oti {
        left_ty :: ctx.types.expr_type(binary.left)
        // TypeParam-bound + erased Any receivers route through
        // virtual dispatch — the boxed value's tag picks the right
        // impl at runtime. Same shape as the FieldExpr path in
        // `try_lower_virtual_call`, just driven from a BinaryOp.
        // For Eq, the call's value IS the bool result. For Neq we
        // wrap in `not`. For Lt/Lte/Gt/Gte, we keep the outer
        // BinaryOp with the call as left + `0` as right (compare
        // returns i32).
        if left_ty is TypeParamType || left_ty is AnyType {
            return lower_op_overload_via_vcall(ctx, binary, type, oti)
        }
        left_name :: type_surface_name(left_ty)
        if left_name == "" { return null }
        // Primitive operands stay on the built-in path — primitives
        // have their own arithmetic / comparison ops.
        if left_ty is PrimitiveType { return null }
        member :: find_impl_member_for(ctx, left_ty, oti.method_name)
        if member is null { return null }
        // Verify the impl actually targets `oti.trait_name` — UFCS
        // lookup is name-based and could match a same-named member
        // on a different trait.
        if !impl_provides(ctx, left_ty, oti.trait_name, oti.method_name) { return null }
        if member is UfcsMember as found {
            lowered_left  :: lower_expr(ctx, binary.left)
            lowered_right :: lower_expr(ctx, binary.right)
            call_args: LoweredExpr[] = []
            call_args.push(lowered_left)
            call_args.push(lowered_right)
            if i32(oti.shape) == i32(OpShape.DirectCall) {
                // Arithmetic + Equals : returns the binary's static type.
                return LoweredCall {
                    .span = binary.span, .type = type,
                    .callee = LoweredIdent {
                        .span = binary.span, .type = type, .symbol = found.symbol,
                    },
                    .args = call_args,
                }
            }
            if i32(oti.shape) == i32(OpShape.NotCall) {
                // `a != b` → `not(equals(a, b))`.
                equals_call :: LoweredCall {
                    .span = binary.span, .type = TY_BOOL,
                    .callee = LoweredIdent {
                        .span = binary.span, .type = TY_BOOL, .symbol = found.symbol,
                    },
                    .args = call_args,
                }
                return LoweredUnary {
                    .span = binary.span, .type = TY_BOOL,
                    .op = LoweredUnaryOp.Not, .operand = equals_call,
                }
            }
            // OpShape.CompareCmp : `a < b` → `(compare(a, b)) < 0`, same
            // for <= / > / >=. The outer BinaryOp matches `binary.op`.
            compare_call :: LoweredCall {
                .span = binary.span, .type = mk_primitive("i32"),
                .callee = LoweredIdent {
                    .span = binary.span, .type = mk_primitive("i32"), .symbol = found.symbol,
                },
                .args = call_args,
            }
            return LoweredBinary {
                .span = binary.span, .type = TY_BOOL,
                .op    = lower_binary_op(binary.op),
                .left  = compare_call,
                .right = LoweredIntLit {
                    .span = binary.span, .type = mk_primitive("i32"), .value = i64(0),
                },
            }
        }
        return null
    }
    return null
}

// Emit `a op b` as a virtual call (the receiver is TypeParam-bound or
// erased to Any). Shape mirrors the field-expr vcall path : Eq /
// Comparable share the dispatch + outer-op patterns from `op_trait_method`.
lower_op_overload_via_vcall :: fn(
    ctx: FnLowerCtx, binary: BinaryExpr, type: Type, oti: OpTraitInfo,
) -> LoweredExpr | null {
    lowered_left  :: lower_expr(ctx, binary.left)
    lowered_right :: lower_expr(ctx, binary.right)
    args: LoweredExpr[] = []
    args.push(lowered_right)
    call :: LoweredVirtualCall {
        .span = binary.span,
        .type = if i32(oti.shape) == i32(OpShape.CompareCmp) { mk_primitive("i32") } else { TY_BOOL },
        .trait_name = oti.trait_name, .method = oti.method_name,
        .receiver = lowered_left, .args = args,
    }
    if i32(oti.shape) == i32(OpShape.DirectCall) {
        return call
    }
    if i32(oti.shape) == i32(OpShape.NotCall) {
        return LoweredUnary {
            .span = binary.span, .type = TY_BOOL,
            .op = LoweredUnaryOp.Not, .operand = call,
        }
    }
    // CompareCmp : preserve the BinaryOp on (compare-call, 0).
    return LoweredBinary {
        .span = binary.span, .type = TY_BOOL,
        .op    = lower_binary_op(binary.op),
        .left  = call,
        .right = LoweredIntLit {
            .span = binary.span, .type = mk_primitive("i32"), .value = i64(0),
        },
    }
}

// True iff some impl entry targets `for_name` with `trait_name` AND
// declares a member named `method_name`. Guards against UFCS-name
// collisions where a struct happens to have a method matching an
// op-trait's method name but doesn't actually implement that trait.
impl_provides :: fn(ctx: FnLowerCtx, for_ty: Type, trait_name: string, method_name: string) -> bool {
    for_name :: type_surface_name(for_ty)
    if for_name == "" { return false }
    for entry in ctx.project.impls.all {
        decl :: entry.decl
        if decl.trait_name != trait_name { continue }
        if !impl_targets_name(decl.for_type, for_name) { continue }
        for m in decl.members {
            if m.name == method_name { return true }
        }
    }
    return false
}

OpShape :: enum(i32) {
    DirectCall,    // `a op b` -> `method(a, b)`             (Add / Sub / Mul / Div / Mod / Eq)
    NotCall,       // `a op b` -> `!method(a, b)`            (Neq)
    CompareCmp,    // `a op b` -> `method(a, b) <orig op> 0` (Lt / Lte / Gt / Gte)
}

OpTraitInfo :: struct {
    trait_name:  string
    method_name: string
    shape:       OpShape
}

op_trait_method :: fn(op: BinaryOp) -> OpTraitInfo | null {
    if i32(op) == i32(BinaryOp.Add) { return OpTraitInfo { .trait_name = "Add", .method_name = "add", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Sub) { return OpTraitInfo { .trait_name = "Sub", .method_name = "sub", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Mul) { return OpTraitInfo { .trait_name = "Mul", .method_name = "mul", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Div) { return OpTraitInfo { .trait_name = "Div", .method_name = "div", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Mod) { return OpTraitInfo { .trait_name = "Rem", .method_name = "rem", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Eq)  { return OpTraitInfo { .trait_name = "Equals", .method_name = "equals", .shape = OpShape.DirectCall } }
    if i32(op) == i32(BinaryOp.Neq) { return OpTraitInfo { .trait_name = "Equals", .method_name = "equals", .shape = OpShape.NotCall } }
    if i32(op) == i32(BinaryOp.Lt)  { return OpTraitInfo { .trait_name = "Comparable", .method_name = "compare", .shape = OpShape.CompareCmp } }
    if i32(op) == i32(BinaryOp.Lte) { return OpTraitInfo { .trait_name = "Comparable", .method_name = "compare", .shape = OpShape.CompareCmp } }
    if i32(op) == i32(BinaryOp.Gt)  { return OpTraitInfo { .trait_name = "Comparable", .method_name = "compare", .shape = OpShape.CompareCmp } }
    if i32(op) == i32(BinaryOp.Gte) { return OpTraitInfo { .trait_name = "Comparable", .method_name = "compare", .shape = OpShape.CompareCmp } }
    return null
}

try_lower_null_eq :: fn(ctx: FnLowerCtx, binary: BinaryExpr) -> LoweredExpr | null {
    union_operand: Expr | null = null
    if is_null_lit(binary.left) && is_union_with_null(ctx.types.expr_type(binary.right)) {
        union_operand = binary.right
    }
    if is_null_lit(binary.right) && is_union_with_null(ctx.types.expr_type(binary.left)) {
        union_operand = binary.left
    }
    if union_operand is null { return null }
    check :: LoweredTypeCheck {
        .span = binary.span, .type = TY_BOOL,
        .value = lower_expr(ctx, union_operand),
        .check_type = mk_primitive("null"),
    }
    if i32(binary.op) == i32(BinaryOp.Eq) { return check }
    return LoweredUnary {
        .span = binary.span, .type = TY_BOOL,
        .op = LoweredUnaryOp.Not, .operand = check,
    }
}

is_null_lit :: fn(e: Expr) -> bool {
    match e {
        is NullLitExpr -> { return true }
        _ -> { return false }
    }
}

is_union_with_null :: fn(type: Type) -> bool {
    match type {
        is UnionType as u -> {
            for v in u.variants {
                if v is PrimitiveType as p {
                    if p.name == "null" { return true }
                }
            }
            return false
        }
        _ -> { return false }
    }
}

lower_if :: fn(ctx: FnLowerCtx, if_expr: IfExpr, type: Type) -> LoweredExpr {
    cond :: lower_expr(ctx, if_expr.cond)
    then_block :: lower_then_with_binding(ctx, if_expr)
    else_block :: lower_if_else(ctx, if_expr.else_branch)
    // Else-less `if` : the body's value is unobservable (the typechecker
    // widens to `T | void`, but `void` has no representation), so force
    // the if to `void` and convert the then-block's trailing expression
    // into an `ExprStmt`. Mirror of `lowerIf`'s else-null branch in
    // `src/lower/passes/expr.ts:1005-1010`.
    if else_block is null {
        then_void :: voidify_block(then_block)
        return LoweredIf {
            .span = if_expr.span, .type = TY_VOID,
            .cond = cond, .then_block = then_void, .else_block = null,
        }
    }
    return LoweredIf {
        .span = if_expr.span, .type = type,
        .cond = cond, .then_block = then_block, .else_block = else_block,
    }
}

voidify_block :: fn(block: LoweredBlock) -> LoweredBlock {
    return LoweredBlock {
        .span = block.span, .type = TY_VOID,
        .stmts = block_stmts_with_trailing(block), .trailing = null,
    }
}

/// Prepend a `let <bind_as> = cast → T (scrut)` when the if-condition is
/// `<scrut> is T as <bind_as>`. The binding only lives inside the
/// then-block ; the lowering site materialises its slot once and every
/// downstream read sees the narrowed type. Mirror of `lowerThenWithBinding`
/// in `src/lower/passes/expr.ts:1020-1044`.
lower_then_with_binding :: fn(ctx: FnLowerCtx, if_expr: IfExpr) -> LoweredBlock {
    block :: lower_block(ctx, if_expr.then_block, false, false)
    cond :: if_expr.cond
    if !(cond is BinaryExpr) { return block }
    if cond is BinaryExpr as bin {
        if i32(bin.op) != i32(BinaryOp.Is) { return block }
        if bin.bind_as == "" { return block }
        scrut_type :: ctx.types.expr_type(bin.left)
        inner_type :: resolve_pattern_type(ctx, bin.right)
        scrut_value :: lower_expr(ctx, bin.left)
        cast_value: LoweredExpr = if scrut_type is UnionType {
            LoweredCast { .span = bin.span, .type = inner_type, .value = scrut_value }
        } else {
            scrut_value
        }
        symbol :: fresh_synthetic_symbol(ctx, bin.bind_as)
        let_stmt: LoweredStmt = LoweredLet {
            .span = bin.span, .name = bin.bind_as, .symbol = symbol,
            .type = inner_type, .value = cast_value,
        }
        new_stmts: LoweredStmt[] = []
        new_stmts.push(let_stmt)
        for s in block.stmts { new_stmts.push(s) }
        return LoweredBlock {
            .span = block.span, .type = block.type,
            .stmts = new_stmts, .trailing = block.trailing,
        }
    }
    return block
}

lower_if_else :: fn(ctx: FnLowerCtx, branch: IfElse | null) -> LoweredBlock | null {
    match branch {
        is null -> { return null }
        is IfElseIf as if_else_if -> {
            chained :: lower_if(ctx, if_else_if.branch, ctx.types.expr_type(if_else_if.branch))
            return LoweredBlock {
                .span = if_else_if.branch.span, .type = type_of(chained),
                .stmts = [], .trailing = chained,
            }
        }
        is IfElseBlock as if_else_block -> { return lower_block(ctx, if_else_block.block, false, false) }
    }
}

lower_struct_lit :: fn(ctx: FnLowerCtx, lit: StructLitExpr, type: Type) -> LoweredExpr {
    // Index the literal's provided values by name so we can walk the
    // struct decl in declaration order ; this matches the TS emit's
    // canonical field ordering even when the source literal reorders
    // fields or omits ones with defaults.
    provided: MutableMap<string, Expr> = MutableMap<string, Expr> { .buckets = [], .size = 0 }
    // Bind each `...spread` source to a synthetic temp so it's
    // evaluated exactly once even when several fields inherit from it.
    // Later spreads win, so `spread_sym` tracks the LAST source —
    // omitted fields read from it. Mirror of TS' `lowerStructLit`
    // (`src/lower/passes/expr.ts:1181`).
    spread_stmts: LoweredStmt[] = []
    spread_sym: Symbol | null = null
    for item in lit.items {
        match item {
            is StructLitField as field -> { provided[field.name] = field.value }
            is StructLitSpread as sp -> {
                value :: lower_expr(ctx, sp.expr)
                sym :: fresh_synthetic_symbol(ctx, "spread")
                spread_sym = sym
                spread_stmts.push(LoweredLet {
                    .span = sp.span, .name = sym.name, .symbol = sym,
                    .type = type, .value = value,
                })
            }
        }
    }
    fields :: build_struct_lit_fields(ctx, type, provided, lit, spread_sym)
    struct_lit :: LoweredStructLit { .span = lit.span, .type = type, .fields = fields }
    if spread_stmts.len() == 0 { return struct_lit }
    return LoweredBlock {
        .span = lit.span, .type = type,
        .stmts = spread_stmts, .trailing = struct_lit,
    }
}

import "vader/types" { StructType, EnumType }
import "vader/resolver/symbol" { SymbolKind as KindForEnum }

// `.North` resolves through context : the surrounding slot's expected
// type pins the enum. Look up the variant's integer index off the
// resolved `EnumType` and emit a `LoweredIntLit`. Falls back to a
// stub when the context isn't an enum (defensive — earlier
// diagnostics should have caught the bad use).
lower_dot_variant :: fn(ctx: FnLowerCtx, expr: DotVariantExpr, type: Type) -> LoweredExpr {
    resolved :: enum_type_or_unwrap(ctx, type)
    match resolved {
        is EnumType as enum_type -> {
            index :: enum_type.indices[expr.variant]
            match index {
                is null -> { return stub(expr.span, type, "unknown variant `${expr.variant}` on `${enum_type.symbol.name}`") }
                is i64 as value -> {
                    return LoweredIntLit {
                        .span = expr.span, .type = mk_primitive(enum_type.repr), .value = value,
                    }
                }
            }
        }
        _ -> { return stub(expr.span, type, "`.${expr.variant}` against non-enum context type") }
    }
}

// `Enum.Variant` field access on the type-name ident — detect when the
// FieldExpr's target is an IdentExpr resolving to an enum symbol +
// the field name matches a variant. Returns null when either check
// fails ; caller falls back to a regular field-access lowering.
try_lower_enum_field :: fn(ctx: FnLowerCtx, expr: FieldExpr, type: Type) -> LoweredExpr | null {
    match expr.target {
        is IdentExpr as target_ident -> {
            target_type :: ctx.types.expr_type(target_ident)
            enum_type :: enum_type_or_unwrap(ctx, target_type)
            match enum_type {
                is EnumType as et -> {
                    index :: et.indices[expr.field]
                    match index {
                        is null -> { return null }
                        is i64 as value -> {
                            return LoweredIntLit {
                                .span = expr.span, .type = mk_primitive(et.repr), .value = value,
                            }
                        }
                    }
                }
                _ -> { return null }
            }
        }
        _ -> { return null }
    }
}

// Unwrap the StructType-as-Enum placeholder if needed (same trick as
// `lower_match::unwrap_enum_type`).
enum_type_or_unwrap :: fn(ctx: FnLowerCtx, type: Type) -> Type {
    match type {
        is EnumType -> { return type }
        is StructType as st -> {
            if i32(st.symbol.kind) != i32(KindForEnum.Enum) { return type }
            real :: ctx.typed.decl_types[st.symbol.id]
            match real {
                is EnumType -> { return real }
                _ -> { return type }
            }
        }
        _ -> { return type }
    }
}

build_struct_lit_fields :: fn(
    ctx: FnLowerCtx, type: Type,
    provided: MutableMap<string, Expr>, lit: StructLitExpr,
    spread_sym: Symbol | null,
) -> LoweredStructLitField[] {
    out: LoweredStructLitField[] = []
    match type {
        is StructType as st -> {
            decl :: ctx.typed.struct_decls[st.symbol.id]
            if decl is null { return fallback_provided_order(ctx, lit) }
            for field_decl in decl.fields {
                // Resolve the field's declared type so a union-typed
                // field widens literal initializers (e.g.
                // `flag: int(42)` against `flag: i32 | null`).
                field_type :: resolve_pattern_type(ctx, field_decl.ty)
                user_value :: provided[field_decl.name]
                if user_value is null {
                    // Omitted field : inherit from the last `...spread`
                    // source via a field access, else fall back to the
                    // declared default. Matches TS' `lowerStructLit`.
                    if spread_sym is Symbol as sym {
                        out.push(LoweredStructLitField {
                            .name = field_decl.name,
                            .value = LoweredFieldAccess {
                                .span = lit.span, .type = field_type,
                                .target = LoweredIdent {
                                    .span = lit.span, .type = type, .symbol = sym,
                                },
                                .field = field_decl.name,
                            },
                        })
                        continue
                    }
                    if field_decl.default != null {
                        out.push(LoweredStructLitField {
                            .name = field_decl.name,
                            .value = lower_field_value(ctx, field_decl.default, field_type, field_decl.span),
                        })
                    }
                } else {
                    out.push(LoweredStructLitField {
                        .name = field_decl.name,
                        .value = lower_field_value(ctx, user_value, field_type, user_value.span),
                    })
                }
            }
            return out
        }
        _ -> { return fallback_provided_order(ctx, lit) }
    }
}

// Lower a struct-lit field value (provided or defaulted) against its
// declared type : widen free literals to the field's union context,
// then apply an `Into` coercion when the field type calls for one.
lower_field_value :: fn(
    ctx: FnLowerCtx, value: Expr, field_type: Type, span: Span,
) -> LoweredExpr {
    lowered :: lower_expr(ctx, value)
    widened :: widen_literal_to_context(lowered, field_type)
    coerced :: try_emit_into_coercion(ctx, widened, type_of(widened), field_type, span)
    match coerced {
        is null -> { return widened }
        _ -> { return coerced }
    }
}

// Defensive fallback : when the struct decl can't be reached, emit
// fields in source order (the previous behaviour).
fallback_provided_order :: fn(ctx: FnLowerCtx, lit: StructLitExpr) -> LoweredStructLitField[] {
    out: LoweredStructLitField[] = []
    for item in lit.items {
        match item {
            is StructLitField as field -> {
                out.push(LoweredStructLitField {
                    .name = field.name, .value = lower_expr(ctx, field.value),
                })
            }
            is StructLitSpread -> {}
        }
    }
    return out
}

lower_seq_lit :: fn(ctx: FnLowerCtx, lit: SeqLitExpr, type: Type) -> LoweredExpr {
    // Tuples share the parser shape `[a, b, c]` with arrays — disambiguate
    // by the resolved type. Tuple-typed literals become struct lits with
    // synthetic `_0` / `_1` / ... fields ; the bytecode emit reads them
    // off the same struct layout the typer pins.
    match type {
        is TupleType -> {
            fields: LoweredStructLitField[] = []
            for i in 0..<lit.elements.len() {
                fields.push(LoweredStructLitField {
                    .name = "_${i}",
                    .value = lower_expr(ctx, lit.elements[i]),
                })
            }
            return LoweredStructLit { .span = lit.span, .type = type, .fields = fields }
        }
        _ -> {
            elements: LoweredExpr[] = []
            for element in lit.elements { elements.push(lower_expr(ctx, element)) }
            return LoweredArrayLit { .span = lit.span, .type = type, .elements = elements }
        }
    }
}


// Preserve the `@<name>(args)` call shape. Comptime-foldable variants
// (`@size_of`, `@type_kind`, …) get baked at evaluation time and reach
// the lowerer as bound `@comptime const` references ; what remains is
// the runtime-bound shape, which the bytecode emit consumes.
lower_intrinsic :: fn(ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type) -> LoweredExpr {
    // `@file("path")` was baked at comptime — substitute the file's
    // contents as a `LoweredStringLit` so downstream phases see the
    // materialised constant rather than re-running the AST. Mirror of
    // `lowerIntrinsic`'s `fileExprs` branch in `src/lower/lower.ts`.
    if intrinsic.name == "file" {
        baked :: lookup_file_baked(ctx, intrinsic)
        match baked {
            is null -> {}
            is string as text -> {
                return LoweredStringLit {
                    .span = intrinsic.span, .type = mk_primitive("string"), .value = text,
                }
            }
        }
    }
    // `@field(target, "name")` folds to `target.name` when the name
    // arg is a static string literal. Mirror of `lowerIntrinsic`'s
    // `case "field"` (`src/lower/passes/expr.ts:453-487`). Comptime-for
    // unrolling can substitute the name slot with a LoweredStringLit
    // — we lower the args here so post-substitution literals get
    // picked up. When the typer left the result type unresolved,
    // refine from the receiver's struct decl + field name pair.
    if intrinsic.name == "field" && intrinsic.args.len() == 2 {
        target :: lower_expr(ctx, intrinsic.args[0])
        name_arg :: lower_expr(ctx, intrinsic.args[1])
        if name_arg is LoweredStringLit as name_lit {
            field_type := type
            if field_type is UnresolvedType {
                refined :: resolve_field_type(ctx, intrinsic.args[0], name_lit.value)
                if !(refined is UnresolvedType) { field_type = refined }
            }
            return LoweredFieldAccess {
                .span = intrinsic.span, .type = field_type,
                .target = target, .field = name_lit.value,
            }
        }
    }
    // Static-arg intrinsics fold at lower time when the typer recorded
    // the arg's underlying Type. Mirror of `lowerIntrinsic`'s
    // `targetTy`-based branches in `src/lower/passes/expr.ts:380-402`.
    folded :: try_fold_static_intrinsic(ctx, intrinsic, type)
    match folded {
        is null -> {}
        _ -> { return folded }
    }
    args: LoweredExpr[] = []
    for arg_expr in intrinsic.args {
        args.push(lower_expr(ctx, arg_expr))
    }
    // Late-fold path : `@size_of` / `@align_of` / `@type_name` /
    // `@type_kind` over a single arg that lowered to a
    // `LoweredTypeConst` (e.g. via `@comptime for` substitution of
    // `t`). The early `try_fold_static_intrinsic` reads the source
    // AST so it can't see post-lower substitutions ; this catches
    // the substituted shape.
    late_folded :: try_late_fold_type_arg(intrinsic.name, args, intrinsic.span, type)
    if !(late_folded is null) { return late_folded }
    // `@size_of(x)` over a `type`-valued runtime expression routes
    // through the dedicated `size_of.type` intrinsic so the bytecode
    // emit picks the right opcode. Mirror of the static-fold-failed
    // fallback in `src/lower/passes/expr.ts:393-396`.
    final_name :: runtime_intrinsic_name(intrinsic.name, args)
    return LoweredIntrinsicCall {
        .span = intrinsic.span, .type = type, .name = final_name,
        .args = args, .display_for = null,
    }
}

/// Late fold for the type-introspection intrinsics — fires when the
/// arg lowered to a `LoweredTypeConst` (which can happen via
/// `@comptime for` substitution that the early AST-level fold doesn't
/// see). Returns null when the pattern doesn't match ; caller falls
/// through to the runtime `LoweredIntrinsicCall`.
try_late_fold_type_arg :: fn(name: string, args: LoweredExpr[], span: Span, type: Type) -> LoweredExpr | null {
    if args.len() != usize(1) { return null }
    arg :: args[0]
    tc: LoweredTypeConst | null = null
    if arg is LoweredTypeConst as t { tc = t }
    if tc is null { return null }
    ty :: tc.value
    if name == "size_of" {
        return LoweredIntLit { .span = span, .type = type, .value = byte_size(ty) }
    }
    if name == "align_of" {
        return LoweredIntLit { .span = span, .type = type, .value = byte_align(ty) }
    }
    if name == "type_name" {
        return LoweredStringLit { .span = span, .type = mk_primitive("string"), .value = display_type(ty) }
    }
    if name == "type_kind" {
        return LoweredStringLit { .span = span, .type = mk_primitive("string"), .value = kind_string_of_type(ty) }
    }
    return null
}

runtime_intrinsic_name :: fn(name: string, args: LoweredExpr[]) -> string {
    if name == "size_of" && args.len() == 1 {
        return "size_of.type"
    }
    return name
}

lookup_file_baked :: fn(ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr) -> string | null {
    return ctx.project.evaluated.file_exprs[intrinsic.id]
}

/// Fold `@size_of` / `@align_of` / `@type_name` / `@type_kind` to a
/// literal when the single arg resolves to a concrete `Type`. The
/// typer's `type_expr_types` table covers most cases ; `type_from_expr`
/// fallback handles type-alias idents the typer left as Unresolved.
try_fold_static_intrinsic :: fn(
    ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type,
) -> LoweredExpr | null {
    name :: intrinsic.name
    if name == "satisfies" {
        return try_fold_satisfies(ctx, intrinsic, type)
    }
    if name == "type_of" {
        return try_fold_type_of(ctx, intrinsic, type)
    }
    if name == "type_args" {
        return try_fold_type_args(ctx, intrinsic, type)
    }
    if name == "fields" {
        return try_fold_fields(ctx, intrinsic, type)
    }
    if name != "size_of" && name != "align_of" && name != "type_name" && name != "type_kind" {
        return null
    }
    if intrinsic.args.len() != usize(1) { return null }
    arg_or_null :: resolve_intrinsic_type_arg(ctx, intrinsic.args[0])
    if arg_or_null is null { return null }
    ty :: arg_ty_or_unresolved(arg_or_null)
    if ty is UnresolvedType { return null }
    if name == "size_of" {
        return LoweredIntLit { .span = intrinsic.span, .type = type, .value = byte_size(ty) }
    }
    if name == "align_of" {
        return LoweredIntLit { .span = intrinsic.span, .type = type, .value = byte_align(ty) }
    }
    if name == "type_name" {
        return LoweredStringLit { .span = intrinsic.span, .type = mk_primitive("string"), .value = display_type(ty) }
    }
    if name == "type_kind" {
        return LoweredStringLit { .span = intrinsic.span, .type = mk_primitive("string"), .value = kind_string_of_type(ty) }
    }
    return null
}

/// Fold `@type_of(x)` to a `LoweredTypeConst` carrying `x`'s static
/// type. The arg is NOT evaluated (Zig-style `@TypeOf`) — only the
/// typed AST's recorded expr-type is read. Mirror of
/// `lowerIntrinsic`'s `case "type_of"` in `src/lower/passes/expr.ts:431-437`.
try_fold_type_of :: fn(
    ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type,
) -> LoweredExpr | null {
    if intrinsic.args.len() != usize(1) { return null }
    arg_type :: expr_type(ctx.types, intrinsic.args[0])
    return LoweredTypeConst {
        .span = intrinsic.span, .type = type, .value = arg_type,
    }
}

/// Fold `@type_args(T)` to an array literal of `LoweredTypeConst`s — one
/// per generic argument of `T`. Mirror of `lowerIntrinsic`'s
/// `case "type_args"` in `src/lower/passes/expr.ts:474-483`. Returns an
/// empty array for non-generic shapes.
try_fold_type_args :: fn(
    ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type,
) -> LoweredExpr | null {
    if intrinsic.args.len() != usize(1) { return null }
    arg_or_null :: resolve_intrinsic_type_arg(ctx, intrinsic.args[0])
    args: Type[] = []
    if !(arg_or_null is null) {
        ty :: arg_ty_or_unresolved(arg_or_null)
        if ty is StructType as st { args = st.args }
        if ty is TraitType as tt { args = tt.args }
    }
    elements: LoweredExpr[] = []
    for a in args {
        elements.push(LoweredTypeConst {
            .span = intrinsic.span, .type = TY_TYPE, .value = a,
        })
    }
    return LoweredArrayLit {
        .span = intrinsic.span, .type = type, .elements = elements,
    }
}

/// Fold `@fields(T)` to an array literal of `Field { name, type }`
/// struct lits — one entry per field declared on `T`. Generic struct
/// args flow into each field's type so `@fields(Pair(string, i64))`
/// reports `value` as `i64`, not the unsubstituted TypeParam. Mirror
/// of `lowerIntrinsic`'s `case "fields"` in
/// `src/lower/passes/expr.ts:498-522`.
///
/// @param ctx        the fn-body lower context.
/// @param intrinsic  the `@fields(T)` call site.
/// @param type       the result type (`Field[]`).
/// @return           the array lit, or `LoweredUnreachable` when the
///                   target isn't a struct / Field core type isn't
///                   reachable / the struct decl can't be found.
try_fold_fields :: fn(
    ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type,
) -> LoweredExpr | null {
    if intrinsic.args.len() != usize(1) { return null }
    arg_or_null :: resolve_intrinsic_type_arg(ctx, intrinsic.args[0])
    if arg_or_null is null { return null }
    target_ty :: arg_ty_or_unresolved(arg_or_null)
    target_struct: StructType | null = null
    if target_ty is StructType as st { target_struct = st }
    if target_struct is null {
        return LoweredUnreachable {
            .span = intrinsic.span, .type = type,
            .reason = "@fields target is not a struct",
        }
    }
    field_type_opt :: find_core_type(ctx, STRUCT_FIELD, [])
    if field_type_opt is null {
        return LoweredUnreachable {
            .span = intrinsic.span, .type = type,
            .reason = "@fields needs std/core::Field",
        }
    }
    field_type :: field_type_opt
    // Find the owning module's loaded view + its typed program.
    owner_module_id :: target_struct.symbol.module
    owner_loaded_opt :: ctx.project.loaded.modules[owner_module_id]
    if owner_loaded_opt is null {
        return LoweredUnreachable {
            .span = intrinsic.span, .type = type,
            .reason = "@fields owner module not loaded",
        }
    }
    owner_typed_opt :: ctx.project.evaluated.typed.modules[owner_module_id]
    if owner_typed_opt is null {
        return LoweredUnreachable {
            .span = intrinsic.span, .type = type,
            .reason = "@fields owner module not typechecked",
        }
    }
    owner_typed :: owner_typed_opt
    owner_decls :: module_decls(owner_loaded_opt)
    decl :: find_struct_decl_by_name(owner_decls, target_struct.symbol.name)
    if decl is null {
        return LoweredUnreachable {
            .span = intrinsic.span, .type = type,
            .reason = "@fields target struct decl not found",
        }
    }
    // Build the type-param → arg substitution using the existing
    // helper that the generic-instance materialiser uses.
    subst :: build_struct_subst(decl, target_struct.args, owner_typed)
    string_type :: mk_primitive("string")
    elements: LoweredExpr[] = []
    for f in decl.fields {
        raw_ty :: resolve_field_type(f.ty, owner_typed, decl, target_struct.args)
        substituted :: substitute(raw_ty, subst)
        field_lit_fields: LoweredStructLitField[] = []
        field_lit_fields.push(LoweredStructLitField {
            .name = "name",
            .value = LoweredStringLit {
                .span = intrinsic.span, .type = string_type, .value = f.name,
            },
        })
        field_lit_fields.push(LoweredStructLitField {
            .name = "type",
            .value = LoweredTypeConst {
                .span = intrinsic.span, .type = TY_TYPE, .value = substituted,
            },
        })
        elements.push(LoweredStructLit {
            .span = intrinsic.span, .type = field_type, .fields = field_lit_fields,
        })
    }
    return LoweredArrayLit {
        .span = intrinsic.span, .type = type, .elements = elements,
    }
}

import "vader/typecheck" { substitute }

/// Fold `@satisfies(T, Trait)` to a literal bool. True iff a user impl
/// `T implements Trait` exists in the registry. Mirror of
/// `lowerIntrinsic`'s `case "satisfies"` branch in
/// `src/lower/passes/expr.ts:416-423`.
try_fold_satisfies :: fn(
    ctx: FnLowerCtx, intrinsic: IntrinsicCallExpr, type: Type,
) -> LoweredExpr | null {
    if intrinsic.args.len() != usize(2) { return null }
    target_or_null :: resolve_intrinsic_type_arg(ctx, intrinsic.args[0])
    trait_or_null  :: resolve_intrinsic_type_arg(ctx, intrinsic.args[1])
    value: bool = false
    if !(target_or_null is null) && !(trait_or_null is null) {
        match arg_ty_or_unresolved(trait_or_null) {
            is TraitType as tt -> {
                value = impl_exists_for(ctx, arg_ty_or_unresolved(target_or_null), tt.symbol)
            }
            _ -> {}
        }
    }
    return LoweredBoolLit { .span = intrinsic.span, .type = type, .value = value }
}

/// Mirror of `ImplRegistry.findFor` in `src/typecheck/impls.ts:81`: a struct
/// or enum target resolves through `has_user`, a primitive target falls
/// back to a name-match scan over the registry's flat entry list (those
/// impls carry `for_symbol = null`).
impl_exists_for :: fn(ctx: FnLowerCtx, target_ty: Type, trait_sym: Symbol) -> bool {
    target_sym :: type_to_target_symbol(target_ty)
    if target_sym is Symbol as ts {
        return ctx.project.impls.has_user(ts, trait_sym)
    }
    if target_ty is PrimitiveType as pt {
        for entry in ctx.project.impls.all {
            if entry.for_symbol is Symbol { continue }
            if entry.trait_symbol.id != trait_sym.id { continue }
            if entry.decl.for_type is IdentExpr as id {
                if id.name == pt.name { return true }
            }
        }
    }
    return false
}

arg_ty_or_unresolved :: fn(t: Type | null) -> Type {
    match t {
        is null -> { return TY_UNRESOLVED }
        _ -> { return t }
    }
}

resolve_intrinsic_type_arg :: fn(ctx: FnLowerCtx, arg: Expr) -> Type | null {
    raw :: ctx.types.type_expr_type(arg)
    if !(raw is UnresolvedType) { return raw }
    scratch: Diagnostic[] = []
    via_type_expr :: type_from_expr(arg, ctx.typed.resolved, scratch)
    if !(via_type_expr is UnresolvedType) { return via_type_expr }
    // Fall-throughs for IdentExpr args that resolve to a Symbol :
    //   (a) Layer 5b in-fn alias : `t :: i32` inside a fn body. The
    //       typer stashed the resolved underlying Type in
    //       `let_type_aliases` keyed by the local's Symbol.id.
    //   (b) Comptime const carrying a `TypeValue`. Recovered from
    //       `comptime_value_by_symbol_id` so dotted refs to a `::`
    //       alias still fold.
    if arg is IdentExpr as id {
        sym :: ctx.typed.resolved.idents[id.span.hash()]
        if sym is null { return via_type_expr }
        if sym is Symbol as s {
            aliased :: ctx.typed.let_type_aliases[s.id]
            if !(aliased is null) { return aliased }
            v :: ctx.project.comptime_value_by_symbol_id[s.id]
            match v {
                is null -> {}
                is TypeValue as tv -> { return tv.value }
                _ -> {}
            }
        }
    }
    return via_type_expr
}

// `@type_kind(T)` stable discriminator. Exhaustive over `Type` (no `_`) and
// kept in lock-step with `src/typecheck/types.ts::kindStringOfType` — the bare
// types that have no user-facing kind collapse to "unknown", `Any` is "any",
// `TypeMeta` is "type". Listing every variant trips T3013 on a new Type kind.
kind_string_of_type :: fn(t: Type) -> string = match t {
    is PrimitiveType  -> "primitive"
    is StructType     -> "struct"
    is EnumType       -> "enum"
    is UnionType      -> "union"
    is ArrayType      -> "array"
    is TupleType      -> "tuple"
    is FnType         -> "fn"
    is TraitType      -> "trait"
    is TypeMetaType   -> "type"
    is TypeParamType  -> "unknown"
    is SelfType       -> "unknown"
    is UnresolvedType -> "unknown"
    is FreeIntType    -> "unknown"
    is FreeFloatType  -> "unknown"
    is NeverType      -> "unknown"
    is AnyType        -> "any"
}

// ============================================================================
// Block + statement lowering
// ============================================================================

/// Lower a `BlockExpr` to a `LoweredBlock`. Block frames are pushed
/// onto `ctx.blocks` so defer-aware lowering (Phase 5) can replay
/// in reverse at every exit edge ; Phase 3 just bookkeeps the stack.
/// @param ctx           the fn-body context.
/// @param block         the source block.
/// @param is_fn_root    true when this is the enclosing fn's body.
/// @param is_loop_body  true when this is the body of a loop.
/// @return              the lowered block.
export lower_block :: fn(
    ctx: FnLowerCtx, block: BlockExpr, is_fn_root: bool, is_loop_body: bool,
) -> LoweredBlock {
    entry_depth :: ctx.blocks.len()
    ctx.blocks.push(new_block_ctx(is_fn_root, is_loop_body))
    stmts: LoweredStmt[] = []
    for stmt in block.stmts {
        lower_stmt_into(ctx, stmt, stmts)
    }
    raw_trailing :: lower_trailing(ctx, block.trailing)
    defer_count :: ctx.blocks[entry_depth].defers.len()
    // Skip the block-fall-through pop_exec when control flow has
    // already exited (return / break / continue). The `drain_*`
    // helpers at those sites already emitted the proper drain count,
    // so a trailing pop_exec here would be dead code.
    last_diverges :: stmts.len() > 0 && stmt_diverges(stmts[stmts.len() - 1])
    // Sequence the block-fall-through defer drain so it runs AFTER
    // the trailing expression has computed its value. The trailing's
    // side-effects must land before any defer fires (their thunks
    // may observe / mutate state visible to the parent block), and
    // the drain must run before the value escapes the block. The
    // only way to achieve both is to bind the trailing to a
    // `__block_N` synthetic local, push `pop_exec`, then return an
    // ident-ref as the new trailing. Mirror of
    // `src/lower/passes/block.ts::emitTrailingValueWithDefers`.
    trailing := raw_trailing
    if defer_count > 0 && !last_diverges {
        if trailing == null {
            stmts.push(LoweredDeferPopExec {
                .span = block.span, .count = i32(defer_count),
            })
        } else {
            value_type :: type_of(trailing)
            tmp_sym :: fresh_synthetic_symbol(ctx, "block")
            stmts.push(LoweredLet {
                .span = trailing.span, .name = tmp_sym.name,
                .symbol = tmp_sym, .type = value_type, .value = trailing,
            })
            stmts.push(LoweredDeferPopExec {
                .span = trailing.span, .count = i32(defer_count),
            })
            trailing = LoweredIdent {
                .span = trailing.span, .type = value_type, .symbol = tmp_sym,
            }
        }
    }
    block_type :: trailing_type(trailing)
    // Pop the BlockCtx — mirror TS by maintaining the stack depth
    // invariant so nested blocks see only their own defers.
    new_blocks: BlockCtx[] = []
    i := usize(0)
    for i < entry_depth {
        new_blocks.push(ctx.blocks[i])
        i = i + 1
    }
    ctx.blocks = new_blocks
    return LoweredBlock {
        .span = block.span, .type = block_type, .stmts = stmts, .trailing = trailing,
    }
}

lower_trailing :: fn(ctx: FnLowerCtx, trailing: Expr | null) -> LoweredExpr | null {
    match trailing {
        is null -> { return null }
        _ -> { return lower_expr(ctx, trailing) }
    }
}

trailing_type :: fn(trailing: LoweredExpr | null) -> Type {
    match trailing {
        is null -> { return TY_VOID }
        _ -> { return type_of(trailing) }
    }
}

// Lower a single stmt and push its lowered form(s) onto `out`. Most
// stmts produce exactly one ; tuple-destructure `let` produces one
// __tup binding + N leaf lets ; defer currently produces zero.
lower_stmt_into :: fn(ctx: FnLowerCtx, stmt: Stmt, out: LoweredStmt[]) -> void {
    match stmt {
        is LetStmt      as let_stmt      -> { lower_let_into(ctx, let_stmt, out) }
        is AssignStmt   as assign_stmt   -> { out.push(lower_assign(ctx, assign_stmt)) }
        is ExprStmt     as expr_stmt     -> {
            out.push(LoweredExprStmt { .span = expr_stmt.span, .expr = lower_expr(ctx, expr_stmt.expr) })
        }
        is ReturnStmt   as return_stmt   -> {
            // Drain every pending defer in the enclosing scopes BEFORE
            // the actual return op. Mirrors TS `lower-stmt` block-exit
            // defer replay. Count = sum of `defers` across every open
            // BlockCtx (the innermost block back up to the fn root).
            // When the drain emits anything, bundle drain + exit into
            // a single statement via `wrap_stmts` so the dump matches
            // TS's `(block (pop_exec N) (return …))` shape rather
            // than two flat sibling stmts.
            drain: LoweredStmt[] = []
            drain_all_defers(ctx, return_stmt.span, drain)
            exit :: lower_return(ctx, return_stmt)
            if drain.len() > 0 {
                drain.push(exit)
                out.push(wrap_stmts(return_stmt.span, drain))
            } else {
                out.push(exit)
            }
        }
        is ForStmt      as for_stmt      -> { out.push(lower_for(ctx, for_stmt)) }
        is BreakStmt    as break_stmt    -> {
            drain: LoweredStmt[] = []
            drain_defers_to_loop(ctx, break_stmt.span, drain)
            exit :: LoweredBreak { .span = break_stmt.span, .label = break_stmt.label }
            if drain.len() > 0 {
                drain.push(exit)
                out.push(wrap_stmts(break_stmt.span, drain))
            } else {
                out.push(exit)
            }
        }
        is ContinueStmt as continue_stmt -> {
            drain: LoweredStmt[] = []
            drain_defers_to_loop(ctx, continue_stmt.span, drain)
            exit :: LoweredContinue { .span = continue_stmt.span, .label = continue_stmt.label }
            if drain.len() > 0 {
                drain.push(exit)
                out.push(wrap_stmts(continue_stmt.span, drain))
            } else {
                out.push(exit)
            }
        }
        is DeferStmt    as defer_stmt    -> {
            // Lift to a synthetic `__defer_N` fn + emit
            // `LoweredDeferPush { LoweredMakeClosure }` at the source
            // site. Block-exit `defer.pop_exec N` emission is handled
            // by `lower_block` (counts defers via the BlockCtx).
            push :: lower_defer(ctx, defer_stmt, lower_block)
            out.push(push)
            // Track the defer count on the innermost open block ctx
            // so the matching fall-through / break / continue / return
            // can drain it with `defer.pop_exec N`.
            n_blocks :: ctx.blocks.len()
            if n_blocks > 0 {
                ctx.blocks[n_blocks - 1].defers.push(defer_stmt)
            }
        }
    }
}

lower_let_into :: fn(ctx: FnLowerCtx, let_stmt: LetStmt, out: LoweredStmt[]) -> void {
    match let_stmt.binding {
        is SimpleBinding as simple -> {
            symbol_or_null :: lookup_local_symbol(ctx.project, ctx.typed.resolved, simple.name_span)
            // Synthesise a Local symbol when the resolver dropped this
            // binding (cascading-error case, e.g. T3001 on an invalid
            // annotation, OR an unused let with zero body use-sites).
            // Mint without bumping `ctx.uniq` so the synth doesn't
            // drift later `fresh_synthetic_symbol("sb")` / `("try")` /
            // … naming away from the TS reference.
            symbol :: match symbol_or_null {
                is Symbol as s -> s
                is null -> synth_unused_local(ctx, simple.name)
            }
            binding_type :: ctx.types.local_type(simple)
            // `let t: type = …` is an in-fn type alias — no runtime
            // slot, the typer pre-resolved the type. Skip emit so the
            // dump matches the TS lowerer's `letTypeAliases`
            // short-circuit (`src/lower/passes/block.ts:101-103`).
            if binding_type is TypeMetaType { return }
            raw_value :: lower_expr(ctx, let_stmt.value)
            widened :: widen_literal_to_context(raw_value, binding_type)
            // Auto-Into coercion when the binding's declared type
            // differs from the value's type AND an `Into[binding_type]`
            // impl exists for the source. Mirror of the typer's
            // `tryInto` hook at let-stmt's value-position.
            coerced :: try_emit_into_coercion(ctx, widened, type_of(widened), binding_type, let_stmt.span)
            value :: match coerced {
                is null -> widened
                _ -> coerced
            }
            init :: lower_cell_init(ctx, symbol, value, binding_type, let_stmt.span)
            out.push(LoweredLet {
                .span = let_stmt.span, .name = simple.name,
                .symbol = symbol, .type = init.slot_type,
                .value = init.value,
            })
        }
        is TupleBinding as tup -> {
            // Desugar `let [a, b] := value` into :
            //   let __tup_n = value
            //   let a = __tup_n._0   (or __tup_n[0] for arrays)
            //   let b = __tup_n._1   (or __tup_n[1] for arrays)
            value :: lower_expr(ctx, let_stmt.value)
            value_type :: type_of(value)
            tup_symbol :: fresh_synthetic_symbol(ctx, "tup")
            out.push(LoweredLet {
                .span = let_stmt.span, .name = tup_symbol.name,
                .symbol = tup_symbol, .type = value_type, .value = value,
            })
            tup_ref :: LoweredIdent { .span = let_stmt.span, .type = value_type, .symbol = tup_symbol }
            emit_let_binding_leaves(ctx, tup, tup_ref, value_type, let_stmt.span, out)
        }
        is WildcardBinding -> {
            out.push(LoweredExprStmt {
                .span = let_stmt.span, .expr = lower_expr(ctx, let_stmt.value),
            })
        }
        is RestBinding -> {
            out.push(LoweredExprStmt {
                .span = let_stmt.span,
                .expr = LoweredUnreachable {
                    .span = let_stmt.span, .type = TY_VOID,
                    .reason = "rest-binding only valid inside tuple destructure",
                },
            })
        }
    }
}

// Walk a `LetBinding` tree, emitting one `LoweredLet` per leaf with
// the target ident's `_<i>` field (tuples) or `[i]` index (arrays).
emit_let_binding_leaves :: fn(
    ctx: FnLowerCtx, binding: TupleBinding, target: LoweredExpr,
    target_type: Type, span: Span, out: LoweredStmt[],
) -> void {
    // `[a, b, ...rest] := arr` over an array : N index reads for the
    // fixed leaves, then a fresh-array + loop-push for the rest leaf.
    rest_index :: rest_leaf_index(binding)
    if rest_index >= 0 {
        if target_type is ArrayType as arr {
            emit_array_destructure(ctx, binding, usize(rest_index), target, arr, span, out)
            return
        }
    }
    for i in 0..<binding.elements.len() {
        leaf :: binding.elements[i]
        emit_let_leaf(ctx, leaf, target, target_type, i, span, out)
    }
}

// Index of the first `...rest` leaf in `binding`, or -1 when none.
rest_leaf_index :: fn(binding: TupleBinding) -> i64 {
    for i in 0..<binding.elements.len() {
        if binding.elements[i] is RestBinding { return i64(i) }
    }
    return i64(-1)
}

// Desugar `[a, ...rest] := arr` (array target) : fixed leaves before the
// rest read by index, the rest leaf binds a fresh array filled by a
// loop pushing `arr[i]` for `i` in `rest_index..<arr.len()`. Mirror of
// TS' `emitArrayDestructure` (`src/lower/passes/block.ts:332`).
emit_array_destructure :: fn(
    ctx: FnLowerCtx, binding: TupleBinding, rest_index: usize,
    target: LoweredExpr, arr: ArrayType, span: Span, out: LoweredStmt[],
) -> void {
    elem_type :: ctx.types.apply(arr.element)
    for i in 0..<rest_index {
        leaf :: binding.elements[i]
        if !(leaf is WildcardBinding) {
            access :: LoweredIndex {
                .span = span, .type = elem_type, .target = target,
                .index = LoweredIntLit { .span = span, .type = mk_primitive("usize"), .value = i64(i) },
            }
            emit_let_leaf_array(ctx, leaf, access, elem_type, span, out)
        }
    }
    rest_leaf :: binding.elements[rest_index]
    match rest_leaf {
        is RestBinding as rest -> {
            emit_rest_loop(ctx, rest, rest_index, target, elem_type, span, out)
        }
        _ -> {}
    }
}

// Emit the rest leaf's fresh-array + index-loop-push for an array
// destructure.
emit_rest_loop :: fn(
    ctx: FnLowerCtx, rest: RestBinding, rest_index: usize,
    target: LoweredExpr, elem_type: Type, span: Span, out: LoweredStmt[],
) -> void {
    // The resolver indexes a rest binding's Symbol by `span` (not
    // `name_span` like simple bindings — see resolver `bind_let_binding`).
    rest_sym :: lookup_local_symbol(ctx.project, ctx.typed.resolved, rest.span)
    if rest_sym is null { return }
    array_type :: mk_array(elem_type, false)
    empty_arr :: LoweredArrayLit { .span = rest.span, .type = array_type, .elements = [] }
    rest_init :: lower_cell_init(ctx, rest_sym, empty_arr, array_type, rest.span)
    out.push(LoweredLet {
        .span = rest.span, .name = rest.name, .symbol = rest_sym,
        .type = rest_init.slot_type, .value = rest_init.value,
    })
    idx_sym :: fresh_synthetic_symbol(ctx, "i")
    out.push(LoweredLet {
        .span = span, .name = idx_sym.name, .symbol = idx_sym, .type = mk_primitive("usize"),
        .value = LoweredIntLit { .span = span, .type = mk_primitive("usize"), .value = i64(rest_index) },
    })
    idx_ref :: LoweredIdent { .span = span, .type = mk_primitive("usize"), .symbol = idx_sym }
    rest_ref :: read_local_cell_aware(ctx, rest_sym, array_type, span)
    push_stmt :: LoweredExprStmt {
        .span = span,
        .expr = LoweredArrayPush {
            .span = span, .type = TY_VOID, .target = rest_ref,
            .value = LoweredIndex { .span = span, .type = elem_type, .target = target, .index = idx_ref },
        },
    }
    inc_stmt :: LoweredAssign {
        .span = span, .target = idx_ref,
        .value = LoweredBinary {
            .span = span, .type = mk_primitive("usize"), .op = LoweredBinaryOp.Add,
            .left = idx_ref,
            .right = LoweredIntLit { .span = span, .type = mk_primitive("usize"), .value = i64(1) },
        },
    }
    loop_stmts: LoweredStmt[] = []
    loop_stmts.push(push_stmt)
    loop_stmts.push(inc_stmt)
    loop_body :: LoweredBlock {
        .span = span, .type = TY_VOID, .stmts = loop_stmts, .trailing = null,
    }
    out.push(LoweredLoop {
        .span = span, .label = null,
        .cond = LoweredBinary {
            .span = span, .type = TY_BOOL, .op = LoweredBinaryOp.Lt,
            .left = idx_ref,
            .right = LoweredArrayLen { .span = span, .type = mk_primitive("usize"), .target = target },
        },
        .body = loop_body,
    })
}

// Read a local respecting closure-cell promotion (mirror of `readLocal`
// in `src/lower/passes/block.ts`).
read_local_cell_aware :: fn(ctx: FnLowerCtx, sym: Symbol, type: Type, span: Span) -> LoweredExpr {
    if ctx.project.closures.captured_symbols.contains(sym.id) {
        cell_ref :: LoweredIdent { .span = span, .type = TY_UNRESOLVED, .symbol = sym }
        return LoweredCellGet { .span = span, .type = type, .target = cell_ref, .value_type = type }
    }
    return LoweredIdent { .span = span, .type = type, .symbol = sym }
}

// A fixed array-destructure leaf (`a` in `[a, ...rest]`) — binds the
// leaf to an already-built index access. SimpleBinding binds directly ;
// nested tuples recurse.
emit_let_leaf_array :: fn(
    ctx: FnLowerCtx, leaf: LetBinding, access: LoweredExpr, elem_type: Type,
    span: Span, out: LoweredStmt[],
) -> void {
    match leaf {
        is SimpleBinding as simple -> {
            symbol :: lookup_local_symbol(ctx.project, ctx.typed.resolved, simple.name_span)
            if symbol is null { return }
            out.push(LoweredLet {
                .span = simple.span, .name = simple.name, .symbol = symbol,
                .type = elem_type, .value = access,
            })
        }
        is TupleBinding as nested -> {
            emit_let_binding_leaves(ctx, nested, access, elem_type, span, out)
        }
        _ -> {}
    }
}

emit_let_leaf :: fn(
    ctx: FnLowerCtx, leaf: LetBinding, target: LoweredExpr,
    target_type: Type, index: usize, span: Span, out: LoweredStmt[],
) -> void {
    match leaf {
        is WildcardBinding -> {}
        is RestBinding -> {
            // Rest binding inside a tuple destructure : MVP emits an
            // unreachable so the dump shape stays well-formed. The
            // full TS port routes through `emitArrayDestructure` (an
            // index-loop that fills a fresh array).
            out.push(LoweredExprStmt {
                .span = span,
                .expr = LoweredUnreachable {
                    .span = span, .type = TY_VOID,
                    .reason = "rest-binding (`...name`) lowering deferred",
                },
            })
        }
        is SimpleBinding as simple -> {
            symbol :: lookup_local_symbol(ctx.project, ctx.typed.resolved, simple.name_span)
            if symbol is null { return }
            elem_type :: tuple_or_array_element_type(target_type, index, ctx, simple)
            access :: build_leaf_access(target, target_type, elem_type, simple.span, index)
            out.push(LoweredLet {
                .span = simple.span, .name = simple.name, .symbol = symbol,
                .type = elem_type, .value = access,
            })
        }
        is TupleBinding as nested -> {
            elem_type :: tuple_or_array_element_type(target_type, index, ctx, simple_placeholder(nested))
            access :: build_leaf_access(target, target_type, elem_type, nested.span, index)
            emit_let_binding_leaves(ctx, nested, access, elem_type, nested.span, out)
        }
    }
}

// Fallback `SimpleBinding`-shaped span carrier for nested-tuple leaf
// type lookup (we read the binding's `local_types` entry by its
// `name_span` which doesn't exist for tuples ; in MVP just return
// TY_UNRESOLVED via the placeholder shape).
simple_placeholder :: fn(nested: TupleBinding) -> SimpleBinding {
    return SimpleBinding {
        .span = nested.span, .name = "", .name_span = nested.span,
    }
}

tuple_or_array_element_type :: fn(
    target_type: Type, index: usize, ctx: FnLowerCtx, binding: SimpleBinding,
) -> Type {
    // Prefer the typer's per-binding type (already substituted) when
    // available — most accurate for the user's slot.
    from_typed :: ctx.types.local_type(binding)
    match from_typed {
        is UnresolvedType -> {}
        _ -> { return from_typed }
    }
    match target_type {
        is TupleType as tup -> {
            if index < tup.elements.len() { return tup.elements[index] }
            return TY_UNRESOLVED
        }
        is ArrayType as arr -> { return arr.element }
        _ -> { return TY_UNRESOLVED }
    }
}

import "vader/types" { UnresolvedType }

// Build the `_<index>` field access (tuple) or `[index]` index
// (array) used to read the leaf value from the synthetic `__tup_n`.
build_leaf_access :: fn(
    target: LoweredExpr, target_type: Type, elem_type: Type, span: Span, index: usize,
) -> LoweredExpr {
    match target_type {
        is ArrayType -> {
            return LoweredIndex {
                .span = span, .type = elem_type, .target = target,
                .index = LoweredIntLit {
                    .span = span, .type = mk_primitive("usize"), .value = i64(index),
                },
            }
        }
        _ -> {
            return LoweredFieldAccess {
                .span = span, .type = elem_type, .target = target, .field = "_${index}",
            }
        }
    }
}

/// Recover the resolver-minted `Symbol` whose `defined_at` matches the
/// given binding-site span. Local + param symbols don't live in
/// `resolved.symbols` (that's the top-level table) ; they surface via
/// `resolved.idents`, the use-site map. Scan its values once and pick
/// the first symbol whose `defined_at` matches the target span. Returns
/// `null` when the binding has no use sites (rare in well-formed code).
/// @param resolved  the module's resolved view (`typed.resolved`).
/// @param name_span the binding-site name span.
/// @return          the resolver-minted symbol, or `null` if absent.
synth_unused_local :: fn(ctx: FnLowerCtx, name: string) -> Symbol {
    next_id :: ctx.project.next_synthetic_id
    ctx.project.next_synthetic_id = next_id - i32(1)
    return Symbol {
        .id         = next_id,
        .kind       = SymbolKind.Local,
        .name       = name,
        .module     = ctx.typed.resolved.path,
        .visibility = Visibility.Private,
        .defined_at = null,
    }
}

export lookup_local_symbol :: fn(
    project_ctx: LowerProjectCtx, resolved: ResolvedModule, name_span: Span,
) -> Symbol | null {
    index :: ensure_local_symbol_index(project_ctx, resolved)
    return index[name_span.hash()]
}

// Build (or fetch) the per-module `defined_span_key -> Symbol` index.
// The first call for a given module pays the O(symbols + idents) build
// cost ; every subsequent lookup is constant-time. The resolver's
// `idents` map is the use-site → Symbol view ; combined with the
// flat `symbols` array (for zero-use bindings) it covers exactly
// the two passes of the previous naive walk.
ensure_local_symbol_index :: fn(
    project_ctx: LowerProjectCtx, resolved: ResolvedModule,
) -> MutableMap<u64, Symbol> {
    cached :: project_ctx.local_symbol_indices[resolved.path]
    if !(cached is null) { return cached }
    index :: MutableMap<u64, Symbol> { .buckets = [], .size = 0 }
    // `idents` first — every referenced binding's defined_at lands here.
    for symbol in resolved.idents.values() {
        match symbol.defined_at {
            is null -> {}
            is Span as defined -> { index[defined.hash()] = symbol }
        }
    }
    // Flat symbol list catches definitions with zero use-sites (shadowed
    // bindings, unused params). Resolver writes `defined_at` for every
    // minted Symbol.
    for symbol in resolved.symbols {
        match symbol.defined_at {
            is null -> {}
            is Span as defined -> {
                key :: defined.hash()
                existing :: index[key]
                if existing is null { index[key] = symbol }
            }
        }
    }
    project_ctx.local_symbol_indices[resolved.path] = index
    return index
}

import "vader/resolver" { ResolvedModule }

lower_assign :: fn(ctx: FnLowerCtx, assign_stmt: AssignStmt) -> LoweredStmt {
    // `m[k] = v` over an IndexSet-impl receiver lowers to a static
    // `set_at(m, k, v)` call (mirrors TS's IndexSet sugar). Detected
    // off the LHS shape : `target` is an IndexExpr whose receiver
    // type has a user-defined IndexSet impl.
    via_index_set :: try_lower_index_set_assign(ctx, assign_stmt)
    match via_index_set {
        is null -> {}
        _ -> { return via_index_set }
    }
    // Reassignment to a captured local : write into its cell rather than
    // overwriting the slot. Mirror of `lowerStmt`'s captured-symbol
    // branch in `src/lower/passes/block.ts:159-169`.
    via_cell :: try_lower_cell_set_assign(ctx, assign_stmt)
    match via_cell {
        is null -> {}
        _ -> { return via_cell }
    }
    return LoweredAssign {
        .span = assign_stmt.span,
        .target = lower_assign_target(ctx, assign_stmt.target),
        .value  = lower_expr(ctx, assign_stmt.value),
    }
}

try_lower_cell_set_assign :: fn(ctx: FnLowerCtx, assign_stmt: AssignStmt) -> LoweredStmt | null {
    target_ident :: as_ident(assign_stmt.target)
    if target_ident is null { return null }
    if target_ident is IdentExpr as ident {
        symbol :: ctx.typed.resolved.idents[ident.span.hash()]
        if symbol is null { return null }
        if symbol is Symbol as resolved {
            if !ctx.project.closures.captured_symbols.contains(resolved.id) { return null }
            value_type :: ctx.types.expr_type(ident)
            // Build the cell pointer. Inside a lifted lambda body the
            // captured symbol has no local slot ; the cell ref lives on
            // the env-struct param at `cap_N`. Otherwise (in the
            // enclosing fn) the local slot itself holds the cell.
            // Mirrors `try_route_through_env`'s structure but without
            // the trailing CellGet wrap — we want the raw cell pointer
            // so CellSet can write through it.
            cell_ref: LoweredExpr = LoweredIdent {
                .span = ident.span, .type = value_type, .symbol = resolved,
            }
            lifted :: ctx.lifted_context
            if !(lifted is null) {
                field_name :: lifted.capture_fields[resolved.id]
                if field_name is string as name {
                    env_ident :: LoweredIdent {
                        .span = ident.span, .type = lifted.env_type, .symbol = lifted.env_symbol,
                    }
                    cell_ref = LoweredFieldAccess {
                        .span = ident.span, .type = TY_UNRESOLVED,
                        .target = env_ident, .field = name,
                    }
                }
            }
            return LoweredCellSet {
                .span = assign_stmt.span,
                .target = cell_ref,
                .value = lower_expr(ctx, assign_stmt.value),
                .value_type = value_type,
            }
        }
    }
    return null
}

/// Lvalue lowerer — bypasses the match-narrowing `LoweredCast` wrap that
/// `lower_ident` applies on use-site reads. The bytecode emitter resolves
/// assignment slots via the raw `LoweredIdent` ; a cast in target position
/// breaks that pattern match. Mirror of `rawIdentTarget` in
/// `src/lower/passes/block.ts:177-179`.
lower_assign_target :: fn(ctx: FnLowerCtx, target: Expr) -> LoweredExpr {
    if target is IdentExpr as ident {
        symbol :: ctx.typed.resolved.idents[ident.span.hash()]
        if symbol is Symbol as resolved {
            return LoweredIdent {
                .span = ident.span, .type = ctx.types.expr_type(ident), .symbol = resolved,
            }
        }
    }
    return lower_expr(ctx, target)
}

import "vader/typecheck" { ImplEntry }

// `arr[lo..<hi]` / `arr[lo..=hi]` over an array-typed receiver lowers
// to `LoweredArraySlice` (zero-copy view). Other index expressions
// (single-element access, user IndexExpr on structs) keep the
// generic `LoweredIndex` shape.

lower_index :: fn(ctx: FnLowerCtx, expr: IndexExpr, type: Type) -> LoweredExpr {
    target_type :: ctx.types.expr_type(expr.target)
    is_range :: index_is_range(ctx, expr.index)
    if is_range {
        // `arr[r]` → zero-copy `LoweredArraySlice` ; `s[r]` (string) →
        // codepoint-range `LoweredStringSlice`. Mirror of TS' two
        // `lowerRangeSlice(..., "array" | "string")` dispatch arms
        // (`src/lower/passes/expr.ts:305`).
        if target_type is ArrayType {
            sliced :: try_lower_range_slice(ctx, expr, type, false)
            if sliced != null { return sliced }
        }
        if target_type is PrimitiveType as prim {
            if prim.name == "string" {
                sliced :: try_lower_range_slice(ctx, expr, type, true)
                if sliced != null { return sliced }
            }
        }
    }
    // Index trait routing : `s[i]` on a `string` / user struct with an
    // `Index<I, T>` impl rewrites to a direct `at(s, i)` call. Mirror of
    // TS' `indexResolutions` consumed by `lowerIndexTraitCall`
    // (`src/lower/passes/expr.ts:295`). Skip for ArrayType (built-in
    // path above) and for Range-typed indices (slicing handled above).
    if !(target_type is ArrayType) && !is_range {
        member :: find_impl_member_for(ctx, target_type, "at")
        if member is UfcsMember as found {
            args: LoweredExpr[] = []
            args.push(lower_expr(ctx, expr.target))
            args.push(lower_expr(ctx, expr.index))
            return LoweredCall {
                .span = expr.span, .type = type,
                .callee = LoweredIdent {
                    .span = expr.span, .type = type, .symbol = found.symbol,
                },
                .args = args,
            }
        }
    }
    return LoweredIndex {
        .span = expr.span, .type = type,
        .target = lower_expr(ctx, expr.target),
        .index  = lower_expr(ctx, expr.index),
    }
}

index_is_range :: fn(ctx: FnLowerCtx, index_expr: Expr) -> bool {
    if index_expr is RangeExpr { return true }
    idx_type :: ctx.types.expr_type(index_expr)
    if idx_type is StructType as st { return st.symbol.name == "Range" }
    return false
}

// Build the slice node — `LoweredStringSlice` for codepoint-range string
// slicing, `LoweredArraySlice` for the zero-copy array view. The two
// share an identical shape ; only the runtime op downstream differs.
mk_slice_node :: fn(as_string: bool, span: Span, type: Type, target: LoweredExpr, lo: LoweredExpr, hi: LoweredExpr) -> LoweredExpr {
    if as_string {
        return LoweredStringSlice {
            .span = span, .type = type, .target = target, .lo = lo, .hi = hi,
        }
    }
    return LoweredArraySlice {
        .span = span, .type = type, .target = target, .lo = lo, .hi = hi,
    }
}

try_lower_range_slice :: fn(ctx: FnLowerCtx, expr: IndexExpr, type: Type, as_string: bool) -> LoweredExpr | null {
    match expr.index {
        is RangeExpr as range_lit -> {
            target_lowered :: lower_expr(ctx, expr.target)
            lo_value :: cast_to_usize(lower_expr(ctx, range_lit.lower), range_lit.span)
            hi_raw   :: cast_to_usize(lower_expr(ctx, range_lit.upper), range_lit.span)
            hi_value :: adjust_hi_inclusive(hi_raw, range_lit.inclusive, range_lit.span)
            return mk_slice_node(as_string, expr.span, type, target_lowered, lo_value, hi_value)
        }
        _ -> {}
    }
    // Range-typed *value* index (`let r = 0..<n ; arr[r]`) — bind the
    // range to a temp so the three field reads (`.start`, `.end`,
    // `.inclusive`) share one evaluation, then emit the slice. Mirrors
    // TS' `lowerRangeSlice` second branch (`src/lower/passes/expr.ts`).
    idx_type :: ctx.types.expr_type(expr.index)
    if idx_type is StructType as st {
        if st.symbol.name != "Range" { return null }
        span :: expr.span
        range_sym :: fresh_synthetic_symbol(ctx, "slice_r")
        range_binding :: LoweredLet {
            .span = span, .name = range_sym.name, .symbol = range_sym,
            .type = idx_type, .value = lower_expr(ctx, expr.index),
        }
        range_ref :: LoweredIdent { .span = span, .type = idx_type, .symbol = range_sym }
        bound_type :: if st.args.len() > 0 { st.args[0] } else { mk_primitive("usize") }
        lo_value :: cast_to_usize(LoweredFieldAccess {
            .span = span, .type = bound_type, .target = range_ref, .field = "start",
        }, span)
        hi_raw :: cast_to_usize(LoweredFieldAccess {
            .span = span, .type = bound_type, .target = range_ref, .field = "end",
        }, span)
        hi_value :: adjust_hi_inclusive_dynamic(hi_raw, LoweredFieldAccess {
            .span = span, .type = TY_BOOL, .target = range_ref, .field = "inclusive",
        }, span)
        stmts: LoweredStmt[] = []
        stmts.push(range_binding)
        return LoweredBlock {
            .span = span, .type = type, .stmts = stmts,
            .trailing = mk_slice_node(
                as_string, span, type, lower_expr(ctx, expr.target), lo_value, hi_value,
            ),
        }
    }
    return null
}

adjust_hi_inclusive_dynamic :: fn(hi: LoweredExpr, inclusive: LoweredExpr, span: Span) -> LoweredExpr {
    usize_ty :: mk_primitive("usize")
    delta :: LoweredIf {
        .span = span, .type = usize_ty, .cond = inclusive,
        .then_block = LoweredBlock {
            .span = span, .type = usize_ty, .stmts = [],
            .trailing = LoweredIntLit { .span = span, .type = usize_ty, .value = i64(1) },
        },
        .else_block = LoweredBlock {
            .span = span, .type = usize_ty, .stmts = [],
            .trailing = LoweredIntLit { .span = span, .type = usize_ty, .value = i64(0) },
        },
    }
    return LoweredBinary {
        .span = span, .type = usize_ty, .op = LoweredBinaryOp.Add,
        .left = hi, .right = delta,
    }
}

cast_to_usize :: fn(value: LoweredExpr, span: Span) -> LoweredExpr {
    // No-op when already usize — mirrors TS' `castToUsize`
    // (`src/lower/passes/expr.ts:864`).
    vt :: type_of(value)
    if vt is PrimitiveType as p {
        if p.name == "usize" { return value }
    }
    return LoweredCast { .span = span, .type = mk_primitive("usize"), .value = value }
}

adjust_hi_inclusive :: fn(hi: LoweredExpr, inclusive: bool, span: Span) -> LoweredExpr {
    if !inclusive { return hi }
    return LoweredBinary {
        .span = span, .type = mk_primitive("usize"), .op = LoweredBinaryOp.Add,
        .left = hi,
        .right = LoweredIntLit { .span = span, .type = mk_primitive("usize"), .value = i64(1) },
    }
}

try_lower_index_set_assign :: fn(ctx: FnLowerCtx, assign_stmt: AssignStmt) -> LoweredStmt | null {
    target :: assign_stmt.target
    match target {
        is IndexExpr as idx -> {
            target_type :: ctx.types.expr_type(idx.target)
            // Resolve `set_at` through the canonical impl-member path so the
            // callee carries the SAME mangle the materialiser emits (and that
            // DCE indexes). The old `synth_set_at_symbol` minted a bare
            // `set_at` symbol that no fn-table slot matched, so the call was
            // silently dropped and `m[k] = v` became a no-op (the value leaked
            // onto the stack). Mirrors lower_index's `find_impl_member_for(…,
            // "at")` on the read side.
            member :: find_impl_member_for(ctx, target_type, "set_at")
            if member is null { return null }
            if member is UfcsMember as found {
                // Build `set_at(target, index, value)` direct call.
                receiver :: lower_expr(ctx, idx.target)
                index :: lower_expr(ctx, idx.index)
                value :: lower_expr(ctx, assign_stmt.value)
                args: LoweredExpr[] = []
                args.push(receiver)
                args.push(index)
                args.push(value)
                return LoweredExprStmt {
                    .span = assign_stmt.span,
                    .expr = LoweredCall {
                        .span = assign_stmt.span, .type = TY_VOID,
                        .callee = LoweredIdent {
                            .span = assign_stmt.span, .type = TY_VOID, .symbol = found.symbol,
                        },
                        .args = args,
                    },
                }
            }
            return null
        }
        _ -> { return null }
    }
}

synth_set_at_symbol :: fn(ctx: FnLowerCtx) -> Symbol {
    return Symbol {
        .id         = i32(0),
        .kind       = SymbolKind.Fn,
        .name       = "set_at",
        .module     = ctx.typed.resolved.path,
        .visibility = Visibility.Private,
        .defined_at = null,
    }
}

lower_return :: fn(ctx: FnLowerCtx, return_stmt: ReturnStmt) -> LoweredStmt {
    match return_stmt.value {
        is null -> { return LoweredReturn { .span = return_stmt.span, .value = null } }
        _ -> {
            lowered :: lower_expr(ctx, return_stmt.value)
            // Widen a literal-shaped return value to the fn's declared
            // return type when the return type is a union and the literal
            // currently carries its narrow inferred type. The typer in
            // Vader doesn't propagate context types into literals ; this
            // late widening matches the TS dump which always records the
            // wider expected type at the use site.
            retyped :: widen_literal_to_context(lowered, ctx.return_type)
            // Auto-Into coercion when the return type doesn't match the
            // value's type AND an `Into[return_type]` impl exists.
            coerced :: try_emit_into_coercion(ctx, retyped, type_of(retyped), ctx.return_type, return_stmt.span)
            final :: match coerced {
                is null -> retyped
                _ -> coerced
            }
            return LoweredReturn { .span = return_stmt.span, .value = final }
        }
    }
}

// True when `s` will exit its enclosing block (control flow never
// reaches a subsequent stmt). Used to suppress block-fall-through
// emissions after a divergent stmt (return / break / continue).
stmt_diverges :: fn(s: LoweredStmt) -> bool {
    if s is LoweredReturn   { return true }
    if s is LoweredBreak    { return true }
    if s is LoweredContinue { return true }
    // `wrap_stmts(span, [pop_exec, return])` produces a
    // `LoweredExprStmt { expr = LoweredBlock { stmts, trailing = null } }`
    // whose inner block's last stmt is the actual return / break /
    // continue. Peek through one level so the enclosing block's
    // fall-through drain doesn't emit a duplicate pop_exec after a
    // wrapped exit.
    if s is LoweredExprStmt as es {
        if es.expr is LoweredBlock as lb {
            n :: lb.stmts.len()
            if n > 0 { return stmt_diverges(lb.stmts[n - 1]) }
        }
    }
    return false
}

// Sum the `defers` count across every open BlockCtx and emit a
// single `defer.pop_exec N` ; matches TS's "drain everything to fn
// root before return" semantics.
drain_all_defers :: fn(ctx: FnLowerCtx, span: Span, out: LoweredStmt[]) -> void {
    total: i32 = 0
    for b in ctx.blocks { total += i32(b.defers.len()) }
    if total > 0 {
        out.push(LoweredDeferPopExec { .span = span, .count = total })
    }
}

// Sum defers from the innermost block up to (but not including) the
// nearest enclosing loop body — break/continue exit only the loop
// scope, not the fn.
drain_defers_to_loop :: fn(ctx: FnLowerCtx, span: Span, out: LoweredStmt[]) -> void {
    total: i32 = 0
    i := i64(ctx.blocks.len()) - i64(1)
    for i >= 0 {
        b :: ctx.blocks[usize(i)]
        total += i32(b.defers.len())
        if b.is_loop_body { break }
        i -= 1
    }
    if total > 0 {
        out.push(LoweredDeferPopExec { .span = span, .count = total })
    }
}

widen_literal_to_context :: fn(expr: LoweredExpr, context_type: Type) -> LoweredExpr {
    if !(context_type is UnionType) { return expr }
    // Only widen when the literal's narrow type appears as one of the
    // union's variants. For enum-context returns / args, the literal's
    // i32 / repr type is NOT a variant — leave it alone.
    inner :: type_of(expr)
    if !union_contains_variant(context_type, inner) { return expr }
    match expr {
        is LoweredIntLit    as lit -> { return LoweredIntLit    { .span = lit.span, .type = context_type, .value = lit.value } }
        is LoweredFloatLit  as lit -> { return LoweredFloatLit  { .span = lit.span, .type = context_type, .value = lit.value } }
        is LoweredStringLit as lit -> { return LoweredStringLit { .span = lit.span, .type = context_type, .value = lit.value } }
        is LoweredCharLit   as lit -> { return LoweredCharLit   { .span = lit.span, .type = context_type, .value = lit.value } }
        is LoweredBoolLit   as lit -> { return LoweredBoolLit   { .span = lit.span, .type = context_type, .value = lit.value } }
        _ -> { return expr }
    }
}

union_contains_variant :: fn(union: Type, variant: Type) -> bool {
    match union {
        is UnionType as u -> {
            for v in u.variants {
                if equals_type(v, variant) { return true }
            }
            return false
        }
        _ -> { return false }
    }
}

// Phase 3 covers infinite-for and while-for. for-in collapses to an
// Iterator step-loop via Phase 5's dedicated module ; emit a stub here.
lower_for :: fn(ctx: FnLowerCtx, for_stmt: ForStmt) -> LoweredStmt {
    // `@comptime for x in <arr> { body }` — unroll at lower time when
    // the iter folds to a `LoweredArrayLit`. Threads the per-iter
    // substitution through `ctx.comptime_bindings` so `lower_ident`
    // folds loop-var reads to their literal. Mirror of
    // `src/lower/passes/for-in.ts::lowerComptimeForIn`.
    if for_stmt.is_comptime {
        if for_stmt.form is InFor as in_form {
            return lower_comptime_for_in(ctx, for_stmt, in_form)
        }
    }
    match for_stmt.form {
        is InfiniteFor -> {
            body :: lower_block(ctx, for_stmt.body, false, true)
            return LoweredLoop {
                .span = for_stmt.span, .label = for_stmt.label,
                .cond = null, .body = body,
            }
        }
        is WhileFor as while_for -> {
            // `for <iter> { body }` sugar : when the cond evaluates to an
            // iterable shape (array, range, struct with `Iterator` impl),
            // route through the for-in lowerer with a synthetic discard
            // binding `_`. Mirrors TS `whileAsForIn` in
            // `src/lower/passes/block.ts:233-238`.
            cond_type :: ctx.types.expr_type(while_for.cond)
            if cond_type is ArrayType {
                synth_in :: InFor {
                    .binding      = "_",
                    .binding_span = while_for.cond.span,
                    .iter         = while_for.cond,
                }
                return lower_for_in(ctx, for_stmt, synth_in, lower_expr, lower_block)
            }
            cond :: lower_expr(ctx, while_for.cond)
            body :: lower_block(ctx, for_stmt.body, false, true)
            return LoweredLoop {
                .span = for_stmt.span, .label = for_stmt.label,
                .cond = cond, .body = body,
            }
        }
        is InFor as in_form -> {
            return lower_for_in(ctx, for_stmt, in_form, lower_expr, lower_block)
        }
    }
}

/// Unroll a `@comptime for x in <arr> { body }` at lower time.
/// Mirror of `src/lower/passes/for-in.ts::lowerComptimeForIn`.
/// Returns a synthetic block whose stmts are the body lowered once
/// per iter element, with the loop-var symbol bound to the per-iter
/// literal via `comptime_bindings`.
lower_comptime_for_in :: fn(ctx: FnLowerCtx, for_stmt: ForStmt, in_form: InFor) -> LoweredStmt {
    span :: for_stmt.span
    binding_symbol :: lookup_for_binding(ctx, in_form.binding_span)
    if binding_symbol is null {
        return LoweredExprStmt {
            .span = span,
            .expr = LoweredUnreachable {
                .span = span, .type = TY_VOID,
                .reason = "@comptime for binding not resolved",
            },
        }
    }
    iter_lowered :: lower_expr(ctx, in_form.iter)
    arr_lit: LoweredArrayLit | null = null
    if iter_lowered is LoweredArrayLit as al { arr_lit = al }
    if arr_lit is null {
        return LoweredExprStmt {
            .span = span,
            .expr = LoweredUnreachable {
                .span = span, .type = TY_VOID,
                .reason = "@comptime for requires a compile-time-known array literal",
            },
        }
    }
    if arr_lit.elements.len() > 256 {
        return LoweredExprStmt {
            .span = span,
            .expr = LoweredUnreachable {
                .span = span, .type = TY_VOID,
                .reason = "@comptime for exceeds the unroll cap (256)",
            },
        }
    }
    // Save the prior binding so nested `@comptime for` over the same
    // name doesn't silently clobber an outer scope's substitution.
    prior :: ctx.comptime_bindings[binding_symbol.id]
    unrolled: LoweredStmt[] = []
    for elt in arr_lit.elements {
        ctx.comptime_bindings[binding_symbol.id] = elt
        body :: lower_block(ctx, for_stmt.body, false, false)
        for s in body.stmts { unrolled.push(s) }
        if body.trailing !is null {
            unrolled.push(LoweredExprStmt {
                .span = span_of(body.trailing), .expr = body.trailing,
            })
        }
    }
    if prior is null {
        // Erase the binding from the map. MutableMap has no `delete`,
        // so leave the last per-iter binding in place — any later use
        // of the same binding symbol would be a recursion bug rather
        // than expected.
    } else {
        ctx.comptime_bindings[binding_symbol.id] = prior
    }
    return LoweredExprStmt {
        .span = span,
        .expr = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = unrolled, .trailing = null,
        },
    }
}

// ============================================================================
// Op translation tables
// ============================================================================

lower_unary_op :: fn(op: UnaryOp) -> LoweredUnaryOp = match op {
    .Neg    -> LoweredUnaryOp.Neg
    .Not    -> LoweredUnaryOp.Not
    .BitNot -> LoweredUnaryOp.BitNot
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_lower_unary_op_table :: fn() -> void {
    assert_eq(i32(lower_unary_op(UnaryOp.Neg)),    i32(LoweredUnaryOp.Neg))
    assert_eq(i32(lower_unary_op(UnaryOp.Not)),    i32(LoweredUnaryOp.Not))
    assert_eq(i32(lower_unary_op(UnaryOp.BitNot)), i32(LoweredUnaryOp.BitNot))
}

@test test_lower_binary_op_basic_arithmetic :: fn() -> void {
    assert_eq(i32(lower_binary_op(BinaryOp.Add)), i32(LoweredBinaryOp.Add))
    assert_eq(i32(lower_binary_op(BinaryOp.Eq)),  i32(LoweredBinaryOp.Eq))
    // `Is` is routed through the dedicated lowerer ; the table maps it
    // to `Eq` to keep the match exhaustive without firing.
    assert_eq(i32(lower_binary_op(BinaryOp.Is)),  i32(LoweredBinaryOp.Eq))
}

lower_binary_op :: fn(op: BinaryOp) -> LoweredBinaryOp = match op {
    .Add    -> LoweredBinaryOp.Add
    .Sub    -> LoweredBinaryOp.Sub
    .Mul    -> LoweredBinaryOp.Mul
    .Div    -> LoweredBinaryOp.Div
    .Mod    -> LoweredBinaryOp.Mod
    .Shl    -> LoweredBinaryOp.Shl
    .Shr    -> LoweredBinaryOp.Shr
    .BitAnd -> LoweredBinaryOp.BitAnd
    .BitOr  -> LoweredBinaryOp.BitOr
    .BitXor -> LoweredBinaryOp.BitXor
    .And    -> LoweredBinaryOp.And
    .Or     -> LoweredBinaryOp.Or
    .Eq     -> LoweredBinaryOp.Eq
    .Neq    -> LoweredBinaryOp.Neq
    .Lt     -> LoweredBinaryOp.Lt
    .Lte    -> LoweredBinaryOp.Lte
    .Gt     -> LoweredBinaryOp.Gt
    .Gte    -> LoweredBinaryOp.Gte
    // Is / In / NotIn are routed through dedicated lowerers above ;
    // mapping them to `Eq` keeps `match` exhaustive without firing.
    .Is     -> LoweredBinaryOp.Eq
    .In     -> LoweredBinaryOp.Eq
    .NotIn  -> LoweredBinaryOp.Eq
}
