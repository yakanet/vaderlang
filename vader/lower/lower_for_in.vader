// vader/lower/lower_for_in — `for x in iter` lowering.
//
// Mirror of `src/lower/passes/for-in.ts::lowerForIn` (MVP slow path).
// Desugars `for x in <iter> { body }` into the Iterator step loop :
//
//   let __iter_n :: <iter, optionally array-wrapped>
//   loop {
//     let __step_m :: <iter>.Iterator.next()
//     if __step_m is null { break }
//     let x :: (__step_m as Yield(T)).value
//     <body>
//   }
//
// Auto-wraps `T[]` iterators into `ArrayIterator(T)` so the loop
// dispatches through the standard Iterator impl. The TS code has
// several fast paths (int-range counter loop, std/iter chain fusion,
// MutableMap inline) that the Vader MVP skips — they're snapshot-
// matching wins for ~5-10 specific snippets but each is a substantial
// port.

module "vader/lower"

import "vader/diagnostics" { Span, lower_error }
AST :: import "vader/parser"
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/types" {
    Type, ArrayType, StructType, TraitType, EnumType, PrimitiveType,
    UnresolvedType,
    mk_struct, mk_array, mk_union, mk_primitive, display_type,
    TY_BOOL, TY_VOID, TY_NEVER, TY_UNRESOLVED,
    STRUCT_ARRAY_ITERATOR, STRUCT_YIELD, TRAIT_ITERATOR,
}

/// Lower a `for x in iter { body }` statement to a step-loop driven
/// by the `Iterator(T).next()` dispatch.
/// @param ctx          the fn-body context.
/// @param for_stmt     the source for-stmt (carries label + body).
/// @param in_form      the iter binding + iter expression.
/// @param recurse      callback to lower nested expressions.
/// @param block_lowerer callback to lower the body block (cycle break).
/// @return             the lowered stmt (a block wrapping the loop).
export lower_for_in :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt {
    span :: for_stmt.span
    // Fast path : `for x in <chain>` where `<chain>` is one or more
    // `std/iter` lazy combinators (`MapIterator` / `FilterIterator`,
    // struct-literal form) wrapping a literal integer range — fuse
    // the whole pipeline into a single counter loop. Skipped when the
    // bottom isn't an int range, when any layer references its source
    // via a variable, or when a `f` / `pred` field isn't a bare fn
    // reference (the slow path handles those).
    chain_form :: try_lower_chain_fusion(ctx, for_stmt, in_form, recurse, block_lowerer)
    match chain_form {
        is null -> {}
        _ -> { return chain_form }
    }
    // Fast path : `for x in lo..<hi` / `for x in lo..=hi` over an
    // integer range lowers to a direct counter loop ; no Range
    // allocation, no `Iterator.next` dispatch. Falls through to the
    // slow path when the range bound isn't an integer.
    int_range :: try_lower_for_in_int_range(ctx, for_stmt, in_form, recurse, block_lowerer)
    match int_range {
        is null -> {}
        _ -> { return int_range }
    }
    iter_lowered_raw :: recurse(ctx, in_form.iter)
    iter_type_raw :: type_of(iter_lowered_raw)

    // Fast path : `for x in arr` over a raw `T[]` lowers to a counter
    // loop with index lookup. No ArrayIterator allocation, no per-iter
    // virtual call. Falls through to the slow path when the iter type
    // isn't a plain array. Mirrors TS `lowerForInRawArray` in
    // `src/lower/passes/for-in.ts:346`.
    raw_array :: try_lower_for_in_raw_array(ctx, for_stmt, in_form, iter_lowered_raw, iter_type_raw, recurse, block_lowerer)
    match raw_array {
        is null -> {}
        _ -> { return raw_array }
    }

    // Fast path : `for entry in m` over `MutableMap(K, V)` (or
    // `for v in s` over `MutableSet(T)`) inlines the bucket-walk +
    // chain-traversal, skipping the MapIterator allocation and the
    // per-iter `next()` + `Yield` allocations. Mirror of TS'
    // `tryLowerForInMapSetIterInline`.
    map_set :: try_lower_for_in_map_set(ctx, for_stmt, in_form, iter_lowered_raw, iter_type_raw, span, block_lowerer)
    match map_set {
        is null -> {}
        _ -> { return map_set }
    }

    // Auto-wrap `T[]` → ArrayIterator(T) so the step-loop can dispatch
    // through the standard Iterator impl. Falls through to the raw
    // value when the array iterator type isn't reachable.
    wrap_result :: try_wrap_array_iter(ctx, iter_lowered_raw, iter_type_raw, span)
    iter_lowered :: wrap_result.iter
    iter_type :: wrap_result.iter_type
    element_type :: resolve_element_type(ctx, iter_type_raw, iter_type, in_form.binding_span.hash())

    // M5001 — `for x in iter` needs an Iterator impl on `iter`. When
    // wrapping leaves the iter as a primitive (string / numeric / …),
    // no Iterator dispatch is reachable from the lower step-loop. Mirrors
    // TS `src/lower/passes/for-in.ts:178` which emits B5001 ; Vader uses
    // M5001 (IteratorImplMissing) instead.
    if iter_type is PrimitiveType {
        // No Iterator impl is reachable from the step-loop for a bare
        // primitive (string / numeric / …) — emit the diagnostic and a
        // single `unreachable` rather than a dispatch loop that would
        // call `next()` on the primitive. Matches TS.
        ctx.project.diags.push(lower_error(.IteratorImplMissing, span,
            "`for x in iter` requires an Iterator impl on ${display_type(iter_type)}"))
        return LoweredExprStmt {
            .span = span,
            .expr = LoweredUnreachable {
                .span = span, .type = TY_VOID,
                .reason = "no Iterator impl on ${display_type(iter_type)}",
            },
        }
    }
    yield_type_opt :: find_core_type(ctx, STRUCT_YIELD, build_one(element_type))
    if yield_type_opt is null {
        return LoweredExprStmt {
            .span = span,
            .expr = LoweredUnreachable {
                .span = span, .type = TY_VOID,
                .reason = "for-in needs std/core::Yield",
            },
        }
    }
    yield_type :: yield_type_opt
    binding_symbol :: resolve_binding_or_synth(ctx, in_form)

    iter_symbol :: fresh_synthetic_symbol(ctx, "iter")
    step_symbol :: fresh_synthetic_symbol(ctx, "step")
    step_union :: union_of_yield_null(yield_type)

    iter_let :: LoweredLet {
        .span = span, .name = iter_symbol.name, .symbol = iter_symbol,
        .type = iter_type, .value = iter_lowered,
    }

    iter_ref :: LoweredIdent { .span = span, .type = iter_type, .symbol = iter_symbol }
    step_call :: build_step_call(ctx, iter_ref, iter_type, step_union, span)
    step_let :: LoweredLet {
        .span = span, .name = step_symbol.name, .symbol = step_symbol,
        .type = step_union, .value = step_call,
    }

    step_ref :: LoweredIdent { .span = span, .type = step_union, .symbol = step_symbol }
    is_done :: LoweredTypeCheck {
        .span = span, .type = TY_BOOL, .value = step_ref, .check_type = mk_primitive("null"),
    }

    yield_cast :: LoweredCast { .span = span, .type = yield_type, .value = step_ref }
    value_access :: LoweredFieldAccess {
        .span = span, .type = element_type, .target = yield_cast, .field = "value",
    }
    bind_let :: LoweredLet {
        .span = span, .name = in_form.binding, .symbol = binding_symbol,
        .type = element_type, .value = value_access,
    }

    user_body :: block_lowerer(ctx, for_stmt.body, false, true)
    body_stmts :: build_body_stmts(bind_let, user_body)

    branch_if :: LoweredExprStmt {
        .span = span,
        .expr = LoweredIf {
            .span = span, .type = TY_VOID,
            .cond = is_done,
            .then_block = LoweredBlock {
                .span = span, .type = TY_VOID,
                .stmts = build_break_stmts(span), .trailing = null,
            },
            .else_block = LoweredBlock {
                .span = span, .type = TY_VOID, .stmts = body_stmts, .trailing = null,
            },
        },
    }

    loop_stmts: LoweredStmt[] = []
    loop_stmts.push(step_let)
    loop_stmts.push(branch_if)

    loop_stmt :: LoweredLoop {
        .span = span, .label = for_stmt.label, .cond = null,
        .body = LoweredBlock {
            .span = span, .type = TY_VOID, .stmts = loop_stmts, .trailing = null,
        },
    }

    block_stmts: LoweredStmt[] = []
    block_stmts.push(iter_let)
    block_stmts.push(loop_stmt)
    return LoweredExprStmt {
        .span = span,
        .expr = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = block_stmts, .trailing = null,
        },
    }
}

// ---- helpers --------------------------------------------------------------

build_one :: fn(t: Type) -> Type[] {
    out: Type[] = []
    out.push(t)
    return out
}

build_break_stmts :: fn(span: Span) -> LoweredStmt[] {
    out: LoweredStmt[] = []
    out.push(LoweredBreak { .span = span, .label = null })
    return out
}

build_body_stmts :: fn(bind_let: LoweredStmt, user_body: LoweredBlock) -> LoweredStmt[] {
    out: LoweredStmt[] = []
    out.push(bind_let)
    for stmt in user_body.stmts { out.push(stmt) }
    if user_body.trailing is null { return out }
    out.push(LoweredExprStmt { .span = span_of(user_body.trailing), .expr = user_body.trailing })
    return out
}

WrapResult :: struct {
    iter:      LoweredExpr
    iter_type: Type
}

// Wrap a non-iterator receiver into a concrete struct iterator so the
// step-loop has something to dispatch `next()` on :
//   - `T[]`     → `ArrayIterator(T)` (struct-wrapped in place ; avoids the
//                 erased-`Iterator(T)` virtual-call hazard, mirror of TS's
//                 raw-array path).
//   - `string`  → `StringChars` via a synthesised `chars(s)` call. `string`
//                 implements `Into(Iterator(char))`, but routing through
//                 `into()` yields the erased `Iterator(char)` trait (the same
//                 hazard) ; calling `chars` keeps the CONCRETE `StringChars`,
//                 which `build_step_call`'s StructType path already resolves
//                 (so `for c in s` matches `for c in s.chars()`). `chars` is
//                 materialised by the normal reachability walk over the emitted
//                 call. Mirror of TS `for-in.ts` resolving `string`'s iterator.
// Returns the input verbatim when no wrap applies.
try_wrap_array_iter :: fn(
    ctx: FnLowerCtx, iter: LoweredExpr, iter_type: Type, span: Span,
) -> WrapResult {
    match iter_type {
        is ArrayType as arr -> {
            wrapped_type :: find_core_type(ctx, STRUCT_ARRAY_ITERATOR, [arr.element])
            if wrapped_type is null { return WrapResult { .iter = iter, .iter_type = iter_type } }
            fields: LoweredStructLitField[] = []
            fields.push(LoweredStructLitField {
                .name = "arr", .value = iter,
            })
            fields.push(LoweredStructLitField {
                .name = "cursor",
                .value = LoweredIntLit {
                    .span = span, .type = mk_primitive("usize"), .value = i64(0),
                },
            })
            wrapped :: LoweredStructLit {
                .span = span, .type = wrapped_type, .fields = fields,
            }
            return WrapResult { .iter = wrapped, .iter_type = wrapped_type }
        }
        is PrimitiveType as p -> {
            if p.name != "string" { return WrapResult { .iter = iter, .iter_type = iter_type } }
            chars_member :: find_free_fn_ufcs(ctx, iter_type, "chars")
            if chars_member is null { return WrapResult { .iter = iter, .iter_type = iter_type } }
            chars_fn_ty :: lookup_fn_type_anywhere(ctx, chars_member.symbol)
            if chars_fn_ty is FnType as ft {
                args: LoweredExpr[] = []
                args.push(iter)
                chars_call :: LoweredCall {
                    .span = span, .type = ft.return_type,
                    .callee = LoweredIdent {
                        .span = span, .type = ft.return_type, .symbol = chars_member.symbol,
                    },
                    .args = args,
                }
                return WrapResult { .iter = chars_call, .iter_type = ft.return_type }
            }
            return WrapResult { .iter = iter, .iter_type = iter_type }
        }
        _ -> { return WrapResult { .iter = iter, .iter_type = iter_type } }
    }
}

// Determine the element type yielded by the iterator. Tries :
// 0. The type the typer already bound to the loop variable, stored under
//    its span in `local_types`. This is authoritative : the typer resolves
//    the `Iterator(T)` impl and substitutes the iterator's concrete type
//    args, so it correctly handles combinators whose element type is NOT
//    the first type arg — `MapIterator(i32, i64)` yields `i64` (the impl's
//    `Iterator(U)`), not the source `i32` ; a `MutableMap` iterator yields
//    `Entry(K, V)`. The structural heuristics below cannot, so they must
//    only run when the typer left no usable entry.
// 1. The raw iter type's first type-arg (Range(T), ArrayIterator(T)).
// 2. `typed.iter_element_types[display_type(raw_iter_type)]` — written
//    by the typecheck when checking the Iterator impl.
// 3. Falls back to TY_UNRESOLVED so the lowered loop still emits a
//    well-formed shape (the typer's earlier diagnostics already
//    surfaced the missing impl).
resolve_element_type :: fn(ctx: FnLowerCtx, raw_iter_type: Type, iter_type: Type, binding_key: u64) -> Type {
    from_typed_binding :: ctx.typed.local_types[binding_key]
    if !(from_typed_binding is null) {
        if !(from_typed_binding is UnresolvedType) { return from_typed_binding }
    }
    match iter_type {
        is StructType as st -> {
            if st.args.len() > usize(0) { return st.args[0] }
        }
        _ -> {}
    }
    match raw_iter_type {
        is StructType as st -> {
            if st.args.len() > usize(0) { return st.args[0] }
        }
        is TraitType as tt -> {
            if tt.args.len() > usize(0) { return tt.args[0] }
        }
        _ -> {}
    }
    side_table_key :: display_type(iter_type)
    from_typed :: ctx.typed.iter_element_types[side_table_key]
    if !(from_typed is null) { return from_typed }
    return TY_UNRESOLVED
}

// Build the per-iter `.next()` step call. Trait-typed iter →
// `LoweredVirtualCall` ; concrete struct iter → `LoweredCall` to a
// synth `next` symbol. The bytecode emit resolves the synth callee
// via the impl-member mangling once that wiring lands.
build_step_call :: fn(
    ctx: FnLowerCtx, iter_ref: LoweredExpr, iter_type: Type, step_union: Type, span: Span,
) -> LoweredExpr {
    match iter_type {
        is TraitType as tt -> {
            if tt.symbol.name == TRAIT_ITERATOR {
                args: LoweredExpr[] = []
                return LoweredVirtualCall {
                    .span = span, .type = step_union,
                    .trait_name = TRAIT_ITERATOR, .method = "next",
                    .receiver = iter_ref, .args = args,
                }
            }
        }
        _ -> {}
    }
    // Concrete struct iter (e.g. `Repeat<i32>`) : the impl-member `next`
    // instance is mangled `<module>$<Struct>$Iterator$next<args-suffix>`
    // (mirror of the generic-impl instance materialisation, lower.vader).
    // Carry that mangle so the CFG call emit resolves it via
    // `function_index_by_mangle` instead of dropping a bare-name callee.
    // For multi-instantiation the erasure-dedupe keeps one body under the
    // first instance's suffix ; single-instantiation (the common case)
    // matches exactly. Cross-module user generic-impls would need the
    // impl's owning module (see GATE B1) — caller-module here covers the
    // colocated-struct case.
    method_next :: "next"
    next_name := method_next
    if iter_type is StructType as st {
        // Resolve the struct's Iterator impl entry. The materialised `next`
        // member is registered under the impl's OWNING module (GATE B1) — not
        // the caller's — so a cross-module iterator (e.g. `std/string`'s
        // `StringChars`, used from any module via `for c in s`) resolves to
        // the same mangle `surface_stdlib_impl_externs` / the generic
        // materialiser emits. Generic impls erase instance args to `__Any` ;
        // concrete-instantiation iterators keep the concrete suffix. Mirror of
        // `find_impl_member_for`.
        owning_module := mangle_module_id(ctx.typed.resolved.display_path)
        is_gen := false
        for entry in ctx.project.impls.all {
            if entry.decl.trait_name != TRAIT_ITERATOR { continue }
            if impl_targets_name(entry.decl.for_type, st.symbol.name) {
                owning_module = mangle_module_id(entry.module)
                is_gen = entry.is_generic
            }
        }
        suffix :: if is_gen { mixed_any_suffix(st.args) } else { args_suffix(st.args) }
        next_name = "${owning_module}$${st.symbol.name}$${TRAIT_ITERATOR}$${method_next}${suffix}"
        // Record the call so the post-lowering pass materialises the (with-body)
        // stdlib impl member instead of dropping the call to the panic fallback.
        ctx.project.referenced_impl_mangles.add(next_name)
    }
    next_symbol :: synth_next_symbol(ctx, next_name)
    args: LoweredExpr[] = []
    args.push(iter_ref)
    return LoweredCall {
        .span = span, .type = step_union,
        .callee = LoweredIdent {
            .span = span, .type = TY_UNRESOLVED, .symbol = next_symbol,
        },
        .args = args,
    }
}

synth_next_symbol :: fn(ctx: FnLowerCtx, name: string) -> Symbol {
    return Symbol {
        .id         = i32(0),
        .kind       = SymbolKind.Fn,
        .name       = name,
        .module     = ctx.typed.resolved.path,
        .visibility = AST.Visibility.Private,
        .defined_at = null,
    }
}

// Look up the for-in binding's resolver-minted Symbol — scan
// `idents.values()` by `defined_at == binding_span`. Mirrors the
// `lookup_local_symbol` shape used elsewhere.
export lookup_for_binding :: fn(ctx: FnLowerCtx, binding_span: Span) -> Symbol | null {
    target_key :: binding_span.hash()
    for [_, symbol] in ctx.typed.resolved.idents {
        match symbol.defined_at {
            is null -> {}
            is Span as defined -> {
                if defined.hash() == target_key { return symbol }
            }
        }
    }
    return null
}

// For-in bindings that the body never references don't appear in
// `resolved.idents` (the use-site map). Synthesize a placeholder
// symbol so the lowered shape stays consistent.
resolve_binding_or_synth :: fn(ctx: FnLowerCtx, in_form: AST.InFor) -> Symbol {
    found :: lookup_for_binding(ctx, in_form.binding_span)
    match found {
        is Symbol as s -> { return s }
        is null -> {
            // Unused for-binding (never referenced in the body, so absent
            // from `resolved.idents`). Mint a FRESH unique id rather than a
            // shared `0` : the counter is still a real local that drives the
            // loop's increment/condition, and bytecode slots are keyed by
            // symbol id — two nested unused-binding loops both at id 0 would
            // alias one slot, so the outer increment writes the inner's
            // counter and the outer loop never terminates (infinite loop).
            fresh :: fresh_synthetic_symbol(ctx, in_form.binding)
            return Symbol {
                .id         = fresh.id,
                .kind       = SymbolKind.Local,
                .name       = in_form.binding,
                .module     = ctx.typed.resolved.path,
                .visibility = AST.Visibility.Private,
                .defined_at = null,
            }
        }
    }
}


// ---- raw-array fast path --------------------------------------------------

// `for x in arr` over a raw `T[]` lowers to a counter loop with index
// lookup — no ArrayIterator allocation, no per-iter virtual call.
// Mirrors TS `lowerForInRawArray` in `src/lower/passes/for-in.ts:346`.
//
// Returns null when the iter type isn't a plain array ; caller falls
// back to the wrap-into-ArrayIterator slow path.
try_lower_for_in_raw_array :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    iter_lowered: LoweredExpr, iter_type: Type,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    array_elem_type: Type = TY_UNRESOLVED
    if iter_type is ArrayType as arr {
        array_elem_type = arr.element
    } else {
        return null
    }
    span :: for_stmt.span
    binding_symbol :: resolve_binding_or_synth(ctx, in_form)
    usize_type :: mk_primitive("usize")

    arr_sym :: fresh_synthetic_symbol(ctx, "for_arr")
    len_sym :: fresh_synthetic_symbol(ctx, "for_len")
    idx_sym :: fresh_synthetic_symbol(ctx, "for_i")

    arr_let :: LoweredLet {
        .span = span, .name = arr_sym.name, .symbol = arr_sym,
        .type = iter_type, .value = iter_lowered,
    }
    arr_ref :: LoweredIdent { .span = span, .type = iter_type, .symbol = arr_sym }
    len_let :: LoweredLet {
        .span = span, .name = len_sym.name, .symbol = len_sym, .type = usize_type,
        .value = LoweredArrayLen { .span = span, .type = usize_type, .target = arr_ref },
    }
    idx_init :: LoweredLet {
        .span = span, .name = idx_sym.name, .symbol = idx_sym, .type = usize_type,
        .value = LoweredIntLit { .span = span, .type = usize_type, .value = i64(0) },
    }
    idx_ref :: LoweredIdent { .span = span, .type = usize_type, .symbol = idx_sym }
    len_ref :: LoweredIdent { .span = span, .type = usize_type, .symbol = len_sym }

    cond :: LoweredBinary {
        .span = span, .type = TY_BOOL, .op = LoweredBinaryOp.Lt,
        .left = idx_ref, .right = len_ref,
    }
    bind_stmt :: LoweredLet {
        .span = span, .name = in_form.binding, .symbol = binding_symbol,
        .type = array_elem_type,
        .value = LoweredIndex {
            .span = span, .type = array_elem_type,
            .target = arr_ref, .index = idx_ref,
        },
    }
    inc_stmt :: LoweredAssign {
        .span = span, .target = idx_ref,
        .value = LoweredBinary {
            .span = span, .type = usize_type, .op = LoweredBinaryOp.Add,
            .left = idx_ref,
            .right = LoweredIntLit { .span = span, .type = usize_type, .value = i64(1) },
        },
    }

    user_body :: block_lowerer(ctx, for_stmt.body, false, true)
    advanced :: prepend_inc_before_matching_continue(user_body, inc_stmt, for_stmt.label)
    body_stmts: LoweredStmt[] = []
    body_stmts.push(bind_stmt)
    for stmt in advanced.stmts { body_stmts.push(stmt) }
    if !(advanced.trailing is null) {
        body_stmts.push(LoweredExprStmt { .span = span_of(advanced.trailing), .expr = advanced.trailing })
    }
    body_stmts.push(inc_stmt)

    loop_stmt :: LoweredLoop {
        .span = span, .label = for_stmt.label, .cond = cond,
        .body = LoweredBlock {
            .span = span, .type = TY_VOID, .stmts = body_stmts, .trailing = null,
        },
    }

    block_stmts: LoweredStmt[] = []
    block_stmts.push(arr_let)
    block_stmts.push(len_let)
    block_stmts.push(idx_init)
    block_stmts.push(loop_stmt)
    return LoweredExprStmt {
        .span = span,
        .expr = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = block_stmts, .trailing = null,
        },
    }
}

// ---- int-range fast path --------------------------------------------------


// `for x in lo..<hi` / `for x in lo..=hi` over an integer-typed range
// bottom emits a counter loop. Mirrors TS's `tryLowerForInIntRange`.
// Returns null when the bound isn't an integer ; caller falls back to
// the slow path (Iterator step dispatch).
try_lower_for_in_int_range :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    range :: extract_range(in_form.iter)
    if range is null { return null }
    raw_lower :: ctx.types.expr_type(range.lower)
    raw_upper :: ctx.types.expr_type(range.upper)
    if !is_integer_type(raw_lower) { return null }
    // Pick the counter's width from whichever bound is concrete : a
    // FreeInt literal on either side adopts the other's width. When
    // both bounds are concrete, the lower side wins (matches the
    // typer's left-to-right inference). When both are FreeInt, fall
    // back to the i32 default via `default_if_free`. Mirror of TS'
    // for-in counter typing where the Range's element type is
    // already settled by the bidirectional infer.
    bound_type :: if raw_lower is FreeIntType {
        if is_integer_type(raw_upper) { default_if_free(raw_upper) } else { default_if_free(raw_lower) }
    } else {
        default_if_free(raw_lower)
    }
    // For-in bindings that the body never references don't surface
    // in `resolved.idents` (the use-site map). Synthesize a placeholder
    // when the lookup misses so the dump still renders ; matches the
    // shape TS produces via its dedicated `resolved.forIns` table.
    binding_symbol :: resolve_binding_or_synth(ctx, in_form)
    span :: for_stmt.span
    // Re-type FreeInt literals on either bound to the resolved
    // `bound_type` so `let i: u64 = int(0) :u64` doesn't dump as
    // `int(0) :i32`. The counter's declared slot already widens to
    // bound_type, but the literal's own type carries the i32 default
    // unless the typer narrowed it ; rewrite the LoweredIntLit here.
    lo :: widen_int_lit(recurse(ctx, range.lower), bound_type)
    hi_raw :: widen_int_lit(recurse(ctx, range.upper), bound_type)

    // Hoist non-trivial upper bounds (calls, casts, …) into a
    // `__for_hi_N` synthetic let so the loop condition reads a
    // single slot per iteration instead of re-evaluating the
    // expression. Cheap shapes (Ident / FieldAccess / IntLit /
    // CharLit) skip the hoist. Mirror of TS' `isCheapInvariant`
    // gate (`src/lower/passes/for-in.ts:694-699`).
    hoist_stmts: LoweredStmt[] = []
    hi: LoweredExpr = hi_raw
    if !is_cheap_invariant(hi_raw) {
        hi_sym :: fresh_synthetic_symbol(ctx, "for_hi")
        hoist_stmts.push(LoweredLet {
            .span = span, .name = hi_sym.name, .symbol = hi_sym,
            .type = bound_type, .value = hi_raw,
        })
        hi = LoweredIdent { .span = span, .type = bound_type, .symbol = hi_sym }
    }

    counter_init :: LoweredLet {
        .span = span, .name = in_form.binding, .symbol = binding_symbol,
        .type = bound_type, .value = lo,
    }
    counter_ref :: LoweredIdent {
        .span = span, .type = bound_type, .symbol = binding_symbol,
    }
    op :: cmp_op_for_inclusive(range.inclusive)
    cond :: LoweredBinary {
        .span = span, .type = TY_BOOL, .op = op,
        .left = counter_ref, .right = hi,
    }
    inc_stmt :: LoweredAssign {
        .span = span, .target = counter_ref,
        .value = LoweredBinary {
            .span = span, .type = bound_type, .op = LoweredBinaryOp.Add,
            .left = counter_ref,
            .right = LoweredIntLit {
                .span = span, .type = bound_type, .value = i64(1),
            },
        },
    }

    user_body :: block_lowerer(ctx, for_stmt.body, false, true)
    loop_stmts :: build_int_range_body(user_body, inc_stmt, for_stmt.label)
    loop_stmt :: LoweredLoop {
        .span = span, .label = for_stmt.label, .cond = cond,
        .body = LoweredBlock {
            .span = span, .type = TY_VOID, .stmts = loop_stmts, .trailing = null,
        },
    }

    block_stmts: LoweredStmt[] = []
    for hs in hoist_stmts { block_stmts.push(hs) }
    block_stmts.push(counter_init)
    block_stmts.push(loop_stmt)
    return LoweredExprStmt {
        .span = span,
        .expr = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = block_stmts, .trailing = null,
        },
    }
}

extract_range :: fn(iter: AST.Expr) -> AST.RangeExpr | null {
    match iter {
        is AST.RangeExpr as r -> { return r }
        _ -> { return null }
    }
}

// When a Range bound is a bare integer literal (e.g. `0` in
// `0..<nu` where `nu: u64`), the typer left it at i32 / FreeInt
// default. Rewrite the LoweredIntLit's type to the loop counter's
// width so the dump shows `int(0) :u64` instead of `int(0) :i32`.
widen_int_lit :: fn(e: LoweredExpr, t: Type) -> LoweredExpr {
    if e is LoweredIntLit as lit {
        return LoweredIntLit { .span = lit.span, .type = t, .value = lit.value }
    }
    return e
}

// True for expressions cheap enough to re-read every loop iteration —
// the loop bound stays inline rather than getting hoisted into a
// `__for_hi_N` synthetic let. Mirror of `isCheapInvariant` in
// `src/lower/passes/for-in.ts:694-699`.
is_cheap_invariant :: fn(e: LoweredExpr) -> bool {
    if e is LoweredIdent       { return true }
    if e is LoweredFieldAccess { return true }
    if e is LoweredIntLit      { return true }
    if e is LoweredCharLit     { return true }
    return false
}

is_integer_type :: fn(t: Type) -> bool {
    match t {
        is PrimitiveType as p -> {
            // Mirrors `isInteger` in `typecheck/types.ts`.
            if p.name == "i8"    { return true }
            if p.name == "i16"   { return true }
            if p.name == "i32"   { return true }
            if p.name == "i64"   { return true }
            if p.name == "isize" { return true }
            if p.name == "u8"    { return true }
            if p.name == "u16"   { return true }
            if p.name == "u32"   { return true }
            if p.name == "u64"   { return true }
            if p.name == "usize" { return true }
            return false
        }
        is FreeIntType -> { return true }
        _ -> { return false }
    }
}

import "vader/types" { FreeIntType }
import "vader/typecheck" { default_if_free }

cmp_op_for_inclusive :: fn(inclusive: bool) -> LoweredBinaryOp {
    if inclusive { return LoweredBinaryOp.Lte }
    return LoweredBinaryOp.Lt
}

build_int_range_body :: fn(user_body: LoweredBlock, inc_stmt: LoweredStmt, loop_label: string | null) -> LoweredStmt[] {
    advanced :: prepend_inc_before_matching_continue(user_body, inc_stmt, loop_label)
    out: LoweredStmt[] = []
    for stmt in advanced.stmts { out.push(stmt) }
    trailing :: advanced.trailing
    if !(trailing is null) {
        out.push(LoweredExprStmt { .span = span_of(trailing), .expr = trailing })
    }
    out.push(inc_stmt)
    return out
}

// ---- continue / counter-increment reconciliation -------------------------

// The counter-based for-in fast paths (int-range, raw-array) place the
// counter increment at the BOTTOM of the loop body. A `continue` lowers to
// a back-edge to the loop header and would skip that increment, spinning
// forever on the same counter value. Rewrite each `continue` that targets
// this loop into `{ inc ; continue }` so every back-edge advances the
// counter. Mirrors `prependIncBeforeMatchingContinue` in
// `src/lower/passes/for-in.ts:707`.
//
// @param block       the lowered user body to rewrite.
// @param inc         the counter-increment stmt to splice before each
//                    matching `continue`.
// @param loop_label  this loop's label, or null. An unlabeled `continue`
//                    only matches when it isn't intercepted by an inner
//                    loop (so we stop recursing into nested loops unless a
//                    label could still target us through them).
prepend_inc_before_matching_continue :: fn(block: LoweredBlock, inc: LoweredStmt, loop_label: string | null) -> LoweredBlock =
    rewrite_continue_block(block, false, inc, loop_label)

// True when a `continue cLabel` targets the loop we're emitting. Unlabeled
// continues match only the innermost loop (so not when nested) and only
// when this loop is itself unlabeled ; labeled continues match by label.
continue_targets_loop :: fn(c_label: string | null, inside_nested_loop: bool, loop_label: string | null) -> bool {
    if c_label == null { return !inside_nested_loop && loop_label == null }
    if loop_label == null { return false }
    return c_label == loop_label
}

rewrite_continue_block :: fn(b: LoweredBlock, inside_nested_loop: bool, inc: LoweredStmt, loop_label: string | null) -> LoweredBlock {
    new_stmts: LoweredStmt[] = []
    for s in b.stmts { new_stmts.push(rewrite_continue_stmt(s, inside_nested_loop, inc, loop_label)) }
    t :: b.trailing
    new_trailing :: if t == null { null } else { rewrite_continue_expr(t, inside_nested_loop, inc, loop_label) }
    return LoweredBlock { .span = b.span, .type = b.type, .stmts = new_stmts, .trailing = new_trailing }
}

rewrite_continue_stmt :: fn(s: LoweredStmt, inside_nested_loop: bool, inc: LoweredStmt, loop_label: string | null) -> LoweredStmt = match s {
    is LoweredContinue as c -> {
        if continue_targets_loop(c.label, inside_nested_loop, loop_label) {
            LoweredExprStmt {
                .span = c.span,
                .expr = LoweredBlock {
                    .span = c.span, .type = TY_VOID, .stmts = [inc, c], .trailing = null,
                },
            }
        } else {
            c
        }
    }
    is LoweredLoop as lp -> {
        // An inner loop intercepts unlabeled continues, so only recurse
        // into it when we carry a label a `continue label` could still
        // reach through it.
        if loop_label == null {
            lp
        } else {
            LoweredLoop {
                .span = lp.span, .label = lp.label, .cond = lp.cond,
                .body = rewrite_continue_block(lp.body, true, inc, loop_label),
            }
        }
    }
    is LoweredExprStmt as es -> LoweredExprStmt {
        .span = es.span, .expr = rewrite_continue_expr(es.expr, inside_nested_loop, inc, loop_label),
    }
    is LoweredLet as lt -> LoweredLet {
        .span = lt.span, .name = lt.name, .symbol = lt.symbol, .type = lt.type,
        .value = rewrite_continue_expr(lt.value, inside_nested_loop, inc, loop_label),
    }
    is LoweredAssign as a -> LoweredAssign {
        .span = a.span,
        .target = rewrite_continue_expr(a.target, inside_nested_loop, inc, loop_label),
        .value = rewrite_continue_expr(a.value, inside_nested_loop, inc, loop_label),
    }
    is LoweredCellSet as cs -> LoweredCellSet {
        .span = cs.span,
        .target = rewrite_continue_expr(cs.target, inside_nested_loop, inc, loop_label),
        .value = rewrite_continue_expr(cs.value, inside_nested_loop, inc, loop_label),
        .value_type = cs.value_type,
    }
    is LoweredReturn as r -> {
        rv :: r.value
        if rv == null {
            r
        } else {
            LoweredReturn { .span = r.span, .value = rewrite_continue_expr(rv, inside_nested_loop, inc, loop_label) }
        }
    }
    is LoweredDeferPush as d -> LoweredDeferPush {
        .span = d.span, .thunk = rewrite_continue_expr(d.thunk, inside_nested_loop, inc, loop_label),
    }
    is LoweredBreak       as br -> br
    is LoweredDeferPopExec as dp -> dp
}

// Only `LoweredBlock` / `LoweredIf` carry nested statements that can hold a
// `continue` ; every other expression kind is a leaf w.r.t. statements, so
// it's returned unchanged.
rewrite_continue_expr :: fn(e: LoweredExpr, inside_nested_loop: bool, inc: LoweredStmt, loop_label: string | null) -> LoweredExpr {
    if e is LoweredBlock as b {
        return rewrite_continue_block(b, inside_nested_loop, inc, loop_label)
    }
    if e is LoweredIf as f {
        eb :: f.else_block
        new_else :: if eb == null { null } else { rewrite_continue_block(eb, inside_nested_loop, inc, loop_label) }
        return LoweredIf {
            .span = f.span, .type = f.type, .cond = f.cond,
            .then_block = rewrite_continue_block(f.then_block, inside_nested_loop, inc, loop_label),
            .else_block = new_else,
        }
    }
    return e
}

// ---- chain fusion ---------------------------------------------------------

import "std/collections" { keys }

// One layer of an `it.map(f).filter(p)` chain. `Range` is the bottom
// (integer-typed) ; `Map` / `Filter` wrap a `source` layer + the fn
// expression. The chain bottoms out at a `RangeExpr` with an integer
// bound type — non-int ranges, runtime-bound chains, etc fall back to
// the generic slow path.
IterChainKind :: enum(u8) {
    Range,
    Map,
    Filter,
}

IterChain :: struct {
    kind:         IterChainKind
    // Range bottom
    range_lower:  AST.Expr | null
    range_upper:  AST.Expr | null
    inclusive:    bool
    element_type: Type
    // Map / Filter layers
    source:       IterChain | null
    map_fn:       AST.Expr | null
    output_type:  Type
    pred_fn:      AST.Expr | null
    span:         Span
}

// Top-level entry — recognise `for x in <chain>` and emit the fused
// counter loop. Returns null whenever the chain doesn't match the
// MVP pattern (Map / Filter struct literals over an int Range bottom).
try_lower_chain_fusion :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    chain :: descend_chain(ctx, in_form.iter)
    if chain is null { return null }
    // Bare ranges already hit the int-range fast path ; bypassing
    // would lose `default_if_free` + counter-name fidelity vs TS.
    if i32(chain.kind) == i32(IterChainKind.Range) { return null }
    binding_symbol :: resolve_binding_or_synth(ctx, in_form)
    user_body :: block_lowerer(ctx, for_stmt.body, false, true)
    body_template :: BodyTemplate {
        .binding_name   = in_form.binding,
        .binding_symbol = binding_symbol,
        .element_type   = chain_element_type(chain),
        .user_body      = user_body,
    }
    stmts :: emit_fused_chain(ctx, chain, for_stmt.label, for_stmt.span, body_template, recurse)
    return LoweredExprStmt {
        .span = for_stmt.span,
        .expr = LoweredBlock {
            .span = for_stmt.span, .type = TY_VOID,
            .stmts = stmts, .trailing = null,
        },
    }
}

BodyTemplate :: struct {
    binding_name:   string
    binding_symbol: Symbol
    element_type:   Type
    user_body:      LoweredBlock
}

// Walk the iter expression top-down. Each layer either matches a
// known `std/iter` combinator (struct literal with the source field
// inline) or bottoms at an integer-typed `RangeExpr`. Anything else
// returns null.
descend_chain :: fn(ctx: FnLowerCtx, expr: AST.Expr) -> IterChain | null {
    match expr {
        is AST.RangeExpr as range -> {
            bound :: ctx.types.expr_type(range.lower)
            if !is_integer_type(bound) { return null }
            element :: default_if_free(bound)
            return IterChain {
                .kind = IterChainKind.Range,
                .range_lower = range.lower,
                .range_upper = range.upper,
                .inclusive = range.inclusive,
                .element_type = element,
                .source = null, .map_fn = null, .output_type = TY_UNRESOLVED,
                .pred_fn = null, .span = range.span,
            }
        }
        is AST.StructLitExpr as struct_lit -> {
            map_symbol_opt    :: module_export(ctx.project, "std/iter", "MapIterator")
            filter_symbol_opt :: module_export(ctx.project, "std/iter", "FilterIterator")
            struct_type :: ctx.types.expr_type(struct_lit)
            match struct_type {
                is StructType as st -> {
                    if matches_iter_symbol(map_symbol_opt, st.symbol.id) {
                        return descend_map(ctx, struct_lit, st)
                    }
                    if matches_iter_symbol(filter_symbol_opt, st.symbol.id) {
                        return descend_filter(ctx, struct_lit, st)
                    }
                }
                _ -> {}
            }
            return null
        }
        // Fluent form : `it.map(f)` / `it.filter(p)` (or the direct-call
        // `map(it, f)` / `filter(it, p)`). The combinators are trivial
        // std/iter constructors, so we recognise the call directly rather
        // than waiting for inlining — mirror of the struct-lit arm above.
        is AST.CallExpr as call -> {
            map_symbol_opt    :: module_export(ctx.project, "std/iter", "MapIterator")
            filter_symbol_opt :: module_export(ctx.project, "std/iter", "FilterIterator")
            if map_symbol_opt == null && filter_symbol_opt == null { return null }
            fluent :: unpack_fluent_combinator(ctx, call)
            if fluent is null { return null }
            inner :: descend_chain(ctx, fluent.receiver)
            if inner is null { return null }
            struct_type :: ctx.types.expr_type(call)
            match struct_type {
                is StructType as st -> {
                    if matches_iter_symbol(map_symbol_opt, st.symbol.id) {
                        if st.args.len() < usize(2) { return null }
                        return IterChain {
                            .kind = IterChainKind.Map,
                            .range_lower = null, .range_upper = null, .inclusive = false,
                            .element_type = TY_UNRESOLVED,
                            .source = inner, .map_fn = fluent.fn_arg, .output_type = st.args[1],
                            .pred_fn = null, .span = call.span,
                        }
                    }
                    if matches_iter_symbol(filter_symbol_opt, st.symbol.id) {
                        return IterChain {
                            .kind = IterChainKind.Filter,
                            .range_lower = null, .range_upper = null, .inclusive = false,
                            .element_type = TY_UNRESOLVED,
                            .source = inner, .map_fn = null, .output_type = TY_UNRESOLVED,
                            .pred_fn = fluent.fn_arg, .span = call.span,
                        }
                    }
                }
                _ -> {}
            }
            return null
        }
        _ -> { return null }
    }
}

// The receiver (chain source) + transform/predicate arg of a fluent
// combinator call. The caller checks the call's return type to decide
// whether it's a `map` or a `filter`.
FluentCombinator :: struct {
    receiver: AST.Expr
    fn_arg:   AST.Expr
}

// Recognise the fluent `it.map(f)` / `it.filter(p)` (UFCS) and the direct
// `map(it, f)` / `filter(it, p)` shapes. Returns the receiver + fn arg, or
// null when the call isn't one of the two fusible combinators. Mirror of
// `src/lower/passes/for-in.ts::unpackFluentCombinator`.
unpack_fluent_combinator :: fn(ctx: FnLowerCtx, call: AST.CallExpr) -> FluentCombinator | null {
    match call.callee {
        // UFCS form `it.map(f)` : the FieldExpr resolved as a free-fn UFCS
        // dispatch (the typer stashed the receiver type under its id). The
        // callee's target is the receiver ; the first arg is the transform.
        is AST.FieldExpr as fe -> {
            recv_ty :: ctx.typed.ufcs_receiver_types[fe.id]
            if recv_ty is null { return null }
            if call.args.len() < usize(1) { return null }
            return FluentCombinator { .receiver = fe.target, .fn_arg = call.args[0].value }
        }
        // Direct-call form `map(it, f)` : first arg is the receiver, second
        // is the transform / predicate.
        is AST.IdentExpr -> {
            if call.args.len() < usize(2) { return null }
            return FluentCombinator { .receiver = call.args[0].value, .fn_arg = call.args[1].value }
        }
        _ -> { return null }
    }
}

matches_iter_symbol :: fn(opt: Symbol | null, id: i32) -> bool {
    match opt {
        is null -> { return false }
        is Symbol as s -> { return s.id == id }
    }
}

descend_map :: fn(ctx: FnLowerCtx, struct_lit: AST.StructLitExpr, struct_type: StructType) -> IterChain | null {
    source_expr :: find_inline_field(struct_lit, "source")
    map_fn      :: find_inline_field(struct_lit, "f")
    if source_expr is null { return null }
    if map_fn is null { return null }
    inner :: descend_chain(ctx, source_expr)
    if inner is null { return null }
    if struct_type.args.len() < usize(2) { return null }
    output_type :: struct_type.args[1]
    return IterChain {
        .kind = IterChainKind.Map,
        .range_lower = null, .range_upper = null, .inclusive = false,
        .element_type = TY_UNRESOLVED,
        .source = inner, .map_fn = map_fn, .output_type = output_type,
        .pred_fn = null, .span = struct_lit.span,
    }
}

descend_filter :: fn(ctx: FnLowerCtx, struct_lit: AST.StructLitExpr, struct_type: StructType) -> IterChain | null {
    source_expr :: find_inline_field(struct_lit, "source")
    pred_fn     :: find_inline_field(struct_lit, "pred")
    if source_expr is null { return null }
    if pred_fn is null { return null }
    inner :: descend_chain(ctx, source_expr)
    if inner is null { return null }
    return IterChain {
        .kind = IterChainKind.Filter,
        .range_lower = null, .range_upper = null, .inclusive = false,
        .element_type = TY_UNRESOLVED,
        .source = inner, .map_fn = null, .output_type = TY_UNRESOLVED,
        .pred_fn = pred_fn, .span = struct_lit.span,
    }
}

import "vader/parser" { StructLitField as ASTStructLitField, StructLitSpread as ASTStructLitSpread }

find_inline_field :: fn(struct_lit: AST.StructLitExpr, name: string) -> AST.Expr | null {
    for item in struct_lit.items {
        match item {
            is ASTStructLitField as field -> {
                if field.name == name { return field.value }
            }
            is ASTStructLitSpread -> { return null }
        }
    }
    return null
}

chain_element_type :: fn(chain: IterChain) -> Type {
    if i32(chain.kind) == i32(IterChainKind.Range) { return chain.element_type }
    if i32(chain.kind) == i32(IterChainKind.Map) { return chain.output_type }
    // Filter : element type comes from the source.
    if chain.source is null { return TY_UNRESOLVED }
    return chain_element_type(chain.source)
}

// Emit the fused chain recursively : each Map layer wraps the inner
// body with `let __mapped_n = f(prev)` ; each Filter layer guards
// the inner body with `if pred(prev) { ... }`. The Range bottom
// expands into the counter loop.
emit_fused_chain :: fn(
    ctx: FnLowerCtx, chain: IterChain, loop_label: string | null, outer_span: Span,
    template: BodyTemplate,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    if i32(chain.kind) == i32(IterChainKind.Range) {
        return emit_fused_range(ctx, chain, loop_label, outer_span, template, recurse)
    }
    if i32(chain.kind) == i32(IterChainKind.Map) {
        return emit_fused_chain_map(ctx, chain, loop_label, outer_span, template, recurse)
    }
    return emit_fused_chain_filter(ctx, chain, loop_label, outer_span, template, recurse)
}

emit_fused_chain_map :: fn(
    ctx: FnLowerCtx, chain: IterChain, loop_label: string | null, outer_span: Span,
    template: BodyTemplate,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    if chain.source is null { return [] }
    if chain.map_fn is null { return [] }
    inner_chain :: chain.source
    map_fn :: chain.map_fn
    output_type :: chain.output_type
    span :: chain.span
    // The source layer (range / filter below us) binds its value to a FRESH
    // symbol typed by the source's element type — that's the input the map
    // consumes. Our wrapped body reads it, computes `f(src)`, and binds the
    // result to the OUTER template's symbol so the consumer above sees the
    // mapped value. Distinct in / out symbols : reusing one would emit the
    // self-referential `let x = f(x)`.
    source_elem :: chain_element_type(inner_chain)
    source_sym :: fresh_synthetic_symbol(ctx, "src")
    inner_template :: BodyTemplate {
        .binding_name = source_sym.name,
        .binding_symbol = source_sym,
        .element_type = source_elem,
        .user_body = wrap_with_map(ctx, template, source_sym, source_elem, map_fn, output_type, span, recurse),
    }
    return emit_fused_chain(ctx, inner_chain, loop_label, outer_span, inner_template, recurse)
}

emit_fused_chain_filter :: fn(
    ctx: FnLowerCtx, chain: IterChain, loop_label: string | null, outer_span: Span,
    template: BodyTemplate,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    if chain.source is null { return [] }
    if chain.pred_fn is null { return [] }
    inner_chain :: chain.source
    pred_fn :: chain.pred_fn
    span :: chain.span
    inner_template :: BodyTemplate {
        .binding_name = template.binding_name,
        .binding_symbol = template.binding_symbol,
        .element_type = template.element_type,
        .user_body = wrap_with_filter(ctx, template, pred_fn, span, recurse),
    }
    return emit_fused_chain(ctx, inner_chain, loop_label, outer_span, inner_template, recurse)
}

// Build the inner body for a Map layer : it reads the source value bound
// by the layer below (`source_sym` : `source_type`), computes the mapped
// value `f(source)`, binds it to the OUTER template's symbol (the value the
// consumer above sees), then runs that consumer's body.
wrap_with_map :: fn(
    ctx: FnLowerCtx, template: BodyTemplate, source_sym: Symbol, source_type: Type,
    map_fn: AST.Expr, output_type: Type, span: Span,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredBlock {
    callee :: recurse(ctx, map_fn)
    arg_ref :: LoweredIdent {
        .span = span, .type = source_type, .symbol = source_sym,
    }
    call_args: LoweredExpr[] = []
    call_args.push(arg_ref)
    mapped_call :: LoweredCall {
        .span = span, .type = output_type,
        .callee = callee, .args = call_args,
    }
    let_stmt :: LoweredLet {
        .span = span, .name = template.binding_name, .symbol = template.binding_symbol,
        .type = output_type, .value = mapped_call,
    }
    out_stmts: LoweredStmt[] = []
    out_stmts.push(let_stmt)
    for stmt in template.user_body.stmts { out_stmts.push(stmt) }
    return LoweredBlock {
        .span = span, .type = TY_VOID,
        .stmts = out_stmts, .trailing = template.user_body.trailing,
    }
}

wrap_with_filter :: fn(
    ctx: FnLowerCtx, template: BodyTemplate, pred_fn: AST.Expr, span: Span,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredBlock {
    callee :: recurse(ctx, pred_fn)
    arg_ref :: LoweredIdent {
        .span = span, .type = template.element_type,
        .symbol = template.binding_symbol,
    }
    call_args: LoweredExpr[] = []
    call_args.push(arg_ref)
    cond :: LoweredCall {
        .span = span, .type = TY_BOOL,
        .callee = callee, .args = call_args,
    }
    if_stmt :: LoweredExprStmt {
        .span = span,
        .expr = LoweredIf {
            .span = span, .type = TY_VOID,
            .cond = cond,
            .then_block = template.user_body,
            .else_block = null,
        },
    }
    inner_stmts: LoweredStmt[] = []
    inner_stmts.push(if_stmt)
    return LoweredBlock {
        .span = span, .type = TY_VOID,
        .stmts = inner_stmts, .trailing = null,
    }
}

// Emit the counter loop at the Range bottom. The user binding is
// re-cast under the surface name so the body sees the same symbol
// the resolver bound.
emit_fused_range :: fn(
    ctx: FnLowerCtx, range_chain: IterChain, loop_label: string | null, outer_span: Span,
    template: BodyTemplate,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    span :: range_chain.span
    int_type :: range_chain.element_type
    if range_chain.range_lower is null { return [] }
    if range_chain.range_upper is null { return [] }
    lo :: recurse(ctx, range_chain.range_lower)
    hi :: recurse(ctx, range_chain.range_upper)

    counter_init :: LoweredLet {
        .span = span, .name = template.binding_name, .symbol = template.binding_symbol,
        .type = int_type, .value = lo,
    }
    counter_ref :: LoweredIdent {
        .span = span, .type = int_type, .symbol = template.binding_symbol,
    }
    op :: cmp_op_for_inclusive(range_chain.inclusive)
    cond :: LoweredBinary {
        .span = span, .type = TY_BOOL, .op = op, .left = counter_ref, .right = hi,
    }
    inc_stmt :: LoweredAssign {
        .span = span, .target = counter_ref,
        .value = LoweredBinary {
            .span = span, .type = int_type, .op = LoweredBinaryOp.Add,
            .left = counter_ref,
            .right = LoweredIntLit { .span = span, .type = int_type, .value = i64(1) },
        },
    }

    body_stmts :: build_int_range_body(template.user_body, inc_stmt, loop_label)
    loop_stmt :: LoweredLoop {
        .span = outer_span, .label = loop_label, .cond = cond,
        .body = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = body_stmts, .trailing = null,
        },
    }
    out: LoweredStmt[] = []
    out.push(counter_init)
    out.push(loop_stmt)
    return out
}

// `for entry in m` over `MutableMap(K, V)` / `for v in s` over
// `MutableSet(T)` — inline the bucket-walk + chain-traversal so the loop
// skips the MapIterator struct, the per-iter `next()` call, and the
// per-iter `Yield` allocation. Returns null when the iter type isn't a
// recognised map/set or std/collections isn't loaded. Mirror of TS'
// `tryLowerForInMapSetIterInline` (src/lower/passes/for-in.ts:795).
try_lower_for_in_map_set :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    src_value: LoweredExpr, src_type: Type, span: Span,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    if src_type is StructType as source {
        entry_sym :: module_export(ctx.project, "std/collections", "Entry")
        if entry_sym is null { return null }
        is_map :: struct_sym_matches(module_export(ctx.project, "std/collections", "MutableMap"), source.symbol.id)
        is_set :: struct_sym_matches(module_export(ctx.project, "std/collections", "MutableSet"), source.symbol.id)
        if !is_map && !is_set { return null }
        // Entry(K, V) args : Map(K, V) → [K, V] ; Set(T) → [T, bool].
        entry_args: Type[] = []
        if is_map {
            for a in source.args { entry_args.push(a) }
        } else {
            if source.args.len() == usize(0) { return null }
            entry_args.push(source.args[0])
            entry_args.push(TY_BOOL)
        }
        if entry_args.len() != usize(2) { return null }
        usize_ty :: mk_primitive("usize")
        null_ty :: mk_primitive("null")
        entry_type :: mk_struct(entry_sym, entry_args)
        entry_or_null :: mk_union([entry_type, null_ty])
        buckets_array_type :: mk_array(entry_or_null, false)
        binding_value_type: Type = entry_type
        if is_set { binding_value_type = source.args[0] }

        // Hoist the source value once.
        src_sym :: fresh_synthetic_symbol(ctx, "iter_src")
        src_let :: LoweredLet {
            .span = span, .name = src_sym.name, .symbol = src_sym,
            .type = src_type, .value = src_value,
        }
        src_ref :: LoweredIdent { .span = span, .type = src_type, .symbol = src_sym }
        // buckets : Map reads `.buckets` ; Set reads `.inner.buckets`.
        buckets_expr: LoweredExpr = LoweredFieldAccess {
            .span = span, .type = buckets_array_type, .target = src_ref, .field = "buckets",
        }
        if is_set {
            inner_map_type :: map_struct_type(module_export(ctx.project, "std/collections", "MutableMap"), entry_args)
            inner_access :: LoweredFieldAccess {
                .span = span, .type = inner_map_type, .target = src_ref, .field = "inner",
            }
            buckets_expr = LoweredFieldAccess {
                .span = span, .type = buckets_array_type, .target = inner_access, .field = "buckets",
            }
        }
        buckets_sym :: fresh_synthetic_symbol(ctx, "iter_buckets")
        buckets_ref :: LoweredIdent { .span = span, .type = buckets_array_type, .symbol = buckets_sym }
        buckets_let :: LoweredLet {
            .span = span, .name = buckets_sym.name, .symbol = buckets_sym,
            .type = buckets_array_type, .value = buckets_expr,
        }
        buckets_len_sym :: fresh_synthetic_symbol(ctx, "iter_buckets_len")
        buckets_len_ref :: LoweredIdent { .span = span, .type = usize_ty, .symbol = buckets_len_sym }
        buckets_len_let :: LoweredLet {
            .span = span, .name = buckets_len_sym.name, .symbol = buckets_len_sym, .type = usize_ty,
            .value = LoweredArrayLen { .span = span, .type = usize_ty, .target = buckets_ref },
        }
        bucket_sym :: fresh_synthetic_symbol(ctx, "iter_bucket")
        bucket_ref :: LoweredIdent { .span = span, .type = usize_ty, .symbol = bucket_sym }
        bucket_let :: LoweredLet {
            .span = span, .name = bucket_sym.name, .symbol = bucket_sym, .type = usize_ty,
            .value = LoweredIntLit { .span = span, .type = usize_ty, .value = i64(0) },
        }
        chain_sym :: fresh_synthetic_symbol(ctx, "iter_chain")
        chain_ref :: LoweredIdent { .span = span, .type = entry_or_null, .symbol = chain_sym }
        chain_let :: LoweredLet {
            .span = span, .name = chain_sym.name, .symbol = chain_sym, .type = entry_or_null,
            .value = LoweredNullLit { .span = span, .type = null_ty },
        }
        chain_is_null :: LoweredTypeCheck {
            .span = span, .type = TY_BOOL, .value = chain_ref, .check_type = null_ty,
        }
        // advance branch : if bucket >= len break ; chain = buckets[bucket] ; bucket += 1
        oob_if :: LoweredExprStmt {
            .span = span,
            .expr = LoweredIf {
                .span = span, .type = TY_VOID,
                .cond = LoweredBinary {
                    .span = span, .type = TY_BOOL, .op = LoweredBinaryOp.Gte,
                    .left = bucket_ref, .right = buckets_len_ref,
                },
                .then_block = single_stmt_block(span, LoweredBreak { .span = span, .label = null }),
                .else_block = null,
            },
        }
        chain_advance :: LoweredAssign {
            .span = span, .target = chain_ref,
            .value = LoweredIndex { .span = span, .type = entry_or_null, .target = buckets_ref, .index = bucket_ref },
        }
        bucket_inc :: LoweredAssign {
            .span = span, .target = bucket_ref,
            .value = LoweredBinary {
                .span = span, .type = usize_ty, .op = LoweredBinaryOp.Add,
                .left = bucket_ref, .right = LoweredIntLit { .span = span, .type = usize_ty, .value = i64(1) },
            },
        }
        advance_stmts: LoweredStmt[] = []
        advance_stmts.push(oob_if)
        advance_stmts.push(chain_advance)
        advance_stmts.push(bucket_inc)
        advance_branch :: LoweredBlock { .span = span, .type = TY_VOID, .stmts = advance_stmts, .trailing = null }
        // body branch : entry = cast(chain) ; chain = entry.next ;
        // bind = entry (map) / entry.key (set) ; <user body>
        entry_tmp_sym :: fresh_synthetic_symbol(ctx, "iter_entry")
        entry_tmp_ref :: LoweredIdent { .span = span, .type = entry_type, .symbol = entry_tmp_sym }
        entry_tmp_let :: LoweredLet {
            .span = span, .name = entry_tmp_sym.name, .symbol = entry_tmp_sym, .type = entry_type,
            .value = LoweredCast { .span = span, .type = entry_type, .value = chain_ref },
        }
        chain_step :: LoweredAssign {
            .span = span, .target = chain_ref,
            .value = LoweredFieldAccess { .span = span, .type = entry_or_null, .target = entry_tmp_ref, .field = "next" },
        }
        binding_symbol :: resolve_binding_or_synth(ctx, in_form)
        bind_value: LoweredExpr = entry_tmp_ref
        if is_set {
            bind_value = LoweredFieldAccess { .span = span, .type = binding_value_type, .target = entry_tmp_ref, .field = "key" }
        }
        binding_let :: LoweredLet {
            .span = span, .name = in_form.binding, .symbol = binding_symbol,
            .type = binding_value_type, .value = bind_value,
        }
        user_body :: block_lowerer(ctx, for_stmt.body, false, true)
        body_stmts: LoweredStmt[] = []
        body_stmts.push(entry_tmp_let)
        body_stmts.push(chain_step)
        body_stmts.push(binding_let)
        for s in block_stmts_with_trailing(user_body) { body_stmts.push(s) }
        body_branch :: LoweredBlock { .span = span, .type = TY_VOID, .stmts = body_stmts, .trailing = null }
        step_if :: LoweredExprStmt {
            .span = span,
            .expr = LoweredIf {
                .span = span, .type = TY_VOID, .cond = chain_is_null,
                .then_block = advance_branch, .else_block = body_branch,
            },
        }
        loop_body_stmts: LoweredStmt[] = []
        loop_body_stmts.push(step_if)
        loop_stmt :: LoweredLoop {
            .span = span, .label = for_stmt.label, .cond = null,
            .body = LoweredBlock { .span = span, .type = TY_VOID, .stmts = loop_body_stmts, .trailing = null },
        }
        all_stmts: LoweredStmt[] = []
        all_stmts.push(src_let)
        all_stmts.push(buckets_let)
        all_stmts.push(buckets_len_let)
        all_stmts.push(bucket_let)
        all_stmts.push(chain_let)
        all_stmts.push(loop_stmt)
        return wrap_stmts(span, all_stmts)
    }
    return null
}

struct_sym_matches :: fn(sym: Symbol | null, id: i32) -> bool {
    if sym is Symbol as s { return s.id == id }
    return false
}

map_struct_type :: fn(map_sym: Symbol | null, entry_args: Type[]) -> Type {
    if map_sym != null { return mk_struct(map_sym, entry_args) }
    return TY_UNRESOLVED
}

single_stmt_block :: fn(span: Span, stmt: LoweredStmt) -> LoweredBlock {
    stmts: LoweredStmt[] = []
    stmts.push(stmt)
    return LoweredBlock { .span = span, .type = TY_VOID, .stmts = stmts, .trailing = null }
}
