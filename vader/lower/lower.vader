// vader/lower/lower — project-level lowerer orchestrator.
//
// Mirror of `src/lower/lower.ts::lowerProject`. Walks every top-level
// decl across the project's typed modules, builds a stub `MonoEntry`
// per non-generic decl, and dispatches to the per-decl-kind lowerer.
// Phase 2 ships the skeleton with empty bodies ; Phase 3 fills in the
// actual expression / statement lowering.
//
// The orchestrator takes `LoadedProject` (for source decls) +
// `TypedProject` (for typed side-tables) + `EvaluatedProject` (for
// comptime values + mono entries). Today's `EvaluatedProject.mono`
// ships empty (the monomorphizer port is deferred to the bytecode emit
// chantier) ; we walk loaded module decls directly until then.

module "vader/lower"

import "std/collections" { MutableMap, keys, values }
import "std/sort" { sort }
import "std/iter" { is_empty }
import "std/string" { compare_ascending, bytes }
import "vader/diagnostics" { Diagnostic, Span }
import "vader/parser" {
    Decl, FnDecl, StructDecl, ConstDecl,
}
import "vader/resolver" { LoadedProject, LoadedModule }
import "vader/typecheck" { TypedProject, TypedProgram }
import "vader/typecheck" { Substitution, new_substitution, substitute, is_empty_substitution }
import "vader/types" { UnresolvedType }
import "vader/types" {
    Type, FnType, StructType, TypeMetaType, TypeParamType, ArrayType, mk_struct, mk_primitive,
    display_type, for_each_type, TY_BOOL, TY_UNRESOLVED, TY_VOID,
}
import "vader/typecheck" { default_if_free }
import "vader/comptime" { EvaluatedProject, EvaluatedProgram }
import "vader/comptime" {
    ComptimeValue, IntValue, FloatValue, BoolValue, CharValue, StringValue,
    NullValue, VoidValue, ArrayValue, StructValue, TypeValue,
}
import "vader/comptime" { MonoEntry }
import "vader/comptime" { mangle_type_arg }

/// Lower every module's top-level decls into a `LoweredProject`.
/// @param loaded     the loaded project (for source decls per module).
/// @param typed      the typed project (for side-tables).
/// @param evaluated  the comptime engine's output.
/// @param diags      diagnostics emitted by the lowerer (L5xxx codes).
/// @return           the lowered project ready for downstream phases.
export lower_project :: fn(
    loaded: LoadedProject, typed: TypedProject, evaluated: EvaluatedProject, diags: Diagnostic[],
) -> LoweredProject {
    project_ctx :: new_lower_project_ctx(evaluated, loaded)
    // Closure analysis runs once at entry — every lambda's capture set
    // is precomputed so per-decl lowering can read it without re-
    // walking the AST.
    project_ctx.closures = analyze_closures(loaded, typed)
    // Populate `core_symbols` from each module's `resolved.core_symbols`
    // table (auto-imported std/core exports). Lookups like
    // `find_core_type("Yield", [T])` go through this cache.
    populate_core_symbols(typed, project_ctx)
    // Build the global symbol_id -> ComptimeValue index so per-ident
    // const-baked lookups (`lookup_const_baked_value`) hit O(1) instead
    // of walking every loaded module's `comptime_decls` map per call.
    populate_comptime_value_index(project_ctx)
    // Build the project-wide impl registry — aggregate every module's
    // `T implements Trait { … }` decls so downstream phases can query
    // by `(for_type, trait_name)`. Unblocks Display dispatch for
    // string interp, try for non-primitive Error variants, and the
    // for-in / Iterator step loop.
    populate_impls(loaded, typed, project_ctx)
    project :: new_lowered_project()

    module_ids :: typed.modules.keys()
    for module_id in module_ids {
        // Stdlib modules: don't lower with-body fns up front (would bloat
        // the project + pollute the synthetic-id counter), but DO surface
        // every bodyless fn signature (`@extern` / intrinsic / declared-
        // only) so the bytecode emitter registers them in the import
        // table. Without this, calls to `byte_len` / `println` / … fall
        // through `emit_call_to_symbol` without hitting the CallImport
        // branch and silently drop. The now-wired whole-program DCE
        // (`prune_unreachable_fns`) culls anything the user never reaches,
        // so over-surfacing is safe.
        if is_stdlib_path(module_id) {
            stdlib_loaded :: loaded.modules[module_id]
            stdlib_typed_opt :: typed.modules[module_id]
            stdlib_decls: LoweredDecl[] = []
            if stdlib_loaded is LoadedModule as sl {
                if stdlib_typed_opt is TypedProgram as stdlib_typed {
                    for d in module_decls(sl) {
                        if d is FnDecl as fd {
                            if fd.body is null && fd.type_params.len() == 0 {
                                lowered :: lower_fn_decl(fd, stdlib_typed, project_ctx, diags)
                                if lowered != null {
                                    stdlib_decls.push(lowered)
                                    // Pre-seed the call-site harvest's seen-set so
                                    // `materialize_nongeneric_stdlib_fns` doesn't
                                    // emit a duplicate decl for the same symbol.
                                    sym :: sl.collected.symbols[fd.name]
                                    if sym is Symbol as s {
                                        project_ctx.nongeneric_stdlib_fns[s.id] = true
                                    }
                                }
                            }
                        }
                    }
                }
                project.modules[module_id] = LoweredModule {
                    .module_id    = module_id,
                    .display_path = sl.module.display_path,
                    .decls        = stdlib_decls,
                }
            }
            continue
        }
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        decls :: module_decls(module_loaded)
        display_path :: module_loaded.module.display_path
        lowered_module :: lower_module(module_id, display_path, module_typed, decls, project_ctx, diags)
        project.modules[module_id] = lowered_module
    }
    // After per-module lowering, materialise generic-struct instances +
    // their matching generic-impl members. Each `evaluated.instances`
    // entry yields a `StructDecl<Concrete>` + per-impl `__T` member fns.
    rep_seen :: materialize_concrete_struct_instances(loaded, typed, project_ctx, project, diags)
    // Generic-fn instances observed at call sites get one
    // monomorphized `LoweredFnDecl` per `(fn_symbol, args)` tuple. The
    // body inherits the source fn-decl but lowered against a typeParam
    // substitution that binds T → arg[i].
    materialize_generic_fn_instances(loaded, typed, project_ctx, project, diags)
    // Non-generic stdlib free fns harvested during call lowering
    // (`append`, `byte_len`, `new_builder`, …). Runs after generic
    // instances since both share the harvest ; its own bodies may
    // harvest further non-generic stdlib fns (cursor-iterated).
    // Fixpoint : materialising a stdlib free-fn body can harvest impl-member
    // calls (→ `referenced_impl_mangles`), and surfacing a stdlib impl-member
    // body (e.g. `StringChars.Iterator.next`) can harvest further stdlib free
    // fns (→ `nongeneric_stdlib_order`, e.g. `decode_codepoint`). Loop the two
    // until neither queue grows. `materialize_nongeneric_stdlib_fns` resumes
    // from a persistent cursor (no re-lowering) ; `surface_*` dedupes via
    // `materialized_impl_keys`, so re-running is idempotent. Surfaces only
    // referenced members so unrelated snippets don't gain unused imports.
    prev_fns := usize(0)
    prev_impls := usize(0)
    draining := true
    for draining {
        materialize_nongeneric_stdlib_fns(loaded, typed, project_ctx, project, diags)
        surface_referenced_intrinsic_externs(loaded, typed, project_ctx, project)
        cur_fns :: project_ctx.nongeneric_stdlib_order.len()
        cur_impls :: project_ctx.referenced_impl_mangles.inner.size
        if cur_fns == prev_fns && cur_impls == prev_impls {
            draining = false
        } else {
            prev_fns = cur_fns
            prev_impls = cur_impls
        }
    }
    // Representative "any-args" structs come AFTER fn instances —
    // matches TS' emission order so generic_brackets etc. byte-match.
    materialize_representatives(loaded, typed, project_ctx, project, rep_seen)
    // Transitively materialise generic-struct shapes referenced by the
    // fields of the structs emitted above (concrete + representative),
    // e.g. `MutableSet(i32)`'s erased `inner: MutableMap(Any, bool)` —
    // otherwise the bytecode interner mints an orphan `ref` for them.
    close_over_field_shapes(loaded, typed, project_ctx, project)
    // Drain per-fn lower diagnostics pushed to `project_ctx.diags`
    // (e.g. M5001 from `lower_for_in`) into the caller-owned sink so
    // they reach `# Diagnostics` in the CLI dump.
    for d in project_ctx.diags { diags.push(d) }
    // Collect vtable entries from impl members. Mirrors TS's
    // `collectVtableEntries`. Without this, `BcModule.impl_table` is
    // always empty and `impl TYPE_ID TRAIT_NAME` directives never land
    // in the .virt — the runtime falls back to mangle-keyed dispatch
    // but the parity dump diverges.
    project.vtable_entries = collect_vtable_entries(project, loaded, typed)
    return project
}

// Walk every module's impl decls × surviving impl-member fns and yield
// one `VtableEntry` per `(trait, method, receiver type, impl fn)`.
// Mirror of `src/lower/lower.ts::collectVtableEntries`.
collect_vtable_entries :: fn(
    project: LoweredProject, loaded: LoadedProject, typed: TypedProject,
) -> VtableEntry[] {
    out: VtableEntry[] = []
    for module_id in project.modules.keys() {
        m :: project.modules[module_id]
        if m is null { continue }
        for d in m.decls {
            if d is LoweredFnDecl as fd {
                trait_method :: impl_trait_method_from_mangled(fd.mangled)
                if trait_method is null { continue }
                receiver_ty :: impl_receiver_type_from_decl(fd, typed)
                if receiver_ty is null { continue }
                // fn_symbol is informational here — build_impl_table only
                // keys on (struct_type, trait_name). Use a synth Symbol
                // when the impl-member resolver lookup returned null so
                // the entry still lands in the table.
                sym :: fd.origin.symbol
                fn_sym :: if sym is Symbol { sym } else {
                    Symbol {
                        .id = i32(0), .kind = SymbolKind.Fn, .name = fd.mangled,
                        .module = "", .visibility = Visibility.Private, .defined_at = null,
                    }
                }
                out.push(VtableEntry {
                    .trait_name  = trait_method.trait_name,
                    .method_name = trait_method.method,
                    .struct_type = receiver_ty,
                    .fn_symbol   = fn_sym,
                })
            }
        }
    }
    return out
}

ImplTraitMethod :: struct { trait_name: string, method: string }

// Decode `<module>$<Receiver>$<Trait>$<method>` mangled name into trait
// + method. The lowerer's `impl_member_mangled` emits this shape ;
// non-impl fns return null. We can't pull the trait/method directly
// from the FnDecl because impl members ship as plain LoweredFnDecls
// (TS keeps a richer ImplRegistry through emit, Vader's mangle
// round-trip is the cheap substitute).
impl_trait_method_from_mangled :: fn(mangled: string) -> ImplTraitMethod | null {
    parts :: split_dollar(mangled)
    if parts.len() < 4 { return null }
    return ImplTraitMethod {
        .trait_name = parts[parts.len() - 2],
        .method     = parts[parts.len() - 1],
    }
}

split_dollar :: fn(s: string) -> string[] {
    out: string[] = []
    cur := ""
    sb :: s.bytes()
    for i in 0..<sb.len() {
        b :: sb[i]
        if b == u8(0x24) { out.push(cur)  cur = "" }
        else { cur = "${cur}${char(u32(b))}" }
    }
    out.push(cur)
    return out
}

// Receiver type from the impl-member's first param (`self`). For
// `Point implements Display { to_string :: fn(self) -> string }`,
// the param's type is `Point`, which becomes the vtable's receiver-type
// key. Returns null when params are empty (defensive — impl members
// always carry self).
impl_receiver_type_from_decl :: fn(fd: LoweredFnDecl, _typed: TypedProject) -> Type | null {
    if fd.params.len() == 0 { return null }
    return fd.params[0].type
}

is_stdlib_path :: fn(path: string) = "stdlib/std/" in path

import "vader/typecheck" { build_impl_registry, ImplEntry }

// Populate `core_symbols` from std/core's resolved view so the
// lowerer can resolve `Range`, `Yield`, `ArrayIterator`, `Iterator`,
// `Display`, `Error`, … without re-walking the project per call.
// `iter_symbols` gets the same treatment for std/iter's exports
// (`MapIterator` / `FilterIterator` / etc.) so chain-fusion can spot
// the well-known struct shapes by symbol id.
populate_core_symbols :: fn(typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        // `core_symbols` on `ResolvedModule` carries cross-module
        // auto-import bindings — std/core's own entry has its
        // exported symbols here. Iterate every module's table and
        // copy into the project context ; std/core's entries
        // dominate since every module imports them.
        for symbol_name in module_typed.resolved.core_symbols.keys() {
            symbol :: module_typed.resolved.core_symbols[symbol_name]
            match symbol {
                is null -> {}
                is Symbol as resolved -> {
                    project_ctx.core_symbols[symbol_name] = resolved
                }
            }
        }
        // `std/iter`'s top-level symbols : copy under `iter_symbols`
        // so chain fusion's `MapIterator` / `FilterIterator` lookups
        // resolve to the canonical struct symbols.
        if is_std_iter_module(module_id) {
            iter_table :: ensure_iter_table(project_ctx)
            for entry in module_typed.resolved.symbols {
                iter_table[entry.name] = entry
            }
        }
        // `std/collections`'s top-level symbols : copy under
        // `collections_symbols` so the for-in MutableMap / MutableSet
        // inliner can recognise the map/set/Entry structs by symbol id.
        if is_std_collections_module(module_id) {
            coll_table :: ensure_collections_table(project_ctx)
            for entry in module_typed.resolved.symbols {
                coll_table[entry.name] = entry
            }
        }
        // `std/string`'s top-level symbols : copy under `string_symbols`
        // so the `s.bytes().len()` peephole resolves the internal
        // `byte_len` host fn (the O(1) fold target). Keyed on the logical
        // display path (exact) to avoid matching `std/string_builder`.
        if module_typed.resolved.display_path == "std/string" {
            string_table :: ensure_string_table(project_ctx)
            for entry in module_typed.resolved.symbols {
                string_table[entry.name] = entry
            }
        }
    }
}

ensure_string_table :: fn(project_ctx: LowerProjectCtx) -> MutableMap<string, Symbol> {
    match project_ctx.string_symbols {
        is null -> {
            table :: MutableMap<string, Symbol> { .buckets = [], .size = 0 }
            project_ctx.string_symbols = table
            return table
        }
        is MutableMap<string, Symbol> as existing -> { return existing }
    }
}

is_std_collections_module :: fn(module_id: string) = "stdlib/std/collections" in module_id

ensure_collections_table :: fn(project_ctx: LowerProjectCtx) -> MutableMap<string, Symbol> {
    match project_ctx.collections_symbols {
        is null -> {
            table :: MutableMap<string, Symbol> { .buckets = [], .size = 0 }
            project_ctx.collections_symbols = table
            return table
        }
        is MutableMap<string, Symbol> as existing -> { return existing }
    }
}

populate_comptime_value_index :: fn(project_ctx: LowerProjectCtx) -> void {
    // Flatten every loaded module's `comptime_decls` into one global
    // `symbol_id -> ComptimeValue` map. Const symbol ids are project-
    // unique (resolver mints from a single counter), so no module can
    // collide with another — direct assignment is safe.
    for module_id in project_ctx.evaluated.modules.keys() {
        program :: project_ctx.evaluated.modules[module_id]
        match program {
            is null -> {}
            is EvaluatedProgram as ep -> {
                for symbol_id in ep.comptime_decls.keys() {
                    v :: ep.comptime_decls[symbol_id]
                    match v {
                        is null -> {}
                        _ -> { project_ctx.comptime_value_by_symbol_id[symbol_id] = v }
                    }
                }
            }
        }
    }
    // Merge `@file`-baked const values from the project-level table.
    // Kept separate from per-module `comptime_decls` so the comptime
    // dump doesn't show these as `@comptime`-decorated, but the lower
    // still inlines them at use sites.
    for symbol_id in project_ctx.evaluated.file_baked_consts.keys() {
        v :: project_ctx.evaluated.file_baked_consts[symbol_id]
        match v {
            is null -> {}
            _ -> { project_ctx.comptime_value_by_symbol_id[symbol_id] = v }
        }
    }
}

is_std_iter_module :: fn(module_id: string) = "stdlib/std/iter.vader" in module_id

ensure_iter_table :: fn(project_ctx: LowerProjectCtx) -> MutableMap<string, Symbol> {
    match project_ctx.iter_symbols {
        is null -> {
            table :: MutableMap<string, Symbol> { .buckets = [], .size = 0 }
            project_ctx.iter_symbols = table
            return table
        }
        is MutableMap<string, Symbol> as existing -> { return existing }
    }
}


// Aggregate every loaded module's impl decls into the project ctx's
// registry. `build_impl_registry` works per-module ; we drain every
// resulting entry into `project_ctx.impls.all` (+ rekey `user_index`
// by `for_symbol.id::trait_symbol.id`, same as the per-module shape).
populate_impls :: fn(loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        module_decls_list :: module_decls(module_loaded)
        per_module :: build_impl_registry(module_decls_list, module_typed.resolved)
        for entry in per_module.all {
            project_ctx.impls.all.push(entry)
            match entry.for_symbol {
                is null -> {}
                is Symbol as for_symbol -> {
                    key :: "${for_symbol.id}::${entry.trait_symbol.id}"
                    project_ctx.impls.user_index[key] = entry
                }
            }
        }
    }
}

// Per-module driver. Walks the decl list, dispatches by kind, and
// builds the resulting `LoweredModule`. Lambda-lifted synth decls
// accumulated on `project_ctx.synth_decls` during the walk get drained
// into this module's `decls` list — they were spawned while lowering
// this module's bodies, so they ship alongside the regular decls.
lower_module :: fn(
    module_id: string, display_path: string, typed: TypedProgram, decls: Decl[],
    project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredModule {
    out_decls: LoweredDecl[] = []
    // First pass : every regular decl in source order. Impl members
    // surface as a multi-decl list right after their ImplDecl so the
    // dump's per-struct grouping matches TS source-order.
    synth_start :: project_ctx.synth_decls.len()
    for decl in decls {
        results :: lower_decl_list(decl, typed, project_ctx, diags, decls)
        for r in results { out_decls.push(r) }
    }
    // Second pass : drain the lambda-lift synth decls accumulated while
    // walking this module's bodies (lambdas / defers route through
    // `synth_decls`). Matches TS `lower.ts:74-78`.
    synth_end :: project_ctx.synth_decls.len()
    for i in synth_start..<synth_end {
        out_decls.push(project_ctx.synth_decls[i])
    }
    return LoweredModule {
        .module_id    = module_id,
        .display_path = display_path,
        .decls        = out_decls,
    }
}

/// Per-decl dispatcher returning every LoweredDecl this source decl
/// expands to. Most decls yield 0 or 1 ; ImplDecl yields one entry
/// per member so impl methods land inline (right after the impl) in
/// the dump.
lower_decl_list :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    diags: Diagnostic[], module_decls: Decl[],
) -> LoweredDecl[] {
    if decl is ImplDecl as impl_decl {
        return lower_impl_member_list(impl_decl, typed, project_ctx, diags, module_decls)
    }
    out: LoweredDecl[] = []
    result :: lower_decl(decl, typed, project_ctx, diags, module_decls)
    if !(result is null) { out.push(result) }
    return out
}

// Per-decl dispatcher. Routes FnDecl / StructDecl / ConstDecl through
// the matching phase-2 stub ; ImplDecl drains into per-member fn-decl
// entries appended to `project_ctx.synth_decls` so the module driver
// picks them up alongside the regular decls. Every other decl kind
// (Enum, Trait, TypeAlias, Import, Assert) returns null — they don't
// produce runtime slots.
lower_decl :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> LoweredDecl | null {
    match decl {
        is FnDecl     as fn_decl     -> { return lower_fn_decl(fn_decl, typed, project_ctx, diags) }
        is StructDecl as struct_decl -> { return lower_struct_decl(struct_decl, typed, project_ctx, diags) }
        is ConstDecl  as const_decl  -> { return lower_const_decl(const_decl, typed, project_ctx, diags) }
        is ImplDecl   as impl_decl   -> {
            lower_impl_members(impl_decl, typed, project_ctx, diags, module_decls)
            return null
        }
        _ -> { return null }
    }
}

import "vader/parser" { ImplDecl, ArrayTypeExpr }

// Each `T implements Trait { method ... }` member surfaces as a fn
// decl with mangled name `<module>$<for-type>$<trait>$<method>`.
// `self` is the first parameter ; its type comes from the impl's
// `for_type`. The lifted fns are appended to `project_ctx.synth_decls`
// so the module driver drains them in the right order.
lower_impl_members :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> void {
    // Back-compat shape : keep the void-returning entry but route
    // through the inline emit + push results to `synth_decls` so any
    // caller still relying on the old "drains at module end" path
    // keeps working. Modern call sites prefer `lower_impl_member_list`.
    members :: lower_impl_member_list(impl_decl, typed, project_ctx, diags, module_decls)
    for m in members { project_ctx.synth_decls.push(m) }
}

/// Return the lowered fn-decl for each member of `impl_decl`, in
/// source order. Yielding the list (instead of pushing to
/// `project_ctx.synth_decls`) lets the caller interleave the members
/// right after the impl's source position — matching TS's per-mono
/// drain that emits each member individually.
lower_impl_member_list :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> LoweredDecl[] {
    out: LoweredDecl[] = []
    // Skip generic impls entirely — the mono pass binds them via a
    // separate path.
    if impl_decl.type_params.len() > 0 { return out }
    if impl_decl.for_type is GenericInstExpr { return out }
    self_type :: lower_for_type(impl_decl, typed)
    base_mangle :: "${mangle_module_id(typed.resolved.display_path)}$${impl_decl.trait_name}"
    for member in impl_decl.members {
        if member.type_params.len() > 0 { continue }
        subst :: new_substitution()
        types :: make_entry_types(typed, subst)
        params :: build_impl_member_params(member, self_type, types, typed, project_ctx)
        return_type :: return_type_of(member, types)
        mangled :: impl_member_mangled(impl_decl, member, typed, module_decls)
        entry :: synth_impl_entry(member, typed, mangled)
        body :: lower_fn_body(member, typed, project_ctx, entry, subst, return_type)
        out.push(LoweredFnDecl {
            .mangled     = mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body,
            .origin      = entry,
        })
    }
    return out
}

/// Post-lowering pass : surface the referenced stdlib intrinsic impl
/// members as bodyless externs, appended to their owning stdlib module's
/// lowered decls (so the bytecode emit reserves them as imports). Gated by
/// `referenced_impl_mangles` so only members an actual call hit are
/// surfaced — see `surface_stdlib_impl_externs`.
surface_referenced_intrinsic_externs :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx, project: LoweredProject,
) -> void {
    for module_id in typed.modules.keys() {
        if !is_stdlib_path(module_id) { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        decls_list :: module_decls(module_loaded)
        extra: LoweredDecl[] = []
        for d in decls_list {
            if d is ImplDecl as impl_ {
                for ext in surface_stdlib_impl_externs(impl_, module_typed, project_ctx, decls_list) {
                    extra.push(ext)
                }
                for ext in surface_array_contains_for_impl(impl_, module_typed, project_ctx) {
                    extra.push(ext)
                }
            }
        }
        if extra.len() == 0 { continue }
        existing :: project.modules[module_id]
        if existing is null { continue }
        merged :: existing.decls
        for e in extra { merged.push(e) }
        project.modules[module_id] = LoweredModule {
            .module_id    = existing.module_id,
            .display_path = existing.display_path,
            .decls        = merged,
        }
    }
}

/// Surface a stdlib impl's BODYLESS members (referenced by a concrete call)
/// as bodyless `LoweredFnDecl`s (extern signatures). They flow through
/// `make_extern_decl` → CFG import so a concrete `recv.method()` call on an
/// intrinsic impl (e.g. `string implements Display { to_string }`) resolves
/// to a `CallImport` the Vader VM dispatches via `host.vader`. Mangle
/// matches `find_impl_member_for`'s call-site mangle (both via the impl's
/// owning module). With-body members are skipped — surfacing them as
/// externs would lose their behaviour, and lowering their bodies up front
/// is the thing the stdlib-skip is meant to avoid.
surface_stdlib_impl_externs :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, module_decls: Decl[],
) -> LoweredDecl[] {
    out: LoweredDecl[] = []
    if impl_decl.type_params.len() > 0 { return out }
    if impl_decl.for_type is GenericInstExpr { return out }
    self_type :: lower_for_type(impl_decl, typed)
    for member in impl_decl.members {
        if member.type_params.len() > 0 { continue }
        mangled :: impl_member_mangled(impl_decl, member, typed, module_decls)
        // Only emit members an actual call referenced — emitting every stdlib
        // impl member would intern unused signature types and shift the type
        // table for unrelated snippets.
        if !project_ctx.referenced_impl_mangles.contains(mangled) { continue }
        // Dedupe against the generic-impl materialiser (and re-entrant calls).
        dedupe_key :: "surfaced::${mangled}"
        if project_ctx.materialized_impl_keys.contains(dedupe_key) { continue }
        project_ctx.materialized_impl_keys.add(dedupe_key)
        types :: make_entry_types(typed, new_substitution())
        params :: build_impl_member_params(member, self_type, types, typed, project_ctx)
        return_type :: return_type_of(member, types)
        entry :: synth_impl_entry(member, typed, mangled)
        // Bodyless (`@intrinsic`) → extern import (Vader VM dispatches via
        // host.vader). With-body (e.g. `i32 implements Hash -> u64(self)`) →
        // materialise the real fn so a devirtualised concrete call resolves
        // directly instead of dropping / surfacing as an unbound host import.
        body_lowered :: if member.body is null {
            null
        } else {
            lower_fn_body(member, typed, project_ctx, entry, new_substitution(), return_type)
        }
        out.push(LoweredFnDecl {
            .mangled     = mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body_lowered,
            .origin      = entry,
        })
    }
    return out
}

/// Materialise the blanket `T[] implements<T: Equals> Contains<T>` member once
/// per element type a `v in arr` call referenced. The generic-impl materialiser
/// (`materialize_impl_for_instance`) is struct-instance-driven and never reaches
/// an array receiver, so `find_impl_member_for` records the element type keyed by
/// the call-site mangle (`project_ctx.array_contains_elems`) ; here we lower the
/// `contains` body with a CONCRETE substitution `T → element` so the body's `==`
/// devirtualises to the element's primitive comparison (unlike a generic free-fn
/// body, whose `==` stays an unbound virtual dispatch on the VM).
///
/// @param impl_decl    the candidate impl ; ignored unless it is the array
///                     `Contains` blanket.
/// @param typed        the impl's owning module (std/core) — source of the subst
///                     symbols and entry types.
/// @param project_ctx  carries `array_contains_elems` (mangle → element) and the
///                     `materialized_impl_keys` dedupe set.
/// @return             one materialised `LoweredFnDecl` per fresh element mangle.
surface_array_contains_for_impl :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
) -> LoweredDecl[] {
    out: LoweredDecl[] = []
    if impl_decl.type_params.len() == 0 { return out }
    if !(impl_decl.for_type is ArrayTypeExpr) { return out }
    if impl_decl.trait_name != "Contains" { return out }
    for member in impl_decl.members {
        if member.name != "contains" { continue }
        for mangled in project_ctx.array_contains_elems.keys() {
            element :: project_ctx.array_contains_elems[mangled]
            if element is null { continue }
            // Dedupe against re-entrant drain-loop passes.
            dedupe_key :: "arr_contains::${mangled}"
            if project_ctx.materialized_impl_keys.contains(dedupe_key) { continue }
            project_ctx.materialized_impl_keys.add(dedupe_key)
            subst :: build_impl_subst(impl_decl, [element], typed, typed)
            self_type :: mk_array(element, false)
            types :: make_entry_types(typed, subst)
            params :: build_impl_member_params(member, self_type, types, typed, project_ctx)
            return_type :: return_type_of(member, types)
            entry :: synth_impl_entry(member, typed, mangled)
            body :: lower_fn_body(member, typed, project_ctx, entry, subst, return_type)
            out.push(LoweredFnDecl {
                .mangled     = mangled,
                .params      = params,
                .return_type = return_type,
                .body        = body,
                .origin      = entry,
            })
        }
    }
    return out
}

build_impl_member_params :: fn(
    member: FnDecl, self_type: Type, types: EntryTypes,
    typed: TypedProgram, project_ctx: LowerProjectCtx,
) -> LoweredParam[] {
    params: LoweredParam[] = []
    for ast_param in member.params {
        // `self` may have no use-sites inside the body (`-> "point"`),
        // in which case `resolved.idents` doesn't surface the symbol.
        // Fall back to a synthesised symbol carrying the param's name
        // so the dump renders the signature correctly.
        symbol_or_null :: lookup_local_symbol(project_ctx, typed.resolved, ast_param.span)
        symbol :: synth_param_or(symbol_or_null, ast_param.name, typed)
        // The lone `self` param carries an absent TypeExpr ; substitute the
        // impl's `for_type` so downstream phases see the concrete receiver
        // type rather than `Self`.
        param_type :: if ast_param.name == "self" { self_type } else { types.param_type(ast_param) }
        params.push(LoweredParam {
            .name = ast_param.name, .symbol = symbol, .type = param_type,
        })
    }
    return params
}

import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/parser" { Visibility }

synth_param_or :: fn(symbol_or_null: Symbol | null, name: string, typed: TypedProgram) -> Symbol {
    match symbol_or_null {
        is Symbol as s -> { return s }
        is null -> {
            return Symbol {
                .id         = i32(0),
                .kind       = SymbolKind.Param,
                .name       = name,
                .module     = typed.resolved.path,
                .visibility = Visibility.Private,
                .defined_at = null,
            }
        }
    }
}

impl_member_mangled :: fn(
    impl_decl: ImplDecl, member: FnDecl, typed: TypedProgram, decls: Decl[],
) -> string {
    target_name :: for_type_name(impl_decl.for_type, typed)
    suffix :: impl_member_overload_suffix(member, impl_decl, target_name, decls)
    return "${mangle_module_id(typed.resolved.display_path)}$${target_name}$${impl_decl.trait_name}$${member.name}${suffix}"
}

/// Number of earlier impl members in `decls` that share the same
/// `(target_name, trait_name, method.name)` triple. The first
/// occurrence yields `""` ; later ones get `_1`, `_2`, …. Mirrors TS's
/// per-impl-method numbering for distinct trait-impl bundles of the
/// same trait against the same target type.
impl_member_overload_suffix :: fn(
    member: FnDecl, owning_impl: ImplDecl, target_name: string, decls: Decl[],
) -> string {
    if member.name_span.start.offset < 0 { return "" }
    target_offset :: member.name_span.start.offset
    seen :: i32(0)
    counter := seen
    for d in decls {
        match d {
            is ImplDecl as other -> {
                other_target :: for_type_name_of(other.for_type)
                if other_target != target_name { continue }
                if other.trait_name != owning_impl.trait_name { continue }
                for m in other.members {
                    if m.name != member.name { continue }
                    if m.name_span.start.offset == target_offset {
                        if counter == i32(0) { return "" }
                        return "_${counter}"
                    }
                    counter = counter + i32(1)
                }
            }
            _ -> {}
        }
    }
    return ""
}

for_type_name_of :: fn(for_type: TypeExpr) -> string {
    match for_type {
        is IdentExpr as e -> { return e.name }
        is GenericInstExpr as gi -> {
            match gi.callee {
                is IdentExpr as inner -> { return inner.name }
                _ -> { return "" }
            }
        }
        _ -> { return "" }
    }
}

// Recover the target struct / enum / alias name from the impl's
// `for_type`. Only `IdentExpr` and `GenericInstExpr(IdentExpr)` shapes
// surface as nominal impls today ; anything else falls back to the
// raw display string (defensive — never expected to fire).
import "vader/parser" { IdentExpr, GenericInstExpr }
for_type_name :: fn(for_type: TypeExpr, typed: TypedProgram) -> string {
    match for_type {
        is IdentExpr as e -> { return e.name }
        is GenericInstExpr as e -> {
            match e.callee {
                is IdentExpr as inner -> { return inner.name }
                _ -> { return "<unknown>" }
            }
        }
        _ -> { return "<unknown>" }
    }
}

import "vader/parser" { TypeExpr }
import "vader/typecheck" { type_from_expr }

lower_for_type :: fn(impl_decl: ImplDecl, typed: TypedProgram) -> Type {
    scratch: Diagnostic[] = []
    return type_from_expr(impl_decl.for_type, typed.resolved, scratch)
}

synth_impl_entry :: fn(member: FnDecl, typed: TypedProgram, mangled: string) -> MonoEntry {
    // Hand the resolver symbol down so downstream phases (DCE,
    // fn-table indexing, vtable_entries) can route by symbol id.
    // Was `null` previously, which left the bytecode emit unable to
    // resolve the impl-member's fn-table slot and the impl directive
    // unable to land in `BcModule.impl_table`.
    return MonoEntry {
        .id             = i32(0),
        .is_main        = false,
        .mangled        = mangled,
        .decl           = member,
        .symbol         = symbol_for_decl(member, typed),
        .subst          = new_substitution(),
        .type_arguments = [],
        .module         = typed,
    }
}

// FnDecl → `LoweredFnDecl`. Phase 3 wires up the body lowering via the
// shared `lower_block` driver. Generic fns (`type_params.len() > 0`)
// stay skipped until the mono pass ships ; phase 2's narrow contract
// holds — non-generic decls only.
lower_fn_decl :: fn(
    fn_decl: FnDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    if fn_decl.type_params.len() > 0 { return null }
    subst :: new_substitution()
    types :: make_entry_types(typed, subst)
    params: LoweredParam[] = []
    for ast_param in fn_decl.params {
        // Param symbols live behind `resolved.idents` use-sites — recover
        // by matching `defined_at` against the param's source span.
        // `@extern` decls have no body and params with no use-sites in the
        // declared body fall through the same gap. Synthesise a Param
        // symbol carrying the source name so the signature renders.
        symbol_or_null :: lookup_local_symbol(project_ctx, typed.resolved, ast_param.span)
        symbol :: synth_param_or(symbol_or_null, ast_param.name, typed)
        param_type_val :: types.param_type(ast_param)
        params.push(LoweredParam {
            .name = ast_param.name, .symbol = symbol, .type = param_type_val,
        })
    }
    return_type :: return_type_of(fn_decl, types)
    entry :: stub_entry(fn_decl, typed)
    body :: lower_fn_body(fn_decl, typed, project_ctx, entry, subst, return_type)
    return LoweredFnDecl {
        .mangled     = entry.mangled,
        .params      = params,
        .return_type = return_type,
        .body        = body,
        .origin      = entry,
    }
}

// Build the fn-body context and invoke the block lowerer. Returns
// `null` for `@extern` / signature-only fns (`body is null`).
lower_fn_body :: fn(
    fn_decl: FnDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    entry: MonoEntry, subst: Substitution, return_type: Type,
) -> LoweredBlock | null {
    match fn_decl.body {
        is null -> { return null }
        _ -> {
            fn_ctx :: new_fn_lower_ctx(project_ctx, entry, typed, subst, return_type, null)
            return lower_block(fn_ctx, fn_decl.body, true, false)
        }
    }
}

// StructDecl → `LoweredStructDecl` with resolved field types. Phase 2
// already needs this since the dump format includes the field list.
// Field types come from `struct_field_types` (the typecheck-side
// side-table the impl pass writes) when available — that's the only
// place self-referential types like `Node.next: Node | null` reach
// without going through a `TypeExpr` lookup that may miss.
lower_struct_decl :: fn(
    struct_decl: StructDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    if struct_decl.type_params.len() > 0 { return null }
    types :: make_entry_types(typed, new_substitution())
    field_table :: lookup_struct_field_table(struct_decl, typed)
    fields: LoweredStructField[] = []
    for field in struct_decl.fields {
        fields.push(LoweredStructField {
            .name = field.name,
            .type = resolve_field_type(types, field, field_table),
        })
    }
    entry :: stub_entry(struct_decl, typed)
    return LoweredStructDecl {
        .mangled = entry.mangled,
        .fields  = fields,
        .origin  = entry,
    }
}

import "vader/parser" { StructField }

// Recover the field-type-by-name table the typecheck wrote alongside
// `struct_decls`. Match by SYMBOL ID, not name — two modules can both
// declare a `PrimitiveType` struct (vader/types and vader/vm both do),
// and a name-only lookup picks whichever module's decl iterates first,
// returning a field table for a different struct entirely.
lookup_struct_field_table :: fn(
    struct_decl: StructDecl, typed: TypedProgram,
) -> MutableMap<string, Type> | null {
    sym :: symbol_for_decl(struct_decl, typed)
    if sym is null { return null }
    return typed.struct_field_types[sym.id]
}

// Pick the most-resolved type available : the typecheck-written
// `struct_field_types` entry first, falling back to the lowerer's
// `EntryTypes.type_expr_type` which reads `type_expr_types` (often
// unpopulated for self-referential fields).
resolve_field_type :: fn(
    types: EntryTypes, field: StructField, table: MutableMap<string, Type> | null,
) -> Type {
    match table {
        is null -> { return types.type_expr_type(field.ty) }
        _ -> {
            from_table :: table[field.name]
            match from_table {
                is null -> { return types.type_expr_type(field.ty) }
                _ -> { return from_table }
            }
        }
    }
}

// ConstDecl → `LoweredConstDecl`. Phase 3 wires the value to the
// expression lowerer. `@comptime`-baked constants live in
// `evaluated.modules[…].comptime_decls` ; the bytecode-emit chantier
// will fold them into `LoweredIntLit` / `LoweredArrayLit` here.
lower_const_decl :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    subst :: new_substitution()
    types :: make_entry_types(typed, subst)
    type_val :: types.const_decl_type(const_decl)
    // Implicit / explicit type-alias consts (`const T: type = i32 | string`,
    // or `Mixed :: i32 | string` with the alias detected during decl typing)
    // have no runtime slot — use sites resolve via `alias_types`. Skip emit
    // so the dump matches the TS lowerer's `constTypeAliases` short-circuit.
    if type_val is TypeMetaType { return null }
    entry :: stub_entry(const_decl, typed)
    fn_ctx :: new_fn_lower_ctx(project_ctx, entry, typed, subst, type_val, null)
    // Prefer the comptime-baked value when the evaluator was able to fold
    // the const expression. The TS lowerer routes through
    // `comptimeValueToLowered(baked, …)` so downstream phases see the
    // materialised literal rather than the source AST.
    value :: lower_const_value(const_decl, typed, project_ctx, fn_ctx, type_val)
    return LoweredConstDecl {
        .mangled = entry.mangled,
        .type    = type_val,
        .value   = value,
        .origin  = entry,
    }
}

lower_const_value :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    fn_ctx: FnLowerCtx, type_val: Type,
) -> LoweredExpr {
    baked :: lookup_comptime_value(const_decl, typed, project_ctx)
    match baked {
        is null -> { return lower_expr(fn_ctx, const_decl.value) }
        _ -> { return comptime_value_to_lowered(baked, default_if_free(type_val), const_decl.span) }
    }
}

lookup_comptime_value :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
) -> ComptimeValue | null {
    program :: project_ctx.evaluated.modules[typed.resolved.path]
    if program is null { return null }
    symbol :: lookup_const_symbol(const_decl, typed)
    if symbol is null { return null }
    if symbol is Symbol as s {
        return program.comptime_decls[s.id]
    }
    return null
}

lookup_const_symbol :: fn(const_decl: ConstDecl, typed: TypedProgram) -> Symbol | null {
    for symbol in typed.resolved.symbols {
        if i32(symbol.kind) != i32(SymbolKind.Const) { continue }
        if symbol.name == const_decl.name { return symbol }
    }
    return null
}


// Recover a fn-decl's resolved return type from `decl_types`. Falls
// back to `void` when the decl-type lookup misses (the fn was rejected
// upstream — cascading diagnostics already surfaced).
return_type_of :: fn(fn_decl: FnDecl, types: EntryTypes) -> Type {
    decl_type :: types.fn_decl_type(fn_decl)
    if decl_type is FnType as ft { return ft.return_type }
    // Impl members aren't in `decl_types` (Symbol.id-keyed for
    // top-level decls). They live in `impl_method_decl_types`
    // keyed by name_span via `span_key` — consult that as a
    // fallback so impl-member return types stop falling through
    // to TY_VOID. Apply the entry's subst so an erasure-flavoured
    // EntryTypes still produces an erased return type.
    impl_type :: types.typed.impl_method_decl_types[fn_decl.name_span.hash()]
    if impl_type is FnType as ft { return types.apply(ft.return_type) }
    return TY_VOID
}

// Build a stub `MonoEntry` for a decl. `mangled` follows the TS
// `<module-id-with-slashes-and-dots-replaced-by-underscores>$<name>`
// convention so downstream phases + the snapshot harness see the same
// stable identifier as the TS lowerer. `is_main` stays the routing
// identity ; the bytecode emit reads that flag (not the mangled
// name) to pick the entry point.
stub_entry :: fn(decl: Decl, typed: TypedProgram) -> MonoEntry {
    name :: decl_name(decl)
    suffix :: overload_suffix_for(decl, typed)
    mangled :: "${mangle_module_id(typed.resolved.display_path)}$${name}${suffix}"
    // Propagate the resolver-side `Symbol` so downstream phases (notably
    // the bytecode emit's `function_index_by_symbol_id` index) can route
    // call sites — `LoweredIdent.symbol` holds the same id, so the two
    // ends meet at the resolver symbol rather than the (null) mono one.
    // `symbol_for_decl` disambiguates fn overloads via `name_span`, which
    // a name-only lookup would mis-route.
    resolved_symbol :: symbol_for_decl(decl, typed)
    return MonoEntry {
        .id             = i32(0),
        .is_main        = is_main_decl(decl),
        .mangled        = mangled,
        .decl           = decl,
        .symbol         = resolved_symbol,
        .subst          = new_substitution(),
        .type_arguments = [],
        .module         = typed,
    }
}

/// `_N` suffix for overloaded fn names. The resolver groups every
/// fn-decl with the same name into `fn_overloads[name]` ; this fn
/// finds the current decl's position in that bucket and emits the
/// matching index. Returns `""` for unique names + non-fn decls.
overload_suffix_for :: fn(decl: Decl, typed: TypedProgram) -> string {
    name_span_or_null :: decl_name_span(decl)
    if name_span_or_null is null { return "" }
    if name_span_or_null is Span as name_span {
        bucket :: typed.resolved.fn_overloads[decl_name(decl)]
        if bucket is null { return "" }
        if bucket is Symbol[] as symbols {
            if symbols.len() < 2 { return "" }
            for i in 0..<symbols.len() {
                match symbols[i].defined_at {
                    is null -> {}
                    is Span as defined -> {
                        if defined.hash() == name_span.hash() {
                            if i == 0 { return "" }
                            return "_${i}"
                        }
                    }
                }
            }
        }
    }
    return ""
}

decl_name_span :: fn(decl: Decl) -> Span | null {
    match decl {
        is FnDecl     as f -> { return f.name_span }
        is StructDecl as s -> { return s.name_span }
        is ConstDecl  as c -> { return c.name_span }
        _ -> { return null }
    }
}

// Slash-and-dot → underscore substitution. Matches the TS prefix the
// lowerer's `mangled` field renders against.
mangle_module_id :: fn(module_id: string) -> string {
    sb := new_builder()
    for c in module_id {
        if c == '/' { sb.append_char('_') }
        else if c == '.' { sb.append_char('_') }
        else { sb.append_char(c) }
    }
    return sb.to_string()
}

import "std/string_builder" { new_builder, append, append_char }

// Recover the source name from any top-level decl. Used for the stub
// entry's `mangled` field ; Phase 3 will switch to the proper mangled
// name once the monomorphizer ports.
decl_name :: fn(decl: Decl) -> string = match decl {
    is FnDecl     as f -> f.name
    is StructDecl as s -> s.name
    is ConstDecl  as c -> c.name
    _ -> ""
}

is_main_decl :: fn(decl: Decl) -> bool {
    match decl {
        is FnDecl as f -> { return f.name == "main" }
        _ -> { return false }
    }
}

// Per-module decls. Loaded module's first file carries them ;
// folder-modules with multiple files are flattened at load time so the
// per-file accessor doesn't have to walk multiple files here. (Mirrors
// `vader/comptime/check.vader::lookup_module_decls`.)
/// Walk `evaluated.instances` and emit a synthetic monomorphic decl
/// per concrete generic instance. Structs land as
/// `Symbol__T1__T2 { field: ConcreteT }` ; generic-impl members
/// follow as `Symbol$Trait$method__T1__T2(...)`. Mirror of TS's
/// `monomorphizeProject` (`src/comptime/specialize.ts`) pass-2.
/// Walk the project ctx's `fn_instances` table and emit one
/// monomorphized `LoweredFnDecl` per instance. The body lowers the
/// source FnDecl against a fresh `Substitution` binding the fn's
/// typeParams to the call site's concrete types.
materialize_generic_fn_instances :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Sort by `<fn_symbol.id>::<args_key>` to match TS's `displayKey`
    // ordering in `src/comptime/instances.ts:33`. The `symbol.id`
    // prefix groups overloads of the same fn ; within a group, args
    // sort alphabetically (so `id(f64)` < `id(i32)` < `id(string)`).
    //
    // The mono pass's Pass 3 (`run_pass_3` in `specialize.vader`)
    // also produces one entry per `(fn symbol, type_arguments)` pair,
    // routed through `evaluated.mono.fn_instance_entries`. The
    // mangled names differ (existing `inst.mangled` carries a
    // double-prefix bug ; mono's `entry.mangled` carries the
    // canonical single-prefix). Until that's reconciled, we keep
    // driving from `project_ctx.fn_instances_order` for byte-parity
    // with the current snapshots, and use mono only as a gate :
    // instances absent from mono (e.g. observed-but-rejected) are
    // skipped early.
    //
    // TODO: drop `project_ctx.fn_instances_order` and read entirely
    // from `evaluated.mono.fn_instance_entries`. Blocked on snapshot
    // updates for the mangled-name change.
    // Transitive monomorphisation : lowering an instance body can
    // register *new* instances (e.g. `outer<T>` calling `inner<T>`),
    // appending to `fn_instances_order` mid-loop. Iterate to a fixpoint
    // over a `processed` set so transitively-discovered instances also
    // materialise. Bodies are built into `collected` first, then sorted
    // by `<fn_symbol.id>::<args>` and pushed — so `inner` (lower symbol
    // id) emits before `outer` regardless of discovery order. Mirror of
    // TS' mono registry, which collects every instance transitively
    // before emit (`src/comptime/specialize.ts` run_pass_3).
    processed: MutableMap<string, bool> = MutableMap<string, bool> { .buckets = [], .size = 0 }
    collected: PendingFnInstance[] = []
    // `fn_instances_order` is append-only here — `build_fn_instance_decl`
    // only ever pushes newly-discovered instances. A growing-array
    // cursor that re-reads `len()` each step therefore visits every
    // transitive instance in one pass ; `processed` dedups duplicate
    // `(symbol, args)` discoveries. Re-indexing by position is safe
    // across reallocs.
    i: usize = 0
    for i < project_ctx.fn_instances_order.len() {
        inst :: project_ctx.fn_instances_order[i]
        i += 1
        key :: fn_instance_key(inst)
        if processed[key] != null { continue }
        processed[key] = true
        // The comptime harvest (`harvest_instances`) does not observe
        // generic fn calls today ; the lowerer's own probe is
        // authoritative, so we don't gate on the mono table.
        built :: build_fn_instance_decl(inst, key, loaded, typed, project_ctx, diags)
        match built {
            is null -> {}
            is PendingFnInstance as p -> { collected.push(p) }
        }
    }
    // Erasure-dedupe : every instance of a NON-trait-dispatching free
    // generic fn erases to the same Any-typed body, so collapse a fn's
    // group to a single decl keyed by `fn_symbol.id`, keeping the first
    // by sort order (`outer<i32>` + `outer<string>` -> one `outer__i32`).
    // Mirror of TS' `erasureDedupe` collapsing each fn group to one
    // representative (`src/comptime/erasure-dedupe.ts`). Impl-member
    // instances never reach `fn_instances` (they route through the mono
    // / vtable path), so this only collapses free generic fns.
    //
    // A trait-dispatching free generic fn (GATE A : `dispatches`, built
    // CONCRETE per instance) does NOT erase — `get__string` and `get__i32`
    // are distinct bodies dispatching `key.hash()` / `key.equals()` on the
    // concrete key, and their call sites target the per-key mangle.
    // Collapsing them to the first-sorted `__i32__` instance routes every
    // non-i32-keyed map's `at`/`set_at` into `i32$Hash$hash` → a string key
    // hits `i32.to_i64` and traps. They are already deduped by full `key`
    // in the build loop above (`processed[key]`) and carry a NULL
    // `origin.symbol` (set in `build_fn_instance_decl`), so the body-emit
    // pass indexes them by mangle — exactly like materialised impl members.
    sorted_pending :: sort(collected, pending_fn_instance_less)
    emitted_fns: MutableMap<i32, bool> = MutableMap<i32, bool> { .buckets = [], .size = 0 }
    for p in sorted_pending {
        if p.dispatches {
            push_to_module(project, p.module_id, p.decl)
            continue
        }
        if emitted_fns[p.fn_symbol_id] != null { continue }
        emitted_fns[p.fn_symbol_id] = true
        push_to_module(project, p.module_id, p.decl)
    }
}

// One materialised fn instance awaiting emission, carrying its routing
// key so the final push order matches the `<symbol.id>::<args>` sort,
// plus the source fn's symbol id for erasure-dedupe grouping.
PendingFnInstance :: struct {
    module_id:    string
    key:          string
    fn_symbol_id: i32
    /// True when the source generic fn trait-dispatches on a type param
    /// (GATE A → concretised per instance via `build_fn_concrete_subst`).
    /// Such instances skip the `fn_symbol_id` erasure-dedupe: each per-key
    /// body (`get__string` vs `get__i32`) is a distinct concrete fn whose
    /// call sites target the per-key mangle.
    dispatches:   bool
    decl:         LoweredFnDecl
}

pending_fn_instance_less :: fn(a: PendingFnInstance, b: PendingFnInstance) = compare_ascending(a.key, b.key)

/// True when `evaluated.mono` carries a FnDecl-kind MonoEntry whose
/// symbol id matches `inst.fn_symbol.id` and whose `type_arguments`
/// matches `inst.type_args`. The mono pass already filters out
/// degenerate instances, so missing entries here mean the lowerer
/// should also skip.
mono_has_fn_instance_for :: fn(project_ctx: LowerProjectCtx, inst: GenericFnInstance) -> bool {
    entries :: project_ctx.evaluated.mono.entries
    i: usize = 0
    for i < entries.len() {
        entry :: entries[i]
        if entry.type_arguments.len() != inst.type_args.len() {
            i += 1
            continue
        }
        match entry.symbol {
            is Symbol as s -> {
                if s.id == inst.fn_symbol.id { return true }
            }
            _ -> {}
        }
        i += 1
    }
    return false
}

fn_instance_key :: fn(inst: GenericFnInstance) -> string {
    sb := new_builder()
    sb.append("${inst.fn_symbol.id}::")
    for a in inst.type_args {
        sb.append(":")
        sb.append(display_type(a))
    }
    return sb.to_string()
}

// Build (but don't push) the monomorphized `LoweredFnDecl` for `inst`.
// Lowering the body here can register transitive fn instances into
// `project_ctx.fn_instances_order` — the caller's fixpoint loop picks
// those up. Returns null when the owner module / source decl is
// missing.
build_fn_instance_decl :: fn(
    inst: GenericFnInstance, key: string, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> PendingFnInstance | null {
    owner_module_id :: inst.owner_module
    owner_module :: loaded.modules[owner_module_id]
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return null }
    if owner_module is null { return null }
    fn_decl :: find_fn_decl_by_name(module_decls(owner_module), inst.fn_symbol.name, inst.type_args.len())
    if fn_decl is null { return null }
    // Erasure vs concrete subst (GATE A) : a generic fn whose body
    // trait-dispatches on a type-param (e.g. `println<T: Display>` calling
    // `msg.to_string()`) must stay CONCRETE per instance — erasing `T` to
    // `Any` lowers the dispatch to `virtual.call` on a `ref _` receiver
    // that no vtable resolves (the mode-a gap). Typecheck flags these in
    // `fn_trait_dispatches`. Everything else still erases to `Any` (TS does
    // the same — concrete-everywhere regresses non-dispatching generics).
    dispatches :: owner_typed.fn_trait_dispatches[fn_decl.id] is bool
    subst :: if dispatches {
        build_fn_concrete_subst(fn_decl, owner_typed, inst.type_args)
    } else {
        build_fn_any_subst(fn_decl, owner_typed)
    }
    types :: make_entry_types(owner_typed, subst)
    params: LoweredParam[] = []
    for ast_param in fn_decl.params {
        symbol_or_null :: lookup_local_symbol(project_ctx, owner_typed.resolved, ast_param.span)
        sym :: synth_param_or(symbol_or_null, ast_param.name, owner_typed)
        raw_ty :: types.param_type(ast_param)
        params.push(LoweredParam {
            .name = ast_param.name, .symbol = sym, .type = raw_ty,
        })
    }
    return_type :: substitute(return_type_of(fn_decl, types), subst)
    entry_decl: Decl = fn_decl
    // A trait-dispatching (GATE A, per-instance-concrete) free generic fn
    // carries a NULL origin symbol so the bytecode body-emit indexes it by
    // MANGLE, not by the shared source-fn symbol id. Every per-key instance
    // (`get__string`, `get__i32`, …) reuses the one `get` symbol ; keeping a
    // non-null symbol makes `reserve_cfg_function` overwrite a single
    // `function_index_by_symbol_id` slot, so all instances but the last
    // ship with an EMPTY body. Mirrors `materialize_impl_for_instance`,
    // which sets `.symbol = null` on impl members for the same reason.
    // Erased (non-dispatching) instances keep the symbol — they collapse to
    // one decl per symbol id via the erasure-dedupe below.
    entry_symbol: Symbol | null = if dispatches { null } else { inst.fn_symbol }
    entry :: MonoEntry {
        .id             = i32(0),
        .is_main        = false,
        .mangled        = inst.mangled,
        .decl           = entry_decl,
        .symbol         = entry_symbol,
        .subst          = subst,
        .type_arguments = inst.type_args,
        .module         = owner_typed,
    }
    body :: lower_fn_body(fn_decl, owner_typed, project_ctx, entry, subst, return_type)
    return PendingFnInstance {
        .module_id    = owner_module_id,
        .key          = key,
        .fn_symbol_id = inst.fn_symbol.id,
        .dispatches   = dispatches,
        .decl         = LoweredFnDecl {
            .mangled     = inst.mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body,
            .origin      = entry,
        },
    }
}

find_fn_decl_by_name :: fn(decls: Decl[], name: string, arity: usize) -> FnDecl | null {
    for d in decls {
        match d {
            is FnDecl as f -> {
                if f.name != name { continue }
                if f.type_params.len() == 0 { continue }
                if f.type_params.len() != arity { continue }
                return f
            }
            _ -> {}
        }
    }
    return null
}

// First non-generic FnDecl named `name` in `decls`. Stdlib fn names are
// effectively unique within a module ; on the rare overload, the first
// match wins (refine to arity-keyed if a real collision surfaces).
find_nongeneric_fn_decl_by_name :: fn(decls: Decl[], name: string) -> FnDecl | null {
    for d in decls {
        if d is FnDecl as f {
            if f.name == name && f.type_params.len() == 0 { return f }
        }
    }
    return null
}

// The non-generic FnDecl that DEFINED `fn_sym`. For an overloaded name
// (`min :: fn(f64, f64) ; min :: fn(usize, usize)`) the resolver minted a
// distinct symbol per decl with `defined_at` = the decl's `name_span` ; match
// on that span so the right overload is materialised. A name-only lookup
// would always pick the first declared overload and the call site (re-pointed
// to a sibling overload by `retype_overload_callee`) would resolve to the
// wrong body — or drop entirely. Falls back to name when the symbol carries
// no span.
find_nongeneric_fn_decl_for_symbol :: fn(decls: Decl[], fn_sym: Symbol) -> FnDecl | null {
    match fn_sym.defined_at {
        is null -> { return find_nongeneric_fn_decl_by_name(decls, fn_sym.name) }
        is Span as want -> {
            for d in decls {
                if d is FnDecl as f {
                    if f.name != fn_sym.name { continue }
                    if f.type_params.len() != usize(0) { continue }
                    if f.name_span.hash() == want.hash() { return f }
                }
            }
            // Span miss (e.g. a re-pointed symbol whose span originated in a
            // different per-module parse) : fall back to the name lookup.
            return find_nongeneric_fn_decl_by_name(decls, fn_sym.name)
        }
    }
}

// Materialise the non-generic stdlib free fns harvested at call sites
// (`register_nongeneric_stdlib_fn`). Each is lowered once via the normal
// `lower_fn_decl` path — with-body fns land as real fns, `@extern` ones
// as `body = null` decls the bytecode emitter routes to the import table.
// Without this, calls to `append` / `byte_len` / `new_builder` and other
// non-generic stdlib fns are dropped (their module bodies are skipped by
// `is_stdlib_path`, and only GENERIC instances are otherwise harvested).
materialize_nongeneric_stdlib_fns :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Cursor over a growing array : lowering one stdlib body can harvest
    // further non-generic stdlib fns it calls, appending mid-loop.
    // Resume from a persisted cursor : the materialise↔surface fixpoint loop
    // re-enters this fn after surfacing harvests further free fns, and we must
    // not re-lower the entries already emitted on an earlier pass.
    for project_ctx.nongeneric_stdlib_cursor < project_ctx.nongeneric_stdlib_order.len() {
        fn_sym :: project_ctx.nongeneric_stdlib_order[project_ctx.nongeneric_stdlib_cursor]
        project_ctx.nongeneric_stdlib_cursor += usize(1)
        module_typed :: typed.modules[fn_sym.module]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[fn_sym.module]
        if module_loaded is null { continue }
        if module_typed is TypedProgram as mt {
            if module_loaded is LoadedModule as ml {
                fn_decl :: find_nongeneric_fn_decl_for_symbol(module_decls(ml), fn_sym)
                if fn_decl is FnDecl as fd {
                    // Bodyless externs are surfaced up front in
                    // `lower_project`'s stdlib branch — skip to avoid a
                    // duplicate import entry for the same symbol.
                    if fd.body is null { continue }
                    lowered :: lower_fn_decl(fd, mt, project_ctx, diags)
                    if lowered != null { push_to_module(project, fn_sym.module, lowered) }
                }
            }
        }
    }
}

build_fn_subst :: fn(fd: FnDecl, args: Type[], typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for i in 0..<fd.type_params.len() {
        if i >= args.len() { break }
        tp_span :: fd.type_params[i].span
        target_key :: tp_span.hash()
        // Span-precise lookup : the resolver minted the TypeParam symbol
        // with `defined_at = tp.span`. Scan `idents.values()` for the
        // matching slot.
        for s in typed.resolved.idents.values() {
            match s.defined_at {
                is null -> {}
                is Span as def -> {
                    if def.hash() == target_key {
                        if i32(s.kind) == i32(SymbolKind.TypeParam) {
                            subst.type_params[s.id] = args[i]
                        }
                    }
                }
            }
        }
    }
    return subst
}

/// Erasure variant of `build_fn_subst` — maps every type-parameter
/// of `fd` to `TY_ANY` so the materialised instance's body / signature
/// renders with `Any` slots regardless of the concrete call-site type
/// arguments. The mangled name still embeds the concrete args (handled
/// by the caller via `inst.mangled`).
build_fn_any_subst :: fn(fd: FnDecl, typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for tp in fd.type_params {
        tp_sym :: find_type_param_in_resolved(typed.resolved, tp.name, tp.span)
        if tp_sym is Symbol as s { subst.type_params[s.id] = TY_ANY }
    }
    return subst
}

// Concrete per-instance subst (GATE A) : map each type-param to its
// concrete arg instead of `Any`. Mirror of `build_fn_any_subst`'s symbol
// resolution (same `find_type_param_in_resolved`, which `build_subst`'s
// span-offset finder doesn't match here) — only the mapped value differs.
build_fn_concrete_subst :: fn(fd: FnDecl, typed: TypedProgram, type_args: Type[]) -> Substitution {
    subst :: new_substitution()
    i: usize = 0
    for tp in fd.type_params {
        if i >= type_args.len() { break }
        tp_sym :: find_type_param_in_resolved(typed.resolved, tp.name, tp.span)
        if tp_sym is Symbol as s { subst.type_params[s.id] = type_args[i] }
        i += 1
    }
    return subst
}

// Phase 1 of the two-pass instance materialisation : concrete struct
// decls only. Returns the dedupe set so the representatives pass
// (Phase 2, called after fn-instances) can resume with the same
// state. `pending_reps` is rebuilt inside the second pass from
// `evaluated.instances` since they're stored on the project ctx.
materialize_concrete_struct_instances :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, diags: Diagnostic[],
) -> MutableSet<string> {
    seen_reps :: new_string_set()
    for inst in project_ctx.evaluated.instances {
        if !mono_has_struct_entry_for(project_ctx, inst) { continue }
        materialize_one_instance(inst, loaded, typed, project_ctx, project, diags)
    }
    return seen_reps
}

// Phase 2 : emit the "any-args" representative struct decls AFTER
// the fn-instance pass has run, so the dump order is :
//   concrete structs ; fn instances ; representative structs.
materialize_representatives :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, seen_reps: MutableSet<string>,
) -> void {
    for inst in project_ctx.evaluated.instances {
        if !mono_has_struct_entry_for(project_ctx, inst) { continue }
        materialize_representative(inst, loaded, typed, project_ctx, project, seen_reps)
    }
}

/// Emit the second-mono "any-args" representative struct decl for a
/// concrete generic instance. The representative shares the first
/// instance's body shape (every field already erased to `Any`) but
/// carries a distinct mangled name: the bare struct mangle plus the
/// any-leaves args. Mirrors `src/comptime/erasure-dedupe.ts:217-257`'s
/// extraStructEntries emission. Deduped on the representative mangle so
/// two concrete instantiations of the same generic shape only emit one.
materialize_representative :: fn(
    inst: GenericInstance, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    seen_reps: MutableSet<string>,
) -> void {
    if !all_concrete_args(inst.args) { return }
    sym :: inst.symbol
    if i32(sym.kind) != i32(SymbolKind.Struct) { return }
    owner_module_id :: sym.module
    owner_module :: loaded.modules[owner_module_id]
    if owner_module is null { return }
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return }
    if owner_typed is TypedProgram as owner_typed_ok {
        // `join_any_displays` already renders nested wrappers with `_`
        // (`Box(Box(i32))` → `Box_Any`), so one top-level `__` join keeps
        // nesting intact. TS extraStructEntries uses the empty-typeArgs
        // template, so its `first.mangled` likewise has no `__<arg>` segment.
        bare_mangled :: "${mangle_module_id(owner_typed_ok.resolved.display_path)}$${sym.name}"
        any_args :: build_any_args_list(inst.args)
        rep_mangled :: "${bare_mangled}__${join_any_displays(any_args)}"
        // Dedup before the struct-decl lookup so a repeated instance of an
        // already-emitted shape skips the linear `find_struct_decl_by_name`.
        if seen_reps.contains(rep_mangled) { return }
        if owner_module is LoadedModule as owner_loaded {
            owner_decls :: module_decls(owner_loaded)
            decl :: find_struct_decl_by_name(owner_decls, sym.name)
            if decl is null { return }
            if decl is StructDecl as sd {
                if sd.type_params.len() == 0 { return }
                seen_reps.add(rep_mangled)
                erase :: build_any_subst(sd, owner_typed_ok)
                fields: LoweredStructField[] = []
                for f in sd.fields {
                    raw_ty :: resolve_field_type(f.ty, owner_typed_ok, sd, inst.args)
                    fields.push(LoweredStructField {
                        .name = f.name,
                        .type = substitute(raw_ty, erase),
                    })
                }
                entry_decl: Decl = sd
                entry :: MonoEntry {
                    .id             = i32(0),
                    .is_main        = false,
                    .mangled        = rep_mangled,
                    .decl           = entry_decl,
                    .symbol         = sym,
                    .subst          = erase,
                    .type_arguments = any_args,
                    .module         = owner_typed_ok,
                }
                push_to_module(project, owner_typed_ok.resolved.path, LoweredStructDecl {
                    .mangled = rep_mangled,
                    .fields  = fields,
                    .origin  = entry,
                })
            }
        }
    }
}

/// Replace every concrete leaf in a `Type` tree with `Any` while
/// preserving generic wrappers (Struct / Trait / Array / Union /
/// Tuple). Mirror of `anyLeavesOf` in
/// `src/comptime/erasure-dedupe.ts:86-100`.
any_leaves_of :: fn(t: Type) -> Type {
    if t is StructType as s {
        if s.args.is_empty() { return TY_ANY }
        new_args: Type[] = []
        for a in s.args { new_args.push(any_leaves_of(a)) }
        return mk_struct(s.symbol, new_args)
    }
    if t is TraitType as tt {
        if tt.args.is_empty() { return TY_ANY }
        new_args: Type[] = []
        for a in tt.args { new_args.push(any_leaves_of(a)) }
        return mk_trait(tt.symbol, new_args)
    }
    if t is ArrayType as a {
        return mk_array(any_leaves_of(a.element), a.immutable)
    }
    if t is UnionType as u {
        new_vars: Type[] = []
        for v in u.variants { new_vars.push(any_leaves_of(v)) }
        return mk_union(new_vars)
    }
    if t is TupleType as tu {
        new_elems: Type[] = []
        for el in tu.elements { new_elems.push(any_leaves_of(el)) }
        return mk_tuple(new_elems)
    }
    return TY_ANY
}

/// Short stable display used when synthesising the representative's
/// mangled name. Mirrors `displayAnyArg` in
/// `src/comptime/erasure-dedupe.ts:105-121`.
display_any_arg :: fn(t: Type) -> string = match t {
    is StructType as s -> if s.args.is_empty() { s.symbol.name } else { joined_named(s.symbol.name, s.args, "_") }
    is TraitType  as t -> if t.args.is_empty() { t.symbol.name } else { joined_named(t.symbol.name, t.args, "_") }
    is ArrayType  as a -> "${display_any_arg(a.element)}_arr"
    is UnionType  as u -> joined_unnamed(u.variants, "__")
    is TupleType  as t -> joined_named("Tup", t.elements, "_")
    _                  -> "Any"
}

joined_named :: fn(name: string, args: Type[], sep: string) -> string {
    sb :: new_builder()
    sb.append(name)
    for a in args {
        sb.append(sep)
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

joined_unnamed :: fn(args: Type[], sep: string) -> string {
    sb :: new_builder()
    first := true
    for a in args {
        if !first { sb.append(sep) }
        first = false
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

build_any_args_list :: fn(args: Type[]) -> Type[] {
    out: Type[] = []
    for a in args { out.push(any_leaves_of(a)) }
    return out
}

join_any_displays :: fn(args: Type[]) -> string {
    sb :: new_builder()
    first := true
    for a in args {
        if !first { sb.append("__") }
        first = false
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

import "vader/types" { mk_trait, mk_array, mk_union, mk_tuple }
import "std/string_builder" { append_char as sb_append_char }

/// True when `evaluated.mono` carries a StructDecl-kind MonoEntry
/// whose `symbol.id` matches `inst.symbol.id` and whose
/// `type_arguments` is non-empty. Lets `materialize_generic_instances`
/// skip instances that the mono pass already rejected (TypeParam-only,
/// stdlib-only, etc.) without re-deriving the filter logic.
mono_has_struct_entry_for :: fn(project_ctx: LowerProjectCtx, inst: GenericInstance) -> bool {
    if i32(inst.symbol.kind) != i32(SymbolKind.Struct) { return false }
    entries :: project_ctx.evaluated.mono.entries
    i: usize = 0
    for i < entries.len() {
        entry :: entries[i]
        if entry.type_arguments.len() == 0 {
            i += 1
            continue
        }
        match entry.symbol {
            is Symbol as s -> {
                if s.id == inst.symbol.id { return true }
            }
            _ -> {}
        }
        i += 1
    }
    return false
}

materialize_one_instance :: fn(
    inst: GenericInstance, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Only concrete instances get a monomorphized decl. Skip uses where
    // any arg is still a TypeParam (those are the generic decl's own
    // body referencing itself).
    if !all_concrete_args(inst.args) { return }
    sym :: inst.symbol
    owner_module_id :: sym.module
    owner_module :: loaded.modules[owner_module_id]
    if owner_module is null { return }
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return }
    if owner_typed is TypedProgram as owner_typed_ok {
        if owner_module is LoadedModule as owner_loaded {
            owner_decls :: module_decls(owner_loaded)
            // (1) Find the StructDecl for this instance ; emit a
            // monomorphized struct decl. Emitted even for stdlib structs
            // (`MutableMap(usize, Span)`, `Entry`, …) — pushed into the
            // empty stdlib lowered module created above so the bytecode
            // type table carries the concrete shape instead of an orphan
            // `ref`. (Filtered from the lower dump, so byte-match is safe.)
            if i32(sym.kind) == i32(SymbolKind.Struct) {
                materialize_struct_instance(inst, owner_decls, owner_typed_ok, project_ctx, project)
                // (2) For every generic impl whose for_type targets the
                // same struct symbol, materialize each member — including
                // stdlib structs (`Range<i32>`, `MutableMap<…>`). Trait
                // default methods (`Range.count()` / `.last()` /
                // `.is_empty()`) need a real body to dispatch through ;
                // skipping stdlib here dropped them onto the defensive
                // `Return` arm in the CFG emit. Whole-program DCE
                // (`prune_unreachable_fns`) culls anything the user never
                // reaches, so over-materialising is safe.
                materialize_impl_members_for(inst, owner_decls, owner_typed_ok, project_ctx, project, loaded, typed, diags)
            }
        }
    }
}

all_concrete_args :: fn(args: Type[]) -> bool {
    for a in args {
        if has_type_param(a) { return false }
    }
    return true
}

has_type_param :: fn(t: Type) -> bool {
    match t {
        is TypeParamType -> { return true }
        is StructType as s -> {
            for a in s.args { if has_type_param(a) { return true } }
            return false
        }
        is ArrayType as ar -> { return has_type_param(ar.element) }
        _ -> { return false }
    }
}

/// Monomorphized struct mangle : `<module>$<Name>__<arg>__<arg>…`.
/// The single source of the concrete-instance naming scheme — both
/// `materialize_struct_instance` and `shape_mangle` build their name
/// here so the closure pass dedups field-referenced shapes against
/// emitted decls by name.
mangle_struct_instance :: fn(display_path: string, name: string, args: Type[]) =
    "${mangle_module_id(display_path)}$${name}${args_suffix(args)}"

materialize_struct_instance :: fn(
    inst: GenericInstance, owner_decls: Decl[], owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
) -> LoweredStructField[] {
    decl :: find_struct_decl_by_name(owner_decls, inst.symbol.name)
    if decl is null { return [] }
    if decl is StructDecl as sd {
        // Non-generic structs fall through safely : empty `type_params`
        // ⇒ identity substs and `args_suffix([]) == ""`, so fields are
        // unchanged and the mangle is the bare `<module>$<Name>`. Lets the
        // closure pass materialise referenced stdlib structs
        // (`StringBuilder`, `JsonObject`, …) whose bodies are never lowered.
        mangled :: mangle_struct_instance(owner_typed.resolved.display_path, inst.symbol.name, inst.args)
        // Erasure : the entry's `subst` keeps the concrete args (for
        // mangling + downstream consumers that need the source-level
        // type-args), but the FIELDS get the anySubst applied so every
        // TypeParam mention lands on `Any`. Identical monos can then
        // collapse to a single C-emit shape. Mirror of TS `anySubst`
        // in `src/comptime/specialize.ts:45-54`.
        subst :: build_struct_subst(sd, inst.args, owner_typed)
        erase :: build_any_subst(sd, owner_typed)
        fields: LoweredStructField[] = []
        for f in sd.fields {
            raw_ty :: resolve_field_type(f.ty, owner_typed, sd, inst.args)
            field_ty :: substitute(raw_ty, erase)
            fields.push(LoweredStructField {
                .name = f.name,
                .type = field_ty,
            })
        }
        entry_decl: Decl = sd
        entry :: MonoEntry {
            .id             = i32(0),
            .is_main        = false,
            .mangled        = mangled,
            .decl           = entry_decl,
            .symbol         = inst.symbol,
            .subst          = subst,
            .type_arguments = inst.args,
            .module         = owner_typed,
        }
        push_to_module(project, owner_typed.resolved.path, LoweredStructDecl {
            .mangled = mangled,
            .fields  = fields,
            .origin  = entry,
        })
        return fields
    }
    return []
}

/// Transitively materialise generic-struct shapes referenced by the
/// fields of already-emitted struct decls. A struct instance's fields
/// are erased to `Any` for the instance's own type-params, but a field
/// whose type names another generic struct keeps that struct's concrete
/// (or partially-erased) args — e.g. `MutableSet(i32)`'s erased field
/// `inner: MutableMap(Any, bool)`. Such a shape is neither a directly
/// instantiated generic nor an all-Any representative, so nothing else
/// materialises it and the bytecode interner mints an orphan `ref
/// MutableMap`. This pass walks every emitted struct decl's fields,
/// materialises each referenced generic-struct shape that has no decl
/// yet (keyed by mangled name), and drains to a fixpoint over the
/// shapes the newly-emitted decls reference in turn. Mirrors the shapes
/// TS' mono pass produces when substituting a representative body's
/// type-params. Bounded by `MAX_FIELD_SHAPES` against a pathological
/// ever-growing generic.
close_over_field_shapes :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject,
) -> void {
    materialized :: new_string_set()
    seen_pushed :: new_string_set()
    worklist: StructType[] = []
    collect :: (sub: Type) -> push_struct_shape(sub, worklist, seen_pushed)
    for module_id in project.modules.keys() {
        m :: project.modules[module_id]
        if m is LoweredModule as mod {
            for decl in mod.decls {
                if decl is LoweredStructDecl as sd { materialized.add(sd.mangled) }
                // Walk fields, signature AND body so a shape reachable only
                // through a body local / expr type (e.g. a `ParsedArgs`
                // local) is harvested alongside field / signature shapes.
                for_each_lowered_type(decl, collect)
            }
        }
    }
    i: usize = 0
    count := 0
    for i < worklist.len() {
        if count >= MAX_FIELD_SHAPES { break }
        shape :: worklist[i]
        i += 1
        mangled :: shape_mangle(shape, typed)
        if mangled is null { continue }
        if materialized.contains(mangled) { continue }
        materialized.add(mangled)
        count += 1
        new_fields :: materialize_shape(shape.symbol, shape.args, loaded, typed, project_ctx, project)
        for f in new_fields { for_each_type(f.type, collect) }
    }
}

/// Cap on representative field shapes materialised per project — guards
/// against a pathological generic that grows its type at each level.
/// Matches TS' `MAX_INSTANCES` (`src/comptime/evaluate.ts`).
MAX_FIELD_SHAPES :: 4096

/// `for_each_type` visitor : push a struct shape onto `out` the first
/// time it's seen — both concrete generic instances (`MutableMap(Any,
/// bool)`) and plain non-generic structs (`StringBuilder`), since either
/// can be referenced without a materialised decl. Dedup by `(symbol.id,
/// display)` keeps the worklist to one entry per distinct shape — the
/// same shape recurs across hundreds of field / signature slots
/// otherwise. TypeParam-bearing shapes (a generic decl's own
/// self-reference) are skipped.
push_struct_shape :: fn(t: Type, out: StructType[], seen: MutableSet<string>) -> void {
    if t is StructType as s {
        if has_type_param(s) { return }
        key :: "${s.symbol.id}|${display_type(s)}"
        if seen.contains(key) { return }
        seen.add(key)
        out.push(s)
    }
}

new_string_set :: fn() = MutableSet<string> {
    .inner = MutableMap<string, bool> { .buckets = [], .size = 0 },
}

/// Visit every `Type` node referenced by `decl` — fields (struct),
/// signature + body (fn), type + value (const). `visit` is passed as a
/// direct fn argument (threaded through the recursion), never stored on a
/// struct, so it stays on the working closure-call path.
for_each_lowered_type :: fn(decl: LoweredDecl, visit: fn(Type) -> void) -> void {
    match decl {
        is LoweredFnDecl as d -> {
            for p in d.params { for_each_type(p.type, visit) }
            for_each_type(d.return_type, visit)
            body :: d.body
            if body != null { for_each_lowered_block(body, visit) }
        }
        is LoweredStructDecl as d -> { for f in d.fields { for_each_type(f.type, visit) } }
        is LoweredConstDecl as d -> {
            for_each_type(d.type, visit)
            for_each_lowered_expr(d.value, visit)
        }
    }
}

for_each_lowered_block :: fn(b: LoweredBlock, visit: fn(Type) -> void) -> void {
    for_each_type(b.type, visit)
    for s in b.stmts { for_each_lowered_stmt(s, visit) }
    trailing :: b.trailing
    if trailing != null { for_each_lowered_expr(trailing, visit) }
}

for_each_lowered_stmt :: fn(s: LoweredStmt, visit: fn(Type) -> void) -> void {
    match s {
        is LoweredLet as st -> {
            for_each_type(st.type, visit)
            for_each_lowered_expr(st.value, visit)
        }
        is LoweredAssign as st -> {
            for_each_lowered_expr(st.target, visit)
            for_each_lowered_expr(st.value, visit)
        }
        is LoweredExprStmt as st -> { for_each_lowered_expr(st.expr, visit) }
        is LoweredReturn as st -> {
            value :: st.value
            if value != null { for_each_lowered_expr(value, visit) }
        }
        is LoweredLoop as st -> {
            cond :: st.cond
            if cond != null { for_each_lowered_expr(cond, visit) }
            for_each_lowered_block(st.body, visit)
        }
        is LoweredBreak    -> {}
        is LoweredContinue -> {}
        is LoweredCellSet as st -> {
            for_each_lowered_expr(st.target, visit)
            for_each_lowered_expr(st.value, visit)
            for_each_type(st.value_type, visit)
        }
        is LoweredDeferPush as st -> { for_each_lowered_expr(st.thunk, visit) }
        is LoweredDeferPopExec -> {}
    }
}

for_each_lowered_expr :: fn(e: LoweredExpr, visit: fn(Type) -> void) -> void {
    for_each_type(e.type, visit)
    match e {
        is LoweredIdent -> {}
        is LoweredCall as c -> {
            for_each_lowered_expr(c.callee, visit)
            for a in c.args { for_each_lowered_expr(a, visit) }
        }
        is LoweredVirtualCall as v -> {
            for_each_lowered_expr(v.receiver, visit)
            for a in v.args { for_each_lowered_expr(a, visit) }
        }
        is LoweredFieldAccess as fa -> { for_each_lowered_expr(fa.target, visit) }
        is LoweredIndex as ix -> {
            for_each_lowered_expr(ix.target, visit)
            for_each_lowered_expr(ix.index, visit)
        }
        is LoweredUnary as u -> { for_each_lowered_expr(u.operand, visit) }
        is LoweredBinary as b -> {
            for_each_lowered_expr(b.left, visit)
            for_each_lowered_expr(b.right, visit)
        }
        is LoweredIf as ie -> {
            for_each_lowered_expr(ie.cond, visit)
            for_each_lowered_block(ie.then_block, visit)
            else_block :: ie.else_block
            if else_block != null { for_each_lowered_block(else_block, visit) }
        }
        is LoweredBlock as bl -> { for_each_lowered_block(bl, visit) }
        is LoweredStructLit as sl -> { for f in sl.fields { for_each_lowered_expr(f.value, visit) } }
        is LoweredArrayLit as al -> { for el in al.elements { for_each_lowered_expr(el, visit) } }
        is LoweredArrayLen as al -> { for_each_lowered_expr(al.target, visit) }
        is LoweredArrayPush as ap -> {
            for_each_lowered_expr(ap.target, visit)
            for_each_lowered_expr(ap.value, visit)
        }
        is LoweredArraySlice as asl -> {
            for_each_lowered_expr(asl.target, visit)
            for_each_lowered_expr(asl.lo, visit)
            for_each_lowered_expr(asl.hi, visit)
        }
        is LoweredStringSlice as ssl -> {
            for_each_lowered_expr(ssl.target, visit)
            for_each_lowered_expr(ssl.lo, visit)
            for_each_lowered_expr(ssl.hi, visit)
        }
        is LoweredCast as cs -> { for_each_lowered_expr(cs.value, visit) }
        is LoweredTypeCheck as tc -> {
            for_each_lowered_expr(tc.value, visit)
            for_each_type(tc.check_type, visit)
        }
        is LoweredIntrinsicCall as ic -> {
            for a in ic.args { for_each_lowered_expr(a, visit) }
            display_for :: ic.display_for
            if display_for != null { for_each_type(display_for, visit) }
        }
        is LoweredCellNew as cn -> {
            for_each_lowered_expr(cn.value, visit)
            for_each_type(cn.value_type, visit)
        }
        is LoweredCellGet as cg -> {
            for_each_lowered_expr(cg.target, visit)
            for_each_type(cg.value_type, visit)
        }
        is LoweredMakeClosure as mc -> { for_each_lowered_expr(mc.env, visit) }
        is LoweredDataConst as dc -> { for_each_type(dc.type, visit) }
        is LoweredTypeConst as tcst -> {
            for_each_type(tcst.type, visit)
            for_each_type(tcst.value, visit)
        }
        // Remaining variants are leaf literals (Int/Float/Bool/Null/Char/
        // String/Unreachable) carrying no nested expr. A future variant that
        // nests an expr/type must be added above, else its shapes are missed.
        _ -> {}
    }
}

// ---- reference walker (whole-program DCE) ---------------------------------

/// Walk a lowered decl's body for *call-graph* references : every
/// `LoweredCall` with a `LoweredIdent` callee yields the callee
/// symbol's `(id, name)` to `visit_fn`, and every `LoweredVirtualCall`
/// yields its `(trait, method)` to `visit_virtual`. Used by
/// `prune_unreachable_fns` (vader/lower/dce.vader) to mark reachable
/// functions from the program roots.
///
/// The callbacks are passed as DIRECT fn args (not boxed in a struct) :
/// the midir `WalkCtx` struct-fn-field invoke pattern segfaults on the
/// native backend, while direct-arg fn params dispatch correctly.
///
/// @param decl          the lowered top-level decl to scan.
/// @param visit_fn      called with `(callee.symbol.id, callee.symbol.name)`
///                      for every direct (ident-callee) call.
/// @param visit_virtual called with `(trait_name, method_name)` for every
///                      virtual call so the vtable fixpoint can keep the
///                      matching impl fns.
export for_each_lowered_ref :: fn(
    decl: LoweredDecl,
    visit_fn: fn(i32, string) -> void,
    visit_virtual: fn(string, string) -> void,
) -> void {
    match decl {
        is LoweredFnDecl as d -> {
            body :: d.body
            if body != null { ref_block(body, visit_fn, visit_virtual) }
        }
        is LoweredConstDecl as d -> ref_expr(d.value, visit_fn, visit_virtual)
        is LoweredStructDecl -> {}
    }
}

ref_block :: fn(b: LoweredBlock, visit_fn: fn(i32, string) -> void, visit_virtual: fn(string, string) -> void) -> void {
    for s in b.stmts { ref_stmt(s, visit_fn, visit_virtual) }
    trailing :: b.trailing
    if trailing != null { ref_expr(trailing, visit_fn, visit_virtual) }
}

ref_stmt :: fn(s: LoweredStmt, visit_fn: fn(i32, string) -> void, visit_virtual: fn(string, string) -> void) -> void {
    match s {
        is LoweredLet as st -> ref_expr(st.value, visit_fn, visit_virtual)
        is LoweredAssign as st -> {
            ref_expr(st.target, visit_fn, visit_virtual)
            ref_expr(st.value, visit_fn, visit_virtual)
        }
        is LoweredExprStmt as st -> ref_expr(st.expr, visit_fn, visit_virtual)
        is LoweredReturn as st -> {
            value :: st.value
            if value != null { ref_expr(value, visit_fn, visit_virtual) }
        }
        is LoweredLoop as st -> {
            cond :: st.cond
            if cond != null { ref_expr(cond, visit_fn, visit_virtual) }
            ref_block(st.body, visit_fn, visit_virtual)
        }
        is LoweredBreak    -> {}
        is LoweredContinue -> {}
        is LoweredCellSet as st -> {
            ref_expr(st.target, visit_fn, visit_virtual)
            ref_expr(st.value, visit_fn, visit_virtual)
        }
        is LoweredDeferPush as st -> ref_expr(st.thunk, visit_fn, visit_virtual)
        is LoweredDeferPopExec -> {}
    }
}

ref_expr :: fn(e: LoweredExpr, visit_fn: fn(i32, string) -> void, visit_virtual: fn(string, string) -> void) -> void {
    match e {
        is LoweredCall as c -> {
            if c.callee is LoweredIdent as callee_ident {
                visit_fn(callee_ident.symbol.id, callee_ident.symbol.name)
            }
            ref_expr(c.callee, visit_fn, visit_virtual)
            for a in c.args { ref_expr(a, visit_fn, visit_virtual) }
        }
        is LoweredVirtualCall as v -> {
            visit_virtual(v.trait_name, v.method)
            ref_expr(v.receiver, visit_fn, visit_virtual)
            for a in v.args { ref_expr(a, visit_fn, visit_virtual) }
        }
        is LoweredFieldAccess as fa -> ref_expr(fa.target, visit_fn, visit_virtual)
        is LoweredIndex as ix -> {
            ref_expr(ix.target, visit_fn, visit_virtual)
            ref_expr(ix.index, visit_fn, visit_virtual)
        }
        is LoweredUnary as u -> ref_expr(u.operand, visit_fn, visit_virtual)
        is LoweredBinary as b -> {
            ref_expr(b.left, visit_fn, visit_virtual)
            ref_expr(b.right, visit_fn, visit_virtual)
        }
        is LoweredIf as ie -> {
            ref_expr(ie.cond, visit_fn, visit_virtual)
            ref_block(ie.then_block, visit_fn, visit_virtual)
            else_block :: ie.else_block
            if else_block != null { ref_block(else_block, visit_fn, visit_virtual) }
        }
        is LoweredBlock as bl -> ref_block(bl, visit_fn, visit_virtual)
        is LoweredStructLit as sl -> { for f in sl.fields { ref_expr(f.value, visit_fn, visit_virtual) } }
        is LoweredArrayLit as al -> { for el in al.elements { ref_expr(el, visit_fn, visit_virtual) } }
        is LoweredArrayLen as al -> ref_expr(al.target, visit_fn, visit_virtual)
        is LoweredArrayPush as ap -> {
            ref_expr(ap.target, visit_fn, visit_virtual)
            ref_expr(ap.value, visit_fn, visit_virtual)
        }
        is LoweredArraySlice as asl -> {
            ref_expr(asl.target, visit_fn, visit_virtual)
            ref_expr(asl.lo, visit_fn, visit_virtual)
            ref_expr(asl.hi, visit_fn, visit_virtual)
        }
        is LoweredStringSlice as ssl -> {
            ref_expr(ssl.target, visit_fn, visit_virtual)
            ref_expr(ssl.lo, visit_fn, visit_virtual)
            ref_expr(ssl.hi, visit_fn, visit_virtual)
        }
        is LoweredCast as cs -> ref_expr(cs.value, visit_fn, visit_virtual)
        is LoweredTypeCheck as tc -> ref_expr(tc.value, visit_fn, visit_virtual)
        is LoweredIntrinsicCall as ic -> { for a in ic.args { ref_expr(a, visit_fn, visit_virtual) } }
        is LoweredCellNew as cn -> ref_expr(cn.value, visit_fn, visit_virtual)
        is LoweredCellGet as cg -> ref_expr(cg.target, visit_fn, visit_virtual)
        is LoweredMakeClosure as mc -> {
            visit_fn(mc.fn_symbol.id, mc.fn_symbol.name)
            ref_expr(mc.env, visit_fn, visit_virtual)
        }
        // A bare `LoweredIdent` whose symbol resolves to a `Fn` is a
        // fn-value reference (e.g. `let f = add`) — visit the target
        // so DCE keeps it alive. Without this, `add` (or any fn passed
        // by value but not directly called) gets pruned and the
        // bytecode emit hits the defensive `Return` stub when it
        // tries to resolve the fn-index. Mirror of TS's same walk.
        is LoweredIdent as ident -> {
            if i32(ident.symbol.kind) == i32(SymbolKind.Fn) {
                visit_fn(ident.symbol.id, ident.symbol.name)
            }
        }
        _ -> {}
    }
}

/// Mangled name a `materialize_shape` call would emit for `s`, or null
/// when the struct's owning module has no `TypedProgram`. Matches
/// `materialize_struct_instance`'s mangle so dedup against already-
/// emitted decls works by name.
shape_mangle :: fn(s: StructType, typed: TypedProject) -> string | null {
    owner_typed :: typed.modules[s.symbol.module]
    if owner_typed is TypedProgram as ot {
        return mangle_struct_instance(ot.resolved.display_path, s.symbol.name, s.args)
    }
    return null
}

/// Materialise the struct decl for `(sym, args)` and return its lowered
/// fields. Thin wrapper over `materialize_struct_instance` that resolves
/// the owning module's decls + typed view from a bare symbol + args.
materialize_shape :: fn(
    sym: Symbol, args: Type[], loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject,
) -> LoweredStructField[] {
    owner_module :: loaded.modules[sym.module]
    owner_typed :: typed.modules[sym.module]
    if owner_module is null { return [] }
    if owner_typed is null { return [] }
    if owner_typed is TypedProgram as ot {
        if owner_module is LoadedModule as ol {
            inst :: GenericInstance { .symbol = sym, .args = args, .display_key = "" }
            return materialize_struct_instance(inst, module_decls(ol), ot, project_ctx, project)
        }
    }
    return []
}

/// Build a substitution mapping every type-parameter of `sd` to
/// `TY_ANY`. Used by the erasure pass to drop type info from
/// monomorphized struct field types so identical monos share a single
/// C-emit shape. Mirror of `anySubst` in `src/comptime/specialize.ts:45`.
build_any_subst :: fn(sd: StructDecl, owner_typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for tp in sd.type_params {
        tp_symbol :: find_type_param_in_resolved(owner_typed.resolved, tp.name, tp.span)
        if !(tp_symbol is null) {
            subst.type_params[tp_symbol.id] = TY_ANY
        }
    }
    return subst
}

import "vader/types" { TY_ANY }

resolve_field_type :: fn(
    ty: TypeExpr, owner_typed: TypedProgram, sd: StructDecl, args: Type[],
) -> Type {
    // Prefer the typer's recorded type ; fall back to `type_from_expr`
    // resolving fresh against the struct's typeParam-shadowed scope.
    raw :: owner_typed.type_expr_types[ty.span.hash()]
    if !(raw is null) {
        // `raw is Type as t` would always be false — `Type` is the union
        // alias and the runtime tag carries the concrete variant, not the
        // alias. After the null check, `raw` already narrows to `Type`.
        if !(raw is UnresolvedType) { return raw }
    }
    scratch: Diagnostic[] = []
    return type_from_expr(ty, owner_typed.resolved, scratch)
}

materialize_impl_members_for :: fn(
    inst: GenericInstance, owner_decls: Decl[], owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    loaded: LoadedProject, typed: TypedProject, diags: Diagnostic[],
) -> void {
    // Walk every module's impls (impls can be in foreign modules) and
    // emit a synth fn for each matching impl member.
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        if module_typed is TypedProgram as mt {
            module_loaded :: loaded.modules[module_id]
            if module_loaded is null { continue }
            if module_loaded is LoadedModule as ml {
                for d in module_decls(ml) {
                    match d {
                        is ImplDecl as impl_decl -> {
                            if !is_generic_impl_for(impl_decl, inst.symbol.name) { continue }
                            materialize_impl_for_instance(
                                impl_decl, inst, mt, owner_typed, project_ctx, project,
                            )
                            // The impl body virtual-calls the bound traits'
                            // methods on the type-param (`cursor.gte(...)` /
                            // `cursor.step()` in `Range.next`). Materialise
                            // those bound-trait impls for the concrete args so
                            // the vtable carries the matching entries.
                            materialize_bound_trait_impls(
                                impl_decl, inst, project_ctx, project, loaded, typed, diags,
                            )
                        }
                        _ -> {}
                    }
                }
            }
        }
    }
}

is_generic_impl_for :: fn(impl_decl: ImplDecl, struct_name: string) -> bool {
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            match gi.callee {
                is IdentExpr as id -> { return id.name == struct_name }
                _ -> { return false }
            }
        }
        _ -> { return false }
    }
}

materialize_impl_for_instance :: fn(
    impl_decl: ImplDecl, inst: GenericInstance,
    impl_typed: TypedProgram, owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
) -> void {
    // Erasure : self type uses any-leaves args (Stack(Any) instead of
    // Stack(i32)) and the substitution carried into params / body maps
    // T → Any. Concrete monos that share the same impl shape post-
    // erasure can then collapse to a single C-emit body. Mangled name
    // keeps the concrete args suffix (`__i32`) so identity tags stay
    // distinct.
    subst :: build_impl_mixed_subst(impl_decl, impl_typed, inst.args)
    // A concrete-instantiation impl (`Wrapper<i32> implements …`) has no
    // type params, so the substitution is empty — keep the concrete
    // instance args (self stays `Wrapper<i32>`). Only a genuinely
    // generic impl (`Repeat<T> implements …`) erases its args to `Any`
    // for the shared post-erasure C-emit body.
    erased_args: Type[] = []
    if is_empty_substitution(subst) {
        for a in inst.args { erased_args.push(a) }
    } else {
        for a in inst.args { erased_args.push(keep_primitive_or_erase(a)) }
    }
    self_struct :: StructType { .symbol = inst.symbol, .args = erased_args }
    self_type: Type = self_struct
    // Suffix from the ERASED args : a generic impl mangles `count__Any`
    // (not `count__i32`) so the shared erased body's sibling self-calls
    // (`self.next()` in the `count` default) and every concrete-arg call
    // site resolve to one name. `find_impl_member_for` / `lower_for_in`
    // erase the receiver args the same way (gated on `ImplEntry.is_generic`).
    // Concrete-instantiation impls keep `erased_args == inst.args`, so their
    // suffix stays concrete. Generic impls use the STRUCTURE-FREE
    // `flat_any_suffix` (one `__Any` per arg) — `args_suffix(erased_args)`
    // would leak inner shape (`MutableMap<_, _[]>` → `at__Any__Any__`) and
    // diverge from a sibling instance's `at__Any__Any`, breaking the
    // single-body dedupe.
    suffix :: if is_empty_substitution(subst) { args_suffix(erased_args) } else { mixed_any_suffix(inst.args) }
    types :: make_entry_types(impl_typed, subst)
    impl_key_prefix :: impl_decl.span.hash()
    for member in impl_decl.members {
        // Erasure dedupe : every concrete-args instance of the same
        // (impl_decl, member) collapses to one emission. The first
        // instance wins ; the call sites land on the survivor via the
        // trait virtual-dispatch in bytecode emit.
        dedupe_key :: "${impl_key_prefix}::${member.name}${suffix}"
        if project_ctx.materialized_impl_keys.contains(dedupe_key) { continue }
        project_ctx.materialized_impl_keys.add(dedupe_key)
        params :: build_impl_member_params(member, self_type, types, impl_typed, project_ctx)
        return_type :: return_type_of(member, types)
        mangled :: "${mangle_module_id(owner_typed.resolved.display_path)}$${inst.symbol.name}$${impl_decl.trait_name}$${member.name}${suffix}"
        entry_decl: Decl = member
        entry :: MonoEntry {
            .id             = i32(0),
            .is_main        = false,
            .mangled        = mangled,
            .decl           = entry_decl,
            .symbol         = null,
            .subst          = subst,
            .type_arguments = inst.args,
            .module         = impl_typed,
        }
        body :: lower_fn_body(member, impl_typed, project_ctx, entry, subst, return_type)
        push_to_module(project, owner_typed.resolved.path, LoweredFnDecl {
            .mangled     = mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body,
            .origin      = entry,
        })
    }
}

import "vader/parser" { BinaryExpr, BinaryOp }

/// For each bounded type param of `impl_decl` (`Range<T> implements<T:
/// Comparable & Step>`), materialise the bound traits' impls for the
/// matching concrete instance arg. The generic-impl body dispatches a
/// type-param method (`cursor.gte(...)`) through a `virtual.call`, so the
/// vtable needs the concrete type's `(trait, method)` rows — which
/// `collect_vtable_entries` builds from the materialised member fns.
/// Deduped per `(type, trait)` ; no-op for unbounded type params.
materialize_bound_trait_impls :: fn(
    impl_decl: ImplDecl, inst: GenericInstance,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    loaded: LoadedProject, typed: TypedProject, diags: Diagnostic[],
) -> void {
    for i in 0..<impl_decl.type_params.len() {
        if i >= inst.args.len() { break }
        bound :: impl_decl.type_params[i].bound
        if bound == null { continue }
        type_name :: type_surface_name(inst.args[i])
        if type_name == "" { continue }
        trait_names: string[] = []
        flatten_trait_bound(bound, trait_names)
        for trait_name in trait_names {
            materialize_bound_impl(type_name, trait_name, project_ctx, project, loaded, typed, diags)
        }
    }
}

// Flatten a type-param bound expression into the list of trait names it
// names. `Comparable & Step` is a `BinaryExpr(BitAnd, ...)` ; a single
// bound is a bare `IdentExpr` ; a generic bound (`Iterator<T>`) takes the
// callee name.
flatten_trait_bound :: fn(bound: TypeExpr, out: string[]) -> void {
    match bound {
        is IdentExpr as id -> { out.push(id.name) }
        is BinaryExpr as b -> {
            if i32(b.op) == i32(BinaryOp.BitAnd) {
                flatten_trait_bound(b.left, out)
                flatten_trait_bound(b.right, out)
            }
        }
        is GenericInstExpr as gi -> {
            match gi.callee {
                is IdentExpr as cid -> { out.push(cid.name) }
                _ -> {}
            }
        }
        _ -> {}
    }
}

// Find the non-generic `<type_name> implements <trait_name>` impl across
// loaded modules and lower its members (SAM + default bodies) so the
// vtable picks them up. Deduped per `(type_name, trait_name)`.
materialize_bound_impl :: fn(
    type_name: string, trait_name: string,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    loaded: LoadedProject, typed: TypedProject, diags: Diagnostic[],
) -> void {
    dedupe_key :: "boundimpl::${type_name}::${trait_name}"
    if project_ctx.materialized_impl_keys.contains(dedupe_key) { return }
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        if module_typed is TypedProgram as mt {
            module_loaded :: loaded.modules[module_id]
            if module_loaded is null { continue }
            if module_loaded is LoadedModule as ml {
                decls :: module_decls(ml)
                for d in decls {
                    if d is ImplDecl as impl_ {
                        if impl_.trait_name != trait_name { continue }
                        if !impl_targets_name(impl_.for_type, type_name) { continue }
                        // Generic / concrete-instantiation impls go through the
                        // struct-instance path ; this targets the non-generic
                        // primitive (or plain struct) impls.
                        if impl_.type_params.len() > 0 { continue }
                        if impl_.for_type is GenericInstExpr { continue }
                        project_ctx.materialized_impl_keys.add(dedupe_key)
                        for m in lower_impl_member_list(impl_, mt, project_ctx, diags, decls) {
                            push_to_module(project, mt.resolved.path, m)
                        }
                        return
                    }
                }
            }
        }
    }
}

build_struct_subst :: fn(decl: StructDecl, args: Type[], typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for i in 0..<decl.type_params.len() {
        if i >= args.len() { break }
        tp_name :: decl.type_params[i].name
        tp_span :: decl.type_params[i].span
        bound :: find_type_param_in_resolved(typed.resolved, tp_name, tp_span)
        match bound {
            is null -> {}
            is Symbol as s -> { subst.type_params[s.id] = args[i] }
        }
    }
    return subst
}

find_type_param_in_resolved :: fn(resolved: ResolvedModule, name: string, def_span: Span) -> Symbol | null {
    target_key :: def_span.hash()
    // Use-site lookup : every use of `T` inside the struct's fields /
    // impl body lands in `idents` ; the value's `defined_at` points
    // back at the TypeParam's source span.
    for s in resolved.idents.values() {
        if s.name != name { continue }
        if i32(s.kind) != i32(SymbolKind.TypeParam) { continue }
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if def.hash() == target_key { return s }
            }
        }
    }
    // Fallback : name-only match (no use-site exists, e.g. a generic
    // decl never instantiated in this very module).
    for s in resolved.idents.values() {
        if s.name == name && i32(s.kind) == i32(SymbolKind.TypeParam) { return s }
    }
    return null
}

build_impl_subst :: fn(
    impl_decl: ImplDecl, args: Type[],
    impl_typed: TypedProgram, owner_typed: TypedProgram,
) -> Substitution {
    subst :: new_substitution()
    // Bounded form (impl-own typeParams) : substitute against impl's
    // typeParams. The legacy `Foo[T] implements ...` form is handled
    // by walking through the impl-side resolved symbols (the resolver
    // hoists struct typeParam names into the impl's scope).
    if impl_decl.type_params.len() > 0 {
        for i in 0..<impl_decl.type_params.len() {
            if i >= args.len() { break }
            tp_sym :: lookup_type_param_symbol(impl_typed.resolved, impl_decl.type_params[i].span)
            if tp_sym is null { continue }
            if tp_sym is Symbol as s { subst.type_params[s.id] = args[i] }
        }
        return subst
    }
    // Legacy form : the struct's typeParams are referenced by name in
    // the impl body. Bind by name against the impl module's symbols.
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            for i in 0..<gi.type_args.len() {
                if i >= args.len() { break }
                tp_name :: type_expr_simple_name(gi.type_args[i])
                if tp_name == "" { continue }
                for s in impl_typed.resolved.symbols {
                    if s.name == tp_name && i32(s.kind) == i32(SymbolKind.TypeParam) {
                        subst.type_params[s.id] = args[i]
                        break
                    }
                }
            }
        }
        _ -> {}
    }
    return subst
}

/// Erasure variant of `build_impl_subst` — every type-parameter
/// reachable from the impl maps to `TY_ANY` instead of the concrete
/// instance args. Used during `materialize_impl_for_instance` so
/// impl-member params / return types collapse to the deduped shape
/// (`value: Any` instead of `value: T` or `value: i32`), letting
/// distinct concrete monos share a single C-emit body.
///
/// Maps by name across every TypeParam symbol the impl module
/// exposes. The legacy `Stack[T] implements ...` form hoists the
/// struct's `T` into the impl's scope without giving it a fresh
/// symbol id ; matching by `(name, kind=TypeParam)` catches it
/// regardless of whose `defined_at` the use sites carry.
collect_impl_type_param_names :: fn(impl_decl: ImplDecl) -> string[] {
    names: string[] = []
    for tp in impl_decl.type_params { names.push(tp.name) }
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            for ta in gi.type_args {
                tp_name :: type_expr_simple_name(ta)
                if tp_name != "" { names.push(tp_name) }
            }
        }
        _ -> {}
    }
    return names
}

/// Mixed substitution : map each impl type param to its concrete instance arg
/// WHEN primitive (so the materialised body sees `K = i32` and primitive trait
/// dispatch devirtualises), else to `Any`. `names[i]` corresponds to `args[i]`.
map_type_params_mixed :: fn(subst: Substitution, scope: Symbol[], names: string[], args: Type[]) -> void {
    for s in scope {
        if i32(s.kind) != i32(SymbolKind.TypeParam) { continue }
        idx: i32 = -1
        for i in 0..<names.len() {
            if s.name == names[i] {
                idx = i32(i)
                break
            }
        }
        if idx < 0 { continue }
        target: Type = TY_ANY
        if usize(idx) < args.len() {
            arg :: args[usize(idx)]
            if arg is PrimitiveType { target = arg }
        }
        subst.type_params[s.id] = target
    }
}

/// Variant of `build_impl_any_subst` keeping PRIMITIVE type args concrete.
build_impl_mixed_subst :: fn(
    impl_decl: ImplDecl, impl_typed: TypedProgram, args: Type[],
) -> Substitution {
    subst :: new_substitution()
    names :: collect_impl_type_param_names(impl_decl)
    map_type_params_mixed(subst, impl_typed.resolved.symbols, names, args)
    map_type_params_mixed(subst, impl_typed.resolved.idents.values(), names, args)
    return subst
}

/// Erase a type arg for the impl-member self-type, but KEEP primitives concrete.
keep_primitive_or_erase :: fn(t: Type) -> Type {
    if t is PrimitiveType { return t }
    return any_leaves_of(t)
}

type_expr_simple_name :: fn(e: TypeExpr) -> string {
    match e {
        is IdentExpr as id -> { return id.name }
        _ -> { return "" }
    }
}

find_struct_decl_by_name :: fn(decls: Decl[], name: string) -> StructDecl | null {
    for d in decls {
        match d {
            is StructDecl as sd -> { if sd.name == name { return sd } }
            _ -> {}
        }
    }
    return null
}

lookup_type_param_symbol :: fn(resolved: ResolvedModule, name_span: Span) -> Symbol | null {
    target_key :: name_span.hash()
    for s in resolved.symbols {
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if def.hash() == target_key { return s }
            }
        }
    }
    for s in resolved.idents.values() {
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if def.hash() == target_key { return s }
            }
        }
    }
    return null
}

args_suffix :: fn(args: Type[]) -> string {
    sb := new_builder()
    for a in args {
        sb.append("__")
        sb.append(mangle_type_arg(a))
    }
    return sb.to_string()
}

/// Erasure suffix for a GENERIC impl member. KEEPS primitive type args concrete
/// (so a primitive-keyed instance devirtualises its trait dispatch — `i32.eq`
/// instead of a `virtual.call` thunk) and flattens every non-primitive arg to a
/// bare `__Any`. The flatten avoids the inner-shape leak a structure-preserving
/// `args_suffix(any_leaves_of(...))` would cause — e.g. `MutableMap<Any, Any[]>`
/// → `at__Any__Any__` diverging from a sibling's `at__Any__Any`. All three
/// suffix sites (`materialize_impl_for_instance`, `find_impl_member_for`,
/// `lower_for_in`) MUST call this with the same `args` so each call name
/// reconciles with the single materialised body (the dedupe keys on the suffix).
/// @param args  the impl's concrete type arguments.
/// @return      `"__<prim>"` per primitive arg, `"__Any"` per other arg.
export mixed_any_suffix :: fn(args: Type[]) -> string {
    sb := new_builder()
    for a in args {
        if a is PrimitiveType as p {
            sb.append("__")
            sb.append(p.name)
        } else {
            sb.append("__Any")
        }
    }
    return sb.to_string()
}

push_to_module :: fn(project: LoweredProject, module_id: string, decl: LoweredDecl) -> void {
    m :: project.modules[module_id]
    if m is null { return }
    if m is LoweredModule as mod {
        mod.decls.push(decl)
    }
}

import "vader/comptime" { GenericInstance }
import "vader/types" { EnumType, PrimitiveType }
import "vader/resolver" { ResolvedModule }
import "vader/comptime" { symbol_for_decl }

module_decls :: fn(module_loaded: LoadedModule) -> Decl[] {
    if module_loaded.module.files.len() == 0 { return [] }
    out: Decl[] = []
    for source_file in module_loaded.module.files {
        for decl in source_file.program.decls {
            out.push(decl)
        }
    }
    return out
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }
import "vader/typecheck" { new_typed_project }
import "vader/comptime" { new_evaluated_project }

@test test_lower_empty_project :: fn() -> void {
    loaded :: LoadedProject {
        .entry        = "",
        .modules      = MutableMap<string, LoadedModule> { .buckets = [], .size = 0 },
        .factory      = factory_for_test(),
        .project_root = null,
        .diags        = [],
    }
    typed :: new_typed_project()
    evaluated :: new_evaluated_project(typed)
    diags: Diagnostic[] = []
    project :: lower_project(loaded, typed, evaluated, diags)
    assert_eq(project.modules.size, usize(0))
}

import "vader/resolver/symbol" { new_factory, SymbolFactory }
factory_for_test :: fn() -> SymbolFactory { return new_factory() }
