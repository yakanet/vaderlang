// vader/lower/lower — project-level lowerer orchestrator.
//
// Mirror of `src/lower/lower.ts::lowerProject`. Walks every top-level
// decl across the project's typed modules, builds a stub `MonoEntry`
// per non-generic decl, and dispatches to the per-decl-kind lowerer.
// Phase 2 ships the skeleton with empty bodies ; Phase 3 fills in the
// actual expression / statement lowering.
//
// The orchestrator takes `LoadedProject` (for source decls) +
// `TypedProject` (for typed side-tables) + `EvaluatedProject` (for
// comptime values + mono entries). Today's `EvaluatedProject.mono`
// ships empty (the monomorphizer port is deferred to the bytecode emit
// chantier) ; we walk loaded module decls directly until then.

module "vader/lower"

import "std/collections" { MutableMap, keys, values }
import "std/sort" { sort }
import "std/iter" { is_empty }
import "std/string" { compare_ascending, byte_at, byte_len, byte_slice }
import "vader/diagnostics" { Diagnostic, Span }
import "vader/parser" {
    Decl, FnDecl, StructDecl, ConstDecl,
}
import "vader/resolver" { LoadedProject, LoadedModule }
import "vader/typecheck" { TypedProject, TypedProgram }
import "vader/typecheck" { Substitution, new_substitution, substitute }
import "vader/types" { UnresolvedType }
import "vader/types" {
    Type, FnType, StructType, TypeMetaType, TypeParamType, ArrayType, mk_struct, mk_primitive,
    display_type, TY_BOOL, TY_UNRESOLVED, TY_VOID,
}
import "vader/typecheck" { default_if_free }
import "vader/comptime" { EvaluatedProject, EvaluatedProgram }
import "vader/comptime" {
    ComptimeValue, IntValue, FloatValue, BoolValue, CharValue, StringValue,
    NullValue, VoidValue, ArrayValue, StructValue, TypeValue,
}
import "vader/comptime" { MonoEntry }

/// Lower every module's top-level decls into a `LoweredProject`.
/// @param loaded     the loaded project (for source decls per module).
/// @param typed      the typed project (for side-tables).
/// @param evaluated  the comptime engine's output.
/// @param diags      diagnostics emitted by the lowerer (L5xxx codes).
/// @return           the lowered project ready for downstream phases.
export lower_project :: fn(
    loaded: LoadedProject, typed: TypedProject, evaluated: EvaluatedProject, diags: Diagnostic[],
) -> LoweredProject {
    project_ctx :: new_lower_project_ctx(evaluated, loaded)
    // Closure analysis runs once at entry — every lambda's capture set
    // is precomputed so per-decl lowering can read it without re-
    // walking the AST.
    project_ctx.closures = analyze_closures(loaded, typed)
    // Populate `core_symbols` from each module's `resolved.core_symbols`
    // table (auto-imported std/core exports). Lookups like
    // `find_core_type("Yield", [T])` go through this cache.
    populate_core_symbols(typed, project_ctx)
    // Build the global symbol_id -> ComptimeValue index so per-ident
    // const-baked lookups (`lookup_const_baked_value`) hit O(1) instead
    // of walking every loaded module's `comptime_decls` map per call.
    populate_comptime_value_index(project_ctx)
    // Build the project-wide impl registry — aggregate every module's
    // `T implements Trait { … }` decls so downstream phases can query
    // by `(for_type, trait_name)`. Unblocks Display dispatch for
    // string interp, try for non-primitive Error variants, and the
    // for-in / Iterator step loop.
    populate_impls(loaded, typed, project_ctx)
    project :: new_lowered_project()

    module_ids :: typed.modules.keys()
    for module_id in module_ids {
        // Skip stdlib bodies — they're filtered from the dump anyway
        // (`is_stdlib_path` in dump.vader) and lowering them would
        // pollute the per-project synthetic-id counter, breaking
        // `__lambda_1` / `__lambda_env_2` numbering in user fixtures.
        //
        // Surfacing only `@intrinsic` / `@extern` signatures here would
        // populate the bytecode import table — but without whole-program
        // DCE on imports, every reachable stdlib fn lands in the dump
        // even when user code calls only `println`. Pair the surfacing
        // with reachability analysis as a separate chantier.
        if is_stdlib_path(module_id) { continue }
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        decls :: module_decls(module_loaded)
        display_path :: module_loaded.module.display_path
        lowered_module :: lower_module(module_id, display_path, module_typed, decls, project_ctx, diags)
        project.modules[module_id] = lowered_module
    }
    // After per-module lowering, materialise generic-struct instances +
    // their matching generic-impl members. Each `evaluated.instances`
    // entry yields a `StructDecl<Concrete>` + per-impl `__T` member fns.
    materialize_generic_instances(loaded, typed, project_ctx, project, diags)
    // Generic-fn instances observed at call sites get one
    // monomorphized `LoweredFnDecl` per `(fn_symbol, args)` tuple. The
    // body inherits the source fn-decl but lowered against a typeParam
    // substitution that binds T → arg[i].
    materialize_generic_fn_instances(loaded, typed, project_ctx, project, diags)
    return project
}

is_stdlib_path :: fn(path: string) = "stdlib/std/" in path

import "vader/typecheck" { build_impl_registry, ImplEntry }

// Populate `core_symbols` from std/core's resolved view so the
// lowerer can resolve `Range`, `Yield`, `ArrayIterator`, `Iterator`,
// `Display`, `Error`, … without re-walking the project per call.
// `iter_symbols` gets the same treatment for std/iter's exports
// (`MapIterator` / `FilterIterator` / etc.) so chain-fusion can spot
// the well-known struct shapes by symbol id.
populate_core_symbols :: fn(typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        // `core_symbols` on `ResolvedModule` carries cross-module
        // auto-import bindings — std/core's own entry has its
        // exported symbols here. Iterate every module's table and
        // copy into the project context ; std/core's entries
        // dominate since every module imports them.
        for symbol_name in module_typed.resolved.core_symbols.keys() {
            symbol :: module_typed.resolved.core_symbols[symbol_name]
            match symbol {
                is null -> {}
                is Symbol as resolved -> {
                    project_ctx.core_symbols[symbol_name] = resolved
                }
            }
        }
        // `std/iter`'s top-level symbols : copy under `iter_symbols`
        // so chain fusion's `MapIterator` / `FilterIterator` lookups
        // resolve to the canonical struct symbols.
        if is_std_iter_module(module_id) {
            iter_table :: ensure_iter_table(project_ctx)
            for entry in module_typed.resolved.symbols {
                iter_table[entry.name] = entry
            }
        }
    }
}

populate_comptime_value_index :: fn(project_ctx: LowerProjectCtx) -> void {
    // Flatten every loaded module's `comptime_decls` into one global
    // `symbol_id -> ComptimeValue` map. Const symbol ids are project-
    // unique (resolver mints from a single counter), so no module can
    // collide with another — direct assignment is safe.
    for module_id in project_ctx.evaluated.modules.keys() {
        program :: project_ctx.evaluated.modules[module_id]
        match program {
            is null -> {}
            is EvaluatedProgram as ep -> {
                for symbol_id in ep.comptime_decls.keys() {
                    v :: ep.comptime_decls[symbol_id]
                    match v {
                        is null -> {}
                        _ -> { project_ctx.comptime_value_by_symbol_id[symbol_id] = v }
                    }
                }
            }
        }
    }
}

is_std_iter_module :: fn(module_id: string) = "stdlib/std/iter.vader" in module_id

ensure_iter_table :: fn(project_ctx: LowerProjectCtx) -> MutableMap(string, Symbol) {
    match project_ctx.iter_symbols {
        is null -> {
            table :: MutableMap(string, Symbol) { .buckets = [], .size = 0 }
            project_ctx.iter_symbols = table
            return table
        }
        is MutableMap(string, Symbol) as existing -> { return existing }
    }
}


// Aggregate every loaded module's impl decls into the project ctx's
// registry. `build_impl_registry` works per-module ; we drain every
// resulting entry into `project_ctx.impls.all` (+ rekey `user_index`
// by `for_symbol.id::trait_symbol.id`, same as the per-module shape).
populate_impls :: fn(loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        module_decls_list :: module_decls(module_loaded)
        per_module :: build_impl_registry(module_decls_list, module_typed.resolved)
        for entry in per_module.all {
            project_ctx.impls.all.push(entry)
            match entry.for_symbol {
                is null -> {}
                is Symbol as for_symbol -> {
                    key :: "${for_symbol.id}::${entry.trait_symbol.id}"
                    project_ctx.impls.user_index[key] = entry
                }
            }
        }
    }
}

// Per-module driver. Walks the decl list, dispatches by kind, and
// builds the resulting `LoweredModule`. Lambda-lifted synth decls
// accumulated on `project_ctx.synth_decls` during the walk get drained
// into this module's `decls` list — they were spawned while lowering
// this module's bodies, so they ship alongside the regular decls.
lower_module :: fn(
    module_id: string, display_path: string, typed: TypedProgram, decls: Decl[],
    project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredModule {
    out_decls: LoweredDecl[] = []
    // First pass : every regular decl in source order. Impl members
    // surface as a multi-decl list right after their ImplDecl so the
    // dump's per-struct grouping matches TS source-order.
    synth_start :: project_ctx.synth_decls.len()
    for decl in decls {
        results :: lower_decl_list(decl, typed, project_ctx, diags, decls)
        for r in results { out_decls.push(r) }
    }
    // Second pass : drain the lambda-lift synth decls accumulated while
    // walking this module's bodies (lambdas / defers route through
    // `synth_decls`). Matches TS `lower.ts:74-78`.
    synth_end :: project_ctx.synth_decls.len()
    for i in synth_start..<synth_end {
        out_decls.push(project_ctx.synth_decls[i])
    }
    return LoweredModule {
        .module_id    = module_id,
        .display_path = display_path,
        .decls        = out_decls,
    }
}

/// Per-decl dispatcher returning every LoweredDecl this source decl
/// expands to. Most decls yield 0 or 1 ; ImplDecl yields one entry
/// per member so impl methods land inline (right after the impl) in
/// the dump.
lower_decl_list :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    diags: Diagnostic[], module_decls: Decl[],
) -> LoweredDecl[] {
    if decl is ImplDecl as impl_decl {
        return lower_impl_member_list(impl_decl, typed, project_ctx, diags, module_decls)
    }
    out: LoweredDecl[] = []
    result :: lower_decl(decl, typed, project_ctx, diags, module_decls)
    if !(result is null) { out.push(result) }
    return out
}

// Per-decl dispatcher. Routes FnDecl / StructDecl / ConstDecl through
// the matching phase-2 stub ; ImplDecl drains into per-member fn-decl
// entries appended to `project_ctx.synth_decls` so the module driver
// picks them up alongside the regular decls. Every other decl kind
// (Enum, Trait, TypeAlias, Import, Assert) returns null — they don't
// produce runtime slots.
lower_decl :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> LoweredDecl | null {
    match decl {
        is FnDecl     as fn_decl     -> { return lower_fn_decl(fn_decl, typed, project_ctx, diags) }
        is StructDecl as struct_decl -> { return lower_struct_decl(struct_decl, typed, project_ctx, diags) }
        is ConstDecl  as const_decl  -> { return lower_const_decl(const_decl, typed, project_ctx, diags) }
        is ImplDecl   as impl_decl   -> {
            lower_impl_members(impl_decl, typed, project_ctx, diags, module_decls)
            return null
        }
        _ -> { return null }
    }
}

import "vader/parser" { ImplDecl }

// Each `T implements Trait { method ... }` member surfaces as a fn
// decl with mangled name `<module>$<for-type>$<trait>$<method>`.
// `self` is the first parameter ; its type comes from the impl's
// `for_type`. The lifted fns are appended to `project_ctx.synth_decls`
// so the module driver drains them in the right order.
lower_impl_members :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> void {
    // Back-compat shape : keep the void-returning entry but route
    // through the inline emit + push results to `synth_decls` so any
    // caller still relying on the old "drains at module end" path
    // keeps working. Modern call sites prefer `lower_impl_member_list`.
    members :: lower_impl_member_list(impl_decl, typed, project_ctx, diags, module_decls)
    for m in members { project_ctx.synth_decls.push(m) }
}

/// Return the lowered fn-decl for each member of `impl_decl`, in
/// source order. Yielding the list (instead of pushing to
/// `project_ctx.synth_decls`) lets the caller interleave the members
/// right after the impl's source position — matching TS's per-mono
/// drain that emits each member individually.
lower_impl_member_list :: fn(
    impl_decl: ImplDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> LoweredDecl[] {
    out: LoweredDecl[] = []
    // Skip generic impls entirely — the mono pass binds them via a
    // separate path.
    if impl_decl.type_params.len() > usize(0) { return out }
    if impl_decl.for_type is GenericInstExpr { return out }
    self_type :: lower_for_type(impl_decl, typed)
    base_mangle :: "${mangle_module_id(typed.resolved.display_path)}$${impl_decl.trait_name}"
    for member in impl_decl.members {
        if member.type_params.len() > usize(0) { continue }
        subst :: new_substitution()
        types :: make_entry_types(typed, subst)
        params :: build_impl_member_params(member, self_type, types, typed, project_ctx)
        return_type :: return_type_of(member, types)
        mangled :: impl_member_mangled(impl_decl, member, typed, module_decls)
        entry :: synth_impl_entry(member, typed, mangled)
        body :: lower_fn_body(member, typed, project_ctx, entry, subst, return_type)
        out.push(LoweredFnDecl {
            .mangled     = mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body,
            .origin      = entry,
        })
    }
    return out
}

build_impl_member_params :: fn(
    member: FnDecl, self_type: Type, types: EntryTypes,
    typed: TypedProgram, project_ctx: LowerProjectCtx,
) -> LoweredParam[] {
    params: LoweredParam[] = []
    for ast_param in member.params {
        // `self` may have no use-sites inside the body (`-> "point"`),
        // in which case `resolved.idents` doesn't surface the symbol.
        // Fall back to a synthesised symbol carrying the param's name
        // so the dump renders the signature correctly.
        symbol_or_null :: lookup_local_symbol(project_ctx, typed.resolved, ast_param.span)
        symbol :: synth_param_or(symbol_or_null, ast_param.name, typed)
        // The lone `self` param carries an absent TypeExpr ; substitute the
        // impl's `for_type` so downstream phases see the concrete receiver
        // type rather than `Self`.
        param_type :: if ast_param.name == "self" { self_type } else { types.param_type(ast_param) }
        params.push(LoweredParam {
            .name = ast_param.name, .symbol = symbol, .type = param_type,
        })
    }
    return params
}

import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/parser" { Visibility }

synth_param_or :: fn(symbol_or_null: Symbol | null, name: string, typed: TypedProgram) -> Symbol {
    match symbol_or_null {
        is Symbol as s -> { return s }
        is null -> {
            return Symbol {
                .id         = i32(0),
                .kind       = SymbolKind.Param,
                .name       = name,
                .module     = typed.resolved.path,
                .visibility = Visibility.Private,
                .defined_at = null,
            }
        }
    }
}

impl_member_mangled :: fn(
    impl_decl: ImplDecl, member: FnDecl, typed: TypedProgram, decls: Decl[],
) -> string {
    target_name :: for_type_name(impl_decl.for_type, typed)
    suffix :: impl_member_overload_suffix(member, impl_decl, target_name, decls)
    return "${mangle_module_id(typed.resolved.display_path)}$${target_name}$${impl_decl.trait_name}$${member.name}${suffix}"
}

/// Number of earlier impl members in `decls` that share the same
/// `(target_name, trait_name, method.name)` triple. The first
/// occurrence yields `""` ; later ones get `_1`, `_2`, …. Mirrors TS's
/// per-impl-method numbering for distinct trait-impl bundles of the
/// same trait against the same target type.
impl_member_overload_suffix :: fn(
    member: FnDecl, owning_impl: ImplDecl, target_name: string, decls: Decl[],
) -> string {
    if member.name_span.start.offset < usize(0) { return "" }
    target_offset :: member.name_span.start.offset
    seen :: i32(0)
    counter := seen
    for d in decls {
        match d {
            is ImplDecl as other -> {
                other_target :: for_type_name_of(other.for_type)
                if other_target != target_name { continue }
                if other.trait_name != owning_impl.trait_name { continue }
                for m in other.members {
                    if m.name != member.name { continue }
                    if m.name_span.start.offset == target_offset {
                        if counter == i32(0) { return "" }
                        return "_${counter}"
                    }
                    counter = counter + i32(1)
                }
            }
            _ -> {}
        }
    }
    return ""
}

for_type_name_of :: fn(for_type: TypeExpr) -> string {
    match for_type {
        is IdentExpr as e -> { return e.name }
        is GenericInstExpr as gi -> {
            match gi.callee {
                is IdentExpr as inner -> { return inner.name }
                _ -> { return "" }
            }
        }
        _ -> { return "" }
    }
}

// Recover the target struct / enum / alias name from the impl's
// `for_type`. Only `IdentExpr` and `GenericInstExpr(IdentExpr)` shapes
// surface as nominal impls today ; anything else falls back to the
// raw display string (defensive — never expected to fire).
import "vader/parser" { IdentExpr, GenericInstExpr }
for_type_name :: fn(for_type: TypeExpr, typed: TypedProgram) -> string {
    match for_type {
        is IdentExpr as e -> { return e.name }
        is GenericInstExpr as e -> {
            match e.callee {
                is IdentExpr as inner -> { return inner.name }
                _ -> { return "<unknown>" }
            }
        }
        _ -> { return "<unknown>" }
    }
}

import "vader/parser" { TypeExpr }
import "vader/typecheck" { type_from_expr }

lower_for_type :: fn(impl_decl: ImplDecl, typed: TypedProgram) -> Type {
    scratch: Diagnostic[] = []
    return type_from_expr(impl_decl.for_type, typed.resolved, scratch)
}

synth_impl_entry :: fn(member: FnDecl, typed: TypedProgram, mangled: string) -> MonoEntry {
    return MonoEntry {
        .id             = i32(0),
        .is_main        = false,
        .mangled        = mangled,
        .decl           = member,
        .symbol         = null,
        .subst          = new_substitution(),
        .type_arguments = [],
        .module         = typed,
    }
}

// FnDecl → `LoweredFnDecl`. Phase 3 wires up the body lowering via the
// shared `lower_block` driver. Generic fns (`type_params.len() > 0`)
// stay skipped until the mono pass ships ; phase 2's narrow contract
// holds — non-generic decls only.
lower_fn_decl :: fn(
    fn_decl: FnDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    if fn_decl.type_params.len() > usize(0) { return null }
    subst :: new_substitution()
    types :: make_entry_types(typed, subst)
    params: LoweredParam[] = []
    for ast_param in fn_decl.params {
        // Param symbols live behind `resolved.idents` use-sites — recover
        // by matching `defined_at` against the param's source span.
        // `@extern` decls have no body and params with no use-sites in the
        // declared body fall through the same gap. Synthesise a Param
        // symbol carrying the source name so the signature renders.
        symbol_or_null :: lookup_local_symbol(project_ctx, typed.resolved, ast_param.span)
        symbol :: synth_param_or(symbol_or_null, ast_param.name, typed)
        param_type_val :: types.param_type(ast_param)
        params.push(LoweredParam {
            .name = ast_param.name, .symbol = symbol, .type = param_type_val,
        })
    }
    return_type :: return_type_of(fn_decl, types)
    entry :: stub_entry(fn_decl, typed)
    body :: lower_fn_body(fn_decl, typed, project_ctx, entry, subst, return_type)
    return LoweredFnDecl {
        .mangled     = entry.mangled,
        .params      = params,
        .return_type = return_type,
        .body        = body,
        .origin      = entry,
    }
}

// Build the fn-body context and invoke the block lowerer. Returns
// `null` for `@extern` / signature-only fns (`body is null`).
lower_fn_body :: fn(
    fn_decl: FnDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    entry: MonoEntry, subst: Substitution, return_type: Type,
) -> LoweredBlock | null {
    match fn_decl.body {
        is null -> { return null }
        _ -> {
            fn_ctx :: new_fn_lower_ctx(project_ctx, entry, typed, subst, return_type, null)
            return lower_block(fn_ctx, fn_decl.body, true, false)
        }
    }
}

// StructDecl → `LoweredStructDecl` with resolved field types. Phase 2
// already needs this since the dump format includes the field list.
// Field types come from `struct_field_types` (the typecheck-side
// side-table the impl pass writes) when available — that's the only
// place self-referential types like `Node.next: Node | null` reach
// without going through a `TypeExpr` lookup that may miss.
lower_struct_decl :: fn(
    struct_decl: StructDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    if struct_decl.type_params.len() > usize(0) { return null }
    types :: make_entry_types(typed, new_substitution())
    field_table :: lookup_struct_field_table(struct_decl, typed)
    fields: LoweredStructField[] = []
    for field in struct_decl.fields {
        fields.push(LoweredStructField {
            .name = field.name,
            .type = resolve_field_type(types, field, field_table),
        })
    }
    entry :: stub_entry(struct_decl, typed)
    return LoweredStructDecl {
        .mangled = entry.mangled,
        .fields  = fields,
        .origin  = entry,
    }
}

import "vader/parser" { StructField }

// Recover the field-type-by-name table the typecheck wrote alongside
// `struct_decls`. Returns `null` when the typer hasn't surfaced one
// for this decl (e.g. cascading-diagnostic recovery).
lookup_struct_field_table :: fn(
    struct_decl: StructDecl, typed: TypedProgram,
) -> MutableMap(string, Type) | null {
    for symbol_id in typed.struct_decls.keys() {
        candidate :: typed.struct_decls[symbol_id]
        if candidate is null { continue }
        if candidate.name == struct_decl.name {
            return typed.struct_field_types[symbol_id]
        }
    }
    return null
}

// Pick the most-resolved type available : the typecheck-written
// `struct_field_types` entry first, falling back to the lowerer's
// `EntryTypes.type_expr_type` which reads `type_expr_types` (often
// unpopulated for self-referential fields).
resolve_field_type :: fn(
    types: EntryTypes, field: StructField, table: MutableMap(string, Type) | null,
) -> Type {
    match table {
        is null -> { return types.type_expr_type(field.ty) }
        _ -> {
            from_table :: table[field.name]
            match from_table {
                is null -> { return types.type_expr_type(field.ty) }
                _ -> { return from_table }
            }
        }
    }
}

// ConstDecl → `LoweredConstDecl`. Phase 3 wires the value to the
// expression lowerer. `@comptime`-baked constants live in
// `evaluated.modules[…].comptime_decls` ; the bytecode-emit chantier
// will fold them into `LoweredIntLit` / `LoweredArrayLit` here.
lower_const_decl :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredDecl | null {
    subst :: new_substitution()
    types :: make_entry_types(typed, subst)
    type_val :: types.const_decl_type(const_decl)
    // Implicit / explicit type-alias consts (`const T: type = i32 | string`,
    // or `Mixed :: i32 | string` with the alias detected during decl typing)
    // have no runtime slot — use sites resolve via `alias_types`. Skip emit
    // so the dump matches the TS lowerer's `constTypeAliases` short-circuit.
    if type_val is TypeMetaType { return null }
    entry :: stub_entry(const_decl, typed)
    fn_ctx :: new_fn_lower_ctx(project_ctx, entry, typed, subst, type_val, null)
    // Prefer the comptime-baked value when the evaluator was able to fold
    // the const expression. The TS lowerer routes through
    // `comptimeValueToLowered(baked, …)` so downstream phases see the
    // materialised literal rather than the source AST.
    value :: lower_const_value(const_decl, typed, project_ctx, fn_ctx, type_val)
    return LoweredConstDecl {
        .mangled = entry.mangled,
        .type    = type_val,
        .value   = value,
        .origin  = entry,
    }
}

lower_const_value :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    fn_ctx: FnLowerCtx, type_val: Type,
) -> LoweredExpr {
    baked :: lookup_comptime_value(const_decl, typed, project_ctx)
    match baked {
        is null -> { return lower_expr(fn_ctx, const_decl.value) }
        _ -> { return comptime_value_to_lowered(baked, default_if_free(type_val), const_decl.span) }
    }
}

lookup_comptime_value :: fn(
    const_decl: ConstDecl, typed: TypedProgram, project_ctx: LowerProjectCtx,
) -> ComptimeValue | null {
    program :: project_ctx.evaluated.modules[typed.resolved.path]
    if program is null { return null }
    symbol :: lookup_const_symbol(const_decl, typed)
    if symbol is null { return null }
    if symbol is Symbol as s {
        return program.comptime_decls[s.id]
    }
    return null
}

lookup_const_symbol :: fn(const_decl: ConstDecl, typed: TypedProgram) -> Symbol | null {
    for symbol in typed.resolved.symbols {
        if i32(symbol.kind) != i32(SymbolKind.Const) { continue }
        if symbol.name == const_decl.name { return symbol }
    }
    return null
}


// Recover a fn-decl's resolved return type from `decl_types`. Falls
// back to `void` when the decl-type lookup misses (the fn was rejected
// upstream — cascading diagnostics already surfaced).
return_type_of :: fn(fn_decl: FnDecl, types: EntryTypes) -> Type {
    decl_type :: types.fn_decl_type(fn_decl)
    if decl_type is FnType as ft { return ft.return_type }
    // Impl members aren't in `decl_types` (Symbol.id-keyed for
    // top-level decls). They live in `impl_method_decl_types`
    // keyed by name_span via `span_key` — consult that as a
    // fallback so impl-member return types stop falling through
    // to TY_VOID. Apply the entry's subst so an erasure-flavoured
    // EntryTypes still produces an erased return type.
    impl_type :: types.typed.impl_method_decl_types[span_key(fn_decl.name_span)]
    if impl_type is FnType as ft { return types.apply(ft.return_type) }
    return TY_VOID
}

// Build a stub `MonoEntry` for a decl. `mangled` follows the TS
// `<module-id-with-slashes-and-dots-replaced-by-underscores>$<name>`
// convention so downstream phases + the snapshot harness see the same
// stable identifier as the TS lowerer. `is_main` stays the routing
// identity ; the bytecode emit reads that flag (not the mangled
// name) to pick the entry point.
stub_entry :: fn(decl: Decl, typed: TypedProgram) -> MonoEntry {
    name :: decl_name(decl)
    suffix :: overload_suffix_for(decl, typed)
    mangled :: "${mangle_module_id(typed.resolved.display_path)}$${name}${suffix}"
    // Propagate the resolver-side `Symbol` so downstream phases (notably
    // the bytecode emit's `function_index_by_symbol_id` index) can route
    // call sites — `LoweredIdent.symbol` holds the same id, so the two
    // ends meet at the resolver symbol rather than the (null) mono one.
    // `symbol_for_decl` disambiguates fn overloads via `name_span`, which
    // a name-only lookup would mis-route.
    resolved_symbol :: symbol_for_decl(decl, typed)
    return MonoEntry {
        .id             = i32(0),
        .is_main        = is_main_decl(decl),
        .mangled        = mangled,
        .decl           = decl,
        .symbol         = resolved_symbol,
        .subst          = new_substitution(),
        .type_arguments = [],
        .module         = typed,
    }
}

/// `_N` suffix for overloaded fn names. The resolver groups every
/// fn-decl with the same name into `fn_overloads[name]` ; this fn
/// finds the current decl's position in that bucket and emits the
/// matching index. Returns `""` for unique names + non-fn decls.
overload_suffix_for :: fn(decl: Decl, typed: TypedProgram) -> string {
    name_span_or_null :: decl_name_span(decl)
    if name_span_or_null is null { return "" }
    if name_span_or_null is Span as name_span {
        bucket :: typed.resolved.fn_overloads[decl_name(decl)]
        if bucket is null { return "" }
        if bucket is Symbol[] as symbols {
            if symbols.len() < usize(2) { return "" }
            for i in 0..<symbols.len() {
                match symbols[i].defined_at {
                    is null -> {}
                    is Span as defined -> {
                        if span_key(defined) == span_key(name_span) {
                            if i == usize(0) { return "" }
                            return "_${i}"
                        }
                    }
                }
            }
        }
    }
    return ""
}

decl_name_span :: fn(decl: Decl) -> Span | null {
    match decl {
        is FnDecl     as f -> { return f.name_span }
        is StructDecl as s -> { return s.name_span }
        is ConstDecl  as c -> { return c.name_span }
        _ -> { return null }
    }
}

// Slash-and-dot → underscore substitution. Matches the TS prefix the
// lowerer's `mangled` field renders against.
mangle_module_id :: fn(module_id: string) -> string {
    sb := new_builder()
    for c in module_id {
        if c == '/' { sb.append_char('_') }
        else if c == '.' { sb.append_char('_') }
        else { sb.append_char(c) }
    }
    return sb.to_string()
}

import "std/string_builder" { new_builder, append, append_char }

// Recover the source name from any top-level decl. Used for the stub
// entry's `mangled` field ; Phase 3 will switch to the proper mangled
// name once the monomorphizer ports.
decl_name :: fn(decl: Decl) -> string = match decl {
    is FnDecl     as f -> f.name
    is StructDecl as s -> s.name
    is ConstDecl  as c -> c.name
    _ -> ""
}

is_main_decl :: fn(decl: Decl) -> bool {
    match decl {
        is FnDecl as f -> { return f.name == "main" }
        _ -> { return false }
    }
}

// Per-module decls. Loaded module's first file carries them ;
// folder-modules with multiple files are flattened at load time so the
// per-file accessor doesn't have to walk multiple files here. (Mirrors
// `vader/comptime/check.vader::lookup_module_decls`.)
/// Walk `evaluated.instances` and emit a synthetic monomorphic decl
/// per concrete generic instance. Structs land as
/// `Symbol__T1__T2 { field: ConcreteT }` ; generic-impl members
/// follow as `Symbol$Trait$method__T1__T2(...)`. Mirror of TS's
/// `monomorphizeProject` (`src/comptime/specialize.ts`) pass-2.
/// Walk the project ctx's `fn_instances` table and emit one
/// monomorphized `LoweredFnDecl` per instance. The body lowers the
/// source FnDecl against a fresh `Substitution` binding the fn's
/// typeParams to the call site's concrete types.
materialize_generic_fn_instances :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Sort by `<fn_symbol.id>::<args_key>` to match TS's `displayKey`
    // ordering in `src/comptime/instances.ts:33`. The `symbol.id`
    // prefix groups overloads of the same fn ; within a group, args
    // sort alphabetically (so `id(f64)` < `id(i32)` < `id(string)`).
    //
    // The mono pass's Pass 3 (`run_pass_3` in `specialize.vader`)
    // also produces one entry per `(fn symbol, type_arguments)` pair,
    // routed through `evaluated.mono.fn_instance_entries`. The
    // mangled names differ (existing `inst.mangled` carries a
    // double-prefix bug ; mono's `entry.mangled` carries the
    // canonical single-prefix). Until that's reconciled, we keep
    // driving from `project_ctx.fn_instances_order` for byte-parity
    // with the current snapshots, and use mono only as a gate :
    // instances absent from mono (e.g. observed-but-rejected) are
    // skipped early.
    //
    // TODO: drop `project_ctx.fn_instances_order` and read entirely
    // from `evaluated.mono.fn_instance_entries`. Blocked on snapshot
    // updates for the mangled-name change.
    sorted :: sort(project_ctx.fn_instances_order, fn_instance_less)
    for inst in sorted {
        // The comptime harvest (`harvest_instances`) does not observe
        // generic fn calls today (only types reachable from typed-side
        // side-tables). The lowerer's own probe — populating
        // `fn_instances_order` from `try_lower_generic_fn_call` /
        // `try_lower_ufcs_call` — is authoritative until the comptime
        // harvest grows fn-call coverage. Gating on the (empty) mono
        // table would silently skip every observed instance.
        materialize_fn_instance(inst, loaded, typed, project_ctx, project, diags)
    }
}

/// True when `evaluated.mono` carries a FnDecl-kind MonoEntry whose
/// symbol id matches `inst.fn_symbol.id` and whose `type_arguments`
/// matches `inst.type_args`. The mono pass already filters out
/// degenerate instances, so missing entries here mean the lowerer
/// should also skip.
mono_has_fn_instance_for :: fn(project_ctx: LowerProjectCtx, inst: GenericFnInstance) -> bool {
    entries :: project_ctx.evaluated.mono.entries
    i: usize = 0
    for i < entries.len() {
        entry :: entries[i]
        if entry.type_arguments.len() != inst.type_args.len() {
            i += 1
            continue
        }
        match entry.symbol {
            is Symbol as s -> {
                if s.id == inst.fn_symbol.id { return true }
            }
            _ -> {}
        }
        i += 1
    }
    return false
}

fn_instance_less :: fn(a: GenericFnInstance, b: GenericFnInstance) -> bool {
    return compare_ascending(fn_instance_key(a), fn_instance_key(b))
}

fn_instance_key :: fn(inst: GenericFnInstance) -> string {
    sb := new_builder()
    sb.append("${inst.fn_symbol.id}::")
    for a in inst.type_args {
        sb.append(":")
        sb.append(display_type(a))
    }
    return sb.to_string()
}

materialize_fn_instance :: fn(
    inst: GenericFnInstance, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject, diags: Diagnostic[],
) -> void {
    owner_module_id :: inst.owner_module
    owner_module :: loaded.modules[owner_module_id]
    if owner_module is null { return }
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return }
    if owner_typed is TypedProgram as ot {
        if owner_module is LoadedModule as ol {
            decls :: module_decls(ol)
            fn_decl :: find_fn_decl_by_name(decls, inst.fn_symbol.name, inst.type_args.len())
            if fn_decl is null { return }
            if fn_decl is FnDecl as fd {
                // Erasure : map every type-param to `TY_ANY` so the
                // emitted body's signature collapses to `(x: Any) ->
                // Any`. The mangled name still carries the concrete
                // args (`identity__i32`) ; only the type slots get
                // erased.
                subst :: build_fn_any_subst(fd, ot)
                types :: make_entry_types(ot, subst)
                params: LoweredParam[] = []
                for ast_param in fd.params {
                    symbol_or_null :: lookup_local_symbol(project_ctx, ot.resolved, ast_param.span)
                    sym :: synth_param_or(symbol_or_null, ast_param.name, ot)
                    raw_ty :: types.param_type(ast_param)
                    params.push(LoweredParam {
                        .name = ast_param.name, .symbol = sym, .type = raw_ty,
                    })
                }
                return_type :: substitute(return_type_of(fd, types), subst)
                entry_decl: Decl = fd
                entry :: MonoEntry {
                    .id             = i32(0),
                    .is_main        = false,
                    .mangled        = inst.mangled,
                    .decl           = entry_decl,
                    .symbol         = inst.fn_symbol,
                    .subst          = subst,
                    .type_arguments = inst.type_args,
                    .module         = ot,
                }
                body :: lower_fn_body(fd, ot, project_ctx, entry, subst, return_type)
                push_to_module(project, owner_module_id, LoweredFnDecl {
                    .mangled     = inst.mangled,
                    .params      = params,
                    .return_type = return_type,
                    .body        = body,
                    .origin      = entry,
                })
            }
        }
    }
}

find_fn_decl_by_name :: fn(decls: Decl[], name: string, arity: usize) -> FnDecl | null {
    for d in decls {
        match d {
            is FnDecl as f -> {
                if f.name != name { continue }
                if f.type_params.len() == usize(0) { continue }
                if f.type_params.len() != arity { continue }
                return f
            }
            _ -> {}
        }
    }
    return null
}

build_fn_subst :: fn(fd: FnDecl, args: Type[], typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for i in 0..<fd.type_params.len() {
        if i >= args.len() { break }
        tp_span :: fd.type_params[i].span
        target_key :: span_key(tp_span)
        // Span-precise lookup : the resolver minted the TypeParam symbol
        // with `defined_at = tp.span`. Scan `idents.values()` for the
        // matching slot.
        for s in typed.resolved.idents.values() {
            match s.defined_at {
                is null -> {}
                is Span as def -> {
                    if span_key(def) == target_key {
                        if i32(s.kind) == i32(SymbolKind.TypeParam) {
                            subst.type_params[s.id] = args[i]
                        }
                    }
                }
            }
        }
    }
    return subst
}

/// Erasure variant of `build_fn_subst` — maps every type-parameter
/// of `fd` to `TY_ANY` so the materialised instance's body / signature
/// renders with `Any` slots regardless of the concrete call-site type
/// arguments. The mangled name still embeds the concrete args (handled
/// by the caller via `inst.mangled`).
build_fn_any_subst :: fn(fd: FnDecl, typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for tp in fd.type_params {
        tp_sym :: find_type_param_in_resolved(typed.resolved, tp.name, tp.span)
        if tp_sym is Symbol as s { subst.type_params[s.id] = TY_ANY }
    }
    return subst
}

materialize_generic_instances :: fn(
    loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx,
    project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Dedupe set for the erasure-dedupe representative pass. One entry
    // per distinct "any-leaves" shape of an instance group ; prevents
    // emitting the same `Pair__string__Any__Any` twice when both
    // `Pair(string, i64)` and `Pair(string, f64)` get materialised.
    seen_reps :: MutableSet(string) {
        .inner = MutableMap(string, bool) { .buckets = [], .size = 0 },
    }
    // Drive from `evaluated.mono` — the monomorphizer pass populates
    // one MonoEntry per concrete struct instance (+ its impl members)
    // via `monomorphize_project::run_pass_2`. We still use
    // `project_ctx.evaluated.instances` as the data source for the
    // per-instance materialisation (to keep the existing helpers
    // unchanged + match the existing mangled-name convention) ; the
    // mono walk only confirms which instances actually have a Pass 2
    // entry. This shaves the legacy "walk every typer-observed
    // instance" path so out-of-scope instances (TypeParam-only,
    // stdlib-owned) get filtered earlier.
    //
    // TODO: full migration to read `entry.subst` / `entry.mangled` /
    // `entry.symbol` directly — currently the legacy helpers re-derive
    // these via `build_struct_subst` + `args_suffix`, duplicating the
    // mono work. Blocked on the double-prefix fn-instance mangled-name
    // alignment ; tracked separately.
    // Representatives must follow every concrete-args struct in the
    // dump : the two-pass collects instances first, then emits any-args
    // representatives at the tail. A single interleaved pass would
    // place the first representative ahead of subsequent instances of
    // the same generic shape.
    pending_reps: GenericInstance[] = []
    for inst in project_ctx.evaluated.instances {
        if !mono_has_struct_entry_for(project_ctx, inst) { continue }
        materialize_one_instance(inst, loaded, typed, project_ctx, project, diags)
        pending_reps.push(inst)
    }
    for inst in pending_reps {
        materialize_representative(inst, loaded, typed, project_ctx, project, seen_reps)
    }
}

/// Emit the second-mono "any-args" representative struct decl for a
/// concrete generic instance. The representative shares the first
/// instance's body shape (every field already erased to `Any`) but
/// carries a distinct mangled name derived from the first.mangled
/// minus its last `__<seg>` suffix plus the any-leaves args. Mirrors
/// `src/comptime/erasure-dedupe.ts:217-257`'s extraStructEntries
/// emission. Deduped on the representative mangle so two concrete
/// instantiations of the same generic shape only emit one.
materialize_representative :: fn(
    inst: GenericInstance, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    seen_reps: MutableSet(string),
) -> void {
    if !all_concrete_args(inst.args) { return }
    sym :: inst.symbol
    if i32(sym.kind) != i32(SymbolKind.Struct) { return }
    owner_module_id :: sym.module
    if is_stdlib_path(owner_module_id) { return }
    owner_module :: loaded.modules[owner_module_id]
    if owner_module is null { return }
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return }
    if owner_typed is TypedProgram as owner_typed_ok {
        if owner_module is LoadedModule as owner_loaded {
            owner_decls :: module_decls(owner_loaded)
            decl :: find_struct_decl_by_name(owner_decls, sym.name)
            if decl is null { return }
            if decl is StructDecl as sd {
                if sd.type_params.len() == usize(0) { return }
                first_mangled :: "${mangle_module_id(owner_typed_ok.resolved.display_path)}$${sym.name}${args_suffix(inst.args)}"
                stripped :: strip_last_suffix(first_mangled)
                any_args :: build_any_args_list(inst.args)
                rep_mangled :: "${stripped}__${join_any_displays(any_args)}"
                if seen_reps.contains(rep_mangled) { return }
                seen_reps.add(rep_mangled)
                erase :: build_any_subst(sd, owner_typed_ok)
                fields: LoweredStructField[] = []
                for f in sd.fields {
                    raw_ty :: resolve_field_type(f.ty, owner_typed_ok, sd, inst.args)
                    fields.push(LoweredStructField {
                        .name = f.name,
                        .type = substitute(raw_ty, erase),
                    })
                }
                entry_decl: Decl = sd
                entry :: MonoEntry {
                    .id             = i32(0),
                    .is_main        = false,
                    .mangled        = rep_mangled,
                    .decl           = entry_decl,
                    .symbol         = sym,
                    .subst          = erase,
                    .type_arguments = any_args,
                    .module         = owner_typed_ok,
                }
                push_to_module(project, owner_typed_ok.resolved.path, LoweredStructDecl {
                    .mangled = rep_mangled,
                    .fields  = fields,
                    .origin  = entry,
                })
            }
        }
    }
}

/// Replace every concrete leaf in a `Type` tree with `Any` while
/// preserving generic wrappers (Struct / Trait / Array / Union /
/// Tuple). Mirror of `anyLeavesOf` in
/// `src/comptime/erasure-dedupe.ts:86-100`.
any_leaves_of :: fn(t: Type) -> Type {
    if t is StructType as s {
        if s.args.is_empty() { return TY_ANY }
        new_args: Type[] = []
        for a in s.args { new_args.push(any_leaves_of(a)) }
        return mk_struct(s.symbol, new_args)
    }
    if t is TraitType as tt {
        if tt.args.is_empty() { return TY_ANY }
        new_args: Type[] = []
        for a in tt.args { new_args.push(any_leaves_of(a)) }
        return mk_trait(tt.symbol, new_args)
    }
    if t is ArrayType as a {
        return mk_array(any_leaves_of(a.element), a.immutable)
    }
    if t is UnionType as u {
        new_vars: Type[] = []
        for v in u.variants { new_vars.push(any_leaves_of(v)) }
        return mk_union(new_vars)
    }
    if t is TupleType as tu {
        new_elems: Type[] = []
        for el in tu.elements { new_elems.push(any_leaves_of(el)) }
        return mk_tuple(new_elems)
    }
    return TY_ANY
}

/// Short stable display used when synthesising the representative's
/// mangled name. Mirrors `displayAnyArg` in
/// `src/comptime/erasure-dedupe.ts:105-121`.
display_any_arg :: fn(t: Type) -> string = match t {
    is StructType as s -> if s.args.is_empty() { s.symbol.name } else { joined_named(s.symbol.name, s.args, "_") }
    is TraitType  as t -> if t.args.is_empty() { t.symbol.name } else { joined_named(t.symbol.name, t.args, "_") }
    is ArrayType  as a -> "${display_any_arg(a.element)}_arr"
    is UnionType  as u -> joined_unnamed(u.variants, "__")
    is TupleType  as t -> joined_named("Tup", t.elements, "_")
    _                  -> "Any"
}

joined_named :: fn(name: string, args: Type[], sep: string) -> string {
    sb :: new_builder()
    sb.append(name)
    for a in args {
        sb.append(sep)
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

joined_unnamed :: fn(args: Type[], sep: string) -> string {
    sb :: new_builder()
    first := true
    for a in args {
        if !first { sb.append(sep) }
        first = false
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

build_any_args_list :: fn(args: Type[]) -> Type[] {
    out: Type[] = []
    for a in args { out.push(any_leaves_of(a)) }
    return out
}

join_any_displays :: fn(args: Type[]) -> string {
    sb :: new_builder()
    first := true
    for a in args {
        if !first { sb.append("__") }
        first = false
        sb.append(display_any_arg(a))
    }
    return "${sb}"
}

/// Strip the last `__<seg>(_\d+)?` from `s`. Used by the second-mono
/// representative mangle to drop the final concrete arg before
/// appending the any-args suffix. Mirrors the JS regex
/// `/__[^_]+(_\d+)?$/` (which matches `__<seg>` with optional trailing
/// `_N` disambiguator from `uniq`).
strip_last_suffix :: fn(s: string) -> string {
    n :: s.byte_len()
    if n < usize(3) { return s }
    // Walk backward looking for `__`. Stop at the last one that's not
    // immediately followed by another `__` (i.e. it's a real arg
    // delimiter, not part of a chained empty arg).
    i := i64(n) - 2
    for i >= 0 {
        if s.byte_at(usize(i)) == 0x5F_u8 {
            if s.byte_at(usize(i + 1)) == 0x5F_u8 {
                // Found `__` ; strip from here.
                return s.byte_slice(usize(0), usize(i))
            }
        }
        i = i - 1
    }
    return s
}

import "vader/types" { mk_trait, mk_array, mk_union, mk_tuple }
import "std/string_builder" { append_char as sb_append_char }

/// True when `evaluated.mono` carries a StructDecl-kind MonoEntry
/// whose `symbol.id` matches `inst.symbol.id` and whose
/// `type_arguments` is non-empty. Lets `materialize_generic_instances`
/// skip instances that the mono pass already rejected (TypeParam-only,
/// stdlib-only, etc.) without re-deriving the filter logic.
mono_has_struct_entry_for :: fn(project_ctx: LowerProjectCtx, inst: GenericInstance) -> bool {
    if i32(inst.symbol.kind) != i32(SymbolKind.Struct) { return false }
    entries :: project_ctx.evaluated.mono.entries
    i: usize = 0
    for i < entries.len() {
        entry :: entries[i]
        if entry.type_arguments.len() == usize(0) {
            i += 1
            continue
        }
        match entry.symbol {
            is Symbol as s -> {
                if s.id == inst.symbol.id { return true }
            }
            _ -> {}
        }
        i += 1
    }
    return false
}

materialize_one_instance :: fn(
    inst: GenericInstance, loaded: LoadedProject, typed: TypedProject,
    project_ctx: LowerProjectCtx, project: LoweredProject, diags: Diagnostic[],
) -> void {
    // Only concrete instances get a monomorphized decl. Skip uses where
    // any arg is still a TypeParam (those are the generic decl's own
    // body referencing itself).
    if !all_concrete_args(inst.args) { return }
    sym :: inst.symbol
    owner_module_id :: sym.module
    if is_stdlib_path(owner_module_id) { return }
    owner_module :: loaded.modules[owner_module_id]
    if owner_module is null { return }
    owner_typed :: typed.modules[owner_module_id]
    if owner_typed is null { return }
    if owner_typed is TypedProgram as owner_typed_ok {
        if owner_module is LoadedModule as owner_loaded {
            owner_decls :: module_decls(owner_loaded)
            // (1) Find the StructDecl for this instance ; emit a
            // monomorphized struct decl.
            if i32(sym.kind) == i32(SymbolKind.Struct) {
                materialize_struct_instance(inst, owner_decls, owner_typed_ok, project_ctx, project)
                // (2) For every generic impl whose for_type targets the
                // same struct symbol, materialize each member.
                materialize_impl_members_for(inst, owner_decls, owner_typed_ok, project_ctx, project, loaded, typed, diags)
            }
        }
    }
}

all_concrete_args :: fn(args: Type[]) -> bool {
    for a in args {
        if has_type_param(a) { return false }
    }
    return true
}

has_type_param :: fn(t: Type) -> bool {
    match t {
        is TypeParamType -> { return true }
        is StructType as s -> {
            for a in s.args { if has_type_param(a) { return true } }
            return false
        }
        is ArrayType as ar -> { return has_type_param(ar.element) }
        _ -> { return false }
    }
}

materialize_struct_instance :: fn(
    inst: GenericInstance, owner_decls: Decl[], owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
) -> void {
    decl :: find_struct_decl_by_name(owner_decls, inst.symbol.name)
    if decl is null { return }
    if decl is StructDecl as sd {
        if sd.type_params.len() == usize(0) { return }
        mangled :: "${mangle_module_id(owner_typed.resolved.display_path)}$${inst.symbol.name}${args_suffix(inst.args)}"
        // Erasure : the entry's `subst` keeps the concrete args (for
        // mangling + downstream consumers that need the source-level
        // type-args), but the FIELDS get the anySubst applied so every
        // TypeParam mention lands on `Any`. Identical monos can then
        // collapse to a single C-emit shape. Mirror of TS `anySubst`
        // in `src/comptime/specialize.ts:45-54`.
        subst :: build_struct_subst(sd, inst.args, owner_typed)
        erase :: build_any_subst(sd, owner_typed)
        fields: LoweredStructField[] = []
        for f in sd.fields {
            raw_ty :: resolve_field_type(f.ty, owner_typed, sd, inst.args)
            field_ty :: substitute(raw_ty, erase)
            fields.push(LoweredStructField {
                .name = f.name,
                .type = field_ty,
            })
        }
        entry_decl: Decl = sd
        entry :: MonoEntry {
            .id             = i32(0),
            .is_main        = false,
            .mangled        = mangled,
            .decl           = entry_decl,
            .symbol         = inst.symbol,
            .subst          = subst,
            .type_arguments = inst.args,
            .module         = owner_typed,
        }
        push_to_module(project, owner_typed.resolved.path, LoweredStructDecl {
            .mangled = mangled,
            .fields  = fields,
            .origin  = entry,
        })
    }
}

/// Build a substitution mapping every type-parameter of `sd` to
/// `TY_ANY`. Used by the erasure pass to drop type info from
/// monomorphized struct field types so identical monos share a single
/// C-emit shape. Mirror of `anySubst` in `src/comptime/specialize.ts:45`.
build_any_subst :: fn(sd: StructDecl, owner_typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for tp in sd.type_params {
        tp_symbol :: find_type_param_in_resolved(owner_typed.resolved, tp.name, tp.span)
        if !(tp_symbol is null) {
            subst.type_params[tp_symbol.id] = TY_ANY
        }
    }
    return subst
}

import "vader/types" { TY_ANY }

resolve_field_type :: fn(
    ty: TypeExpr, owner_typed: TypedProgram, sd: StructDecl, args: Type[],
) -> Type {
    // Prefer the typer's recorded type ; fall back to `type_from_expr`
    // resolving fresh against the struct's typeParam-shadowed scope.
    raw :: owner_typed.type_expr_types[span_key(ty.span)]
    if !(raw is null) {
        // `raw is Type as t` would always be false — `Type` is the union
        // alias and the runtime tag carries the concrete variant, not the
        // alias. After the null check, `raw` already narrows to `Type`.
        if !(raw is UnresolvedType) { return raw }
    }
    scratch: Diagnostic[] = []
    return type_from_expr(ty, owner_typed.resolved, scratch)
}

materialize_impl_members_for :: fn(
    inst: GenericInstance, owner_decls: Decl[], owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
    loaded: LoadedProject, typed: TypedProject, diags: Diagnostic[],
) -> void {
    // Walk every module's impls (impls can be in foreign modules) and
    // emit a synth fn for each matching impl member.
    for module_id in typed.modules.keys() {
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        if module_typed is TypedProgram as mt {
            module_loaded :: loaded.modules[module_id]
            if module_loaded is null { continue }
            if module_loaded is LoadedModule as ml {
                for d in module_decls(ml) {
                    match d {
                        is ImplDecl as impl_decl -> {
                            if !is_generic_impl_for(impl_decl, inst.symbol.name) { continue }
                            materialize_impl_for_instance(
                                impl_decl, inst, mt, owner_typed, project_ctx, project,
                            )
                        }
                        _ -> {}
                    }
                }
            }
        }
    }
}

is_generic_impl_for :: fn(impl_decl: ImplDecl, struct_name: string) -> bool {
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            match gi.callee {
                is IdentExpr as id -> { return id.name == struct_name }
                _ -> { return false }
            }
        }
        _ -> { return false }
    }
}

materialize_impl_for_instance :: fn(
    impl_decl: ImplDecl, inst: GenericInstance,
    impl_typed: TypedProgram, owner_typed: TypedProgram,
    project_ctx: LowerProjectCtx, project: LoweredProject,
) -> void {
    // Erasure : self type uses any-leaves args (Stack(Any) instead of
    // Stack(i32)) and the substitution carried into params / body maps
    // T → Any. Concrete monos that share the same impl shape post-
    // erasure can then collapse to a single C-emit body. Mangled name
    // keeps the concrete args suffix (`__i32`) so identity tags stay
    // distinct.
    erased_args: Type[] = []
    for a in inst.args { erased_args.push(any_leaves_of(a)) }
    self_struct :: StructType { .symbol = inst.symbol, .args = erased_args }
    self_type: Type = self_struct
    suffix :: args_suffix(inst.args)
    subst :: build_impl_any_subst(impl_decl, impl_typed)
    types :: make_entry_types(impl_typed, subst)
    impl_key_prefix :: span_key(impl_decl.span)
    for member in impl_decl.members {
        // Erasure dedupe : every concrete-args instance of the same
        // (impl_decl, member) collapses to one emission. The first
        // instance wins ; the call sites land on the survivor via the
        // trait virtual-dispatch in bytecode emit.
        dedupe_key :: "${impl_key_prefix}::${member.name}"
        if project_ctx.materialized_impl_keys.contains(dedupe_key) { continue }
        project_ctx.materialized_impl_keys.add(dedupe_key)
        params :: build_impl_member_params(member, self_type, types, impl_typed, project_ctx)
        return_type :: return_type_of(member, types)
        mangled :: "${mangle_module_id(owner_typed.resolved.display_path)}$${inst.symbol.name}$${impl_decl.trait_name}$${member.name}${suffix}"
        entry_decl: Decl = member
        entry :: MonoEntry {
            .id             = i32(0),
            .is_main        = false,
            .mangled        = mangled,
            .decl           = entry_decl,
            .symbol         = null,
            .subst          = subst,
            .type_arguments = inst.args,
            .module         = impl_typed,
        }
        body :: lower_fn_body(member, impl_typed, project_ctx, entry, subst, return_type)
        push_to_module(project, owner_typed.resolved.path, LoweredFnDecl {
            .mangled     = mangled,
            .params      = params,
            .return_type = return_type,
            .body        = body,
            .origin      = entry,
        })
    }
}

build_struct_subst :: fn(decl: StructDecl, args: Type[], typed: TypedProgram) -> Substitution {
    subst :: new_substitution()
    for i in 0..<decl.type_params.len() {
        if i >= args.len() { break }
        tp_name :: decl.type_params[i].name
        tp_span :: decl.type_params[i].span
        bound :: find_type_param_in_resolved(typed.resolved, tp_name, tp_span)
        match bound {
            is null -> {}
            is Symbol as s -> { subst.type_params[s.id] = args[i] }
        }
    }
    return subst
}

find_type_param_in_resolved :: fn(resolved: ResolvedModule, name: string, def_span: Span) -> Symbol | null {
    target_key :: span_key(def_span)
    // Use-site lookup : every use of `T` inside the struct's fields /
    // impl body lands in `idents` ; the value's `defined_at` points
    // back at the TypeParam's source span.
    for s in resolved.idents.values() {
        if s.name != name { continue }
        if i32(s.kind) != i32(SymbolKind.TypeParam) { continue }
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if span_key(def) == target_key { return s }
            }
        }
    }
    // Fallback : name-only match (no use-site exists, e.g. a generic
    // decl never instantiated in this very module).
    for s in resolved.idents.values() {
        if s.name == name && i32(s.kind) == i32(SymbolKind.TypeParam) { return s }
    }
    return null
}

build_impl_subst :: fn(
    impl_decl: ImplDecl, args: Type[],
    impl_typed: TypedProgram, owner_typed: TypedProgram,
) -> Substitution {
    subst :: new_substitution()
    // Bounded form (impl-own typeParams) : substitute against impl's
    // typeParams. The legacy `Foo[T] implements ...` form is handled
    // by walking through the impl-side resolved symbols (the resolver
    // hoists struct typeParam names into the impl's scope).
    if impl_decl.type_params.len() > usize(0) {
        for i in 0..<impl_decl.type_params.len() {
            if i >= args.len() { break }
            tp_sym :: lookup_type_param_symbol(impl_typed.resolved, impl_decl.type_params[i].span)
            if tp_sym is null { continue }
            if tp_sym is Symbol as s { subst.type_params[s.id] = args[i] }
        }
        return subst
    }
    // Legacy form : the struct's typeParams are referenced by name in
    // the impl body. Bind by name against the impl module's symbols.
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            for i in 0..<gi.type_args.len() {
                if i >= args.len() { break }
                tp_name :: type_expr_simple_name(gi.type_args[i])
                if tp_name == "" { continue }
                for s in impl_typed.resolved.symbols {
                    if s.name == tp_name && i32(s.kind) == i32(SymbolKind.TypeParam) {
                        subst.type_params[s.id] = args[i]
                        break
                    }
                }
            }
        }
        _ -> {}
    }
    return subst
}

/// Erasure variant of `build_impl_subst` — every type-parameter
/// reachable from the impl maps to `TY_ANY` instead of the concrete
/// instance args. Used during `materialize_impl_for_instance` so
/// impl-member params / return types collapse to the deduped shape
/// (`value: Any` instead of `value: T` or `value: i32`), letting
/// distinct concrete monos share a single C-emit body.
///
/// Maps by name across every TypeParam symbol the impl module
/// exposes. The legacy `Stack[T] implements ...` form hoists the
/// struct's `T` into the impl's scope without giving it a fresh
/// symbol id ; matching by `(name, kind=TypeParam)` catches it
/// regardless of whose `defined_at` the use sites carry.
build_impl_any_subst :: fn(
    impl_decl: ImplDecl, impl_typed: TypedProgram,
) -> Substitution {
    subst :: new_substitution()
    names :: collect_impl_type_param_names(impl_decl)
    map_type_params_by_name(subst, impl_typed.resolved.symbols, names)
    map_type_params_by_name(subst, impl_typed.resolved.idents.values(), names)
    return subst
}

collect_impl_type_param_names :: fn(impl_decl: ImplDecl) -> string[] {
    names: string[] = []
    for tp in impl_decl.type_params { names.push(tp.name) }
    match impl_decl.for_type {
        is GenericInstExpr as gi -> {
            for ta in gi.type_args {
                tp_name :: type_expr_simple_name(ta)
                if tp_name != "" { names.push(tp_name) }
            }
        }
        _ -> {}
    }
    return names
}

map_type_params_by_name :: fn(subst: Substitution, scope: Symbol[], names: string[]) -> void {
    for s in scope {
        if i32(s.kind) != i32(SymbolKind.TypeParam) { continue }
        for nm in names {
            if s.name == nm {
                subst.type_params[s.id] = TY_ANY
                break
            }
        }
    }
}

type_expr_simple_name :: fn(e: TypeExpr) -> string {
    match e {
        is IdentExpr as id -> { return id.name }
        _ -> { return "" }
    }
}

find_struct_decl_by_name :: fn(decls: Decl[], name: string) -> StructDecl | null {
    for d in decls {
        match d {
            is StructDecl as sd -> { if sd.name == name { return sd } }
            _ -> {}
        }
    }
    return null
}

lookup_type_param_symbol :: fn(resolved: ResolvedModule, name_span: Span) -> Symbol | null {
    target_key :: span_key(name_span)
    for s in resolved.symbols {
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if span_key(def) == target_key { return s }
            }
        }
    }
    for s in resolved.idents.values() {
        match s.defined_at {
            is null -> {}
            is Span as def -> {
                if span_key(def) == target_key { return s }
            }
        }
    }
    return null
}

args_suffix :: fn(args: Type[]) -> string {
    sb := new_builder()
    for a in args {
        sb.append("__")
        sb.append(type_surface_for_mangle(a))
    }
    return sb.to_string()
}

type_surface_for_mangle :: fn(t: Type) -> string {
    match t {
        is PrimitiveType as p -> { return p.name }
        is StructType    as s -> { return s.symbol.name }
        is EnumType      as e -> { return e.symbol.name }
        _ -> { return "T" }
    }
}

push_to_module :: fn(project: LoweredProject, module_id: string, decl: LoweredDecl) -> void {
    m :: project.modules[module_id]
    if m is null { return }
    if m is LoweredModule as mod {
        mod.decls.push(decl)
    }
}

import "vader/comptime" { GenericInstance }
import "vader/types" { EnumType, PrimitiveType }
import "vader/resolver" { ResolvedModule }
import "vader/comptime" { symbol_for_decl }

module_decls :: fn(module_loaded: LoadedModule) -> Decl[] {
    if module_loaded.module.files.len() == usize(0) { return [] }
    out: Decl[] = []
    for source_file in module_loaded.module.files {
        for decl in source_file.program.decls {
            out.push(decl)
        }
    }
    return out
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }
import "vader/typecheck" { new_typed_project }
import "vader/comptime" { new_evaluated_project }

@test test_lower_empty_project :: fn() -> void {
    loaded :: LoadedProject {
        .entry        = "",
        .modules      = MutableMap(string, LoadedModule) { .buckets = [], .size = 0 },
        .factory      = factory_for_test(),
        .project_root = null,
        .diags        = [],
    }
    typed :: new_typed_project()
    evaluated :: new_evaluated_project(typed)
    diags: Diagnostic[] = []
    project :: lower_project(loaded, typed, evaluated, diags)
    assert_eq(project.modules.size, usize(0))
}

import "vader/resolver/symbol" { new_factory, SymbolFactory }
factory_for_test :: fn() -> SymbolFactory { return new_factory() }
