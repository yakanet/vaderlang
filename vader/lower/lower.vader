// vader/lower/lower — project-level lowerer orchestrator.
//
// Mirror of `src/lower/lower.ts::lowerProject`. Walks every top-level
// decl across the project's typed modules, builds a stub `MonoEntry`
// per non-generic decl, and dispatches to the per-decl-kind lowerer.
//
// The orchestrator takes `LoadedProject` (for source decls) +
// `TypedProject` (for typed side-tables) + `EvaluatedProject` (for
// comptime values + mono entries). The heavy lifting lives in sibling
// files of this same `vader/lower` module : table population
// (lower_populate), per-decl lowering (lower_decl), generic instance
// materialization (lower_mono), substitutions & mangling (lower_subst),
// stdlib/intrinsic extern surfacing (lower_stdlib), the DCE reference
// walker (lower_ref), and vtable / output assembly (lower_finish).

module "vader/lower"

import "std/collections" { MutableMap, keys }
import "std/sort" { sort }
import "std/string_builder" { append }

import "vader/diagnostics" { Diagnostic }
import "vader/parser" { Decl, FnDecl, StructDecl, ConstDecl, ImplDecl }
import "vader/resolver" { LoadedProject, LoadedModule }
import "vader/typecheck" { TypedProject, TypedProgram }
import "vader/comptime" { EvaluatedProject, ComptimeValue }
import "vader/resolver/symbol" { Symbol }

/// Lower every module's top-level decls into a `LoweredProject`.
/// @param loaded     the loaded project (for source decls per module).
/// @param typed      the typed project (for side-tables).
/// @param evaluated  the comptime engine's output.
/// @param diags      diagnostics emitted by the lowerer (L5xxx codes).
/// @return           the lowered project ready for downstream phases.
export lower_project :: fn(
    loaded: LoadedProject, typed: TypedProject, evaluated: EvaluatedProject, diags: Diagnostic[],
) -> LoweredProject {
    project_ctx :: new_lower_project_ctx(evaluated, loaded, typed)
    // Closure analysis runs once at entry — every lambda's capture set
    // is precomputed so per-decl lowering can read it without re-
    // walking the AST.
    project_ctx.closures = analyze_closures(loaded, typed)
    // Populate `core_symbols` from each module's `resolved.core_symbols`
    // table (auto-imported std/core exports). Lookups like
    // `find_core_type("Yield", [T])` go through this cache.
    populate_core_symbols(typed, project_ctx)
    // Build the global symbol_id -> ComptimeValue index so per-ident
    // const-baked lookups (`lookup_const_baked_value`) hit O(1) instead
    // of walking every loaded module's `comptime_decls` map per call.
    populate_comptime_value_index(project_ctx)
    // Build the project-wide impl registry — aggregate every module's
    // `T implements Trait { … }` decls so downstream phases can query
    // by `(for_type, trait_name)`. Unblocks Display dispatch for
    // string interp, try for non-primitive Error variants, and the
    // for-in / Iterator step loop.
    populate_impls(loaded, typed, project_ctx)
    project :: new_lowered_project()

    module_ids :: typed.modules.keys()
    for module_id in module_ids {
        // Stdlib modules: don't lower with-body fns up front (would bloat
        // the project + pollute the synthetic-id counter), but DO surface
        // every bodyless fn signature (`@extern` / intrinsic / declared-
        // only) so the bytecode emitter registers them in the import
        // table. Without this, calls to `byte_len` / `println` / … fall
        // through `emit_call_to_symbol` without hitting the CallImport
        // branch and silently drop. The now-wired whole-program DCE
        // (`prune_unreachable_fns`) culls anything the user never reaches,
        // so over-surfacing is safe.
        // The skip is for IMPORTED stdlib modules. When a stdlib module is the
        // ENTRY (e.g. `vader test stdlib/std/base64` or running a stdlib file
        // directly), it's the code under test — lower it in full (with bodies)
        // so its `@test` fns / `main` survive. Entry is never stdlib in the
        // normal self-compile, so the fixed point is unaffected.
        if is_stdlib_path(module_id) && module_id != loaded.entry {
            stdlib_loaded :: loaded.modules[module_id]
            stdlib_typed_opt :: typed.modules[module_id]
            stdlib_decls: LoweredDecl[] = []
            if stdlib_loaded is LoadedModule as sl {
                if stdlib_typed_opt is TypedProgram as stdlib_typed {
                    for d in module_decls(sl) {
                        if d is FnDecl as fd {
                            if fd.body is null && fd.type_params.len() == 0 {
                                lowered :: lower_fn_decl(fd, stdlib_typed, project_ctx, diags)
                                if lowered != null {
                                    stdlib_decls.push(lowered)
                                    // Pre-seed the call-site harvest's seen-set so
                                    // `materialize_nongeneric_stdlib_fns` doesn't
                                    // emit a duplicate decl for the same symbol.
                                    sym :: sl.collected.symbols[fd.name]
                                    if sym is Symbol as s {
                                        project_ctx.nongeneric_stdlib_fns[s.id] = true
                                    }
                                }
                            }
                        }
                    }
                }
                project.modules[module_id] = LoweredModule {
                    .module_id    = module_id,
                    .display_path = sl.module.display_path,
                    .decls        = stdlib_decls,
                }
            }
            continue
        }
        module_typed :: typed.modules[module_id]
        if module_typed is null { continue }
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        decls :: module_decls(module_loaded)
        display_path :: module_loaded.module.display_path
        // Entry IS a stdlib module (`vader test stdlib/std/numbers`, running a
        // stdlib file) : `lower_module` lowers its fns WITH bodies (lifting any
        // lambdas). Seed the call-site-harvest seen-set BEFORE that walk so a
        // call to one of these fns (e.g. `test_x` → `strip_numeric_text`) does
        // NOT also queue it into `nongeneric_stdlib_order` — a second lowering by
        // `materialize_nongeneric_stdlib_fns` re-lifts its lambdas under FRESH
        // ids, so the emitted make-closure (id from one copy) misses the
        // surviving decl (the other copy) at emit → make-closure GATE-B1 panic.
        // The imported-stdlib branch above already seeds its bodyless fns ; this
        // is its with-body, entry analogue.
        if is_stdlib_path(module_id) {
            for d in decls {
                if d is FnDecl as fd {
                    if fd.type_params.len() == 0 {
                        sym :: module_loaded.collected.symbols[fd.name]
                        if sym is Symbol as s { project_ctx.nongeneric_stdlib_fns[s.id] = true }
                    }
                }
            }
        }
        lowered_module :: lower_module(module_id, display_path, module_typed, decls, project_ctx, diags)
        project.modules[module_id] = lowered_module
    }
    // After per-module lowering, materialise generic-struct instances +
    // their matching generic-impl members. Each `evaluated.instances`
    // entry yields a `StructDecl<Concrete>` + per-impl `__T` member fns.
    rep_seen :: materialize_concrete_struct_instances(loaded, typed, project_ctx, project, diags)
    // Generic-fn instances + non-generic stdlib free fns are MUTUALLY
    // recursive : a generic instance body calls stdlib fns (harvested into
    // `nongeneric_stdlib_order`), and a harvested stdlib body calls generic
    // fns (registered into `fn_instances_order` — e.g. `std/json::write_object`
    // → `MutableMap.len`). Drain all the queues in ONE joint fixpoint until
    // none grows : each pass resumes from its own persistent cursor, so
    // re-entry only processes newly-registered work (`drain_generic_fn_instances`
    // builds into `generic_collected` ; `materialize_nongeneric_stdlib_fns`
    // resumes from `nongeneric_stdlib_cursor` ; `surface_*` dedupes via
    // `materialized_impl_keys`). A pre-fixpoint single generic pass would
    // strand any instance a later stdlib-harvest round registers (the
    // `len__...` GATE-B1 unresolved-callee bug). The generic instances are
    // FLUSHED (sorted + erasure-deduped + pushed) once after convergence so
    // emission order is a single deterministic sort.
    // All four queues are append-only (the three arrays) / add-only (the mangle
    // set), so their combined length strictly increases until the joint fixpoint
    // settles — loop until the total stops growing.
    prev_total: usize = 0
    draining := true
    for draining {
        drain_generic_fn_instances(loaded, typed, project_ctx, project, diags)
        materialize_nongeneric_stdlib_fns(loaded, typed, project_ctx, project, diags)
        surface_referenced_intrinsic_externs(loaded, typed, project_ctx, project)
        cur_total :: project_ctx.fn_instances_order.len() +
            project_ctx.pending_generic_impl_recv.len() +
            project_ctx.nongeneric_stdlib_order.len() +
            project_ctx.referenced_impl_mangles.inner.size +
            project_ctx.virtually_dispatched_traits.inner.size +
            project_ctx.constructed_struct_symbols.inner.size
        if cur_total == prev_total { draining = false } else { prev_total = cur_total }
    }
    // INVARIANT : anything that can register a generic fn instance or harvest a
    // non-generic stdlib fn MUST run inside the loop above — the flush is
    // one-shot, so a post-flush registration is stranded (the bug this closes).
    // `materialize_representatives` / `close_over_field_shapes` below only push
    // struct decls (no body lowering), so they register nothing — keep it that way.
    flush_generic_fn_instances(project_ctx, project)
    // Representative "any-args" structs come AFTER fn instances —
    // matches TS' emission order so generic_brackets etc. byte-match.
    materialize_representatives(loaded, typed, project_ctx, project, rep_seen)
    // Transitively materialise generic-struct shapes referenced by the
    // fields of the structs emitted above (concrete + representative),
    // e.g. `MutableSet(i32)`'s erased `inner: MutableMap(Any, bool)` —
    // otherwise the bytecode interner mints an orphan `ref` for them.
    close_over_field_shapes(loaded, typed, project_ctx, project)
    // Drain per-fn lower diagnostics pushed to `project_ctx.diags`
    // (e.g. M5001 from `lower_for_in`) into the caller-owned sink so
    // they reach `# Diagnostics` in the CLI dump.
    for d in project_ctx.diags { diags.push(d) }
    // Collect vtable entries from impl members. Mirrors TS's
    // `collectVtableEntries`. Without this, `BcModule.impl_table` is
    // always empty and `impl TYPE_ID TRAIT_NAME` directives never land
    // in the .virt — the runtime falls back to mangle-keyed dispatch
    // but the parity dump diverges.
    project.vtable_entries = collect_vtable_entries(project, loaded, typed)
    // Route non-scalar const decls to their read sites : bulky array consts
    // become synthetic `__const_<name>` accessor fns (resolved by a `call` in
    // `build_ident`), every other const is recorded for inline rebuild. Runs
    // last so it sees every materialised decl. See `inline_consts.vader`.
    inline_consts(project)
    return project
}

// Per-module driver. Walks the decl list, dispatches by kind, and
// builds the resulting `LoweredModule`. Lambda-lifted synth decls
// accumulated on `project_ctx.synth_decls` during the walk get drained
// into this module's `decls` list — they were spawned while lowering
// this module's bodies, so they ship alongside the regular decls.
lower_module :: fn(
    module_id: string, display_path: string, typed: TypedProgram, decls: Decl[],
    project_ctx: LowerProjectCtx, diags: Diagnostic[],
) -> LoweredModule {
    out_decls: LoweredDecl[] = []
    // First pass : every regular decl in source order. Impl members
    // surface as a multi-decl list right after their ImplDecl so the
    // dump's per-struct grouping matches TS source-order.
    synth_start :: project_ctx.synth_decls.len()
    for decl in decls {
        results :: lower_decl_list(decl, typed, project_ctx, diags, decls)
        for r in results { out_decls.push(r) }
    }
    // Second pass : drain the lambda-lift synth decls accumulated while
    // walking this module's bodies (lambdas / defers route through
    // `synth_decls`). Matches TS `lower.ts:74-78`.
    synth_end :: project_ctx.synth_decls.len()
    for i in synth_start..<synth_end {
        out_decls.push(project_ctx.synth_decls[i])
    }
    return LoweredModule {
        .module_id    = module_id,
        .display_path = display_path,
        .decls        = out_decls,
    }
}

/// Per-decl dispatcher returning every LoweredDecl this source decl
/// expands to. Most decls yield 0 or 1 ; ImplDecl yields one entry
/// per member so impl methods land inline (right after the impl) in
/// the dump.
lower_decl_list :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx,
    diags: Diagnostic[], module_decls: Decl[],
) -> LoweredDecl[] {
    if decl is ImplDecl as impl_decl {
        return lower_impl_member_list(impl_decl, typed, project_ctx, diags, module_decls)
    }
    out: LoweredDecl[] = []
    result :: lower_decl(decl, typed, project_ctx, diags, module_decls)
    if !(result is null) { out.push(result) }
    return out
}

// Per-decl dispatcher. Routes FnDecl / StructDecl / ConstDecl through
// the matching phase-2 stub ; ImplDecl drains into per-member fn-decl
// entries appended to `project_ctx.synth_decls` so the module driver
// picks them up alongside the regular decls. Every other decl kind
// (Enum, Trait, TypeAlias, Import, Assert) returns null — they don't
// produce runtime slots.
lower_decl :: fn(
    decl: Decl, typed: TypedProgram, project_ctx: LowerProjectCtx, diags: Diagnostic[],
    module_decls: Decl[],
) -> LoweredDecl | null {
    match decl {
        is FnDecl     as fn_decl     -> { return lower_fn_decl(fn_decl, typed, project_ctx, diags) }
        is StructDecl as struct_decl -> { return lower_struct_decl(struct_decl, typed, project_ctx, diags) }
        is ConstDecl  as const_decl  -> { return lower_const_decl(const_decl, typed, project_ctx, diags) }
        is ImplDecl   as impl_decl   -> {
            lower_impl_members(impl_decl, typed, project_ctx, diags, module_decls)
            return null
        }
        _ -> { return null }
    }
}


module_decls :: fn(module_loaded: LoadedModule) -> Decl[] {
    files :: module_loaded.module.files
    if files.len() == 0 { return [] }
    // Single-file module (the common case) : return the file's decls directly,
    // no concat allocation — mirrors `comptime/check.vader::lookup_module_decls`.
    // Hot : `call_site_fn_flavor` reaches through here per generic call site.
    if files.len() == 1 { return files[0].program.decls }
    out: Decl[] = []
    for source_file in files {
        for decl in source_file.program.decls {
            out.push(decl)
        }
    }
    return out
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }

import "vader/typecheck" { new_typed_project }
import "vader/comptime" { new_evaluated_project }
import "vader/resolver/symbol" { new_factory, SymbolFactory }

@test test_lower_empty_project :: fn() -> void {
    loaded :: LoadedProject {
        .entry        = "",
        .modules      = MutableMap<string, LoadedModule> {},
        .factory      = factory_for_test(),
        .project_root = null,
        .diags        = [],
    }
    typed :: new_typed_project()
    evaluated :: new_evaluated_project(typed)
    diags: Diagnostic[] = []
    project :: lower_project(loaded, typed, evaluated, diags)
    assert_eq(project.modules.size, usize(0))
}

factory_for_test :: fn() -> SymbolFactory { return new_factory() }
