// vader/lower/lower_string_lit — string + interpolation lowering, with Display coercion.
//
// A text-only string literal becomes a single `LoweredStringLit`. A literal with
// any `${expr}` segment lowers to ONE right-sized byte buffer (`lower_interp_buffer`)
// when some part is a directly-writable primitive (int / uint / bool) — each
// writes its bytes straight in, no throwaway interned string per part. A purely
// text + `${string}` / `${Display}` interpolation has no digit to format, so it
// stays on the leaner all-string concat path (`concat_from_collected` →
// `lower_concat_chain` → the shared `concat_N`, same shape as `+`). Interpolated
// `${Display}` values render via `build_display_to_string_call` (handles
// primitives, structs, and FreeFloat→f64 pinning). The buffer primitives live in
// the force-loaded `std/core` prelude, so resolution always succeeds.

module "vader/lower"

import "std/collections" { MutableMap }
import "std/abort"

import "vader/parser" { StringLitExpr, StringLitText, StringLitInterp }
import "vader/diagnostics" { Span }
import "vader/resolver/symbol" { Symbol }
import "vader/types" { Type, FnType, FreeFloatType, mk_primitive, TY_STRING, is_signed_int_name, is_unsigned_int_name, TRAIT_DISPLAY, METHOD_TO_STRING }

lower_string_lit :: fn(ctx: FnLowerCtx, expr: StringLitExpr, type: Type) -> LoweredExpr {
    string_type :: TY_STRING
    if !has_interp_part(expr) {
        body := ""
        for part in expr.parts {
            match part {
                is StringLitText as text -> { body = body + text.value }
                _ -> {}
            }
        }
        return LoweredStringLit { .span = expr.span, .type = string_type, .value = body }
    }

    // Build into one exact-sized byte buffer : text + each `${value}` writes its
    // bytes straight in, so a `${int}` formats its digits with no throwaway
    // interned string (the old `value.to_string()` per part). Interned once at
    // `finish`.
    return lower_interp_buffer(ctx, expr)
}

// Lower a flattened string `+` chain (`operands` are the lowered leaves, in
// order) to a single interned string : a call to the shared, arity-specialised
// `concat_N` (`vader/lower/lower_concat.vader`). `concat_N` is one right-sized
// byte buffer written part-by-part and interned once — no StringBuilder struct /
// parts array, one intern for the whole chain, ANY arity (no magic 2/3/4, no
// cliff). It is synthesised on first use of arity N and shared across every
// N-leaf concat ; the call site stays one `call`.
lower_concat_chain :: fn(ctx: FnLowerCtx, operands: LoweredExpr[], span: Span) -> LoweredExpr {
    n :: operands.len()
    string_type :: TY_STRING
    // A 1-leaf "chain" can't arise from `+` (always ≥ 2 leaves), but the all-
    // string `${}` path can collect a single operand ; pass it through.
    if n == 1 { return operands[0] }
    sym :: get_or_create_concat(ctx, i32(n))
    if sym == null { return unreachable_buffer("concat_${n} unresolved") }
    return mk_lowered_call(sym, operands, string_type, span)
}

// ICE for the (provably-dead) std/core buffer-API resolution guards — std/core
// is the force-loaded prelude, so these never fire. A resolution miss here is a
// broken toolchain, not a user error, so we PANIC (fail loud) rather than emit a
// degraded `stub` that would silently miscompile every `${…}` / `+`.
unreachable_buffer :: fn(why: string) -> LoweredExpr =
    unreachable("lower_string_lit: ${why} (std/core must be force-loaded)")

// Build a `<fn>(args)` call typed `ret`.
mk_lowered_call :: fn(sym: Symbol, args: LoweredExpr[], ret: Type, span: Span) -> LoweredExpr =
    LoweredCall {
        .span = span, .type = ret,
        .callee = LoweredIdent { .span = span, .type = ret, .symbol = sym },
        .args = args,
    }

// A `LoweredIdent` referencing a synthetic local (buffer / offset / param).
synth_ident :: fn(sym: Symbol, ty: Type, span: Span) -> LoweredExpr =
    LoweredIdent { .span = span, .type = ty, .symbol = sym }

// Resolve a `std/core` free fn by name (the Writer / Buffer API) via the generic
// `module_export` lookup. Returns `null` only if std/core wasn't loaded ; since
// it is the force-loaded prelude, the caller treats a null as a compiler
// invariant violation (panics via `unreachable_buffer`).
resolve_writer_fn :: fn(ctx: FnLowerCtx, name: string) -> Symbol | null =
    module_export(ctx.project, "std/core", name)

// The `Buffer` type, read from `write_string_at`'s `self` param. Shared by
// `lower_interp_buffer` and `synthesize_concat_fn` (both size + write a buffer
// via the std/core writer API). `null` when the fn type can't be resolved.
resolve_buffer_type :: fn(ctx: FnLowerCtx, wstr_sym: Symbol) -> Type | null {
    ft :: lookup_fn_type_anywhere(ctx, wstr_sym)
    if ft is FnType as f { return if f.params.len() == 0 { null } else { f.params[0] } }
    return null
}

// How a `${value}` part writes into the buffer. `Str` also covers verbatim text.
// How a part contributes : `Text` = verbatim literal, `Str` = a runtime string,
// the rest = a primitive that formats its bytes directly.
WriterKind :: enum(u8) { Text, Str, Signed, Unsigned, Bool, Display }

// A `distinct`-over-int is deliberately NOT stripped to its base : it may carry a
// CUSTOM `Display` impl (e.g. `Instant`'s ISO-8601 form over `distinct i64`), so it
// must take the `.Display` path and dispatch to that impl — the int fast path would
// wrongly write its raw backing integer. Only a bare primitive fast-paths.
classify_kind :: fn(t: Type) -> WriterKind {
    if t is PrimitiveType as p {
        if is_signed_int_name(p.name)   { return .Signed }
        if is_unsigned_int_name(p.name) { return .Unsigned }
        if p.name == "bool"   { return .Bool }
        if p.name == "string" { return .Str }
    }
    return .Display
}

// Interpolation → ONE exact-sized byte buffer when some part is a directly
// writable primitive (int / uint / bool) : those write their digits straight in,
// skipping the throwaway interned string the old `value.to_string()` minted per
// `${int}`. The buffer is sized up front — verbatim text bytes + bounds (≤ 20 per
// int, ≤ 5 per bool) + the runtime `byte_len` of string / `${Display}` parts — so
// it never grows ; `off` threads through the offset-returning `write_*`
// primitives, interned once. A purely text + `${string}` / `${Display}`
// interpolation has no digit to format, so it stays on the leaner all-string
// `concat_N` path (`concat_from_collected`). Each part is lowered once.
lower_interp_buffer :: fn(ctx: FnLowerCtx, expr: StringLitExpr) -> LoweredExpr {
    string_type :: TY_STRING
    usize_type :: mk_primitive("usize")
    span :: expr.span
    // Lower every part once, classifying interpolated values by type.
    values: LoweredExpr[] = []
    kinds: WriterKind[] = []
    has_direct := false
    for part in expr.parts {
        match part {
            is StringLitText as t -> {
                values.push(LoweredStringLit { .span = t.span, .type = string_type, .value = t.value })
                kinds.push(.Text)
            }
            is StringLitInterp as interp -> {
                inner :: lower_expr(ctx, interp.expr)
                k :: classify_kind(type_of(inner))
                if k == WriterKind.Signed || k == WriterKind.Unsigned || k == WriterKind.Bool { has_direct = true }
                values.push(inner)
                kinds.push(k)
            }
        }
    }
    if !has_direct { return concat_from_collected(ctx, values, kinds, span) }

    // Resolve the std/core buffer API ; a miss (impossible — force-loaded) falls
    // back to concat. Separate checks so each narrows to a non-null Symbol.
    nbb_sym :: resolve_writer_fn(ctx, "new_byte_buffer")
    if nbb_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    finish_sym :: resolve_writer_fn(ctx, "finish_buffer")
    if finish_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    blen_sym :: resolve_writer_fn(ctx, "byte_len")
    if blen_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    wstr_sym :: resolve_writer_fn(ctx, "write_string_at")
    if wstr_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    wint_sym :: resolve_writer_fn(ctx, "write_int")
    if wint_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    wuint_sym :: resolve_writer_fn(ctx, "write_unsigned")
    if wuint_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    wbool_sym :: resolve_writer_fn(ctx, "write_bool")
    if wbool_sym == null { return concat_from_collected(ctx, values, kinds, span) }
    // Buffer type from `write_string_at`'s self param.
    buffer_type :: resolve_buffer_type(ctx, wstr_sym)
    if buffer_type == null { return concat_from_collected(ctx, values, kinds, span) }
    register_nongeneric_imported_fn(ctx, nbb_sym)
    register_nongeneric_imported_fn(ctx, finish_sym)
    register_nongeneric_imported_fn(ctx, blen_sym)
    register_nongeneric_imported_fn(ctx, wstr_sym)
    register_nongeneric_imported_fn(ctx, wint_sym)
    register_nongeneric_imported_fn(ctx, wuint_sym)
    register_nongeneric_imported_fn(ctx, wbool_sym)

    // Process parts : bind each string / `${Display}` to a tmp (referenced twice —
    // size + write — so `${f()}` isn't evaluated twice), accumulate the static byte
    // bound + the runtime `byte_len` size terms, and record what to write.
    stmts: LoweredStmt[] = []
    write_values: LoweredExpr[] = []
    write_kinds: WriterKind[] = []
    const_bytes: i64 = 0
    runtime_size: LoweredExpr | null = null
    for i in 0..<values.len() {
        v :: values[i]
        k :: kinds[i]
        if k == WriterKind.Signed {
            const_bytes = const_bytes + 20
            write_values.push(cast_to_width(v, "i64", span))
            write_kinds.push(.Signed)
        } else if k == WriterKind.Unsigned {
            const_bytes = const_bytes + 20
            write_values.push(cast_to_width(v, "u64", span))
            write_kinds.push(.Unsigned)
        } else if k == WriterKind.Bool {
            const_bytes = const_bytes + 5
            write_values.push(v)
            write_kinds.push(.Bool)
        } else if k == WriterKind.Text {
            if v is LoweredStringLit as lit { const_bytes = const_bytes + i64(lit.value.bytes().len()) }
            write_values.push(v)
            write_kinds.push(.Str)
        } else {
            // Str / Display — bind to a tmp, add a runtime `byte_len` size term.
            str_val :: if k == WriterKind.Display { build_display_to_string_call(ctx, v, span) } else { v }
            tmp_sym :: fresh_synthetic_symbol(ctx, "p")
            stmts.push(LoweredLet { .span = span, .name = tmp_sym.name, .symbol = tmp_sym, .type = string_type, .value = str_val })
            tmp_ref :: synth_ident(tmp_sym, string_type, span)
            blen_call :: mk_lowered_call(blen_sym, [tmp_ref], usize_type, span)
            if runtime_size == null { runtime_size = blen_call } else {
                runtime_size = LoweredBinary { .span = span, .type = usize_type, .op = .Add, .left = runtime_size, .right = blen_call }
            }
            write_values.push(tmp_ref)
            write_kinds.push(.Str)
        }
    }
    // size = const_bytes + Σ byte_len(str tmps).
    const_lit :: LoweredIntLit { .span = span, .type = usize_type, .value = const_bytes }
    size: LoweredExpr = const_lit
    if runtime_size != null {
        size = LoweredBinary { .span = span, .type = usize_type, .op = .Add, .left = const_lit, .right = runtime_size }
    }
    buf_sym :: fresh_synthetic_symbol(ctx, "buf")
    stmts.push(LoweredLet {
        .span = span, .name = buf_sym.name, .symbol = buf_sym, .type = buffer_type,
        .value = mk_lowered_call(nbb_sym, [size], buffer_type, span),
    })
    off_sym :: fresh_synthetic_symbol(ctx, "off")
    stmts.push(LoweredLet {
        .span = span, .name = off_sym.name, .symbol = off_sym, .type = usize_type,
        .value = LoweredIntLit { .span = span, .type = usize_type, .value = 0 },
    })
    // `off = buf.write_X(off, value)` per part — the write returns the new offset.
    for i in 0..<write_values.len() {
        wv :: write_values[i]
        wsym :: match write_kinds[i] {
            .Signed                 -> wint_sym
            .Unsigned               -> wuint_sym
            .Bool                   -> wbool_sym
            .Str | .Text | .Display -> wstr_sym
        }
        call :: mk_lowered_call(wsym, [synth_ident(buf_sym, buffer_type, span), synth_ident(off_sym, usize_type, span), wv], usize_type, span)
        stmts.push(LoweredAssign { .span = span, .target = synth_ident(off_sym, usize_type, span), .value = call })
    }
    return LoweredBlock {
        .span = span, .type = string_type, .stmts = stmts,
        .trailing = mk_lowered_call(finish_sym, [synth_ident(buf_sym, buffer_type, span), synth_ident(off_sym, usize_type, span)], string_type, span),
    }
}

// The non-direct path : each part as a string operand (Str / Text verbatim, else
// `value.to_string()`), concatenated via the same shared `concat_N` as `+`.
// Used when no part is a direct-write primitive, or the buffer API doesn't resolve.
concat_from_collected :: fn(ctx: FnLowerCtx, values: LoweredExpr[], kinds: WriterKind[], span: Span) -> LoweredExpr {
    operands: LoweredExpr[] = []
    for i in 0..<values.len() {
        if kinds[i] == WriterKind.Str || kinds[i] == WriterKind.Text {
            operands.push(values[i])
        } else {
            operands.push(build_display_to_string_call(ctx, values[i], span))
        }
    }
    return lower_concat_chain(ctx, operands, span)
}

// Widen `inner` to `width` (i64 / u64) for the write fn ; identity when already it.
cast_to_width :: fn(inner: LoweredExpr, width: string, span: Span) -> LoweredExpr {
    t :: type_of(inner)
    if t is PrimitiveType as p { if p.name == width { return inner } }
    return LoweredCast { .span = span, .type = mk_primitive(width), .value = inner }
}

// Build a `<T>.Display.to_string(value)` call shape. Prefers a direct
// `LoweredCall` to the per-receiver impl member when the impl is
// statically resolvable (concrete struct / enum types). Falls back
// to `LoweredVirtualCall` for primitives / generic-T receivers where
// the impl exists per-instantiation but isn't reachable at lower-time.
build_display_to_string_call :: fn(ctx: FnLowerCtx, value: LoweredExpr, span: Span) -> LoweredExpr {
    string_type :: TY_STRING
    no_args: LoweredExpr[] = []
    direct :: try_direct_display_call(ctx, value, span)
    if direct != null { return direct }
    // Erased Display dispatch (generic-`T` receiver) : record the trait so
    // every primitive `Display` impl enters the vtable (the boxed tag picks
    // the impl at runtime). See `virtually_dispatched_traits`.
    ctx.project.virtually_dispatched_traits.add(TRAIT_DISPLAY)
    return LoweredVirtualCall {
        .span       = span,
        .type       = string_type,
        .trait_name = TRAIT_DISPLAY,
        .method     = METHOD_TO_STRING,
        .receiver   = value,
        .args       = no_args,
    }
}

// Look up `<sourceType>.Display.to_string` statically. Returns a
// `LoweredCall` whose callee is the impl-member's mangled fn symbol
// when reachable ; null otherwise. The mangling matches what
// `lower_impl_members` registers in `lower.vader`.
try_direct_display_call :: fn(ctx: FnLowerCtx, value: LoweredExpr, span: Span) -> LoweredExpr | null {
    string_type :: TY_STRING
    source_type := type_of(value)
    // A `FreeFloat` literal (un-defaulted at lower-time) displays as `f64`:
    // pin it so the lookup finds f64's concrete Ryu `Display` impl rather than
    // falling through to an erased virtual dispatch.
    if source_type is FreeFloatType { source_type = mk_primitive("f64") }
    // Resolve `<T>.Display.to_string` through the canonical UFCS path. This
    // mangles via the IMPL's owning module (`std_core$usize$Display$to_string`,
    // not the caller's) AND records the mangle in `referenced_impl_mangles`, so
    // the post-lowering pass surfaces the bodyless intrinsic member as an import
    // and the call resolves to its `$vt` wrapper. A previous hand-rolled scan
    // here emitted a bare `to_string` callee with no recorded reference, so the
    // call fell through to the emit's defensive `Return` (e.g. every `${usize}`
    // interpolation silently mis-compiled). `null` (no concrete Display impl:
    // generic-T / trait receiver) falls back to a `LoweredVirtualCall`.
    member :: find_impl_member_for(ctx, source_type, METHOD_TO_STRING)
    if member is null { return null }
    // Build the direct `to_string(value)` call — or, when the member is the
    // identity `fn(self) = self` (string's `Display`), inline to `value` itself.
    call_args: LoweredExpr[] = []
    call_args.push(value)
    return build_member_call_or_inline(member, call_args, string_type, span)
}

has_interp_part :: fn(expr: StringLitExpr) -> bool {
    for part in expr.parts {
        match part {
            is StringLitInterp -> { return true }
            _ -> {}
        }
    }
    return false
}
