// vader/lower/lower_generator_fusion — inline a consumed `generator` body into
// its for-in (Couche 4, stream-fusion-generalization.md).
//
// `for v in gen(args) { body }` where `gen` carries `generator` is lowered by
// inlining gen's body with (a) each param bound to the matching call arg and
// (b) each `yield e` redirected to the consumer's loop-var binding + body — no
// state-machine struct, no boxed `Iterator`, no virtual `next()`. The generator's
// own `for x in <param>` fuses through the existing for-in fast paths (raw array,
// int range, map/set, chain fusion). Tried from `lower_for_in` right after the
// combinator-chain fusion; a `null` result falls through to the boxed path.
//
// Handles a DIRECT call `for v in gen(args)` — generic or not: a generic
// generator reconstructs its instance substitution at this site via
// `infer_type_args` + the `.NET`-model flavor path, then lowers the body in a
// gen-ctx under that subst. Chained combinators (`xs.iter().gen_map(f)`, a UFCS
// FieldExpr callee) recurse into the receiver — Increment 3.

module "vader/lower"

import "std/collections"
import "vader/diagnostics"
AST :: import "vader/parser"
import "vader/resolver/symbol"
import "vader/types"
import "vader/typecheck"

// Recognise `for v in <gen-call>` where the callee is a directly-called
// `generator` fn (generic or not), and inline its yield-loop in place of the
// boxed `next()` dispatch. Returns null for any non-matching shape (the caller
// falls through to the generic step-loop).
export try_lower_generator_inline :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    // Decline when a `break <var>` / `continue <var>` targets THIS for-in by its
    // iteration variable (typecheck recorded it): the inlined form builds no
    // `LoweredLoop` for the consumer loop, so there is nothing to stamp with the
    // target label — the jump would silently no-op at the backend. Fall back to
    // the boxed state-machine path, which builds a stampable `LoweredLoop`.
    if ctx.typed.loop_target_labels[for_stmt.id] != null { return null }
    // Direct-ident callee only (Increment 1): `gen(args)`, not `recv.gen(args)`.
    // Both `is` bindings stay live in the inner block, so the worker takes them.
    if in_form.iter is AST.CallExpr as call {
        if call.callee is AST.IdentExpr as callee_id {
            return inline_gen_ident_call(ctx, for_stmt, in_form, call, callee_id, recurse, block_lowerer)
        }
    }
    return null
}

// The yielded element type for a `generator` fn, from the typecheck-side
// registry (`register_generator_iter_impls`) substituted by the call's instance
// subst. Null when the fn isn't registered (declines fusion). Shared by the
// direct-call and combinator fusion sites.
genstate_element :: fn(typed: TypedProgram, fn_name: string, subst: Substitution) -> Type | null {
    raw :: typed.iter_element_types[gen_state_name(fn_name)]
    if raw is null { return null }
    return substitute(raw, subst)
}

// Build the yield sink for a generator inlined into a `for` consumer. For a
// plain `for x in <gen>` the sink binds the single consumer variable. For a
// `for [k, v] in <gen>` destructure the sink binds a fresh element temp and the
// `let [k, v] := <temp>` destructure is baked into the FRONT of the consumer
// body — lowered HERE, in the consumer's `ctx`, where the pattern leaves (k, v)
// resolve. (Doing it at yield time would splice into the generator's own ctx,
// where those leaf symbols don't resolve — the destructure would silently drop.)
build_gen_sink :: fn(
    ctx: FnLowerCtx, pattern: AST.LetBinding | null,
    binding_symbol: Symbol, binding_name: string,
    element_type: Type, body: LoweredBlock, span: Span,
) -> GenInlineSink {
    if pattern is AST.TupleBinding as tup {
        elem_sym :: fresh_synthetic_symbol(ctx, "gen_elem")
        destructure :: emit_for_pattern_destructure(ctx, tup, elem_sym, element_type, span)
        return GenInlineSink {
            .binding_symbol = elem_sym,
            .binding_name = elem_sym.name,
            .element_type = element_type,
            .body = prepend_stmts_to_block(destructure, body),
        }
    }
    return GenInlineSink {
        .binding_symbol = binding_symbol,
        .binding_name = binding_name,
        .element_type = element_type,
        .body = body,
    }
}

// The direct-call worker. Resolves the callee to its `generator` FnDecl, binds
// each param to its arg, and lowers the generator body with the consumer's body
// installed as the `yield` sink (`ctx.gen_inline_sink`).
inline_gen_ident_call :: fn(
    ctx: FnLowerCtx, for_stmt: AST.ForStmt, in_form: AST.InFor, call: AST.CallExpr,
    callee_id: AST.IdentExpr,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredStmt | null {
    raw_callee :: ctx.typed.resolved.idents[callee_id.span.hash()]
    if raw_callee is null { return null }
    // Follow a directly-called imported generator's ImportBinding to its owner fn.
    callee_sym :: follow_import_binding(ctx, raw_callee)
    owner_typed :: resolve_owner_typed(ctx, callee_sym.module)
    if owner_typed is null { return null }
    fn_decl :: owner_typed.fn_decls[callee_sym.id]
    if fn_decl is null { return null }
    if !fn_is_generator(fn_decl) { return null }
    gen_body :: fn_decl.body
    if gen_body is null { return null }
    if call.args.len() != fn_decl.params.len() { return null }

    // The generator's instance substitution: empty for a non-generic generator ;
    // the inferred per-instance subst for a generic one. Null → a generic body
    // whose type args don't infer to all-concrete ; bail to the boxed path.
    subst_opt :: gen_instance_subst(ctx, callee_id, call, fn_decl, owner_typed)
    if subst_opt is null { return null }
    subst :: subst_opt

    // Direction A: the call result is the concrete `__genstate_<fn>` struct, not
    // `Iterator<U>` — take the yielded element from the registered element.
    element_type :: genstate_element(ctx.typed, fn_decl.name, subst)
    if element_type is null { return null }
    if element_type == TY_VOID { return null }

    // Bind each generator param to its call arg — a `let <param> = <arg>` ahead
    // of the inlined body. Args lower in the CONSUMER ctx (they are consumer
    // exprs) ; the param SYMBOL is the generator module's own, so the body (lowered
    // below in `owner_typed`) resolves its references to these lets.
    param_lets: LoweredStmt[] = []
    for i in 0..<fn_decl.params.len() {
        p :: fn_decl.params[i]
        p_sym :: lookup_local_symbol(ctx.project, owner_typed.resolved, p.span)
        if p_sym is null { return null }
        arg_lowered :: recurse(ctx, call.args[i].value)
        param_lets.push(LoweredLet {
            .span = p.span, .name = p.name, .symbol = p_sym,
            .type = type_of(arg_lowered), .value = arg_lowered,
        })
    }

    lb :: resolve_loop_binding(ctx, in_form.loop_var, for_stmt.span)
    consumer_body :: block_lowerer(ctx, for_stmt.body, false, true)

    // Lower the generator body in its OWN fn-ctx — the generator's module +
    // its instance subst — sharing `ctx.project` so synthetic ids don't collide
    // with the consumer's. The sink routes each `yield e` to the consumer's
    // binding + body ; nested generator-in-generator consumption saves/restores
    // its own sink on the inner ctx.
    gen_return :: substitute(return_type_of(fn_decl, make_entry_types(owner_typed, subst)), subst)
    gen_ctx :: new_fn_lower_ctx(ctx.project, stub_entry(fn_decl, owner_typed), owner_typed, subst, gen_return, null)
    gen_ctx.gen_inline_sink = build_gen_sink(ctx, lb.pattern, lb.symbol, lb.name, element_type, consumer_body, for_stmt.span)
    lowered_gen :: block_lowerer(gen_ctx, gen_body, false, false)

    out: LoweredStmt[] = []
    out.push_all(param_lets)
    out.push_all(block_stmts_with_trailing(lowered_gen))
    return wrap_stmts(for_stmt.span, out)
}

// The generator's owning-module typed program: `ctx.typed` when the call is
// same-module, else the project table. Null when the module isn't loaded.
resolve_owner_typed :: fn(ctx: FnLowerCtx, module: string) -> TypedProgram | null {
    if module == ctx.typed.resolved.path { return ctx.typed }
    m :: ctx.project.typed.modules[module]
    if m is TypedProgram as ot { return ot }
    return null
}

// The instance substitution for the generator body: empty for a non-generic
// generator ; the inferred per-instance subst for a generic one, via the same
// `infer_type_args` + `.NET`-model flavor path the generic call site uses
// (`emit_generic_fn_call`). Null when a generic generator's type args don't
// infer to all-concrete — the caller then bails to the boxed path.
gen_instance_subst :: fn(
    ctx: FnLowerCtx, callee_id: AST.IdentExpr, call: AST.CallExpr,
    fn_decl: AST.FnDecl, owner_typed: TypedProgram,
) -> Substitution | null {
    if fn_decl.type_params.len() == 0 { return new_substitution() }
    ft :: ctx.types.raw_expr_type(callee_id)
    if ft is FnType as f {
        return subst_from_concrete(fn_decl, owner_typed, infer_type_args(f, call, ctx))
    }
    return null
}

// Pick the per-instance substitution for `fn_decl<concrete_args>` via the
// `.NET`-model flavor classifier — the shared tail of both the direct-call subst
// (`gen_instance_subst`) and the chained-combinator subst.
subst_from_flavor :: fn(fn_decl: AST.FnDecl, owner_typed: TypedProgram, concrete_args: Type[]) -> Substitution {
    flavor :: fn_instance_flavor(fn_decl, owner_typed, concrete_args)
    if flavor == InstanceFlavor.Mono { return build_fn_concrete_subst(fn_decl, owner_typed, concrete_args) }
    if flavor == InstanceFlavor.Mixed { return build_fn_mixed_subst(fn_decl, owner_typed, concrete_args) }
    return build_fn_any_subst(fn_decl, owner_typed)
}

// Strip distinct wrappers off `args`, require all-concrete, then pick the flavor
// subst — the shared finalize tail of every generator subst path. Null when any
// arg stays a free type param (the caller bails to the boxed path).
subst_from_concrete :: fn(fn_decl: AST.FnDecl, owner_typed: TypedProgram, args: Type[]) -> Substitution | null {
    concrete :: strip_distinct_each(args)
    if !all_concrete(concrete) { return null }
    return subst_from_flavor(fn_decl, owner_typed, concrete)
}

// ---- chained generator combinators (Increment 3) --------------------------
//
// A generator whose FIRST param is the source iterator — `map`/`filter`
// (`generator fn<T, U>(self: Iterator<T>, f) -> Iterator<U> { for x in self { … } }`)
// — consumed in a chain (`xs.iter().map(f)`). Unlike a direct call, `self` is
// itself an iterator we want to FUSE into, not materialise: binding `let self =
// xs.iter()` would leave a boxed `ArrayIterator`. So a generator combinator is a
// `descend_chain` LAYER (`IterChainKind.Generator`) whose source recurses into the
// receiver — the generator body's `for <lv> in self { <inner> }` becomes the source loop binding
// `<lv>`, and `<inner>` (lowered in the gen-ctx with the outer sink) routes each
// `yield e` to the consumer. Nested combinators thread sinks so the whole chain
// flattens to one loop.

// One source loop of a generator combinator body — `[<prelude>] for <loopvar> in
// <param> { <inner> }`, fused over `source` (the `descend_chain` of the arg bound
// to that param). A combinator with more than one source param (`chain`) carries
// the extra loops beyond the primary `self` loop in `GenComboLayer.extra_sources`.
GenSourceBinding :: struct {
    source:  IterChain      // the param's arg chain
    loopvar: Symbol         // the loop's binding variable
    inner:   AST.BlockExpr  // the loop body (contains the yield)
    prelude: AST.Stmt[]     // counter `let`s ahead of this loop (take/skip/enumerate)
}

// The inlined body of a generator combinator layer, carried on `IterChain`.
GenComboLayer :: struct {
    decl:        AST.FnDecl      // the generator combinator
    subst:       Substitution    // its instance substitution
    owner:       TypedProgram    // the module the generator is defined in
    loopvar:     Symbol          // the body's primary `for <loopvar> in self` variable
    inner:       AST.BlockExpr   // the primary for-loop body (contains the yield)
    arg_sym:     Symbol | null   // the single non-self DATA param's symbol (map's `f`) ; null for a 0-arg combinator (`enumerate`) or when the non-self param is itself a source (`chain`)
    arg_expr:    AST.Expr | null // the call's non-self DATA argument (map's `f`, …) ; null as above
    output_elem: Type            // the combinator's yielded element type
    prelude:     AST.Stmt[]      // counter `let`s ahead of the primary source loop (take/skip/enumerate)
    // Additional source loops beyond the primary `self` loop, in body order —
    // one per extra source param (`chain`'s `other`). Empty for every single-
    // source combinator (map / filter / take / skip / enumerate / flat_map).
    extra_sources: GenSourceBinding[] = []
}

// Recognise `<recv>.gen_combinator(arg)` (UFCS) or `gen_combinator(<recv>, arg)`
// where the callee is a `generator` fn whose body is one or more `for <lv> in
// <param> { <inner> }` source loops (map/filter/take/skip/enumerate: one loop over
// `self` ; `chain`: two, over `self` and `other`). Returns a `Generator` chain
// layer whose primary source is `descend_chain(<recv>)` and whose extra source
// params fuse independently, else null (the chain falls back to the boxed path).
try_descend_gen_combinator :: fn(ctx: FnLowerCtx, call: AST.CallExpr) -> IterChain | null {
    fluent :: unpack_fluent_combinator(ctx, call)
    if fluent is null { return null }
    callee_sym :: combinator_callee_sym(ctx, call, fluent.receiver)
    if callee_sym is null { return null }
    owner :: resolve_owner_typed(ctx, callee_sym.module)
    if owner is null { return null }
    decl :: owner.fn_decls[callee_sym.id]
    if decl is null { return null }
    if !fn_is_generator(decl) { return null }
    // v1: `self` plus zero (`enumerate`) or one (map/filter/take/skip/chain) non-self param.
    if decl.params.len() != 1 && decl.params.len() != 2 { return null }
    loops :: extract_gen_source_loops(decl)
    if loops is null { return null }

    // The primary loop iterates `self` (param 0) ; its source is the receiver.
    primary :: find_source_loop(loops, 0)
    if primary is null { return null }
    source :: descend_chain(ctx, fluent.receiver, true)
    if source is null { return null }
    primary_loopvar :: lookup_local_symbol(ctx.project, owner.resolved, primary.loopvar_span)
    if primary_loopvar is null { return null }

    // Classify the non-self param (param 1, if any): a SOURCE — its own loop, as in
    // `chain`'s `other` — fuses as an extra source ; otherwise it's DATA (map's `f`,
    // take's `n`), bound once ahead of the loops.
    param1_loop :: find_source_loop(loops, 1)
    // The non-self param is DATA (map's `f`, take's `n`) unless it has its own source
    // loop — `chain`'s `other`, which fuses as an extra source instead.
    arg_is_data :: decl.params.len() == 2 && param1_loop is null
    extra_sources: GenSourceBinding[] = []
    if param1_loop is GenSourceLoop as sl {
        other_expr :: fluent.fn_arg
        if other_expr is null { return null }
        other_src :: descend_chain(ctx, other_expr, true)
        if other_src is null { return null }
        other_loopvar :: lookup_local_symbol(ctx.project, owner.resolved, sl.loopvar_span)
        if other_loopvar is null { return null }
        extra_sources.push(GenSourceBinding {
            .source = other_src, .loopvar = other_loopvar, .inner = sl.inner, .prelude = sl.prelude,
        })
    }
    // No 3-source combinator exists — reject any loop over param ≥ 2.
    if loops.len() > 1 + extra_sources.len() { return null }

    // The non-self DATA arg (null for a 0-arg / all-source combinator) — seeds the
    // instance subst (map/filter's transform carries the element concretely) and is
    // bound once ahead of the loops.
    data_arg :: if arg_is_data { fluent.fn_arg } else { null }
    subst_opt :: gen_combo_subst(ctx, decl, owner, callee_sym, fluent.receiver, data_arg, chain_element_type(source))
    if subst_opt is null { return null }
    arg_sym :: if arg_is_data { combinator_arg_sym(ctx, decl, owner) } else { null }
    if arg_is_data && arg_sym is null { return null }

    // Direction A: the call result is the concrete `__genstate_<fn>` struct, not
    // `Iterator<U>` — take the yielded element from the registered element.
    output_elem :: genstate_element(ctx.typed, decl.name, subst_opt)
    if output_elem is null { return null }
    return mk_generator_chain(source, GenComboLayer {
        .decl = decl, .subst = subst_opt, .owner = owner,
        .loopvar = primary_loopvar, .inner = primary.inner,
        .arg_sym = arg_sym, .arg_expr = data_arg, .output_elem = output_elem,
        .prelude = primary.prelude, .extra_sources = extra_sources,
    }, call.span)
}

// The source loop over param `param_index`, or null when no loop iterates it.
find_source_loop :: fn(loops: GenSourceLoop[], param_index: usize) -> GenSourceLoop | null {
    for l in loops { if l.param_index == param_index { return l } }
    return null
}

// The symbol of a combinator's single non-self param (`decl.params[1]`), or null
// for a 0-arg combinator (`enumerate`, whose only param is `self`).
combinator_arg_sym :: fn(ctx: FnLowerCtx, decl: AST.FnDecl, owner: TypedProgram) -> Symbol | null {
    if decl.params.len() < 2 { return null }
    return lookup_local_symbol(ctx.project, owner.resolved, decl.params[1].span)
}

// One source loop of a generator combinator body, tagged with the PARAM it
// iterates. `prelude` is the run of non-loop statements ahead of it — a leading
// counter `let` for `take`/`skip`/`enumerate` (`i: usize = 0`), empty otherwise.
GenSourceLoop :: struct { param_index: usize, loopvar_span: Span, inner: AST.BlockExpr, prelude: AST.Stmt[] }

// Split a generator combinator body into its ordered source loops. Each top-level
// `for <lv> in <param_k> { <inner> }` statement is a source loop over param k ;
// every other statement (a counter `let`) accrues as the `prelude` of the NEXT
// loop. Null when the body dangles statements after its last loop, or has no loop
// at all — shapes the fusion doesn't model. map/filter/take/skip/enumerate yield a
// single loop over `self` ; `chain` yields two (over `self` and `other`).
extract_gen_source_loops :: fn(decl: AST.FnDecl) -> GenSourceLoop[] | null {
    body :: decl.body
    if body is null { return null }
    if body.trailing != null { return null }
    if body.stmts.len() == 0 { return null }
    loops: GenSourceLoop[] = []
    pending: AST.Stmt[] = []
    for stmt in body.stmts {
        matched :: match_source_loop(stmt, decl)
        if matched is GenSourceLoop as sl {
            loops.push(GenSourceLoop {
                .param_index = sl.param_index, .loopvar_span = sl.loopvar_span,
                .inner = sl.inner, .prelude = pending,
            })
            pending = []
        } else {
            pending.push(stmt)
        }
    }
    // A dangling prelude after the last loop isn't a fusible shape.
    if pending.len() > 0 { return null }
    if loops.len() == 0 { return null }
    return loops
}

// The source loop `stmt` forms — `for <lv> in <param_k> { <inner> }`, tagged with
// param k — or null when it isn't a top-level loop over one of `decl`'s params. The
// returned `prelude` is empty ; the caller fills it with the preceding non-loop run.
match_source_loop :: fn(stmt: AST.Stmt, decl: AST.FnDecl) -> GenSourceLoop | null {
    if stmt is AST.ForStmt as fs {
        if fs.form is AST.InFor as inf {
            if inf.iter is AST.IdentExpr as it {
                for i in 0..<decl.params.len() {
                    if decl.params[i].name == it.name {
                        return GenSourceLoop { .param_index = i, .loopvar_span = loop_var_span(inf.loop_var, fs.span), .inner = fs.body, .prelude = [] }
                    }
                }
            }
        }
    }
    return null
}

// The resolved callee symbol of a combinator call — the free-fn symbol for a UFCS
// `recv.name(arg)` (via the receiver type) or a direct `name(recv, arg)` ident.
combinator_callee_sym :: fn(ctx: FnLowerCtx, call: AST.CallExpr, receiver: AST.Expr) -> Symbol | null {
    @partial match call.callee {
        is AST.FieldExpr as fe -> {
            found :: find_free_fn_ufcs(ctx, ctx.types.expr_type(receiver), fe.field)
            if found is UfcsMember as m { return m.symbol }
            return null
        }
        is AST.IdentExpr as id -> {
            sym :: ctx.typed.resolved.idents[id.span.hash()]
            if sym is null { return null }
            // A directly-called imported combinator resolves to the `import`
            // ImportBinding ; follow it to the OWNER fn so `resolve_owner_typed`
            // + `gen_state_symbol` see the defining module.
            return follow_import_binding(ctx, sym)
        }
        _ -> { return null }
    }
}

// The instance substitution for a generator combinator: empty when non-generic,
// else inferred by unifying the generic signature's params with the receiver +
// arg types (`unify_params` — the same engine `infer_type_args` uses, but driven
// from the normalised `(receiver, fn_arg)` so it works for UFCS and direct alike).
// Null when a type param stays unbound (bail to the struct/boxed path).
gen_combo_subst :: fn(
    ctx: FnLowerCtx, decl: AST.FnDecl, owner: TypedProgram, callee_sym: Symbol,
    receiver: AST.Expr, fn_arg: AST.Expr | null, source_elem: Type,
) -> Substitution | null {
    if decl.type_params.len() == 0 { return new_substitution() }
    // 0-arg combinator (`enumerate`): no fn arg to infer from — `self`'s only type
    // param IS the source element, so bind it straight from the fused source's
    // concrete element type (`substitute` then rewrites it through the yielded
    // element, tuple included). `source_elem` is post-fusion concrete, with no
    // erased-head ambiguity — the same unambiguous binding the 1-arg path uses.
    if fn_arg is null { return subst_from_concrete(decl, owner, [source_elem]) }
    ft :: owner.decl_types[callee_sym.id]
    if ft is FnType as f {
        if f.params.len() < 2 { return null }
        bindings :: MutableMap<i32, Type> {}
        order: i32[] = []
        // Bind the SOURCE element type-param from the post-fusion concrete
        // `source_elem`, NOT from the receiver's (possibly erased) type. `self` is
        // `Iterator<T>` for every combinator, so its element `T` is `params[0]`'s
        // trait arg. This retires the old "unify arg before receiver" ordering
        // hack (which only existed to stop an erased head binding `T = Any` first).
        // For a concrete head `source_elem` equals the receiver's element, so the
        // result (and the `order` / `concrete_args`) is byte-identical to the old
        // path — see the task #25 note in project_stream_fusion_generators.
        source_bound := false
        if f.params[0] is TraitType as p0 {
            if p0.args.len() >= 1 {
                unify_params(p0.args[0], source_elem, bindings, order, ctx)
                source_bound = true
            }
        }
        // Non-`Iterator<T>` self shouldn't occur for these combinators ; keep the
        // receiver-unify fallback so an unexpected shape behaves as before.
        if !source_bound {
            unify_params(f.params[0], default_if_free(ctx.types.expr_type(receiver)), bindings, order, ctx)
        }
        // Then the fn arg, for any param it introduces beyond the source element
        // (map's `U` from `f: fn(T) -> U`). `T` is already pinned, and
        // `unify_params` keeps the first binding, so a concrete arg just agrees.
        unify_params(f.params[1], default_if_free(ctx.types.expr_type(fn_arg)), bindings, order, ctx)
        concrete_args: Type[] = []
        for id in order {
            v :: bindings[id]
            if v is null { return null }
            concrete_args.push(v)
        }
        return subst_from_concrete(decl, owner, concrete_args)
    }
    return null
}

// Emit a `Generator` chain layer: each source loop binds its loop var to every
// source element and runs the combinator's inner body, whose `yield e` routes (via
// the shared gen-ctx sink) to the OUTER template's binding + body. The single non-
// self DATA param (map's `f`, …) binds once ahead ; multi-source combinators
// (`chain`) fuse each source loop in body order, all into the same sink.
emit_fused_gen_combinator :: fn(
    ctx: FnLowerCtx, chain: IterChain, loop_label: string | null, outer_span: Span,
    template: BodyTemplate,
    recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    src :: chain.source
    layer :: chain.gen_layer
    if src is null { return [] }
    if layer is null { return [] }

    // Shared gen-ctx (owner module + instance subst) with the OUTER template installed
    // as the yield sink — every source loop routes its yields to the same consumer body.
    gen_return :: substitute(return_type_of(layer.decl, make_entry_types(layer.owner, layer.subst)), layer.subst)
    gen_ctx :: new_fn_lower_ctx(ctx.project, stub_entry(layer.decl, layer.owner), layer.owner, layer.subst, gen_return, null)
    gen_ctx.gen_inline_sink = build_gen_sink(ctx, template.pattern, template.binding_symbol, template.binding_name, template.element_type, template.user_body, chain.span)

    out: LoweredStmt[] = []
    // Bind the combinator's single non-self DATA arg (map's `f`, take's `n`) once,
    // ahead of the loops. A 0-arg / all-source combinator (enumerate / chain) has none.
    arg_expr :: layer.arg_expr
    arg_sym :: layer.arg_sym
    if arg_expr != null && arg_sym != null {
        arg_lowered :: recurse(ctx, arg_expr)
        out.push(LoweredLet {
            .span = chain.span, .name = arg_sym.name, .symbol = arg_sym,
            .type = type_of(arg_lowered), .value = arg_lowered,
        })
    }
    // The primary `self` loop, then each extra source loop (chain's `other`), fused
    // in body order — all binding into the shared sink.
    primary_binding :: GenSourceBinding { .source = src, .loopvar = layer.loopvar, .inner = layer.inner, .prelude = layer.prelude }
    out.push_all(fuse_source_loop(ctx, gen_ctx, primary_binding, loop_label, outer_span, chain.span, recurse))
    for extra in layer.extra_sources {
        out.push_all(fuse_source_loop(ctx, gen_ctx, extra, loop_label, outer_span, chain.span, recurse))
    }
    return out
}

// Fuse one source loop of a generator combinator: lower its inner body in the
// shared gen-ctx (yields route to the installed sink), then emit its prelude (a
// counter `let`, sibling of the loop so inner counter refs resolve) followed by the
// fused source loop binding the loop var to each element.
fuse_source_loop :: fn(
    ctx: FnLowerCtx, gen_ctx: FnLowerCtx, binding: GenSourceBinding, loop_label: string | null,
    outer_span: Span, span: Span, recurse: fn(FnLowerCtx, AST.Expr) -> LoweredExpr,
) -> LoweredStmt[] {
    inner_lowered :: recurse(gen_ctx, binding.inner)
    if inner_lowered is LoweredBlock as inner_block {
        inner_template :: BodyTemplate {
            .binding_name = binding.loopvar.name,
            .binding_symbol = binding.loopvar,
            .element_type = chain_element_type(binding.source),
            .user_body = inner_block,
        }
        source_stmts :: emit_fused_chain(ctx, binding.source, loop_label, outer_span, inner_template, recurse)
        out: LoweredStmt[] = []
        if binding.prelude.len() > 0 {
            prelude_expr: AST.Expr = AST.BlockExpr { .span = span, .stmts = binding.prelude, .trailing = null }
            prelude_lowered :: recurse(gen_ctx, prelude_expr)
            if prelude_lowered is LoweredBlock as pb { out.push_all(pb.stmts) }
        }
        out.push_all(source_stmts)
        return out
    }
    return []
}
