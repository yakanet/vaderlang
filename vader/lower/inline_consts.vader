// vader/lower/inline_consts — route module-level const decls to their read sites.
//
// Mirror of the `fn-wrap` + `inline` buckets of
// `src/lower/passes/inline-consts.ts`. A non-scalar const reference can't be
// emitted as a bare ident — `build_ident` has no const-load case (the CFG
// design inlines consts out). This pass classifies every `LoweredConstDecl`
// and records how its read sites should resolve, consumed at CFG-build time
// by `vader/midir/build.vader::build_ident` :
//
//   - fn-wrap : an array literal of `FN_WRAP_MIN_ELEMENTS`+ elements (struct /
//     string elements that the data pool can't hold, e.g. `INTRINSICS`). The
//     const decl is REPLACED IN PLACE by a synthetic 0-arg accessor fn
//     `__const_<name>` returning the literal ; each reference lowers to one
//     `call` instead of re-emitting the whole literal. In-place replacement
//     keeps the accessor at the const's fn-table position so emission order
//     matches the TS lowerer.
//   - inline  : everything else (scalars, small lists, struct literals). The
//     value is recorded verbatim and `build_ident` re-builds it at each read
//     site. Scalars normally fold earlier in `lower_expr.vader::lower_ident` ;
//     recording them here is a safety net for any reference that didn't fold.
//
// The data-pool bucket (primitive-element `const T[]` → `.rodata`) is NOT yet
// ported : such consts fall through to fn-wrap. The compiler tree reaches no
// primitive-array const (the crypto K-tables live in unimported std/crypto),
// so this is byte-parity-neutral for the self-host audit — see CLAUDE.md §9.

module "vader/lower"

import "std/collections" { MutableMap }
AST :: import "vader/parser"
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/comptime" { MonoEntry }
import "vader/types" { ArrayType, StructType, display_type }

// Break-even point : the `call` at each read site is cheaper than re-emitting
// `2 * N` ops to rebuild the literal once N passes this threshold. Matches
// `FN_WRAP_MIN_ELEMENTS` in `src/lower/passes/inline-consts.ts`.
FN_WRAP_MIN_ELEMENTS :: usize(4)

/// Classify every const decl in `project` and record its read-site routing on
/// `project.const_fn_wrap` / `project.const_inline`, replacing fn-wrapped
/// const decls with their synthetic accessor fns. Mutates `project` in place.
///
/// @param project  the lowered project ; its `modules` + const maps are mutated.
export inline_consts :: fn(project: LoweredProject) -> void {
    // Fresh synthetic ids for accessor fns — negative, so they never collide
    // with a real (non-negative) symbol id. Decrements per fn-wrap in
    // deterministic module × decl order. (Mirror of TS `-nextSyntheticId++`.)
    next_synth: i32 = -1
    for module_id in project.modules.keys() {
        m :: project.modules[module_id]
        if m is null { continue }
        new_decls: LoweredDecl[] = []
        changed := false
        for d in m.decls {
            if d is LoweredConstDecl as cd {
                sym :: cd.origin.symbol
                if sym is Symbol as s {
                    // Data-pool bucket : an immutable `const T[]` of primitive
                    // literals is materialised once into `.rodata` (native) /
                    // a data segment (wasm) / an in-memory const buffer (VM),
                    // and every read site lowers to a zero-copy `data.const`
                    // view — never rebuilt. Takes priority over fn-wrap, which
                    // would `array.new` + refill at each call. Mutable / non-
                    // primitive arrays fall through to the existing buckets.
                    if try_data_pool(cd, s, project) {
                        changed = true
                        continue
                    }
                    if should_fn_wrap(cd.value) {
                        fn_symbol :: const_accessor_symbol(s, next_synth)
                        next_synth = next_synth - 1
                        project.const_fn_wrap[s.id] = ConstFnWrap { .fn_symbol = fn_symbol, .call_type = cd.type }
                        new_decls.push(synthesize_const_fn(cd, fn_symbol))
                        changed = true
                        continue
                    }
                    project.const_inline[s.id] = cd.value
                }
            }
            new_decls.push(d)
        }
        if changed {
            project.modules[module_id] = LoweredModule {
                .module_id    = m.module_id,
                .display_path = m.display_path,
                .decls        = new_decls,
            }
        }
    }
}

// fn-wrap eligibility : a bulky array literal. Smaller arrays + every other
// shape (scalars, struct literals) route through the inline bucket.
should_fn_wrap :: fn(value: LoweredExpr) -> bool {
    if value is LoweredArrayLit as a { return a.elements.len() >= FN_WRAP_MIN_ELEMENTS }
    return false
}

// Route an immutable `const T[]` into the project data pool : register a
// `DataPoolEntry`, point the const's read sites at a `LoweredDataConst` (via
// `const_inline`, which `build_ident` rebuilds as the `data.const` op), and
// report success so the caller drops the decl. Returns false for any
// non-eligible shape (mutable array, non-poolable element, non-array) — those
// keep the fn-wrap / inline buckets.
//
// Poolable elements : integer / char / bool / float literals (each reduced to an
// `i64` bit pattern) and string literals (kept verbatim). Struct arrays route
// through later phases.
try_data_pool :: fn(cd: LoweredConstDecl, symbol: Symbol, project: LoweredProject) -> bool {
    if cd.type is ArrayType as arr_type {
        if !arr_type.immutable { return false }
        if cd.value is LoweredArrayLit as lit {
            element_type_name :: display_type(arr_type.element)
            entry :: render_data_pool_entry(lit, element_type_name)
            if entry != null {
                pool_index :: project.data_pool.len()
                project.data_pool.push(entry)
                project.const_inline[symbol.id] = LoweredDataConst {
                    .span = lit.span, .type = cd.type, .pool_index = pool_index,
                }
                return true
            }
        }
    }
    return false
}

// Build the pooled entry for an immutable array literal, or null when an element
// isn't poolable. A `string[]` becomes a `StrDataPoolEntry` (values verbatim) ;
// every other element type takes the primitive bit-pattern path.
render_data_pool_entry :: fn(lit: LoweredArrayLit, element_name: string) -> DataPoolEntry | null {
    if element_name == "string" {
        values :: render_string_items(lit)
        if values == null { return null }
        return StrDataPoolEntry { .values = values }
    }
    rendered :: render_data_items(lit, element_name)
    if rendered != null {
        return PrimDataPoolEntry { .element_type_name = element_name, .items = rendered }
    }
    // Aggregate (struct / nested-array elements) : bakeable only when every leaf
    // is a constant literal and every struct is a named, non-generic struct (its
    // symbol-id keys the baked value ; `midir` recurses over the same literal).
    if is_bakeable_array(lit) {
        return AggregateDataPoolEntry { .element_type_name = element_name, .literal = lit }
    }
    return null
}

// Recursive bakeability gate. Mirrors `midir/build::lowered_to_bc_value` exactly :
// a node accepted here must be convertible there. Conservative — anything not a
// constant literal / named-struct / array falls through to fn-wrap.
is_bakeable_array :: fn(lit: LoweredArrayLit) -> bool {
    for el in lit.elements {
        if !is_bakeable_value(el) { return false }
    }
    return true
}

is_bakeable_value :: fn(el: LoweredExpr) -> bool {
    if el is LoweredIntLit    { return true }
    if el is LoweredFloatLit  { return true }
    if el is LoweredBoolLit   { return true }
    if el is LoweredCharLit   { return true }
    if el is LoweredStringLit { return true }
    if el is LoweredArrayLit  as a { return is_bakeable_array(a) }
    if el is LoweredStructLit as s { return is_bakeable_struct(s) }
    return false
}

// A named, non-generic struct literal whose fields are all bakeable. Tuples
// (`TupleType`) and generic instances are rejected — the baked struct is resolved
// at the backend by `symbol_id` alone, which a tuple lacks and a generic shares
// across monomorphized instances.
is_bakeable_struct :: fn(s: LoweredStructLit) -> bool {
    if s.type is StructType as st {
        if st.args.len() > 0 { return false }
        for f in s.fields {
            if !is_bakeable_value(f.value) { return false }
        }
        return true
    }
    return false
}

// Collect every element's string value, or null when any element isn't a plain
// string literal (interpolation lowers to a builder, never reaching here).
render_string_items :: fn(lit: LoweredArrayLit) -> string[] | null {
    out: string[] = []
    for el in lit.elements {
        if el is LoweredStringLit as s { out.push(s.value) } else { return null }
    }
    return out
}

// Collect every element's raw bit pattern as `i64`, or null when any element
// isn't a poolable primitive literal (int / char / bool / float). `element_name`
// is the array's element type name — needed to pick the f32 vs f64 width when
// reinterpreting a float literal's IEEE-754 bits.
render_data_items :: fn(lit: LoweredArrayLit, element_name: string) -> i64[] | null {
    out: i64[] = []
    for el in lit.elements {
        bits :: data_item_bits(el, element_name)
        if bits == null { return null }
        out.push(bits)
    }
    return out
}

// Raw `i64` bit pattern of a poolable primitive literal, or null otherwise.
// Floats are reinterpreted via `to_bits()` at the element's natural width
// (`f32` keeps the low 32 bits), matching `vm/virt_reader_bc::value_from_bits`.
data_item_bits :: fn(el: LoweredExpr, element_name: string) -> i64 | null {
    if el is LoweredIntLit as i  { return i.value }
    if el is LoweredCharLit as c { return i64(c.value) }
    if el is LoweredBoolLit as b { return if b.value { 1 } else { 0 } }
    if el is LoweredFloatLit as f {
        if element_name == "f32" { return i64(u64(f32(f.value).to_bits())) }
        return i64(f.value.to_bits())
    }
    return null
}

// The accessor fn's symbol, carrying a FRESH synthetic id (`synth_id`, always
// negative) — distinct from the const's own id, so it can never collide with a
// real symbol id in the DCE's by-id index. (Reusing the const id, the prior
// design, let an unrelated id shift collide the accessor with another symbol,
// so the DCE dropped it and the emit hit a dangling `__const_*` callee — GATE
// B1.) The lowered DCE seeds every accessor as a root ; `build_const_ref` emits
// each const reference as a 0-arg `call` to this symbol.
const_accessor_symbol :: fn(orig_sym: Symbol, synth_id: i32) -> Symbol = Symbol {
    .id         = synth_id,
    .kind       = SymbolKind.Fn,
    .name       = "__const_${orig_sym.name}",
    .module     = orig_sym.module,
    .visibility = AST.Visibility.Private,
    .defined_at = orig_sym.defined_at,
}

// Build the synthetic 0-arg accessor fn for a fn-wrapped const. Mirror of TS's
// `synthesizeFnFromConst` : the body is a block whose trailing expression is
// the const's value, and the origin reuses the const's MonoEntry with the
// symbol swapped for the `fn_symbol` built by `const_accessor_symbol`.
synthesize_const_fn :: fn(cd: LoweredConstDecl, fn_symbol: Symbol) -> LoweredFnDecl {
    synth_entry :: MonoEntry {
        .id             = cd.origin.id,
        .is_main        = false,
        .mangled        = cd.origin.mangled,
        .decl           = cd.origin.decl,
        .symbol         = fn_symbol,
        .subst          = cd.origin.subst,
        .type_arguments = cd.origin.type_arguments,
        .module         = cd.origin.module,
    }
    no_stmts: LoweredStmt[] = []
    no_params: LoweredParam[] = []
    return LoweredFnDecl {
        .mangled     = "__const_${cd.mangled}",
        .params      = no_params,
        .return_type = cd.type,
        .body        = LoweredBlock {
            .span     = span_of(cd.value),
            .type     = cd.type,
            .stmts    = no_stmts,
            .trailing = cd.value,
        },
        .origin = synth_entry,
    }
}
