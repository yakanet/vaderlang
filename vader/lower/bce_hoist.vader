// vader/lower/bce_hoist — post-inline BCE (bounds-check elimination) tagging pass.
//
// The loop desugars (foreach `try_lower_for_in_raw_array`, int-range
// `try_lower_for_in_int_range`, and iterator fusion `emit_fused_array`) all
// lower to a counter loop that runs `0..<len(arr)` over an array and indexes
// `arr[idx]`. Each marks the `arr.len()` bound it emits with
// `LoweredArrayLen.bce_recheck` and (foreach / fusion) its synthesized
// `arr[idx]` access with `LoweredIndex.bce_recheck`, but DEFERS the safety
// decision to this pass.
//
// Why post-inline : a `for x in a.map(f)` / a `for x in a { helper(x) }` body
// is, at desugar time, an INDIRECT call (fn-value) or a direct call not yet
// inlined — `bce_block_unsafe` would flag it and bail. `bce_hoist_tag` runs
// AFTER `devirtualize_fn_refs` + `inline_fns` (see `lower.vader`), so a pure
// callback / inlinable helper has become its inlined body and proves safe. No
// combinator is special-cased : the decision is purely "does the inlined loop
// body allocate / call / yield / rebind the array ?" (`bce_block_unsafe`,
// `vader/lower/lower_for_in.vader`).
//
// When safe : the `arr.len()` bound's `resolve_buf` is set (the C backend then
// resolves + PINS arr's buffer in the preheader, and the body's `arr[idx]`
// accesses reuse it — the measured lever), and each synthesized `arr[idx]` has
// its bounds check elided. The `bce_recheck` markers are consumed here and never
// reach codegen. Mutates the lowered tree in place (like `devirtualize_fn_refs`).

module "vader/lower"

import "std/collections"

/// Project-wide purity memo, shared across the whole pass. A callee is resolved
/// to its decl the same two ways the backend does (`midir/emit.vader`, and the
/// sibling walk in `dce.vader`): by mangle (impl-member calls carry the mangle in
/// `symbol.name`) then by definition symbol id (bare free-fn calls carry it in
/// `symbol.id`). `memo` caches `bce_fn_pure` verdicts keyed by mangle, and doubles
/// as the recursion-cycle guard : a fn is stamped impure on entry (a re-entrant
/// query reads that) and overwritten with its real verdict before returning.
BcePurityCtx :: struct {
    by_mangle: MutableMap<string, LoweredFnDecl>
    by_symid:  MutableMap<i32, LoweredFnDecl>
    memo:      MutableMap<string, bool>
}

/// Resolve a call's callee `(name, sym_id)` to its decl — mangle first, then the
/// definition symbol id — or `null` for an unresolved / `@extern` callee.
bce_resolve_fn :: fn(pctx: BcePurityCtx, name: string, sym_id: i32) -> LoweredFnDecl | null {
    m :: pctx.by_mangle[name]
    if m != null {
        return m
    }
    return pctx.by_symid[sym_id]
}

/// Is `fd` provably free of allocation / GC-safepoints — its body allocates
/// nothing (no literal / push / slice / closure), suspends nowhere (no yield /
/// await / defer), and calls ONLY other pure fns ? Memoised by mangle. A bodyless
/// (`@extern`) fn and any recursion cycle are conservatively impure. This is what
/// makes `bce_call_unsafe` accept a pure callback (`a.map(square)`) without naming
/// any combinator.
bce_fn_pure :: fn(pctx: BcePurityCtx, fd: LoweredFnDecl) -> bool {
    key :: fd.mangled
    cached :: pctx.memo[key]
    if cached != null {
        return cached
    }
    body :: fd.body
    if body == null {
        return false
    }
    // Stamp impure BEFORE walking : a re-entrant (recursive) query hits this and
    // gets `false` — a cycle can't be proven pure. The real verdict overwrites it
    // below, so no non-cyclic caller ever reads the sentinel.
    pctx.memo[key] = false
    result :: !bce_block_unsafe(body, -1, pctx)
    pctx.memo[key] = result
    return result
}

// Index every fn decl by mangle, and non-generic-instance fns also by definition
// symbol id, for `bce_resolve_fn`. Mangles are unique ; symbol ids are NOT — a
// generic's monomorphic instances all share the generic's symbol id, so indexing
// an instance by symid would collide (last-wins) and could resolve a callee to the
// WRONG instance. Same rule as `dce.vader`. An instance is therefore only reachable
// via its (unique) mangle ; a symid-only callee that misses stays conservatively
// impure — never mis-resolved to a sibling with a different purity.
bce_build_purity_ctx :: fn(project: LoweredProject) -> BcePurityCtx {
    by_mangle :: MutableMap<string, LoweredFnDecl> {}
    by_symid :: MutableMap<i32, LoweredFnDecl> {}
    for [_, m] in project.modules {
        for d in m.decls {
            if d is LoweredFnDecl as fd {
                by_mangle[fd.mangled] = fd
                s :: fd.origin.symbol
                if s != null && fd.origin.type_arguments.len() == 0 {
                    by_symid[s.id] = fd
                }
            }
        }
    }
    return BcePurityCtx {
        .by_mangle = by_mangle, .by_symid = by_symid,
        .memo = MutableMap<string, bool> {},
    }
}

/// Run the BCE tagging pass over every function body in `project`. Idempotent
/// per node (each `bce_recheck` marker is cleared once consumed).
export bce_hoist_tag :: fn(project: LoweredProject) -> void {
    pctx :: bce_build_purity_ctx(project)
    for [_, m] in project.modules {
        for d in m.decls {
            if d is LoweredFnDecl as fd {
                body :: fd.body
                if body != null {
                    bh_block(body, pctx)
                }
            }
        }
    }
}

// ---- descent : reach every block, pair a recheck-len with its sibling loop ----

bh_block :: fn(b: LoweredBlock, pctx: BcePurityCtx) -> void {
    for st in b.stmts {
        bh_stmt(st, pctx)
    }
    trailing :: b.trailing
    if trailing != null {
        bh_expr(trailing, pctx)
    }
    bh_pair(b, pctx)
}

bh_stmt :: fn(s: LoweredStmt, pctx: BcePurityCtx) -> void {
    if s is LoweredLet as st {
        bh_expr(st.value, pctx)
    } else if s is LoweredAssign as st {
        bh_expr(st.target, pctx)
        bh_expr(st.value, pctx)
    } else if s is LoweredCellSet as st {
        bh_expr(st.target, pctx)
        bh_expr(st.value, pctx)
    } else if s is LoweredExprStmt as st {
        bh_expr(st.expr, pctx)
    } else if s is LoweredReturn as st {
        v :: st.value
        if v != null {
            bh_expr(v, pctx)
        }
    } else if s is LoweredYield as st {
        bh_expr(st.value, pctx)
    } else if s is LoweredAwait as st {
        bh_expr(st.awaited, pctx)
    } else if s is LoweredLoop as st {
        c :: st.cond
        if c != null {
            bh_expr(c, pctx)
        }
        bh_block(st.body, pctx)
    } else if s is LoweredDeferPush as st {
        bh_expr(st.thunk, pctx)
    }
    // Break / Continue / DeferPopExec : no nested block.
}

bh_expr :: fn(e: LoweredExpr, pctx: BcePurityCtx) -> void {
    if e is LoweredBlock as x {
        bh_block(x, pctx)
    } else if e is LoweredIf as x {
        bh_expr(x.cond, pctx)
        bh_block(x.then_block, pctx)
        eb :: x.else_block
        if eb != null {
            bh_block(eb, pctx)
        }
    } else if e is LoweredBinary as x {
        bh_expr(x.left, pctx)
        bh_expr(x.right, pctx)
    } else if e is LoweredUnary as x {
        bh_expr(x.operand, pctx)
    } else if e is LoweredCast as x {
        bh_expr(x.value, pctx)
    } else if e is LoweredTypeCheck as x {
        bh_expr(x.value, pctx)
    } else if e is LoweredIndex as x {
        bh_expr(x.target, pctx)
        bh_expr(x.index, pctx)
    } else if e is LoweredFieldAccess as x {
        bh_expr(x.target, pctx)
    } else if e is LoweredArrayLen as x {
        bh_expr(x.target, pctx)
    } else if e is LoweredCall as x {
        bh_expr(x.callee, pctx)
        for a in x.args {
            bh_expr(a, pctx)
        }
    } else if e is LoweredVirtualCall as x {
        bh_expr(x.receiver, pctx)
        for a in x.args {
            bh_expr(a, pctx)
        }
    } else if e is LoweredIntrinsicCall as x {
        for a in x.args {
            bh_expr(a, pctx)
        }
    } else if e is LoweredStructLit as x {
        for f in x.fields {
            bh_expr(f.value, pctx)
        }
    } else if e is LoweredArrayLit as x {
        for el in x.elements {
            bh_expr(el, pctx)
        }
    } else if e is LoweredArrayPush as x {
        bh_expr(x.target, pctx)
        bh_expr(x.value, pctx)
    } else if e is LoweredArraySlice as x {
        bh_expr(x.target, pctx)
        bh_expr(x.lo, pctx)
        bh_expr(x.hi, pctx)
    } else if e is LoweredStringSlice as x {
        bh_expr(x.target, pctx)
        bh_expr(x.lo, pctx)
        bh_expr(x.hi, pctx)
    } else if e is LoweredCellNew as x {
        bh_expr(x.value, pctx)
    } else if e is LoweredCellGet as x {
        bh_expr(x.target, pctx)
    } else if e is LoweredMakeClosure as x {
        bh_expr(x.env, pctx)
    }
    // Leaves (lits / ident / data-const / unreachable / type-const) : nothing.
}

// In block `b`, find a `let __ = arr.len()` marked `bce_recheck` and a sibling
// loop. If the loop body is BCE-safe (no alloc / impure call / yield / rebind of
// arr), hoist arr's resolve (`resolve_buf`) and elide the synthesized `arr[idx]`
// checks.
bh_pair :: fn(b: LoweredBlock, pctx: BcePurityCtx) -> void {
    the_len: LoweredArrayLen | null = null
    for st in b.stmts {
        if st is LoweredLet as ll {
            if ll.value is LoweredArrayLen as al {
                if al.bce_recheck {
                    the_len = al
                }
            }
        }
    }
    if the_len == null {
        return
    }
    the_loop: LoweredLoop | null = null
    for st in b.stmts {
        if st is LoweredLoop as lp {
            the_loop = lp
        }
    }
    the_len.bce_recheck = false
    if the_loop == null {
        return
    }
    // Guard on the bound array's symbol : rebinding it (`arr = other`) would leave
    // the pinned resolve stale. Synthetic (foreach / fusion) arrays are never
    // rebound, so this is a no-op there ; for an int-range `0..<a.len()` it catches
    // a user rebind of `a`.
    guard :: bh_guard_sym(the_len)
    if bce_block_unsafe(the_loop.body, guard, pctx) {
        return
    }
    the_len.resolve_buf = true
    bh_mark_idx_block(the_loop.body)
}

bh_guard_sym :: fn(al: LoweredArrayLen) -> i32 {
    if al.target is LoweredIdent as id {
        return id.symbol.id
    }
    return -1
}

// ---- mark synthesized `arr[idx]` accesses bounds-safe (this loop only) --------
// Walks the loop body setting `bounds_safe` on every `bce_recheck` LoweredIndex,
// but does NOT descend into a nested LoweredLoop — a nested loop's accesses belong
// to its own (separately paired) len bound.

bh_mark_idx_block :: fn(b: LoweredBlock) -> void {
    for st in b.stmts {
        bh_mark_idx_stmt(st)
    }
    trailing :: b.trailing
    if trailing != null {
        bh_mark_idx_expr(trailing)
    }
}

bh_mark_idx_stmt :: fn(s: LoweredStmt) -> void {
    if s is LoweredLet as st {
        bh_mark_idx_expr(st.value)
    } else if s is LoweredAssign as st {
        bh_mark_idx_expr(st.target)
        bh_mark_idx_expr(st.value)
    } else if s is LoweredCellSet as st {
        bh_mark_idx_expr(st.target)
        bh_mark_idx_expr(st.value)
    } else if s is LoweredExprStmt as st {
        bh_mark_idx_expr(st.expr)
    } else if s is LoweredReturn as st {
        v :: st.value
        if v != null {
            bh_mark_idx_expr(v)
        }
    } else if s is LoweredYield as st {
        bh_mark_idx_expr(st.value)
    } else if s is LoweredAwait as st {
        bh_mark_idx_expr(st.awaited)
    } else if s is LoweredDeferPush as st {
        bh_mark_idx_expr(st.thunk)
    }
    // LoweredLoop : NOT descended (nested loop owns its own accesses).
    // Break / Continue / DeferPopExec : nothing.
}

bh_mark_idx_expr :: fn(e: LoweredExpr) -> void {
    if e is LoweredIndex as x {
        if x.bce_recheck {
            x.bounds_safe = true
            x.bce_recheck = false
        }
        bh_mark_idx_expr(x.target)
        bh_mark_idx_expr(x.index)
    } else if e is LoweredBlock as x {
        bh_mark_idx_block(x)
    } else if e is LoweredIf as x {
        bh_mark_idx_expr(x.cond)
        bh_mark_idx_block(x.then_block)
        eb :: x.else_block
        if eb != null {
            bh_mark_idx_block(eb)
        }
    } else if e is LoweredBinary as x {
        bh_mark_idx_expr(x.left)
        bh_mark_idx_expr(x.right)
    } else if e is LoweredUnary as x {
        bh_mark_idx_expr(x.operand)
    } else if e is LoweredCast as x {
        bh_mark_idx_expr(x.value)
    } else if e is LoweredTypeCheck as x {
        bh_mark_idx_expr(x.value)
    } else if e is LoweredFieldAccess as x {
        bh_mark_idx_expr(x.target)
    } else if e is LoweredArrayLen as x {
        bh_mark_idx_expr(x.target)
    } else if e is LoweredCall as x {
        bh_mark_idx_expr(x.callee)
        for a in x.args {
            bh_mark_idx_expr(a)
        }
    } else if e is LoweredVirtualCall as x {
        bh_mark_idx_expr(x.receiver)
        for a in x.args {
            bh_mark_idx_expr(a)
        }
    } else if e is LoweredIntrinsicCall as x {
        for a in x.args {
            bh_mark_idx_expr(a)
        }
    } else if e is LoweredCellNew as x {
        bh_mark_idx_expr(x.value)
    } else if e is LoweredCellGet as x {
        bh_mark_idx_expr(x.target)
    }
    // Leaves + array/struct literals / slices / closures : a synthesized loop-var
    // access never nests there, so no descent needed.
}

// ---- tests ----------------------------------------------------------------

import "std/testing"
import "vader/diagnostics"
import "vader/types"
import "vader/resolver/symbol"
import "vader/typecheck"
import "vader/comptime"
AST :: import "vader/parser"

// Minimal fixtures. `bce_fn_pure` reads only `fd.mangled` + `fd.body` and, via
// the ctx, resolves callees by mangle / symbol id — the rest of the MonoEntry /
// LoweredFnDecl shape is inert filler here.

bce_test_ctx :: fn() -> BcePurityCtx = BcePurityCtx {
    .by_mangle = MutableMap<string, LoweredFnDecl> {},
    .by_symid = MutableMap<i32, LoweredFnDecl> {},
    .memo = MutableMap<string, bool> {},
}

bce_test_sym :: fn(id: i32, name: string) -> Symbol = Symbol {
    .id = id, .kind = SymbolKind.Fn, .name = name, .module = "test",
    .visibility = AST.Visibility.Private, .defined_at = null,
}

bce_test_fn :: fn(sym: Symbol, body: LoweredBlock | null) -> LoweredFnDecl {
    // MonoEntry shape mirrors `synth_mono_entry` (lower_lambda.vader) — kept inline
    // because that helper needs a FnLowerCtx the fixture deliberately doesn't build.
    entry :: MonoEntry {
        .id = sym.id, .is_main = false, .mangled = sym.name,
        .decl = stub_decl_for(sym), .symbol = sym, .subst = new_substitution(),
        .type_arguments = [], .module = null,
    }
    return LoweredFnDecl {
        .mangled = sym.name, .params = [], .return_type = TY_VOID,
        .body = body, .origin = entry,
    }
}

bce_test_block :: fn(stmts: LoweredStmt[]) -> LoweredBlock = LoweredBlock {
    .span = empty_span(), .type = TY_VOID, .stmts = stmts, .trailing = null,
}

// `return 0` — no allocation, no call : pure.
bce_test_pure_return :: fn() -> LoweredStmt = LoweredReturn {
    .span = empty_span(),
    .value = LoweredIntLit { .span = empty_span(), .type = TY_VOID, .value = 0 },
}

// `return [0]` — an array literal allocates : impure.
bce_test_alloc_return :: fn() -> LoweredStmt = LoweredReturn {
    .span = empty_span(),
    .value = LoweredArrayLit {
        .span = empty_span(), .type = TY_VOID,
        .elements = [LoweredIntLit { .span = empty_span(), .type = TY_VOID, .value = 0 }],
    },
}

// `return callee()` — a bare call to `callee`.
bce_test_call_return :: fn(callee: Symbol) -> LoweredStmt = LoweredReturn {
    .span = empty_span(),
    .value = LoweredCall {
        .span = empty_span(), .type = TY_VOID,
        .callee = LoweredIdent { .span = empty_span(), .type = TY_VOID, .symbol = callee },
        .args = [],
    },
}

// Register a callee both ways `bce_resolve_fn` looks it up.
bce_test_register :: fn(ctx: BcePurityCtx, fd: LoweredFnDecl) -> void {
    ctx.by_mangle[fd.mangled] = fd
    s :: fd.origin.symbol
    if s != null {
        ctx.by_symid[s.id] = fd
    }
}

@test test_bce_fn_pure_pure_body :: fn() -> void {
    fd :: bce_test_fn(bce_test_sym(1, "pure"), bce_test_block([bce_test_pure_return()]))
    assert(bce_fn_pure(bce_test_ctx(), fd), "a non-allocating body is pure")
}

@test test_bce_fn_pure_allocating_body :: fn() -> void {
    fd :: bce_test_fn(bce_test_sym(2, "alloc"), bce_test_block([bce_test_alloc_return()]))
    assert(!bce_fn_pure(bce_test_ctx(), fd), "an allocating body is impure")
}

@test test_bce_fn_pure_extern_body :: fn() -> void {
    fd :: bce_test_fn(bce_test_sym(3, "ext"), null)
    assert(!bce_fn_pure(bce_test_ctx(), fd), "a bodyless (@extern) fn is conservatively impure")
}

@test test_bce_fn_pure_memoises_verdict :: fn() -> void {
    fd :: bce_test_fn(bce_test_sym(4, "memo"), bce_test_block([bce_test_pure_return()]))
    ctx :: bce_test_ctx()
    assert(bce_fn_pure(ctx, fd), "first call computes the verdict")
    assert(bce_fn_pure(ctx, fd), "second call returns the same verdict via the memo")
    cached :: ctx.memo["memo"]
    if cached != null {
        assert(cached, "the memoised verdict is `pure`")
    } else {
        assert(false, "the verdict must have been memoised")
    }
}

@test test_bce_fn_pure_call_to_pure_callee :: fn() -> void {
    leaf_sym :: bce_test_sym(10, "leaf")
    leaf :: bce_test_fn(leaf_sym, bce_test_block([bce_test_pure_return()]))
    caller :: bce_test_fn(bce_test_sym(11, "caller"), bce_test_block([bce_test_call_return(leaf_sym)]))
    ctx :: bce_test_ctx()
    bce_test_register(ctx, leaf)
    assert(bce_fn_pure(ctx, caller), "calling a pure fn keeps the caller pure")
}

@test test_bce_fn_pure_call_to_impure_callee :: fn() -> void {
    leaf_sym :: bce_test_sym(20, "leaf_alloc")
    leaf :: bce_test_fn(leaf_sym, bce_test_block([bce_test_alloc_return()]))
    caller :: bce_test_fn(bce_test_sym(21, "caller_impure"), bce_test_block([bce_test_call_return(leaf_sym)]))
    ctx :: bce_test_ctx()
    bce_test_register(ctx, leaf)
    assert(!bce_fn_pure(ctx, caller), "calling an allocating fn makes the caller impure")
}

@test test_bce_fn_pure_unresolved_callee :: fn() -> void {
    // Callee absent from the ctx (an @extern / unknown fn) : the call is unsafe.
    ghost_sym :: bce_test_sym(30, "ghost")
    caller :: bce_test_fn(bce_test_sym(31, "caller_ghost"), bce_test_block([bce_test_call_return(ghost_sym)]))
    assert(!bce_fn_pure(bce_test_ctx(), caller), "an unresolved callee is treated as impure")
}

@test test_bce_fn_pure_recursive_fn :: fn() -> void {
    // `rec` calls itself : the memo sentinel (impure-on-entry) breaks the cycle and
    // reports it impure rather than recursing forever.
    rec_sym :: bce_test_sym(40, "rec")
    rec :: bce_test_fn(rec_sym, bce_test_block([bce_test_call_return(rec_sym)]))
    ctx :: bce_test_ctx()
    bce_test_register(ctx, rec)
    assert(!bce_fn_pure(ctx, rec), "a recursion cycle is conservatively impure")
}
