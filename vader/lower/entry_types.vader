// vader/lower/entry_types — type-table accessor for a lowering pass.
//
// Hides the `(TypedProgram,
// Substitution)` pair behind a single accessor — lower passes call
// `expr_type(view, e)` rather than `substitute(typed.expr_types[e.id]
// ?? TY_UNRESOLVED, subst)`. The boundary lets future changes (e.g.
// materialising substituted bodies on `MonoEntry`) touch one file.

module "vader/lower"

import "std/collections" { MutableMap }
import "vader/diagnostics" { Span }
import "vader/parser" {
    Expr, TypeExpr, SimpleBinding, RestBinding, FnParam,
    FnDecl, StructDecl, ConstDecl,
}
import "vader/types" { Type, TY_UNRESOLVED }
import "vader/typecheck" { TypedProgram }
import "vader/typecheck" { Substitution, substitute, is_empty_substitution }

/// Per-entry view over the typed program with substitution applied at
/// every read. The struct holds both inputs ; the accessor functions
/// short-circuit when `subst` is empty.
export EntryTypes :: struct {
    typed: TypedProgram
    subst: Substitution
}

/// Build an `EntryTypes` view for `(typed, subst)`.
/// @param typed  the module's typed program.
/// @param subst  the entry's substitution (may be empty).
/// @return       a fresh view.
export make_entry_types :: fn(typed: TypedProgram, subst: Substitution) -> EntryTypes {
    return EntryTypes { .typed = typed, .subst = subst }
}

/// Apply the entry's substitution to an arbitrary type. No-op when the
/// substitution is empty (the common case for non-generic decls).
/// @param self  the entry-types view.
/// @param t     the type to rewrite.
/// @return      the rewritten type (may be `t` itself).
export apply :: fn(self: EntryTypes, t: Type) -> Type {
    if is_empty_substitution(self.subst) { return t }
    return substitute(t, self.subst)
}

// Apply the entry's substitution to a `Type | null` lookup result,
// falling back to `TY_UNRESOLVED` on misses. The lookup-and-substitute
// pattern repeats across every per-table accessor — centralised here
// so a future side-table rekey only touches one match site.
apply_or_unresolved :: fn(self: EntryTypes, raw: Type | null) -> Type {
    if raw is null { return TY_UNRESOLVED }
    return apply(self, raw)
}

/// Per-expression type, with substitution applied. Falls back to
/// `TY_UNRESOLVED` when the node has no recorded type (matches the
/// inline lookups it replaces).
/// @param self  the entry-types view.
/// @param expr  the AST expression node.
/// @return      the resolved type.
export expr_type :: fn(self: EntryTypes, expr: Expr) -> Type {
    return apply_or_unresolved(self, self.typed.expr_types[expr.id])
}

/// Per-expression type WITHOUT applying the entry substitution — the raw
/// recorded signature. Needed where a type-param must stay visible despite the
/// entry's subst binding it: a self-recursive generic call's callee resolves to
/// the very fn being instantiated, so its `T` is in `subst`; the substituting
/// `expr_type` concretises `T` and hides the genericity, mis-routing the call
/// away from the instance mangle (GATE-B1). Use is deliberately narrow — only
/// `try_lower_generic_fn_call`'s self-recursion retry calls it. The substituting
/// `expr_type` stays the default everywhere else; reading raw broadly would
/// change non-self-recursive generic-call routing (the typer can record a callee
/// type carrying the enclosing fn's type-param).
/// @param self  the entry-types view.
/// @param expr  the AST expression node.
/// @return      the recorded type, no substitution applied; `TY_UNRESOLVED`
///              on a miss.
export raw_expr_type :: fn(self: EntryTypes, expr: Expr) -> Type {
    raw :: self.typed.expr_types[expr.id]
    if raw is null { return TY_UNRESOLVED }
    return raw
}

/// Per-local-binding type. Same fallback convention as `expr_type`.
/// @param self     the entry-types view.
/// @param binding  the `SimpleBinding` AST node.
/// @return         the resolved type.
export local_type :: fn(self: EntryTypes, binding: SimpleBinding) -> Type {
    return apply_or_unresolved(self, self.typed.local_types[binding.span.hash()])
}

/// Per-rest-binding type (rest pattern in destructure).
/// @param self     the entry-types view.
/// @param binding  the `RestBinding` AST node.
/// @return         the resolved type.
export rest_local_type :: fn(self: EntryTypes, binding: RestBinding) -> Type {
    return apply_or_unresolved(self, self.typed.local_types[binding.span.hash()])
}

/// Per-fn-param type.
/// @param self   the entry-types view.
/// @param param  the `FnParam` AST node.
/// @return       the resolved type.
export param_type :: fn(self: EntryTypes, param: FnParam) -> Type {
    return apply_or_unresolved(self, self.typed.param_types[param.span.hash()])
}

/// Per-type-expression type.
/// @param self       the entry-types view.
/// @param type_expr  the `TypeExpr` AST node.
/// @return           the resolved type.
export type_expr_type :: fn(self: EntryTypes, type_expr: TypeExpr) -> Type {
    return apply_or_unresolved(self, self.typed.type_expr_types[type_expr.span.hash()])
}

/// Per-fn-decl type. `decl_types` is Symbol.id-keyed, so we resolve
/// the matching symbol from `resolved.symbols` first. Overloaded fns
/// share a name ; match by span via `fn_overloads`.
export fn_decl_type :: fn(self: EntryTypes, decl: FnDecl) -> Type {
    return fn_decl_type_by_span(self, decl.name, decl.name_span)
}

export struct_decl_type :: fn(self: EntryTypes, decl: StructDecl) -> Type {
    return decl_type_by_name(self, decl.name)
}

export const_decl_type :: fn(self: EntryTypes, decl: ConstDecl) -> Type {
    return decl_type_by_name(self, decl.name)
}

decl_type_by_name :: fn(self: EntryTypes, name: string) -> Type {
    for s in self.typed.resolved.symbols {
        if s.name == name {
            return apply_or_unresolved(self, self.typed.decl_types[s.id])
        }
    }
    return apply_or_unresolved(self, null)
}

fn_decl_type_by_span :: fn(self: EntryTypes, name: string, name_span: Span) -> Type {
    bucket :: self.typed.resolved.fn_overloads[name]
    match bucket {
        is null -> {}
        _ -> {
            for s in bucket {
                sp :: s.defined_at
                if sp is null { continue }
                if sp.start.line == name_span.start.line &&
                   sp.start.column == name_span.start.column {
                    return apply_or_unresolved(self, self.typed.decl_types[s.id])
                }
            }
        }
    }
    return decl_type_by_name(self, name)
}


// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }
import "vader/typecheck" { empty_typed_program }
import "vader/typecheck" { new_substitution }
import "vader/types" {
    mk_primitive, mk_array, mk_type_param, display_type,
}
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/parser" { Visibility }

@test test_apply_is_identity_under_empty_subst :: fn() -> void {
    typed :: empty_typed_program()
    view  :: make_entry_types(typed, new_substitution())
    same  :: apply(view, mk_primitive("i64"))
    assert_eq(display_type(same), "i64")
}

@test test_apply_substitutes_type_param :: fn() -> void {
    typed :: empty_typed_program()
    subst :: new_substitution()
    symbol :: Symbol {
        .id         = 11,
        .kind       = SymbolKind.TypeParam,
        .name       = "T",
        .module     = "test",
        .visibility = Visibility.Private,
        .defined_at = null,
    }
    subst.type_params[11] = mk_primitive("string")
    view :: make_entry_types(typed, subst)
    rewritten :: apply(view, mk_array(mk_type_param(symbol), false))
    assert_eq(display_type(rewritten), "string[]")
}
