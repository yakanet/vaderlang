// vader/lower/lower_populate — populate the LowerProjectCtx side-tables.
//

module "vader/lower"

import "std/collections" { MutableMap, values }

import "vader/resolver" { LoadedProject, ResolvedModule }
import "vader/typecheck" { TypedProject, build_impl_registry }
import "vader/comptime" { EvaluatedProgram, ComptimeValue }
import "vader/resolver/symbol" { Symbol }

// Populate `core_symbols` from std/core's resolved view so the lowerer can
// resolve `Range`, `Yield`, `ArrayIterator`, `Iterator`, `Display`, `Error`,
// … without re-walking the project per call. Per-module export lookups
// (std/iter's `MappedIterator`, std/string's `bytes`, …) go through the lazy
// `module_export` below instead of dedicated per-module tables.
populate_core_symbols :: fn(typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for [_, module_typed] in typed.modules {
        // `core_symbols` on `ResolvedModule` carries cross-module
        // auto-import bindings — std/core's own entry has its
        // exported symbols here. Iterate every module's table and
        // copy into the project context ; std/core's entries
        // dominate since every module imports them.
        for [symbol_name, symbol] in module_typed.resolved.core_symbols {
            project_ctx.core_symbols[symbol_name] = symbol
        }
    }
}

// Resolve a top-level export of a stdlib module by display path + name, e.g.
// `module_export(ctx, "std/iter", "MappedIterator")`. Backs the for-in chain
// fusion + MutableMap/Set inline + `s.bytes().len()` peephole + `${…}`→
// StringBuilder desugar, which each used to carry a hardcoded per-module
// symbol table. Lazily caches one `name -> Symbol` map per path (merging
// every module sharing the path), keyed on the exact logical `display_path`
// (a `module_id` substring match is fragile — it broke when a module moved
// to a per-file subfolder, and `std/string` would match `std/string_builder`).
// Returns null when the module isn't loaded or has no such export, so the
// gated peepholes simply don't fire.
module_export :: fn(ctx: LowerProjectCtx, display_path: string, name: string) -> Symbol | null {
    cached :: ctx.module_symbol_cache[display_path]
    if cached != null { return cached[name] }
    table :: MutableMap<string, Symbol> {}
    for [_, module_typed] in ctx.typed.modules {
        if module_typed.resolved.display_path != display_path { continue }
        for entry in module_typed.resolved.symbols {
            table[entry.name] = entry
        }
    }
    ctx.module_symbol_cache[display_path] = table
    return table[name]
}

populate_comptime_value_index :: fn(project_ctx: LowerProjectCtx) -> void {
    // Flatten every loaded module's `comptime_decls` into one global
    // `symbol_id -> ComptimeValue` map. Const symbol ids are project-
    // unique (resolver mints from a single counter), so no module can
    // collide with another — direct assignment is safe.
    for [_, ep] in project_ctx.evaluated.modules {
        for [symbol_id, v] in ep.comptime_decls {
            project_ctx.comptime_value_by_symbol_id[symbol_id] = v
        }
    }
    // Merge `@file`-baked const values from the project-level table.
    // Kept separate from per-module `comptime_decls` so the comptime
    // dump doesn't show these as `@comptime`-decorated, but the lower
    // still inlines them at use sites.
    for [symbol_id, v] in project_ctx.evaluated.file_baked_consts {
        project_ctx.comptime_value_by_symbol_id[symbol_id] = v
    }
}

// Aggregate every loaded module's impl decls into the project ctx's
// registry. `build_impl_registry` works per-module ; we drain every
// resulting entry into `project_ctx.impls.all` (+ rekey `user_index`
// by `for_symbol.id::trait_symbol.id`, same as the per-module shape).
populate_impls :: fn(loaded: LoadedProject, typed: TypedProject, project_ctx: LowerProjectCtx) -> void {
    for [module_id, module_typed] in typed.modules {
        module_loaded :: loaded.modules[module_id]
        if module_loaded is null { continue }
        module_decls_list :: module_decls(module_loaded)
        per_module :: build_impl_registry(module_decls_list, module_typed.resolved)
        for entry in per_module.all {
            project_ctx.impls.all.push(entry)
            match entry.for_symbol {
                is null -> {}
                is Symbol as for_symbol -> {
                    key :: "${for_symbol.id}::${entry.trait_symbol.id}"
                    project_ctx.impls.user_index[key] = entry
                }
            }
        }
    }
}
