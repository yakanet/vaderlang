// vader/lower/lower_async ŌĆö the `async` state-machine desugar (Phase 1).
//
// Called from `lower_fn_decl` for a non-generic `async` fn. Takes the body
// lowered in async mode (so every `await e` has been hoisted to a transient
// `LoweredAwait` statement by the ANF sink in `lower_expr` / `lower_block`) and
// produces, per async fn `f`:
//
//   1. a synthesized `__asyncstate_<n>` struct ŌĆö every param + every spilled
//      local (v1: spill-all) + a single erased `awaited: Async<Any>` slot (the
//      child currently being driven) + a `state: i32` resume discriminant;
//   2. a synthesized `<module>$<State>$Async$resume` fn whose body is the
//      resumable state machine `loop { if self.state == 0 { ŌĆ” } else if ŌĆ” }`,
//      returning `T | Suspended`;
//   3. the rewritten `f` body: `return __asyncstate_<n> { <params>, .awaited =
//      null, .state = entry }`.
//
// The state struct + resume fn are pushed to `project.synth_decls`, drained by
// `lower_module`, and auto-wired into the `Async::resume` vtable by
// `collect_vtable_entries` (which decodes the `$Async$resume` mangle ŌĆö no async-
// specific wiring). The block-split engine (`GenBuild`, states, spill, routing)
// is shared with `generator` via `lower_coroutine.vader` ŌĆö the async seams
// there implement Model A (recursive self-drive): each suspension point stores
// its child once and re-drives it on every `resume`, reading the completed value
// back through the child's own `resume` return channel (no external injection).
// See `.claude/plans/async-await-structured-concurrency.md` ┬¦4 / ┬¦12.

module "vader/lower"

import "vader/parser" { FnDecl, Visibility }
import "vader/types" {
    Type, mk_struct, mk_primitive, mk_trait, TY_VOID, TY_BOOL, TY_ANY, TRAIT_ASYNC, METHOD_RESUME,
    METHOD_CANCEL, STRUCT_SUSPENDED,
}
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/typecheck" { fn_is_async, async_result_arg }
import "std/collections" { MutableMap }
import "vader/diagnostics" { Span }
import "std/abort"

// ---- state-struct synthesis + entry ---------------------------------------

// Build one `$Async$<method>` vtable member of the state struct : the mangle +
// synthetic `Symbol` + `LoweredFnDecl` with `self: state_ty` as param[0] ŌĆö the
// shape `collect_vtable_entries` keys on. Shared by `resume` and `cancel`, which
// differ only in method name, return type, and body (both take the same
// `self_sym` ŌĆö each references it only inside its own body, so the shared symbol
// resolves to each fn's own param slot).
mk_async_method_decl :: fn(
    fn_ctx: FnLowerCtx, module_seg: string, state_sym: Symbol, self_sym: Symbol,
    state_ty: Type, method: string, return_ty: Type, body: LoweredBlock,
) -> LoweredFnDecl {
    mangled :: "${module_seg}$${state_sym.name}$${TRAIT_ASYNC}$${method}"
    sym :: Symbol {
        .id = next_synthetic_id(fn_ctx), .kind = SymbolKind.Fn, .name = mangled,
        .module = fn_ctx.typed.resolved.path, .visibility = Visibility.Private, .defined_at = null,
    }
    return LoweredFnDecl {
        .mangled = mangled,
        .params = [LoweredParam { .name = "self", .symbol = self_sym, .type = state_ty }],
        .return_type = return_ty, .body = body,
        .origin = synth_mono_entry(fn_ctx, sym),
    }
}

// Synthesize + register the `__asyncstate` struct and its `$Async$resume` +
// `$Async$cancel` fns into `project.synth_decls`.
push_async_decls :: fn(
    fn_ctx: FnLowerCtx, state_sym: Symbol, self_sym: Symbol, state_ty: Type,
    resume_ty: Type, resume_body: LoweredBlock, cancel_body: LoweredBlock,
    state_fields: LoweredStructField[],
) -> void {
    module_seg :: mangle_module_id(fn_ctx.typed.resolved.display_path)
    resume_decl :: mk_async_method_decl(fn_ctx, module_seg, state_sym, self_sym, state_ty, METHOD_RESUME, resume_ty, resume_body)
    cancel_decl :: mk_async_method_decl(fn_ctx, module_seg, state_sym, self_sym, state_ty, METHOD_CANCEL, TY_VOID, cancel_body)
    state_decl :: LoweredStructDecl {
        .mangled = state_sym.name, .fields = state_fields,
        .origin = synth_mono_entry(fn_ctx, state_sym),
    }
    fn_ctx.project.synth_decls.push(state_decl)
    fn_ctx.project.synth_decls.push(resume_decl)
    fn_ctx.project.synth_decls.push(cancel_decl)
}

// Fold a fn-root block's trailing expression into a terminating statement, so
// the coroutine block-split (which walks `stmts` only) doesn't drop the implicit
// return. A value result returns the trailing ; a void result runs it for its
// side effect and lets the fall-off completion emit the `null` done-marker.
// A `null` trailing (body ends in an explicit `return`) is left untouched.
async_fold_trailing :: fn(body: LoweredBlock, result_is_void: bool) -> LoweredBlock {
    t :: body.trailing
    if t == null { return body }
    stmts: LoweredStmt[] = []
    for s in body.stmts { stmts.push(s) }
    if result_is_void {
        stmts.push(LoweredExprStmt { .span = body.span, .expr = t })
    } else {
        stmts.push(LoweredReturn { .span = body.span, .value = t })
    }
    return LoweredBlock { .span = body.span, .type = TY_VOID, .stmts = stmts, .trailing = null }
}

// ---- entry ----------------------------------------------------------------

/// Lower an `async` fn to the state-machine form. Synthesizes `__asyncstate`
/// and `<module>$<State>$Async$resume` into `project.synth_decls`, and returns
/// the rewritten `f` body (`return __asyncstate { <args>, .awaited = null,
/// .state = entry }`).
///
/// Handles straight-line awaits, awaits in conditional branches, single + nested
/// loops, `if` / `break` / `continue`, and fallible (`T | Error`) results. v1
/// spills every param + local (no liveness pass) ; generic async fns are out of
/// scope. `await` in a short-circuit operand / loop condition is diagnosed
/// (M5009) by the ANF, not reached here.
///
/// @param fn_ctx        the async fn's fn-lowering context (with `in_async` set).
/// @param fn_decl       the async FnDecl (for its span).
/// @param params        the async fn's lowered params (become frame fields).
/// @param lowered_body  the body lowered in async mode (awaits ŌåÆ `LoweredAwait`).
/// @param result_type   the declared result type `T` (the value `return`
///                      completes with ; the `T` in `T | Suspended`).
/// @param is_main       true for the `async main` entry ŌĆö inline the run-driver
///                      and return `T` (the exit code) instead of the `Async<T>`
///                      frame ; every other async fn returns the frame.
/// @return              the rewritten `f` body.
export lower_async_fn :: fn(
    fn_ctx: FnLowerCtx, fn_decl: FnDecl, params: LoweredParam[],
    lowered_body: LoweredBlock, result_type: Type, is_main: bool,
) -> LoweredBlock {
    span :: fn_decl.span
    i32_ty :: mk_primitive("i32")

    // Frame struct symbol ŌĆö async calls type as the erased `Async<T>`, so no
    // consumer needs a deterministic name (unlike generators, which type the
    // call as the concrete state struct for chaining) ; a fresh lifted symbol
    // suffices. Both the synth `resume` fn's receiver and the body's
    // `return __asyncstate {ŌĆ”}` box use THIS symbol, so the vtable row matches.
    state_sym :: fresh_lifted_symbol_with_prefix(fn_ctx, true, "__async_", "__asyncstate_")
    state_ty :: mk_struct(state_sym, [])
    self_sym :: fresh_synthetic_symbol(fn_ctx, "self")

    suspended_opt :: find_core_type(fn_ctx, STRUCT_SUSPENDED, [])
    if suspended_opt == null { panic("async lowering: `Suspended` core type not found") }
    suspended_ty :: suspended_opt
    async_sym :: find_core_trait(fn_ctx.project, TRAIT_ASYNC)
    if async_sym == null { panic("async lowering: `Async` core trait not found") }
    // The single erased `awaited` slot + the erased result a child `resume`
    // returns through the vtable (its concrete `T' | Suspended` reinterpreted).
    async_any_ty :: mk_trait(async_sym, [TY_ANY])
    resume_erased_ty :: union_of_result_suspended(TY_ANY, suspended_ty)
    // The synth `resume` fn's own return type : `T | Suspended` (flattened). A
    // void result normalizes to `null` (see `async_result_arg`) so a void
    // coroutine completes with the `null` done-marker, never a valueless pop.
    resume_ty :: union_of_result_suspended(async_result_arg(result_type), suspended_ty)

    gb :: GenBuild {
        .self_sym = self_sym, .state_ty = state_ty, .i32_ty = i32_ty,
        .yield_ty = TY_VOID, .span = span,
        .states = [], .field_map = MutableMap<i32, string> {}, .fields = [], .loop_stack = [],
        .fn_ctx = fn_ctx, .is_async = true, .result_ty = result_type,
        .suspended_ty = suspended_ty, .async_any_ty = async_any_ty,
        .resume_erased_ty = resume_erased_ty,
    }
    // A trailing-expression body (implicit return, no `return` keyword) carries
    // its completion value in `body.trailing` ; the block-split only walks
    // `stmts`, so fold the trailing into a terminating statement first ŌĆö else the
    // value is dropped and the machine parks forever. (Generators never hit this:
    // they `yield`, so their trailing is void.)
    body :: async_fold_trailing(lowered_body, gb_result_is_void(gb))

    // Spill: params first, then every local (v1: spill-all) ŌåÆ frame fields.
    for p in params { gb_add_field(gb, p.symbol, p.type) }
    gb_collect_block(gb, body)

    // Route local/param refs to `self.<field>`, then split at awaits into states.
    routed :: gb_route_block(gb, body)
    entry_state :: gb_build(gb, routed)

    // Synthesize the frame struct (spilled fields + optional `__defers` +
    // `awaited` + `state`) and its `$Async$resume` fn.
    state_fields: LoweredStructField[] = []
    for f in gb.fields { state_fields.push(f) }
    if gb.has_defers {
        state_fields.push(LoweredStructField { .name = GB_DEFERS_FIELD, .type = gb_defers_ty() })
    }
    state_fields.push(LoweredStructField { .name = "awaited", .type = async_any_ty })
    state_fields.push(LoweredStructField { .name = "state", .type = i32_ty })
    push_async_decls(fn_ctx, state_sym, self_sym, state_ty, resume_ty, gb_next_body(gb), gb_cancel_body(gb), state_fields)

    // Rewrite `f`'s body: `return __asyncstate { <all fields>, .awaited = null,
    // .state = entry }`. Param fields carry the incoming args (a captured param is
    // cell-wrapped here ŌĆö `gb_param_construct_value`) ; local fields get a zero
    // value (assigned in `resume()` before first read, but `struct.new` needs
    // every field). Field order matches the struct decl.
    nparams :: params.len()
    construct_fields: LoweredStructLitField[] = []
    for idx in 0..<gb.fields.len() {
        f :: gb.fields[idx]
        value :: if idx < nparams {
            gb_param_construct_value(gb, params[idx])
        } else {
            zero_value_lit(span, f.type)
        }
        construct_fields.push(LoweredStructLitField { .name = f.name, .value = value })
    }
    if gb.has_defers {
        construct_fields.push(LoweredStructLitField {
            .name = GB_DEFERS_FIELD,
            .value = LoweredArrayLit { .span = span, .type = gb_defers_ty(), .elements = [] },
        })
    }
    construct_fields.push(LoweredStructLitField {
        .name = "awaited", .value = zero_value_lit(span, async_any_ty),
    })
    construct_fields.push(LoweredStructLitField {
        .name = "state", .value = LoweredIntLit { .span = span, .type = i32_ty, .value = entry_state },
    })
    construct :: LoweredStructLit { .span = span, .type = state_ty, .fields = construct_fields }
    // `async main` : inline the run-driver over the freshly built frame and
    // return the completed `i32`. Every other async fn just returns the frame
    // (the caller's `await` / a driver drives it).
    if is_main {
        return async_main_driver(fn_ctx, construct, async_sym, suspended_ty, resume_ty, result_type, span)
    }
    return LoweredBlock {
        .span = span, .type = TY_VOID,
        .stmts = [LoweredReturn { .span = span, .value = construct }],
        .trailing = null,
    }
}

// The run-driver for an async `main`. When `std/async` is loaded (the program
// imports it ŌĆö which it must to `sleep`), route the frame through its
// park-based `run_async_main` : construct the frame, upcast to `Async<T>`, and
// `return run_async_main(frame)`. That driver blocks on the scheduler between
// re-drives, so a `main` that suspends works. Without `std/async` (a `main` that
// awaits only immediately-ready things), fall back to the inline single-resume
// driver ŌĆö no scheduler dependency, and a stray suspension traps loudly.
async_main_driver :: fn(
    fn_ctx: FnLowerCtx, construct: LoweredExpr, async_sym: Symbol,
    suspended_ty: Type, resume_ty: Type, result_type: Type, span: Span,
) -> LoweredBlock {
    async_ty :: mk_trait(async_sym, [result_type])
    run_sym :: fn_ctx.typed.run_async_main_symbol
    if run_sym != null {
        // Seed `run_async_main`'s materialisation (a synthesised call isn't
        // auto-harvested) and route through it : `return run_async_main(frame)`.
        register_nongeneric_imported_fn(fn_ctx, run_sym)
        call :: LoweredCall {
            .span = span, .type = result_type,
            .callee = LoweredIdent { .span = span, .type = result_type, .symbol = run_sym },
            .args = [LoweredCast { .span = span, .type = async_ty, .value = construct }],
        }
        return LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = [LoweredReturn { .span = span, .value = call }],
            .trailing = null,
        }
    }
    r_sym :: fresh_synthetic_symbol(fn_ctx, "root")
    r_ref :: LoweredIdent { .span = span, .type = resume_ty, .symbol = r_sym }
    // r :: (frame as Async<T>).resume()   (virtual ŌĆö T | Suspended)
    let_r :: LoweredLet {
        .span = span, .name = r_sym.name, .symbol = r_sym, .type = resume_ty,
        .value = LoweredVirtualCall {
            .span = span, .type = resume_ty, .trait_name = TRAIT_ASYNC, .method = METHOD_RESUME,
            .receiver = LoweredCast { .span = span, .type = async_ty, .value = construct }, .args = [],
        },
    }
    // if r is Suspended { trap }   ŌĆö a parked root can't progress in Phase 2a.
    guard :: LoweredIf {
        .span = span, .type = TY_VOID,
        .cond = LoweredTypeCheck { .span = span, .type = TY_BOOL, .value = r_ref, .check_type = suspended_ty },
        .then_block = LoweredBlock {
            .span = span, .type = TY_VOID,
            .stmts = [LoweredExprStmt {
                .span = span,
                .expr = LoweredUnreachable {
                    .span = span, .type = TY_VOID, .trap = true,
                    .reason = "async `main` suspended, but this build has no scheduler (Phase 2b) to resume it",
                },
            }],
            .trailing = null,
        },
        .else_block = null,
    }
    // return cast(r, T)   ŌĆö r is the completed value once past the guard.
    ret :: LoweredReturn { .span = span, .value = LoweredCast { .span = span, .type = result_type, .value = r_ref } }
    return LoweredBlock {
        .span = span, .type = TY_VOID,
        .stmts = [let_r, LoweredExprStmt { .span = span, .expr = guard }, ret],
        .trailing = null,
    }
}
