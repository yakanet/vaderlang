// vader/lower/lower_match — match-expression lowerer.
//
// Mirror of `src/lower/passes/match.ts`. Flattens `match scrutinee { arm... }`
// to a let-bind on the scrutinee + a chain of `if (predicate) <arm-body>`
// blocks. Pattern bindings (`x is T as alias`, `BindingPattern("name")`,
// struct destructure, tuple destructure) are introduced inside the arm
// block so they're scoped per-arm.
//
// Out of scope in Phase 4 : tuple-with-union narrowing (`is null | [a, b]`
// case) — emits a simple sequential check without the union-variant cast.
// The full TS-side `narrowToTupleVariant` lands when the typecheck-side
// `union_variants` accessor surfaces.
//
// Callback parameters break the `lower_expr ↔ lower_match` import
// cycle ; top-level fn-type aliases hit a parser limitation in Vader
// so the shape gets inlined at every site.

module "vader/lower"

import "std/collections" { MutableMap, values }
import "vader/diagnostics" { Span }
import "vader/parser" {
    MatchExpr, MatchArm, Pattern, WildcardPattern, BindingPattern, IsPattern,
    StructPattern, StructPatternField, PatternFieldValue, PatternBinding,
    PatternLiteral, TuplePattern, EnumVariantPattern, LiteralPattern, Expr,
}
import "vader/resolver/symbol" { Symbol }
// `lower_expr` is supplied as a callback ; this breaks the cycle
// between `lower_expr` (which imports this module) and the body of
// `lower_match` (which calls back into `lower_expr` for nested
// expression lowering). Same pattern as
// `vader/comptime/eval_binary.vader::evaluate_binary`'s `recurse` arg.
import "vader/types" {
    Type, UnionType, TupleType, StructType, EnumType, UnresolvedType, mk_primitive,
    TY_BOOL, TY_VOID, TY_NEVER, TY_UNRESOLVED,
}
import "vader/typecheck" { TypedProgram }
import "vader/typecheck" { type_from_expr }
import "vader/diagnostics" { Diagnostic }

/// Lower a `MatchExpr` to a block containing the scrutinee binding
/// + an if-chain over the arms.
/// @param ctx          the fn-body context.
/// @param expr         the source match.
/// @param result_type  the result type the surrounding context expects.
/// @param recurse      callback to lower nested expressions (breaks the
///                     `lower_expr ↔ lower_match` import cycle).
/// @return             the lowered block.
export lower_match :: fn(
    ctx: FnLowerCtx, expr: MatchExpr, result_type: Type,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredExpr {
    scrut_type :: ctx.types.expr_type(expr.scrutinee)
    scrut_symbol :: fresh_synthetic_symbol(ctx, "scrut")
    scrut_value :: recurse(ctx, expr.scrutinee)

    stmts: LoweredStmt[] = []
    stmts.push(LoweredLet {
        .span = span_of(scrut_value), .name = scrut_symbol.name, .symbol = scrut_symbol,
        .type = scrut_type, .value = scrut_value,
    })

    fallback: LoweredBlock = wrap_block(expr.span, LoweredUnreachable {
        .span = expr.span, .type = result_type,
        .reason = "non-exhaustive match (T3013 should have caught this)",
    })

    arm_count :: expr.arms.len()
    if arm_count == usize(0) {
        for stmt in fallback.stmts { stmts.push(stmt) }
        return LoweredBlock {
            .span = expr.span, .type = result_type,
            .stmts = stmts, .trailing = fallback.trailing,
        }
    }

    chain: LoweredBlock = fallback
    cursor := arm_count
    for cursor > usize(0) {
        cursor = cursor - usize(1)
        arm :: expr.arms[cursor]
        arm_block :: lower_arm(ctx, arm, scrut_symbol, scrut_type, recurse)
        predicate :: arm_predicate(ctx, arm, scrut_symbol, scrut_type, recurse)
        match predicate {
            is null -> { chain = arm_block }
            _ -> {
                if_node :: LoweredIf {
                    .span = arm.span, .type = result_type,
                    .cond = predicate, .then_block = arm_block, .else_block = chain,
                }
                chain = wrap_block(arm.span, if_node)
            }
        }
    }

    for stmt in chain.stmts { stmts.push(stmt) }
    return LoweredBlock {
        .span = expr.span, .type = result_type,
        .stmts = stmts, .trailing = chain.trailing,
    }
}

lower_arm :: fn(
    ctx: FnLowerCtx, arm: MatchArm, scrut_symbol: Symbol, scrut_type: Type,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredBlock {
    stmts: LoweredStmt[] = []
    introduce_pattern_bindings(ctx, arm.pattern, scrut_symbol, scrut_type, stmts, arm.span)
    body :: recurse(ctx, arm.body)
    return LoweredBlock {
        .span = arm.span, .type = type_of(body),
        .stmts = stmts, .trailing = body,
    }
}

arm_predicate :: fn(
    ctx: FnLowerCtx, arm: MatchArm, scrut_symbol: Symbol, scrut_type: Type,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredExpr | null {
    span :: arm.pattern.span
    scrut_ident :: LoweredIdent { .span = span, .type = scrut_type, .symbol = scrut_symbol }
    core :: pattern_predicate(ctx, arm.pattern, scrut_ident, scrut_type, span, recurse)
    match arm.guard {
        is null -> { return core }
        _ -> {
            guard :: recurse(ctx, arm.guard)
            match core {
                is null -> { return guard }
                _ -> {
                    return LoweredBinary {
                        .span = arm.span, .type = TY_BOOL, .op = LoweredBinaryOp.And,
                        .left = core, .right = guard,
                    }
                }
            }
        }
    }
}

pattern_predicate :: fn(
    ctx: FnLowerCtx, pattern: Pattern, target: LoweredExpr, target_type: Type, span: Span,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredExpr | null {
    match pattern {
        is WildcardPattern -> { return null }
        is BindingPattern  -> { return null }
        is IsPattern as is_pattern -> {
            return LoweredTypeCheck {
                .span = span, .type = TY_BOOL,
                .value = target,
                .check_type = resolve_pattern_type(ctx, is_pattern.ty),
            }
        }
        is StructPattern as struct_pattern -> {
            return struct_pattern_predicate(ctx, struct_pattern, target, span, recurse)
        }
        is EnumVariantPattern as variant_pattern -> {
            variant_lit :: enum_variant_literal(target_type, variant_pattern.variant, span, ctx)
            return LoweredBinary {
                .span = span, .type = TY_BOOL, .op = LoweredBinaryOp.Eq,
                .left = target, .right = variant_lit,
            }
        }
        is LiteralPattern as literal_pattern -> {
            literal :: recurse(ctx, literal_pattern.value)
            return LoweredBinary {
                .span = span, .type = TY_BOOL, .op = LoweredBinaryOp.Eq,
                .left = target, .right = literal,
            }
        }
        is TuplePattern as tuple_pattern -> {
            return tuple_pattern_predicate(ctx, tuple_pattern, target, target_type, span, recurse)
        }
    }
}

struct_pattern_predicate :: fn(
    ctx: FnLowerCtx, pattern: StructPattern, target: LoweredExpr, span: Span,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredExpr {
    accumulator: LoweredExpr = LoweredBoolLit { .span = span, .type = TY_BOOL, .value = true }
    for field in pattern.fields {
        match field.value {
            is PatternLiteral as literal -> {
                literal_value :: recurse(ctx, literal.value)
                eq :: LoweredBinary {
                    .span = field.span, .type = TY_BOOL, .op = LoweredBinaryOp.Eq,
                    .left = LoweredFieldAccess {
                        .span = field.span, .type = type_of(literal_value),
                        .target = target, .field = field.name,
                    },
                    .right = literal_value,
                }
                accumulator = LoweredBinary {
                    .span = field.span, .type = TY_BOOL, .op = LoweredBinaryOp.And,
                    .left = accumulator, .right = eq,
                }
            }
            _ -> {}
        }
    }
    return accumulator
}

tuple_pattern_predicate :: fn(
    ctx: FnLowerCtx, pattern: TuplePattern, target: LoweredExpr, target_type: Type, span: Span,
    recurse: fn(FnLowerCtx, Expr) -> LoweredExpr,
) -> LoweredExpr | null {
    accumulator: LoweredExpr | null = null
    element_types :: tuple_element_types(target_type, pattern.elements.len())
    // A tuple pattern over a union (`[i32, string] | null`) first checks
    // `is [tuple]` to narrow the union, then reads slots off the narrowed
    // value. Without the seed check the (irrefutable) element bindings
    // produce no predicate and the arm would always match.
    tuple_ty :: tuple_variant_of(target_type, pattern.elements.len())
    eff_target: LoweredExpr = target
    if target_type is UnionType {
        if tuple_ty is TupleType as tt {
            accumulator = LoweredTypeCheck {
                .span = span, .type = TY_BOOL, .value = target, .check_type = tt,
            }
            eff_target = narrow_target(target, target_type, tt, span)
        }
    }
    for i in 0..<pattern.elements.len() {
        element_pattern :: pattern.elements[i]
        element_type :: element_types[i]
        field_access :: LoweredFieldAccess {
            .span = element_pattern.span, .type = element_type,
            .target = eff_target, .field = "_${i}",
        }
        sub :: pattern_predicate(ctx, element_pattern, field_access, element_type, element_pattern.span, recurse)
        match sub {
            is null -> {}
            _ -> {
                match accumulator {
                    is null -> { accumulator = sub }
                    _ -> {
                        accumulator = LoweredBinary {
                            .span = element_pattern.span, .type = TY_BOOL, .op = LoweredBinaryOp.And,
                            .left = accumulator, .right = sub,
                        }
                    }
                }
            }
        }
    }
    return accumulator
}

tuple_element_types :: fn(target_type: Type, arity: usize) -> Type[] {
    tup :: tuple_variant_of(target_type, arity)
    if tup is TupleType as t {
        if t.elements.len() == arity { return t.elements }
    }
    return fill_unresolved(arity)
}

// Pick the `arity`-element tuple shape from `t` — directly when `t` is a
// tuple, or from a union variant (`[i32, string] | null`). Returns null
// when no matching tuple exists. Mirror of `pick_tuple_variant` on the
// typecheck side ; used so a tuple pattern over a union narrows to the
// tuple before reading slots.
tuple_variant_of :: fn(t: Type, arity: usize) -> TupleType | null {
    if t is TupleType as tup {
        if tup.elements.len() == arity { return tup }
        return null
    }
    if t is UnionType as u {
        for v in u.variants {
            if v is TupleType as tup {
                if tup.elements.len() == arity { return tup }
            }
        }
    }
    return null
}

fill_unresolved :: fn(arity: usize) -> Type[] {
    out: Type[] = []
    for i in 0..<arity { out.push(TY_UNRESOLVED) }
    return out
}

enum_variant_literal :: fn(target_type: Type, name: string, span: Span, ctx: FnLowerCtx) -> LoweredExpr {
    // `type_expr.vader::type_from_symbol` currently returns a placeholder
    // `StructType` for enum decls (the comment in that file calls it out
    // explicitly). Unwrap the real `EnumType` from `decl_types` here so
    // the variant index lookup works regardless of which entry point
    // resolved the target's type.
    resolved :: unwrap_enum_type(target_type, ctx)
    match resolved {
        is EnumType as enum_type -> {
            index :: enum_type.indices[name]
            match index {
                is null -> {
                    return LoweredUnreachable {
                        .span = span, .type = TY_UNRESOLVED,
                        .reason = "unknown variant `${name}` on `${enum_type.symbol.name}`",
                    }
                }
                is i64 as value -> {
                    return LoweredIntLit {
                        .span = span, .type = mk_primitive(enum_type.repr), .value = value,
                    }
                }
            }
        }
        _ -> {
            return LoweredUnreachable {
                .span = span, .type = TY_UNRESOLVED,
                .reason = "`.${name}` against unresolved type",
            }
        }
    }
}

import "vader/resolver/symbol" { SymbolKind }

unwrap_enum_type :: fn(target_type: Type, ctx: FnLowerCtx) -> Type {
    match target_type {
        is EnumType -> { return target_type }
        is StructType as st -> {
            if i32(st.symbol.kind) != i32(SymbolKind.Enum) { return target_type }
            real :: ctx.typed.decl_types[st.symbol.id]
            match real {
                is EnumType -> { return real }
                _ -> { return target_type }
            }
        }
        _ -> { return target_type }
    }
}

// ============================================================================
// Pattern bindings (let-stmts introduced inside the arm)
// ============================================================================

introduce_pattern_bindings :: fn(
    ctx: FnLowerCtx, pattern: Pattern, scrut_symbol: Symbol, scrut_type: Type,
    out: LoweredStmt[], span: Span,
) -> void {
    scrut_ref :: LoweredIdent { .span = span, .type = scrut_type, .symbol = scrut_symbol }
    walk_pattern_bindings(ctx, pattern, scrut_ref, scrut_type, out, span)
}

walk_pattern_bindings :: fn(
    ctx: FnLowerCtx, pattern: Pattern, target: LoweredExpr, target_type: Type,
    out: LoweredStmt[], span: Span,
) -> void {
    match pattern {
        is BindingPattern as binding -> {
            symbol :: resolve_pattern_symbol(ctx, binding.span, binding.name)
            init :: lower_cell_init(ctx, symbol, target, target_type, span)
            out.push(LoweredLet {
                .span = span, .name = binding.name, .symbol = symbol,
                .type = init.slot_type, .value = init.value,
            })
        }
        is IsPattern as is_pattern -> {
            inner_type :: resolve_pattern_type(ctx, is_pattern.ty)
            narrowed_target :: narrow_target(target, target_type, inner_type, span)
            match is_pattern.bind_as {
                is null -> {}
                is string as alias -> {
                    symbol :: resolve_pattern_symbol(ctx, is_pattern.span, alias)
                    init :: lower_cell_init(ctx, symbol, narrowed_target, inner_type, span)
                    out.push(LoweredLet {
                        .span = span, .name = alias, .symbol = symbol,
                        .type = init.slot_type, .value = init.value,
                    })
                }
            }
            match is_pattern.inner {
                is null -> {}
                _ -> {
                    walk_pattern_bindings(ctx, is_pattern.inner, narrowed_target, inner_type, out, span)
                }
            }
        }
        is StructPattern as struct_pattern -> {
            for field in struct_pattern.fields {
                match field.value {
                    is PatternBinding as binding -> {
                        field_type :: struct_field_type(ctx, target_type, field.name)
                        field_access :: LoweredFieldAccess {
                            .span = field.span, .type = field_type,
                            .target = target, .field = field.name,
                        }
                        symbol :: resolve_pattern_symbol(ctx, binding.span, binding.name)
                        init :: lower_cell_init(ctx, symbol, field_access, field_type, field.span)
                        out.push(LoweredLet {
                            .span = field.span, .name = binding.name, .symbol = symbol,
                            .type = init.slot_type, .value = init.value,
                        })
                    }
                    _ -> {}
                }
            }
        }
        is TuplePattern as tuple_pattern -> {
            element_types :: tuple_element_types(target_type, tuple_pattern.elements.len())
            // Narrow a union scrutinee (`[i32, string] | null`) to the
            // tuple shape before reading slots, so `._0` lands on the
            // tuple variant rather than the bare union value.
            tuple_ty :: tuple_variant_of(target_type, tuple_pattern.elements.len())
            narrowed :: if tuple_ty is TupleType as tt {
                narrow_target(target, target_type, tt, tuple_pattern.span)
            } else { target }
            for i in 0..<tuple_pattern.elements.len() {
                element_pattern :: tuple_pattern.elements[i]
                element_type :: element_types[i]
                field_access :: LoweredFieldAccess {
                    .span = element_pattern.span, .type = element_type,
                    .target = narrowed, .field = "_${i}",
                }
                walk_pattern_bindings(ctx, element_pattern, field_access, element_type, out, element_pattern.span)
            }
        }
        is WildcardPattern -> {}
        is EnumVariantPattern -> {}
        is LiteralPattern -> {}
    }
}

narrow_target :: fn(target: LoweredExpr, target_type: Type, inner_type: Type, span: Span) -> LoweredExpr {
    match target_type {
        is UnionType -> { return LoweredCast { .span = span, .type = inner_type, .value = target } }
        _ -> { return target }
    }
}

struct_field_type :: fn(ctx: FnLowerCtx, target_type: Type, field_name: string) -> Type {
    match target_type {
        is StructType as st -> {
            decl :: ctx.typed.struct_decls[st.symbol.id]
            if decl is null { return TY_UNRESOLVED }
            for field in decl.fields {
                if field.name == field_name {
                    return resolve_pattern_type(ctx, field.ty)
                }
            }
            return TY_UNRESOLVED
        }
        _ -> { return TY_UNRESOLVED }
    }
}

// Pattern-introduced bindings : `resolved.idents.values()` exposes
// every Symbol the resolver minted (use-sites stored against scope-
// owned symbols). Scan once for one whose `defined_at` matches the
// pattern's name_span. Synthesise a fresh symbol when the resolver
// didn't write one — defensive against cascading diagnostics.
resolve_pattern_symbol :: fn(ctx: FnLowerCtx, name_span: Span, name: string) -> Symbol {
    target_key :: span_key(name_span)
    for symbol in ctx.typed.resolved.idents.values() {
        match symbol.defined_at {
            is null -> {}
            is Span as defined -> {
                if span_key(defined) == target_key { return symbol }
            }
        }
    }
    return fresh_synthetic_symbol(ctx, name)
}

wrap_block :: fn(span: Span, expr: LoweredExpr) -> LoweredBlock {
    return LoweredBlock { .span = span, .type = type_of(expr), .stmts = [], .trailing = expr }
}

import "vader/parser" { TypeExpr }

// Pattern-position type expressions don't always get a
// `type_expr_types` entry — the typecheck's match arm walker doesn't
// re-resolve pattern.ty through the type-expr pass. Try the
// side-table first ; on miss, fall back to `type_from_expr` against
// the resolver view (the same helper the typecheck uses for fn
// signatures).
export resolve_pattern_type :: fn(ctx: FnLowerCtx, type_expr: TypeExpr) -> Type {
    from_table :: ctx.types.type_expr_type(type_expr)
    if from_table is UnresolvedType {
        // The type-expr table missed (common for materialised default-
        // method clones, whose pattern type-exprs aren't span-recorded).
        // Resolve fresh from the AST, then apply the entry's substitution
        // so an erased generic-impl instance turns `is Yield<T>` into
        // `is Yield<Any>` instead of leaking the impl's TypeParam.
        scratch: Diagnostic[] = []
        return ctx.types.apply(type_from_expr(type_expr, ctx.typed.resolved, scratch))
    }
    return from_table
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq, assert }
import "std/string" { byte_len }
import "vader/diagnostics" { empty_span }

@test test_fill_unresolved_emits_unresolved_array :: fn() -> void {
    types :: fill_unresolved(usize(3))
    assert_eq(types.len(), usize(3))
}

// `test_enum_variant_literal_unknown` removed : `enum_variant_literal`
// now takes a `FnLowerCtx` so the synthetic ctx scaffolding outweighs
// the test value. Coverage moves to the snippet harness via
// `enum_basic/_main.vader` once the snapshot flip lands.

@test test_tuple_element_types_falls_back_to_unresolved :: fn() -> void {
    // Non-tuple target widens to an all-unresolved slot list ; matches
    // the typecheck's recovery semantics for arity mismatches.
    types :: tuple_element_types(TY_UNRESOLVED, usize(2))
    assert_eq(types.len(), usize(2))
}
