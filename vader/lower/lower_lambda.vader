// vader/lower/lower_lambda — lambda lifting (consumes closure analysis).
//
// Mirror of `src/lower/passes/lambda.ts`. Turns each `LambdaExpr` into :
//   1. A synthesised top-level fn (the "lifted fn") whose params are
//      `env` first + the lambda's own params.
//   2. A synthesised env struct decl carrying one `cap_<N>` field per
//      captured outer symbol (from `closure_analysis`).
//   3. A `LoweredMakeClosure` expression at the original site that
//      packs the env literal (with captured values) + the lifted fn.
//
// Captures come from `ctx.project.closures.lambda_captures[lambda.id]`,
// populated once at project entry by `analyze_closures`. The lifted
// fn's body is lowered with a `lifted_context` so captured idents
// route through `env.cap_N` rather than resolving to outer locals.

import "std/collections" { MutableMap, values }
import "vader/diagnostics/diagnostic" { Span, empty_span }
AST :: import "vader/parser/ast"
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/typecheck/types" {
    Type, FnType, mk_struct, TY_UNRESOLVED, TY_VOID,
}
import "vader/typecheck/substitution" { new_substitution }
import "vader/comptime/mono_ast" { MonoEntry }
import "vader/lower/ctx" { FnLowerCtx, LiftedFnContext, Capture, new_fn_lower_ctx }
import "vader/lower/entry_types" { expr_type, param_type, span_key }
import "vader/lower/helpers" { fresh_synthetic_symbol }
import "vader/lower/lowered_ast" {
    LoweredExpr, LoweredFnDecl, LoweredStructDecl, LoweredParam,
    LoweredMakeClosure, LoweredStructLit, LoweredStructLitField,
    LoweredStructField, LoweredIdent, LoweredBlock,
}

/// Lower a `LambdaExpr` to a `LoweredMakeClosure`. Synthesises the
/// lifted fn + the env struct (with one `cap_<N>` field per capture
/// from `closure_analysis`), pushes both onto `ctx.project.synth_decls`,
/// then returns the make-closure node carrying the env literal.
/// @param ctx           the surrounding fn-body context.
/// @param lambda        the source lambda.
/// @param block_lowerer callback to lower a `BlockExpr` (cycle-breaker,
///                      same pattern as `lower_match`).
/// @return              the make-closure expression.
export lower_lambda :: fn(
    ctx: FnLowerCtx, lambda: AST.LambdaExpr,
    block_lowerer: fn(FnLowerCtx, AST.BlockExpr, bool, bool) -> LoweredBlock,
) -> LoweredExpr {
    captures :: lookup_captures(ctx, lambda)
    lifted_symbol :: fresh_lifted_symbol(ctx, false)
    env_symbol    :: fresh_lifted_symbol(ctx, true)
    env_param_symbol :: synth_env_param_symbol(ctx)
    env_type :: mk_struct(env_symbol, [])

    env_fields :: build_env_struct_fields(captures)
    capture_fields_map :: build_capture_fields_map(captures)

    env_decl :: LoweredStructDecl {
        .mangled = env_symbol.name,
        .fields  = env_fields,
        .origin  = synth_mono_entry(ctx, env_symbol),
    }

    lifted_params :: build_lifted_params(ctx, lambda, env_param_symbol, env_type)
    return_type :: lambda_return_type(ctx, lambda)
    lifted_entry :: synth_mono_entry(ctx, lifted_symbol)
    // Body lowers in a fresh fn-ctx ; `lifted_context` routes captured
    // ident reads through `env.cap_N` instead of resolving to outer
    // locals that don't exist in the lifted scope.
    lifted_ctx :: new_fn_lower_ctx(
        ctx.project, lifted_entry, ctx.typed, ctx.subst, return_type, null,
    )
    lifted_ctx.lifted_context = LiftedFnContext {
        .env_symbol     = env_param_symbol,
        .env_type       = env_type,
        .capture_fields = capture_fields_map,
    }
    body :: block_lowerer(lifted_ctx, lambda.body, true, false)

    lifted_decl :: LoweredFnDecl {
        .mangled     = lifted_symbol.name,
        .params      = lifted_params,
        .return_type = return_type,
        .body        = body,
        .origin      = lifted_entry,
    }

    ctx.project.synth_decls.push(env_decl)
    ctx.project.synth_decls.push(lifted_decl)

    return LoweredMakeClosure {
        .span = lambda.span, .type = ctx.types.expr_type(lambda),
        .fn_symbol = lifted_symbol,
        .env = LoweredStructLit {
            .span = lambda.span, .type = env_type,
            .fields = build_env_lit_fields(lambda.span, captures),
        },
    }
}

// Recover the closure-analysis capture list for `lambda`. Falls back
// to an empty list when the analysis didn't observe the lambda (e.g.
// a recovery path past an earlier diagnostic).
lookup_captures :: fn(ctx: FnLowerCtx, lambda: AST.LambdaExpr) -> Capture[] {
    found :: ctx.project.closures.lambda_captures[lambda.id]
    match found {
        is null -> { return [] }
        _ -> { return found }
    }
}

build_env_struct_fields :: fn(captures: Capture[]) -> LoweredStructField[] {
    fields: LoweredStructField[] = []
    for i in 0..<captures.len() {
        fields.push(LoweredStructField {
            .name = "cap_${i}", .type = TY_UNRESOLVED,
        })
    }
    return fields
}

build_env_lit_fields :: fn(span: Span, captures: Capture[]) -> LoweredStructLitField[] {
    fields: LoweredStructLitField[] = []
    for i in 0..<captures.len() {
        capture :: captures[i]
        fields.push(LoweredStructLitField {
            .name = "cap_${i}",
            .value = LoweredIdent {
                .span = span, .type = capture.type, .symbol = capture.symbol,
            },
        })
    }
    return fields
}

build_capture_fields_map :: fn(captures: Capture[]) -> MutableMap(i32, string) {
    map :: MutableMap(i32, string) { .buckets = [], .size = usize(0) }
    for i in 0..<captures.len() {
        map[captures[i].symbol.id] = "cap_${i}"
    }
    return map
}

build_lifted_params :: fn(
    ctx: FnLowerCtx, lambda: AST.LambdaExpr, env_param_symbol: Symbol, env_type: Type,
) -> LoweredParam[] {
    params: LoweredParam[] = []
    params.push(LoweredParam {
        .name = env_param_symbol.name, .symbol = env_param_symbol, .type = env_type,
    })
    for ast_param in lambda.params {
        symbol :: find_param_symbol(ctx, ast_param)
        match symbol {
            is null -> {}
            is Symbol as resolved -> {
                params.push(LoweredParam {
                    .name = ast_param.name, .symbol = resolved,
                    .type = ctx.types.param_type(ast_param),
                })
            }
        }
    }
    return params
}

find_param_symbol :: fn(ctx: FnLowerCtx, fn_param: AST.FnParam) -> Symbol | null {
    target_key :: span_key(fn_param.span)
    for symbol in ctx.typed.resolved.idents.values() {
        match symbol.defined_at {
            is null -> {}
            is Span as defined -> {
                if span_key(defined) == target_key { return symbol }
            }
        }
    }
    return null
}

lambda_return_type :: fn(ctx: FnLowerCtx, lambda: AST.LambdaExpr) -> Type {
    fn_type :: ctx.types.expr_type(lambda)
    match fn_type {
        is FnType as ft -> { return ft.return_type }
        _ -> { return TY_UNRESOLVED }
    }
}

next_synthetic_id :: fn(ctx: FnLowerCtx) -> i32 {
    id :: ctx.project.next_synthetic_id
    ctx.project.next_synthetic_id = id - i32(1)
    return id
}

next_mono_entry_id :: fn(ctx: FnLowerCtx) -> i32 {
    id :: ctx.project.next_mono_entry_id
    ctx.project.next_mono_entry_id = id + i32(1)
    return id
}

synth_env_param_symbol :: fn(ctx: FnLowerCtx) -> Symbol {
    // Use the per-fn `uniq` counter so the name matches TS's
    // `freshSyntheticSymbol("env")` form (`__env_0`, `__env_1`, …).
    return fresh_synthetic_symbol(ctx, "env")
}

fresh_lifted_symbol :: fn(ctx: FnLowerCtx, is_env: bool) -> Symbol {
    id :: next_synthetic_id(ctx)
    suffix :: render_id_for_name(id)
    prefix := "__lambda_"
    kind := SymbolKind.Fn
    if is_env {
        prefix = "__lambda_env_"
        kind = SymbolKind.Struct
    }
    return Symbol {
        .id         = id,
        .kind       = kind,
        .name       = "${prefix}${suffix}",
        .module     = ctx.typed.resolved.path,
        .visibility = AST.Visibility.Private,
        .defined_at = null,
    }
}

// Synthetic IDs walk negative ; render as an unsigned magnitude for
// readability so dumps don't show `-3`-style suffixes.
render_id_for_name :: fn(id: i32) -> string {
    if id < i32(0) {
        return "${i32(0) - id}"
    }
    return "${id}"
}

synth_mono_entry :: fn(ctx: FnLowerCtx, symbol: Symbol) -> MonoEntry {
    return MonoEntry {
        // Use a private counter (not the project-wide synthetic id pool)
        // so MonoEntry minting doesn't bump the symbol-id counter the
        // lambda-naming uses. Mirror of TS's `synthLambdaEntryId`
        // in `src/lower/passes/lambda.ts:198`.
        .id             = next_mono_entry_id(ctx),
        .is_main        = false,
        .mangled        = symbol.name,
        .decl           = stub_decl_for(symbol),
        .symbol         = symbol,
        .subst          = new_substitution(),
        .type_arguments = [],
        .module         = ctx.typed,
    }
}

// Synthetic decls have no real source AST. Pick the right Decl variant
// so `match` walkers don't trip the wrong arm. Every field gets an
// explicit initialiser to dodge Vader's default-value codegen path.
stub_decl_for :: fn(symbol: Symbol) -> AST.Decl {
    kind_value :: i32(symbol.kind)
    if kind_value == i32(SymbolKind.Struct) {
        struct_decl: AST.Decl = AST.StructDecl {
            .span        = empty_span(),
            .id          = AST.UNASSIGNED_NODE_ID,
            .name        = symbol.name,
            .name_span   = empty_span(),
            .visibility  = AST.Visibility.Private,
            .type_params = [],
            .fields      = [],
            .decorators  = [],
        }
        return struct_decl
    }
    fn_decl: AST.Decl = AST.FnDecl {
        .span                 = empty_span(),
        .id                   = AST.UNASSIGNED_NODE_ID,
        .name                 = symbol.name,
        .name_span            = empty_span(),
        .visibility           = AST.Visibility.Private,
        .type_params          = [],
        .params               = [],
        .return_type          = null,
        .body                 = null,
        .decorators           = [],
        .sam_synthetic        = false,
        .is_expression_bodied = false,
        .materialized         = false,
    }
    return fn_decl
}
