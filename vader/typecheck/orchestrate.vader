// vader/typecheck/orchestrate — full-pipeline typecheck.
//
// Adds body-walking on top of `check.vader::check_module` so CLI / dump
// callers get a fully-typed program in one call. Kept separate so
// `check.vader` stays free of `expr` / `stmt` imports (see header
// of `check.vader` for the cycle rationale).
//
// Also exposes `check_project_with_bodies` which takes a
// `LoadedProject` (multi-module) and propagates wire + cross-module
// type info into the entry module's `TypedProgram`.

module "vader/typecheck"

import "std/collections" { MutableMap, keys }
import "vader/diagnostics" { Diagnostic, Span }
AST :: import "vader/parser"
import "vader/parser" { Program }
import "vader/resolver" { LoadedProject, LoadedModule, SourceFile }
import "vader/resolver" { ResolvedModule, resolve_module, resolve_module_with_collected, resolve_module_with_collected_dp, resolve_module_with_collected_dp_seeded, build_core_seed, find_core_module_id }
import "vader/resolver/symbol" { Symbol, SymbolFactory }
import "vader/resolver" { wire_imports, ImportTargetTable, run_orphan_rule_check_for_module }
import "vader/types" { display_type, type_base_name }
import "vader/diagnostics" { typecheck_error }
import "vader/types" {
    Type, ArrayType, EnumType, FnType, SelfType, StructType, TraitType,
    TupleType, UnionType,
    mk_array, mk_fn, mk_struct, mk_tuple, mk_union, mk_enum,
    TY_UNRESOLVED, TY_TYPE, TY_VOID,
}

// Concatenate every file of a (possibly multi-file) module into one
// synthetic Program so the resolver body-walks ALL files, not just
// files[0]. Mirror of TS `mergeFilePrograms` (src/resolver/index.ts).
// `span_key` is file-aware, so idents from sibling files at the same
// (line, column) no longer collide in the merged per-module map.
merge_module_program :: fn(files: SourceFile[]) -> Program {
    first :: files[0].program
    if files.len() == usize(1) { return first }
    all_decls: AST.Decl[] = []
    for f in files {
        for d in f.program.decls { all_decls.push(d) }
    }
    return Program {
        .file = first.file, .span = first.span, .id = first.id,
        .module = first.module, .decls = all_decls,
    }
}

/// Run the full typecheck pipeline : decl-level + body-walking. The
/// result carries the same `TypedProgram` + `ImplRegistry` as
/// `check_module`, just with `expr_types` / `local_types` populated.
export check_module_with_bodies :: fn(
    program: Program, resolved: ResolvedModule,
    factory: SymbolFactory, diags: Diagnostic[],
) -> CheckResult {
    result :: check_module(program, resolved, factory, diags)
    walk_bodies(program.decls, result.typed, diags)
    return CheckResult {
        .typed = result.typed, .impls = result.impls, .others = [],
        .all_modules = MutableMap<string, TypedProgram> {},
    }
}

/// Multi-module typecheck. Types the entry module fully, then
/// types each directly-imported module *just enough* to harvest
/// its top-level decl types (for cross-module ident lookup). Wires
/// imports across the project and patches the entry's
/// `import_targets` + `external_types`.
export check_project_with_bodies :: fn(
    project: LoadedProject, diags: Diagnostic[],
) -> CheckResult {
    entry_loaded :: project.modules[project.entry]
    if entry_loaded is null {
        return CheckResult {
            .typed = empty_fallback(project), .impls = empty_impls(), .others = [],
            .all_modules = MutableMap<string, TypedProgram> {},
        }
    }

    // Phase A0 : materialise single-abstract-method sugar
    // (`Type implements Trait -> expr`) project-wide so the resolver
    // (run next) walks bodies with `self` / `other` / … properly
    // bound — synthesising trait-method params on the SAM members
    // happens here, not after resolve.
    materialize_all_sams_pre_resolve(project)

    // Build the core_symbols seed once — every per-module resolve gets
    // the same map so the body-walker can fire R2006 unconditionally on
    // unresolved idents instead of deferring to typecheck.
    core_seed :: build_core_seed(project)

    entry_rm :: resolve_module_with_collected_dp_seeded(
        merge_module_program(entry_loaded.module.files), project.entry,
        entry_loaded.module.display_path,
        project.factory, entry_loaded.collected, core_seed,
    )
    entry_typed :: new_typed_program(entry_rm)
    preload_core_symbols(entry_rm, project)

    // Pre-resolve every module first so we can register all type
    // aliases project-wide before any fn signature is lowered.
    per_module :: MutableMap<string, TypedProgram> {}
    per_module[project.entry] = entry_typed
    for id in project.modules.keys() {
        if id == project.entry { continue }
        other :: project.modules[id]
        if other is null { continue }
        rm :: resolve_module_with_collected_dp_seeded(
            merge_module_program(other.module.files), id, other.module.display_path,
            project.factory, other.collected, core_seed,
        )
        preload_core_symbols(rm, project)
        typed :: new_typed_program(rm)
        per_module[id] = typed
    }
    // Phase A : register every type alias project-wide. Cross-
    // module aliases (`Pet` imported from `./types`) need to land
    // before any fn signature consults them.
    register_aliases(entry_typed, merge_module_program(entry_loaded.module.files).decls)
    for id in project.modules.keys() {
        if id == project.entry { continue }
        other :: project.modules[id]
        if other is null { continue }
        other_typed :: per_module[id]
        match other_typed {
            is null -> {}
            _ -> { register_aliases(other_typed, merge_module_program(other.module.files).decls) }
        }
    }
    merge_external_alias_types(entry_typed, per_module)
    // Make every module's enums resolvable cross-module before any fn
    // signature is lowered — so a `d: parser.Visibility` param resolves to
    // the `EnumType` (→ `repr` ordinal at bytecode emit) instead of the
    // struct placeholder.
    broadcast_enum_types(per_module, project)
    // Wire imports + resolver-side imports_to early so cross-module
    // alias lookups (`Pet` from `./types`) follow ImportBinding to
    // the real symbol during fn-signature lowering below.
    wire_targets :: wire_imports(project)
    entry_typed.import_targets = wire_targets
    populate_resolver_imports(entry_typed)
    populate_resolver_imports_for_others(entry_typed, project, per_module)
    // R2018 orphan-rule pre-resolve check (project-level — needs the
    // wire_imports redirect table to resolve ImportBinding to the
    // concrete owner). Diagnostics fold into each module's resolved
    // diags bucket so the CLI / typecheck dumpers surface them in
    // their usual place.
    run_orphan_rule_check_for_module(entry_loaded, project.entry,
        entry_rm.idents, wire_targets, entry_rm.diags)
    for id in project.modules.keys() {
        if id == project.entry { continue }
        other :: project.modules[id]
        if other is null { continue }
        other_typed :: per_module[id]
        match other_typed {
            is null -> {}
            _ -> {
                run_orphan_rule_check_for_module(other, id,
                    other_typed.resolved.idents, wire_targets,
                    other_typed.resolved.diags)
            }
        }
    }
    // Pre-populate `namespace_member_types` from each target module's
    // exported types so `type_from_expr`'s FieldExpr arm can resolve
    // `P.Decl` in fn-signature type positions (which run during
    // `declare_module` below — before `populate_external_types`
    // builds `namespace_exports`).
    prepopulate_namespace_member_types(entry_typed, project, per_module)

    // Phase B : declare every decl (fn signatures, struct types, etc.)
    // across ALL files of the module. decl_types is Symbol.id-keyed and
    // the span-keyed tables (param_types / type_expr_types) are now
    // file-aware, so merging sibling files no longer collides — fn
    // signatures in non-first files get declared too (was the source of
    // `?` types on multi-file modules).
    declare_module(merge_module_program(entry_loaded.module.files).decls, entry_rm, entry_typed, project.factory, diags)
    // For every imported module, prepopulate its `namespace_member_types`
    // (mirroring the entry's prepop above) BEFORE its own `declare_module`.
    // The whole-program lowerer lowers imported bodies too, so a signature
    // whose param/return is a namespace-qualified imported type
    // (`d: p.TraitDecl`) must resolve here — otherwise `type_from_expr` reads
    // an empty table and the param degrades to `?` (→ field-gets drop to
    // `Drop;Return` in emit). prepop needs `import_targets` (= wire_targets) ;
    // the later body-check loop re-sets it idempotently. Each module's prepop
    // is self-contained (reads the target's exports from `collected.symbols` +
    // `alias_types`, not from any module's `declare_module`), so interleaving
    // prepop with declare is safe.
    for id in project.modules.keys() {
        if id == project.entry { continue }
        other :: project.modules[id]
        if other is null { continue }
        other_typed :: per_module[id]
        if other_typed is null { continue }
        other_typed.import_targets = wire_targets
        prepopulate_namespace_member_types(other_typed, project, per_module)
        // Merge cross-module alias/union types into this import too (the entry
        // got this at top via `merge_external_alias_types`). A signature param
        // typed by an imported union/alias (`got: Type`, `sh: Shape`) resolves
        // via `resolved.alias_types`, which only holds the module's OWN aliases
        // until merged — without this, the param degrades to `?` (→ field-gets
        // and `is T as a` binds collapse). `register_aliases` already ran for
        // every module above, so all sources are available.
        merge_external_alias_types(other_typed, per_module)
        declare_module(merge_module_program(other.module.files).decls, other_typed.resolved, other_typed, project.factory, diags)
    }
    // Cross-module struct visibility — see `broadcast_struct_decls`.
    broadcast_struct_decls(per_module)

    // Wire was done before declare ; now populate the remaining
    // typecheck-side tables that depend on per-module decl types.
    // Settle expression-bodied fn returns in every non-entry module
    // BEFORE copying their FnTypes into the entry's external_types /
    // imported_fn_overloads — otherwise a `fn(a, b) = if … { a } …`
    // export lands as `fn(_, _) -> ?` in the bucket.
    populate_core_symbols(entry_typed, project, per_module)
    // Cross-publish trait_decls (Iterator, Display, …) to every
    // per_module typed program BEFORE settle walks their bodies — so
    // `s.chars().count()` inside std/string's `len` can find
    // Iterator's default `count` method via `try_default_trait_method`.
    cross_publish_trait_decls(per_module)
    cross_publish_fn_decls(per_module)
    // Populate `imported_fn_overloads` for every NON-ENTRY module BEFORE
    // `settle_external_expr_bodied_returns` walks their bodies — otherwise
    // UFCS dispatch inside an external expr-bodied fn (e.g. `s.chars()
    // .count()` inside std/string::len) doesn't see cross-module overloads.
    // The entry's overload table is populated AFTER settle so it picks up
    // the resolved return types of expr-bodied externals.
    for id in per_module.keys() {
        if id == project.entry { continue }
        other_typed :: per_module[id]
        if other_typed is null { continue }
        populate_imported_fn_overloads(other_typed, per_module)
    }
    settle_external_expr_bodied_returns(project, per_module)
    populate_external_types(entry_typed, project, per_module)
    populate_imported_fn_overloads(entry_typed, per_module)
    merge_struct_decls(entry_typed, per_module)
    merge_external_impl_methods(entry_typed, project, per_module)

    // Two-pass body walk : first pass infers expression-bodied fn
    // return types (forward-reference safe) ; second pass re-types
    // bodies with all returns settled. Diags are captured only on
    // the second pass — the first one is a throwaway sink.
    if has_expr_bodied_fn(merge_module_program(entry_loaded.module.files).decls) {
        walk_bodies(merge_module_program(entry_loaded.module.files).decls, entry_typed, diag_sink())
        reset_expr_tables(entry_typed)
    }
    walk_bodies(merge_module_program(entry_loaded.module.files).decls, entry_typed, diags)

    // Body-check every imported module too, so the lowerer sees the
    // expression types of imported fn bodies. The whole-program lowerer
    // (vader/lower) lowers EVERY module's bodies to emit their bytecode ;
    // without per-module body types, imported bodies degrade — e.g. `m[k]`
    // Index resolution misses (target_type unresolved) and the emitter
    // drops the call. Each import needs its OWN external types wired first
    // (the entry-only setup above doesn't reach them), so we replay the
    // same setup chain parameterised on each module's typed program.
    // Diagnostics route to a throwaway sink : the user-facing surface stays
    // entry-only (the resolver-diag forwarding below is likewise
    // entry-scoped). Mirrors TS, which body-checks imports.
    for id in project.modules.keys() {
        if id == project.entry { continue }
        other :: project.modules[id]
        if other is null { continue }
        other_typed :: per_module[id]
        if other_typed is null { continue }
        // `import_targets` and `namespace_member_types` were both set for this
        // module before its `declare_module` (the loop above, mirroring the
        // entry) and persist — no need to re-set / rebuild them here.
        populate_resolver_imports(other_typed)
        populate_external_types(other_typed, project, per_module)
        // Rebuild from scratch : the pre-settle populate (so settle's own UFCS
        // sees cross-module overloads) captured expr-bodied callees' returns while
        // still `?`, and `push_overload` APPENDS — so the stale `fn(i64) -> ?` for
        // an overloaded expr-bodied import (`abs`) would sit BEFORE the settled
        // `fn(i64) -> i64`, and `pick_overload` returns the first match (the `?`,
        // which then flows as `any` and truncates wide-int compares to `i32.lt`).
        // Follow-up : a replace-on-signature `push_overload` would make populate
        // idempotent and drop this clear.
        other_typed.imported_fn_overloads = MutableMap<string, FnType[]> {}
        populate_imported_fn_overloads(other_typed, per_module)
        merge_external_impl_methods(other_typed, project, per_module)
        other_decls :: merge_module_program(other.module.files).decls
        if has_expr_bodied_fn(other_decls) {
            walk_bodies(other_decls, other_typed, diag_sink())
            reset_expr_tables(other_typed)
        }
        walk_bodies(other_decls, other_typed, diag_sink())
    }

    // Forward resolver-side R-codes (unresolved-ident, reserved-name, …)
    // so the CLI's `# Diagnostics` block surfaces them next to T-codes.
    for d in entry_typed.resolved.diags { diags.push(d) }

    impls :: build_impl_registry(merge_module_program(entry_loaded.module.files).decls, entry_typed.resolved)
    // Every directly-imported non-stdlib module gets its own `## <path>`
    // section in the dump.
    others: TypedProgram[] = collect_direct_imports(entry_loaded, project, per_module)
    return CheckResult {
        .typed = entry_typed, .impls = impls, .others = others,
        .all_modules = per_module,
    }
}

collect_direct_imports :: fn(
    entry_loaded: LoadedModule, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> TypedProgram[] {
    out: TypedProgram[] = []
    from_file :: entry_loaded.module.files[0].path
    stdlib_root :: default_stdlib_root()
    seen :: MutableMap<string, bool> {}
    for raw in entry_loaded.collected.import_paths {
        if starts_with(raw, "std/") { continue }
        target :: resolve_import_path(raw, from_file, stdlib_root, project.project_root)
        if target is null { continue }
        target_id :: module_id_from_root(target)
        if target_id == project.entry { continue }
        if !(seen[target_id] is null) { continue }
        seen[target_id] = true
        tp :: per_module[target_id]
        match tp {
            is null -> {}
            _ -> { out.push(tp) }
        }
    }
    return out
}

import "std/string" { starts_with, ends_with }
import "vader/resolver" { default_stdlib_root, module_id_from_root, resolve_import_path }


empty_impls :: fn() -> ImplRegistry { return new_registry() }

empty_fallback :: fn(project: LoadedProject) -> TypedProgram {
    loaded :: project.modules[project.entry]
    match loaded {
        is null -> {
            // Defensive — load_project guarantees entry is loaded.
            return new_typed_program(synth_resolved())
        }
        _ -> {
            rm :: resolve_module(loaded.module.files[0].program, project.entry, project.factory)
            return new_typed_program(rm)
        }
    }
}

synth_resolved :: fn() -> ResolvedModule {
    return ResolvedModule {
        .path = "",
        .display_path = "",
        .symbols = [],
        .symbols_by_name = MutableMap<string, Symbol> {},
        .idents = MutableMap<u64, Symbol> {},
        .immutable_locals = MutableMap<i32, bool> {},
        .fn_overloads = MutableMap<string, Symbol[]> {},
        .core_symbols = MutableMap<string, Symbol> {},
        .imports_to = MutableMap<i32, Symbol> {},
        .alias_types = MutableMap<i32, Type> {},
        .alias_decls = MutableMap<i32, AST.TypeAliasDecl> {},
        .type_param_bounds = MutableMap<i32, AST.Expr> {},
        .diags = [],
        .deprecated_messages = MutableMap<i32, string> {},
        .namespace_member_types = MutableMap<i32, MutableMap<string, Type>> {},
    }
}

/// For every Symbol id appearing in `import_targets` as a
/// `SymbolTarget`, copy its declared type from the target module's
/// `decl_types` into `entry_typed.external_types`. Lets
/// `infer_ident` resolve a cross-module name to its full type
/// without re-walking the project at lookup time.
populate_external_types :: fn(
    entry_typed: TypedProgram, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> void {
    match entry_typed.import_targets {
        is null -> {}
        _ -> { populate_from(entry_typed.import_targets, entry_typed, project, per_module) }
    }
}

populate_from :: fn(
    targets: ImportTargetTable, entry_typed: TypedProgram,
    project: LoadedProject, per_module: MutableMap<string, TypedProgram>,
) -> void {
    for sym_id in targets.symbol_targets.keys() {
        st :: targets.symbol_targets[sym_id]
        if st is null { continue }
        external :: lookup_external_type(st, per_module)
        match external {
            is null -> {}
            _ -> { entry_typed.external_types[st.symbol.id] = external }
        }
    }
    // Namespace targets : for `name :: import "p"`, materialise an
    // `(field_name → Type)` table from `p`'s public exports so
    // `field.vader` can resolve `name.foo` accesses.
    for sym_id in targets.namespace_targets.keys() {
        mod_id :: targets.namespace_targets[sym_id]
        if mod_id is null { continue }
        if entry_typed.namespace_exports[mod_id] is null {
            entry_typed.namespace_exports[mod_id] = build_namespace_exports(mod_id, project, per_module)
        }
    }
}

// Merge every other module's `struct_decls` and `trait_decls` into
// the entry's tables so `field.vader` can look up cross-module
// struct field definitions when resolving `external_pt.field`.
// Each module mints its own Symbol ids ; the entries don't collide.
// Walk every non-entry module's `ImplDecl`s and register their UFCS
// method signatures in the entry's `impl_methods` table. Lets
// `sb.to_string()` (where the impl lives in `std/string_builder`)
// dispatch through the same path as local impls.
merge_external_impl_methods :: fn(
    entry_typed: TypedProgram, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> void {
    entry_path :: entry_typed.resolved.path
    for id in per_module.keys() {
        other :: per_module[id]
        if other is null { continue }
        if other.resolved.path == entry_path { continue }
        loaded :: project.modules[id]
        if loaded is null { continue }
        for decl in merge_module_program(loaded.module.files).decls {
            match decl {
                is AST.ImplDecl as id_decl -> {
                    for_ty :: type_from_expr(id_decl.for_type, other.resolved, diag_sink())
                    record_struct_trait(entry_typed, for_ty, id_decl.trait_name)
                    // Trait args resolve in the impl owner's scope so
                    // cross-module impls record concrete types.
                    impl_trait_args: Type[] = []
                    for ta in id_decl.trait_args {
                        impl_trait_args.push(type_from_expr(ta, other.resolved, diag_sink()))
                    }
                    record_struct_trait_args(entry_typed, for_ty, id_decl.trait_name, impl_trait_args)
                    trait_decl_ext :: lookup_trait_decl(id_decl.trait_name, entry_typed)
                    for m in id_decl.members {
                        key :: "${display_type(for_ty)}::${m.name}"
                        base_key :: "${type_base_name(for_ty)}::${m.name}"
                        trait_method_ext :: lookup_trait_method(trait_decl_ext, m.name)
                        ufcs_ty :: ufcs_method_type(m, for_ty, trait_method_ext, other, diag_sink())
                        match ufcs_ty {
                            is null -> {}
                            _ -> {
                                entry_typed.impl_methods[key] = ufcs_ty
                                entry_typed.impl_methods[base_key] = ufcs_ty
                                record_impl_trait(entry_typed, base_key, id_decl.trait_name)
                            }
                        }
                    }
                    base_key :: type_base_name(for_ty)
                    // `X implements Iterator(T)` — index the element
                    // type so `for x in X { … }` binds `x` to T.
                    if id_decl.trait_name == "Iterator" && id_decl.trait_args.len() == 1 {
                        elem :: type_from_expr(id_decl.trait_args[0], other.resolved, diag_sink())
                        entry_typed.iter_element_types[base_key] = elem
                    }
                    // `X implements Into(Iterator(T))` — for-in
                    // coercion : `for x in X` desugars to `Into(Iterator(T))::into()`
                    // then iterates the result, yielding T.
                    if id_decl.trait_name == "Into" && id_decl.trait_args.len() == 1 {
                        elem :: into_iterator_element(id_decl.trait_args[0], other.resolved)
                        match elem {
                            is null -> {}
                            _ -> { entry_typed.iter_element_types[base_key] = elem }
                        }
                    }
                    // `X implements Index[I, T]` — index the result
                    // type so `m[k]` returns T.
                    if id_decl.trait_name == "Index" && id_decl.trait_args.len() == 2 {
                        result_ty :: type_from_expr(id_decl.trait_args[1], other.resolved, diag_sink())
                        entry_typed.index_target_types[base_key] = result_ty
                    }
                }
                _ -> {}
            }
        }
    }
}

diag_sink :: fn() -> Diagnostic[] { return [] }


// `Into(Iterator(T))` is the for-in coercion entry point — pull T
// out of the `Iterator(T)` arg so `for x in X` binds x to T.
// Returns null when the arg isn't shaped like `Iterator(T)`.
into_iterator_element :: fn(
    arg: AST.TypeExpr, resolved: ResolvedModule,
) -> Type | null {
    if !(arg is AST.GenericInstExpr) { return null }
    if !(arg.callee is AST.IdentExpr) { return null }
    if arg.callee.name != "Iterator" { return null }
    if arg.type_args.len() != 1 { return null }
    return type_from_expr(arg.type_args[0], resolved, diag_sink())
}

// Append `trait_name` to the impl-method-trait bucket for `base_key`.
// Two distinct traits providing the same method on the same receiver
// make `x.method()` ambiguous (T3032).
record_impl_trait :: fn(typed: TypedProgram, base_key: string, trait_name: string) -> void {
    bucket :: typed.impl_method_traits[base_key]
    match bucket {
        is null -> { typed.impl_method_traits[base_key] = [trait_name] }
        _ -> {
            for n in bucket { if n == trait_name { return } }
            bucket.push(trait_name)
            typed.impl_method_traits[base_key] = bucket
        }
    }
}

record_struct_trait :: fn(typed: TypedProgram, for_ty: Type, trait_name: string) -> void {
    name :: type_base_name(for_ty)
    if name == "" { return }
    bucket :: typed.struct_implemented_traits[name]
    match bucket {
        is null -> { typed.struct_implemented_traits[name] = [trait_name] }
        _ -> {
            for n in bucket { if n == trait_name { return } }
            bucket.push(trait_name)
            typed.struct_implemented_traits[name] = bucket
        }
    }
}

record_struct_trait_args :: fn(
    typed: TypedProgram, for_ty: Type, trait_name: string, args: Type[],
) -> void {
    name :: type_base_name(for_ty)
    if name == "" { return }
    per_struct :: typed.struct_trait_args[name]
    match per_struct {
        is null -> {
            fresh :: MutableMap<string, Type[]> {}
            fresh[trait_name] = args
            typed.struct_trait_args[name] = fresh
        }
        _ -> { per_struct[trait_name] = args }
    }
}


// Walk every loaded module's `ImplDecl`s and call
// `materialize_sam_members` against the matching trait — works
// cross-module so `Foo implements Display -> "..."` picks up
// Display from `std/core`. Emits R2016 when the short impl form
// (`Type implements Trait -> expr`) targets a trait with != 1
// required method.
export materialize_all_sams_pre_resolve :: fn(project: LoadedProject) -> void {
    for id in project.modules.keys() {
        loaded :: project.modules[id]
        if loaded is null { continue }
        for decl in merge_module_program(loaded.module.files).decls {
            if !(decl is AST.ImplDecl) { continue }
            found :: find_named_decl_in_project(decl.trait_name, project)
            if found.trait_decl is null {
                if found.other_kind != "" {
                    project.diags.push(resolver_error(.TraitNameNotATrait,
                        decl.trait_name_span,
                        "`${decl.trait_name}` is a ${found.other_kind}"))
                } else {
                    project.diags.push(resolver_error(.UnresolvedTypeName,
                        decl.trait_name_span, "`${decl.trait_name}`"))
                }
                continue
            }
            trait_decl :: found.trait_decl
            check_short_impl_arity(decl, trait_decl, project.diags)
            // `@intrinsic <T> implements <Trait>` arrives with an empty
            // `members` list — synthesise body-less FnDecls from the
            // trait's methods so the rest of the pipeline (declare /
            // ufcs / walk_fn_body) sees them.
            materialize_intrinsic_members(decl, trait_decl)
            // Always materialise the SAM rename — `check_short_impl_arity`
            // already marked invalid synthetics as `materialized=true` so
            // body-walk + body-typecheck skip them, but the rename still
            // lets the T3036 "missing method" loop credit the SAM-named
            // slot. Without the rename, both required methods would be
            // flagged missing instead of just the unprovided one.
            materialize_sam_members(decl, trait_decl, loaded.node_id_factory)
            // Default-bodied trait methods get cloned into the impl
            // (body + signature substituted). Bodies carry the
            // materialised-span marker + IDs minted from the host
            // module's factory so cloned nodes contribute distinct
            // expr_types entries in the typecheck dump (rendered as
            // `undefined:undefined` — matches TS).
            materialize_default_members(decl, trait_decl, loaded.node_id_factory)
        }
    }
}

/// R2016 : `Type implements Trait -> expr` desugars one body into the
/// trait's lone required method. When the trait has 0 or 2+ required
/// methods, the sugar is ill-defined — emit once per synthetic member.
/// Mirrors `src/resolver/materialize.ts::checkShortImplArity`.
check_short_impl_arity :: fn(
    impl_: AST.ImplDecl, trait_: AST.TraitDecl, diags: Diagnostic[],
) -> bool {
    required :: required_methods(trait_.members).len()
    if required == usize(1) { return true }
    fired := false
    for i in 0..<impl_.members.len() {
        m :: impl_.members[i]
        if m.sam_synthetic {
            diags.push(resolver_error(.ShortImplFormSingleMethod, m.span,
                "trait `${impl_.trait_name}` has ${required} required methods"))
            // Mark the synthetic body as already-typechecked so the
            // walker skips it — otherwise T3020 / R2006 on `self` cascade
            // out of a body the user can't fix without restructuring the
            // impl. Same `materialized` flag default-method clones use.
            impl_.members[i].materialized = true
            fired = true
        }
    }
    return !fired
}

import "vader/diagnostics" { resolver_error }
import "vader/resolver" { required_methods }

/// Project-wide trait-name lookup. Single walk discriminates
/// "found as trait" from "found as non-trait" so the impl-resolution
/// path can emit R2007 vs R2009 without a second traversal.
NamedDeclLookup :: struct {
    trait_decl: AST.TraitDecl | null
    /// Empty when no decl named `name` was found ; otherwise one of
    /// `"struct"` / `"enum"` / `"alias"`. Only meaningful when
    /// `trait_decl is null` ; the trait branch wins.
    other_kind: string
}

find_named_decl_in_project :: fn(
    name: string, project: LoadedProject,
) -> NamedDeclLookup {
    other: string = ""
    for id in project.modules.keys() {
        loaded :: project.modules[id]
        if loaded is null { continue }
        for decl in merge_module_program(loaded.module.files).decls {
            if decl is AST.TraitDecl {
                if decl.name == name { return NamedDeclLookup { .trait_decl = decl, .other_kind = "" } }
            }
            if other == "" {
                if decl is AST.StructDecl    { if decl.name == name { other = "struct" } }
                if decl is AST.EnumDecl      { if decl.name == name { other = "enum" } }
                if decl is AST.TypeAliasDecl { if decl.name == name { other = "alias" } }
            }
        }
    }
    return NamedDeclLookup { .trait_decl = null, .other_kind = other }
}

// Back-compat shim — kept for the bytecode emit + other consumers
// that only need the trait branch.
find_trait_decl_in_project :: fn(
    name: string, project: LoadedProject,
) -> AST.TraitDecl | null {
    return find_named_decl_in_project(name, project).trait_decl
}

import "vader/resolver" {
    materialize_default_members, materialize_intrinsic_members, materialize_sam_members,
}

has_expr_bodied_fn :: fn(decls: AST.Decl[]) -> bool {
    for d in decls {
        if d is AST.FnDecl {
            if d.is_expression_bodied {
                if d.return_type is null { return true }
            }
        }
        if d is AST.ImplDecl {
            for m in d.members {
                if m.is_expression_bodied {
                    if m.return_type is null { return true }
                }
            }
        }
    }
    return false
}

// Clear per-expression tables so the second pass can re-populate
// them with the now-settled fn return types. Decl-level tables
// (`decl_types`, struct/trait decls, impl_methods, …) stay intact —
// only side-tables filled from inside fn bodies need a refresh.
reset_expr_tables :: fn(typed: TypedProgram) -> void {
    typed.expr_types = MutableMap<usize, Type> {}
    typed.expr_kinds = MutableMap<usize, string> {}
    typed.node_spans = MutableMap<usize, Span> {}
    typed.ufcs_receiver_types = MutableMap<usize, Type> {}
    typed.local_types = MutableMap<u64, Type> {}
    typed.narrowed_bindings = MutableMap<i32, Type> {}
}

// Walk a module's top-level decls and register every type alias
// (explicit `T :: type ...` or implicit `T :: <type-expr>`) into
// `resolved.alias_types`. Runs across the project BEFORE
// `declare_module` so cross-module aliases resolve at fn-signature
// lowering time.
register_aliases :: fn(typed: TypedProgram, decls: AST.Decl[]) -> void {
    for decl in decls {
        match decl {
            is AST.TypeAliasDecl as ta -> {
                aliased :: type_from_expr(ta.aliased, typed.resolved, diag_sink())
                for s in typed.resolved.symbols {
                    if s.name == ta.name {
                        typed.resolved.alias_types[s.id] = aliased
                        typed.resolved.alias_decls[s.id] = ta
                    }
                }
            }
            is AST.ConstDecl as cd -> {
                if cd.ty is null && register_alias_const(cd, typed) {}
            }
            _ -> {}
        }
    }
}

// Compute every enum's `EnumType` across all files of all modules (Phase A)
// and broadcast it into every module's `alias_types`, keyed by the enum
// symbol's global id. A fn signature or struct field then resolves an enum
// reference — same-module, cross-module, or in a sibling file of a
// multi-file module — to its `EnumType` rather than the `type_from_symbol`
// `.Enum -> mk_struct` placeholder, so the bytecode emit collapses the enum
// to its `repr` ordinal. Enum-only — type aliases keep their entry-merge
// scope. Keyed by global symbol id, so no cross-module name collisions.
// Must run before `declare_module` lowers any signature.
// Cross-module struct visibility : each module's `declare_module` only
// populates its OWN `struct_decls` / `struct_field_types`. Field access
// on a local variable typed as a struct from another module (e.g.
// `block: LoweredBlock` in main.vader, with LoweredBlock from
// vader/lower) lookups `typed.struct_decls[sym.id]` on the CURRENT
// module's view — misses → `?` → cascading. Merge every module's
// struct tables into every other module's view so the lookup hits
// regardless of where the struct was declared. Symbol.id is the global
// key, so a flat merge is enough. Mirror of `broadcast_enum_types`.
broadcast_struct_decls :: fn(per_module: MutableMap<string, TypedProgram>) -> void {
    all_decls :: MutableMap<i32, AST.StructDecl> {}
    all_fields :: MutableMap<i32, MutableMap<string, Type>> {}
    for id in per_module.keys() {
        typed :: per_module[id]
        if typed == null { continue }
        for sid in typed.struct_decls.keys() {
            d :: typed.struct_decls[sid]
            if d != null { all_decls[sid] = d }
        }
        for sid in typed.struct_field_types.keys() {
            f :: typed.struct_field_types[sid]
            if f != null { all_fields[sid] = f }
        }
    }
    for id in per_module.keys() {
        typed :: per_module[id]
        if typed == null { continue }
        for sid in all_decls.keys() {
            d :: all_decls[sid]
            if d != null && typed.struct_decls[sid] == null {
                typed.struct_decls[sid] = d
            }
        }
        for sid in all_fields.keys() {
            f :: all_fields[sid]
            if f != null && typed.struct_field_types[sid] == null {
                typed.struct_field_types[sid] = f
            }
        }
    }
}

broadcast_enum_types :: fn(per_module: MutableMap<string, TypedProgram>, project: LoadedProject) -> void {
    collected :: MutableMap<i32, Type> {}
    for id in per_module.keys() {
        typed :: per_module[id]
        if typed is null { continue }
        loaded :: project.modules[id]
        if loaded is null { continue }
        by_name :: MutableMap<string, Symbol> {}
        for s in typed.resolved.symbols { by_name[s.name] = s }
        for file in loaded.module.files {
            for decl in file.program.decls {
                if decl is AST.EnumDecl as ed {
                    sym :: by_name[ed.name]
                    if sym is null { continue }
                    repr :: resolve_repr(ed.repr, typed.resolved, diag_sink())
                    indices :: resolve_enum_indices(ed, repr, diag_sink())
                    collected[sym.id] = mk_enum(sym, repr, indices)
                }
            }
        }
    }
    for id in per_module.keys() {
        typed :: per_module[id]
        if typed is null { continue }
        for sid in collected.keys() {
            t :: collected[sid]
            if t is null { continue }
            typed.resolved.alias_types[sid] = t
        }
    }
}

register_alias_const :: fn(cd: AST.ConstDecl, typed: TypedProgram) -> bool {
    if !is_alias_value_expr(cd.value, typed.resolved) { return false }
    aliased :: type_from_expr(cd.value, typed.resolved, diag_sink())
    for s in typed.resolved.symbols {
        if s.name == cd.name {
            typed.resolved.alias_types[s.id] = aliased
        }
    }
    return true
}

export is_alias_value_expr :: fn(e: AST.Expr, resolved: ResolvedModule) -> bool {
    if e is AST.IdentExpr {
        if is_primitive_name(e.name) { return true }
        sym :: resolved.idents[e.span.hash()]
        if sym is null { return false }
        match sym.kind {
            .Struct -> { return true }
            .Trait  -> { return true }
            .Enum   -> { return true }
            .TypeAlias -> { return true }
            .TypeParam -> { return true }
            .BuiltinType -> { return true }
            _ -> { return false }
        }
    }
    if e is AST.BinaryExpr {
        if i32(e.op) == i32(AST.BinaryOp.BitOr) {
            return is_alias_value_expr(e.left, resolved) && is_alias_value_expr(e.right, resolved)
        }
    }
    if e is AST.GenericInstExpr { return true }
    if e is AST.FnTypeExpr { return true }
    if e is AST.ArrayTypeExpr { return true }
    return false
}

import "vader/types" { is_primitive_name }

// Mirror every non-entry module's `alias_types` / `alias_decls` into
// the entry's resolver tables so cross-module aliases (e.g. `Pet`
// imported from `./types`) expand at use sites.
merge_external_alias_types :: fn(
    entry_typed: TypedProgram, per_module: MutableMap<string, TypedProgram>,
) -> void {
    entry_path :: entry_typed.resolved.path
    for id in per_module.keys() {
        other :: per_module[id]
        if other is null { continue }
        if other.resolved.path == entry_path { continue }
        for sym_id in other.resolved.alias_types.keys() {
            ty :: other.resolved.alias_types[sym_id]
            if ty is null { continue }
            entry_typed.resolved.alias_types[sym_id] = ty
        }
        for sym_id in other.resolved.alias_decls.keys() {
            decl :: other.resolved.alias_decls[sym_id]
            if decl is null { continue }
            entry_typed.resolved.alias_decls[sym_id] = decl
        }
    }
}

/// Copy every typed program's `trait_decls` (+ owner) into every
/// other typed program's tables. After this each per_module knows
/// about every project-wide trait, so default-method dispatch from
/// any body can find the trait declaration regardless of which
/// module the trait lives in.
cross_publish_trait_decls :: fn(per_module: MutableMap<string, TypedProgram>) -> void {
    // Pass 1 : collect every (trait_sym_id, decl, owner) tuple.
    ids: i32[] = []
    decls: AST.TraitDecl[] = []
    owners: ResolvedModule[] = []
    for id in per_module.keys() {
        tp :: per_module[id]
        if tp is null { continue }
        for sym_id in tp.trait_decls.keys() {
            d :: tp.trait_decls[sym_id]
            if d is null { continue }
            o :: tp.trait_decl_owners[sym_id]
            owner_resolved: ResolvedModule = tp.resolved
            match o {
                is null -> {}
                _ -> { owner_resolved = o }
            }
            ids.push(sym_id)
            decls.push(d)
            owners.push(owner_resolved)
        }
    }
    // Pass 2 : write back into every typed program.
    for id in per_module.keys() {
        tp :: per_module[id]
        if tp is null { continue }
        for i in 0..<ids.len() {
            sid :: ids[i]
            tp.trait_decls[sid] = decls[i]
            tp.trait_decl_owners[sid] = owners[i]
        }
    }
}

/// Same idea as `cross_publish_trait_decls` but for `fn_decls`.
/// Lets T3006 enforcement reach cross-module callees (e.g. checking
/// bounds on `std/math.min`'s type-params from an entry call site).
cross_publish_fn_decls :: fn(per_module: MutableMap<string, TypedProgram>) -> void {
    ids: i32[] = []
    fdecls: AST.FnDecl[] = []
    for id in per_module.keys() {
        tp :: per_module[id]
        if tp is null { continue }
        for sym_id in tp.fn_decls.keys() {
            d :: tp.fn_decls[sym_id]
            if d is null { continue }
            ids.push(sym_id)
            fdecls.push(d)
        }
    }
    for id in per_module.keys() {
        tp :: per_module[id]
        if tp is null { continue }
        for i in 0..<ids.len() {
            tp.fn_decls[ids[i]] = fdecls[i]
        }
    }
}

merge_struct_decls :: fn(
    entry_typed: TypedProgram, per_module: MutableMap<string, TypedProgram>,
) -> void {
    entry_path :: entry_typed.resolved.path
    for id in per_module.keys() {
        other :: per_module[id]
        if other is null { continue }
        if other.resolved.path == entry_path { continue }
        for sym_id in other.struct_decls.keys() {
            decl :: other.struct_decls[sym_id]
            if decl is null { continue }
            entry_typed.struct_decls[sym_id] = decl
        }
        for sym_id in other.trait_decls.keys() {
            decl :: other.trait_decls[sym_id]
            if decl is null { continue }
            entry_typed.trait_decls[sym_id] = decl
            owner :: other.trait_decl_owners[sym_id]
            match owner {
                is null -> { entry_typed.trait_decl_owners[sym_id] = other.resolved }
                _ -> { entry_typed.trait_decl_owners[sym_id] = owner }
            }
        }
        for sym_id in other.struct_field_types.keys() {
            fmap :: other.struct_field_types[sym_id]
            if fmap is null { continue }
            entry_typed.struct_field_types[sym_id] = fmap
            // Walk every field type for transitively-referenced named
            // types (Enum / Struct / Trait declared in other modules
            // but not directly imported by the entry). Pull their real
            // `decl_types` entries into `external_types` so passes that
            // lift placeholders (e.g. `lift_enum_placeholder` in
            // `expr_dot_variant.vader`) can find them. Without this,
            // `FlagSpec { .kind = .Str }` rejects `.Str` because
            // `FlagKind` (only reached transitively via the struct
            // field) never lands in any lookup table.
            for fname in fmap.keys() {
                ft :: fmap[fname]
                if ft is null { continue }
                pull_referenced_external_types(ft, entry_typed, per_module)
            }
        }
    }
}

/// Walk `t` and, for every named-type symbol (Struct / Enum / Trait)
/// declared in a non-entry module, copy its real declared type from
/// the owning module's `decl_types` into `entry.external_types`. The
/// `external_types[id]` presence check inside `register_external`
/// both memoizes and breaks Struct ↔ Struct cycles.
///
/// Spells out the variant arms instead of routing through
/// `for_each_type` so the recursion stays a plain call graph — a
/// closure capturing the two-field context tripped the self-host
/// codegen at the time of writing.
pull_referenced_external_types :: fn(
    t: Type, entry: TypedProgram, per_module: MutableMap<string, TypedProgram>,
) -> void {
    match t {
        is StructType as st -> {
            register_external(st.symbol, entry, per_module)
            for a in st.args { pull_referenced_external_types(a, entry, per_module) }
        }
        is TraitType as tr -> {
            register_external(tr.symbol, entry, per_module)
            for a in tr.args { pull_referenced_external_types(a, entry, per_module) }
        }
        is EnumType as en -> { register_external(en.symbol, entry, per_module) }
        is ArrayType as a -> { pull_referenced_external_types(a.element, entry, per_module) }
        is TupleType as p -> {
            for el in p.elements { pull_referenced_external_types(el, entry, per_module) }
        }
        is UnionType as u -> {
            for v in u.variants { pull_referenced_external_types(v, entry, per_module) }
        }
        is FnType as f -> {
            for p in f.params { pull_referenced_external_types(p, entry, per_module) }
            pull_referenced_external_types(f.return_type, entry, per_module)
        }
        _ -> {}
    }
}

register_external :: fn(
    sym: Symbol, entry: TypedProgram, per_module: MutableMap<string, TypedProgram>,
) -> void {
    if !(entry.external_types[sym.id] is null) { return }
    if sym.module == entry.resolved.path { return }
    owner :: per_module[sym.module]
    if owner is null { return }
    declared :: owner.decl_types[sym.id]
    if declared is null { return }
    entry.external_types[sym.id] = declared
    // Chained references — `Foo { bar: Bar }` where `Bar { baz: Baz }`.
    pull_referenced_external_types(declared, entry, per_module)
}

// Build a name → FnType[] index of every imported free fn so
// `field.vader::try_free_fn_ufcs` can dispatch `x.method()` to a
// stdlib helper without requiring the user to re-implement it
// locally. Walks `external_types` (already populated with the
// imported name's resolved Type) and buckets by symbol name.
/// Pre-walk every non-entry, non-stdlib module's bodies so that
/// expression-bodied fns get their return-type patched into the
/// owning module's decl_types (used by `populate_imported_fn_overloads`)
/// AND so the per-module `expr_types` / `expr_kinds` populate for
/// the typecheck dump — every loaded user module gets its own
/// `## <path>` section with its body's expr lines.
settle_external_expr_bodied_returns :: fn(
    project: LoadedProject, per_module: MutableMap<string, TypedProgram>,
) -> void {
    entry_path :: project.entry
    // Two-pass : expression-bodied fns whose body calls other expr-bodied
    // fns in the same module need the callees' return types patched
    // before the caller's inference sees them. A second walk picks up
    // the now-resolved return types so chains like
    // `lexer_error(...) = new_diagnostic(...)` (where new_diagnostic
    // is itself expr-bodied) settle to the concrete return type
    // instead of `?`.
    //
    // Pass 0 always runs on every module — that's the only place
    // per-module `expr_types` / `expr_kinds` get populated for the
    // typecheck dump's `## <path>` sections.
    //
    // Pass 1 is the re-walk that picks up settled returns ; it's
    // pure waste on modules without expression-bodied fns since
    // there's nothing to re-settle. Gate it so std/iter et al. don't
    // pay for a double-walk just because a sibling module needed
    // settling.
    for pass in 0..<2 {
        for id in project.modules.keys() {
            if id == entry_path { continue }
            loaded :: project.modules[id]
            if loaded is null { continue }
            other_typed :: per_module[id]
            if other_typed is null { continue }
            if pass == 1 && !has_expr_bodied_fn(merge_module_program(loaded.module.files).decls) { continue }
            walk_bodies(merge_module_program(loaded.module.files).decls, other_typed, diag_sink())
        }
    }
}

populate_imported_fn_overloads :: fn(
    entry_typed: TypedProgram, per_module: MutableMap<string, TypedProgram>,
) -> void {
    // First : every named import lands in `imported_fn_overloads`
    // so explicitly-imported helpers (e.g. `import "p" { foo }`)
    // dispatch via UFCS on their declared first param.
    targets :: entry_typed.import_targets
    match targets {
        is null -> {}
        _ -> {
            for sym_id in targets.symbol_targets.keys() {
                st :: targets.symbol_targets[sym_id]
                if st is null { continue }
                ty :: entry_typed.external_types[st.symbol.id]
                if ty is null { continue }
                match ty {
                    is FnType as ft -> {
                        push_overload(entry_typed, st.symbol.name, ft)
                        // Also push under the entry's binding name so
                        // `import "std/iter" { slice as slice_array }`
                        // is dispatchable as `arr.slice_array(...)`.
                        // sym_id is the entry's ImportBinding ; find
                        // its local name in resolved.symbols.
                        for s in entry_typed.resolved.symbols {
                            if s.id == sym_id && s.name != st.symbol.name {
                                push_overload(entry_typed, s.name, ft)
                            }
                        }
                    }
                    _ -> {}
                }
            }
        }
    }
    // Then : every loaded module's `decl_types` contributes its
    // exported fns so unqualified UFCS dispatch (e.g. `sb.to_string()`
    // where `to_string` wasn't explicitly imported) still finds the
    // matching free fn from `std/string_builder`. We iterate
    // `fn_overloads` (not `symbols`) so every overload of the same
    // name (`len :: fn[T](self: MutableSet(T))` AND `len :: fn[K, V]
    // (self: MutableMap(K, V))`) lands in the bucket.
    entry_path :: entry_typed.resolved.path
    for id in per_module.keys() {
        other :: per_module[id]
        if other is null { continue }
        if other.resolved.path == entry_path { continue }
        for name in other.resolved.fn_overloads.keys() {
            bucket :: other.resolved.fn_overloads[name]
            if bucket is null { continue }
            for sym in bucket {
                ty :: other.decl_types[sym.id]
                if ty is null { continue }
                match ty {
                    is FnType as ft -> { push_overload(entry_typed, name, ft) }
                    _ -> {}
                }
            }
        }
    }
}

push_overload :: fn(typed: TypedProgram, name: string, ft: FnType) -> void {
    bucket :: typed.imported_fn_overloads[name]
    match bucket {
        is null -> { typed.imported_fn_overloads[name] = [ft] }
        _       -> {
            bucket.push(ft)
            typed.imported_fn_overloads[name] = bucket
        }
    }
}

// Mirror `import_targets.symbol_targets` into the resolver's
// `imports_to` table so `type_from_expr` can dereference ImportBinding
// symbols (e.g. `ParseError` from `std/string`) to their real exported
// counterpart without needing the full `TypedProgram`.
populate_resolver_imports :: fn(entry_typed: TypedProgram) -> void {
    match entry_typed.import_targets {
        is null -> {}
        _ -> {
            for sym_id in entry_typed.import_targets.symbol_targets.keys() {
                st :: entry_typed.import_targets.symbol_targets[sym_id]
                if st is null { continue }
                entry_typed.resolved.imports_to[sym_id] = st.symbol
            }
        }
    }
}

/// Mirror `entry_typed.import_targets` onto every non-entry module's
/// `resolved.imports_to`. Without this, the non-entry typecheck pass
/// can't follow its own ImportBinding symbols to the real exports —
/// every cross-module type reference (e.g. `LexerCode` in
/// `diagnostic.vader` when the entry isn't `diagnostic.vader` itself)
/// collapses to `?` (Unresolved) and cascades through every
/// downstream `match` / `is` check. Each non-entry module owns its
/// own subset of sym.ids ; we walk per-module collected.imports to
/// route each id back to its owning module's `imports_to`.
populate_resolver_imports_for_others :: fn(
    entry_typed: TypedProgram, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> void {
    targets :: entry_typed.import_targets
    if targets is null { return }
    for id in project.modules.keys() {
        if id == project.entry { continue }
        loaded :: project.modules[id]
        if loaded is null { continue }
        other_typed :: per_module[id]
        if other_typed is null { continue }
        for sym_id in loaded.collected.imports.keys() {
            st :: targets.symbol_targets[sym_id]
            if st is null { continue }
            other_typed.resolved.imports_to[sym_id] = st.symbol
        }
    }
}

preload_core_symbols :: fn(rm: ResolvedModule, project: LoadedProject) -> void {
    core_id :: find_core_module_id(project)
    if core_id is null { return }
    core_loaded :: project.modules[core_id]
    if core_loaded is null { return }
    for name in core_loaded.collected.symbols.keys() {
        sym :: core_loaded.collected.symbols[name]
        if sym is null { continue }
        rm.core_symbols[name] = sym
    }
}

populate_core_symbols :: fn(
    entry_typed: TypedProgram, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> void {
    core_id :: find_core_module_id(project)
    if core_id is null { return }
    core_loaded :: project.modules[core_id]
    if core_loaded is null { return }
    core_typed :: per_module[core_id]
    // EXPERIMENT (complete fix): seed core symbols into EVERY module's typed
    // program, not just the entry.
    populate_core_symbols_into(entry_typed, core_loaded, core_typed)
    for id in per_module.keys() {
        other :: per_module[id]
        if other == null { continue }
        if other.resolved.path != entry_typed.resolved.path {
            populate_core_symbols_into(other, core_loaded, core_typed)
        }
    }
}

populate_core_symbols_into :: fn(
    typed: TypedProgram, core_loaded: LoadedModule, core_typed: TypedProgram | null,
) -> void {
    for name in core_loaded.collected.symbols.keys() {
        sym :: core_loaded.collected.symbols[name]
        if sym == null { continue }
        typed.core_symbols[name] = sym
        // Mirror into the resolver's `core_symbols` table so
        // `type_from_expr` can fall back to it for bare names
        // referencing core types (Error, Range, …).
        typed.resolved.core_symbols[name] = sym
        // Also surface the type into `external_types` so a future
        // reference to a core symbol (e.g. via `mk_struct(Range, ...)`)
        // returns the concrete declared type.
        if core_typed == null { continue }
        t :: core_typed.decl_types[sym.id]
        if t == null { continue }
        typed.external_types[sym.id] = t
    }
}


build_namespace_exports :: fn(
    mod_id: string, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> MutableMap<string, Type> {
    out :: MutableMap<string, Type> {}
    loaded :: project.modules[mod_id]
    if loaded is null { return out }
    typed :: per_module[mod_id]
    if typed is null { return out }
    for name in loaded.collected.symbols.keys() {
        sym :: loaded.collected.symbols[name]
        if sym is null { continue }
        t :: typed.decl_types[sym.id]
        if !(t is null) {
            out[name] = t
            continue
        }
        aliased :: typed.resolved.alias_types[sym.id]
        if !(aliased is null) { out[name] = aliased }
    }
    return out
}

/// Pre-populate `entry_typed.resolved.namespace_member_types` from
/// each target module's `collected.symbols` + `alias_types`. Runs
/// BEFORE `declare_module` so fn signatures referencing `P.Decl` in
/// type position resolve correctly. The full `namespace_exports`
/// table (built later from `decl_types`) is only used for
/// value-position field access via `field.vader::try_namespace_field`.
/// Called for the entry AND for every imported module (each before its own
/// `declare_module`) — the whole-program lowerer lowers imported bodies too,
/// so their fn signatures can reference `P.Decl` namespace-qualified types
/// that must resolve here instead of degrading to `?`. Plain (non-namespace)
/// imports still resolve via `imports_to` + `alias_types` and don't need this.
prepopulate_namespace_member_types :: fn(
    entry_typed: TypedProgram, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> void {
    targets :: entry_typed.import_targets
    if targets is null { return }
    for sym_id in targets.namespace_targets.keys() {
        mod_id :: targets.namespace_targets[sym_id]
        if mod_id is null { continue }
        members :: build_namespace_type_members(mod_id, project, per_module)
        entry_typed.resolved.namespace_member_types[sym_id] = members
    }
}

build_namespace_type_members :: fn(
    mod_id: string, project: LoadedProject,
    per_module: MutableMap<string, TypedProgram>,
) -> MutableMap<string, Type> {
    out :: MutableMap<string, Type> {}
    loaded :: project.modules[mod_id]
    if loaded is null { return out }
    target_typed :: per_module[mod_id]
    for name in loaded.collected.symbols.keys() {
        sym :: loaded.collected.symbols[name]
        if sym is null { continue }
        // TypeAlias resolves to the alias's expanded union (already
        // registered on the owning module's `resolved.alias_types`
        // by `register_aliases`). Other type-kind symbols resolve via
        // `type_from_symbol`, which dispatches on `sym.kind`.
        if !(target_typed is null) {
            aliased :: target_typed.resolved.alias_types[sym.id]
            if !(aliased is null) {
                out[name] = aliased
                continue
            }
        }
        if is_type_kind(sym.kind) { out[name] = type_from_symbol(sym, []) }
    }
    return out
}


import "vader/resolver" { SymbolTarget }

lookup_external_type :: fn(
    st: SymbolTarget, per_module: MutableMap<string, TypedProgram>,
) -> Type | null {
    typed :: per_module[st.module_id]
    if typed is null { return null }
    declared :: typed.decl_types[st.symbol.id]
    if !(declared is null) { return declared }
    return typed.resolved.alias_types[st.symbol.id]
}

/// Walk every fn / const body in `decls` and type-check it. Skips
/// extern / abstract decls (no body). For ConstDecls without an
/// annotation, types the value expression and back-fills the const's
/// declared type (post `default_if_free`) so `IdentExpr` lookups
/// against it return a concrete type.
export walk_bodies :: fn(
    decls: AST.Decl[], typed: TypedProgram, diags: Diagnostic[],
) -> void {
    // Pre-pass : seed `struct_implemented_traits` for every impl in the
    // module so any earlier-declared impl's body that returns a
    // later-declared type can still trait-widen. Bigger metadata (impl
    // methods, iter_element_types, Into-keys, …) still lands in the main
    // pass so the order-of-operations within each impl block stays the
    // same — fewer surprises for downstream passes.
    for decl in decls {
        match decl {
            is AST.ImplDecl as id -> {
                for_ty :: type_from_expr(id.for_type, typed.resolved, diag_sink())
                record_struct_trait(typed, for_ty, id.trait_name)
            }
            _ -> {}
        }
    }
    for decl in decls {
        match decl {
            is AST.FnDecl as fd -> { walk_fn_body(fd, typed, diags) }
            is AST.ConstDecl as cd -> { check_const_value(cd, typed, diags) }
            is AST.AssertDecl as ad -> { check_expr(ad.condition, null, typed, diags) }
            is AST.StructDecl as sd -> {
                // Type each field's default value against the field's
                // declared type so `delta: isize = -1` types the `-1`
                // UnaryExpr as `isize`, not the default `{integer}`.
                for f in sd.fields {
                    match f.default {
                        is null -> {}
                        _ -> {
                            field_ty :: type_from_expr(f.ty, typed.resolved, diags)
                            check_expr(f.default, field_ty, typed, diags)
                        }
                    }
                }
            }
            is AST.ImplDecl as id -> {
                for_ty :: type_from_expr(id.for_type, typed.resolved, diags)
                if id.trait_name == "Into" {
                    if id.trait_args.len() == 1 {
                        target_ty :: type_from_expr(id.trait_args[0], typed.resolved, diags)
                        if equals_type(for_ty, target_ty) {
                            diags.push(typecheck_error(.IntoIdentityForbidden, id.span,
                                "`${display_type(for_ty)} implements Into<${display_type(target_ty)}>` — source and target must differ"))
                        }
                    }
                }
                // Index `X implements Iterator(T)` so `for x in X` binds
                // `x` to T (matches the external-impl path).
                local_base_key :: type_base_name(for_ty)
                if id.trait_name == "Iterator" && id.trait_args.len() == 1 {
                    elem :: type_from_expr(id.trait_args[0], typed.resolved, diags)
                    typed.iter_element_types[local_base_key] = elem
                }
                if id.trait_name == "Into" && id.trait_args.len() == 1 {
                    elem :: into_iterator_element(id.trait_args[0], typed.resolved)
                    match elem {
                        is null -> {}
                        _ -> { typed.iter_element_types[local_base_key] = elem }
                    }
                }
                if id.trait_name == "Index" && id.trait_args.len() == 2 {
                    result_ty :: type_from_expr(id.trait_args[1], typed.resolved, diags)
                    typed.index_target_types[local_base_key] = result_ty
                }
                check_impl_missing_methods(id, typed, diags)
                record_struct_trait(typed, for_ty, id.trait_name)
                local_impl_trait_args: Type[] = []
                for ta in id.trait_args {
                    local_impl_trait_args.push(type_from_expr(ta, typed.resolved, diags))
                }
                record_struct_trait_args(typed, for_ty, id.trait_name, local_impl_trait_args)
                trait_decl :: lookup_trait_decl(id.trait_name, typed)
                for m in id.members {
                    trait_method :: lookup_trait_method(trait_decl, m.name)
                    declare_impl_method_for_trait(m, for_ty, trait_method, typed, diags)
                    key :: "${display_type(for_ty)}::${m.name}"
                    base_key :: "${type_base_name(for_ty)}::${m.name}"
                    ufcs_ty :: ufcs_method_type(m, for_ty, trait_method, typed, diags)
                    match ufcs_ty {
                        is null -> {}
                        _ -> {
                            typed.impl_methods[key] = ufcs_ty
                            typed.impl_methods[base_key] = ufcs_ty
                            record_impl_trait(typed, base_key, id.trait_name)
                        }
                    }
                    // `Into(T)` impls are indexed under a target-
                    // qualified key so multiple `Into` impls for the
                    // same source (e.g. `Into(i32)` + `Into(string)`)
                    // don't collide.
                    if id.trait_name == "Into" && id.trait_args.len() == 1 && m.name == "into" {
                        target_ty :: type_from_expr(id.trait_args[0], typed.resolved, diags)
                        into_key :: "${display_type(for_ty)}::into::${display_type(target_ty)}"
                        match ufcs_ty {
                            is null -> {}
                            _ -> { typed.impl_methods[into_key] = ufcs_ty }
                        }
                    }
                    walk_fn_body(m, typed, diags)
                }
            }
            _ -> {}
        }
    }
}

walk_fn_body :: fn(fd: AST.FnDecl, typed: TypedProgram, diags: Diagnostic[]) -> void {
    // SAM short-impl synthetics carry no real body to type ; skip them.
    // Default-method clones are also `materialized` but DO need typing —
    // the resolver bound their `self`, and their body's expr_types feed
    // the lowerer (otherwise every node lands on `:?`).
    if fd.materialized && fd.sam_synthetic { return }
    match fd.body {
        is null -> {}
        is AST.BlockExpr as body -> { check_fn_body(fd, body, typed, diags, check_expr) }
    }
}

/// Pre-walk an impl method's signature so `self` resolves to the
/// impl block's for-type and the rest of the params take their
/// annotated types. Result lands in `param_types` + `decl_types`
/// so `infer_ident` / `check_fn_body` see concrete types.
check_impl_missing_methods :: fn(
    id: AST.ImplDecl, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    trait_decl :: lookup_trait_decl(id.trait_name, typed)
    if trait_decl is null { return }
    for required in trait_decl.members {
        if required.body is null {
            if !impl_has_method(id, required.name) {
                diags.push(typecheck_error(.ImplMissingRequiredMethod, id.trait_name_span,
                    "`${id.trait_name}` requires method `${required.name}` — not provided in this impl block"))
            }
        }
    }
}

lookup_trait_method :: fn(td: AST.TraitDecl | null, name: string) -> AST.FnDecl | null {
    if td is null { return null }
    for m in td.members { if m.name == name { return m } }
    return null
}

lookup_trait_decl :: fn(name: string, typed: TypedProgram) -> AST.TraitDecl | null {
    for sym in typed.resolved.symbols {
        if sym.name != name { continue }
        td :: typed.trait_decls[sym.id]
        if td != null { return td }
    }
    // Cross-module fallback : `Direction implements Display { … }`
    // references `Display` without an explicit import binding, so the
    // local-symbol walk above misses it. `cross_publish_trait_decls`
    // already copies every trait decl into every typed program's
    // `trait_decls` map ; scan it directly by name. Mirror of TS'
    // `sourceTraitDecl(sym)` which reads the canonical decl off the
    // symbol's `source` pointer.
    for sym_id in typed.trait_decls.keys() {
        d :: typed.trait_decls[sym_id]
        if d is null { continue }
        if d.name == name { return d }
    }
    return null
}

impl_has_method :: fn(id: AST.ImplDecl, name: string) -> bool {
    for m in id.members { if m.name == name { return true } }
    return false
}

/// UFCS-bound method type : `fn(self, ...rest) -> R` lowers to
/// `fn(...rest) -> R` since the self is bound from the receiver.
/// Returns null when the signature is malformed.
ufcs_method_type :: fn(
    fd: AST.FnDecl, for_ty: Type, trait_method: AST.FnDecl | null,
    typed: TypedProgram, diags: Diagnostic[],
) -> Type | null {
    rest: Type[] = []
    for i in 0..<fd.params.len() {
        p :: fd.params[i]
        if i == 0 && p.name == "self" { continue }
        rest.push(param_type(p, for_ty, typed, diags))
    }
    ret :: declare_impl_return(fd, for_ty, trait_method, typed, diags)
    return mk_fn(rest, ret)
}

declare_impl_method_for_trait :: fn(
    fd: AST.FnDecl, for_ty: Type, trait_method: AST.FnDecl | null,
    typed: TypedProgram, diags: Diagnostic[],
) -> void {
    params: Type[] = []
    for p in fd.params {
        pt :: param_type(p, for_ty, typed, diags)
        typed.param_types[p.span.hash()] = pt
        params.push(pt)
    }
    ret :: declare_impl_return(fd, for_ty, trait_method, typed, diags)
    // Impl methods aren't in `resolved.symbols` (they're members of
    // an ImplDecl, not top-level names) — use the dedicated span-keyed
    // table.
    typed.impl_method_decl_types[fd.name_span.hash()] = mk_fn(params, ret)
}

declare_impl_return :: fn(
    fd: AST.FnDecl, for_ty: Type, trait_method: AST.FnDecl | null,
    typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    // Explicit annotation wins.
    match fd.return_type {
        is null -> {}
        _ -> { return type_from_expr(fd.return_type, typed.resolved, diags) }
    }
    // Trait method's return type, with `Self` substituted to `for_ty`,
    // when the impl's matching method has no annotation. Lets
    // `Direction implements Turnable { turn_left :: fn(self) = … }`
    // pick up `-> Self` from `Turnable.turn_left`.
    if !(trait_method is null) {
        match trait_method.return_type {
            is null -> {}
            _ -> {
                trait_ret :: type_from_expr(trait_method.return_type, typed.resolved, diags)
                return substitute_self(trait_ret, for_ty)
            }
        }
    }
    // Expression-bodied fns without an annotation defer to body
    // inference ; `check_fn_body` flips `inferred_return` on Unresolved.
    if fd.is_expression_bodied { return TY_UNRESOLVED }
    return TY_VOID
}


param_type :: fn(
    p: AST.FnParam, for_ty: Type, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    match p.ty {
        is null -> {
            if p.name == "self" { return for_ty }
            return TY_UNRESOLVED
        }
        _ -> { return type_from_expr(p.ty, typed.resolved, diags) }
    }
}

declare_return :: fn(
    fd: AST.FnDecl, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    match fd.return_type {
        is null -> {
            // Expression-bodied fns without an annotation defer their
            // return type to body inference (`check_fn_body` flips on
            // `inferred_return` when this comes back as Unresolved).
            if fd.is_expression_bodied { return TY_UNRESOLVED }
            return TY_VOID
        }
        _ -> { return type_from_expr(fd.return_type, typed.resolved, diags) }
    }
}


check_const_value :: fn(cd: AST.ConstDecl, typed: TypedProgram, diags: Diagnostic[]) -> void {
    sym :: lookup_sym_by_name_orch(typed.resolved, cd.name)
    if sym is null { return }
    annot :: typed.decl_types[sym.id]
    expected: Type | null = null
    match annot {
        is null -> {}
        _ -> { expected = annot }
    }
    if is_type_value_expr(cd.value, typed) {
        if annot is null {
            typed.decl_types[sym.id] = TY_TYPE
        }
        alias_ty :: type_from_expr(cd.value, typed.resolved, diags)
        typed.resolved.alias_types[sym.id] = alias_ty
        return
    }
    got :: check_expr(cd.value, expected, typed, diags)
    if annot is null {
        typed.decl_types[sym.id] = default_if_free(got)
    }
}

lookup_sym_by_name_orch :: fn(resolved: ResolvedModule, name: string) -> Symbol | null {
    for s in resolved.symbols { if s.name == name { return s } }
    return null
}

// True when `e` is an expression that names a type (builtin, struct,
// trait, type alias, …). These get folded by `type_from_expr` rather
// than walked as value-position expressions.
is_type_value_expr :: fn(e: AST.Expr, typed: TypedProgram) -> bool {
    if e is AST.IdentExpr {
        if !(primitive_from_name(e.name) is null) { return true }
        sym :: typed.resolved.idents[e.span.hash()]
        if sym is null { return false }
        return is_type_kind(sym.kind)
    }
    if e is AST.BinaryExpr {
        // Treat `T | U` chains as types.
        if i32(e.op) == i32(AST.BinaryOp.BitOr) {
            return is_type_value_expr(e.left, typed) && is_type_value_expr(e.right, typed)
        }
    }
    if e is AST.GenericInstExpr { return true }
    if e is AST.FnTypeExpr { return true }
    if e is AST.ArrayTypeExpr { return true }
    return false
}

is_type_kind :: fn(k: SymbolKind) -> bool = match k {
    .Struct    -> true
    .Trait     -> true
    .Enum      -> true
    .TypeAlias -> true
    .TypeParam -> true
    .BuiltinType -> true
    _ -> false
}

import "vader/resolver/symbol" { SymbolKind }

