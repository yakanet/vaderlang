// vader/typecheck/test_helpers — shared AST walker for inline @tests.
//
// `find_first_in_block` factors out the recursive descent every
// `infer_*` test block needs to locate the first expression a
// predicate accepts. Callers wrap with a tiny `accept_X` predicate
// and narrow the returned `AST.Expr | null` via `match … is AST.XExpr`.
//
// The per-file `*_check_stub` helpers and the parse + resolve + check pipeline
// stay per-file : moving them here would either create a file-level cycle
// (test_helpers would import every `infer_*`, but those files import
// test_helpers from their test block) or force every caller to absorb
// the exhaustive-match boilerplate for `AST.Expr | null`.

module "vader/typecheck"

AST :: import "vader/parser"

/// Walk the first decl's body looking for the first expression that
/// `pred` accepts (returns non-null). Descends through `BlockExpr`,
/// `ReturnStmt`, `ExprStmt`, `BinaryExpr.{left, right}`,
/// `CallExpr.{callee, args}`. Other variants are leaves for the walker.
///
/// `pred` receives every visited expression and returns either the
/// expression itself (to stop the walk) or `null` to keep walking.
/// Callers narrow the returned `AST.Expr | null` to the variant
/// they're looking for.
export find_first_in_block :: fn(
    b: AST.BlockExpr, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    for stmt in b.stmts {
        hit :: find_first_in_stmt(stmt, pred)
        if hit !is null { return hit }
    }
    t :: b.trailing
    if t is null { return null }
    return find_first_in_expr(t, pred)
}

find_first_in_stmt :: fn(
    s: AST.Stmt, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    match s {
        is AST.ReturnStmt as r -> {
            v :: r.value
            if v is null { return null }
            return find_first_in_expr(v, pred)
        }
        is AST.ExprStmt as es -> { return find_first_in_expr(es.expr, pred) }
        _ -> { return null }
    }
}

find_first_in_expr :: fn(
    e: AST.Expr, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    hit :: pred(e)
    if hit !is null { return hit }
    match e {
        is AST.BinaryExpr as b -> {
            l :: find_first_in_expr(b.left, pred)
            if l !is null { return l }
            return find_first_in_expr(b.right, pred)
        }
        is AST.CallExpr as c -> {
            callee :: find_first_in_expr(c.callee, pred)
            if callee !is null { return callee }
            for a in c.args {
                arg :: find_first_in_expr(a.value, pred)
                if arg !is null { return arg }
            }
            return null
        }
        is AST.FieldExpr as f -> { return find_first_in_expr(f.target, pred) }
        is AST.BlockExpr as bx -> { return find_first_in_block(bx, pred) }
        is AST.IfExpr as ifx -> {
            cond :: find_first_in_expr(ifx.cond, pred)
            if cond !is null { return cond }
            then :: find_first_in_block(ifx.then_block, pred)
            if then !is null { return then }
            match ifx.else_branch {
                is null -> { return null }
                is AST.IfElseBlock as eb -> { return find_first_in_block(eb.block, pred) }
                is AST.IfElseIf    as ei -> {
                    inner: AST.Expr = ei.branch
                    return find_first_in_expr(inner, pred)
                }
            }
        }
        _ -> { return null }
    }
}

