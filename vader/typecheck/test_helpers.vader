// vader/typecheck/test_helpers — shared scaffolding for inline @tests.
//
// Three things are duplicated across `expr_ident.vader`, `call.vader`,
// `binary.vader` (and growing) :
//   - tiny AST walkers that find the first expression matching a
//     predicate in a fn body
//   - the parse + resolve + check_module pipeline that prepares a
//     `TypedProgram` for a source snippet
//   - the `stub_check_expr` callback the per-variant inference fns
//     take as a cycle-break for `check_expr`
//
// The walker is generalised here ; `stub_check_expr` and the
// orchestrator helper still live per-file because they each pull in a
// different subset of `infer_*` fns (importing them all here would drag
// the dependency cone into every file that imports test_helpers).

AST :: import "vader/parser/ast"

/// Walk the first decl's body looking for the first expression that
/// `pred` accepts (returns non-null). Descends through `BlockExpr`,
/// `ReturnStmt`, `ExprStmt`, `BinaryExpr.{left, right}`,
/// `CallExpr.{callee, args}`. Other variants are leaves for the walker.
///
/// `pred` receives every visited expression and returns either the
/// expression itself (to stop the walk) or `null` to keep walking.
/// Callers narrow the returned `AST.Expr | null` to the variant
/// they're looking for.
export find_first_in_block :: fn(
    b: AST.BlockExpr, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    for stmt in b.stmts {
        hit :: find_first_in_stmt(stmt, pred)
        if hit is AST.Expr { return hit }
    }
    t :: b.trailing
    if t is null { return null }
    return find_first_in_expr(t, pred)
}

find_first_in_stmt :: fn(
    s: AST.Stmt, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    match s {
        is AST.ReturnStmt as r -> {
            v :: r.value
            if v is null { return null }
            return find_first_in_expr(v, pred)
        }
        is AST.ExprStmt as es -> { return find_first_in_expr(es.expr, pred) }
        _ -> { return null }
    }
}

find_first_in_expr :: fn(
    e: AST.Expr, pred: fn(AST.Expr) -> AST.Expr | null,
) -> AST.Expr | null {
    hit :: pred(e)
    if hit is AST.Expr { return hit }
    match e {
        is AST.BinaryExpr as b -> {
            l :: find_first_in_expr(b.left, pred)
            if l is AST.Expr { return l }
            return find_first_in_expr(b.right, pred)
        }
        is AST.CallExpr as c -> {
            callee :: find_first_in_expr(c.callee, pred)
            if callee is AST.Expr { return callee }
            for a in c.args {
                arg :: find_first_in_expr(a.value, pred)
                if arg is AST.Expr { return arg }
            }
            return null
        }
        is AST.BlockExpr as bx -> { return find_first_in_block(bx, pred) }
        _ -> { return null }
    }
}
