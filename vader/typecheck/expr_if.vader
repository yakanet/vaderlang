// vader/typecheck/expr_if — IfExpr inference.
//
// Type of `if cond { then } else { else }` is the union of branch
// types. Surface T3019 when the condition isn't `bool`-assignable.
//
// Branch-condition narrowing (`if x is T as a { … }`, `x == null`,
// `x.f != null`, including `&&` chains) is applied through `narrow.vader`
// in the then/else branches ; free-numeric branch types repin via
// `join_if_branches` ; divergent guards (`if … { return }`) narrow the
// fall-through. See `detect_is_narrow` / `collect_and_narrows`.

module "vader/typecheck"

import "vader/diagnostics" { Diagnostic, typecheck_error }
import "vader/types" { Type, UnresolvedType, PrimitiveType, FreeIntType, FreeFloatType, display_type, mk_primitive, TY_BOOL, TY_FREE_INT, TY_NULL, TY_VOID, TY_UNRESOLVED }
AST :: import "vader/parser"

/// Combine the two branch types of an `if`/`else`. A free numeric-literal branch
/// coerces to a concrete sibling of its own family — `if c { x: i32 } else { 0 }`
/// is `i32`, not `i32 | {integer}` — mirroring the binary-operator coercion
/// (`binary.vader::numeric_result`). Without this, an unannotated `::` binding
/// (`expected = null`) escapes as a union with no arithmetic defined on it
/// (T3017). Unrelated branches fall back to the plain union.
join_if_branches :: fn(a: Type, b: Type) -> Type {
    if a is FreeIntType {
        if b is FreeIntType { return a }
        if is_concrete_int(b) { return b }
    }
    if b is FreeIntType {
        if is_concrete_int(a) { return a }
    }
    if a is FreeFloatType {
        if b is FreeFloatType { return a }
        if is_concrete_float(b) { return b }
    }
    if b is FreeFloatType {
        if is_concrete_float(a) { return a }
    }
    return union_of([a, b])
}

is_concrete_int :: fn(t: Type) -> bool {
    if t is PrimitiveType as p { return is_int_name(p.name) }
    return false
}

is_concrete_float :: fn(t: Type) -> bool {
    if t is PrimitiveType as p { return is_float_name(p.name) }
    return false
}

/// Type-check an `IfExpr`. `expected` flows into both branches so
/// `let x: i64 = if c { 1 } else { 2 }` narrows each literal to i64.
export infer_if :: fn(
    e: AST.IfExpr, expected: Type | null,
    typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    cond_ty :: check_expr_fn(e.cond, TY_BOOL, typed, diags)
    if !is_assignable(cond_ty, TY_BOOL, null) {
        diags.push(typecheck_error(.ConditionMustBeBool, e.cond.span,
            "if condition must be `bool`, got ${display_type(cond_ty)}"))
    }
    // A `&&` condition narrows EACH operand's scrutinee for the then-block
    // (`if a is T && a.f { … }`) ; its else can't narrow (we don't know which
    // operand was false). A single (non-`&&`) condition keeps the existing
    // then + inverse-else narrowing.
    is_and :: if e.cond is AST.BinaryExpr as bc { bc.op == AST.BinaryOp.And } else { false }
    then_narrows: IsNarrow[] = []
    else_narrowing: IsNarrow | null = null
    if is_and {
        then_narrows = collect_and_narrows(e.cond, typed)
    } else {
        single :: detect_is_narrow(e.cond, typed, diags)
        if single is IsNarrow as s {
            then_narrows.push(s)
            else_narrowing = s
        }
    }
    pushed :: push_then_narrows(then_narrows, typed)
    then_ty :: check_block(e.then_block, expected, typed, diags, ctx, check_expr_fn)
    pop_then_narrows(pushed, typed)
    match e.else_branch {
        is null -> {
            return collapse_if_unresolved(union_of([then_ty, TY_VOID]), then_ty, TY_VOID)
        }
        is AST.IfElseBlock as eb -> {
            else_ty :: check_else_with_narrow(eb.block, else_narrowing, expected, typed, diags, ctx, check_expr_fn)
            return collapse_if_unresolved(join_if_branches(then_ty, else_ty), then_ty, else_ty)
        }
        is AST.IfElseIf as ei -> {
            inner: AST.Expr = ei.branch
            else_ty :: check_else_branch_expr(inner, else_narrowing, expected, typed, diags, check_expr_fn)
            return collapse_if_unresolved(join_if_branches(then_ty, else_ty), then_ty, else_ty)
        }
    }
}

// `if` whose then or else branch is `?` collapses the whole expression
// to `?` — folding the Unresolved into a union (`? | i32`) would let
// downstream `default_if_free` paper over a missing type instead of
// surfacing T3034 (recursive expression-bodied fn).
collapse_if_unresolved :: fn(joined: Type, a: Type, b: Type) -> Type {
    if a is UnresolvedType { return TY_UNRESOLVED }
    if b is UnresolvedType { return TY_UNRESOLVED }
    return joined
}

check_else_with_narrow :: fn(
    block: AST.BlockExpr, narrowing: IsNarrow | null,
    expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    prev: NarrowSlot | null = null
    static_ty: Type = TY_UNRESOLVED
    if narrowing is IsNarrow as n {
        static_ty = n.static_ty
        if n.field_key == "" { prev = push_narrow(typed, n.sym_id, n.else_ty) }
        else { prev = push_field_narrow(typed, n.field_key, n.else_ty) }
    }
    result :: check_block(block, expected, typed, diags, ctx, check_expr_fn)
    if narrowing is IsNarrow as n {
        if n.field_key == "" { pop_narrow(typed, n.sym_id, prev, static_ty) }
        else { pop_field_narrow(typed, n.field_key, prev, static_ty) }
    }
    return result
}

check_else_branch_expr :: fn(
    inner: AST.Expr, narrowing: IsNarrow | null,
    expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    prev: NarrowSlot | null = null
    static_ty: Type = TY_UNRESOLVED
    if narrowing is IsNarrow as n {
        static_ty = n.static_ty
        if n.field_key == "" { prev = push_narrow(typed, n.sym_id, n.else_ty) }
        else { prev = push_field_narrow(typed, n.field_key, n.else_ty) }
    }
    result :: check_expr_fn(inner, expected, typed, diags)
    if narrowing is IsNarrow as n {
        if n.field_key == "" { pop_narrow(typed, n.sym_id, prev, static_ty) }
        else { pop_field_narrow(typed, n.field_key, prev, static_ty) }
    }
    return result
}

// Minimal `if x is T { … }` narrowing : when the cond is a binary `is`
// op whose LHS is an `IdentExpr` resolving to a local Symbol, narrow
// that binding to `T` inside the then-branch.
//
// `field_key` is `""` for ident narrowings ; otherwise it carries the
// `${sym_id}.${field}` slot used by `narrowed_fields` so chains like
// `b.items != null` narrow `b.items` inside the matching branch.
IsNarrow :: struct {
    sym_id:    i32
    static_ty: Type
    then_ty:   Type
    else_ty:   Type
    field_key: string = ""
}

// One pushed narrowing, recorded so a scope (a `&&` right operand, a
// then-block) can unwind it.
PushedNarrow :: struct {
    sym_id:    i32
    field_key: string
    prev:      NarrowSlot | null
    static_ty: Type
}

// Collect the scrutinee / field narrowings introduced by a `&&` condition
// chain, left-to-right (flattening nested `&&`). Each leaf (`x is T`,
// `x == null`, `x.f != null`, …) contributes its `then` narrowing via
// `detect_is_narrow`. A conjunction's else side can't narrow (we don't know
// which operand was false), so callers apply these to the then side only.
// Detection only — operands are type-checked with real diags by the caller,
// so `detect_is_narrow` routes its own here to a sink.
collect_and_narrows :: fn(cond: AST.Expr, typed: TypedProgram) -> IsNarrow[] {
    if cond is AST.BinaryExpr as x {
        if x.op == AST.BinaryOp.And {
            out :: collect_and_narrows(x.left, typed)
            for n in collect_and_narrows(x.right, typed) { out.push(n) }
            return out
        }
    }
    out: IsNarrow[] = []
    single :: detect_is_narrow(cond, typed, diag_sink())
    if single is IsNarrow as n { out.push(n) }
    return out
}

// Push each narrowing's `then` type and return the records to unwind later.
push_then_narrows :: fn(narrows: IsNarrow[], typed: TypedProgram) -> PushedNarrow[] {
    pushed: PushedNarrow[] = []
    for n in narrows {
        if n.field_key == "" {
            prev :: push_narrow(typed, n.sym_id, n.then_ty)
            pushed.push(PushedNarrow { .sym_id = n.sym_id, .field_key = "", .prev = prev, .static_ty = n.static_ty })
        } else {
            prev :: push_field_narrow(typed, n.field_key, n.then_ty)
            pushed.push(PushedNarrow { .sym_id = n.sym_id, .field_key = n.field_key, .prev = prev, .static_ty = n.static_ty })
        }
    }
    return pushed
}

// Unwind in reverse (LIFO) so stacked pushes on the same slot restore cleanly.
pop_then_narrows :: fn(pushed: PushedNarrow[], typed: TypedProgram) -> void {
    for k in 0..<pushed.len() {
        rec :: pushed[pushed.len() - 1 - k]
        if rec.field_key == "" { pop_narrow(typed, rec.sym_id, rec.prev, rec.static_ty) }
        else { pop_field_narrow(typed, rec.field_key, rec.prev, rec.static_ty) }
    }
}

detect_is_narrow :: fn(
    cond: AST.Expr, typed: TypedProgram, diags: Diagnostic[],
) -> IsNarrow | null {
    // `!(x is T)` flips the two arms — peel the Not, then swap. Carry
    // `field_key` so a field scrutinee (`!(b.opt is null)`) still narrows the
    // FIELD in the then-block — without it the swap records a symbol narrowing
    // (field_key "") and `b.opt.<sub>` in the then-block keeps the union type
    // and degrades (the compiler's own `build_if` `e.else_block.span`).
    if cond is AST.UnaryExpr {
        if cond.op == AST.UnaryOp.Not {
            inner :: detect_is_narrow(cond.operand, typed, diags)
            if inner is null { return null }
            return IsNarrow {
                .sym_id    = inner.sym_id,
                .static_ty = inner.static_ty,
                .then_ty   = inner.else_ty,
                .else_ty   = inner.then_ty,
                .field_key = inner.field_key,
            }
        }
    }
    if !(cond is AST.BinaryExpr) { return null }
    // `x == null` / `x != null` / `null == x` / `null != x` — both
    // orderings flip the same way.
    if cond.op == AST.BinaryOp.Eq || cond.op == AST.BinaryOp.Neq {
        ident_side :: pick_ident_vs_null(cond.left, cond.right)
        if !(ident_side is null) {
            sym :: typed.resolved.idents[ident_side.span.hash()]
            if sym is null { return null }
            // Subtract from the binding's CURRENT flow-narrowed type, not its
            // declared type, so nested / sequential guards compose : an outer
            // `!(x is null)` must survive an inner `!(x is T)`. Falls back to
            // the declared type when no narrowing is active for this binding.
            base :: narrow_for_binding(typed, sym.id, type_of_symbol(sym, typed))
            // Never narrow an unresolved binding — mirrors the field-chain
            // guard in `resolve_field_chain_static` (narrow.vader). A
            // premature imported-body walk (settle pass 0, before the
            // module's imports are wired) resolves `m[k]`-bound locals to
            // `?` ; recording a `?` narrowing here poisons every later
            // reference (it survives into the authoritative re-walk).
            if base is UnresolvedType { return null }
            null_ty :: TY_NULL
            non_null :: subtract_type(base, null_ty)
            if cond.op == AST.BinaryOp.Eq {
                return IsNarrow { .sym_id = sym.id, .static_ty = base, .then_ty = null_ty, .else_ty = non_null }
            }
            return IsNarrow { .sym_id = sym.id, .static_ty = base, .then_ty = non_null, .else_ty = null_ty }
        }
        // `b.field == null` / `b.field != null` — field-level narrowing.
        field_side :: pick_field_vs_null(cond.left, cond.right)
        if !(field_side is null) {
            field_info :: resolve_field_chain_static(field_side, typed)
            if !(field_info is null) {
                null_ty :: TY_NULL
                // Compose against the field's current flow-narrowed type (like
                // the ident path below and stmt.vader) so sequential field
                // guards refine instead of resetting to the declared union.
                base :: narrow_for_field(typed, field_info.field_key, field_info.static_ty)
                non_null :: subtract_type(base, null_ty)
                if cond.op == AST.BinaryOp.Eq {
                    return IsNarrow {
                        .sym_id = 0, .static_ty = base,
                        .then_ty = null_ty, .else_ty = non_null,
                        .field_key = field_info.field_key,
                    }
                }
                return IsNarrow {
                    .sym_id = 0, .static_ty = base,
                    .then_ty = non_null, .else_ty = null_ty,
                    .field_key = field_info.field_key,
                }
            }
        }
        return null
    }
    if cond.op != AST.BinaryOp.Is { return null }
    narrowed :: type_from_expr(cond.right, typed.resolved, diags)
    // `if <scrut> is T as a { … }` — write the bind's type into `local_types`
    // so `IdentExpr` lookups inside the then-block resolve `a` to T. Recorded
    // regardless of the scrutinee's shape : the binding's type is `T`,
    // independent of whether `<scrut>` is a bare ident (narrowable below) or a
    // field chain (`x.y is T as a`). Without this an `as`-binding off a
    // field-chain scrutinee has no type, so field / iterable accesses on it
    // degrade — e.g. `for d in a.items` falls to the iterator path and emits an
    // unresolved `next`.
    if cond.bind_as != "" {
        typed.local_types[cond.right.span.hash()] = narrowed
    }
    // Scrutinee-VARIABLE narrowing : a bare ident narrows its symbol slot.
    if cond.left is AST.IdentExpr {
        sym :: typed.resolved.idents[cond.left.span.hash()]
        if sym is null { return null }
        // Current flow-narrowed base (see the `== null` path) so nested guards
        // compose instead of resetting to the declared union each time.
        base :: narrow_for_binding(typed, sym.id, type_of_symbol(sym, typed))
        // Same guard as the ident-vs-null path above: don't narrow an
        // unresolved binding.
        if base is UnresolvedType { return null }
        return IsNarrow {
            .sym_id    = sym.id,
            .static_ty = base,
            .then_ty   = narrowed,
            .else_ty   = subtract_type_with_impls(base, narrowed, typed),
        }
    }
    // Scrutinee FIELD-CHAIN narrowing : `x.y is T` narrows the `x.y` slot,
    // mirroring the `x.y == null` field path above. Without this, `is null` /
    // `is T` on a field never narrows (only `== null` did), so a field read
    // after a divergent `if x.y is null { return }` guard degrades — the
    // `convert_function` `body :: d.body ; body.span` drop.
    if cond.left is AST.FieldExpr as field_lhs {
        field_info :: resolve_field_chain_static(field_lhs, typed)
        if field_info is null { return null }
        // Compose against the field's current flow-narrowed type so chained
        // `if x.f is A {…} else if x.f is B {…}` guards refine instead of
        // resetting to the declared type (mirrors the ident path / stmt.vader).
        base :: narrow_for_field(typed, field_info.field_key, field_info.static_ty)
        return IsNarrow {
            .sym_id    = 0,
            .static_ty = base,
            .then_ty   = narrowed,
            .else_ty   = subtract_type_with_impls(base, narrowed, typed),
            .field_key = field_info.field_key,
        }
    }
    return null
}


// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver" { resolve_module }
import "vader/resolver/symbol" { new_factory }

expr_if_check_stub :: fn(
    e: AST.Expr, expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    // @partial: test stub — only the literal / ident / if expr kinds the if
    // tests build are typed; every other Expr is irrelevant → unresolved.
    @partial match e {
        is AST.IntLitExpr  as x -> { return narrow_for_expected(TY_FREE_INT, expected) }
        is AST.BoolLitExpr as x -> { return TY_BOOL }
        is AST.IdentExpr   as x -> { return infer_ident(x, typed) }
        is AST.IfExpr      as x -> { return infer_if(x, expected, typed, diags, null, expr_if_check_stub) }
        _ -> { return TY_UNRESOLVED }
    }
}

accept_if :: fn(e: AST.Expr) -> AST.Expr | null {
    if e is AST.IfExpr { return e }
    return null
}

first_if_in_last_fn :: fn(src: string) -> AST.IfExpr | null {
    parsed :: parse_source(src, "t.vader")
    last :: parsed.program.decls[parsed.program.decls.len() - 1]
    match last {
        is AST.FnDecl as f -> {
            match f.body {
                is null -> {}
                is AST.BlockExpr as b -> {
                    hit :: find_first_in_block(b, accept_if)
                    if hit is AST.IfExpr { return hit }
                }
            }
        }
        _ -> {}
    }
    return null
}

checked :: fn(src: string) -> TypedProgram {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    diags: Diagnostic[] = []
    result :: check_module(parsed.program, rm, factory, diags)
    return result.typed
}

@test
test_if_both_branches_int_returns_int :: fn() -> void {
    src :: "f :: fn(c: bool) -> i32 { return if c { 1 } else { 2 } }"
    typed :: checked(src)
    ifx :: first_if_in_last_fn(src)
    if ifx is null { assert(false, "expected an if expr") return }
    diags: Diagnostic[] = []
    ty :: infer_if(ifx, mk_primitive("i32"), typed, diags, null, expr_if_check_stub)
    assert_eq(display_type(ty), "i32")
}

@test
test_if_without_else_yields_union_with_void :: fn() -> void {
    src :: "f :: fn(c: bool) -> void { if c { 1 } }"
    typed :: checked(src)
    ifx :: first_if_in_last_fn(src)
    if ifx is null { assert(false, "expected an if expr") return }
    diags: Diagnostic[] = []
    ty :: infer_if(ifx, null, typed, diags, null, expr_if_check_stub)
    assert_eq(display_type(ty), "void | {integer}")
}

@test
test_if_cond_not_bool_emits_T3019 :: fn() -> void {
    src :: "f :: fn() -> i32 { return if 1 { 1 } else { 2 } }"
    typed :: checked(src)
    ifx :: first_if_in_last_fn(src)
    if ifx is null { assert(false, "expected an if expr") return }
    diags: Diagnostic[] = []
    infer_if(ifx, null, typed, diags, null, expr_if_check_stub)
    found := false
    for d in diags { if d.code.id == "T3019" { found = true } }
    assert(found, "expected T3019 on non-bool cond")
}
