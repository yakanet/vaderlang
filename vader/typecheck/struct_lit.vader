// vader/typecheck/struct_lit — StructLitExpr inference (`Point { x: 1 }`).
//
// Lowers `type_name` into a `StructType` (T3001 if it isn't one), looks
// up the struct's fields via `typed.struct_decls`, and checks each item.
// Returns the struct type.

import "vader/diagnostics/diagnostic" { Diagnostic, typecheck_error }
import "vader/typecheck/coerce" { try_into }
import "vader/typecheck/field" { find_struct_field_type, substitute_by_name }

lookup_pre_resolved_field_for_lit :: fn(struct_id: i32, name: string, typed: TypedProgram) -> Type | null {
    fmap :: typed.struct_field_types[struct_id]
    if fmap is null { return null }
    return fmap[name]
}
import "vader/typecheck/type_ops" { is_assignable }
import "vader/typecheck/types" { Type, StructType, display_type, TY_UNRESOLVED }
import "vader/typecheck/type_expr" { type_from_expr }
import "vader/typecheck/typed_ast" { TypedProgram }
AST :: import "vader/parser/ast"

/// Type-check a `StructLitExpr`. Always returns the struct type even
/// when the body has errors so downstream passes keep flowing.
export infer_struct_lit :: fn(
    e: AST.StructLitExpr, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    ty :: type_from_expr(e.type_name, typed.resolved, diags)
    match ty {
        is StructType as st -> { return check_struct_body(e, st, typed, diags, check_expr_fn) }
        _ -> {
            diags.push(typecheck_error(.TypeMismatch, e.type_name.span,
                "${display_type(ty)} is not a struct"))
            // Still type every item so nested diagnostics surface.
            for item in e.items { check_item_no_expected(item, typed, diags, check_expr_fn) }
            return ty
        }
    }
}

check_struct_body :: fn(
    e: AST.StructLitExpr, st: StructType, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    decl :: typed.struct_decls[st.symbol.id]
    provided: string[] = []
    has_spread := false
    for item in e.items {
        match item {
            is AST.StructLitSpread as sp -> {
                has_spread = true
                got :: check_expr_fn(sp.expr, st, typed, diags)
                if !is_assignable(got, st, null) {
                    diags.push(typecheck_error(.TypeMismatch, sp.span,
                        "spread source must be assignable to ${display_type(st)}, got ${display_type(got)}"))
                }
            }
            is AST.StructLitField as f -> {
                check_field(f, st, decl, typed, diags, provided, check_expr_fn)
            }
        }
    }
    // T3037 — required fields without defaults must be provided when no
    // `...spread` covers them.
    if decl is AST.StructDecl {
        if !has_spread { check_missing_fields(e, st, decl, provided, diags) }
    }
    return st
}

check_field :: fn(
    f: AST.StructLitField, st: StructType, decl: AST.StructDecl | null,
    typed: TypedProgram, diags: Diagnostic[], provided: string[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    expected: Type | null = null
    if decl is AST.StructDecl {
        // Prefer the pre-resolved field type (handles cross-module
        // structs where the field type references another module's
        // type-params). Fall back to walking the AST locally.
        raw: Type | null = lookup_pre_resolved_field_for_lit(st.symbol.id, f.name, typed)
        if raw is null {
            raw = find_struct_field_type(decl, f.name, typed.resolved, diags)
        }
        match raw {
            is null -> {}
            _ -> { expected = substitute_by_name(raw, decl.type_params, st.args) }
        }
    }
    got :: check_expr_fn(f.value, expected, typed, diags)
    if expected is null {
        diags.push(typecheck_error(.FieldDoesNotExist, f.name_span,
            "`${f.name}` on ${display_type(st)}"))
        return
    }
    // Duplicate-field check runs against the list ; the offending field
    // still gets type-checked against the field type so nested diags
    // surface for the second occurrence too.
    if contains_name(provided, f.name) {
        diags.push(typecheck_error(.FieldAlreadyProvided, f.name_span,
            "field `${f.name}` already provided in this struct literal"))
    }
    provided.push(f.name)
    if is_assignable(got, expected, null) { return }
    if try_into(got, expected, typed) { return }
    diags.push(typecheck_error(.TypeMismatch, f.span,
        "expected ${display_type(expected)}, got ${display_type(got)}"))
}

contains_name :: fn(names: string[], target: string) -> bool {
    for n in names { if n == target { return true } }
    return false
}

check_missing_fields :: fn(
    e: AST.StructLitExpr, st: StructType, decl: AST.StructDecl,
    provided: string[], diags: Diagnostic[],
) -> void {
    missing: string[] = []
    for sf in decl.fields {
        if sf.default is null {
            if !contains_name(provided, sf.name) { missing.push("`${sf.name}`") }
        }
    }
    if missing.len() == 0 { return }
    label := "fields"
    if missing.len() == usize(1) { label = "field" }
    diags.push(typecheck_error(.MissingRequiredFieldInStructLit, e.span,
        "missing required ${label} on ${display_type(st)}: ${join_commas(missing)}"))
}

check_item_no_expected :: fn(
    item: AST.StructLitItem, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    match item {
        is AST.StructLitField  as f  -> { check_expr_fn(f.value, null, typed, diags) }
        is AST.StructLitSpread as sp -> { check_expr_fn(sp.expr,  null, typed, diags) }
    }
    return
}

join_commas :: fn(parts: string[]) -> string {
    out := ""
    for i in 0..<parts.len() {
        if i > usize(0) { out = "${out}, " }
        out = "${out}${parts[i]}"
    }
    return out
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver/resolve" { resolve_module }
import "vader/resolver/symbol" { new_factory }
import "vader/typecheck/check" { check_module }
import "vader/typecheck/expr_ident" { infer_ident }
import "vader/typecheck/expr_literals" { infer_int_lit, infer_string_lit }
import "vader/typecheck/test_helpers" { find_first_in_block }
import "vader/typecheck/type_ops" { narrow_for_expected }

stub_check_expr :: fn(
    e: AST.Expr, expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    match e {
        is AST.IntLitExpr    as x -> { return narrow_for_expected(infer_int_lit(x), expected) }
        is AST.StringLitExpr as x -> { return infer_string_lit(x) }
        is AST.IdentExpr     as x -> { return infer_ident(x, typed) }
        is AST.StructLitExpr as x -> { return infer_struct_lit(x, typed, diags, stub_check_expr) }
        _ -> { return TY_UNRESOLVED }
    }
}

accept_struct_lit :: fn(e: AST.Expr) -> AST.Expr | null {
    if e is AST.StructLitExpr { return e }
    return null
}

ExpectedSL :: struct {
    typed: TypedProgram
    sl:    AST.StructLitExpr
}

expect_struct_lit :: fn(src: string) -> ExpectedSL {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    diags: Diagnostic[] = []
    result :: check_module(parsed.program, rm, factory, diags)
    last :: parsed.program.decls[parsed.program.decls.len() - 1]
    match last {
        is AST.FnDecl as f -> {
            match f.body {
                is null -> {}
                is AST.BlockExpr as b -> {
                    hit :: find_first_in_block(b, accept_struct_lit)
                    if hit is AST.StructLitExpr { return ExpectedSL { .typed = result.typed, .sl = hit } }
                }
            }
        }
        _ -> {}
    }
    assert(false, "expected a StructLitExpr in: ${src}")
    return ExpectedSL { .typed = result.typed, .sl = synthetic_sl() }
}

import "vader/diagnostics/diagnostic" { empty_span }

synthetic_sl :: fn() -> AST.StructLitExpr {
    sp :: empty_span()
    int_lit: AST.Expr = AST.IntLitExpr {
        .span = sp, .id = AST.UNASSIGNED_NODE_ID, .value = 0, .suffix = null,
    }
    return AST.StructLitExpr {
        .span = sp, .id = AST.UNASSIGNED_NODE_ID,
        .type_name = int_lit, .items = [],
    }
}

@test
test_struct_lit_types_to_struct :: fn() -> void {
    src :: """
Point :: struct {
    x: i32
    y: i32
}
f :: fn() -> Point { return Point { .x = 1, .y = 2 } }
"""
    eb :: expect_struct_lit(src)
    diags: Diagnostic[] = []
    assert_eq(display_type(infer_struct_lit(eb.sl, eb.typed, diags, stub_check_expr)), "Point")
    assert_eq(diags.len(), usize(0))
}

@test
test_struct_lit_unknown_field_emits_T3009 :: fn() -> void {
    src :: """
Point :: struct { x: i32 }
f :: fn() -> Point { return Point { .x = 1, .z = 2 } }
"""
    eb :: expect_struct_lit(src)
    diags: Diagnostic[] = []
    infer_struct_lit(eb.sl, eb.typed, diags, stub_check_expr)
    found := false
    for d in diags { if d.code.id == "T3009" { found = true } }
    assert(found, "expected T3009 on unknown field")
}

@test
test_struct_lit_missing_field_emits_T3037 :: fn() -> void {
    src :: """
Point :: struct {
    x: i32
    y: i32
}
f :: fn() -> Point { return Point { .x = 1 } }
"""
    eb :: expect_struct_lit(src)
    diags: Diagnostic[] = []
    infer_struct_lit(eb.sl, eb.typed, diags, stub_check_expr)
    found := false
    for d in diags { if d.code.id == "T3037" { found = true } }
    assert(found, "expected T3037 on missing field")
}

@test
test_struct_lit_field_type_mismatch_emits_T3001 :: fn() -> void {
    src :: """
Point :: struct { x: i32 }
f :: fn() -> Point { return Point { .x = "hello" } }
"""
    eb :: expect_struct_lit(src)
    diags: Diagnostic[] = []
    infer_struct_lit(eb.sl, eb.typed, diags, stub_check_expr)
    found := false
    for d in diags { if d.code.id == "T3001" { found = true } }
    assert(found, "expected T3001 on field type mismatch")
}
