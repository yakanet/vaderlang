// vader/typecheck/dead_code â€” name-reachability lints : W0007 (dead private
// decls, per-module, on every build) and W0012 (dead exported fns, project-wide,
// `vader lint` only).
//
// A reference-reachability lint. For every top-level declaration of the (merged,
// all-files) module, collect the NAMES it references â€” in bodies, signatures,
// field / alias / const / enum types, decorator args. Then BFS from the roots
// (`export`-visible decls, `main`, `@test` / `@extern` / `@intrinsic`, every
// `impl` member, `@assert`); a PRIVATE top-level decl whose name is never reached
// is dead â†’ W0007.
//
// `dead_exports` (W0012, at the bottom) reuses the very same collectors and BFS,
// but merges EVERY module's decls and drops the `export`-is-a-root clause, so a
// public fn unreachable across the whole project â€” invisible to the per-module
// W0007 and to a lowered-project DCE diff (lazy lowering never materialises it) â€”
// is flagged. It runs only under `vader lint`, never on the default build.
//
// Name-based by design. Resolving every reference to a `Symbol.id` is the gap
// that sank the unused-import attempt (W0006) : `resolved.idents` is span-keyed,
// `files[0]`-only, and misses positions. Collecting names over the merged AST
// over-approximates uses (a local shadowing a top-level name marks it used) â€” the
// SAFE bias for a lint : we under-report, never false-positive (a false positive
// would tell you to delete live code). Mirrors the AST traversal of
// `vader/lsp/analysis/reference_index.vader`, with two additions it lacks but
// dead-code needs : `FieldExpr.field` (UFCS `recv.foo()`) and string-interpolation
// parts (`"${foo()}"`).

module "vader/typecheck"

import "std/collections"
import "vader/diagnostics"
import "vader/resolver"
AST :: import "vader/parser"

// A private top-level declaration that may be dead â€” keyed for the final report.
DeadDecl :: struct {
    name:      string
    name_span: Span
}

// ---- name collection (mirror of reference_index, emitting names) ----------

collect_expr_names :: fn(e: AST.Expr, out: string[]) -> void {
    match e {
        is AST.IdentExpr         as x -> { out.push(x.name) }
        is AST.NullCoalesceExpr  as x -> {
            collect_expr_names(x.left, out)
            inner :: AST.coalesce_fallback_expr(x.fallback)
            if inner != null { collect_expr_names(inner, out) }
        }
        is AST.CallExpr          as x -> {
            collect_expr_names(x.callee, out)
            for a in x.args { collect_expr_names(a.value, out) }
        }
        // UFCS / member name : `recv.foo()` references the free fn / member `foo`.
        // reference_index drops `.field` ; dead-code must keep it or every
        // UFCS-only-called fn reads as dead.
        is AST.FieldExpr         as x -> {
            out.push(x.field)
            collect_expr_names(x.target, out)
        }
        is AST.IndexExpr         as x -> {
            collect_expr_names(x.target, out)
            collect_expr_names(x.index, out)
        }
        is AST.UnaryExpr         as x -> { collect_expr_names(x.operand, out) }
        is AST.BinaryExpr        as x -> {
            collect_expr_names(x.left, out)
            collect_expr_names(x.right, out)
        }
        is AST.IfExpr            as x -> {
            collect_expr_names(x.cond, out)
            collect_block_names(x.then_block, out)
            match x.else_branch {
                is null                 -> {}
                is AST.IfElseIf    as b -> { collect_expr_names(b.branch, out) }
                is AST.IfElseBlock as b -> { collect_block_names(b.block, out) }
            }
        }
        is AST.MatchExpr         as x -> {
            collect_expr_names(x.scrutinee, out)
            for arm in x.arms {
                collect_pattern_names(arm.pattern, out)
                collect_opt_expr_names(arm.guard, out)
                collect_expr_names(arm.body, out)
            }
        }
        is AST.BlockExpr         as x -> { collect_block_names(x, out) }
        is AST.LambdaExpr        as x -> {
            for p in x.params {
                collect_opt_expr_names(p.ty, out)
                collect_opt_expr_names(p.default_value, out)
            }
            collect_opt_expr_names(x.return_type, out)
            collect_block_names(x.body, out)
        }
        is AST.StructLitExpr     as x -> {
            collect_expr_names(x.type_name, out)
            for it in x.items {
                match it {
                    is AST.StructLitField  as f  -> { collect_expr_names(f.value, out) }
                    is AST.StructLitSpread as sp -> { collect_expr_names(sp.expr, out) }
                }
            }
        }
        is AST.SeqLitExpr        as x -> { for it in x.elements { collect_expr_names(it, out) } }
        is AST.RangeExpr         as x -> {
            collect_expr_names(x.lower, out)
            collect_expr_names(x.upper, out)
        }
        is AST.AwaitExpr         as x -> { collect_expr_names(x.inner, out) }
        is AST.CastExpr          as x -> {
            collect_expr_names(x.value, out)
            collect_expr_names(x.target, out)
        }
        is AST.GenericInstExpr   as x -> {
            collect_expr_names(x.callee, out)
            for a in x.type_args { collect_expr_names(a, out) }
        }
        is AST.IntrinsicCallExpr as x -> { for a in x.args { collect_expr_names(a, out) } }
        // `"${foo()}"` references `foo` â€” reference_index skips interpolation parts.
        is AST.StringLitExpr     as x -> {
            for part in x.parts {
                if part is AST.StringLitInterp as si { collect_expr_names(si.expr, out) }
            }
        }
        is AST.FnTypeExpr        as x -> {
            for p in x.params { collect_expr_names(p, out) }
            collect_opt_expr_names(x.return_type, out)
        }
        is AST.ArrayTypeExpr     as x -> { collect_expr_names(x.element, out) }
        is AST.DotVariantExpr         -> {}
        is AST.IntLitExpr             -> {}
        is AST.FloatLitExpr           -> {}
        is AST.BoolLitExpr            -> {}
        is AST.NullLitExpr            -> {}
        is AST.CharLitExpr            -> {}
    }
}

collect_stmt_names :: fn(s: AST.Stmt, out: string[]) -> void {
    match s {
        is AST.LetStmt      as x -> {
            collect_opt_expr_names(x.ty, out)
            collect_expr_names(x.value, out)
        }
        is AST.AssignStmt   as x -> {
            collect_expr_names(x.target, out)
            collect_expr_names(x.value, out)
        }
        is AST.ExprStmt     as x -> { collect_expr_names(x.expr, out) }
        is AST.ReturnStmt   as x -> { collect_opt_expr_names(x.value, out) }
        is AST.YieldStmt    as x -> { collect_expr_names(x.value, out) }
        is AST.ForStmt      as x -> {
            match x.form {
                is AST.InfiniteFor      -> {}
                is AST.WhileFor as w    -> { collect_expr_names(w.cond, out) }
                is AST.InFor    as f    -> { collect_expr_names(f.iter, out) }
            }
            collect_block_names(x.body, out)
        }
        is AST.BreakStmt    -> {}
        is AST.ContinueStmt -> {}
        is AST.DeferStmt    as x -> {
            match x.body {
                is AST.DeferStmtBody  as b -> { collect_stmt_names(b.stmt, out) }
                is AST.DeferBlockBody as b -> { collect_block_names(b.block, out) }
            }
        }
    }
}

collect_block_names :: fn(b: AST.BlockExpr, out: string[]) -> void {
    for s in b.stmts { collect_stmt_names(s, out) }
    collect_opt_expr_names(b.trailing, out)
}

collect_pattern_names :: fn(p: AST.Pattern, out: string[]) -> void {
    match p {
        is AST.IsPattern as x -> {
            collect_expr_names(x.ty, out)
            collect_opt_pattern_names(x.inner, out)
        }
        is AST.StructPattern as x -> {
            for f in x.fields {
                match f.value {
                    is AST.PatternBinding        -> {}
                    is AST.PatternLiteral as lit -> { collect_expr_names(lit.value, out) }
                }
            }
        }
        is AST.TuplePattern       as x -> { for el in x.elements { collect_pattern_names(el, out) } }
        is AST.WildcardPattern         -> {}
        is AST.BindingPattern          -> {}
        is AST.EnumVariantPattern      -> {}
        is AST.LiteralPattern     as x -> { collect_expr_names(x.value, out) }
        is AST.OrPattern          as x -> { for alt in x.patterns { collect_pattern_names(alt, out) } }
    }
}

collect_decorator_names :: fn(ds: AST.Decorator[], out: string[]) -> void {
    for d in ds { for a in d.args { collect_expr_names(a, out) } }
}

collect_type_param_names :: fn(ps: AST.TypeParam[], out: string[]) -> void {
    for p in ps { collect_opt_expr_names(p.bound, out) }
}

collect_opt_expr_names :: fn(e: AST.Expr | null, out: string[]) -> void {
    if e != null { collect_expr_names(e, out) }
}

collect_opt_block_names :: fn(b: AST.BlockExpr | null, out: string[]) -> void {
    if b != null { collect_block_names(b, out) }
}

collect_opt_pattern_names :: fn(p: AST.Pattern | null, out: string[]) -> void {
    if p != null { collect_pattern_names(p, out) }
}

// ---- per-decl reference sets ----------------------------------------------

fn_refs :: fn(d: AST.FnDecl, out: string[]) -> void {
    collect_decorator_names(d.decorators, out)
    collect_type_param_names(d.type_params, out)
    for p in d.params {
        collect_opt_expr_names(p.ty, out)
        collect_opt_expr_names(p.default_value, out)
    }
    collect_opt_expr_names(d.return_type, out)
    collect_opt_block_names(d.body, out)
}

// ---- root classification --------------------------------------------------

is_public :: fn(v: AST.Visibility) = v == AST.Visibility.Public

// A declaration pins liveness regardless of visibility when it is an entry point
// (`main`), host- or test-wired (`@test` / `@extern` / `@intrinsic` / `@export`),
// or explicitly exempted by the author (`@allow_unused`, for intentional dead
// code : an API not yet wired, a symmetry helper, a test fixture's deliberate
// decoy). The single root list shared by both name-reachability lints : W0007
// (`is_root_decl`) adds the public surface on top ; W0012 (`dead_exports`) uses
// this alone, so a project-dead PUBLIC fn stays flaggable.
is_wired_root :: fn(decorators: AST.Decorator[], name: string) -> bool {
    if name == "main" { return true }
    for dec in decorators {
        if dec.name == "test"         { return true }
        if dec.name == "extern"       { return true }
        if dec.name == "intrinsic"    { return true }
        if dec.name == "export"       { return true }
        if dec.name == "allow_unused" { return true }
    }
    return false
}

// A W0007 reachability root : the public surface (`export`) plus every
// wired-or-exempt root. Never flagged, its refs kept live.
is_root_decl :: fn(v: AST.Visibility, decorators: AST.Decorator[], name: string) =
    is_public(v) || is_wired_root(decorators, name)

// ---- shared traversal (W0007 + W0012) -------------------------------------

// One named top-level decl's identity plus the names it references â€” the unit
// both lints classify. `is_fn` lets W0012 flag fn exports only.
NamedDeclRefs :: struct {
    name:       string
    name_span:  Span
    visibility: AST.Visibility
    decorators: AST.Decorator[]
    is_fn:      bool
    refs:       string[]
}

// Collect the reference names of a top-level decl. For the six NAMED kinds
// returns its identity + refs ; for `impl` / `@assert` (whose refs are always
// live) it seeds them into `seed_refs` and returns null ; imports reference no
// in-module name and return null. The single source of truth for "what does a
// decl reference", shared by `check_dead_code` (W0007) and `dead_exports`
// (W0012) so the two can never drift a collection edge apart.
collect_decl_refs :: fn(d: AST.Decl, seed_refs: string[]) -> NamedDeclRefs | null {
    match d {
        is AST.FnDecl as x -> {
            r: string[] = []
            fn_refs(x, r)
            return named_head(x.name, x.name_span, x.visibility, x.decorators, true, r)
        }
        is AST.ConstDecl as x -> {
            r: string[] = []
            collect_decorator_names(x.decorators, r)
            collect_opt_expr_names(x.ty, r)
            collect_expr_names(x.value, r)
            return named_head(x.name, x.name_span, x.visibility, x.decorators, false, r)
        }
        is AST.StructDecl as x -> {
            r: string[] = []
            collect_decorator_names(x.decorators, r)
            collect_type_param_names(x.type_params, r)
            for f in x.fields {
                collect_expr_names(f.ty, r)
                collect_opt_expr_names(f.default, r)
            }
            return named_head(x.name, x.name_span, x.visibility, x.decorators, false, r)
        }
        is AST.EnumDecl as x -> {
            r: string[] = []
            collect_decorator_names(x.decorators, r)
            collect_opt_expr_names(x.repr, r)
            return named_head(x.name, x.name_span, x.visibility, x.decorators, false, r)
        }
        is AST.TraitDecl as x -> {
            r: string[] = []
            collect_decorator_names(x.decorators, r)
            collect_type_param_names(x.type_params, r)
            collect_opt_expr_names(x.requires, r)
            for m in x.members { fn_refs(m, r) }
            return named_head(x.name, x.name_span, x.visibility, x.decorators, false, r)
        }
        is AST.TypeAliasDecl as x -> {
            r: string[] = []
            collect_decorator_names(x.decorators, r)
            collect_type_param_names(x.type_params, r)
            collect_expr_names(x.aliased, r)
            return named_head(x.name, x.name_span, x.visibility, x.decorators, false, r)
        }
        // Impl members are dispatched (vtable / UFCS) and can't be proven dead ;
        // the block is nameless. Seed its refs as live roots.
        is AST.ImplDecl as x -> {
            collect_type_param_names(x.type_params, seed_refs)
            collect_expr_names(x.for_type, seed_refs)
            seed_refs.push(x.trait_name)
            for ta in x.trait_args { collect_expr_names(ta, seed_refs) }
            for m in x.members { fn_refs(m, seed_refs) }
            return null
        }
        // `@assert(cond)` is always evaluated â€” its refs are live.
        is AST.AssertDecl as x -> {
            collect_expr_names(x.condition, seed_refs)
            return null
        }
        // Imports name CROSS-module symbols ; unused imports are W0006's job.
        is AST.ImportDecl -> { return null }
    }
}

// Pack a named decl's identity + collected refs into a `NamedDeclRefs` â€” one
// constructor so the six arms of `collect_decl_refs` stay one line each.
named_head :: fn(
    name: string, name_span: Span, visibility: AST.Visibility,
    decorators: AST.Decorator[], is_fn: bool, refs: string[],
) = NamedDeclRefs {
    .name = name, .name_span = name_span, .visibility = visibility,
    .decorators = decorators, .is_fn = is_fn, .refs = refs,
}

// BFS over the name-edge graph from the seeded roots, returning the reachable
// set. `work` grows as we discover referenced names ; the manual cursor loop
// (not `0..<len`) re-reads the growing length. Shared by both lints.
bfs_reachable :: fn(
    root_names: string[], seed_refs: string[], refs_by_name: MutableMap<string, string[]>,
) -> MutableSet<string> {
    reachable :: MutableSet<string> {}
    work: string[] = []
    for n in root_names { work.push(n) }
    for r in seed_refs  { work.push(r) }
    cursor: usize = 0
    for cursor < work.len() {
        n :: work[cursor]
        cursor += 1
        if n in reachable { continue }
        reachable.add(n)
        nrefs :: refs_by_name[n]
        if nrefs != null { for r in nrefs { work.push(r) } }
    }
    return reachable
}

// ---- entry ----------------------------------------------------------------

/// Flag every private top-level declaration of `decls` that is never reached
/// from the module's public surface â€” W0007. Runs on the entry module after its
/// bodies are typed (`orchestrate.vader`), so the lint applies to the module
/// currently being compiled (like `@internal`).
///
/// @param decls  the module's merged top-level declarations (all files).
/// @param diags  sink for the W0007 warnings.
export check_dead_code :: fn(decls: AST.Decl[], diags: Diagnostic[]) -> void {
    refs_by_name :: MutableMap<string, string[]> {}
    root_names: string[] = []
    seed_refs:  string[] = []
    flaggable:  DeadDecl[] = []

    for d in decls {
        nd :: collect_decl_refs(d, seed_refs)
        if nd == null {
            continue
        }
        register_refs(refs_by_name, nd.name, nd.refs)
        if is_root_decl(nd.visibility, nd.decorators, nd.name) {
            root_names.push(nd.name)
        } else {
            flaggable.push(DeadDecl { .name = nd.name, .name_span = nd.name_span })
        }
    }

    reachable :: bfs_reachable(root_names, seed_refs, refs_by_name)
    for fd in flaggable {
        if !(fd.name in reachable) {
            diags.push(warning(.DeadCode, fd.name_span, "`${fd.name}` is never used"))
        }
    }
}

// Append `refs` to the edge set for `name` (overloads share a name â†’ merge).
register_refs :: fn(m: MutableMap<string, string[]>, name: string, refs: string[]) -> void {
    cur :: m[name]
    if cur == null { m[name] = refs }
    else { for r in refs { cur.push(r) } }
}

// ---- unused-export (W0012) : project-wide dead exported fns ----------------
//
// Same name-reachability engine as W0007 (`collect_decl_refs` + `bfs_reachable`),
// but run ONCE over the MERGED decls of every non-stdlib module instead of
// per-module, and with one root difference : a plain `export` is NOT a root here.
// W0007 roots the whole public surface (`is_root_decl`, so it only flags dead
// PRIVATES) ; unused-export uses `is_wired_root` alone, so a public fn
// unreachable across the WHOLE project is flaggable â€” what the per-module pass
// structurally can't see (an `export` used by no other module looks live to
// W0007 but is dead project-wide).
//
// This lives OUTSIDE the default build : `vader lint` calls it, `vader build`
// never does (P-lean). It runs on load+parse alone â€” a name-reachability walk
// needs no types â€” so it is cheap and, unlike a lowered-project diff, immune to
// lazy lowering (which never materialises an unreached imported-module fn and so
// would hide a dead export from any input-vs-output diff).

/// One dead exported function : an `export`-keyword fn unreachable from the
/// project's true roots. `name_span` points at the name token â€” its file + line
/// carry the location for the report, so no separate module field is needed.
export DeadExport :: struct {
    name:      string
    name_span: Span
}

/// Report every `export`-keyword FUNCTION unreachable from the project's true
/// roots â€” the `unused-export` lint (W0012).
///
/// Pass the MERGED decls of every non-stdlib module, so a fn used by any module
/// counts as reached. Seeds the BFS with the wired roots only (`is_wired_root`)
/// â€” NOT plain exports â€” then flags each public non-root fn whose name no live
/// decl reaches. Types / consts are registered (a live one can be a fn's sole
/// caller) but never flagged: fn exports only in v1.
///
/// P-safe (inherits `check_dead_code`'s bias) : a name collision across modules
/// marks the name reachable, so the lint UNDER-reports (never a false positive
/// that would tell you to delete live code). A fn is always named at every call
/// / UFCS / value / generic-instantiation site, so a genuinely used export is
/// never flagged.
///
/// @param decls  the merged top-level decls of every non-stdlib module.
/// @return       every dead exported fn, in the order encountered.
export dead_exports :: fn(decls: AST.Decl[]) -> DeadExport[] {
    refs_by_name :: MutableMap<string, string[]> {}
    root_names: string[] = []
    seed_refs:  string[] = []
    flaggable:  DeadExport[] = []

    for d in decls {
        nd :: collect_decl_refs(d, seed_refs)
        if nd == null {
            continue
        }
        register_refs(refs_by_name, nd.name, nd.refs)
        if is_wired_root(nd.decorators, nd.name) {
            root_names.push(nd.name)
        } else if nd.is_fn && is_public(nd.visibility) {
            // The only kind v1 flags : a plain public non-root fn. Its refs are
            // registered above, so a REACHABLE one still keeps its callees live ;
            // only an unreached one is reported. (A PRIVATE dead fn is W0007's
            // job ; a public non-root type / const is registered but not flagged.)
            flaggable.push(DeadExport { .name = nd.name, .name_span = nd.name_span })
        }
    }

    reachable :: bfs_reachable(root_names, seed_refs, refs_by_name)
    out: DeadExport[] = []
    for e in flaggable {
        if !(e.name in reachable) {
            out.push(e)
        }
    }
    return out
}

/// Result of linting a LOADED project for unused exports : the findings plus
/// whether the project exposed a `main` (its reachability seed). A rootless
/// project (`has_main == false`) yields no findings â€” callers surface an
/// under-report warning instead of trusting the empty list.
export UnusedExportReport :: struct {
    has_main: bool
    findings: DeadExport[]
}

/// Run `dead_exports` over a loaded project : merge every non-stdlib module's
/// decls, detect the `main` root, and lint. The single source of truth for
/// "lint a loaded project", shared by `vader lint` (`vader/cli`) and the LSP
/// (`vader/lsp/analysis`) so the stdlib filter and `main` detection never drift.
///
/// @param project  the loaded module graph (from `load_project` or the LSP cache).
/// @return         findings + `has_main` (see `UnusedExportReport`).
export dead_exports_of_project :: fn(project: LoadedProject) -> UnusedExportReport {
    all_decls: AST.Decl[] = []
    has_main := false
    for [_, lm] in project.modules {
        if lm.module.display_path.starts_with(STDLIB_PREFIX) {
            continue
        }
        for d in concat_file_decls(lm.module.files) {
            all_decls.push(d)
            if d is AST.FnDecl as fd {
                if fd.name == "main" {
                    has_main = true
                }
            }
        }
    }
    if !has_main {
        return UnusedExportReport { .has_main = false, .findings = [] }
    }
    return UnusedExportReport { .has_main = true, .findings = dead_exports(all_decls) }
}

/// Render one `DeadExport` as its W0012 warning. The single mapper both the CLI
/// and the LSP use, so the code + wording stay in one place.
///
/// @param e  the dead exported fn to report.
export dead_export_diag :: fn(e: DeadExport) =
    warning(.UnusedExport, e.name_span, "`${e.name}` is never used")

/// Render every finding of `es` as its W0012 warning â€” the list form of
/// `dead_export_diag`, used by both `vader lint` and the LSP.
///
/// @param es  the dead exported fns to report.
export dead_export_diags :: fn(es: DeadExport[]) -> Diagnostic[] {
    out: Diagnostic[] = []
    for e in es {
        out.push(dead_export_diag(e))
    }
    return out
}

// ---- tests ----------------------------------------------------------------

import "std/testing"

// Parse `src` as a single-file module and return the number of W0007 the pass
// raises â€” the reachability BFS exercised end to end on a synthetic graph.
dead_count :: fn(src: string) -> usize {
    parsed :: AST.parse_source(src, "t.vader")
    diags: Diagnostic[] = []
    check_dead_code(parsed.program.decls, diags)
    return diags.len()
}

@test
test_flags_unreachable_private :: fn() -> void {
    // `helper` is private and reached by nothing â†’ flagged.
    src :: "module \"t\"\nhelper :: fn() -> i32 = 1\nmain :: fn() -> i32 = 0\n"
    assert_eq(dead_count(src), 1)
}

@test
test_keeps_reachable_private :: fn() -> void {
    // `helper` is reached from `main` â†’ not flagged.
    src :: "module \"t\"\nhelper :: fn() -> i32 = 1\nmain :: fn() -> i32 = helper()\n"
    assert_eq(dead_count(src), 0)
}

@test
test_exported_is_root :: fn() -> void {
    // An exported decl is the public surface ; never flagged even when unused.
    src :: "module \"t\"\nexport helper :: fn() -> i32 = 1\n"
    assert_eq(dead_count(src), 0)
}

@test
test_transitive_dead_flags_both :: fn() -> void {
    // `a` references `b`, but nothing live reaches `a` â†’ both are dead. A plain
    // "has a caller" check would wrongly spare `b`; root-reachability flags both.
    src :: "module \"t\"\na :: fn() -> i32 = b()\nb :: fn() -> i32 = 2\nmain :: fn() -> i32 = 0\n"
    assert_eq(dead_count(src), 2)
}
