// vader/typecheck/expr — bidirectional expression inference orchestrator.
//
// The entry point
// is `check_expr(expr, expected, t, diags) -> Type` :
//   - bottom-up : compute the natural type of `expr` via per-variant
//     handlers in `expr_literals.vader` (and later expr_ident /
//     expr_block / call / field / …).
//   - top-down : when `expected` is non-null, narrow FreeInt/FreeFloat
//     to the concrete primitive so `let x: i64 = 5` works without an
//     explicit cast.
//   - records the final type into `typed.expr_types` keyed by the
//     expression's span.
//
// Every Expr variant has a dedicated per-variant handler (literals, ident,
// call, field, binary, …) and the dispatch match in `infer_expr` is
// exhaustive — a newly-added Expr variant trips T3013 here.

module "vader/typecheck"

import "vader/diagnostics"
AST :: import "vader/parser"
import "vader/types"

/// Type-check `expr`. `expected` provides bidirectional context — pass
/// `null` for fresh-position uses. The returned `Type` is the post-
/// narrowing type ; it's also written into `typed.expr_types`.
export check_expr :: fn(
    expr: AST.Expr, expected: Type | null,
    typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    got :: infer_expr(expr, expected, typed, diags)
    final :: narrow_for_expected(got, expected)
    // A char literal that coerced to a concrete integer must fit it — `b == '💩'`
    // (u8) is rejected here, where both the codepoint and the pinned type are known.
    if expr is AST.CharLitExpr as cl {
        if final is PrimitiveType as p {
            if is_int_name(p.name) && !char_fits(cl.value, p.name) {
                diags.push(typecheck_error(.CharLiteralOutOfRange, cl.span,
                    "character literal (codepoint ${cl.value}) does not fit in `${p.name}`"))
            }
        }
    }
    // A free integer literal pinned to a concrete integer width must fit it —
    // `x: i32 = 9000000000` / `x: u8 = 300` are rejected here, where both the
    // value and the pinned type are known (mirrors the char bounds check above).
    if expr is AST.IntLitExpr as il {
        if final is PrimitiveType as p {
            if is_int_name(p.name) && !int_fits(il.value, p.name) {
                diags.push(typecheck_error(.IntegerLiteralOutOfRange, il.span,
                    "integer literal ${il.value} does not fit in `${p.name}`"))
            }
        }
    }
    // A negated literal pinned to an unsigned width has no representation —
    // `z: u32 = -1` would silently wrap to all-ones. Restricted to a literal
    // operand so `-someSignedVar` reinterpretation stays the author's call.
    if expr is AST.UnaryExpr as un {
        if un.op == .Neg && un.operand is AST.IntLitExpr {
            if final is PrimitiveType as p {
                if is_unsigned_int_name(p.name) {
                    diags.push(typecheck_error(.IntegerLiteralOutOfRange, un.span,
                        "negative literal does not fit unsigned `${p.name}`"))
                }
            }
        }
    }
    record_expr(typed, expr, final)
    return final
}

/// Write the final type of `expr` into `expr_types`, plus its kind + span
/// into the dump-only side-tables. Centralised so every writer keeps the
/// three in lockstep. `expr_kinds` / `node_spans` are populated only when
/// `typed.dump_types` is set (the typed-ast dump) — they feed nothing else,
/// so build / run / LSP skip those two inserts per expression.
export record_expr :: fn(typed: TypedProgram, expr: AST.Expr, ty: Type) -> void {
    typed.expr_types[expr.id] = ty
    if typed.dump_types {
        typed.expr_kinds[expr.id] = expr_kind_name(expr)
        typed.node_spans[expr.id] = expr.span
    }
}

/// Map an `AST.Expr` to its variant name as a string. Used by the
/// typed-ast dump.
export expr_kind_name :: fn(e: AST.Expr) -> string = match e {
    is AST.IntLitExpr        -> "IntLitExpr"
    is AST.FloatLitExpr      -> "FloatLitExpr"
    is AST.BoolLitExpr       -> "BoolLitExpr"
    is AST.NullLitExpr       -> "NullLitExpr"
    is AST.CharLitExpr       -> "CharLitExpr"
    is AST.StringLitExpr     -> "StringLitExpr"
    is AST.IdentExpr         -> "IdentExpr"
    is AST.BlockExpr         -> "BlockExpr"
    is AST.IfExpr            -> "IfExpr"
    is AST.MatchExpr         -> "MatchExpr"
    is AST.CallExpr          -> "CallExpr"
    is AST.BinaryExpr        -> "BinaryExpr"
    is AST.UnaryExpr         -> "UnaryExpr"
    is AST.FieldExpr         -> "FieldExpr"
    is AST.IndexExpr         -> "IndexExpr"
    is AST.StructLitExpr     -> "StructLitExpr"
    is AST.SeqLitExpr        -> "SeqLitExpr"
    is AST.RangeExpr         -> "RangeExpr"
    is AST.DotVariantExpr    -> "DotVariantExpr"
    is AST.LambdaExpr        -> "LambdaExpr"
    is AST.AwaitExpr         -> "AwaitExpr"
    is AST.CastExpr          -> "CastExpr"
    is AST.GenericInstExpr   -> "GenericInstExpr"
    is AST.IntrinsicCallExpr -> "IntrinsicCallExpr"
    is AST.ArrayTypeExpr     -> "ArrayTypeExpr"
    is AST.FnTypeExpr        -> "FnTypeExpr"
}

infer_expr :: fn(
    expr: AST.Expr, expected: Type | null,
    typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    // Every Expr variant has a dedicated arm — the match is exhaustive, so
    // T3013 now guards it: a new Expr variant trips the check here.
    match expr {
        is AST.IntLitExpr    -> { return TY_FREE_INT }
        is AST.FloatLitExpr  -> { return TY_FREE_FLOAT }
        is AST.BoolLitExpr   -> { return TY_BOOL }
        is AST.NullLitExpr   -> { return TY_NULL }
        is AST.CharLitExpr   -> { return TY_FREE_CHAR }
        is AST.StringLitExpr as e -> {
            // Walk interpolation parts so `"${x}"`'s `x` lands in
            // `expr_types`. T3018 Display
            // check is deferred — currently we just type the inner.
            for part in e.parts {
                if part is AST.StringLitInterp as p { check_expr(p.expr, null, typed, diags) }
            }
            return TY_STRING
        }
        is AST.IdentExpr     as e -> {
            sym :: typed.resolved.idents[e.span.hash()]
            if !(sym is null) {
                // W0001 : reference to a `@deprecated` decl.
                msg :: typed.resolved.deprecated_messages[sym.id]
                if !(msg is null) {
                    detail: string = "`${e.name}`"
                    if msg != "" { detail = "`${e.name}`: ${msg}" }
                    diags.push(warning(.UseOfDeprecated, e.span, detail))
                }
            }
            return infer_ident(e, typed)
        }
        is AST.BlockExpr     as e -> { return check_block(e, expected, typed, diags, null, check_expr) }
        is AST.IfExpr        as e -> { return infer_if(e, expected, typed, diags, null, check_expr) }
        is AST.MatchExpr     as e -> { return infer_match(e, expected, typed, diags, null, check_expr) }
        is AST.CallExpr      as e -> { return infer_call(e, typed, diags, check_expr) }
        is AST.BinaryExpr    as e -> { return infer_binary(e, expected, typed, diags, check_expr) }
        is AST.FieldExpr     as e -> { return infer_field(e, typed, diags, check_expr) }
        is AST.StructLitExpr as e -> { return infer_struct_lit(e, typed, diags, check_expr) }
        is AST.SeqLitExpr    as e -> { return infer_seq_lit(e, expected, typed, diags, check_expr) }
        is AST.UnaryExpr     as e -> { return infer_unary(e, expected, typed, diags, check_expr) }
        is AST.IndexExpr     as e -> { return infer_index(e, typed, diags, check_expr) }
        is AST.CastExpr      as e -> { return infer_cast(e, typed, diags, check_expr) }
        is AST.RangeExpr     as e -> { return infer_range(e, typed, diags, check_expr) }
        is AST.DotVariantExpr as e -> { return infer_dot_variant(e, expected, typed, diags) }
        is AST.LambdaExpr    as e -> { return infer_lambda(e, expected, typed, diags, check_expr) }
        is AST.AwaitExpr     as e -> { return infer_await(e, typed, diags, check_expr) }
        is AST.IntrinsicCallExpr as e -> { return infer_intrinsic(e, typed, diags, check_expr) }
        is AST.GenericInstExpr as e -> { return infer_generic_inst(e, typed, diags, check_expr) }
        is AST.ArrayTypeExpr as e -> { return infer_array_type_value(e, typed, diags) }
        is AST.FnTypeExpr    as e -> { return infer_fn_type_value(e, typed, diags) }
    }
}

// ---- tests ----------------------------------------------------------------

import "std/testing"

@test
test_check_expr_writes_into_expr_types :: fn() -> void {
    typed :: empty_typed_program()
    e :: AST.IntLitExpr {
        .span = empty_span(), .id = AST.UNASSIGNED_NODE_ID,
        .value = 42,
    }
    diags: Diagnostic[] = []
    check_expr(e, null, typed, diags)
    hit :: typed.expr_types[e.id]
    match hit {
        is null -> { assert(false, "expr_types should have an entry") }
        is FreeIntType -> {}
        is FreeCharType -> {}
        _ -> { assert(false, "expected FreeInt") }
    }
}

@test
test_check_expr_narrows_free_int_to_expected_primitive :: fn() -> void {
    typed :: empty_typed_program()
    e :: AST.IntLitExpr {
        .span = empty_span(), .id = AST.UNASSIGNED_NODE_ID,
        .value = 42,
    }
    diags: Diagnostic[] = []
    expected: Type = mk_primitive("i64")
    result :: check_expr(e, expected, typed, diags)
    assert_eq(display_type(result), "i64")
}

@test
test_check_expr_keeps_free_float_when_no_expected :: fn() -> void {
    typed :: empty_typed_program()
    e :: AST.FloatLitExpr {
        .span = empty_span(), .id = AST.UNASSIGNED_NODE_ID,
        .value = 1.5,
    }
    diags: Diagnostic[] = []
    result :: check_expr(e, null, typed, diags)
    assert(result is FreeFloatType, "unconstrained float stays FreeFloat")
}

@test
test_check_expr_narrows_through_block :: fn() -> void {
    // `{ 42 }` with expected = i64 narrows the inner literal end-to-end :
    // outer `check_expr` calls `infer_block`, `infer_block` recurses via
    // `check_expr` on the trailing, the recursive call narrows FreeInt to
    // i64. The outer wrapper writes the final i64 into expr_types for
    // the block too.
    typed :: empty_typed_program()
    inner :: AST.IntLitExpr {
        .span = empty_span(), .id = AST.UNASSIGNED_NODE_ID,
        .value = 42,
    }
    block :: AST.BlockExpr {
        .span = empty_span(), .id = AST.UNASSIGNED_NODE_ID,
        .stmts = [], .trailing = inner,
    }
    diags: Diagnostic[] = []
    expected: Type = mk_primitive("i64")
    assert_eq(display_type(check_expr(block, expected, typed, diags)), "i64")
}
