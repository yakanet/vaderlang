// vader/typecheck/expr_try â€” TryExpr inference (`expr?`).
//
// `expr?` types as the non-error half of `expr` (`string | JsonError` â†’
// `string`) AND enforces the propagation contract: `?` lowers to an implicit
// `return <error>`, so the enclosing fn's return type must be able to carry
// every error variant of `expr` â€” else T3067 (the error would otherwise be
// returned into a non-error slot and miscompile at runtime).

module "vader/typecheck"

import "vader/diagnostics" { Diagnostic, typecheck_error }
import "vader/types" { Type, TraitType, UnionType, TRAIT_ERROR, mk_union }
AST :: import "vader/parser"

/// Type-check `inner?`. Strips every `Error`-implementing variant from a
/// union â€” `string | JsonError` â†’ `string`. Non-union inner types pass
/// through unchanged. Diagnoses a non-propagatable error (T3067).
export infer_try :: fn(
    e: AST.TryExpr, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    inner :: check_expr_fn(e.inner, null, typed, diags)
    check_error_propagatable(e, inner, typed, diags)
    return strip_error_variants(inner, typed)
}

// The propagation gate (T3067). `?` lowers to `return <error>` **verbatim** â€” no
// coercion, unlike an ordinary `return` (`build_return_stmts` in `lower_try.vader`
// vs `lower_stmt`'s `try_emit_into_coercion`). So the gate admits only the
// *coercion-free* ways an error can be returned: plain assignability
// (`is_assignable`) or subtype/trait widening (`try_trait_widen`, which records
// no coercion â€” e.g. `MyErr â†’ Error`). It deliberately does NOT use `flows_into`,
// whose `try_into` arm also admits `.into()` / arrayâ†’iter coercions that the
// `?`-return never materialises (those would be returned raw â†’ miscompile).
// Per-variant, because neither predicate decomposes a union *source*. A
// non-fallible `?` (no error variant) is left alone ; a `?` with no enclosing fn
// (module-scope const init) has nowhere to propagate â†’ also T3067.
check_error_propagatable :: fn(
    e: AST.TryExpr, inner: Type, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    errs :: error_variant_list(inner, typed)
    if errs.len() == 0 { return }
    ctx :: resolve_ctx(null, typed)
    if ctx == null {
        diags.push(typecheck_error(.TryErrorNotPropagatable, e.span, ""))
        return
    }
    for ev in errs {
        if !can_return_error(ev, ctx.return_type, typed) {
            diags.push(typecheck_error(.TryErrorNotPropagatable, e.span, ""))
            return
        }
    }
}

// Can `ev` (an error variant) be returned as `ret` without a coercion? Plain
// assignability, or a subtype/trait widen (`MyErr â†’ Error`) â€” the two forms `?`'s
// raw `return <error>` can represent. Excludes `.into()` coercions (see above).
can_return_error :: fn(ev: Type, ret: Type, typed: TypedProgram) =
    is_assignable(ev, ret, null) || try_trait_widen(ev, ret, typed)

// The `Error`-implementing variants of `t` â€” every union member that is
// error-like, or `t` itself when it is a bare error type. Empty for a
// non-fallible `t`.
error_variant_list :: fn(t: Type, typed: TypedProgram) -> Type[] {
    out: Type[] = []
    if t is UnionType as u {
        for v in u.variants {
            if is_error_like(v, typed) { out.push(v) }
        }
    } else if is_error_like(t, typed) {
        out.push(t)
    }
    return out
}

strip_error_variants :: fn(t: Type, typed: TypedProgram) -> Type {
    if !(t is UnionType) { return t }
    kept: Type[] = []
    for v in t.variants {
        if !is_error_like(v, typed) { kept.push(v) }
    }
    if kept.len() == 0 { return t }
    if kept.len() == 1 { return kept[0] }
    return mk_union(kept)
}

// `TraitType` is handled separately because trait symbols don't live in
// `struct_implemented_traits` â€” only their concrete implementers do.
is_error_like :: fn(t: Type, typed: TypedProgram) -> bool {
    if t is TraitType as tr { return tr.symbol.name == TRAIT_ERROR }
    return struct_implements_trait(t, TRAIT_ERROR, typed)
}
