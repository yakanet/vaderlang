// vader/typecheck/stmt — statement + block + fn-body checking.
//
// Walks every statement of a fn body, types each one, tracks loop
// depth + return type via `FnContext`, and writes results into
// `local_types` / `expr_types`. Stops short of W0002 dead-code
// detection, T3041 mutate-`::`-local, IndexSet dispatch, custom
// Iterator trait lookup, `comptime for` unrolling, and `Self`
// substitution — those land with later phases.

module "vader/typecheck"

import "vader/diagnostics/diagnostic" { Diagnostic, Span, typecheck_error }
import "vader/resolver/scope" { span_full_key, span_key }
AST :: import "vader/parser/ast"
import "vader/typecheck/context" { FnContext, new_fn_context }
import "vader/typecheck/coerce" { try_into }
import "vader/typecheck/type_expr" { type_from_expr }
import "vader/typecheck/type_ops" { default_if_free, narrow_for_expected }
import "vader/typecheck/type_assign" { is_assignable }
import "vader/types" {
    Type, ArrayType, FnType, StructType, TupleType, TypeParamType, UnresolvedType, display_type,
    TY_BOOL, TY_NEVER, TY_VOID, TY_UNRESOLVED,
}
import "vader/typecheck/typed_ast" { TypedProgram, new_typed_program }

/// Check every statement in `block`, then type the trailing expression
/// (or `void` when none). Writes the block's type into `expr_types`.
/// `ctx` carries the surrounding fn's return type + loop depth ;
/// pass `null` for stand-alone block exprs.
export check_block :: fn(
    block: AST.BlockExpr, expected: Type | null,
    typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    // Track flow-narrowing pushed by divergent guards (`if x is T
    // { return … }`) so subsequent stmts see the complement type.
    // Each entry holds the binding's sym_id + the static type to
    // restore on block exit (mirrors `pop_narrow` semantics).
    divergent_narrows: DivergentNarrow[] = []
    for stmt in block.stmts {
        check_stmt(stmt, typed, diags, ctx, check_expr_fn)
        push_divergent_narrow_if(stmt, typed, divergent_narrows)
    }
    result: Type = TY_VOID
    match block.trailing {
        is null -> {
            // Diverged block (last stmt is `return` / `break` /
            // `continue`) carries `Never` so callers (`infer_if`,
            // `infer_match`) collapse the union arm cleanly.
            if block.stmts.len() > 0 {
                last :: block.stmts[block.stmts.len() - 1]
                if is_divergent_stmt(last) { result = TY_NEVER }
            }
        }
        _ -> { result = check_expr_fn(block.trailing, expected, typed, diags) }
    }
    // Restore the binding's static type on block exit so outer
    // scopes don't see the narrowed shape.
    for dn in divergent_narrows {
        if dn.field_key == "" { pop_narrow(typed, dn.sym_id, dn.prev, dn.static_ty) }
        else { pop_field_narrow(typed, dn.field_key, dn.prev, dn.static_ty) }
    }
    // Don't clobber the trailing expression's `expr_kinds` entry —
    // expression-bodied fns synthesise a BlockExpr around the trailing
    // with overlapping spans, and the trailing's true kind (BinaryExpr
    // / CallExpr / …) is what callers want to see in the dump.
    // Now keyed by AST id, so the block's id and the trailing expr's
    // id are distinct ; the null-guard remains a defence in depth.
    if typed.expr_kinds[block.id] is null {
        typed.expr_kinds[block.id] = "BlockExpr"
    }
    if typed.expr_types[block.id] is null {
        typed.expr_types[block.id] = result
        typed.node_spans[block.id] = block.span
    }
    return result
}

/// Type-check a single statement. Reads `ctx` for `return` / `break` /
/// `continue` validation ; writes `local_types` for let-bindings.
export check_stmt :: fn(
    stmt: AST.Stmt, typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    match stmt {
        is AST.LetStmt      as s -> { check_let(s, typed, diags, check_expr_fn) }
        is AST.AssignStmt   as s -> { check_assign(s, typed, diags, check_expr_fn) }
        is AST.ExprStmt     as s -> { check_expr_fn(s.expr, null, typed, diags) }
        is AST.ReturnStmt   as s -> { check_return(s, typed, diags, ctx, check_expr_fn) }
        is AST.ForStmt      as s -> { check_for(s, typed, diags, ctx, check_expr_fn) }
        is AST.BreakStmt    as s -> { check_loop_jump(s.span, ctx, diags) }
        is AST.ContinueStmt as s -> { check_loop_jump(s.span, ctx, diags) }
        is AST.DeferStmt    as s -> { check_defer(s, typed, diags, ctx, check_expr_fn) }
    }
    return
}

/// Type-check a fn body. Reads the fn's declared return type from
/// `decl_types`, builds an initial `FnContext`, then walks the body.
/// Final-expression / implicit-return type-checking happens through
/// the trailing-expr arm of `check_block`.
export check_fn_body :: fn(
    fn_decl: AST.FnDecl, body: AST.BlockExpr,
    typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    return_type :: lookup_return_type(fn_decl, typed)
    // Expression-bodied without explicit return type : infer from
    // the trailing expression. `declare_fn_return` leaves this as
    // TY_UNRESOLVED ; we resolve it here and patch `decl_types` so
    // call sites see the inferred type.
    inferred_return :: fn_decl.is_expression_bodied && (return_type is UnresolvedType)
    expected: Type | null = return_type
    if inferred_return { expected = null }
    ctx :: new_fn_context(return_type, null)
    prev :: typed.current_fn_ctx
    typed.current_fn_ctx = ctx
    got :: check_block(body, expected, typed, diags, ctx, check_expr_fn)
    if inferred_return {
        // Recursive fns leave their return as `?` — the body's
        // inferred type contains an Unresolved leaf (the recursive
        // call) so substituting would just amplify the unresolved-
        // ness. Surface T3034 instead.
        if contains_unresolved(got) {
            diags.push(typecheck_error(.RecursiveExprBodiedFn, fn_decl.name_span,
                "`${fn_decl.name}`"))
        } else {
            defaulted :: default_if_free(got)
            patch_fn_return_type(fn_decl, defaulted, typed)
        }
    } else {
        // Implicit-return : a trailing expression substitutes for an
        // explicit `return`. Surface T3020 against the trailing's span.
        match body.trailing {
            is null -> {}
            _ -> { emit_return_mismatch_if(got, return_type, body.trailing.span, typed, diags) }
        }
    }
    typed.current_fn_ctx = prev
}

patch_fn_return_type :: fn(fn_decl: AST.FnDecl, ret: Type, typed: TypedProgram) -> void {
    sp :: fn_decl.name_span
    cur :: typed.decl_types[span_key(sp)]
    match cur {
        is FnType as ft -> { typed.decl_types[span_key(sp)] = mk_fn(ft.params, ret) }
        _ -> {}
    }
}

contains_unresolved :: fn(t: Type) -> bool {
    match t {
        is UnresolvedType -> { return true }
        is UnionType as u -> {
            for v in u.variants { if contains_unresolved(v) { return true } }
            return false
        }
        is ArrayType as a -> { return contains_unresolved(a.element) }
        is FnType as f -> {
            for p in f.params { if contains_unresolved(p) { return true } }
            return contains_unresolved(f.return_type)
        }
        is TupleType as p -> {
            for el in p.elements { if contains_unresolved(el) { return true } }
            return false
        }
        is StructType as s -> {
            for a in s.args { if contains_unresolved(a) { return true } }
            return false
        }
        _ -> { return false }
    }
}

import "vader/types" { mk_fn, UnionType }

// Push T3020 when `got` doesn't flow into `expected`. Shared between
// `check_return` and the implicit-return check in `check_fn_body` so
// wording / arity stay in sync.
emit_return_mismatch_if :: fn(
    got: Type, expected: Type, span: Span, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    if is_assignable(got, expected, null) { return }
    if try_into(got, expected, typed) { return }
    diags.push(typecheck_error(.BodyReturnIncompatible, span,
        "expected ${display_type(expected)}, got ${display_type(got)}"))
}

// ---- per-stmt helpers -----------------------------------------------------

check_let :: fn(
    s: AST.LetStmt, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    ann: Type | null = null
    match s.ty {
        is null -> {}
        _ -> { ann = type_from_expr(s.ty, typed.resolved, diags) }
    }
    got :: check_expr_fn(s.value, ann, typed, diags)
    declared: Type = TY_UNRESOLVED
    match ann {
        is null -> { declared = default_if_free(got) }
        _ -> {
            declared = ann
            if !is_assignable(got, ann, null) && !try_into(got, ann, typed) {
                diags.push(typecheck_error(.TypeMismatch, s.span,
                    "expected ${display_type(ann)}, got ${display_type(got)}"))
            }
        }
    }
    // T3035 : `name := <type-expr>` (mutable) where the inferred
    // type is `type` is rejected — Layer 4 milestone B.1 doesn't
    // ship a runtime Type value. The immutable form (`name :: ...`)
    // is fine since it lowers as a const-as-type-alias.
    if s.mutable && declared is TypeMetaType {
        diags.push(typecheck_error(.TypeValuedSlotNotYetSupported, s.span,
            "`type`-valued locals are not yet supported (Layer 4 milestone B.1) ; use the immutable form `name :: <type-expr>` for an in-fn type alias, or a top-level alias `Name :: type[T] ...`"))
    }
    assign_binding_types(s.binding, declared, typed, diags)
}

import "vader/types" { TypeMetaType }

check_assign :: fn(
    s: AST.AssignStmt, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    // T3041 : bare-ident assignment to a `::`-bound local. Mirrors
    // TS — surface the diag and skip the value-side typing so the
    // dump doesn't carry extra expr_types for a rejected write.
    if s.target is AST.IdentExpr {
        if is_const_reassign(s.target, typed) {
            diags.push(typecheck_error(.CannotReassignConst, s.target.span,
                "`${s.target.name}` is declared with `::` — use `:=` to allow mutation"))
            return
        }
    }
    // T3042 : `arr[i] = v` when arr's static type is `const T[]`.
    // For Array-typed receivers we still write the full IndexExpr
    // into `expr_types` (matches TS). For non-Array receivers the
    // assignment LHS doesn't land in `expr_types` — only its sub-
    // parts do, since the IndexSet trait dispatch is the read site.
    if s.target is AST.IndexExpr {
        ix :: s.target
        target_arr_ty :: check_expr_fn(ix.target, null, typed, diags)
        check_expr_fn(ix.index, null, typed, diags)
        if target_arr_ty is ArrayType {
            if target_arr_ty.immutable {
                diags.push(typecheck_error(.CannotMutateImmutableArray, ix.target.span,
                    "cannot mutate `${display_type(target_arr_ty)}` — declared with `const`"))
                return
            }
            full_target_ty :: check_expr_fn(s.target, null, typed, diags)
            check_expr_fn(s.value, full_target_ty, typed, diags)
            return
        }
        check_expr_fn(s.value, null, typed, diags)
        return
    }
    target_ty :: check_expr_fn(s.target, null, typed, diags)
    value_hint: Type | null = null
    if !(target_ty is UnresolvedType) { value_hint = target_ty }
    check_expr_fn(s.value, value_hint, typed, diags)
    return
}

is_const_reassign :: fn(ident: AST.IdentExpr, typed: TypedProgram) -> bool {
    sym :: typed.resolved.idents[span_key(ident.span)]
    if sym is null { return false }
    return !(typed.resolved.immutable_locals[sym.id] is null)
}

check_return :: fn(
    s: AST.ReturnStmt, typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    // Fall back to the typed-program-wide ctx when the arg-side ctx
    // is null — the dispatcher's recursive paths (`infer_if`,
    // `infer_match`) pass `null` so the body's return targets aren't
    // visible without this fallback.
    effective: FnContext | null = ctx
    match ctx {
        is null -> { effective = typed.current_fn_ctx }
        _ -> {}
    }
    v :: s.value
    if v is null {
        match effective {
            is null -> {}
            _ -> { emit_return_mismatch_if(TY_VOID, effective.return_type, s.span, typed, diags) }
        }
        return
    }
    expected: Type | null = null
    match effective {
        is null -> {}
        _ -> { expected = effective.return_type }
    }
    got :: check_expr_fn(v, expected, typed, diags)
    match effective {
        is null -> {}
        _ -> { emit_return_mismatch_if(got, effective.return_type, s.span, typed, diags) }
    }
}

check_for :: fn(
    s: AST.ForStmt, typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    match s.form {
        is AST.InfiniteFor -> {}
        is AST.WhileFor as w -> {
            got :: check_expr_fn(w.cond, null, typed, diags)
            // `for X { ... }` desugars to `for _ in X { ... }` when X
            // is iterable (array today ; custom Iterator impls land
            // with coerce.vader). Skip T3019 in that case to match TS.
            if got is ArrayType { /* iterable — no diag */ }
            else if !is_assignable(got, TY_BOOL, null) {
                diags.push(typecheck_error(.ConditionMustBeBool, w.cond.span,
                    "while condition must be `bool`, got ${display_type(got)}"))
            }
        }
        is AST.InFor as f -> {
            iter_ty :: check_expr_fn(f.iter, null, typed, diags)
            elem :: for_in_element(iter_ty, typed)
            typed.local_types[span_key(f.binding_span)] = elem
        }
    }
    inner_ctx :: bump_loop_depth(ctx)
    check_block(s.body, null, typed, diags, inner_ctx, check_expr_fn)
    return
}

check_loop_jump :: fn(span: Span, ctx: FnContext | null, diags: Diagnostic[]) -> void {
    if ctx is null { return }
    if ctx.loop_depth == 0 {
        diags.push(typecheck_error(.BreakContinueOutsideLoop, span,
            "`break` / `continue` only allowed inside a loop"))
    }
}

check_defer :: fn(
    s: AST.DeferStmt, typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    match s.body {
        is AST.DeferStmtBody  as b -> { check_stmt(b.stmt, typed, diags, ctx, check_expr_fn) }
        is AST.DeferBlockBody as b -> { check_block(b.block, null, typed, diags, ctx, check_expr_fn) }
    }
    return
}

// ---- support --------------------------------------------------------------

bump_loop_depth :: fn(ctx: FnContext | null) -> FnContext | null {
    if ctx is null { return null }
    return FnContext {
        .return_type = ctx.return_type,
        .self_type   = ctx.self_type,
        .loop_depth  = ctx.loop_depth + 1,
    }
}

// Restore-stack entry for a divergent-guard narrowing pushed onto
// a `check_block` scope. Held in a per-block array so the original
// static types are restored when the block exits.
//
// `field_key` is `""` for ident narrowings ; otherwise it carries the
// `${sym_id}.${field}` slot used by `narrowed_fields` so divergent
// guards on `b.items` restore the right side-table on scope exit.
DivergentNarrow :: struct {
    sym_id:    i32
    prev:      Type | null
    static_ty: Type
    field_key: string = ""
}

// Detect `if x is T { return ... }` pattern and push the complement
// narrowing for the rest of the block. The then-branch must end in a
// divergent statement (return / break / continue) — we approximate
// this by requiring the then-block's last stmt to be a `ReturnStmt`.
push_divergent_narrow_if :: fn(
    stmt: AST.Stmt, typed: TypedProgram, stack: DivergentNarrow[],
) -> void {
    if !(stmt is AST.ExprStmt) { return }
    if !(stmt.expr is AST.IfExpr) { return }
    if_expr :: stmt.expr
    if !(if_expr.else_branch is null) { return }
    if !then_is_divergent(if_expr.then_block) { return }
    narrowing :: detect_is_narrow_for_block(if_expr.cond, typed)
    if narrowing is null { return }
    if narrowing.field_key == "" {
        prev :: push_narrow(typed, narrowing.sym_id, narrowing.else_ty)
        stack.push(DivergentNarrow {
            .sym_id    = narrowing.sym_id,
            .prev      = prev,
            .static_ty = narrowing.static_ty,
        })
    } else {
        prev :: push_field_narrow(typed, narrowing.field_key, narrowing.else_ty)
        stack.push(DivergentNarrow {
            .sym_id    = narrowing.sym_id,
            .prev      = prev,
            .static_ty = narrowing.static_ty,
            .field_key = narrowing.field_key,
        })
    }
}

then_is_divergent :: fn(b: AST.BlockExpr) -> bool {
    if b.stmts.len() == 0 { return false }
    return is_divergent_stmt(b.stmts[b.stmts.len() - 1])
}

is_divergent_stmt :: fn(s: AST.Stmt) -> bool {
    if s is AST.ReturnStmt { return true }
    if s is AST.BreakStmt { return true }
    if s is AST.ContinueStmt { return true }
    return false
}

BlockNarrow :: struct {
    sym_id:    i32
    static_ty: Type
    else_ty:   Type
    field_key: string = ""
}

detect_is_narrow_for_block :: fn(cond: AST.Expr, typed: TypedProgram) -> BlockNarrow | null {
    // Mirrors `expr_if.vader::detect_is_narrow` but kept local to
    // avoid the cross-import — we only need the else-type for the
    // divergent-guard case.
    if cond is AST.UnaryExpr {
        if i32(cond.op) == i32(AST.UnaryOp.Not) {
            inner :: detect_is_narrow_for_block(cond.operand, typed)
            if inner is null { return null }
            return BlockNarrow {
                .sym_id    = inner.sym_id,
                .static_ty = inner.static_ty,
                .else_ty   = subtract_type(inner.static_ty, inner.else_ty),
            }
        }
    }
    if !(cond is AST.BinaryExpr) { return null }
    // `x == null` / `x != null` / `null == x` / `null != x` — both
    // orderings flip the same way ; divergent guard pushes the
    // complement narrowing for the rest of the block.
    if i32(cond.op) == i32(AST.BinaryOp.Eq) || i32(cond.op) == i32(AST.BinaryOp.Neq) {
        ident_side :: pick_ident_vs_null(cond.left, cond.right)
        if !(ident_side is null) {
            sym :: typed.resolved.idents[span_key(ident_side.span)]
            if sym is null { return null }
            base :: type_of_symbol(sym, typed)
            current :: narrow_for_binding(typed, sym.id, base)
            null_ty :: mk_primitive("null")
            if i32(cond.op) == i32(AST.BinaryOp.Eq) {
                return BlockNarrow {
                    .sym_id    = sym.id,
                    .static_ty = base,
                    .else_ty   = subtract_type(current, null_ty),
                }
            }
            return BlockNarrow { .sym_id = sym.id, .static_ty = base, .else_ty = null_ty }
        }
        field_side :: pick_field_vs_null(cond.left, cond.right)
        if !(field_side is null) {
            target :: resolve_field_chain_static(field_side, typed)
            if !(target is null) {
                null_ty :: mk_primitive("null")
                current :: narrow_for_field(typed, target.field_key, target.static_ty)
                if i32(cond.op) == i32(AST.BinaryOp.Eq) {
                    return BlockNarrow {
                        .sym_id    = 0,
                        .static_ty = target.static_ty,
                        .else_ty   = subtract_type(current, null_ty),
                        .field_key = target.field_key,
                    }
                }
                return BlockNarrow {
                    .sym_id    = 0,
                    .static_ty = target.static_ty,
                    .else_ty   = null_ty,
                    .field_key = target.field_key,
                }
            }
        }
        return null
    }
    if i32(cond.op) != i32(AST.BinaryOp.Is) { return null }
    if !(cond.left is AST.IdentExpr) { return null }
    sym :: typed.resolved.idents[span_key(cond.left.span)]
    if sym is null { return null }
    base :: type_of_symbol(sym, typed)
    current :: narrow_for_binding(typed, sym.id, base)
    narrowed :: type_from_expr(cond.right, typed.resolved, diag_sink_stmt())
    return BlockNarrow {
        .sym_id    = sym.id,
        .static_ty = base,
        .else_ty   = subtract_type(current, narrowed),
    }
}

import "vader/types" { mk_primitive }


diag_sink_stmt :: fn() -> Diagnostic[] { return [] }

import "vader/typecheck/narrow" {
    narrow_for_binding, narrow_for_field,
    pick_field_vs_null, pick_ident_vs_null,
    pop_field_narrow, pop_narrow, push_field_narrow, push_narrow,
    resolve_field_chain_static,
}
import "vader/typecheck/expr_ident" { type_of_symbol }
import "vader/typecheck/type_ops" { subtract_type }

// Pull the iterator's element type. `T[]` yields `T` directly ;
// generic `StructType` falls back to first type arg (covers Range and
// Iterator(T) wrappers). Otherwise probes `typed.iter_element_types`
// for the indexed `X implements Iterator(T)` impl.
for_in_element :: fn(iter_ty: Type, typed: TypedProgram) -> Type {
    match iter_ty {
        is ArrayType as a -> { return a.element }
        is StructType as st -> {
            elem :: typed.iter_element_types[st.symbol.name]
            match elem {
                is null -> {
                    if st.args.len() >= 1 { return st.args[0] }
                    return TY_UNRESOLVED
                }
                _ -> {
                    // Substitute the impl's TypeParam against the
                    // struct's declared type_params + concrete args
                    // (`Range[T] implements Iterator[T]` records the
                    // impl-side `T` — substitute_by_name swaps it
                    // for the call-site's concrete arg by name).
                    decl :: typed.struct_decls[st.symbol.id]
                    if decl is null { return elem }
                    return substitute_by_name(elem, decl.type_params, st.args)
                }
            }
        }
        _ -> { return TY_UNRESOLVED }
    }
}

import "vader/typecheck/field" { substitute_by_name }

lookup_return_type :: fn(fn_decl: AST.FnDecl, typed: TypedProgram) -> Type {
    decl_ty :: typed.decl_types[span_key(fn_decl.name_span)]
    if decl_ty is null { return TY_UNRESOLVED }
    match decl_ty {
        is FnType as f -> { return f.return_type }
        _ -> { return TY_UNRESOLVED }
    }
}

/// Walk a let-binding tree and write the inferred / declared type into
/// `typed.local_types` keyed by the binding span (the same span the
/// resolver passed to `mint_local`). Wildcards are skipped — they
/// don't introduce a Symbol.
export assign_binding_types :: fn(
    b: AST.LetBinding, declared: Type, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    match b {
        is AST.SimpleBinding   as sb -> { typed.local_types[span_key(sb.name_span)] = declared }
        is AST.RestBinding     as rb -> { typed.local_types[span_key(rb.span)] = declared }
        is AST.WildcardBinding       -> {}
        is AST.TupleBinding    as tb -> { assign_tuple(tb, declared, typed, diags) }
    }
}

assign_tuple :: fn(
    tb: AST.TupleBinding, declared: Type, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    match declared {
        is TupleType as tup -> {
            if tup.elements.len() != tb.elements.len() {
                // Best-effort : Unresolved on each leaf, the resolver-
                // emitted shape error already surfaces upstream.
                for leaf in tb.elements { assign_binding_types(leaf, TY_UNRESOLVED, typed, diags) }
                return
            }
            for i in 0..<tb.elements.len() {
                assign_binding_types(tb.elements[i], tup.elements[i], typed, diags)
            }
        }
        // Array destructuring : `[first, …rest] := arr` binds every
        // simple/wildcard slot to the element type and the
        // `RestBinding` to the array as a whole.
        is ArrayType as arr -> {
            for leaf in tb.elements {
                match leaf {
                    is AST.RestBinding -> { assign_binding_types(leaf, declared, typed, diags) }
                    _ -> { assign_binding_types(leaf, arr.element, typed, diags) }
                }
            }
        }
        _ -> {
            for leaf in tb.elements { assign_binding_types(leaf, TY_UNRESOLVED, typed, diags) }
        }
    }
}

// ---- tests ----------------------------------------------------------------
//
// Local `stub_check_expr` avoids importing `expr.vader` (would create a
// load-time cycle through `expr → stmt`). Full end-to-end coverage runs
// via `check_module_with_bodies` in `orchestrate.vader`.

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver/resolve" { resolve_module }
import "vader/resolver/symbol" { new_factory }
import "vader/typecheck/decl" { declare_module }
import "vader/typecheck/expr_ident" { infer_ident }
import "vader/typecheck/expr_literals" { infer_int_lit, infer_string_lit }
// Bundles parse + resolve + declare + walks fn bodies with the stub.
// Returns both `typed` and `diags` so test sites can assert on either.
StubResult :: struct {
    typed: TypedProgram
    diags: Diagnostic[]
}

stub_check_module :: fn(src: string) -> StubResult {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    typed :: new_typed_program(rm)
    diags: Diagnostic[] = []
    declare_module(parsed.program.decls, rm, typed, factory, diags)
    for decl in parsed.program.decls {
        if decl is AST.FnDecl {
            match decl.body {
                is AST.BlockExpr as body -> { check_fn_body(decl, body, typed, diags, stub_check_expr) }
                is null -> {}
            }
        }
    }
    return StubResult { .typed = typed, .diags = diags }
}

// Tiny check_expr replacement — only the variants the inline tests
// exercise (int / string literals + idents). FreeInt narrowing reuses
// the shared `narrow_for_expected` so the stub matches the real
// orchestrator's behavior.
stub_check_expr :: fn(
    e: AST.Expr, expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    match e {
        is AST.IntLitExpr    as x -> { return narrow_for_expected(infer_int_lit(x), expected) }
        is AST.StringLitExpr as x -> { return infer_string_lit(x) }
        is AST.IdentExpr     as x -> { return infer_ident(x, typed) }
        _ -> { return TY_UNRESOLVED }
    }
}

has_code :: fn(diags: Diagnostic[], code: string) -> bool {
    for d in diags { if d.code.id == code { return true } }
    return false
}

@test
test_let_simple_binding_records_local_type :: fn() -> void {
    src :: "f :: fn() -> i32 { x :: 42 }"
    out :: stub_check_module(src)
    sb :: first_simple_binding(src)
    if sb is null { assert(false, "expected SimpleBinding") return }
    ty :: out.typed.local_types[span_key(sb.name_span)]
    if ty is null { assert(false, "binding should have a type") return }
    // Bare `42` defaults to i32 via `default_if_free`.
    assert_eq(display_type(ty), "i32")
}

@test
test_let_with_annotation_narrows_free_int :: fn() -> void {
    src :: "f :: fn() -> i64 { x: i64 = 5 }"
    out :: stub_check_module(src)
    sb :: first_simple_binding(src)
    if sb is null { assert(false, "expected SimpleBinding") return }
    ty :: out.typed.local_types[span_key(sb.name_span)]
    if ty is null { assert(false, "binding should have a type") return }
    assert_eq(display_type(ty), "i64")
}

@test
test_let_annotation_mismatch_emits_T3001 :: fn() -> void {
    out :: stub_check_module("f :: fn() -> void { x: i32 = \"hello\" }")
    assert(has_code(out.diags, "T3001"), "expected T3001 on annotation mismatch")
}

@test
test_return_value_mismatch_emits_T3020 :: fn() -> void {
    out :: stub_check_module("f :: fn() -> i32 { return \"hello\" }")
    assert(has_code(out.diags, "T3020"), "expected T3020 on return-type mismatch")
}

@test
test_return_bare_in_non_void_emits_T3020 :: fn() -> void {
    out :: stub_check_module("f :: fn() -> i32 { return }")
    assert(has_code(out.diags, "T3020"), "expected T3020 on bare return in non-void fn")
}

@test
test_for_in_array_narrows_binding :: fn() -> void {
    src :: "f :: fn(xs: i32[]) -> void { for x in xs { } }"
    out :: stub_check_module(src)
    sp :: first_for_in_binding_span(src)
    if sp is null { assert(false, "expected a for-in") return }
    ty :: out.typed.local_types[span_key(sp)]
    if ty is null { assert(false, "for-in binding should have a type") return }
    assert_eq(display_type(ty), "i32")
}

// ---- test walkers ---------------------------------------------------------

first_simple_binding :: fn(src: string) -> AST.SimpleBinding | null {
    parsed :: parse_source(src, "t.vader")
    match parsed.program.decls[0] {
        is AST.FnDecl as f -> {
            match f.body {
                is AST.BlockExpr as b -> {
                    for s in b.stmts {
                        if s is AST.LetStmt {
                            if s.binding is AST.SimpleBinding { return s.binding }
                        }
                    }
                }
                is null -> {}
            }
        }
        _ -> {}
    }
    return null
}

first_for_in_binding_span :: fn(src: string) -> Span | null {
    parsed :: parse_source(src, "t.vader")
    match parsed.program.decls[0] {
        is AST.FnDecl as f -> {
            match f.body {
                is AST.BlockExpr as b -> {
                    for s in b.stmts {
                        if s is AST.ForStmt {
                            match s.form {
                                is AST.InFor as inf -> { return inf.binding_span }
                                _ -> {}
                            }
                        }
                    }
                }
                is null -> {}
            }
        }
        _ -> {}
    }
    return null
}
