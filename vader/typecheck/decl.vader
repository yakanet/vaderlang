// vader/typecheck/decl — top-level type collection.
//
// Mirror of `src/typecheck/passes/decl.ts::declareType`. Walks every
// top-level decl in source order, mints its declared `Type`, and stores
// the result in `typed.decl_types` keyed by the decl's `name_span`.
// Later passes (body checking, ImplRegistry building) read this side
// table without re-walking the AST.
//
// MVP-trimmed against the TS reference :
//   - No `@extern` ABI validation (T3050/T3051) — lands when call.vader
//     wires up extern decoration handling.
//   - No Layer 4-sugar const-as-type-alias detection. Plain ConstDecls
//     get their annotated type ; un-annotated ones stay un-typed at
//     decl level (their literal type lands in `expr_types` at body time).
//   - ImplDecls contribute to `ImplRegistry` (Phase 2.4), not here.
//   - AssertDecl is a no-op (handled by comptime).

module "vader/typecheck"

import "std/collections" { MutableMap }
import "vader/diagnostics" { Diagnostic, Span, typecheck_error }
import "vader/resolver" { ResolvedModule }
import "vader/resolver/symbol" { Symbol, SymbolKind, SymbolFactory, make }
AST :: import "vader/parser"
import "vader/parser" { Visibility }
import "vader/types" {
    Type, ArrayType, PrimitiveType, UnresolvedType, display_type,
    StructType, EnumType, TraitType, UnionType, FnType, TupleType,
    TypeParamType, TypeMetaType, SelfType, FreeIntType, FreeFloatType,
    NeverType, AnyType,
    mk_struct, mk_trait, mk_fn, mk_enum, mk_type_param,
    TY_UNRESOLVED, TY_VOID,
}

/// Walk every top-level decl in `program.decls` and mint its `Type` into
/// `typed.decl_types`. The pass is single-shot — re-running it is
/// idempotent if `decl_types` is cleared first.
///
/// Builds a `name → Symbol` map up front so per-decl lookups don't scan
/// the sorted `resolved.symbols` array N times.
export declare_module :: fn(
    program_decls: AST.Decl[], resolved: ResolvedModule,
    typed: TypedProgram, factory: SymbolFactory, diags: Diagnostic[],
) -> void {
    by_name :: MutableMap<string, Symbol> {}
    for s in resolved.symbols { by_name[s.name] = s }
    for decl in program_decls {
        declare_decl(decl, by_name, resolved, typed, factory, diags)
        register_deprecated(decl, by_name, resolved)
    }
}

register_deprecated :: fn(
    decl: AST.Decl, by_name: MutableMap<string, Symbol>, resolved: ResolvedModule,
) -> void {
    name :: decorated_decl_name(decl)
    if name == "" { return }
    msg :: deprecated_message(decorated_decl_decorators(decl))
    if msg is null { return }
    sym :: by_name[name]
    if sym is null { return }
    resolved.deprecated_messages[sym.id] = msg
}

decorated_decl_name :: fn(d: AST.Decl) -> string {
    match d {
        is AST.FnDecl as x        -> { return x.name }
        is AST.StructDecl as x    -> { return x.name }
        is AST.EnumDecl as x      -> { return x.name }
        is AST.TraitDecl as x     -> { return x.name }
        is AST.TypeAliasDecl as x -> { return x.name }
        is AST.ConstDecl as x     -> { return x.name }
        _ -> { return "" }
    }
}

decorated_decl_decorators :: fn(d: AST.Decl) -> AST.Decorator[] {
    match d {
        is AST.FnDecl as x        -> { return x.decorators }
        is AST.StructDecl as x    -> { return x.decorators }
        is AST.EnumDecl as x      -> { return x.decorators }
        is AST.TraitDecl as x     -> { return x.decorators }
        is AST.TypeAliasDecl as x -> { return x.decorators }
        is AST.ConstDecl as x     -> { return x.decorators }
        _ -> { return [] }
    }
}

deprecated_message :: fn(decs: AST.Decorator[]) -> string | null {
    for d in decs {
        if d.name != "deprecated" { continue }
        if d.args.len() == 0 { return "" }
        a :: d.args[0]
        if a is AST.StringLitExpr {
            if a.parts.len() == 1 {
                p :: a.parts[0]
                if p is AST.StringLitText { return p.value }
            }
        }
        return ""
    }
    return null
}

declare_decl :: fn(
    decl: AST.Decl, by_name: MutableMap<string, Symbol>,
    resolved: ResolvedModule, typed: TypedProgram,
    factory: SymbolFactory, diags: Diagnostic[],
) -> void {
    match decl {
        is AST.FnDecl as fn_decl -> { declare_fn(fn_decl, by_name, resolved, typed, diags) }
        is AST.StructDecl as sd  -> {
            declare_named_with_args(sd.name, sd.name_span, sd.type_params, by_name, typed, resolved.path, factory, mk_struct)
            // Index the struct decl by symbol id so `field.vader` can
            // walk fields without re-traversing the program AST.
            sym :: by_name[sd.name]
            if sym is Symbol {
                typed.struct_decls[sym.id] = sd
                // Pre-resolve every field's type using THIS module's
                // resolved.idents. Cross-module field lookups (entry
                // struct lives in `std/collections` but `entry.value`
                // is read from main) consult these directly via the
                // owner module's bindings.
                fields_map :: MutableMap<string, Type> {}
                for f in sd.fields {
                    fields_map[f.name] = type_from_expr(f.ty, resolved, diags)
                }
                typed.struct_field_types[sym.id] = fields_map
            }
        }
        is AST.EnumDecl as ed    -> { declare_enum(ed, by_name, resolved, typed, diags) }
        is AST.TraitDecl as td   -> {
            declare_named_with_args(td.name, td.name_span, td.type_params, by_name, typed, resolved.path, factory, mk_trait)
            sym :: by_name[td.name]
            if sym is Symbol {
                typed.trait_decls[sym.id] = td
                typed.trait_decl_owners[sym.id] = resolved
            }
        }
        is AST.TypeAliasDecl as ta -> { declare_type_alias(ta, resolved, typed, diags) }
        is AST.ConstDecl as cd   -> { declare_const(cd, resolved, typed, diags) }
        // ImplDecl → ImplRegistry (Phase 2.4). AssertDecl → comptime only.
        // ImportDecl was wired by the resolver. No-op here for all three.
        is AST.ImplDecl   -> {}
        is AST.AssertDecl -> {}
        is AST.ImportDecl -> {}
    }
}

/// Shared minter for Struct / Trait decls — they only differ in the
/// `Type` constructor (`mk_struct` vs `mk_trait`). Mints one fresh
/// TypeParam Symbol per declared `[T]` so the resulting Type renders
/// as `Foo(T)` rather than `Foo(?)`. The resolver mints type-params in
/// the body-walker scope ; we re-mint here because they're not exposed
/// at the top-level symbol table.
declare_named_with_args :: fn(
    name: string, name_span: Span, type_params: AST.TypeParam[],
    by_name: MutableMap<string, Symbol>, typed: TypedProgram,
    module_path: string, factory: SymbolFactory,
    mk: fn(Symbol, Type[]) -> Type,
) -> void {
    sym :: by_name[name]
    if sym is null { return }
    args: Type[] = []
    for tp in type_params {
        tp_sym :: factory.make(.TypeParam, tp.name, module_path, .Private, tp.span)
        args.push(mk_type_param(tp_sym))
    }
    typed.decl_types[sym.id] = mk(sym, args)
}

// ---- per-decl declarers ---------------------------------------------------

declare_fn :: fn(
    decl: AST.FnDecl, by_name: MutableMap<string, Symbol>,
    resolved: ResolvedModule, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    params: Type[] = []
    for p in decl.params {
        params.push(declare_fn_param(p, resolved, typed, diags))
    }
    return_type :: declare_fn_return(decl, resolved, diags)
    // For overloaded fns, `by_name[fn_name]` returns only ONE symbol.
    // Match by span so each overload gets its own decl_types entry.
    sym :: lookup_fn_symbol_by_span(decl, resolved, by_name)
    match sym {
        is null -> {}
        is Symbol as s -> {
            typed.decl_types[s.id] = mk_fn(params, return_type)
            typed.fn_decls[s.id] = decl
        }
    }
    if decl.name == "main" { check_main_signature(decl, params, return_type, diags) }
    if has_extern_decorator(decl.decorators) {
        validate_extern(decl, params, return_type, typed, diags)
    }
    check_public_return_visibility(decl, return_type, diags)
}

// ---- T3052 : private type in a public interface ---------------------------

// Fire T3052 when an `export`ed fn's return type names a type that isn't
// itself exported — a caller in another module receives a value of a type it
// can't name. Mirrors Rust's E0446 (`private_interfaces`). v1 covers return
// types only ; params / exported struct fields / type-alias RHS are a planned
// follow-up (see TODO §"Reject private types in a public signature").
check_public_return_visibility :: fn(decl: AST.FnDecl, return_type: Type, diags: Diagnostic[]) -> void {
    if decl.visibility != Visibility.Public { return }
    leak :: first_unexported_type(return_type)
    if leak == null { return }
    ret_span: Span = decl.span
    if decl.return_type != null { ret_span = decl.return_type.span }
    diags.push(typecheck_error(.PrivateTypeInPublicInterface, ret_span,
        "exported `${decl.name}` returns `${leak.name}`, which is not exported from its module ; export `${leak.name}` or make `${decl.name}` private"))
}

// First non-exported user type referenced anywhere in `t`, or null when the
// whole type is nameable across the module boundary. Exhaustive over the
// closed `Type` union (no `_` fall-through) so adding a new symbol-carrying
// variant trips T3013 here and forces a conscious decision ; every type that
// carries no nameable symbol (primitives, type-params, `Self`, the
// erasure/inference synthetics) is a leaf that contributes nothing → null.
first_unexported_type :: fn(t: Type) -> Symbol | null {
    match t {
        is StructType as s -> {
            if is_private_user_type(s.symbol) { return s.symbol }
            return first_unexported_in(s.args)
        }
        is EnumType as e -> {
            // EnumType carries no generic args today ; if parametric enums land,
            // recurse into them here like StructType / TraitType.
            if is_private_user_type(e.symbol) { return e.symbol }
            return null
        }
        is TraitType as tr -> {
            if is_private_user_type(tr.symbol) { return tr.symbol }
            return first_unexported_in(tr.args)
        }
        is UnionType    as u -> { return first_unexported_in(u.variants) }
        is ArrayType    as a -> { return first_unexported_type(a.element) }
        is TupleType    as p -> { return first_unexported_in(p.elements) }
        is FnType       as f -> {
            in_params :: first_unexported_in(f.params)
            if in_params != null { return in_params }
            return first_unexported_type(f.return_type)
        }
        is PrimitiveType  -> { return null }
        is TypeParamType  -> { return null }
        is TypeMetaType   -> { return null }
        is SelfType       -> { return null }
        is UnresolvedType -> { return null }
        is FreeIntType    -> { return null }
        is FreeFloatType  -> { return null }
        is NeverType      -> { return null }
        is AnyType        -> { return null }
    }
}

first_unexported_in :: fn(types: Type[]) -> Symbol | null {
    for t in types {
        r :: first_unexported_type(t)
        if r != null { return r }
    }
    return null
}

is_private_user_type :: fn(sym: Symbol) -> bool {
    if sym.visibility != Visibility.Private { return false }
    return is_user_type_kind(sym.kind)
}

is_user_type_kind :: fn(k: SymbolKind) -> bool {
    if k == .Struct    { return true }
    if k == .Enum      { return true }
    if k == .Trait     { return true }
    if k == .TypeAlias { return true }
    return false
}

// ---- @extern ABI validation -----------------------------------------------

validate_extern :: fn(
    decl: AST.FnDecl, params: Type[], return_type: Type,
    typed: TypedProgram, diags: Diagnostic[],
) -> void {
    if !(decl.body is null) {
        diags.push(typecheck_error(.ExternMustNotHaveBody, decl.body.span,
            "`@extern` fn `${decl.name}` cannot have a body — drop the `= ...` / `{ ... }`"))
    }
    args :: extern_decorator_args(decl.decorators)
    if args.len() > usize(2) {
        diags.push(typecheck_error(.InvalidExternDecl, decl.span,
            "`@extern` accepts 0, 1, or 2 string arguments — got ${args.len()}"))
        return
    }
    for a in args {
        if !is_plain_string_literal(a) {
            diags.push(typecheck_error(.InvalidExternDecl, a.span,
                "`@extern` arguments must be plain string literals (no interpolation)"))
        }
    }
    for i in 0..<decl.params.len() {
        pt :: params[i]
        if !is_extern_abi_type(pt, false) {
            diags.push(typecheck_error(.InvalidExternDecl, decl.params[i].span,
                "`@extern` parameter type must be a primitive or `string`, got `${display_type(pt)}`"))
        }
    }
    if !is_extern_abi_type(return_type, true) {
        ret_span: Span = decl.span
        if !(decl.return_type is null) { ret_span = decl.return_type.span }
        diags.push(typecheck_error(.InvalidExternDecl, ret_span,
            "`@extern` return type must be a primitive, `string`, or `void`, got `${display_type(return_type)}`"))
    }
    sym_name :: extern_symbol_name_for(decl)
    prior :: typed.extern_symbols[sym_name]
    if prior is AST.FnDecl as p {
        if p.id != decl.id {
            diags.push(typecheck_error(.InvalidExternDecl, decl.span,
                "duplicate `@extern` C symbol `${sym_name}` — already declared on `${p.name}`"))
        }
    } else {
        typed.extern_symbols[sym_name] = decl
    }
}

has_extern_decorator :: fn(decs: AST.Decorator[]) -> bool {
    for d in decs { if d.name == "extern" { return true } }
    return false
}

extern_decorator_args :: fn(decs: AST.Decorator[]) -> AST.Expr[] {
    for d in decs { if d.name == "extern" { return d.args } }
    return []
}

is_plain_string_literal :: fn(e: AST.Expr) -> bool {
    if !(e is AST.StringLitExpr) { return false }
    if e.parts.len() != usize(1) { return false }
    return e.parts[0] is AST.StringLitText
}

/// `@extern("c_name")` override reader — falls back to the source fn
/// name. Last string arg is the C symbol (2-arg form reserves the
/// first slot for a future WASM module hint).
///
/// Distinct from `vader/midir/build.vader::extern_symbol_name` (which
/// reads the **first** arg) : that helper runs post-lowering on the
/// `LoweredFnDecl` shape and predates the 2-arg form ; both should
/// converge on this last-arg convention once midir is rebased.
extern_symbol_name_for :: fn(decl: AST.FnDecl) -> string {
    for d in decl.decorators {
        if d.name != "extern" { continue }
        if d.args.len() == usize(0) { continue }
        last :: d.args[d.args.len() - usize(1)]
        if last is AST.StringLitExpr as s {
            if s.parts.len() == usize(1) {
                if s.parts[0] is AST.StringLitText as t { return t.value }
            }
        }
    }
    return decl.name
}

/// C-ABI type whitelist : primitives + `string`. `void` allowed only in
/// return position (the caller passes `allow_void = true` for return types).
/// `null` is rejected everywhere — it's not a marshallable value.
is_extern_abi_type :: fn(t: Type, allow_void: bool) -> bool {
    match t {
        is UnresolvedType -> { return true }       // upstream error, don't pile on
        is PrimitiveType as p -> {
            if p.name == "void" { return allow_void }
            if p.name == "null" { return false }
            return true
        }
        _ -> { return false }
    }
}

lookup_fn_symbol_by_span :: fn(
    decl: AST.FnDecl, resolved: ResolvedModule,
    by_name: MutableMap<string, Symbol>,
) -> Symbol | null {
    bucket :: resolved.fn_overloads[decl.name]
    match bucket {
        is null -> {}
        _ -> {
            for s in bucket {
                sp :: s.defined_at
                if sp is null { continue }
                // Match the file too : two overloads at the same (line, column)
                // in DIFFERENT sibling files of a module would otherwise collide,
                // and the second's decl_types entry would never be written (the
                // file-blind hazard `span_key` already folds the file hash for).
                if sp.start.line == decl.name_span.start.line &&
                   sp.start.column == decl.name_span.start.column &&
                   sp.start.file == decl.name_span.start.file {
                    return s
                }
            }
        }
    }
    return by_name[decl.name]
}

// `main` must return i32 and either take no params or a single
// `[string]` arg — emitters wire the entry point assuming both.
check_main_signature :: fn(
    decl: AST.FnDecl, params: Type[], return_type: Type, diags: Diagnostic[],
) -> void {
    if !is_primitive_named(return_type, "i32") {
        diags.push(typecheck_error(.InvalidMainSignature, decl.span,
            "main must return i32"))
        return
    }
    if params.len() == 0 { return }
    if params.len() == 1 {
        match params[0] {
            is ArrayType as a -> {
                if is_primitive_named(a.element, "string") { return }
            }
            _ -> {}
        }
    }
    diags.push(typecheck_error(.InvalidMainSignature, decl.span,
        "main takes either no parameters or a single `[string]` argument"))
}

is_primitive_named :: fn(t: Type, name: string) -> bool {
    match t {
        is PrimitiveType as p -> { return p.name == name }
        _ -> { return false }
    }
}

declare_fn_param :: fn(
    p: AST.FnParam, resolved: ResolvedModule, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    ty :: p.ty
    match ty {
        is null -> {
            // SPEC §4 : top-level fn signatures must be fully annotated, except
            // `self` which carries the implicit `Self` type, bound at body time.
            if p.name == "self" { return TY_UNRESOLVED }
            diags.push(typecheck_error(.FnSignatureMustBeAnnotated, p.span,
                "parameter ${p.name} lacks a type"))
            return TY_UNRESOLVED
        }
        _ -> {
            resolved_ty :: type_from_expr(ty, resolved, diags)
            typed.param_types[p.span.hash()] = resolved_ty
            return resolved_ty
        }
    }
}

declare_fn_return :: fn(
    decl: AST.FnDecl, resolved: ResolvedModule, diags: Diagnostic[],
) -> Type {
    rt :: decl.return_type
    match rt {
        is null -> {
            // Expression-bodied without annotation : inference defers to body
            // checking. Block-bodied without annotation : default to void.
            if decl.is_expression_bodied { return TY_UNRESOLVED }
            return TY_VOID
        }
        _ -> { return type_from_expr(rt, resolved, diags) }
    }
}

declare_enum :: fn(
    decl: AST.EnumDecl, by_name: MutableMap<string, Symbol>,
    resolved: ResolvedModule, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    sym :: by_name[decl.name]
    repr :: resolve_repr(decl.repr, resolved, diags)
    indices :: resolve_enum_indices(decl, repr, diags)
    match sym {
        is null -> {}
        is Symbol as s -> {
            enum_type :: mk_enum(s, repr, indices)
            typed.decl_types[s.id] = enum_type
            // Also expose the `EnumType` on the resolver's type side-table so
            // a type-position reference (`d: Direction`) resolves to the enum
            // — `resolve_named_type` reads `alias_types` before falling to the
            // `type_from_symbol` `.Enum -> mk_struct` placeholder, and
            // `merge_external_alias_types` propagates it cross-module. Without
            // this an enum slot stays a `StructType` and the bytecode emit
            // mints a `ref` instead of collapsing to the `repr` ordinal.
            resolved.alias_types[s.id] = enum_type
        }
    }
}

declare_type_alias :: fn(
    decl: AST.TypeAliasDecl, resolved: ResolvedModule, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    aliased :: type_from_expr(decl.aliased, resolved, diags)
    // Index by alias symbol id ; `decl_types` and `alias_types` share
    // the key so use sites get the expanded union.
    for s in resolved.symbols {
        if s.name == decl.name {
            typed.decl_types[s.id] = aliased
            resolved.alias_types[s.id] = aliased
            resolved.alias_decls[s.id] = decl
        }
    }
}

import "vader/parser" { TypeAliasDecl }

declare_const :: fn(
    decl: AST.ConstDecl, resolved: ResolvedModule, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    sym :: lookup_sym_by_name(resolved, decl.name)
    if sym is null { return }
    annotation :: decl.ty
    match annotation {
        is null -> {
            if is_type_position_value(decl.value, resolved) {
                alias_ty :: type_from_expr(decl.value, resolved, diags)
                resolved.alias_types[sym.id] = alias_ty
                typed.decl_types[sym.id] = TY_TYPE
            }
        }
        _ -> { typed.decl_types[sym.id] = type_from_expr(annotation, resolved, diags) }
    }
}

lookup_sym_by_name :: fn(resolved: ResolvedModule, name: string) -> Symbol | null {
    for s in resolved.symbols { if s.name == name { return s } }
    return null
}

is_type_position_value :: fn(e: AST.Expr, resolved: ResolvedModule) -> bool {
    if e is AST.IdentExpr {
        if !(primitive_from_name(e.name) is null) { return true }
        sym :: resolved.idents[e.span.hash()]
        if sym is null { return false }
        match sym.kind {
            .Struct -> { return true }
            .Trait  -> { return true }
            .Enum   -> { return true }
            .TypeAlias   -> { return true }
            .TypeParam   -> { return true }
            .BuiltinType -> { return true }
            _ -> { return false }
        }
    }
    if e is AST.BinaryExpr {
        if i32(e.op) == i32(AST.BinaryOp.BitOr) {
            return is_type_position_value(e.left, resolved) && is_type_position_value(e.right, resolved)
        }
    }
    if e is AST.GenericInstExpr { return true }
    if e is AST.FnTypeExpr { return true }
    if e is AST.ArrayTypeExpr { return true }
    return false
}

import "vader/types" { TY_TYPE }

// ---- helpers --------------------------------------------------------------

resolve_repr :: fn(
    repr: AST.TypeExpr | null, resolved: ResolvedModule, diags: Diagnostic[],
) -> string {
    if repr is null { return "i32" }
    repr_ty :: type_from_expr(repr, resolved, diags)
    match repr_ty {
        is PrimitiveType as p -> {
            if is_int_name(p.name) { return p.name }
            diags.push(typecheck_error(.EnumReprMustBePrimitiveInt, repr.span,
                "got ${p.name}"))
            return "i32"
        }
        _ -> {
            diags.push(typecheck_error(.EnumReprMustBePrimitiveInt, repr.span,
                "got ${display_type(repr_ty)}"))
            return "i32"
        }
    }
}


// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver" { resolve_module }
import "vader/resolver/symbol" { new_factory }

// Resolve `src`, declare-types, then look up the type of the decl
// named `name` by rendering its `display_type`. Returns `<missing>` if
// the decl never landed in `decl_types`.
declared_type :: fn(src: string, name: string) -> string {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    typed :: new_typed_program(rm)
    diags: Diagnostic[] = []
    declare_module(parsed.program.decls, rm, typed, factory, diags)
    for s in rm.symbols {
        if s.name != name { continue }
        ty :: typed.decl_types[s.id]
        if ty is null { return "<missing>" }
        return display_type(ty)
    }
    return "<unknown name>"
}

@test
test_declare_fn_records_signature :: fn() -> void {
    assert_eq(
        declared_type("add :: fn(a: i32, b: i32) -> i32 { return a + b }", "add"),
        "fn(i32, i32) -> i32",
    )
}

@test
test_declare_fn_void_return_when_no_annotation :: fn() -> void {
    assert_eq(declared_type("greet :: fn(name: string) { }", "greet"), "fn(string) -> void")
}

@test
test_declare_struct_records_struct_type :: fn() -> void {
    src :: """
Point :: struct {
    x: i32
    y: i32
}
"""
    assert_eq(declared_type(src, "Point"), "Point")
}

@test
test_declare_generic_struct_records_args :: fn() -> void {
    src :: """
Wrap :: struct<T> {
    value: T
}
"""
    assert_eq(declared_type(src, "Wrap"), "Wrap<T>")
}

@test
test_declare_enum_records_enum_type :: fn() -> void {
    src :: """
Color :: enum {
    Red
    Green
    Blue
}
"""
    assert_eq(declared_type(src, "Color"), "Color")
}

@test
test_declare_type_alias_records_aliased :: fn() -> void {
    // Resolver binds the alias's `<T>` type-params before walking the
    // body, so `T` resolves to its TypeParam symbol. The
    // canonical-union sort puts `null` before `T` alphabetically.
    assert_eq(declared_type("Maybe<T> :: T | null", "Maybe"), "null | T")
}

@test
test_declare_const_with_annotation_records_type :: fn() -> void {
    assert_eq(declared_type("PI: f64 :: 3.14", "PI"), "f64")
}
