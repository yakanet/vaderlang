// vader/typecheck/field — FieldExpr inference (`obj.f`).
//
// `infer_field` recursively checks the target, then runs a priority-ordered
// chain of `try_*` dispatchers and returns the first non-null result :
//   - namespace-import field access (`mod.foo`),
//   - array methods ; impl-method / free-fn / trait-method UFCS dispatch ;
//     bounded-TypeParam trait dispatch,
//   - tuple positional index ; discriminated-union common-field access ;
//     enum-variant dot access (`Color.Red`),
//   - struct field lookup (the terminal fallback), with generic-arg
//     substitution so a field typed `T` resolves to the receiver's
//     concrete arg (`substitute_struct_field`).
// `resolve_struct_field` emits T3009 (missing field) / T3008 (non-struct
// target) when nothing matches.

module "vader/typecheck"

import "std/string" { join }
import "vader/diagnostics" { Diagnostic, Span, typecheck_error }
AST :: import "vader/parser"
import "vader/resolver" { ResolvedModule }
import "vader/types" {
    Type, ArrayType, EnumType, PrimitiveType, StructType, TraitType, TupleType, UnionType, UnresolvedType,
    FreeIntType, FreeFloatType, FreeCharType,
    display_type, type_base_name, TY_UNRESOLVED,
}

/// Type-check a `FieldExpr`. Chains the per-target-shape attempts in
/// priority order ; each `try_*` returns `Type | null` (null = "not
/// my case"). `try_struct_field` is the terminal fallback that emits
/// T3008/T3009 when nothing matches.
export infer_field :: fn(
    e: AST.FieldExpr, typed: TypedProgram, diags: Diagnostic[],
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    // Namespace-import field access — `mod.foo` where `mod` is an
    // import binding. Runs before the recursive target check.
    ns_lookup :: try_namespace_field(e, typed)
    match ns_lookup {
        is null -> {}
        _ -> { return ns_lookup }
    }
    target_ty :: check_expr_fn(e.target, null, typed, diags)
    if target_ty is UnresolvedType { return TY_UNRESOLVED }

    candidate: Type | null = null
    candidate = try_array_method_dispatch(target_ty, e)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_impl_method_ufcs(target_ty, e, typed, diags)
    match candidate { is null -> {} _ -> { return candidate } }
    // Bounded TypeParam dispatch runs BEFORE free-fn UFCS : a free fn
    // whose first param accepts the TypeParam wildcard would otherwise
    // hijack the dispatch instead of routing through the type-param's
    // trait bound.
    candidate = try_typeparam_bound_method(target_ty, e, typed)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_free_fn_ufcs_dispatch(target_ty, e, typed)
    match candidate {
        is null -> {}
        _ -> {
            repin_free_ufcs_receiver(target_ty, e, typed, check_expr_fn)
            return candidate
        }
    }
    candidate = try_trait_method_dispatch(target_ty, e, typed)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_default_trait_method_dispatch(target_ty, e, typed)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_tuple_index_dispatch(target_ty, e, diags)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_union_common_field_dispatch(target_ty, e, typed, diags)
    match candidate { is null -> {} _ -> { return candidate } }
    candidate = try_enum_variant_dispatch(target_ty, e, diags)
    match candidate { is null -> {} _ -> { return candidate } }
    return resolve_struct_field(target_ty, e, typed, diags)
}

// ---- per-target-shape dispatch fns ---------------------------------------
//
// Each `try_*` returns null when the target_ty kind doesn't match its
// shape, or when the shape matches but the lookup yielded nothing.
// Splitting `infer_field`'s cascade into these tiny fns keeps each C
// body bounded instead of the original 40 k-line monster.

try_array_method_dispatch :: fn(target_ty: Type, e: AST.FieldExpr) -> Type | null {
    if !(target_ty is ArrayType) { return null }
    return array_method_type(e.field, target_ty)
}

// `x.method()` where `<x-type> implements <Trait> { method :: ... }`.
// Indexed by orchestrate.vader at impl-load time. Try exact display
// first, then fall back to the base-name key + substitute the impl's
// type-params against the receiver's concrete args.
try_impl_method_ufcs :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram, diags: Diagnostic[],
) -> Type | null {
    impl_ufcs :: typed.impl_methods["${display_type(target_ty)}::${e.field}"]
    match impl_ufcs {
        is null -> {}
        _ -> {
            check_trait_ambiguity(e, target_ty, typed, diags)
            return impl_ufcs
        }
    }
    base_impl :: typed.impl_methods["${type_base_name(target_ty)}::${e.field}"]
    if base_impl == null { return null }
    check_trait_ambiguity(e, target_ty, typed, diags)
    return substitute_impl_method(base_impl, target_ty, typed)
}

try_typeparam_bound_method :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram,
) -> Type | null {
    if !(target_ty is TypeParamType) { return null }
    bound :: typed.resolved.type_param_bounds[target_ty.symbol.id]
    if bound is null { return null }
    // Find the trait carrying `e.field` AND record its name so the
    // lower can emit `vcall Trait.method` once the receiver gets
    // erased to Any post-monomorphization.
    trait_name :: dispatch_bounded_method_trait(bound, e.field, typed)
    if trait_name == "" { return null }
    typed.bounded_dispatch_trait[e.id] = trait_name
    // Attribute the dispatch to the enclosing fn so the lowerer keeps its
    // generic instances concrete (no Any-erasure) — see `fn_trait_dispatches`.
    if typed.current_fn_ctx is FnContext as fctx {
        if fctx.fn_id != 0 { typed.fn_trait_dispatches[fctx.fn_id] = true }
    }
    tm :: dispatch_bounded_method(bound, e.field, typed)
    if tm is null { return null }
    return substitute_self(tm, target_ty)
}

// Variant of `dispatch_bounded_method` that returns the trait NAME
// instead of the method type. Same walk over `A & B` intersections.
dispatch_bounded_method_trait :: fn(
    bound: AST.Expr, name: string, typed: TypedProgram,
) -> string {
    if bound is AST.BinaryExpr {
        if bound.op == AST.BinaryOp.BitAnd {
            l :: dispatch_bounded_method_trait(bound.left, name, typed)
            if l != "" { return l }
            return dispatch_bounded_method_trait(bound.right, name, typed)
        }
    }
    bound_ty :: type_from_expr(bound, typed.resolved, [])
    if bound_ty is TraitType as tt {
        if try_trait_method(bound_ty, name, typed) is null { return "" }
        return tt.symbol.name
    }
    return ""
}

// `x.foo()` dispatching to a free fn `foo` whose first param accepts
// `target_ty`. Walks the local module's `fn_overloads` bucket and
// returns the curried fn type (receiver stripped). Records the
// receiver type in `ufcs_receiver_types` for the call-site lowerer.
try_free_fn_ufcs_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram,
) -> Type | null {
    free_ufcs :: try_free_fn_ufcs_with_first(e.field, target_ty, typed)
    if free_ufcs == null { return null }
    typed.ufcs_receiver_types[e.id] = free_ufcs.first_param
    return free_ufcs.curried
}

// When a free-numeric receiver resolves to a free-fn UFCS call, re-pin it to
// the fn's first-param type (just recorded in `ufcs_receiver_types`) so it
// lowers AS that type — mirrors how a regular call pins its args to the param
// types (call.vader). Without this, `50.millis()` types the receiver as a free
// int, lowers it as i32, and the lowerer can't match `millis`'s i64 first param
// (→ midir panic, see bug_ufcs_primitive_literal_freefn).
repin_free_ufcs_receiver :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> void {
    if !(target_ty is FreeIntType || target_ty is FreeFloatType || target_ty is FreeCharType) { return }
    first_param :: typed.ufcs_receiver_types[e.id]
    if first_param == null { return }
    // Re-check the receiver with the first-param type as `expected` — pins the
    // free literal (propagating to sub-expressions) by recording its pinned
    // type in `expr_types`. Diagnostics already fired on the first
    // (no-expectation) check at infer_field's head, so a fresh `[]` sinks them.
    // The bound result is the pinned receiver type ; we want only the side
    // effect on `expr_types`, so it's bound (not a trailing value-return).
    repinned :: check_expr_fn(e.target, first_param, typed, [])
}

try_trait_method_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram,
) -> Type | null {
    if !(target_ty is TraitType) { return null }
    trait_method :: try_trait_method(target_ty, e.field, typed)
    if trait_method is null { return null }
    return substitute_self(trait_method, target_ty)
}

// Struct that implements a trait carrying a same-named method WITH a
// default body (`Iterator.count` / `Iterator.is_empty`) — synthesise
// the dispatch from the trait method's signature.
try_default_trait_method_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram,
) -> Type | null {
    if !(target_ty is StructType) { return null }
    return try_default_trait_method(target_ty, e.field, typed)
}

// `tup.0` — positional access on tuples. Out-of-range raises T3009.
try_tuple_index_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, diags: Diagnostic[],
) -> Type | null {
    if !(target_ty is TupleType) { return null }
    idx :: parse_tuple_index(e.field)
    if idx < 0 || idx >= target_ty.elements.len() {
        diags.push(typecheck_error(.FieldDoesNotExist, e.field_span,
            "`${e.field}` on ${display_type(target_ty)}"))
        return TY_UNRESOLVED
    }
    return target_ty.elements[idx]
}

try_union_common_field_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram, diags: Diagnostic[],
) -> Type | null {
    if !(target_ty is UnionType) { return null }
    return union_common_field(target_ty, e.field, typed, diags)
}

// `Direction.North` — variant access on the enum type itself.
try_enum_variant_dispatch :: fn(
    target_ty: Type, e: AST.FieldExpr, diags: Diagnostic[],
) -> Type | null {
    if !(target_ty is EnumType) { return null }
    idx :: target_ty.indices[e.field]
    if idx is null {
        diags.push(typecheck_error(.UnknownEnumVariant, e.field_span,
            "`${e.field}` is not a variant of ${display_type(target_ty)}"))
        return TY_UNRESOLVED
    }
    return target_ty
}

// Terminal struct-field lookup + the catch-all diagnostics for any
// other unsupported shape. Returns a real Type (not Type | null)
// since this is the last fallthrough.
resolve_struct_field :: fn(
    target_ty: Type, e: AST.FieldExpr, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    if !(target_ty is StructType) {
        diags.push(typecheck_error(.NotIndexable, e.span,
            "`.${e.field}` on non-struct type ${display_type(target_ty)}"))
        return TY_UNRESOLVED
    }
    decl :: typed.struct_decls[target_ty.symbol.id]
    if decl is null {
        // declare_module didn't index the struct decl (cross-module
        // reference before wire.vader lands, typically).
        return TY_UNRESOLVED
    }
    // T3054 : reject reads (and assignment LHS, which types through here too)
    // of an `@internal` field from outside its declaring module.
    check_internal_field(target_ty, decl, e.field, e.field_span, typed, diags)
    // Cross-module : `struct_field_types` carries already-resolved
    // field types using the OWNING module's resolved.idents.
    pre_resolved :: lookup_pre_resolved_field(target_ty.symbol.id, e.field, typed)
    found: Type | null = pre_resolved
    if found is null {
        found = find_struct_field_type(decl, e.field, typed.resolved, diags)
    }
    if found == null {
        diags.push(typecheck_error(.FieldDoesNotExist, e.field_span,
            "`${e.field}` on ${display_type(target_ty)}"))
        return TY_UNRESOLVED
    }
    substituted :: substitute_struct_field(found, decl, target_ty)
    return narrow_field_if_active(e, substituted, typed)
}

/// Enforce `@internal` field visibility (T3054). A field parsed as
/// `Visibility.Private` (the `@internal` decorator) is readable, writable,
/// constructible, and pattern-bindable only from its declaring module. Fields
/// are public by default, so this fires only for the rare opt-in field.
///
/// Same-module access is always allowed — the test mirrors the established
/// cross-module comparison `sym.module != typed.resolved.path`
/// (`vader/typecheck/expr_ident.vader`). Shared by the read site
/// (`resolve_struct_field`), the construction site (`struct_lit.vader`), and
/// the pattern site (`match_expr.vader`).
///
/// @param st          the struct type whose field is being accessed.
/// @param decl        the struct's AST decl, carrying per-field visibility
///                    (present even for imported structs via
///                    `broadcast_struct_decls`).
/// @param field_name  the field being touched.
/// @param span        where to point the diagnostic.
/// @error             T3054 when `field_name` is `@internal` and the access is
///                    from a different module than `st.symbol.module`.
export check_internal_field :: fn(
    st: StructType, decl: AST.StructDecl, field_name: string,
    span: Span, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    if st.symbol.module == typed.resolved.path { return }
    for field in decl.fields {
        if field.name == field_name {
            if field.visibility == AST.Visibility.Private {
                diags.push(typecheck_error(.InternalFieldAccess, span,
                    "`${field_name}` is `@internal` to module `${st.symbol.module}`"))
            }
            return
        }
    }
}

/// Look up `${root_sym.id}#path` for this FieldExpr's chain in
/// `narrowed_fields` and return that type ; falls through to `declared`
/// when no chain narrowing is active.
narrow_field_if_active :: fn(
    e: AST.FieldExpr, declared: Type, typed: TypedProgram,
) -> Type {
    // Fast path : the common case is no live field narrowings at all,
    // so dodge the chain walk + key build entirely.
    if typed.narrowed_fields.is_empty() { return declared }
    key :: field_chain_key(e, typed)
    if key == "" { return declared }
    return narrow_for_field(typed, key, declared)
}

lookup_pre_resolved_field :: fn(struct_id: i32, name: string, typed: TypedProgram) -> Type | null {
    fmap :: typed.struct_field_types[struct_id]
    if fmap is null { return null }
    return fmap[name]
}

/// Substitute typeParam bindings from `decl.type_params` against
/// `target.args` into `field_ty`. Lets `Node(i32) { value: T }` →
/// `value: i32` instead of leaving `T` raw.
substitute_struct_field :: fn(
    field_ty: Type, decl: AST.StructDecl, target: StructType,
) -> Type {
    if decl.type_params.len() == 0 { return field_ty }
    bindings :: MutableMap<i32, Type> {}
    n :: min(decl.type_params.len(), target.args.len())
    for i in 0..<n {
        tp :: decl.type_params[i]
        // The struct's TypeParam Symbol id was minted in decl.vader
        // when the StructType was built. We can't recover it from
        // the AST alone, so we match on name : decl.vader's
        // declare_named_with_args mints a fresh TypeParam Symbol per
        // `tp.name` and stamps it into `target.args[i]` via
        // `mk_type_param`. The Sym id we want lives in target.args[i].
        match target.args[i] {
            is TypeParamType as tpt -> { bindings[tpt.symbol.id] = target.args[i] }
            _ -> {}
        }
        // Build a name→type bindings map so unify_by_name can match
        // the field's raw `T` reference (TypeParam from decl.vader's
        // mint) against `target.args[i]`.
    }
    // Walk the field type and rewrite any TypeParam whose name
    // matches one of the struct's typeParams.
    return substitute_by_name(field_ty, decl.type_params, target.args)
}

export substitute_by_name :: fn(
    t: Type, tps: AST.TypeParam[], args: Type[],
) -> Type {
    // @partial: only TypeParam and the composite variants can carry a param to
    // rewrite; every scalar / primitive variant has no inner type → return as-is.
    @partial match t {
        is TypeParamType as tp -> {
            for i in 0..<min(tps.len(), args.len()) {
                if tps[i].name == tp.symbol.name { return args[i] }
            }
            return t
        }
        is ArrayType as a -> {
            return mk_array(substitute_by_name(a.element, tps, args), a.immutable)
        }
        is TupleType as tu -> {
            els: Type[] = []
            for el in tu.elements { els.push(substitute_by_name(el, tps, args)) }
            return mk_tuple(els)
        }
        is StructType as s -> {
            sargs: Type[] = []
            for a in s.args { sargs.push(substitute_by_name(a, tps, args)) }
            return mk_struct(s.symbol, sargs)
        }
        is TraitType as r -> {
            rargs: Type[] = []
            for a in r.args { rargs.push(substitute_by_name(a, tps, args)) }
            return mk_trait(r.symbol, rargs)
        }
        is UnionType as u -> {
            vs: Type[] = []
            for v in u.variants { vs.push(substitute_by_name(v, tps, args)) }
            return union_of(vs)
        }
        is FnType as f -> {
            ps: Type[] = []
            for p in f.params { ps.push(substitute_by_name(p, tps, args)) }
            return mk_fn(ps, substitute_by_name(f.return_type, tps, args))
        }
        _ -> { return t }
    }
}

import "std/collections" { MutableMap }
import "std/math" { min }
import "vader/types" {
    FnType, TypeParamType,
    mk_array, mk_fn, mk_struct, mk_trait, mk_tuple, mk_union,
}
import "vader/types" { mk_primitive, TY_VOID }

/// MVP UFCS dispatch for the canonical array methods. Returns the
/// per-method `FnType` synthesised from the element type, or `null`
/// when the method isn't a known array method. Mirrors the stdlib
/// `T[]` free fns the lowerer wires in :
///   - `len()`               → `usize`
///   - `push(T)`             → `void`
///   - `push_all(const T[])` → `void`
///   - `copy_to(...)`        → `void`
///   - `remove_last()`       → `T | null`
///   - `clear()`            → `void`
array_method_type :: fn(name: string, arr: ArrayType) -> Type | null {
    // The ops with dedicated lowering are typed here : `len` / `push` lower to
    // `LoweredArrayLen` / `LoweredArrayPush`, and `push_all` / `copy_to` /
    // `remove_last` / `clear` lower to `LoweredIntrinsicCall`s backed by
    // parameterless bytecode ops (`lower_call.vader::try_lower_array_op`). None
    // have a free-fn / trait fallback, so the typer must supply their signature.
    //
    // Everything else resolves elsewhere (import required, per the UFCS policy) :
    // `is_empty` ⟶ `std/iter::is_empty(arr: T[])`, `slice` ⟶ `std/iter::slice`,
    // `contains` ⟶ the `Contains` trait, `reverse`/`first`/`last` ⟶ std/iter free
    // fns.
    if name == "len"  { return mk_fn([], mk_primitive("usize")) }
    if name == "push" { return mk_fn([arr.element], TY_VOID) }
    // `push_all` reads its source, so a `const T[]` param accepts both a
    // mutable and a borrowed source (mirrors `std/iter::clone`).
    if name == "push_all" { return mk_fn([mk_array(arr.element, true)], TY_VOID) }
    // `copy_to(src_start, dst, dst_start, len)` — `dst` is written, so it must
    // be a mutable `T[]` ; the three cursors are `usize`.
    if name == "copy_to" {
        usize_t :: mk_primitive("usize")
        return mk_fn([usize_t, mk_array(arr.element, false), usize_t, usize_t], TY_VOID)
    }
    if name == "remove_last" { return mk_fn([], mk_union([arr.element, mk_primitive("null")])) }
    if name == "clear" { return mk_fn([], TY_VOID) }
    return null
}

/// The names of the built-in array methods, in declaration order. Single source
/// of truth for both `array_method_type` (which signs each) and
/// `array_builtin_methods` (which enumerates them for completion).
ARRAY_METHOD_NAMES: const string[]: [
    "len", "push", "push_all", "copy_to", "remove_last", "clear",
]

// The methods that mutate the receiver — rejected on an `immutable` array, so
// completion drops them on a borrowed view (`s.bytes()` → `const u8[]`).
array_method_mutates :: fn(name: string) -> bool =
    name == "push" || name == "push_all" || name == "remove_last" || name == "clear"

/// A built-in array method surfaced for completion — its name plus the resolved
/// signature (`array_method_type`'s result). LSP member completion lists these :
/// they're neither free fns nor `impl` members, so no other path enumerates them.
export ArrayBuiltinMethod :: struct {
    name:      string
    signature: Type
}

/// Every built-in method callable on `arr` via UFCS (`len`, `push`, …), each
/// with its resolved signature. Mirrors exactly what `array_method_type`
/// resolves ; the mutating subset is omitted when `arr.immutable`.
///
/// @param arr  the receiver array type (its `element` / `immutable` drive the
///             signatures and the mutating-method filter).
/// @return     the available built-in methods, in declaration order.
export array_builtin_methods :: fn(arr: ArrayType) -> ArrayBuiltinMethod[] {
    out: ArrayBuiltinMethod[] = []
    for name in ARRAY_METHOD_NAMES {
        if arr.immutable && array_method_mutates(name) { continue }
        sig :: array_method_type(name, arr)
        if sig == null { continue }
        out.push(ArrayBuiltinMethod { .name = name, .signature = sig })
    }
    return out
}

/// MVP UFCS for the canonical primitive (string / char) methods.
/// Mirrors the stdlib `T` free fns the lowerer wires in.
///
/// MID-REORG : this hardcoded string/char surface is being retired. The typer
/// claims these methods but the lowerer reaches them only via free-fn UFCS over
/// loaded modules, so any entry whose impl isn't loaded miscompiles. `len` was
/// the first removed — it lives in `std/core` (the prelude) now. The remaining
/// string/char entries move to `std/string` / `std/char` (import-required) or
/// get implemented/dropped per .claude/plans/core-string-utf8-reorg.md.
import "vader/resolver/symbol" { Symbol }

/// When `e.target` is an `IdentExpr` resolving to a namespace
/// `ImportBinding`, look up `e.field` in the target module's
/// exports and return its declared type. Returns null when the
/// pattern doesn't match (caller falls through to the struct-field
/// path).
// `s.foo()` where `foo` is a free fn whose first param accepts `s`'s
// type. Walks `resolved.fn_overloads[foo]` and returns the curried
// `FnType` (receiver stripped) of the first overload whose first
// param accepts `s`. Null when no overload matches.
// Emit T3032 when two distinct traits both provide `e.field` on
// `target_ty`. The impl_method dispatch picks one silently ; this
// hook surfaces the ambiguity instead of letting it bite later.
check_trait_ambiguity :: fn(
    e: AST.FieldExpr, target_ty: Type, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    base_key :: "${type_base_name(target_ty)}::${e.field}"
    traits :: typed.impl_method_traits[base_key]
    if traits is null { return }
    if traits.len() < 2 { return }
    diags.push(typecheck_error(.AmbiguousOverload, e.field_span,
        "`${e.field}` on ${display_type(target_ty)} is ambiguous between traits: ${traits.join(", ")}"))
}

// Substitute the impl method's TypeParams against the receiver's
// concrete type args. Lets `MutableSet[T] implements ... { contains
// :: fn(self, value: T) -> bool }` produce `fn(i32) -> bool` when
// called on `MutableSet(i32)`.
substitute_impl_method :: fn(impl_ty: Type, target_ty: Type, typed: TypedProgram) -> Type {
    if !(target_ty is StructType) { return impl_ty }
    decl :: typed.struct_decls[target_ty.symbol.id]
    if decl is null { return impl_ty }
    return substitute_by_name(impl_ty, decl.type_params, target_ty.args)
}

// `u.field` where `u: V1 | V2 | …`. Returns the union of each
// variant's `.field` type when every variant carries it ; null when
// any variant lacks the field (caller falls through to T3009).
union_common_field :: fn(
    u: UnionType, name: string, typed: TypedProgram, diags: Diagnostic[],
) -> Type | null {
    types: Type[] = []
    for v in u.variants {
        if !(v is StructType) { return null }
        decl :: typed.struct_decls[v.symbol.id]
        if decl is null { return null }
        ty :: find_struct_field_type(decl, name, typed.resolved, diags)
        if ty is null { return null }
        types.push(substitute_struct_field(ty, decl, v))
    }
    return union_of(types)
}

// Replace every `SelfType` in `t` with `self_ty`. Used to specialise
// trait-method signatures at the receiver's type (`fn(Self) -> Self`
// → `fn(T) -> T` when called on a `T`).
substitute_self :: fn(t: Type, self_ty: Type) -> Type {
    // @partial: only SelfType and the composite variants can contain a `Self`
    // leaf; every scalar / primitive variant has no `Self` to replace.
    @partial match t {
        is SelfType -> { return self_ty }
        is ArrayType as a -> { return mk_array(substitute_self(a.element, self_ty), a.immutable) }
        is StructType as s -> {
            args: Type[] = []
            for a in s.args { args.push(substitute_self(a, self_ty)) }
            return mk_struct(s.symbol, args)
        }
        is FnType as f -> {
            ps: Type[] = []
            for p in f.params { ps.push(substitute_self(p, self_ty)) }
            return mk_fn(ps, substitute_self(f.return_type, self_ty))
        }
        is UnionType as u -> {
            vs: Type[] = []
            for v in u.variants { vs.push(substitute_self(v, self_ty)) }
            return union_of(vs)
        }
        is TupleType as t2 -> {
            els: Type[] = []
            for el in t2.elements { els.push(substitute_self(el, self_ty)) }
            return mk_tuple(els)
        }
        _ -> { return t }
    }
}

import "vader/types" { SelfType }

// Walk a TypeParam bound expression (single trait or `A & B` chain)
// and return the first trait whose declared methods include `name`.
dispatch_bounded_method :: fn(
    bound: AST.Expr, name: string, typed: TypedProgram,
) -> Type | null {
    // Intersection : `A & B` — recurse on each side.
    if bound is AST.BinaryExpr {
        if bound.op == AST.BinaryOp.BitAnd {
            l :: dispatch_bounded_method(bound.left, name, typed)
            if !(l is null) { return l }
            return dispatch_bounded_method(bound.right, name, typed)
        }
    }
    bound_ty :: type_from_expr(bound, typed.resolved, [])
    if bound_ty is TraitType {
        return try_trait_method(bound_ty, name, typed)
    }
    return null
}

// `t.method()` where `t: <SomeTrait>`. Looks up the method on the
// trait decl, drops the `self` param, and returns the curried fn
// type. Null when the trait isn't indexed or the method is missing.
/// For a struct receiver, find a trait it implements whose method by
/// the given name has a default (non-empty) body, and return the
/// curried signature with `Self → struct_ty`. Trait type-args aren't
/// recovered (`struct_implemented_traits` only stores trait names),
/// so methods that reference the trait's `T` come back unsubstituted —
/// good enough for std/string's `len = s.chars().count()`
/// where `count :: fn(self) -> usize` doesn't mention `T`.
try_default_trait_method :: fn(
    target_ty: StructType, name: string, typed: TypedProgram,
) -> Type | null {
    trait_names :: typed.struct_implemented_traits[target_ty.symbol.name]
    if trait_names is null { return null }
    for trait_name in trait_names {
        trait_sym :: lookup_trait_symbol(trait_name, typed)
        if trait_sym is null { continue }
        decl :: typed.trait_decls[trait_sym.id]
        if decl is null { continue }
        owner :: typed.trait_decl_owners[trait_sym.id]
        owner_resolved: ResolvedModule = typed.resolved
        match owner {
            is null -> {}
            _ -> { owner_resolved = owner }
        }
        for m in decl.members {
            if m.name != name { continue }
            if m.body is null { continue }     // require default body
            params: Type[] = []
            for i in 1..<m.params.len() {
                p :: m.params[i]
                params.push(type_from_expr_opt_in(p.ty, owner_resolved))
            }
            ret :: type_from_expr_opt_in(m.return_type, owner_resolved)
            // Substitute Self → struct, then trait type-params →
            // recorded impl args. Lets `(0..<5).last()` report
            // `i32 | null` instead of `T | null`.
            sub_self :: substitute_self(mk_fn(params, ret), target_ty)
            return substitute_trait_typeparams(sub_self, decl, trait_name, target_ty, typed)
        }
    }
    return null
}

substitute_trait_typeparams :: fn(
    t: Type, trait_decl: AST.TraitDecl, trait_name: string,
    target_ty: StructType, typed: TypedProgram,
) -> Type {
    if trait_decl.type_params.len() == 0 { return t }
    per_struct :: typed.struct_trait_args[target_ty.symbol.name]
    if per_struct is null { return t }
    impl_args :: per_struct[trait_name]
    if impl_args is null { return t }
    // The impl args might themselves reference TypeParams from the
    // implementing struct (`Range[T] implements Iterator[T]` records
    // `[T]` where T is Range's). Resolve those against the receiver's
    // concrete args first so `(10..=15).last()` ends up `i32 | null`.
    resolved_args: Type[] = []
    struct_decl :: typed.struct_decls[target_ty.symbol.id]
    for a in impl_args {
        if struct_decl is null { resolved_args.push(a) }
        else { resolved_args.push(substitute_by_name(a, struct_decl.type_params, target_ty.args)) }
    }
    return substitute_by_name(t, trait_decl.type_params, resolved_args)
}

lookup_trait_symbol :: fn(name: string, typed: TypedProgram) -> Symbol | null {
    for sym in typed.resolved.symbols {
        if sym.name == name { return sym }
    }
    core :: typed.resolved.core_symbols[name]
    match core {
        is null -> { return null }
        is Symbol as s -> { return s }
    }
}

// Pad a trait's use-site args with declared `<T = Default>` defaults when the
// site (e.g. a `T: Add` bound, which carries no explicit trait-args) supplies
// fewer than the trait declares. A `Self` default resolves to `TY_SELF` here ;
// the caller's `substitute_self(target_ty)` then maps it to the receiver type.
pad_trait_default_args :: fn(
    args: Type[], tps: AST.TypeParam[], resolved: ResolvedModule,
) -> Type[] {
    if args.len() >= tps.len() { return args }
    out: Type[] = [] * tps.len()   // final size is args + filled defaults, ≤ tps.len()
    out.push_all(args)
    for i in args.len()..<tps.len() {
        d :: tps[i].default
        if d is null { break }
        out.push(type_from_expr(d, resolved, []))
    }
    return out
}

try_trait_method :: fn(t: TraitType, name: string, typed: TypedProgram) -> Type | null {
    decl :: typed.trait_decls[t.symbol.id]
    if decl is null { return null }
    // Resolve the trait method's param + return types against the
    // OWNER module's resolved.idents — std/core's `Iterator(T).next`
    // signature references `T` (a Symbol minted during std/core's
    // resolve pass), so typing it against the entry's idents would
    // hand back Unresolved.
    owner :: typed.trait_decl_owners[t.symbol.id]
    owner_resolved: ResolvedModule = typed.resolved
    match owner {
        is null -> {}
        _ -> { owner_resolved = owner }
    }
    for m in decl.members {
        if m.name != name { continue }
        params: Type[] = []
        for i in 1..<m.params.len() {
            p :: m.params[i]
            params.push(type_from_expr_opt_in(p.ty, owner_resolved))
        }
        ret :: type_from_expr_opt_in(m.return_type, owner_resolved)
        padded :: pad_trait_default_args(t.args, decl.type_params, owner_resolved)
        return substitute_by_name(mk_fn(params, ret), decl.type_params, padded)
    }
    return null
}

type_from_expr_opt_in :: fn(e: AST.TypeExpr | null, resolved: ResolvedModule) -> Type {
    if e is null { return TY_VOID }
    return type_from_expr(e, resolved, [])
}

UfcsResult :: struct {
    curried:     Type
    first_param: Type
}

try_free_fn_ufcs_with_first :: fn(
    name: string, target_ty: Type, typed: TypedProgram,
) -> UfcsResult | null {
    bucket :: typed.resolved.fn_overloads[name]
    match bucket {
        is null -> {}
        _ -> {
            for sym in bucket {
                ft :: typed.decl_types[sym.id]
                if ft is null { continue }
                if !(ft is FnType) { continue }
                curried :: try_curry_receiver(ft, target_ty, typed)
                if !(curried is null) {
                    return UfcsResult { .curried = curried, .first_param = ft.params[0] }
                }
            }
        }
    }
    imported :: typed.imported_fn_overloads[name]
    match imported {
        is null -> {}
        _ -> {
            for ft in imported {
                curried :: try_curry_receiver(ft, target_ty, typed)
                if !(curried is null) {
                    return UfcsResult { .curried = curried, .first_param = ft.params[0] }
                }
            }
        }
    }
    return null
}

/// A free function callable on a receiver type via UFCS — its name plus the
/// curried signature (the type after the receiver is bound). Powers LSP member
/// completion, which lists these alongside struct fields and impl methods.
export UfcsMethod :: struct {
    name:    string
    curried: Type
}

/// Every free function callable on `target_ty` via UFCS (first param fits the
/// receiver), deduplicated by name. Enumerates the module's own overloads then
/// the imported ones — the same two buckets `try_free_fn_ufcs_with_first`
/// resolves a single call against, but surfaced as a list for completion.
export ufcs_methods_for :: fn(target_ty: Type, typed: TypedProgram) -> UfcsMethod[] {
    out: UfcsMethod[] = []
    seen :: MutableMap<string, bool> {}
    for [name, bucket] in typed.resolved.fn_overloads {
        for sym in bucket {
            ft :: typed.decl_types[sym.id]
            if ft is null { continue }
            if !(ft is FnType) { continue }
            curried :: try_curry_receiver(ft, target_ty, typed)
            if curried is null { continue }
            if seen[name] != null { continue }
            seen[name] = true
            out.push(UfcsMethod { .name = name, .curried = curried })
            break
        }
    }
    for [name, fts] in typed.imported_fn_overloads {
        if seen[name] != null { continue }
        for ft in fts {
            curried :: try_curry_receiver(ft, target_ty, typed)
            if curried is null { continue }
            seen[name] = true
            out.push(UfcsMethod { .name = name, .curried = curried })
            break
        }
    }
    return out
}

try_curry_receiver :: fn(ft: FnType, target_ty: Type, typed: TypedProgram) -> Type | null {
    if ft.params.len() == 0 { return null }
    // Non-generic fast path : skip the unify+substitute walk for
    // overloads whose first param has no TypeParam (the vast majority
    // of stdlib fns), since `try_free_fn_ufcs_with_first` calls this
    // for every overload in the bucket on every UFCS site.
    if !type_contains_type_param(ft.params[0]) {
        if !receiver_fits_first_param(target_ty, ft.params[0], typed) { return null }
        rest: Type[] = []
        for i in 1..<ft.params.len() { rest.push(ft.params[i]) }
        return mk_fn(rest, ft.return_type)
    }
    bindings :: MutableMap<i32, Type> {}
    unify_type_param(ft.params[0], target_ty, bindings)
    // Default Free* bindings so the curried return type comes back as
    // `i32`/`f64` instead of `{integer}`/`{float}` — same pattern as
    // `infer_call`'s `pinFreeNumericArg` (call.vader:208).
    for k in bindings.keys() {
        v :: bindings[k]
        if v is null { continue }
        bindings[k] = default_if_free(v)
    }
    fitted_first :: substitute_map(ft.params[0], bindings)
    if !receiver_fits_first_param(target_ty, fitted_first, typed) { return null }
    rest: Type[] = []
    for i in 1..<ft.params.len() { rest.push(substitute_map(ft.params[i], bindings)) }
    return mk_fn(rest, substitute_map(ft.return_type, bindings))
}

// A receiver fits a UFCS first-param when (a) direct assignability holds,
// (b) the param is a wildcard TypeParam, or (c) the param is a trait the
// receiver implements.
// Trait widening here covers user `T implements Trait` impls AND
// `Array(T) implements Iterator(T)` (which is hardcoded via `try_array_to_iter`
// because adding it to `is_assignable` bloats c-emit).
receiver_fits_first_param :: fn(target_ty: Type, first: Type, typed: TypedProgram) -> bool {
    if is_assignable(target_ty, first, null) { return true }
    if first is TypeParamType { return true }
    if first is TraitType {
        if try_trait_widen(target_ty, first, typed) { return true }
        if try_array_to_iter(target_ty, first) { return true }
    }
    return false
}

// Parse `0`, `1`, … from a tuple `.N` field name. Returns -1 when
// the name isn't a non-negative integer literal — `.foo` on a tuple
// then falls through to T3009 via the bounds check.
parse_tuple_index :: fn(s: string) -> i32 {
    sb :: s.bytes()
    len :: sb.len()
    if len == 0 { return -1 }
    n: i32 = 0
    for i in 0..<len {
        c :: sb[i]
        if c < u8('0') || c > u8('9') { return -1 }
        n = n * 10 + i32(c - u8('0'))
    }
    return n
}

try_namespace_field :: fn(e: AST.FieldExpr, typed: TypedProgram) -> Type | null {
    mod_id :: namespace_call_mod_id(e, typed)
    if mod_id is null { return null }
    exports :: typed.namespace_exports[mod_id]
    if exports is null { return null }
    return exports[e.field]
}

// Resolve a `mod.field` FieldExpr's base to the imported module id, or null
// when the base isn't a namespace import binding. Shared by `try_namespace_field`
// (value type) and `call.vader::namespace_member_params` (decl params).
namespace_call_mod_id :: fn(e: AST.FieldExpr, typed: TypedProgram) -> string | null {
    target :: e.target
    if !(target is AST.IdentExpr) { return null }
    sym :: typed.resolved.idents[target.span.hash()]
    if sym is null { return null }
    if sym.kind != SymbolKind.ImportBinding { return null }
    targets :: typed.import_targets
    if targets is null { return null }
    return targets.namespace_targets[sym.id]
}

import "vader/resolver/symbol" { SymbolKind }

/// Walk a struct's fields for `name` and return the resolved field type,
/// or `null` if the field doesn't exist. Shared with `struct_lit.vader`
/// so the lookup convention stays in one place — generic substitution,
/// when it lands, plugs in here.
export find_struct_field_type :: fn(
    decl: AST.StructDecl, name: string,
    resolved: ResolvedModule, diags: Diagnostic[],
) -> Type | null {
    for field in decl.fields {
        if field.name == name { return type_from_expr(field.ty, resolved, diags) }
    }
    return null
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver" { resolve_module }
import "vader/resolver/symbol" { new_factory }

// Stub that handles only the variants the field tests touch — Ident
// (for `p` in `p.x`), Field (for nested `obj.a.b`), and Int literals.
field_check_stub :: fn(
    e: AST.Expr, expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    // @partial: test stub — only the ident / field / literal expr kinds the
    // field tests build are typed; every other Expr is irrelevant → unresolved.
    @partial match e {
        is AST.IntLitExpr    as x -> { return infer_int_lit(x) }
        is AST.StringLitExpr as x -> { return infer_string_lit(x) }
        is AST.IdentExpr     as x -> { return infer_ident(x, typed) }
        is AST.FieldExpr     as x -> { return infer_field(x, typed, diags, field_check_stub) }
        _ -> { return TY_UNRESOLVED }
    }
}

accept_field :: fn(e: AST.Expr) -> AST.Expr | null {
    if e is AST.FieldExpr { return e }
    return null
}

FieldFixture :: struct {
    typed: TypedProgram
    field: AST.FieldExpr | null
}

first_field_in_last_fn :: fn(src: string) -> FieldFixture {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    diags: Diagnostic[] = []
    result :: check_module(parsed.program, rm, factory, diags)
    last :: parsed.program.decls[parsed.program.decls.len() - 1]
    if last is AST.FnDecl as f {
        match f.body {
            is null -> { return FieldFixture { .typed = result.typed, .field = null } }
            is AST.BlockExpr as b -> {
                hit :: find_first_in_block(b, accept_field)
                field: AST.FieldExpr | null = null
                if hit is AST.FieldExpr { field = hit }
                return FieldFixture { .typed = result.typed, .field = field }
            }
        }
    }
    return FieldFixture { .typed = result.typed, .field = null }
}

@test
test_field_on_struct_returns_field_type :: fn() -> void {
    src :: """
Point :: struct {
    x: i32
    y: i32
}
get_x :: fn(p: Point) -> i32 { return p.x }
"""
    fx :: first_field_in_last_fn(src)
    match fx.field {
        is null -> { assert(false, "expected a field expr") }
        is AST.FieldExpr as f -> {
            diags: Diagnostic[] = []
            assert_eq(display_type(infer_field(f, fx.typed, diags, field_check_stub)), "i32")
            assert_eq(diags.len(), 0)
        }
    }
}

@test
test_field_missing_emits_T3009 :: fn() -> void {
    src :: """
Point :: struct {
    x: i32
}
get_z :: fn(p: Point) -> i32 { return p.z }
"""
    fx :: first_field_in_last_fn(src)
    match fx.field {
        is null -> { assert(false, "expected a field expr") }
        is AST.FieldExpr as f -> {
            diags: Diagnostic[] = []
            infer_field(f, fx.typed, diags, field_check_stub)
            assert(diags.len() >= 1, "expected a diagnostic")
            assert_eq(diags[0].code.id, "T3009")
        }
    }
}

@test
test_field_on_non_struct_emits_T3008 :: fn() -> void {
    src :: """
f :: fn(n: i32) -> i32 { return n.x }
"""
    fx :: first_field_in_last_fn(src)
    match fx.field {
        is null -> { assert(false, "expected a field expr") }
        is AST.FieldExpr as f -> {
            diags: Diagnostic[] = []
            infer_field(f, fx.typed, diags, field_check_stub)
            assert(diags.len() >= 1, "expected a diagnostic")
            assert_eq(diags[0].code.id, "T3008")
        }
    }
}
