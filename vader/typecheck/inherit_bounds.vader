// vader/typecheck/inherit_bounds — typeParam-bound inheritance from
// struct head into impl blocks.
//
// `Foo :: struct[T: Display] { … }` + `Foo[T] implements Bar` should
// inherit `T: Display` into the impl block's typeParam scope so
// `Bar`'s methods see the bound. The TS side walks each ImplDecl,
// finds the struct's typeParams (when ImplDecl.forType is a generic
// instantiation), and merges bounds.
//
// MVP : the Vader parser doesn't expose typeParam bounds on
// `StructDecl.type_params` yet (bounds are parsed as decorators,
// not as a `: bound` clause on the param). Once the AST surface
// lands, this fn walks `impl.type_params` and stamps inherited
// bounds. Today : no-op.

module "vader/typecheck"

import "vader/diagnostics/diagnostic" { Diagnostic }
import "vader/typecheck/typed_ast" { TypedProgram }
AST :: import "vader/parser/ast"

/// Walk every ImplDecl and inherit struct-head bounds into the impl's
/// typeParam scope. MVP : no-op (AST doesn't carry bounds yet).
export inherit_bounds :: fn(_: AST.Decl[], _: TypedProgram, _: Diagnostic[]) -> void {
    return
}
