// vader/typecheck/context — shared context threaded through every typecheck pass.
//
// Two layers :
//
//   - `Globals`    — built once per project. Carries cross-module shared
//                    state : the symbol factory and the auto-imported
//                    `std/core` symbols.
//   - `FnContext`  — pushed by `check_fn_body`, drives `return` checking
//                    and `Self` substitution inside method bodies.
//
// Per-module side-tables live on `TypedProgram` directly (see
// `typed_ast.vader`) rather than being duplicated here — a single
// representation, no during/after split.

module "vader/typecheck"

import "std/collections"
import "vader/resolver/symbol"
import "vader/types"

/// Project-level shared state. Built once at the start of `check_project`
/// and threaded through every pass.
export Globals :: struct {
    /// Shared symbol id allocator. Typecheck mints synthetic locals
    /// (`for <iter>` discard, narrowing temporaries) through this so ids
    /// stay globally unique across phases.
    factory: SymbolFactory

    /// Auto-imported `std/core` symbols, looked up for `Display` /
    /// `Error` / `Iterator` etc. when a trait reference dodges the
    /// module's local imports. Populated by `check_project` once the
    /// core module is resolved ; null pre-MVP / dump-only pipelines.
    core_symbols: MutableMap<string, Symbol> | null
}

export new_globals :: fn(factory: SymbolFactory) -> Globals {
    return Globals {
        .factory      = factory,
        .core_symbols = null,
    }
}

/// Per-fn-body state — pushed by `check_fn_body`, consumed by `ReturnStmt`
/// checking and `Self` substitution inside method bodies.
export FnContext :: struct {
    /// Type the body must return. `void` for fns without a `-> T` clause.
    return_type: Type
    /// `Self` substitution when type-checking a method inside an impl
    /// block. `null` outside trait/impl context.
    self_type:  Type | null
    /// Loop depth — `break` / `continue` legal only when > 0.
    loop_depth: i32
    /// AST node id of the fn whose body is being checked. Lets deep
    /// expression checks (e.g. bounded trait-method dispatch in
    /// `field.vader`) attribute a finding back to the enclosing fn via
    /// `fn_trait_dispatches`. Keyed by id (not name) so overloaded fns
    /// don't collide. `0` for lambdas / synthetic contexts.
    fn_id: usize = 0
    /// True when the enclosing fn is a generator (it `yield`s). Drives `yield`
    /// legality, forbids `return <value>`, and suppresses the
    /// missing-return obligation on the `-> Iterator<T>` body. False for
    /// lambdas and synthetic contexts, so a `yield` inside a nested lambda
    /// trips the "yield outside generator" check.
    is_generator: bool = false
    /// Element type `T` of the generator's `-> Iterator<T>` return —
    /// `yield e` must coerce to it. Null when not a generator (or the
    /// return type wasn't a valid `Iterator<T>`).
    yield_type: Type | null = null
    /// True when the enclosing fn is an async coroutine (it `await`s). Drives
    /// `await` legality and forbids `defer` (v1). False for lambdas and
    /// synthetic contexts, so an `await` in a nested lambda trips T3064.
    is_async: bool = false
    /// Union of every value `return`'s type seen in this body — accumulated by
    /// `check_return`. A block-body lambda that ends in `return` types its block
    /// as `never` (it diverges) ; this recovers the lambda's real return type
    /// from its returns, so a type param sitting inside a `U | Error` return
    /// position stays inferable (else it drops → GATE B1). Null until the first
    /// value `return`.
    inferred_return: Type | null = null
}

export new_fn_context :: fn(return_type: Type, self_type: Type | null) -> FnContext {
    return FnContext {
        .return_type = return_type,
        .self_type   = self_type,
        .loop_depth  = 0,
    }
}

// ---- tests ----------------------------------------------------------------

import "std/testing"

@test
test_new_globals_factory_starts_at_one :: fn() -> void {
    factory :: SymbolFactory {}
    g :: new_globals(factory)
    assert_eq(g.factory.next, 1)
    if g.core_symbols !is null {
        assert(false, "core_symbols should start null")
    }
}

@test
test_new_fn_context_holds_return_type :: fn() -> void {
    ctx :: new_fn_context(mk_primitive("i32"), null)
    match ctx.return_type {
        is PrimitiveType as p -> { assert_eq(p.name, "i32") }
        _ -> { assert(false, "expected i32 return type") }
    }
    assert_eq(ctx.loop_depth, 0)
    if ctx.self_type !is null {
        assert(false, "self_type should start null")
    }
}

@test
test_new_fn_context_records_self :: fn() -> void {
    self_t: Type = mk_primitive("string")
    ctx :: new_fn_context(TY_NEVER, self_t)
    match ctx.self_type {
        is null -> { assert(false, "self_type should be set") }
        is .PrimitiveType as p -> { assert_eq(p.name, "string") }
        _ -> { assert(false, "expected string self_type") }
    }
}
