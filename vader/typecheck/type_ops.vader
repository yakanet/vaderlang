// vader/typecheck/type_ops — equality, assignability, union canonicalisation.
//
// Mirror of the operations on Type defined in `src/typecheck/types.ts`. The
// **trait-widening** branch of `is_assignable` and the `intersects` helper
// both need an `ImplRegistry` to query "does T implement Trait?" — that
// dependency lives in `impls.vader` (Phase 2.4). Until that lands, the
// MVP version takes a `TraitOracle` interface so callers can stub the
// trait check (returns false → no widening).

module "vader/typecheck"

import "std/string" { compare_ascending_ci }
import "std/sort" { sort }
import "vader/types" {
    Type, PrimitiveType, StructType, EnumType, TraitType, UnionType,
    FnType, ArrayType, TupleType, TypeParamType, TypeMetaType, SelfType,
    UnresolvedType, FreeIntType, FreeFloatType, NeverType, AnyType,
    TY_NEVER, display_type, mk_primitive, mk_union, type_base_name,
}

// ---- numeric registries (used by Free* defaulting + assignable) -----------
//
// Vader has no array-spread `[...A, ...B]` yet, so `ALL_INTS` / `NUMERIC`
// would force duplicating every entry. We instead compose the predicates :
// `is_int_name = is_signed_int_name || is_unsigned_int_name`, which keeps
// each list as the single source of truth.

export SIGNED_INTS   :: ["i8", "i16", "i32", "i64", "isize"]
export UNSIGNED_INTS :: ["u8", "u16", "u32", "u64", "usize"]
export FLOATS        :: ["f32", "f64"]

export is_signed_int_name   :: fn(name: string) -> bool { return contains_name(SIGNED_INTS, name) }
export is_unsigned_int_name :: fn(name: string) -> bool { return contains_name(UNSIGNED_INTS, name) }
export is_float_name        :: fn(name: string) -> bool { return contains_name(FLOATS, name) }
export is_int_name          :: fn(name: string) -> bool { return is_signed_int_name(name) || is_unsigned_int_name(name) }
export is_numeric_name      :: fn(name: string) -> bool { return is_int_name(name) || is_float_name(name) }

contains_name :: fn(names: const string[], target: string) -> bool {
    for n in names { if n == target { return true } }
    return false
}

// ---- equality -------------------------------------------------------------

/// Structural equality. Recursive on unions / fns / arrays / tuples ; for
/// nominal types (Struct / Trait / Enum / TypeParam) we compare symbol ids.
export equals_type :: fn(a: Type, b: Type) -> bool = match a {
    is TypeMetaType   -> b is TypeMetaType
    is SelfType       -> b is SelfType
    is UnresolvedType -> b is UnresolvedType
    is NeverType      -> b is NeverType
    is FreeIntType    -> b is FreeIntType
    is FreeFloatType  -> b is FreeFloatType
    is AnyType        -> b is AnyType
    is PrimitiveType as ax  -> match b { is PrimitiveType  as bx -> ax.name == bx.name              _ -> false }
    is TypeParamType as ax  -> match b { is TypeParamType  as bx -> ax.symbol.id == bx.symbol.id     _ -> false }
    // `StructType(EnumSym)` is the placeholder `type_from_expr` returns
    // for enum names ; treat it as equivalent to the real `EnumType` so
    // body-time assignability (annotation vs inferred) doesn't fight the
    // placeholder/proper distinction.
    is EnumType      as ax  -> match b {
        is EnumType   as bx -> ax.symbol.id == bx.symbol.id
        is StructType as bx -> bx.symbol.id == ax.symbol.id
        _ -> false
    }
    is StructType    as ax  -> match b {
        is StructType as bx -> nominal_eq(ax.symbol.id, ax.args, bx.symbol.id, bx.args)
        is EnumType   as bx -> ax.symbol.id == bx.symbol.id
        _ -> false
    }
    is TraitType     as ax  -> match b { is TraitType      as bx -> nominal_eq(ax.symbol.id, ax.args, bx.symbol.id, bx.args) _ -> false }
    is ArrayType     as ax  -> match b { is ArrayType      as bx -> ax.immutable == bx.immutable && equals_type(ax.element, bx.element) _ -> false }
    is TupleType     as ax  -> match b { is TupleType      as bx -> type_list_equals(ax.elements, bx.elements) _ -> false }
    is FnType        as ax  -> match b { is FnType         as bx -> type_list_equals(ax.params, bx.params) && equals_type(ax.return_type, bx.return_type) _ -> false }
    is UnionType     as ax  -> match b { is UnionType      as bx -> type_list_equals(ax.variants, bx.variants) _ -> false }
}

nominal_eq :: fn(a_id: i32, a_args: Type[], b_id: i32, b_args: Type[]) -> bool {
    if a_id != b_id { return false }
    return type_list_equals(a_args, b_args)
}

type_list_equals :: fn(a: Type[], b: Type[]) -> bool {
    if a.len() != b.len() { return false }
    for i in 0..<a.len() {
        if !equals_type(a[i], b[i]) { return false }
    }
    return true
}

// ---- assignability --------------------------------------------------------

/// Whether `from` can flow into a slot expecting `to` without explicit
/// coercion. No implicit numeric widening — explicit cast required.
/// Trait-widening is gated by `oracle` ; pass `null` if the registry
/// isn't built yet (Phase 1) — widening then falls back to false.
// `is_assignable` and its per-variant helpers live in `type_assign.vader`
// — moved out so each variant compiles to a small dedicated C fn instead
// of one monster cascade.

/// Minimal duck-typed view of the impl registry consumed by trait widening.
/// Real registry lives in `impls.vader` (Phase 2.4) — this surface lets
/// `is_assignable` ship before that's built.
export TraitOracle :: struct {
    /// Returns true when `from`'s nominal type implements the trait `to`.
    has_impl: fn(Type, TraitType) -> bool
}

// ---- canonical union ------------------------------------------------------

/// Build a union from `variants`. Flattens nested unions, drops `Never`
/// (absorbed — a value of that type doesn't exist), dedups, sorts by
/// `display_type` output for stability. Empty / all-Never input
/// collapses to `Never`.
export union_of :: fn(variants: Type[]) -> Type {
    dedup: Type[] = []
    for v in variants {
        v.collect_variant(dedup)
    }
    if dedup.len() == 0 { return TY_NEVER }
    if dedup.len() == 1 { return dedup[0] }
    sorted :: sort(dedup, (a: Type, b: Type) -> compare_ascending_ci(display_type(a), display_type(b)))
    return mk_union(sorted)
}

collect_variant :: fn(v: Type, into: Type[]) -> void {
    if v is NeverType { return }
    match v {
        is UnionType as u -> {
            for inner in u.variants { inner.collect_variant(into) }
        }
        _ -> {
            for existing in into {
                if equals_type(existing, v) { return }
            }
            into.push(v)
        }
    }
}

// ---- free-type defaulting -------------------------------------------------

/// Replace FreeInt with `i32` and FreeFloat with `f64`. Used when a free
/// numeric literal escapes its bidirectional context and needs a
/// concrete type to flow into downstream phases.
export default_if_free :: fn(t: Type) -> Type {
    match t {
        is FreeIntType   -> { return mk_primitive("i32") }
        is FreeFloatType -> { return mk_primitive("f64") }
        _ -> { return t }
    }
}

/// Dispatch key for trait-impl side-tables (`struct_implemented_traits`,
/// `struct_trait_args`). Defaults Free* first so a `7` literal keys the
/// same as `i32` for impls like `i32 implements Doubler`. Returns `""`
/// for types with no nominal name — callers gate on the empty sentinel.
export dispatch_key :: fn(t: Type) -> string {
    return type_base_name(default_if_free(t))
}

/// True iff the nominal carrier of `t` is registered as implementing the
/// trait named `trait_name` in `typed.struct_implemented_traits`. Returns
/// false for shapes with no nominal name (Union, Fn, Array, …) and for
/// nominal types that have no impl entry. Shared by `expr?` error-stripping,
/// trait-bound widening and UFCS dispatch.
export struct_implements_trait :: fn(t: Type, trait_name: string, typed: TypedProgram) -> bool {
    name :: dispatch_key(t)
    if name == "" { return false }
    bucket :: typed.struct_implemented_traits[name]
    if bucket is null { return false }
    for n in bucket { if n == trait_name { return true } }
    return false
}


/// Bidirectional narrowing : when a Free* literal flows into a slot that
/// wants a concrete numeric of the matching family, fold the literal to
/// the concrete primitive. Used by every check_expr-style call site.
export narrow_for_expected :: fn(got: Type, expected: Type | null) -> Type {
    if expected is null { return got }
    if !(expected is PrimitiveType) { return got }
    if got is FreeIntType   && is_int_name(expected.name)   { return expected }
    if got is FreeFloatType && is_float_name(expected.name) { return expected }
    return got
}

/// Do `a` and `b` share any concrete runtime value ? Powers T3040
/// ("test can never match") and the match-arm overlap check.
/// UnionType on either side recurses into its variants. Otherwise
/// falls back to `equals_type`.
export types_overlap :: fn(a: Type, b: Type) -> bool {
    av :: union_variants(a)
    if !(av is null) {
        for v in av { if types_overlap(v, b) { return true } }
        return false
    }
    bv :: union_variants(b)
    if !(bv is null) {
        for v in bv { if types_overlap(a, v) { return true } }
        return false
    }
    return equals_type(a, b)
}

union_variants :: fn(t: Type) -> Type[] | null {
    match t {
        is UnionType as u -> { return u.variants }
        _ -> { return null }
    }
}

/// Subtract a single variant from a type. Returns the remaining type
/// (or `Never` if nothing remains). For non-union sources subtracting
/// the same shape yields `Never` ; subtracting a different shape is a
/// no-op. Used by flow narrowing — `if x is T` widens to "not T" on
/// the false side / in code after a divergent guard.
export subtract_type :: fn(from: Type, removed: Type) -> Type {
    if from is UnionType {
        kept: Type[] = []
        for v in from.variants {
            if !equals_type(v, removed) { kept.push(v) }
        }
        if kept.len() == 0 { return TY_NEVER }
        if kept.len() == 1 { return kept[0] }
        return mk_union(kept)
    }
    if equals_type(from, removed) { return TY_NEVER }
    return from
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/types" { mk_array, mk_fn, mk_tuple, TY_FREE_INT, TY_FREE_FLOAT }

@test
test_equals_primitive :: fn() -> void {
    assert(equals_type(mk_primitive("i32"), mk_primitive("i32")), "i32 == i32")
    assert(!equals_type(mk_primitive("i32"), mk_primitive("i64")), "i32 != i64")
}

@test
test_equals_array :: fn() -> void {
    a1: Type = mk_array(mk_primitive("i32"), false)
    a2: Type = mk_array(mk_primitive("i32"), false)
    a3: Type = mk_array(mk_primitive("i32"), true)
    assert(equals_type(a1, a2), "i32[] == i32[]")
    assert(!equals_type(a1, a3), "i32[] != const i32[]")
}

// `is_assignable` tests live in `type_assign.vader` alongside the impl.

@test
test_union_of_dedup :: fn() -> void {
    i32_t: Type = mk_primitive("i32")
    str_t: Type = mk_primitive("string")
    // A | B | A should collapse to A | B
    u :: union_of([i32_t, str_t, i32_t])
    match u {
        is UnionType as un -> { assert_eq(un.variants.len(), usize(2)) }
        _ -> { assert(false, "expected a Union after dedup") }
    }
}

@test
test_union_of_drops_never :: fn() -> void {
    i32_t: Type = mk_primitive("i32")
    never_t: Type = TY_NEVER
    // i32 | Never should collapse to i32
    u :: union_of([i32_t, never_t])
    match u {
        is PrimitiveType as pt -> { assert_eq(pt.name, "i32") }
        _ -> { assert(false, "Never should be absorbed") }
    }
}

@test
test_union_of_flattens :: fn() -> void {
    i32_t: Type = mk_primitive("i32")
    str_t: Type = mk_primitive("string")
    bool_t: Type = mk_primitive("bool")
    inner :: mk_union([i32_t, str_t])
    u :: union_of([inner, bool_t])
    match u {
        is UnionType as un -> { assert_eq(un.variants.len(), usize(3)) }
        _ -> { assert(false, "flattened union should have 3 variants") }
    }
}

@test
test_default_if_free :: fn() -> void {
    match default_if_free(TY_FREE_INT) {
        is PrimitiveType as p -> { assert_eq(p.name, "i32") }
        _ -> { assert(false, "FreeInt defaults to i32") }
    }
    match default_if_free(TY_FREE_FLOAT) {
        is PrimitiveType as p -> { assert_eq(p.name, "f64") }
        _ -> { assert(false, "FreeFloat defaults to f64") }
    }
    // Non-free types pass through.
    i32_t :: mk_primitive("i32")
    match default_if_free(i32_t) {
        is PrimitiveType as p -> { assert_eq(p.name, "i32") }
        _ -> { assert(false, "i32 should pass through") }
    }
}
