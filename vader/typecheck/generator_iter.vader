// vader/typecheck/generator_iter — Direction A: a `@generator`'s call result is a
// CONCRETE nominal type implementing `Iterator<U>`, not the erased trait.
//
// A `@generator fn -> Iterator<U>` returns the honest erased `Iterator<U>` in
// source, but a call to it is typed as the concrete synthesized state struct
// `<fn>$State` (which `implements Iterator<U>`), erased to `Iterator<U>` only at
// boundaries. This makes a combinator chain `arr.iter().map(f).filter(p)` resolve
// field/UFCS on a CONCRETE receiver (like the hand-written `MappedIterator`),
// instead of the erased trait receiver that mis-resolves to a virtual dispatch.
// The state-struct symbol is derived DETERMINISTICALLY from the fn symbol so the
// lowerer (`lower_generator.vader`) reuses the same one — see
// `.claude/plans/stream-fusion-generalization.md` §12 "Direction A".

module "vader/typecheck"

AST :: import "vader/parser"
import "vader/parser" { Visibility }
import "vader/diagnostics" { Diagnostic }
import "vader/resolver/symbol" { Symbol, SymbolKind }
import "vader/types" { Type, StructType, ArrayType, TraitType, mk_struct }
import "std/collections" { MutableMap }

// The `<fn>$State` naming convention — one source of truth shared by the symbol
// mint (`gen_state_symbol`), the registry keys, and the lower-side recognition
// (`is_gen_state_struct`).
GEN_STATE_PREFIX :: "__genstate_"

/// The deterministic state-struct name for a `@generator` fn named `fn_name`.
export gen_state_name :: fn(fn_name: string) -> string = "${GEN_STATE_PREFIX}${fn_name}"

// Reserved synthetic-id range for generator state structs — a large negative
// offset distinct from the lowerer's small-magnitude `next_synthetic_id` pool
// (which starts at -1 and decrements). Self-compile is nowhere near 1M synthetic
// ids, so the two pools cannot meet ; the offset is a stopgap for resolver-minting
// (see the plan's CLEANUP entry).
GEN_STATE_ID_BASE :: -1000000

/// The nominal state-struct symbol for a `@generator` from its `(id, name,
/// module)` — deterministic (no counter, no side-table) so typecheck and lowering
/// agree on it. Threaded via raw `(id, name, module)` so a caller holding those
/// (the registry) needn't fabricate a throwaway `Symbol` just to be re-read.
export gen_state_symbol_of :: fn(fn_id: i32, fn_name: string, module: string) -> Symbol = Symbol {
    .id         = GEN_STATE_ID_BASE - fn_id,
    .kind       = SymbolKind.Struct,
    .name       = gen_state_name(fn_name),
    .module     = module,
    .visibility = Visibility.Private,
    .defined_at = null,
}

/// The state-struct symbol for a `@generator` fn symbol.
export gen_state_symbol :: fn(fn_sym: Symbol) -> Symbol =
    gen_state_symbol_of(fn_sym.id, fn_sym.name, fn_sym.module)

/// True when `t` is a `@generator`'s synthetic `<fn>$State` iterator struct.
/// Recognises by the deterministic `gen_state_symbol` name (not user-derived).
export is_gen_state_struct :: fn(t: Type) -> bool {
    if t is StructType as st { return starts_with(st.symbol.name, GEN_STATE_PREFIX) }
    return false
}

// One `@generator`'s state-struct registration facts, collected from the module
// that OWNS the fn (its `decl_types` / resolved symbol resolve the element).
GenStateEntry :: struct { name: string, module: string, id: i32, element: Type }

/// Register every `@generator` fn's synthetic state struct as `implements
/// Iterator<U>` — into EVERY module's registry — so a call to it types as a
/// concrete iterator (chains resolve) regardless of which module consumes it.
/// Runs before any body walk so `try_trait_widen` sees `<fn>$State → Iterator`
/// while typing chained receivers.
///
/// Cross-module: a generator's element resolves only in its OWNER module (whose
/// `decl_types` carries its signature) — `cross_publish_fn_decls` copies fn_decls
/// but not decl_types, so a copy in a consuming module's `fn_decls` yields
/// `TY_UNRESOLVED` and is skipped, deduping the collection to one entry per fn.
export register_generator_iter_impls :: fn(per_module: MutableMap<string, TypedProgram>) -> void {
    entries: GenStateEntry[] = []
    for [_, owner] in per_module {
        sink: Diagnostic[] = []
        for [sym_id, fn_decl] in owner.fn_decls {
            if !fn_is_generator(fn_decl) { continue }
            elem :: generator_element_type(fn_decl, lookup_return_type(fn_decl, owner), sink)
            if elem is null { continue }
            entries.push(GenStateEntry {
                .name = fn_decl.name, .module = owner.resolved.path, .id = sym_id, .element = elem,
            })
        }
    }
    for [_, tp] in per_module {
        if entries.len() > 0 { tp.has_generators = true }
        for e in entries {
            state_ty :: mk_struct(gen_state_symbol_of(e.id, e.name, e.module), [])
            record_struct_trait(tp, state_ty, "Iterator")
            record_struct_trait_args(tp, state_ty, "Iterator", [e.element])
            tp.iter_element_types[gen_state_name(e.name)] = e.element
            tp.generator_symbols[e.name] = Symbol {
                .id = e.id, .kind = SymbolKind.Fn, .name = e.name,
                .module = e.module, .visibility = Visibility.Private, .defined_at = null,
            }
        }
    }
}

/// The concrete result type for a call whose callee is a `@generator`, or null.
/// `mk_struct(<fn>$State, [element])` — a nominal type that `implements
/// Iterator<element>`. The concrete element (from the call's substituted return
/// `Iterator<i32>`) is carried as the sole type arg so a terminal returning the
/// element (`collect -> element[]`, `find -> element | null`) on a chain of these
/// concretises instead of erasing to `T[]` (the `<fn>$State<E> implements
/// Iterator<E>` convention that `resolve_struct_trait_args` reads).
export generator_call_result_type :: fn(c: AST.CallExpr, typed: TypedProgram, concrete_ret: Type) -> Type | null {
    // Cheap program-level bail: a generator-free program (the compiler's own
    // self-compile today) skips the per-call callee probe entirely.
    if !typed.has_generators { return null }
    fn_sym :: callee_generator_symbol(c, typed)
    if fn_sym is null { return null }
    elem :: iterator_element_of(concrete_ret)
    if elem is null { return mk_struct(gen_state_symbol(fn_sym), []) }
    return mk_struct(gen_state_symbol(fn_sym), [elem])
}

/// The element `E` of an `Iterator<E>`, or null when `t` isn't a single-arg
/// `Iterator`. The `@generator`'s declared return is `Iterator<E>`, so the call's
/// substituted return yields the concrete element.
iterator_element_of :: fn(t: Type) -> Type | null {
    if t is TraitType as tt {
        if tt.symbol.name == "Iterator" && tt.args.len() > 0 { return tt.args[0] }
    }
    return null
}

// The callee's fn symbol IF it is a `@generator`, else null. Handles the direct
// ident callee and the UFCS field callee (free fn whose first param fits the
// receiver).
callee_generator_symbol :: fn(c: AST.CallExpr, typed: TypedProgram) -> Symbol | null {
    @partial match c.callee {
        is AST.IdentExpr as id -> {
            // Direct call `name(args)` : the resolver already picked the overload,
            // so trust its bound symbol (a picked eager overload is simply not a
            // generator).
            sym :: typed.resolved.idents[id.span.hash()]
            if sym is null { return null }
            if is_generator_symbol(sym, typed) { return sym }
            return null
        }
        is AST.FieldExpr as fe -> {
            recv_ty :: typed.expr_types[fe.target.id]
            if recv_ty is null { return null }
            return ufcs_generator_symbol(fe.field, recv_ty, typed)
        }
        _ -> { return null }
    }
}

is_generator_symbol :: fn(sym: Symbol, typed: TypedProgram) -> bool {
    fd :: typed.fn_decls[sym.id]
    if fd is AST.FnDecl as f { return fn_is_generator(f) }
    return false
}

// The `@generator` combinator named `name` for a UFCS `.name()` on an ITERATOR
// receiver, or null. Consults the `generator_symbols` registry — authoritative for
// an OVERLOADED name (`map` = eager `T[]` + lazy `Iterator<T>`), unlike following
// the single import binding, which may resolve to the eager (non-generator) overload
// and miss the generator. A bare ARRAY receiver never selects the lazy generator
// (`arr.map(f)` is the eager overload; lazy is opt-in via `arr.iter()`).
ufcs_generator_symbol :: fn(name: string, recv_ty: Type, typed: TypedProgram) -> Symbol | null {
    if recv_ty is ArrayType { return null }
    gen_sym :: typed.generator_symbols[name]
    if gen_sym is null { return null }
    if generator_receiver_is_iterator(recv_ty, typed) { return gen_sym }
    return null
}

// Whether `recv_ty` is an actual iterator (a struct impl'ing `Iterator`, or the
// erased `Iterator` trait) — so a combinator's `self: Iterator<T>` param accepts it.
// Excludes the `T[] -> Iterator` blanket (the array case is guarded above).
generator_receiver_is_iterator :: fn(recv_ty: Type, typed: TypedProgram) -> bool {
    if recv_ty is TraitType as tt { return tt.symbol.name == "Iterator" }
    return struct_implements_trait(recv_ty, "Iterator", typed)
}
