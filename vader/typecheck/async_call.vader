// vader/typecheck/async_call — call-site typing for `@async fn` calls.
//
// A call to an `@async fn -> T` is typed as the erased `Async<T>`. Unlike a
// generator (which types the call as a concrete `<fn>$State<E>` so method chains
// keep the element concrete), async doesn't chain — and `all` wants a
// homogeneous erased awaitable — so the erased trait is both sufficient and
// required. Direct-call (`IdentExpr`) only in v1 ; a UFCS async call falls
// through to null.

module "vader/typecheck"

import "vader/types" { Type, TraitType, mk_trait, TY_NULL, TRAIT_ASYNC }
AST :: import "vader/parser"

/// The `Async<T>` result type when `c`'s callee is an async coroutine, else null.
///
/// Two source shapes converge here : the transitional `@async fn -> T` (wrap the
/// return to `Async<T>`) and the target `fn -> Async<T>` where the coroutine
/// already declares its erased type (return it verbatim — wrapping it again
/// would nest to `Async<Async<T>>`). A `void` result normalizes to `null`
/// (`Async<null>`) : void isn't a first-class stack value, so `void | Suspended`
/// couldn't represent a completed-but-void coroutine. Mirror in `lower_decl`.
export async_call_result_type :: fn(c: AST.CallExpr, typed: TypedProgram, concrete_ret: Type) -> Type | null {
    async_sym :: typed.async_symbol
    if async_sym == null { return null }
    if c.callee is AST.IdentExpr as id {
        sym :: typed.resolved.idents[id.span.hash()]
        if sym == null { return null }
        fd :: typed.fn_decls[sym.id]
        if fd is AST.FnDecl as f {
            // Unwrap-then-wrap-once handles both shapes uniformly : `-> T`
            // (inner = T) and `-> Async<T>` (inner = T) both yield `Async<T>`,
            // never a nested `Async<Async<T>>`.
            if fn_is_async(f) { return mk_trait(async_sym, [async_result_arg(async_inner_type(concrete_ret))]) }
        }
    }
    return null
}

/// The raw value type a coroutine body produces : the `T` of a declared
/// `Async<T>` return (target form), or the declared return itself (transitional
/// `-> T`). NOT normalized — `void` stays `void` (the body is void-bodied) ; the
/// void→null step happens only where the erased `Async<...>` type is built.
export async_inner_type :: fn(t: Type) -> Type {
    if t is TraitType as tt {
        if tt.symbol.name == TRAIT_ASYNC && tt.args.len() > 0 { return tt.args[0] }
    }
    return t
}

/// The `Async` type argument for an `@async fn`'s declared result : `void`
/// normalizes to `null` (see `async_call_result_type`), everything else passes
/// through. Shared with `lower_decl` so the call-site type and the lowered decl
/// type agree.
export async_result_arg :: fn(result: Type) -> Type = if is_void(result) { TY_NULL } else { result }
