// vader/typecheck/match_expr — MatchExpr inference (MVP).
//
// `match scrutinee { p1 -> b1, p2 -> b2 }` types as `union_of(arm bodies)`.
// Out of scope: exhaustiveness check (T3013), per-arm scrutinee
// narrowing (binding patterns like `is X as x` typing `x` to X) — both
// land with `narrow.vader`. Guards must be `bool` (T3019).

module "vader/typecheck"

import "vader/diagnostics" { Diagnostic, typecheck_error, warning }
import "vader/types" { Type, UnionType, EnumType, PrimitiveType, display_type, TY_BOOL }
AST :: import "vader/parser"

/// Type-check a `MatchExpr`. `expected` flows into every arm body so
/// `let x: i32 = match v { is Foo -> 1, is Bar -> 2 }` narrows each
/// arm to i32.
export infer_match :: fn(
    e: AST.MatchExpr, expected: Type | null,
    typed: TypedProgram, diags: Diagnostic[],
    ctx: FnContext | null,
    check_expr_fn: fn(AST.Expr, Type | null, TypedProgram, Diagnostic[]) -> Type,
) -> Type {
    raw_scrut :: check_expr_fn(e.scrutinee, null, typed, diags)
    scrut_ty :: lift_enum_placeholder(raw_scrut, typed)
    scrut_sym_id :: scrutinee_sym_id(e.scrutinee, typed)
    scrut_field_key :: scrutinee_field_key(e.scrutinee, typed)
    arm_types: Type[] = []
    remaining := scrut_ty
    has_wildcard := false
    covered_enum_variants: string[] = []
    for arm in e.arms {
        if arm.pattern is AST.LiteralPattern as lp { check_expr_fn(lp.value, null, typed, diags) }
        // Re-bind the pattern types against the narrowed `remaining`
        // so wildcard/binding arms see only the still-possible
        // variants ("union − matched").
        bind_pattern_types(arm.pattern, remaining, typed, diags)
        // Per-arm narrowing — `is T` arms see just T, wildcard /
        // binding arms see `remaining` (subset of `scrut_ty` after
        // earlier arms removed their matched variants).
        arm_narrow :: arm_narrow_for(arm.pattern, remaining, typed)
        prev_arm: Type | null = null
        if scrut_sym_id != -1 {
            match arm_narrow {
                is null -> {}
                _ -> { prev_arm = push_narrow(typed, scrut_sym_id, arm_narrow) }
            }
        }
        prev_field: Type | null = null
        if scrut_field_key != "" {
            match arm_narrow {
                is null -> {}
                _ -> { prev_field = push_field_narrow(typed, scrut_field_key, arm_narrow) }
            }
        }
        match arm.guard {
            is null -> {}
            _ -> {
                got :: check_expr_fn(arm.guard, TY_BOOL, typed, diags)
                if !is_assignable(got, TY_BOOL, null) {
                    diags.push(typecheck_error(.ConditionMustBeBool, arm.guard.span,
                        "match-arm guard must be `bool`, got ${display_type(got)}"))
                }
            }
        }
        arm_types.push(check_expr_fn(arm.body, expected, typed, diags))
        if scrut_sym_id != -1 {
            match arm_narrow {
                is null -> {}
                _ -> { pop_narrow(typed, scrut_sym_id, prev_arm, scrut_ty) }
            }
        }
        if scrut_field_key != "" {
            match arm_narrow {
                is null -> {}
                _ -> { pop_field_narrow(typed, scrut_field_key, prev_field, scrut_ty) }
            }
        }
        // Subtract the matched type from `remaining` for subsequent
        // arms — `is T`, wildcard/binding, and tuple shapes consume
        // their corresponding union variants.
        match arm.pattern {
            is AST.IsPattern as ip -> {
                matched :: type_from_expr(ip.ty, typed.resolved, scratch_diags())
                if is_overlap_checkable(scrut_ty) && is_overlap_checkable(matched) {
                    if !types_overlap(scrut_ty, matched) {
                        diags.push(typecheck_error(.UnreachableIsTest, ip.span,
                            "`${display_type(matched)}` is never a value of `${display_type(scrut_ty)}`"))
                    }
                }
                remaining = subtract_type(remaining, matched)
            }
            is AST.EnumVariantPattern as ev -> {
                covered_enum_variants.push(ev.variant)
            }
            is AST.TuplePattern as tp -> {
                // Subtract any TupleType variant whose arity matches.
                tup_ty :: pick_tuple_variant(remaining, tp.elements.len())
                if !(tup_ty is null) { remaining = subtract_type(remaining, tup_ty) }
                // Irrefutable tuple (all bindings / wildcards) matches every
                // tuple of that arity ; counts as a wildcard for exhaustiveness.
                if is_irrefutable_tuple_pattern(tp) {
                    has_wildcard = true
                }
            }
            is AST.WildcardPattern -> {
                has_wildcard = true
                remaining = TY_NEVER
            }
            is AST.BindingPattern -> {
                has_wildcard = true
                remaining = TY_NEVER
            }
            _ -> {}
        }
    }
    // T3013 — non-exhaustive match. `@partial` / `@unreachable` opt out
    // (the latter asserts the uncovered variants trap rather than degrade).
    if !has_wildcard && !e.partial && !e.unreachable && e.arms.len() > 0 {
        if scrut_ty is UnionType {
            if !is_never(remaining) {
                diags.push(typecheck_error(.NonExhaustiveMatch, e.span,
                    "variant ${display_type(remaining)} of ${display_type(scrut_ty)} is not covered"))
            }
        } else if scrut_ty is EnumType {
            missing_variant :: missing_enum_variant_name(scrut_ty, typed, covered_enum_variants)
            if missing_variant != "" {
                diags.push(typecheck_error(.NonExhaustiveMatch, e.span,
                    "variant .${missing_variant} of ${display_type(scrut_ty)} is not covered"))
            }
        } else if scrut_ty is UnresolvedType {
            // skip — upstream error already surfaced.
        } else {
            diags.push(typecheck_error(.NonExhaustiveMatch, e.span,
                "match on non-union ${display_type(scrut_ty)} requires a wildcard arm"))
        }
    }
    // W0005 — a wildcard arm on a closed union silences the T3013 check above,
    // so a newly added variant degrades silently into `_` instead of erroring
    // (the bug class CLAUDE.md §6 forbids). A value-producing match must
    // enumerate every variant, or opt out with `@partial`. Statement matches
    // (arms all return / do nothing → void/never result) and open scrutinees
    // (i32 / string / …) are exempt.
    result_ty :: union_of(arm_types)
    // `has_wildcard` is only set by a wildcard / binding arm, so it already
    // implies ≥ 1 arm — no explicit arm-count guard needed.
    if has_wildcard && !e.partial && !e.unreachable && !is_void(result_ty) && !is_never(result_ty) {
        if scrut_ty is UnionType || scrut_ty is EnumType {
            diags.push(warning(.WildcardOnClosedUnion, e.span,
                "wildcard arm on closed union `${display_type(scrut_ty)}` — enumerate its variants or mark the match `@partial`"))
        }
    }
    return result_ty
}

is_void :: fn(t: Type) -> bool {
    if t is PrimitiveType as p { return p.name == "void" }
    return false
}

// First enum variant name absent from `covered`. Uses the EnumType's
// `indices` map (populated at declare-time) so we don't need to walk
// the program AST a second time.
// True iff every leaf of `tp` is a binding / wildcard — i.e. matches
// every tuple of that arity by construction. Mirrors TS's
// `isIrrefutableTuple`.
is_irrefutable_tuple_pattern :: fn(tp: AST.TuplePattern) -> bool {
    for el in tp.elements {
        if el is AST.WildcardPattern { continue }
        if el is AST.BindingPattern  { continue }
        if el is AST.TuplePattern as nested {
            if !is_irrefutable_tuple_pattern(nested) { return false }
            continue
        }
        return false
    }
    return true
}

missing_enum_variant_name :: fn(
    en: EnumType, typed: TypedProgram, covered: string[],
) -> string {
    for [name, _] in en.indices {
        found := false
        for c in covered {
            if c == name {
                found = true
                break
            }
        }
        if !found { return name }
    }
    return ""
}

is_never :: fn(t: Type) -> bool {
    match t { is NeverType -> { return true } _ -> { return false } }
}

import "vader/types" { NeverType, TY_NEVER }

arm_narrow_for :: fn(p: AST.Pattern, remaining: Type, typed: TypedProgram) -> Type | null {
    match p {
        is AST.IsPattern as ip -> { return type_from_expr(ip.ty, typed.resolved, scratch_diags()) }
        is AST.WildcardPattern -> { return remaining }
        is AST.BindingPattern  -> { return remaining }
        _ -> { return null }
    }
}


is_overlap_checkable :: fn(t: Type) -> bool {
    match t {
        is UnresolvedType -> { return false }
        is TypeParamType -> { return false }
        is TypeMetaType -> { return false }
        is TraitType -> { return false }
        _ -> { return true }
    }
}

import "vader/types" { TraitType, TypeMetaType, TypeParamType, UnresolvedType }

scrutinee_sym_id :: fn(scrut: AST.Expr, typed: TypedProgram) -> i32 {
    if !(scrut is AST.IdentExpr) { return -1 }
    sym :: typed.resolved.idents[scrut.span.hash()]
    if sym is null { return -1 }
    return sym.id
}

/// Build the `${root_sym.id}#path` field-narrow key when the
/// scrutinee is a `recv.f1.f2.…` chain rooted at an `IdentExpr`.
/// Returns `""` (no narrowing slot) for other scrutinee shapes.
scrutinee_field_key :: fn(scrut: AST.Expr, typed: TypedProgram) -> string {
    if !(scrut is AST.FieldExpr) { return "" }
    return field_chain_key(scrut, typed)
}

/// Walk a match-arm pattern and record each binding's type in
/// `typed.local_types`. Tuple patterns destructure element-wise
/// against the scrutinee's `TupleType`. Other pattern shapes are
/// no-ops at MVP — adding StructPattern field binding support
/// requires the resolver to expose field-name → Symbol mappings,
/// which lands with the deeper narrowing work.
bind_pattern_types :: fn(p: AST.Pattern, scrut: Type, typed: TypedProgram, diags: Diagnostic[]) -> void {
    match p {
        is AST.TuplePattern as tp -> {
            tu :: pick_tuple_variant(scrut, tp.elements.len())
            match tu {
                is null -> {}
                _ -> {
                    for i in 0..<tp.elements.len() {
                        bind_pattern_types(tp.elements[i], tu.elements[i], typed, diags)
                    }
                }
            }
        }
        is AST.BindingPattern as bp -> {
            typed.local_types[bp.span.hash()] = scrut
        }
        is AST.IsPattern as ip -> {
            // `is T as a` binds `a` to T (the narrowed type). The
            // resolver mints the binding at `ip.span` when bind_as
            // is non-null ; write the lowered T as its type.
            narrowed :: type_from_expr(ip.ty, typed.resolved, scratch_diags())
            match ip.bind_as {
                is null -> {}
                _ -> { typed.local_types[ip.span.hash()] = narrowed }
            }
            // Nested pattern (e.g. `is T as a { x, y }`) — recurse
            // with the narrowed type so inner StructPattern bindings
            // pick up T's field types.
            match ip.inner {
                is null -> {}
                _ -> { bind_pattern_types(ip.inner, narrowed, typed, diags) }
            }
        }
        is AST.StructPattern as sp -> { bind_struct_pattern(sp, scrut, typed, diags) }
        _ -> {}
    }
}

bind_struct_pattern :: fn(
    sp: AST.StructPattern, scrut: Type, typed: TypedProgram, diags: Diagnostic[],
) -> void {
    match scrut {
        is StructType as st -> {
            decl :: typed.struct_decls[st.symbol.id]
            if decl is null { return }
            for field in sp.fields {
                // T3054 : reject binding an `@internal` field in a struct
                // pattern from outside its declaring module.
                check_internal_field(st, decl, field.name, field.name_span, typed, diags)
                match field.value {
                    is AST.PatternBinding as pb -> {
                        ft :: find_struct_field_type(decl, field.name, typed.resolved, scratch_diags())
                        match ft {
                            is null -> {}
                            _ -> { typed.local_types[pb.span.hash()] = ft }
                        }
                    }
                    _ -> {}
                }
            }
        }
        _ -> {}
    }
}

scratch_diags :: fn() -> Diagnostic[] { return [] }

/// Find a matching `TupleType` variant inside `t` for a pattern of
/// `arity` elements. Falls back to the bare `TupleType` when `t` is
/// one ; returns null when neither path matches.
pick_tuple_variant :: fn(t: Type, arity: usize) -> TupleType | null {
    match t {
        is TupleType as tu -> {
            if tu.elements.len() == arity { return tu }
            return null
        }
        is UnionType as u -> {
            for v in u.variants {
                match v {
                    is TupleType as tu -> {
                        if tu.elements.len() == arity { return tu }
                    }
                    _ -> {}
                }
            }
            return null
        }
        _ -> { return null }
    }
}

import "vader/types" { StructType, TupleType }

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq }
import "vader/parser" { parse_source }
import "vader/resolver" { resolve_module }
import "vader/resolver/symbol" { new_factory }
import "vader/types" { TY_UNRESOLVED }
import "vader/diagnostics" { empty_span }

match_expr_check_stub :: fn(
    e: AST.Expr, expected: Type | null, typed: TypedProgram, diags: Diagnostic[],
) -> Type {
    match e {
        is AST.IntLitExpr    as x -> { return narrow_for_expected(infer_int_lit(x), expected) }
        is AST.BoolLitExpr   as x -> { return infer_bool_lit(x) }
        is AST.StringLitExpr as x -> { return infer_string_lit(x) }
        is AST.IdentExpr     as x -> { return infer_ident(x, typed) }
        is AST.MatchExpr     as x -> { return infer_match(x, expected, typed, diags, null, match_expr_check_stub) }
        _ -> { return TY_UNRESOLVED }
    }
}

accept_match :: fn(e: AST.Expr) -> AST.Expr | null {
    if e is AST.MatchExpr { return e }
    return null
}

ExpectedMatch :: struct {
    typed: TypedProgram
    m:     AST.MatchExpr
}

expect_match :: fn(src: string) -> ExpectedMatch {
    parsed :: parse_source(src, "t.vader")
    factory :: new_factory()
    rm :: resolve_module(parsed.program, "t", factory)
    diags: Diagnostic[] = []
    result :: check_module(parsed.program, rm, factory, diags)
    last :: parsed.program.decls[parsed.program.decls.len() - 1]
    match last {
        is AST.FnDecl as f -> {
            match f.body {
                is null -> {}
                is AST.BlockExpr as b -> {
                    hit :: find_first_in_block(b, accept_match)
                    if hit is AST.MatchExpr { return ExpectedMatch { .typed = result.typed, .m = hit } }
                }
            }
        }
        _ -> {}
    }
    assert(false, "expected a MatchExpr in: ${src}")
    return ExpectedMatch { .typed = result.typed, .m = synthetic_match() }
}

synthetic_match :: fn() -> AST.MatchExpr {
    sp :: empty_span()
    scrut: AST.Expr = AST.IntLitExpr {
        .span = sp, .id = AST.UNASSIGNED_NODE_ID, .value = 0, .suffix = null,
    }
    return AST.MatchExpr {
        .span = sp, .id = AST.UNASSIGNED_NODE_ID,
        .scrutinee = scrut, .arms = [], .partial = false,
    }
}

@test
test_match_single_arm_returns_arm_type :: fn() -> void {
    src :: "f :: fn(x: i32) -> i32 { return match x { _ -> 42 } }"
    em :: expect_match(src)
    diags: Diagnostic[] = []
    assert_eq(display_type(infer_match(em.m, null, em.typed, diags, null, match_expr_check_stub)), "{integer}")
}

@test
test_match_two_arms_unions :: fn() -> void {
    src :: "f :: fn(x: i32) -> string | i32 { return match x { 0 -> \"zero\", _ -> 1 } }"
    em :: expect_match(src)
    diags: Diagnostic[] = []
    ty :: infer_match(em.m, null, em.typed, diags, null, match_expr_check_stub)
    // union_of sorts by display (`s` < `{`), so `string | {integer}`.
    assert_eq(display_type(ty), "string | {integer}")
}

@test
test_match_guard_non_bool_emits_T3019 :: fn() -> void {
    src :: "f :: fn(x: i32) -> i32 { return match x { _ if 1 -> 0, _ -> 1 } }"
    em :: expect_match(src)
    diags: Diagnostic[] = []
    infer_match(em.m, null, em.typed, diags, null, match_expr_check_stub)
    found := false
    for d in diags { if d.code.id == "T3019" { found = true } }
    assert(found, "expected T3019 on non-bool guard")
}
