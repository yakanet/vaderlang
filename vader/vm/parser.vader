// vader/vm/parser — read a `.virt` text bytecode dump into a `MainBody`.
//
// The format is the one produced by `vader build --target=ir-text` —
// stable enough that the Vader-side VM can validate end-to-end against
// the live TS pipeline without waiting on the typer / lower / bytecode-
// emit port (TODO §2.4, docs/SELFHOST_VM.md).
//
// Sprint coverage so far: i32 const / arith / cmp, locals, structured
// `block`/`loop`/`if`/`else`/`end`, `br`/`br_if`, `return`. The parser
// resolves every branching op's target pc in a single pass via a scope
// stack keyed on the label names the `.virt` format carries
// (`if $L0`, `loop $L1`, `br $L1`, `end $L1`, etc).

import "std/string" { byte_len, slice, starts_with, trim, split }
import "std/numbers" { parse_int_in_base }
import "vader/vm/op" { Op, I32Const, LocalGet, LocalSet, I32Add, I32Sub, I32Mul, I32Div, I32Mod, I32Eq, I32Ne, I32Lt, I32Le, I32Gt, I32Ge, Block, Loop, If, Else, End, Br, BrIf, Return, MainBody }

// A scope entry built when we see `block`/`loop`/`if`. `kind` is "loop"
// for back-edges (br jumps to opener+1), anything else jumps past the
// matching `end`. `label` is the textual `$LN` ; an `end LABEL` line
// closes the matching entry (the formatter guarantees uniqueness).
ScopeEntry :: struct {
    label:     string
    is_loop:   bool
    opener_pc: i32
}

// A `br`/`br_if` we couldn't resolve yet because its target scope
// hasn't closed. Held in a side list, drained when the matching end
// pops the target scope.
PendingBr :: struct {
    br_pc:        i32
    target_label: string
}

// Strip a trailing `; ...` comment (the .virt format glues a source-
// span annotation after every op). The semicolon never appears inside
// an op payload today, so a first-occurrence split is correct.
strip_comment :: fn(line: string) -> string {
    parts :: line.split(";")
    if parts.len() == 0 { return line }
    return parts[0].trim()
}

// First whitespace-separated token after `prefix` — the structured ops
// embed their label here (`block $L0 void` → `$L0`).
first_token_after :: fn(cleaned: string, prefix: string) -> string {
    rest :: cleaned.slice(prefix.byte_len(), cleaned.byte_len()).trim()
    parts :: rest.split(" ")
    if parts.len() == 0 { return "" }
    return parts[0]
}

// Walk every line of the .virt source. The first `fn` opener starts
// the body ; we collect `local` decls (to size the locals frame) and
// ops, resolving every branching op's jump target via a scope stack.
export parse_virt :: fn(src: string) -> MainBody {
    ops:         Op[] = []
    table:       i32[] = []
    local_count := 0
    in_fn := false

    // Scope stack — grown via push, logical top tracked by `scope_sp`.
    // Vader has no `inout`/`ref` params for primitives, so the cursor
    // lives in a 1-element `usize[]` we pass by handle and mutate
    // element 0 of. Same trick for the pending-br cursor below.
    scopes: ScopeEntry[] = []
    scope_sp: usize[] = [0]
    pending: PendingBr[] = []
    pending_sp: usize[] = [0]

    lines :: src.split("\n")
    for line in lines {
        cleaned :: strip_comment(line)
        if cleaned.byte_len() == 0 { continue }
        if cleaned.starts_with("fn ") {
            if in_fn { break }
            in_fn = true
            continue
        }
        if !in_fn { continue }
        if cleaned.starts_with("local ") {
            local_count += 1
            continue
        }
        // Every accepted op gets its own table entry (always -1 sentinel
        // by default ; branching ops fill it before exec sees them).
        pc :: (i32)(ops.len())
        appended :: try_push_op(cleaned, ops)
        if !appended { continue }
        table.push(-1)
        wire_control_flow(cleaned, pc, ops, table, scopes, scope_sp, pending, pending_sp)
    }
    return MainBody { .ops = ops, .local_count = local_count, .jump_table = table }
}

// Push the op for `cleaned` onto `ops`. Returns `true` if a known op
// was appended ; unknown lines (directives a sprint doesn't yet
// handle) are silently dropped so they don't shift pc indices.
try_push_op :: fn(cleaned: string, ops: Op[]) -> bool {
    return match parse_op_line(cleaned) {
        is null          -> false
        is I32Const as o -> { ops.push(o)  true }
        is LocalGet as o -> { ops.push(o)  true }
        is LocalSet as o -> { ops.push(o)  true }
        is I32Add   as o -> { ops.push(o)  true }
        is I32Sub   as o -> { ops.push(o)  true }
        is I32Mul   as o -> { ops.push(o)  true }
        is I32Div   as o -> { ops.push(o)  true }
        is I32Mod   as o -> { ops.push(o)  true }
        is I32Eq    as o -> { ops.push(o)  true }
        is I32Ne    as o -> { ops.push(o)  true }
        is I32Lt    as o -> { ops.push(o)  true }
        is I32Le    as o -> { ops.push(o)  true }
        is I32Gt    as o -> { ops.push(o)  true }
        is I32Ge    as o -> { ops.push(o)  true }
        is Block    as o -> { ops.push(o)  true }
        is Loop     as o -> { ops.push(o)  true }
        is If       as o -> { ops.push(o)  true }
        is Else     as o -> { ops.push(o)  true }
        is End      as o -> { ops.push(o)  true }
        is Br       as o -> { ops.push(o)  true }
        is BrIf     as o -> { ops.push(o)  true }
        is Return   as o -> { ops.push(o)  true }
    }
}

// Update the scope stack and the jump table for the op at `pc`. Called
// after `try_push_op` so the op is already appended.
wire_control_flow :: fn(
    cleaned: string, pc: i32, ops: Op[], table: i32[],
    scopes: ScopeEntry[], scope_sp_box: usize[],
    pending: PendingBr[], pending_sp_box: usize[],
) -> void {
    if cleaned.starts_with("block ") {
        push_scope(scopes, scope_sp_box, ScopeEntry { .label = first_token_after(cleaned, "block "), .is_loop = false, .opener_pc = pc })
    } else if cleaned.starts_with("loop ") {
        // Loop target is the start of its body (opener_pc + 1) — known
        // immediately, so we fill `table[pc]` up front.
        push_scope(scopes, scope_sp_box, ScopeEntry { .label = first_token_after(cleaned, "loop "), .is_loop = true, .opener_pc = pc })
        table[pc] = pc + 1
    } else if cleaned.starts_with("if ") {
        push_scope(scopes, scope_sp_box, ScopeEntry { .label = first_token_after(cleaned, "if "), .is_loop = false, .opener_pc = pc })
    } else if cleaned == "else" {
        // Find the open if scope (the topmost non-loop) ; its fall-
        // through target is the op past the else.
        sp :: scope_sp_box[0]
        if sp > 0 {
            top :: scopes[sp - 1]
            table[top.opener_pc] = pc + 1
            // Repurpose the same entry as an "else scope" so its
            // matching `end` pairs the else with the past-end pc.
            scopes[sp - 1] = ScopeEntry { .label = top.label, .is_loop = false, .opener_pc = pc }
        }
    } else if cleaned.starts_with("end") {
        sp :: scope_sp_box[0]
        if sp > 0 {
            top :: scopes[sp - 1]
            scope_sp_box[0] -= 1
            // Block/if/else fall-through target = past the end. Loops
            // don't fall through via the opener — their `table[opener]`
            // already points at the body start.
            if !top.is_loop && table[top.opener_pc] < 0 {
                table[top.opener_pc] = pc + 1
            }
            // Else entries (we repurposed the if's slot above) also
            // need their pc → past-end mapping.
            if !top.is_loop && top.opener_pc != pc {
                // top.opener_pc still points at the else's pc, fill it.
                if table[top.opener_pc] < 0 || table[top.opener_pc] == pc + 1 {
                    table[top.opener_pc] = pc + 1
                }
            }
            // Drain pending brs targeting this scope's label.
            drain_pending(pending, pending_sp_box, top.label, top.is_loop, top.opener_pc, pc, table)
        }
    } else if cleaned.starts_with("br ") {
        defer_or_resolve_br(cleaned, "br ", pc, scopes, scope_sp_box, pending, pending_sp_box, table)
    } else if cleaned.starts_with("br_if ") {
        defer_or_resolve_br(cleaned, "br_if ", pc, scopes, scope_sp_box, pending, pending_sp_box, table)
    }
}

push_scope :: fn(scopes: ScopeEntry[], sp_box: usize[], entry: ScopeEntry) -> void {
    sp :: sp_box[0]
    if sp == scopes.len() { scopes.push(entry) }
    else { scopes[sp] = entry }
    sp_box[0] += 1
}

// `br`/`br_if` to a loop label resolves immediately (loop start known).
// Branches to a block/if/else label are deferred until that scope's
// `end` is seen — they're appended to `pending`.
defer_or_resolve_br :: fn(
    cleaned: string, prefix: string, pc: i32,
    scopes: ScopeEntry[], scope_sp_box: usize[],
    pending: PendingBr[], pending_sp_box: usize[],
    table: i32[],
) -> void {
    label :: first_token_after(cleaned, prefix)
    sp :: scope_sp_box[0]
    // Find the matching scope by label from the top.
    i :: (i32)(sp) - 1
    found_idx := -1
    for i >= 0 {
        if scopes[(usize)(i)].label == label {
            found_idx = i
            i = -1                          // break
        } else {
            i -= 1
        }
    }
    if found_idx < 0 { return }             // unresolved — bytecode invariant
    target :: scopes[(usize)(found_idx)]
    if target.is_loop {
        table[pc] = target.opener_pc + 1
    } else {
        psp :: pending_sp_box[0]
        entry :: PendingBr { .br_pc = pc, .target_label = label }
        if psp == pending.len() { pending.push(entry) }
        else { pending[psp] = entry }
        pending_sp_box[0] += 1
    }
}

// When a scope ends, fill in every pending `br`/`br_if` that named it.
drain_pending :: fn(
    pending: PendingBr[], pending_sp_box: usize[],
    label: string, is_loop: bool, opener_pc: i32, end_pc: i32,
    table: i32[],
) -> void {
    psp :: pending_sp_box[0]
    new_sp := 0
    i := 0
    for i < (i32)(psp) {
        entry :: pending[(usize)(i)]
        if entry.target_label == label {
            if is_loop {
                table[entry.br_pc] = opener_pc + 1
            } else {
                table[entry.br_pc] = end_pc + 1
            }
        } else {
            pending[(usize)(new_sp)] = entry
            new_sp += 1
        }
        i += 1
    }
    pending_sp_box[0] = (usize)(new_sp)
}

// Returns `null` for unrecognised ops so the parser can keep going past
// directives a sprint doesn't yet handle.
parse_op_line :: fn(cleaned: string) -> Op | null {
    if cleaned.starts_with("i32.const ") {
        return parse_int_arg(cleaned, "i32.const ")
    }
    if cleaned.starts_with("local.get ") {
        return parse_slot_arg(cleaned, "local.get ", true)
    }
    if cleaned.starts_with("local.set ") {
        return parse_slot_arg(cleaned, "local.set ", false)
    }
    if cleaned == "i32.add" { return I32Add {} }
    if cleaned == "i32.sub" { return I32Sub {} }
    if cleaned == "i32.mul" { return I32Mul {} }
    if cleaned == "i32.div" { return I32Div {} }
    if cleaned == "i32.mod" { return I32Mod {} }
    if cleaned == "i32.eq"  { return I32Eq {} }
    if cleaned == "i32.ne"  { return I32Ne {} }
    if cleaned == "i32.lt"  { return I32Lt {} }
    if cleaned == "i32.le"  { return I32Le {} }
    if cleaned == "i32.gt"  { return I32Gt {} }
    if cleaned == "i32.ge"  { return I32Ge {} }
    if cleaned.starts_with("block ") { return Block {} }
    if cleaned.starts_with("loop ")  { return Loop  {} }
    if cleaned.starts_with("if ")    { return If    {} }
    if cleaned == "else"             { return Else  {} }
    if cleaned.starts_with("end")    { return End   {} }
    if cleaned.starts_with("br_if ") { return BrIf  {} }
    if cleaned.starts_with("br ")    { return Br    {} }
    if cleaned == "return"           { return Return {} }
    return null
}

parse_int_arg :: fn(line: string, prefix: string) -> Op | null {
    rest :: line.slice(prefix.byte_len(), line.byte_len()).trim()
    return match parse_int_in_base(rest, 10) {
        is i64 as n -> I32Const { .value = (i32)(n) }
        is Error    -> null
    }
}

parse_slot_arg :: fn(line: string, prefix: string, is_get: bool) -> Op | null {
    rest :: line.slice(prefix.byte_len(), line.byte_len()).trim()
    return match parse_int_in_base(rest, 10) {
        is i64 as n -> {
            if is_get { LocalGet { .slot = (i32)(n) } }
            else      { LocalSet { .slot = (i32)(n) } }
        }
        is Error -> null
    }
}
