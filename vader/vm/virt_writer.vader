// vader/vm/virt_writer — VM-side `.virt` text writer.
//
// A thin delegation to the canonical `vader/bytecode::dump_bytecode` (the exact
// inverse of `parse_virt_bc`). Kept as a `vader/vm` entry so VM-side callers
// (the builder round-trip smoke test) don't reach across into `vader/bytecode`
// directly, and so there is a SINGLE `BytecodeModule → .virt` serialiser — the
// previous standalone writer here duplicated `dump.vader` arm-for-arm.
//
// Limitation inherited from `dump_bytecode`: the data pool is not serialised
// (`dump.vader` emits `data.const` ops but no `data N …` directives). No
// current `write_virt` caller carries a data pool, so this is moot in practice ;
// completing `dump_bytecode`'s data-pool emission would lift it for both.

module "vader/vm"

bc :: import "vader/bytecode"

/// Render a `BytecodeModule` as `.virt` text. Resolves the entry directive from
/// the module's `is_main` fn so the dump is self-contained (round-trips through
/// `parse_virt_bc`), then defers to `dump_bytecode`.
///
/// @param module  the bytecode module to serialise.
/// @return        the `.virt` text dump (canonical form, trailing newline).
export write_virt :: fn(module: bc.BytecodeModule) -> string {
    entry := ""
    for f in module.functions {
        if f.is_main { entry = f.name }
    }
    return bc.dump_bytecode(module, entry)
}
