// vader/vm/host — host-import surface for the Vader-side VM.
//
// Every `call.import N` runs through `dispatch_import` here ; per-host
// arms unwrap the args from the caller stack, invoke the corresponding
// native stdlib intrinsic, and wrap the result back into an `Value`.
// The shape is a flat mangled-name cascade with trap-on-miss
// semantics. Lives in its own file (split out of
// `vader/vm/exec.vader` 2026-05-14) so the executor stays focused on
// the dispatch loop.

module "vader/vm"

bc :: import "vader/bytecode"

import "std/io" { read_file_bytes, write_file_bytes, exists, is_dir, read_dir, print, eprint, temp_dir, Stream }
import "std/env" { get_env }
import "std/tty" { is_tty }
import "std/process" { spawn_run, spawn_last_stdout, spawn_last_stderr }
import "std/math" { sqrt, pow, floor, ceil, round, sin, cos, tan }
import "std/time" { now, monotonic }
import "std/string" { trim }

/// Outcome of a successful host call. `value` is unused when the import
/// has `has_return == false` — the exec checks the import's signature
/// before pushing.
export HostCallResult :: HostOk | Trap
export HostOk :: struct { value: Value }

/// Pop two strings, run a binary predicate, wrap as `BoolVal`. Used
/// by `starts_with` / `ends_with` / `contains`.
host_str_pair_to_bool :: fn(stack: Value[], arg_base: usize, at_pc: i32, label: string, apply: fn(string, string) -> bool) -> HostCallResult {
    a :: read_string(stack[arg_base    ], at_pc, "${label} receiver")
    b :: read_string(stack[arg_base + 1], at_pc, "${label} arg")
    if a is Trap { return a }
    if b is Trap { return b }
    return HostOk { .value = BoolVal { .value = apply(a.value, b.value) } }
}

/// One f64 arg → one f64 result. Used by `std/math` unary intrinsics
/// (`sqrt` / `floor` / `ceil` / `round` / `abs`).
host_f64_unary :: fn(stack: Value[], arg_base: usize, at_pc: i32, label: string, apply: fn(f64) -> f64) -> HostCallResult {
    a :: read_f64(stack[arg_base], at_pc, label)
    if a is Trap { return a }
    return HostOk { .value = F64Val { .value = apply(a.value) } }
}

/// Two f64 args → one f64 result. Used by `std/math` binary intrinsics
/// (`pow` / `min` / `max`).
host_f64_binary :: fn(stack: Value[], arg_base: usize, at_pc: i32, label: string, apply: fn(f64, f64) -> f64) -> HostCallResult {
    a :: read_f64(stack[arg_base    ], at_pc, "${label} arg 0")
    b :: read_f64(stack[arg_base + 1], at_pc, "${label} arg 1")
    if a is Trap { return a }
    if b is Trap { return b }
    return HostOk { .value = F64Val { .value = apply(a.value, b.value) } }
}

/// Two integer args → bool. Reads both via `read_i64` (widening `I32Val`), so
/// it covers every integer width ; equality on the i64 bit pattern is correct
/// for signed and unsigned alike.
host_int_pair_to_bool :: fn(stack: Value[], arg_base: usize, at_pc: i32, label: string, apply: fn(i64, i64) -> bool) -> HostCallResult {
    a :: read_i64(stack[arg_base    ], at_pc, "${label} receiver")
    b :: read_i64(stack[arg_base + 1], at_pc, "${label} arg")
    if a is Trap { return a }
    if b is Trap { return b }
    return HostOk { .value = BoolVal { .value = apply(a.value, b.value) } }
}

/// Dispatch a host import. Matches on `intrinsic_id_for(info.mangled_name)`
/// (the single manifest classification) — every arm pops the args from
/// `stack[arg_base ..]`, executes the host action, and returns either
/// `HostOk { value }` (the result pushed onto the caller's value stack) or a
/// `Trap` (surfaced verbatim). Hosts the VM doesn't serve (native-only C shims)
/// and non-intrinsics fall through the grouped arm to the unbound `Trap`.
///
/// @param info      the import descriptor (mangled name + signature).
/// @param stack     caller value stack — args live at `[arg_base ..]`.
/// @param arg_base  cursor of the first arg in `stack`.
/// @param gc_state  1-element box for the `std/runtime` collection
///                  counter — `collect` bumps `[0]`, `collections`
///                  reads it.
/// @param at_pc     pc of the calling `call.import` op, used for Trap
///                  diagnostics only.
/// @param string_array_type_id  the module's `string[]` ArrayType index
///                  (see `find_string_array_type_id`), stamped onto the
///                  arrays returned by `split` / `read_dir` so they narrow
///                  to `is string[]` in their `string[] | Error` union return.
/// @param u8_array_type_id  the module's `u8[]` ArrayType index (see
///                  `find_u8_array_type_id`), stamped onto the array `bytes`
///                  materialises so it narrows to `is u8[]`.
/// @return          `HostOk { value }` on success ; `Trap` on a missing
///                  import, malformed arg, or host-level failure.
export dispatch_import :: fn(info: bc.BcImport, stack: Value[], arg_base: usize, gc_state: usize[], at_pc: i32, string_array_type_id: i32, u8_array_type_id: i32) -> HostCallResult {
    match bc.intrinsic_id_for(info.mangled_name) {
    .IoWrite -> {
        // arg_base + 0 : Stream tag ; arg_base + 1 : the string payload.
        STDOUT :: i32(0)
        STDERR :: i32(1)
        tag :: read_i32(stack[arg_base], at_pc, "write stream")
        if tag is Trap { return tag }
        msg :: read_string(stack[arg_base + 1], at_pc, "write msg")
        if msg is Trap { return msg }
        if tag.value == STDOUT {
            print(msg.value)
        } else if tag.value == STDERR {
            eprint(msg.value)
        } else {
            return Trap { .message = "write at pc=${at_pc}: invalid Stream tag ${tag.value}" }
        }
        return HostOk { .value = zero_value() }
    }
    // ---- std/string family ----------------------------------------------
    .StringByteLen -> {
        // Internal fold target — `s.bytes().len()` lowers to a std_string$byte_len
        // import. The body's own `.bytes().len()` folds to the native byte_len.
        s :: read_string(stack[arg_base], at_pc, "byte_len")
        if s is Trap { return s }
        return HostOk { .value = I32Val { .value = i32(s.value.bytes().len()) } }
    }
    .CoreBytesToString -> {
        // bytes→string : the VM gathers the boxed u8 slots into a real `u8[]` and
        // lets the native intern them verbatim (no UTF-8 validation). Native
        // O(1)-reinterprets a borrowed slice.
        arr :: read_array(stack[arg_base], at_pc, "bytes_to_string receiver")
        if arr is Trap { return arr }
        raw: u8[] = []
        for i in 0..<arr.length {
            b :: read_i32(arr.elements[arr.offset + i], at_pc, "bytes_to_string byte")
            if b is Trap { return b }
            raw.push(u8(b.value))
        }
        return HostOk { .value = StringVal { .value = raw.bytes_to_string() } }
    }
    .CoreBytes -> {
        // Native zero-copies a `const u8[]` view ; the VM materialises a copy
        // (boxed slots can't alias the interned bytes) — same values.
        s :: read_string(stack[arg_base], at_pc, "bytes receiver")
        if s is Trap { return s }
        return HostOk { .value = bytes_to_value(s.value, u8_array_type_id) }
    }
    .CoreStringHash -> {
        // String `Hash` reads the FNV-1a-64 cached on the interned atom. Calling
        // `.hash()` on the Vader string here lowers to the native
        // `vader_string_hash` intrinsic in the VM's own build, so the VM and
        // native produce identical hashes for the same atom. u64 rides in I64Val.
        s :: read_string(stack[arg_base], at_pc, "hash receiver")
        if s is Trap { return s }
        return HostOk { .value = I64Val { .value = i64(s.value.hash()) } }
    }
    // `StringBuilder implements Display` moved to pure Vader in Target ABI S3 ;
    // the resolver materialises its body (a byte-Buffer read + `bytes_to_string`),
    // so the VM runs a real fn — there is no host shim to dispatch here.
    .CoreStringIndexAt -> {
        s :: read_string(stack[arg_base    ], at_pc, "string[] receiver")
        i :: read_i32   (stack[arg_base + 1], at_pc, "string[] index")
        if s is Trap { return s }
        if i is Trap { return i }
        // Walk UTF-8 until the `i`-th codepoint, then decode it. OOB
        // returns U+0000 in the VM ; the native runtime traps instead.
        sb :: s.value.bytes()
        target :: usize(i.value)
        cursor: usize = 0
        seen:   usize = 0
        n :: sb.len()
        for cursor < n {
            [cp, width] :: sb.decode_codepoint_at(cursor)
            if seen == target { return HostOk { .value = CharVal { .value = cp } } }
            cursor = cursor + width
            seen   = seen + 1
        }
        return HostOk { .value = CharVal { .value = char(0) } }
    }
    // ---- std/core Display + Equals intrinsics ----------------------------
    // `string implements Hash` is now pure Vader (FNV-1a-64 over `bytes()`,
    // `std/core/primitives.vader`) — the host arm + the old 31-bit `fnv1a31_low`
    // were retired (S6) so a single hash function is live across VM + native.
    // `@intrinsic string implements Equals` — structural string compare.
    // Reached when map key lookups dispatch `key.equals(other)` virtually
    // (the virtual.call intrinsic fallback in exec.vader rebuilds this mangle).
    .CoreStringEquals -> {
        return host_str_pair_to_bool(stack, arg_base, at_pc, "equals", (a, b) -> a == b)
    }
    .CoreStringNotEquals -> {
        return host_str_pair_to_bool(stack, arg_base, at_pc, "not_equals", (a, b) -> a != b)
    }
    // `@intrinsic <intwidth> implements Equals` — bodyless for every integer
    // width, so an erased map-key lookup (`MutableMap<Any, K>` with integer K)
    // dispatches `key.equals(other)` virtually and surfaces it as a host import
    // (mirror of the string arms above). Reached e.g. by `MutableSet<i32>`.
    .PrimIntEquals -> {
        return host_int_pair_to_bool(stack, arg_base, at_pc, "equals", (a: i64, b: i64) -> a == b)
    }
    .PrimIntNotEquals -> {
        return host_int_pair_to_bool(stack, arg_base, at_pc, "not_equals", (a: i64, b: i64) -> a != b)
    }
    // `<width> implements Display.to_string` for every primitive — the
    // VM emits the SPEC §9 canonical form via `display_value`. Width
    // doesn't matter at runtime (every integer collapses to `I32Val`),
    // so a single arm covers all the per-width manglings.
    .PrimDisplayToString -> {
        // `u32` / `u64` / `usize` literals exceeding `i64.MAX` ride the
        // same `I64Val` carrier as signed `i64`. Default `display_value`
        // renders that bit pattern as signed i64 (e.g. `-9551616` instead
        // of `18446744073700000000`). The lower pass routes wide
        // unsigned interpolations through this dispatch — recover the
        // unsigned form by reinterpreting the bit pattern.
        if bc.is_unsigned_display(info.mangled_name) {
            v :: stack[arg_base]
            // @partial: integer carriers reinterpret as unsigned; other tags trap.
            return @partial match v {
                is I64Val as i -> HostOk { .value = StringVal { .value = u64(i.value).to_string() } }
                is I32Val as i -> HostOk { .value = StringVal { .value = u64(u32(i.value)).to_string() } }
                // Any other Value tag means the lowerer routed a non-
                // integer through `<u_width>$Display$to_string`. Trap
                // loudly so the regression surfaces here instead of as a
                // mysteriously wrong rendering.
                _ -> Trap { .message = "${info.mangled_name} at pc=${at_pc}: expected integer Value, got ${describe_value_tag(v)}" }
            }
        }
        return HostOk { .value = StringVal { .value = display_value(stack[arg_base]) } }
    }
    // ---- std/runtime collection counters ---------------------------------
    // The Vader VM has no GC arena ; the snippet tests just need the
    // counter to be present + monotonic. `collect` bumps it, `collections`
    // returns the current value, `bytes_used` / `bytes_copied` stay at
    // zero (no real arena to measure).
    .RuntimeCollect -> {
        gc_state[0] = gc_state[0] + 1
        return HostOk { .value = NullVal {} }
    }
    .RuntimeCollections -> { return HostOk { .value = I32Val { .value = i32(gc_state[0]) } } }
    .RuntimeBytesUsed   -> { return HostOk { .value = I32Val { .value = 0 } } }
    .RuntimeBytesCopied -> { return HostOk { .value = I32Val { .value = 0 } } }
    // ---- std/time --------------------------------------------------------
    // `now_unix_ms` / `monotonic_ns` are module-private in std/time now ; reach
    // the native clock through the public `now()` / `monotonic()` (this host is
    // native, so these are native calls — no VM re-dispatch, no recursion).
    .TimeNowUnixMs   -> { return HostOk { .value = I64Val { .value = i64(now()) / 1_000_000 } } }
    .TimeMonotonicNs -> { return HostOk { .value = I64Val { .value = i64(monotonic()) } } }
    // ---- std/math --------------------------------------------------------
    .MathSqrt  -> { return host_f64_unary(stack, arg_base, at_pc, "sqrt",  (a) -> sqrt(a)) }
    .MathSin   -> { return host_f64_unary(stack, arg_base, at_pc, "sin",   (a) -> sin(a)) }
    .MathCos   -> { return host_f64_unary(stack, arg_base, at_pc, "cos",   (a) -> cos(a)) }
    .MathTan   -> { return host_f64_unary(stack, arg_base, at_pc, "tan",   (a) -> tan(a)) }
    .MathFloor -> { return host_f64_unary(stack, arg_base, at_pc, "floor", (a) -> floor(a)) }
    .MathCeil  -> { return host_f64_unary(stack, arg_base, at_pc, "ceil",  (a) -> ceil(a)) }
    .MathRound -> { return host_f64_unary(stack, arg_base, at_pc, "round", (a) -> round(a)) }
    .MathPow   -> { return host_f64_binary(stack, arg_base, at_pc, "pow", (a, b) -> pow(a, b)) }
    .StringParseFloat -> {
        s :: read_string(stack[arg_base], at_pc, "parse_float")
        if s is Trap { return s }
        trimmed :: s.value.trim()
        if trimmed.bytes().len() == 0 { return HostOk { .value = ErrorVal { .message = "parse_float: empty string" } } }
        parsed :: parse_decimal_f64(trimmed)
        if parsed is null { return HostOk { .value = ErrorVal { .message = "parse_float: invalid float '${trimmed}'" } } }
        return HostOk { .value = F64Val { .value = parsed } }
    }
    // ---- std/io fallible file ops ---------------------------------------
    // `read_file` / `write_file` are gone — `read_file_string` /
    // `write_file_string` are now pure-Vader wrappers over the byte
    // intrinsics below, so the VM executes their bytecode directly (which
    // calls `std_io$read_file_bytes` / `std_io$write_file_bytes`) — no
    // dedicated host arm.
    .IoReadFileBytes -> {
        path :: read_string(stack[arg_base], at_pc, "read_file_bytes")
        if path is Trap { return path }
        result :: read_file_bytes(path.value)
        // Early-return narrows `result` to `u8[]` on the success path. The
        // bytes are boxed as `u8` slots (riding in `I32Val`) tagged so they
        // narrow under `is u8[]` — mirrors the `bytes` arm above.
        if result is Error {
            return HostOk { .value = ErrorVal { .message = "read_file_bytes failed: ${path.value}" } }
        }
        return HostOk { .value = u8_array_to_value(result, u8_array_type_id) }
    }
    .IoWriteFileBytes -> {
        path :: read_string(stack[arg_base], at_pc, "write_file_bytes path")
        if path is Trap { return path }
        arr :: read_array(stack[arg_base + 1], at_pc, "write_file_bytes content")
        if arr is Trap { return arr }
        content: u8[] = [] * arr.length
        for i in 0..<arr.length {
            b :: read_i32(arr.elements[arr.offset + i], at_pc, "write_file_bytes byte")
            if b is Trap { return b }
            content.push(u8(b.value))
        }
        result :: write_file_bytes(path.value, content)
        if result is Error { return HostOk { .value = ErrorVal { .message = "write_file_bytes failed: ${path.value}" } } }
        return HostOk { .value = NullVal {} }
    }
    .IoExists -> {
        path :: read_string(stack[arg_base], at_pc, "exists")
        if path is Trap { return path }
        return HostOk { .value = BoolVal { .value = exists(path.value) } }
    }
    .IoIsDir -> {
        path :: read_string(stack[arg_base], at_pc, "is_dir")
        if path is Trap { return path }
        return HostOk { .value = BoolVal { .value = is_dir(path.value) } }
    }
    .IoTempDir -> {
        return HostOk { .value = StringVal { .value = temp_dir() } }
    }
    .IoReadDir -> {
        path :: read_string(stack[arg_base], at_pc, "read_dir")
        if path is Trap { return path }
        // `read_dir` returns `string[] | Error`. The early-return
        // guard narrows `result` to the array on the success path. Needed by
        // the resolver's module discovery (vader/resolver/discover.vader) when
        // the compiler runs itself through the VM.
        result :: read_dir(path.value)
        if result is Error {
            return HostOk { .value = ErrorVal { .message = "read_dir failed: ${path.value}" } }
        }
        return HostOk { .value = string_array_to_value(result, string_array_type_id) }
    }
    // ---- std/process spawn ----------------------------------------------
    .ProcessSpawnRun -> {
        argv :: read_array(stack[arg_base], at_pc, "spawn_run argv")
        if argv is Trap { return argv }
        argv_strings: string[] = []
        for i in 0..<argv.length {
            element :: read_string(argv.elements[argv.offset + i], at_pc, "spawn_run argv element")
            if element is Trap { return element }
            argv_strings.push(element.value)
        }
        code :: spawn_run(argv_strings)
        return HostOk { .value = I32Val { .value = code } }
    }
    .ProcessSpawnLastStdout -> {
        return HostOk { .value = StringVal { .value = spawn_last_stdout() } }
    }
    .ProcessSpawnLastStderr -> {
        return HostOk { .value = StringVal { .value = spawn_last_stderr() } }
    }
    // ---- std/tty + std/env ----------------------------------------------
    .TtyIsTty -> {
        tag :: read_i32(stack[arg_base], at_pc, "is_tty stream")
        if tag is Trap { return tag }
        stream :: if tag.value == 1 { Stream.Stderr } else { Stream.Stdout }
        return HostOk { .value = BoolVal { .value = is_tty(stream) } }
    }
    .EnvGetEnv -> {
        name :: read_string(stack[arg_base], at_pc, "get_env name")
        if name is Trap { return name }
        value :: get_env(name.value)
        if value == null { return HostOk { .value = NullVal {} } }
        return HostOk { .value = StringVal { .value = value } }
    }
    // ---- std/abort -------------------------------------------------------
    .AbortPanic -> {
        message :: read_string(stack[arg_base], at_pc, "panic")
        if message is Trap { return message }
        return Trap { .message = "vader: panic — ${message.value}" }
    }
    // Hosts served natively (C shims) but not by the VM, plus non-intrinsics —
    // grouped so a new IntrinsicId variant still trips T3013 here.
    .IoReadLine | .IoReadStdin | .IoPollStdin | .IoSetStdinUnbuffered
        | .IoCurrentExecutableLocation | .NotIntrinsic -> {}
    }
    return Trap { .message = "unbound host import '${info.mangled_name}' at pc=${at_pc}" }
}

