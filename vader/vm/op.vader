// vader/vm/op — bytecode op shapes shared by `parser.vader` and `exec.vader`.
//
// One variant per supported op kind. The union grows sprint by sprint
// in lock-step with the acceptance snippets (docs/SELFHOST_VM.md).
// Control-flow ops (`If`, `Else`, `End`, `Branch`, `BranchIf`) carry
// no operand here — their target pc lives in `BytecodeFunction.jump_table[pc]`.

module "vader/vm"

import "std/string_builder" { StringBuilder, new_builder, append }

/// The full op set understood by the Vader-side VM. Each variant is
/// pure data — the executor's `match` arms in `exec.vader` carry the
/// semantics. New ops are appended (never reshaped), so the existing
/// pattern-match arms keep compiling across sprints.
export Op :: I32Const
    | LocalGet
    | LocalSet
    | LocalTee
    | StringConst
    | NullConst
    | BoolConst
    | CharConst
    | F64Const
    | I64Const
    | CallImport
    | Call
    | FnRef
    | MakeClosure
    | CallIndirect
    | VirtualCall
    | StructNew
    | StructGet
    | StructSet
    | LocalField
    | ArrayNew
    | ArrayPush
    | ArrayGet
    | ArraySet
    | ArrayLen
    | ArraySlice
    | DataConst
    | RefCast
    | Convert
    | TypeCheck
    | TypeConst
    | DeferPush
    | DeferPopExec
    | BuilderNew
    | BuilderAppendStr
    | BuilderAppendDisplay
    | BuilderFinish
    | SizeOfType
    | I32Add
    | I32Sub
    | I32Mul
    | I32Div
    | I32Mod
    | I32Eq
    | I32Ne
    | I32Lt
    | I32Le
    | I32Gt
    | I32Ge
    | I32Neg
    | I32BitNot
    | I32BitAnd
    | I32BitOr
    | I32BitXor
    | I32Shl
    | I32Shr
    | I32ShrU
    | U32Div
    | U32Mod
    | U32Lt
    | U32Le
    | U32Gt
    | U32Ge
    | I64Add
    | I64Sub
    | I64Mul
    | I64Div
    | I64Mod
    | I64Neg
    | I64Eq
    | I64Ne
    | I64Lt
    | I64Le
    | I64Gt
    | I64Ge
    | U64Div
    | U64Mod
    | U64Lt
    | U64Le
    | U64Gt
    | U64Ge
    | I64Shl
    | I64Shr
    | I64ShrU
    | I64BitAnd
    | I64BitOr
    | I64BitXor
    | I64BitNot
    | F64Add
    | F64Sub
    | F64Mul
    | F64Div
    | F64Neg
    | F64Eq
    | F64Ne
    | F64Lt
    | F64Le
    | F64Gt
    | F64Ge
    | BoolEq
    | BoolNe
    | BoolAnd
    | BoolOr
    | BoolNot
    | CharEq
    | CharNe
    | CharLt
    | CharLe
    | CharGt
    | CharGe
    | StringEq
    | StringNe
    | StringConcat
    | IntToChar
    | CharToInt
    | RefEq
    | RefNe
    | Drop
    | Block
    | Loop
    | If
    | Else
    | End
    | Branch
    | BranchIf
    | Return
    | ReturnLit

/// Push a constant i32 onto the value stack.
export I32Const :: struct { value: i32 }
/// Read `slots[slot]` onto the value stack.
export LocalGet :: struct { slot: i32 }
/// Pop the value stack into `slots[slot]`.
export LocalSet :: struct { slot: i32 }
/// Write the top of the value stack into `slots[slot]` *without*
/// popping — useful when the bytecode wants both side-effect and the
/// value still available (e.g. just after `struct.new_stack`).
export LocalTee :: struct { slot: i32 }
/// Push `module.strings[index]` onto the value stack.
export StringConst :: struct { index: i32 }
/// Push the singleton `NullVal` (the runtime `null`). Sprint 5a addition.
export NullConst :: struct {}
/// Push a `BoolVal { value }`. Sprint 5a addition.
export BoolConst :: struct { value: bool }
/// Push a `CharVal { value }`. The codepoint is parsed from the .virt
/// as a base-10 integer (u32 range) and stored as a `char`. Sprint 5a.
export CharConst :: struct { value: char }
/// Invoke a host-side import (e.g. `println`) — `index` keys into `module.imports`.
export CallImport :: struct { index: i32 }
/// Invoke a Vader-side function — `function_index` keys into `module.functions`.
/// Sprint 4 (a) addition : the executor pops `parameter_count` values
/// from the caller's stack, builds a new `Frame`, and pushes it.
export Call :: struct { function_index: i32 }

/// Push a function reference (`FnVal`) for `function_index`. Used when
/// a fn is stored in a struct field, passed as an argument, or bound to
/// a local. Sprint 4 (b4) addition ; the resulting `FnVal.env` is
/// always `null` — closures with captured state come from `MakeClosure`.
export FnRef :: struct { function_index: i32 }

/// Build a closure : pop an `env` value (typically a `StructVal`
/// carrying the captured cells) and push a `FnVal { function_index, env }`.
/// The lifted fn's signature has an extra leading `env` parameter ;
/// `CallIndirect` prepends `env` as `slot 0` when invoking. `type_id`
/// is informational (mirrors `fn.ref`'s static-type hint). Sprint 4 (b5)
/// addition.
export MakeClosure :: struct { function_index: i32 }

/// Invoke a function through a `FnVal` on top of the value stack.
/// `type_id` indexes into `module.types` and resolves to a `FnType`
/// whose `parameter_type_ids.len()` tells the executor how many
/// **user-visible** args to pop from the caller stack ; if the popped
/// `FnVal` carries a non-`null` `env`, the executor prepends it as
/// `slot 0` before binding the user args (matching how the lifted
/// closure body expects them). Sprint 4 (b4) addition ; (b5) added the
/// env-prepend path.
export CallIndirect :: struct { type_id: i32 }

/// Trait-method virtual dispatch — pops the receiver from the top of
/// the stack, looks up its type id in the per-(trait, method) vtable
/// keyed by `vtable_key` (format `"<TraitName>.<MethodName>"`), then
/// invokes the resolved fn with `[receiver, ...args]`. `parameter_count`
/// includes the receiver — so the executor pops `parameter_count - 1`
/// user args plus the receiver itself. Mirrors `src/vm/exec.ts:306-330`.
/// Sprint 6 addition.
export VirtualCall :: struct { parameter_count: i32, vtable_key: string }

/// Allocate a struct of type `type_id`. Pops `field_count` values (in
/// field-declaration order) from the value stack and wraps them in a
/// `StructVal`. The bytecode pipeline emits two variants — `struct.new`
/// and `struct.new_stack` — that share this VM op : the heap/stack
/// distinction is a codegen concern, not a runtime one (TS VM
/// `src/vm/exec.ts` collapses both cases too). Sprint 4 (b1) addition.
export StructNew :: struct { type_id: i32 }
/// Pop a `StructVal`, push `struct.fields[field_index]`. `type_id` is
/// kept for diagnostics (the executor traps if the popped value's
/// tag doesn't match). Sprint 4 (b1) addition.
export StructGet :: struct { type_id: i32, field_index: i32 }
/// Pop the new field value, then the struct ; mutate `struct.fields[
/// field_index]` to the new value. Statement-form — no value pushed
/// back. Mirrors `StructNew` in collapsing the heap/stack variants
/// (`struct.set` / `struct.set_stack`) into one VM op. Sprint 4 (b1).
export StructSet :: struct { type_id: i32, field_index: i32 }
/// Fused `local.get N ; struct.get T F`. Reads `slots[slot]`, expects
/// a `StructVal`, pushes its `fields[field_index]`.
export LocalField :: struct { slot: i32, type_id: i32, field_index: i32 }

/// Allocate an `ArrayVal` of type `type_id`. If `length > 0`, pops
/// `length` initial elements from the value stack (in caller-push
/// order — first pushed becomes `elements[0]`) and uses them as the
/// initial contents ; if `length == 0`, creates a fresh empty array
/// ready for `array.push`. Sprint 4 (b2) addition.
export ArrayNew :: struct { type_id: i32, length: i32 }
/// Pop a value, then an array ; append the value to `array.elements`.
/// Statement-form, no value pushed back. Sprint 4 (b2) addition.
export ArrayPush :: struct { type_id: i32 }
/// Pop an index (i32) and an array ; push `array.elements[index]`.
/// Traps on out-of-bounds index. Sprint 4 (b2) addition.
export ArrayGet :: struct { type_id: i32 }
/// Pop the new element value, an index, and an array ; mutate
/// `array.elements[index]` in place. Statement-form, no push back.
/// Sprint 4 (b2) addition.
export ArraySet :: struct { type_id: i32 }
/// Pop an array, push its element count (approximated as an i32 ;
/// the TS VM pushes a usize but our `Value` doesn't carry width tags).
/// Sprint 4 (b2) addition.
export ArrayLen :: struct {}

/// Zero-copy slice : pops `arr` / `lo` / `hi` from the stack ; pushes a
/// fresh array header that shares `arr.elements` semantically. On the
/// self-host VM the underlying storage is `Value[]` so the slice copies
/// (no shared mutability) ; the C runtime version views.
export ArraySlice :: struct { type_id: i32 }

/// Push the pre-materialised array at `module.data_pool[pool_index]`.
/// `type_id` is the BcType index of the resulting `const T[]` array.
/// The pool is built once at module-load time (parser materialises
/// each `data N <kind> hex"..."` directive into an `ArrayVal`) ; this
/// op is the runtime read for `const T[]` literals routed to .rodata
/// by the bytecode emitter.
export DataConst :: struct { pool_index: i32, type_id: i32 }

/// No-op runtime cast — the .virt format emits `ref.cast TID` after
/// every `array.get` / `struct.get` to narrow the static type from
/// `ref` to a concrete element type. Our VM's Values already carry
/// their concrete tag, so the cast is purely informational ; the op's
/// type_id operand is intentionally dropped at parse time. Sprint 4
/// (b2) addition (mirrors `src/vm/exec.ts` which also bumps pc).
export RefCast :: struct {}

/// Numeric width conversion. The .virt format emits `<from>.to_<to>`
/// at every cast site ; `target` carries enough info to re-tag the
/// stack value to the right storage class (I32Val / I64Val / F64Val /
/// CharVal) so downstream typed ops (`f64.div`, `u32.shl`, …) find a
/// matching tag.
export Convert :: struct { target: ConvertTarget }

/// Storage class for a numeric conversion target. Mirrors the VM's
/// runtime tagging : every 8/16/32-bit integer collapses to `I32Val`,
/// every 64-bit-wide integer to `I64Val`, every float to `F64Val`.
export ConvertTarget :: enum(u8) {
    I32
    I64
    F64
    Char
}

/// Pop one value and push a `BoolVal` indicating whether its runtime
/// type matches `module.types[type_id]`. Mirrors `src/vm/exec.ts`'s
/// `type_check` op ; recurses through `UnionType` variants. Drives
/// `match` arm dispatch and `if x is T` narrowing. Sprint 5b addition.
export TypeCheck :: struct { type_id: i32 }

/// Push a `TypeVal { type_id }` — the runtime reification of a `type`
/// value. Emitted when a `TypeMeta`-typed ident reaches value position
/// (`@type_of(x)`, `let m : type = i32`, etc.). Layer 4 §1.19 B.1.
export TypeConst :: struct { type_id: i32 }

/// Pop a closure (fn ref + env) and append it to the current frame's
/// defer-stack. Drained later by `DeferPopExec` on normal exits or by
/// the panic-unwind walker around `exec` when an op traps. A8 single-
/// track defer model — see TS counterpart at `src/bytecode/ops.ts`
/// `kind: "defer.push"`.
export DeferPush :: struct {}

/// Pop and execute the last `count` entries on the current frame's
/// defer-stack (LIFO). Emitted by the lowerer at every normal exit
/// (return / break / continue / block fall-through) — the `count`
/// matches the number of defers introduced in the scopes the exit
/// transcends.
export DeferPopExec :: struct { count: i32 }

/// Allocate a fresh empty `BuilderVal` and push it onto the value stack.
/// Sprint 4 (b3) addition — backs Vader's `"${...}"` string interpolation
/// (the lowerer emits builder.new → append_str / append_display ... →
/// builder.finish for every interpolated string literal).
export BuilderNew :: struct {}
/// Pop a string then a builder ; append the string to `builder.parts`.
/// Statement-form, no push back. Sprint 4 (b3) addition.
export BuilderAppendStr :: struct {}
/// Pop a value then a builder ; format the value through `display_value`
/// (recursive for struct/array) and append the result to `builder.parts`.
/// Statement-form, no push back. Sprint 4 (b3) addition.
export BuilderAppendDisplay :: struct {}
/// Pop a builder ; concatenate `builder.parts` into a single `string`
/// and push it. Sprint 4 (b3) addition.
export BuilderFinish :: struct {}
/// Pop a `TypeVal` ; push a `usize` carrying the byte size of the type
/// at `module.types[type_id]`. Backs the runtime path of `@size_of(t)`.
/// Layer 4 §1.19 B.2.
export SizeOfType :: struct {}
/// Pop two i32 (left, right) ; push left + right.
export I32Add :: struct {}
/// Pop two i32 (left, right) ; push left - right.
export I32Sub :: struct {}
/// Pop two i32 (left, right) ; push left * right.
export I32Mul :: struct {}
/// Pop two i32 (left, right) ; push left / right. Traps on right == 0.
export I32Div :: struct {}
/// Pop two i32 (left, right) ; push left % right. Traps on right == 0.
export I32Mod :: struct {}
/// Pop two i32 ; push `1` if equal, `0` otherwise.
export I32Eq :: struct {}
/// Pop two i32 ; push `1` if not equal, `0` otherwise.
export I32Ne :: struct {}
/// Pop two i32 (left, right) ; push `1` if left < right, `0` otherwise.
export I32Lt :: struct {}
/// Pop two i32 (left, right) ; push `1` if left <= right, `0` otherwise.
export I32Le :: struct {}
/// Pop two i32 (left, right) ; push `1` if left > right, `0` otherwise.
export I32Gt :: struct {}
/// Pop two i32 (left, right) ; push `1` if left >= right, `0` otherwise.
export I32Ge :: struct {}
/// Push a constant f64 onto the value stack. The .virt format encodes
/// the literal in decimal with optional fraction (`f64.const 3.5`).
export F64Const :: struct { value: f64 }
/// Push a constant i64 onto the value stack.
export I64Const :: struct { value: i64 }
/// I64 arithmetic + comparison ops mirroring the I32 family.
export I64Add :: struct {}
export I64Sub :: struct {}
export I64Mul :: struct {}
export I64Div :: struct {}
export I64Mod :: struct {}
export I64Neg :: struct {}
export I64Eq :: struct {}
export I64Ne :: struct {}
export I64Lt :: struct {}
export I64Le :: struct {}
export I64Gt :: struct {}
export I64Ge :: struct {}
/// Unsigned 64-bit divide. Pops two i64-tagged values carrying a u64 bit
/// pattern, divides as u64, pushes the i64-tagged quotient.
export U64Div :: struct {}
/// Unsigned 64-bit modulo. Mirrors `U64Div`.
export U64Mod :: struct {}
/// Unsigned 64-bit less-than. Pops two i64-tagged values carrying a u64
/// bit pattern, pushes a `BoolVal` of the unsigned compare. The VM
/// aliases u64 onto `I64Val` ; signed I64Lt would read e.g. SHA-256
/// round constants (high bit set) as negative and miscompare.
export U64Lt  :: struct {}
/// Unsigned 64-bit ≤. See `U64Lt`.
export U64Le  :: struct {}
/// Unsigned 64-bit >. See `U64Lt`.
export U64Gt  :: struct {}
/// Unsigned 64-bit ≥. See `U64Lt`.
export U64Ge  :: struct {}
/// 64-bit shift-left. Distinct from `I32Shl` so wide-width operands
/// don't silently truncate to the low 32 bits via the I32 path's
/// i32-typed apply closure (`u64.shl 32` on a 32-bit register is
/// shift-by-≥-width and wraps).
export I64Shl    :: struct {}
/// 64-bit arithmetic shift-right (sign-extending). Pairs with `I64Shl`.
export I64Shr    :: struct {}
/// 64-bit logical shift-right (zero-filling). Used by unsigned-width
/// source ops (`u64.shr`, `usize.shr`).
export I64ShrU   :: struct {}
/// 64-bit bitwise AND. Distinct from `I32BitAnd` so wide-width masks
/// keep their high bits (e.g. `bit_len & 0xFFFF_FFFF_FFFF_FFFF_u64`).
export I64BitAnd :: struct {}
/// 64-bit bitwise OR.
export I64BitOr  :: struct {}
/// 64-bit bitwise XOR.
export I64BitXor :: struct {}
/// 64-bit bitwise NOT. Same shape as `I32BitNot` but on i64-tagged
/// operands.
export I64BitNot :: struct {}
/// Pop two f64 (left, right) ; push `left + right` as F64Val.
export F64Add :: struct {}
/// Pop two f64 (left, right) ; push `left - right` as F64Val.
export F64Sub :: struct {}
/// Pop two f64 (left, right) ; push `left * right` as F64Val.
export F64Mul :: struct {}
/// Pop two f64 (left, right) ; push `left / right` as F64Val.
export F64Div :: struct {}
/// Pop one f64 ; push `-value`.
export F64Neg :: struct {}
/// Pop two f64 ; push `BoolVal` for ordered equality.
export F64Eq :: struct {}
/// Pop two f64 ; push `BoolVal` for ordered inequality.
export F64Ne :: struct {}
/// Pop two f64 (left, right) ; push `BoolVal` for `left < right`.
export F64Lt :: struct {}
/// Pop two f64 (left, right) ; push `BoolVal` for `left <= right`.
export F64Le :: struct {}
/// Pop two f64 (left, right) ; push `BoolVal` for `left > right`.
export F64Gt :: struct {}
/// Pop two f64 (left, right) ; push `BoolVal` for `left >= right`.
export F64Ge :: struct {}

// The seven ops below are width-aliased : every integer-width sibling
// (`isize.neg`, `u32.bitand`, ...) collapses onto its `I32X` variant
// because the VM aliases every integer width to `I32Val`. See
// `is_int_op` in `vader/vm/parser.vader` for the parser-side collapse.
/// Pop one i32 ; push `-value`.
export I32Neg :: struct {}
/// Pop one i32 ; push `~value`.
export I32BitNot :: struct {}
/// Pop two i32 (left, right) ; push `left & right`.
export I32BitAnd :: struct {}
/// Pop two i32 (left, right) ; push `left | right`.
export I32BitOr :: struct {}
/// Pop two i32 (left, right) ; push `left ^ right`.
export I32BitXor :: struct {}
/// Pop two i32 (left, right) ; push `left << right`.
export I32Shl :: struct {}
/// Pop two i32 (left, right) ; push `left >> right` (arithmetic shift —
/// preserves the sign bit). Used by signed-width source ops
/// (`i32.shr` / `i64.shr` / `isize.shr` / `i8.shr` / `i16.shr`).
export I32Shr :: struct {}
/// Pop two i32 (left, right) ; push `left >> right` interpreted as a
/// logical (unsigned) shift — the sign bit is replaced by zero. Used by
/// unsigned-width source ops (`u32.shr` / `u64.shr` / `usize.shr` /
/// `u8.shr` / `u16.shr`). The Vader VM aliases every integer width to
/// signed `I32Val`, so we distinguish the two shifts at the op level
/// rather than at the value tag.
export I32ShrU :: struct {}
/// Unsigned 32-bit divide. Pops two i32-tagged values carrying a u32
/// bit pattern, divides as u32, pushes the i32-tagged quotient. The
/// VM aliases every integer width ≤ 32 bits onto `I32Val` ; signed
/// I32Div would treat e.g. SHA-256 round constants (high bit set) as
/// negative and divide wrong. Mirrors the `I32Shr` / `I32ShrU` split
/// above.
export U32Div :: struct {}
/// Unsigned 32-bit modulo. Mirrors `U32Div`.
export U32Mod :: struct {}
/// Unsigned 32-bit less-than. Pops two i32-tagged values carrying a u32
/// bit pattern, pushes a `BoolVal` of the unsigned compare.
export U32Lt  :: struct {}
/// Unsigned 32-bit ≤. See `U32Lt`.
export U32Le  :: struct {}
/// Unsigned 32-bit >. See `U32Lt`.
export U32Gt  :: struct {}
/// Unsigned 32-bit ≥. See `U32Lt`.
export U32Ge  :: struct {}
/// Pop two bools ; push `BoolVal` (equal). Sprint 5a addition.
export BoolEq :: struct {}
/// Pop two bools ; push `BoolVal` (not equal). Sprint 5a addition.
export BoolNe :: struct {}
/// Pop two bools ; push `BoolVal` (logical AND). Sprint 5a addition.
export BoolAnd :: struct {}
/// Pop two bools ; push `BoolVal` (logical OR). Sprint 5a addition.
export BoolOr :: struct {}
/// Pop one bool ; push `BoolVal` (logical NOT). Sprint 5a addition.
export BoolNot :: struct {}
/// Pop two chars ; push `BoolVal` (equal). Sprint 5a addition.
export CharEq :: struct {}
/// Pop two chars ; push `BoolVal` (not equal). Sprint 5a addition.
export CharNe :: struct {}
/// Pop two chars (left, right) ; push `BoolVal` (left < right).
export CharLt :: struct {}
/// Pop two chars (left, right) ; push `BoolVal` (left <= right).
export CharLe :: struct {}
/// Pop two chars (left, right) ; push `BoolVal` (left > right).
export CharGt :: struct {}
/// Pop two chars (left, right) ; push `BoolVal` (left >= right).
export CharGe :: struct {}
/// Pop two strings (left, right) ; push `BoolVal` for byte-equality.
export StringEq :: struct {}
/// Pop two strings (left, right) ; push `BoolVal` for byte-inequality.
export StringNe :: struct {}
/// Pop two strings (left, right) ; push their concatenation as a
/// fresh `StringVal`.
export StringConcat :: struct {}
/// Pop a value (`I32Val` or `CharVal`) ; push a `CharVal` carrying the
/// same codepoint. Emitted for every `<int>.to_char` Convert op so the
/// downstream `display_value` / `builder.append_display` arm formats
/// the value as a UTF-8 character rather than its decimal codepoint.
export IntToChar :: struct {}
/// Pop a value (`CharVal` or `I32Val`) ; push an `I32Val` carrying the
/// same codepoint. Emitted for every `char.to_<int>` Convert op so the
/// downstream integer arms see the expected tag.
export CharToInt :: struct {}
/// Pop two references ; push `BoolVal` for identity equality. In the
/// VM today, all reference-typed Values are heap-allocated so identity
/// matches Vader's reference semantics for struct / array / fn / builder.
/// Sprint 5a addition.
export RefEq :: struct {}
/// Pop two references ; push `BoolVal` for identity inequality.
export RefNe :: struct {}
/// Pop and discard the top of the value stack. Sprint 5a addition —
/// emitted by the lowerer when a value is computed but never read
/// (e.g. an expression-statement whose result is unused).
export Drop :: struct {}
/// Marker — the executor just bumps pc. Opens a forward-jumping scope.
export Block :: struct {}
/// Marker — the executor just bumps pc. Opens a backward-jumping scope
/// (`Branch` to a loop label resolves to the body start, not past-end).
export Loop :: struct {}
/// Pops one i32 condition. Non-zero falls through ; zero jumps to the
/// matching `Else` (or past the matching `End` if none). The actual
/// target pc lives in the enclosing function's `jump_table[pc]`.
export If :: struct {}
/// Reached only when the matching `If` took the truthy path — jumps
/// past the matching `End`. Target pc in `jump_table[pc]`.
export Else :: struct {}
/// Marker — closes the matching `Block`/`Loop`/`If`/`Else`. The
/// executor bumps pc through it ; the parser uses `End` lines to
/// resolve every still-pending `Branch` / `BranchIf`.
export End :: struct {}
/// Unconditional jump to the labelled scope's target (`jump_table[pc]`).
export Branch :: struct {}
/// Pops one i32 condition. Non-zero jumps ; zero falls through.
export BranchIf :: struct {}
/// Return from the current function. The top of the value stack
/// (if any) becomes the value pushed onto the caller's stack ;
/// the executor pops the current `Frame` and resumes the parent.
export Return :: struct {}
/// Fused `<T>.const X ; return` — pushes the literal then returns it.
/// `value` is the inner const op (carried verbatim) so every backend
/// inlines the right literal form.
export ReturnLit :: struct { value: ConstOp }

/// Primitive literal-producing op carried by `ReturnLit`. Mirrors the
/// TS `ConstOp` extracted from `Op`. Each variant produces exactly one
/// `Value` push.
export ConstOp ::
    | I32Const
    | I64Const
    | F64Const
    | BoolConst
    | CharConst
    | NullConst
    | StringConst

/// Narrow an `Op` to a `ConstOp` if it carries one, else `null`.
/// Used by `ReturnLit`-aware code paths that need the inner literal
/// without re-matching every callsite.
///
/// @param o  the op to inspect.
/// @return   the same op upcast to `ConstOp`, or `null` when `o` is
///           not a literal-producing op.
export const_op_of :: fn(o: Op) -> ConstOp | null {
    match o {
        is I32Const    as v -> { return v }
        is I64Const    as v -> { return v }
        is F64Const    as v -> { return v }
        is BoolConst   as v -> { return v }
        is CharConst   as v -> { return v }
        is NullConst   as v -> { return v }
        is StringConst as v -> { return v }
        _ -> { return null }
    }
}

/// Host-side description of a `call.import` target. The `mangled`
/// name is the key the executor's dispatcher matches on
/// (`std_io$println` etc.) ; `parameter_count` tells it how many
/// values to pop from the caller's stack before the host call ;
/// `has_return` controls whether a value gets pushed back afterwards.
export ImportInfo :: struct {
    name: string
    mangled: string
    parameter_count: usize
    has_return: bool
}

/// One Vader-side function body. `jump_table[pc]` is filled by the
/// parser for every branching op, and is `-1` for all others :
///   - `If`     → pc just past the matching `Else` (or `End` if none)
///   - `Else`   → pc just past the matching `End`
///   - `Loop`   → opener_pc + 1 (back-edge target for `Branch`)
///   - `Branch` / `BranchIf` → resolved scope target
///   - every other op → `-1` sentinel, the executor ignores it
///
/// `parameter_count` is the number of arguments the caller pops from
/// its stack at the `Call` site ; `local_count` is the number of
/// *additional* locals declared in the body. The frame's slot array
/// is sized `parameter_count + local_count`, with params at the bottom.
export BytecodeFunction :: struct {
    name: string
    parameter_count: usize
    local_count: usize
    ops: Op[]
    jump_table: i32[]
}

/// Module-level type table entry, indexed by the `.virt`'s `type N ...`
/// ordinal. Sprint 4 (b1) only consumed `StructType.field_count` ;
/// Sprint 5b adds `UnionType.variant_type_ids` for `type_check`'s
/// recursive union matching. `RefType` / `FnType` are still placeholders
/// (trait-typed type_check lands in Sprint 6 with `virtual.call`).
export TypeDecl :: PrimitiveType | StructType | ArrayType | RefType | FnType | UnionType

/// `primitive i32` / `primitive string` / `primitive bool` / etc.
export PrimitiveType :: struct { kind: string }

/// `struct NAME { field0:tid0, field1:tid1, ... }`. `field_count` is
/// the number of values `struct.new` / `struct.new_stack` pop from the
/// value stack and the number of slots in `StructVal.fields`.
export StructType :: struct { name: string, field_count: usize }

/// `array TID` — single-element-type heap-grown array.
export ArrayType :: struct { element_type_id: i32 }

/// Trait-typed (or opaque) reference. `trait_name` carries the name
/// from the `.virt` `ref NAME` directive (`ref Error`, `ref Iterator`,
/// …) ; `""` for the wildcard `ref _` form, which the bytecode pipeline
/// emits for slots that hold any heap-allocated reference without a
/// concrete underlying decl. Used by `type_matches` (via
/// `ref_type_matches` in `exec.vader`) to route `is Trait` patterns —
/// `is Error` matches when the value is an `ErrorVal` ; the wildcard
/// matches any struct / array / builder / fn ; other trait names fall
/// back to `false` until a `.virt` impl table directive lands.
export RefType :: struct { trait_name: string }

/// `fn (TIDs) -> TID` — function-pointer type. Sprint 4 (b1) records
/// it but doesn't use it ; `call.indirect` lookups will at (b4).
export FnType :: struct { parameter_type_ids: i32[], return_type_id: i32 }

/// `union T1,T2,...` — tagged-union type id whose variants are listed
/// as a comma-separated set of type ids. `type_check` matches by
/// recursing into each variant. Sprint 5b addition.
export UnionType :: struct { variant_type_ids: i32[] }

/// One trait-method vtable, keyed by `<TraitName>.<MethodName>` and
/// holding a list of `(type_id → function_index)` entries — one per
/// implementing struct. Built post-parse by `build_vtables` (in
/// `parser.vader`) which scans every function's mangled name for the
/// `…$<TypeName>$<TraitName>$<MethodName>` suffix that the lowerer
/// emits, then matches `<TypeName>` against `module.types[i]`'s
/// `StructType.name`. The `.virt` text format itself does not carry
/// vtable directives — they're entirely a runtime-side synthesis.
export Vtable :: struct {
    key: string
    entries: VtableEntry[]
}

/// One `(type_id, function_index)` row of a vtable.
export VtableEntry :: struct {
    type_id: i32
    function_index: i32
}

/// Records a `<type_id> implements <trait_name>` pair from the .virt
/// `impl` directive. Used by `ref_type_matches` to answer `is Trait`
/// patterns where the trait body wouldn't otherwise survive DCE.
export Impl :: struct {
    type_id: i32
    trait_name: string
}

/// Top-level holder for a parsed .virt module. `main_index` points
/// at the entry function in `functions` — populated by the parser
/// from the `export main N` directive, with a fallback search for a
/// mangled name ending in `$main` if the directive is absent. `vtables`
/// is built lazily after parse by `build_vtables` from the trait-method
/// fn-name convention. `impls` is populated directly from the
/// `impl TYPE_ID TRAIT_NAME` directives the .virt writer emits.
export Module :: struct {
    strings: string[]
    imports: ImportInfo[]
    types: TypeDecl[]
    functions: BytecodeFunction[]
    vtables: Vtable[]
    impls: Impl[]
    /// Pre-materialised `const T[]` literals. `DataConst` ops index this
    /// array directly. Built by the parser from the `data N <kind> hex"..."`
    /// directives ; mirrors `BytecodeModule.dataPool` on the TS side.
    data_pool: ArrayVal[]
    main_index: i32
}

/// Tagged runtime value carried on the VM's value stack. Sprint 3
/// widened the stack from raw `i32[]` to this union so strings flow
/// through `string.const` / `call.import` alongside numerics ; Sprint
/// 4 (b1) added `StructVal` for `struct.new` / `struct.get` / `struct.set` ;
/// Sprint 4 (b2) added `ArrayVal` for the array ops ; Sprint 4 (b3)
/// added `BuilderVal` for `${…}` interpolation via the `builder.*`
/// intrinsics ; Sprint 4 (b4) added `FnVal` for `fn.ref` / `call.indirect` ;
/// Sprint 5a adds `NullVal` / `BoolVal` / `CharVal` for the corresponding
/// const + comparison op families. Mirrors `src/vm/value.ts`.
export Value :: I32Val
       | I64Val
       | F64Val
       | StringVal
       | StructVal
       | ArrayVal
       | BuilderVal
       | FnVal
       | NullVal
       | BoolVal
       | CharVal
       | ErrorVal
       | TypeVal

/// 32-bit integer payload.
export I32Val :: struct { value: i32 }

/// 64-bit integer payload. Carries `i64.const` literals plus the results
/// of the `I64*` arithmetic / comparison ops (and any `I32Val` widened
/// by `read_i64`).
export I64Val :: struct { value: i64 }

/// 64-bit float payload. Used for `f64` (and aliased `f32`) values
/// flowing through `f64.const` and the `f64.*` arithmetic family.
export F64Val :: struct { value: f64 }

/// String payload — the underlying buffer is borrowed from the
/// module's `strings` pool, so the VM never has to allocate.
export StringVal :: struct { value: string }

/// Heap-allocated struct payload. `type_id` indexes into `Module.types`
/// (used for diagnostics + future `type_check` op) ; `fields[i]` carries
/// the i-th declared field. `Value[]` resolves intra-module so the
/// alias-expansion bug (TODO §3.8, cross-module-only) doesn't bite here.
export StructVal :: struct {
    type_id: i32
    fields: Value[]
}

/// Heap-allocated array payload — grow-only via `array.push`, fixed-size
/// indexed access via `array.get` / `array.set`. `type_id` indexes into
/// `Module.types` (an `ArrayType`) ; `elements` is the shared backing
/// buffer (multiple views may point at the same array). `offset` and
/// `length` carve out the logical slice — owning arrays have
/// `offset == 0` and `length == elements.len()`. A7 unified view model :
/// `array.slice` returns a view (shared `elements`, adjusted bounds) ;
/// `array.set` writes through to the parent (Go-style aliasing) ;
/// `array.push` detaches into a fresh `elements` when the array is a
/// view so tail slots held by sibling views aren't clobbered.
export ArrayVal :: struct {
    type_id:  i32
    elements: Value[]
    offset:   usize
    length:   usize
}

/// String-builder payload — the runtime backing of the `builder.new` /
/// `builder.append_*` / `builder.finish` intrinsic family. `parts`
/// accumulates string fragments in caller-push order ; `builder.finish`
/// concatenates them in one pass. Mirrors the host-side
/// `std/string_builder.StringBuilder` shape ; kept as a distinct
/// `Value` variant rather than a `StructVal` so the intrinsic dispatch
/// stays branch-free.
export BuilderVal :: struct {
    parts: string[]
}

/// Function-reference payload — the runtime value pushed by `fn.ref`
/// and `make_closure`, consumed by `call.indirect`. `function_index`
/// keys into `Module.functions` (same index space as the direct `Call`
/// op). `env` is `null` for plain fn-refs (Sprint 4 (b4)) and a captured
/// value (typically a `StructVal` holding the cell-wrapped captures)
/// for closures (Sprint 4 (b5)). At `CallIndirect` time, a non-`null`
/// `env` is bound to the callee's `slot 0` before the user args fill
/// `slot 1 ..`.
export FnVal :: struct {
    function_index: i32
    env: Value | null
}

/// Singleton runtime `null`. Has no fields — `is NullVal` is the only
/// way to discriminate. Sprint 5a addition.
export NullVal :: struct {}

/// Boolean payload. Sprint 5a addition — drives `if` / `br_if` once a
/// snippet's comparison chain uses `bool.*` ops (legacy `i32.*` cmp
/// arms still push `I32Val { 0|1 }` for back-compat with vm_if/vm_for).
export BoolVal :: struct { value: bool }

/// Unicode codepoint payload. Sprint 5a addition. Mirrors `src/vm/value.ts`'s
/// `char` tag — the bytecode emits `char.const N` where N is the u32
/// codepoint ; equality and ordering use the underlying numeric.
export CharVal :: struct { value: char }

/// Error value — the Vader runtime sentinel for a failed fallible call.
/// Carries a short diagnostic. Matches against any `is Error` pattern
/// (where `Error` is the stdlib trait every concrete error implements).
/// Host imports for `parse_int` / `parse_float` / `read_file` / `write_file`
/// produce one of these on failure ; the user-side `match … { is Error -> … }`
/// or `?` propagation pick it up.
export ErrorVal :: struct { message: string }

/// Runtime reification of a `type` value — pushed by `type.const N`,
/// `type_id` keys `Module.types`. Layer 4 §1.19 B.1.
export TypeVal :: struct { type_id: i32 }

// ---- Display impls on each `Value` variant --------------------------------
//
// Every variant carries its own `Display` impl so the dispatcher below
// (`display_value`) can route narrowed receivers via `.to_string()`
// rather than hand-rolling each rendering. `Value` itself does NOT
// implement `Display` — Vader's UFCS-on-union-receivers limitation
// (TODO §3.8) makes `value.to_string()` fail to resolve, regardless of
// whether the impl is on the union or on each variant. The free-fn
// `display_value(v: Value)` is the workaround : `match`-narrows to a
// concrete variant, then calls the per-variant `to_string`. When §3.8
// lands, `display_value` collapses into `Value implements Display via match`
// and these per-variant impls become reachable as `value.to_string()`
// directly.

I32Val implements Display {
    to_string :: fn(self) -> string = "${self.value}"
}

F64Val implements Display {
    to_string :: fn(self) -> string = "${self.value}"
}

I64Val implements Display {
    to_string :: fn(self) -> string = "${self.value}"
}

StringVal implements Display {
    to_string :: fn(self) -> string = self.value
}

BuilderVal implements Display {
    to_string :: fn(self) -> string = "<builder len=${self.parts.len()}>"
}

FnVal implements Display {
    to_string :: fn(self) -> string = if self.env is null { "<fn ${self.function_index}>" } else { "<fn ${self.function_index}+env>" }
}

NullVal implements Display {
    to_string :: fn(self) -> string = "null"
}

BoolVal implements Display {
    to_string :: fn(self) -> string = if self.value { "true" } else { "false" }
}

CharVal implements Display {
    to_string :: fn(self) -> string = "${self.value}"
}

ErrorVal implements Display {
    to_string :: fn(self) -> string = "<error: ${self.message}>"
}

TypeVal implements Display {
    to_string :: fn(self) -> string = "<type ${self.type_id}>"
}

/// Renders as `<type_id>{ field0, field1, … }` — type_id is the ordinal
/// from `Module.types` (the executor doesn't carry the type table here,
/// so field names aren't available). Example : `5{ 1, 2 }` for a 2-field
/// struct of type id 5 with fields `1` and `2`. Matches `displayValue`
/// in `src/vm/value.ts` so the cross-VM parity stays.
StructVal implements Display {
    to_string :: fn(self) -> string {
        sb :: new_builder()
        sb.append("${self.type_id}{ ")
        i: usize = 0
        for i < self.fields.len() {
            if i > 0 { sb.append(", ") }
            sb.append(display_value(self.fields[i]))
            i += 1
        }
        sb.append(" }")
        return "${sb}"
    }
}

/// Renders as `[elem0, elem1, …]` — empty arrays as `[]`. Example :
/// `[1, 2, 3]`. Matches `displayValue` in `src/vm/value.ts`.
ArrayVal implements Display {
    to_string :: fn(self) -> string {
        sb :: new_builder()
        sb.append("[")
        i: usize = 0
        for i < self.length {
            if i > 0 { sb.append(", ") }
            sb.append(display_value(self.elements[self.offset + i]))
            i += 1
        }
        sb.append("]")
        return "${sb}"
    }
}

/// Free-fn dispatcher for `Value.to_string()` — works around the UFCS-on-
/// union-receivers bug (TODO §3.8). Narrows `v` to a concrete variant
/// via `match`, then calls the variant's `Display` impl directly.
///
/// @param v  the tagged value to render.
/// @return   the human-readable representation, computed by the variant's
///           `to_string` impl.
export display_value :: fn(v: Value) -> string = match v {
    is I32Val as i -> i.to_string()
    is I64Val as i -> i.to_string()
    is F64Val as f -> f.to_string()
    is StringVal as s -> s.to_string()
    is StructVal as s -> s.to_string()
    is ArrayVal as a -> a.to_string()
    is BuilderVal as b -> b.to_string()
    is FnVal as f -> f.to_string()
    is NullVal as n -> n.to_string()
    is BoolVal as b -> b.to_string()
    is CharVal as c -> c.to_string()
    is ErrorVal as e -> e.to_string()
    is TypeVal as t -> t.to_string()
}
