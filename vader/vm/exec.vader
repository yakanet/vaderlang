// vader/vm/exec — stack-machine interpreter for the .virt bytecode.
//
// Reads a parsed `MainBody` (see `parser.vader`) and runs it to completion.
// The op set grows sprint by sprint (docs/SELFHOST_VM.md); the stack is
// `i32[]` until sprint 3+ widens it to a tagged `Value` union mirroring
// `src/vm/value.ts`.
//
// Errors raised by the VM itself (stack underflow, malformed bytecode,
// unsupported op) come back as a `Trap` variant of `VmResult` with a
// labelled message — the runtime's generic "array index out of bounds"
// would otherwise mask compiler / parser bugs.

import "std/io" { read_file, eprintln }
import "vader/vm/op" { Op, I32Const, LocalGet, LocalSet, I32Add, I32Sub, I32Mul, I32Div, I32Mod, I32Eq, I32Ne, I32Lt, I32Le, I32Gt, I32Ge, Block, Loop, If, Else, End, Br, BrIf, Return, MainBody }
import "vader/vm/parser" { parse_virt }

// Tagged outcome of an `exec` call. `Ok` carries the program's i32
// return value ; `Trap` carries a debug-friendly message so the host
// can surface it instead of a generic runtime abort.
export VmResult :: Ok | Trap
export Ok   :: struct { value: i32 }
export Trap :: struct { msg: string }

// Stack-machine interpreter, pc-based to support structured `if/else`
// jumps. Stack management uses a logical `sp` cursor over a grow-only
// `i32[]` — Vader arrays support `push` but not `pop`, so the cursor
// pattern keeps the inner loop allocation-free.
export exec :: fn(body: MainBody) -> VmResult {
    stack:  i32[] = []
    sp: usize = 0
    locals: i32[] = []
    i := 0
    for i < body.local_count {
        locals.push(0)
        i += 1
    }
    pc := 0
    n :: body.ops.len()
    for pc < (i32)(n) {
        op :: body.ops[pc]
        match op {
            is I32Const as ic -> {
                if sp == stack.len() { stack.push(ic.value) }
                else { stack[sp] = ic.value }
                sp += 1
                pc += 1
            }
            is LocalGet as lg -> {
                if lg.slot < 0 || (usize)(lg.slot) >= locals.len() {
                    return Trap { .msg = "local.get slot ${lg.slot} out of range at pc=${pc}" }
                }
                v :: locals[lg.slot]
                if sp == stack.len() { stack.push(v) }
                else { stack[sp] = v }
                sp += 1
                pc += 1
            }
            is LocalSet as ls -> {
                if sp == 0 {
                    return Trap { .msg = "local.set on empty stack at pc=${pc}" }
                }
                if ls.slot < 0 || (usize)(ls.slot) >= locals.len() {
                    return Trap { .msg = "local.set slot ${ls.slot} out of range at pc=${pc}" }
                }
                sp -= 1
                locals[ls.slot] = stack[sp]
                pc += 1
            }
            is I32Add -> {
                if sp < 2 { return Trap { .msg = "i32.add stack underflow at pc=${pc}" } }
                stack[sp - 2] = stack[sp - 2] + stack[sp - 1]
                sp -= 1
                pc += 1
            }
            is I32Sub -> {
                if sp < 2 { return Trap { .msg = "i32.sub stack underflow at pc=${pc}" } }
                stack[sp - 2] = stack[sp - 2] - stack[sp - 1]
                sp -= 1
                pc += 1
            }
            is I32Mul -> {
                if sp < 2 { return Trap { .msg = "i32.mul stack underflow at pc=${pc}" } }
                stack[sp - 2] = stack[sp - 2] * stack[sp - 1]
                sp -= 1
                pc += 1
            }
            is I32Div -> {
                if sp < 2 { return Trap { .msg = "i32.div stack underflow at pc=${pc}" } }
                if stack[sp - 1] == 0 { return Trap { .msg = "i32.div by zero at pc=${pc}" } }
                stack[sp - 2] = stack[sp - 2] / stack[sp - 1]
                sp -= 1
                pc += 1
            }
            is I32Mod -> {
                if sp < 2 { return Trap { .msg = "i32.mod stack underflow at pc=${pc}" } }
                if stack[sp - 1] == 0 { return Trap { .msg = "i32.mod by zero at pc=${pc}" } }
                stack[sp - 2] = stack[sp - 2] % stack[sp - 1]
                sp -= 1
                pc += 1
            }
            is I32Eq -> {
                if sp < 2 { return Trap { .msg = "i32.eq stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] == stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is I32Ne -> {
                if sp < 2 { return Trap { .msg = "i32.ne stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] != stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is I32Lt -> {
                if sp < 2 { return Trap { .msg = "i32.lt stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] <  stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is I32Le -> {
                if sp < 2 { return Trap { .msg = "i32.le stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] <= stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is I32Gt -> {
                if sp < 2 { return Trap { .msg = "i32.gt stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] >  stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is I32Ge -> {
                if sp < 2 { return Trap { .msg = "i32.ge stack underflow at pc=${pc}" } }
                stack[sp - 2] = if stack[sp - 2] >= stack[sp - 1] { 1 } else { 0 }
                sp -= 1
                pc += 1
            }
            is Block -> { pc += 1 }
            is Loop  -> { pc += 1 }
            is If -> {
                if sp == 0 { return Trap { .msg = "if on empty stack at pc=${pc}" } }
                sp -= 1
                if stack[sp] != 0 {
                    pc += 1
                } else {
                    target :: body.jump_table[pc]
                    if target < 0 {
                        return Trap { .msg = "if has no jump target at pc=${pc} (bad bytecode)" }
                    }
                    pc = target
                }
            }
            is Else -> {
                target :: body.jump_table[pc]
                if target < 0 {
                    return Trap { .msg = "else has no jump target at pc=${pc} (bad bytecode)" }
                }
                pc = target
            }
            is End -> { pc += 1 }
            is Br -> {
                target :: body.jump_table[pc]
                if target < 0 {
                    return Trap { .msg = "br has no jump target at pc=${pc} (bad bytecode)" }
                }
                pc = target
            }
            is BrIf -> {
                if sp == 0 { return Trap { .msg = "br_if on empty stack at pc=${pc}" } }
                sp -= 1
                if stack[sp] != 0 {
                    target :: body.jump_table[pc]
                    if target < 0 {
                        return Trap { .msg = "br_if has no jump target at pc=${pc} (bad bytecode)" }
                    }
                    pc = target
                } else {
                    pc += 1
                }
            }
            is Return -> {
                if sp == 0 { return Ok { .value = 0 } }
                return Ok { .value = stack[sp - 1] }
            }
        }
    }
    // Fall-through with no return — defensive, mirror the TS VM with 0.
    return Ok { .value = 0 }
}

// ---- entry --------------------------------------------------------------

// Read + parse + execute. Returns the program's exit value on success,
// or 1 (with eprintln of the trap message) on a VM-level failure. The
// `i32!` cross-module match-as-expression bug (TODO §2.4) keeps us
// from returning a richer `i32!` to the caller for now.
export run_virt :: fn(path: string) -> i32 {
    source :: read_file(path)
    if source is Error {
        eprintln("vader run: cannot read ${path}")
        return 1
    }
    return match exec(parse_virt(source)) {
        is Ok   as o -> o.value
        is Trap as t -> {
            eprintln("vader vm: ${t.msg}")
            1
        }
    }
}
