// vader/vm/exec — stack-machine interpreter for the .virt bytecode.
//
// Reads a `VmState` wrapping a `vader/bytecode::BytecodeModule` (see
// `module.vader` / `virt_reader_bc.vader`) and runs its `main` function. The
// op set grows sprint by sprint (docs/SELFHOST_VM.md) ;
// the value stack is `Value[]` (tagged union), promoted from the raw
// `i32[]` of sprints 1-2 so strings and host calls can flow through.
//
// Sprint 4 introduces explicit `Frame` records and a frame stack —
// each Vader-side `call N` pushes a callee frame, `return` pops it
// and pushes the return value onto the caller's stack. Locals live
// in the frame's `slots` array (params at the bottom, then declared
// locals) ; the value stack is per-frame.
//
// VM-level errors (stack underflow, malformed bytecode, unsupported
// op, host-import dispatch miss) come back as a `Trap` variant of
// `VmResult` with a labelled message — the runtime's generic
// "array index out of bounds" would otherwise mask compiler / parser
// bugs.
//
// Split into siblings (2026-05-14) :
//   - `value.vader` — Value projections (`read_*`, `describe_value_tag`)
//     and type-matching (`type_matches`, `ref_type_matches`, vtable
//     lookup) shared with the host dispatcher.
//   - `host.vader`  — `dispatch_import` + every per-host arm.
//   This file keeps the frame stack, apply-op helpers, the main `exec`
//   loop, and the `run_virt` entry point.

module "vader/vm"

bc :: import "vader/bytecode"

import "std/io"
import "std/string"

// IEEE 754 bit reinterpret uses the stdlib intrinsics (`f64.to_bits()` /
// `u64.from_bits()`, `std/core`'s FloatBits / BitsFloat) directly. They lower to
// the F64ToBits / BitsToF64 opcodes, which emit_c turns into an inline `union`
// cast — no runtime symbol, no C call. This file used to bind the runtime's
// `vader_*_to_bits` helpers via `@extern` because the bootstrap seed predated
// those opcodes and emitted them as unbound imports ; the seed has long since
// been regenerated, so that detour is obsolete. Dropping it also removes four
// `@extern` from the compiler tree — an `@extern` is exempt from the emit-time
// wiring check and therefore invisible to the VM's own host dispatcher, so the
// fewer the compiler declares, the less of it is unrunnable on its own bytecode.

// Mangled host-import names. Lifted to module-scope so the dispatch
// chain reads as identifier comparisons rather than raw-string
// literals — also avoids re-allocating the strings per op execution.
// Raw form (`r"..."`) bypasses Vader's `$<ident>` interpolation
// syntax, which would otherwise try to resolve `println` etc. as
// inline expressions.

// Maximum frame depth — guards against runaway recursion (the
// callee-frame allocation could otherwise grow unbounded). Picked
// well above what hand-written snippets need ; large enough that
// genuine recursive workloads pass, small enough to surface a Trap
// before the host runs out of memory.
MAX_FRAME_DEPTH :: 1024

// Step ceiling for comptime VM runs (`exec_fn_value`, capture != null) — a
// non-terminating `@comptime` loop must error, not hang the build. Generous
// enough for real computed tables (MD5_K is ~640 ops) ; a true infinite loop
// trips it in ~1s. Normal main / test runs are unbounded.
COMPTIME_STEP_BUDGET: i64: 100_000_000

/// A single call frame on the VM's frame stack. `slots[0..parameter_count]`
/// hold the params bound at `Call` time, followed by `local_count` zero-
/// initialised locals. `stack` is per-frame ; `sp` is the logical top
/// cursor (the array is grow-only, see `push_value`). `pc` indexes into
/// the function's `ops` array.
Frame :: struct {
    function_index: i32
    slots:          Value[]
    stack:          Value[]
    payload:        i64[]
    tag:            StackTag[]
    slot_payload:   i64[]
    slot_tag:       StackTag[]
    sp:             usize
    pc:             i32
    /// Defer-stack — closures pushed via `DeferPush` op, drained LIFO by
    /// `DeferPopExec` on structured exits, or by the panic-unwind handler at
    /// the top of `exec_entry`'s loop when a user-reachable op traps (which
    /// runs each thunk as a normal frame above the one being torn down).
    /// Grow-only ; the live region is `defers[0..defer_count]`.
    defers:         Value[]
    defer_count:    usize
}

/// Push `value` at the cursor position, growing the backing array
/// when needed (Vader has `push` but not capacity-managed insert).
///
/// @param stack   the grow-only value stack (mutated in place).
/// @param cursor  logical top index — `cursor == stack.len()` means a
///                fresh slot is needed, otherwise an existing one is
///                overwritten (cheaper than `push`).
/// @param value   the value to write.
push_value :: fn(stack: Value[], cursor: usize, value: Value) -> void {
    if cursor == stack.len() { stack.push(value) }
    else                     { stack[cursor] = value }
}

// ---- SoA value stack (lever A) --------------------------------------------
// The operand stack and locals are stored column-major: scalar bits live in
// the `payload` (i64) column, the variant discriminant in `tag`, and only heap
// values in the `stack` / `slots` (refs) column. A scalar write leaves the refs
// slot as a stale-but-valid `Value` (GC-safe, retention bounded by stack depth)
// and only a ref write updates it. `push_val` / `peek_val` bridge to a boxed
// `Value` at the boundaries (host calls, heap-object contents, comptime).

/// Discriminant column for the SoA stack / slots. `enum(u8)` so a `tag[]`
/// packs one byte per entry ; scalar tags carry their bits in `payload`, `Ref`
/// keeps the boxed `Value` in the refs column.
StackTag :: enum(u8) { I32, I64, F64, Bool, Char, Null, Ref }

/// Shared placeholder written into a refs column over a freshly-grown slot,
/// never dereferenced (its tag is not `StackTag.Ref`) but kept valid so the GC's
/// generic scan of the refs array never chases garbage.
NULL_VALUE :: NullVal {}

/// True when `t` marks a value `read_i32` accepts (i32 / char / i64 carriers).
/// Mirrors `read_i32`'s @partial match EXACTLY — a stricter test would reject
/// bytecode the boxed path accepted.
is_i32_tag :: fn(t: StackTag) = t == StackTag.I32 || t == StackTag.Char || t == StackTag.I64

/// True when `t` marks a value `read_i64` accepts (i64 / i32 carriers).
is_i64_tag :: fn(t: StackTag) = t == StackTag.I64 || t == StackTag.I32

/// True when `t` marks a value `read_f64` accepts. `read_f64` is STRICT (it does
/// not coerce integers), so this is an exact tag test.
is_f64_tag :: fn(t: StackTag) = t == StackTag.F64

/// Cold path for an arithmetic arm whose operand carries an unexpected tag.
/// The fast arms read `payload` directly, which for a `Ref` / `Null` slot holds
/// STALE bits — so without this the VM would compute a plausible wrong number
/// instead of naming the bad bytecode. It is the differential oracle for the
/// native backend (CLAUDE.md §9) : silently-wrong is the one outcome it must
/// never produce.
arith_tag_trap :: fn(frame: Frame, back: usize, op_label: string) -> Trap {
    v :: peek_val(frame, frame.sp - back)
    return Trap { .message = "${op_label} at pc=${frame.pc}: expected numeric operand, got ${describe_value_tag(v)}" }
}

/// Grow the three stack columns so index `cursor` is addressable.
stack_ensure :: fn(frame: Frame, cursor: usize) -> void {
    if cursor == frame.payload.len() {
        frame.payload.push(0)
        frame.tag.push(StackTag.Null)
        frame.stack.push(NULL_VALUE)
    }
}

/// Write `value` into the stack columns at `cursor` (growing if needed).
/// Mirrors `push_value` (caller bumps `sp`). Scalars land in payload + tag,
/// heap values in the refs column.
push_val :: fn(frame: Frame, cursor: usize, value: Value) -> void {
    stack_ensure(frame, cursor)
    match value {
        is I32Val as x -> {
            frame.payload[cursor] = i64(x.value)
            frame.tag[cursor] = StackTag.I32
        }
        is I64Val as x -> {
            frame.payload[cursor] = x.value
            frame.tag[cursor] = StackTag.I64
        }
        is F64Val as x -> {
            frame.payload[cursor] = i64((x.value).to_bits())
            frame.tag[cursor] = StackTag.F64
        }
        is BoolVal as x -> {
            frame.payload[cursor] = if x.value { 1 } else { 0 }
            frame.tag[cursor] = StackTag.Bool
        }
        is CharVal as x -> {
            frame.payload[cursor] = i64(u32(x.value))
            frame.tag[cursor] = StackTag.Char
        }
        is NullVal -> { frame.tag[cursor] = StackTag.Null }
        _ -> {
            frame.stack[cursor] = value
            frame.tag[cursor] = StackTag.Ref
        }
    }
}

/// Materialise the stack value at absolute index `idx` as a boxed `Value`.
peek_val :: fn(frame: Frame, idx: usize) -> Value {
    match frame.tag[idx] {
        .Ref  -> { return frame.stack[idx] }
        .I32  -> { return I32Val  { .value = i32(frame.payload[idx]) } }
        .I64  -> { return I64Val  { .value = frame.payload[idx] } }
        .F64  -> { return F64Val  { .value = (u64(frame.payload[idx])).from_bits() } }
        .Bool -> { return BoolVal { .value = frame.payload[idx] != 0 } }
        .Char -> { return CharVal { .value = char(u32(frame.payload[idx])) } }
        .Null -> { return NULL_VALUE }
    }
}

/// Materialise a local slot value as a boxed `Value`.
slot_val :: fn(frame: Frame, slot: usize) -> Value {
    match frame.slot_tag[slot] {
        .Ref  -> { return frame.slots[slot] }
        .I32  -> { return I32Val  { .value = i32(frame.slot_payload[slot]) } }
        .I64  -> { return I64Val  { .value = frame.slot_payload[slot] } }
        .F64  -> { return F64Val  { .value = (u64(frame.slot_payload[slot])).from_bits() } }
        .Bool -> { return BoolVal { .value = frame.slot_payload[slot] != 0 } }
        .Char -> { return CharVal { .value = char(u32(frame.slot_payload[slot])) } }
        .Null -> { return NULL_VALUE }
    }
}

/// Write a boxed `Value` into local slot `slot` (slot always exists).
slot_set :: fn(frame: Frame, slot: usize, value: Value) -> void {
    match value {
        is I32Val as x -> {
            frame.slot_payload[slot] = i64(x.value)
            frame.slot_tag[slot] = StackTag.I32
        }
        is I64Val as x -> {
            frame.slot_payload[slot] = x.value
            frame.slot_tag[slot] = StackTag.I64
        }
        is F64Val as x -> {
            frame.slot_payload[slot] = i64((x.value).to_bits())
            frame.slot_tag[slot] = StackTag.F64
        }
        is BoolVal as x -> {
            frame.slot_payload[slot] = if x.value { 1 } else { 0 }
            frame.slot_tag[slot] = StackTag.Bool
        }
        is CharVal as x -> {
            frame.slot_payload[slot] = i64(u32(x.value))
            frame.slot_tag[slot] = StackTag.Char
        }
        is NullVal -> { frame.slot_tag[slot] = StackTag.Null }
        _ -> {
            frame.slots[slot] = value
            frame.slot_tag[slot] = StackTag.Ref
        }
    }
}

/// Materialise stack values `[start, endx)` as a boxed `Value[]` for the call /
/// host boundaries (`build_callee_frame`, `dispatch_import`).
peek_range :: fn(frame: Frame, start: usize, endx: usize) -> Value[] {
    out: Value[] = []
    for i in start..<endx { out.push(peek_val(frame, i)) }
    return out
}


/// Append `new_frame` at `cursor[0]`, growing `frames` if needed. The
/// `frames` array is grow-only — `pop_frame` only decrements the cursor,
/// the underlying slot is reused on the next push. Same cursor pattern
/// used elsewhere in the VM (scope stack, pending branches).
///
/// @param frames     the grow-only frame stack (mutated in place).
/// @param cursor     1-element box — `[0]` is the logical top index.
/// @param new_frame  the callee frame to push.
push_frame :: fn(frames: Frame[], cursor: usize[], new_frame: Frame) -> void {
    if cursor[0] == frames.len() { frames.push(new_frame) }
    else                         { frames[cursor[0]] = new_frame }
    cursor[0] += 1
}

/// Decrement the frame cursor by 1. The released slot stays in
/// `frames` (carrying its now-unreferenced `slots` / `stack` arrays
/// until the next push overwrites it).
///
/// @param cursor  1-element box — `[0]` is the logical top index.
pop_frame :: fn(cursor: usize[]) -> void {
    cursor[0] -= 1
}

/// Project the live frame stack into plain `PauseFrame` data for the debugger's
/// `on_pause` callback — so the DAP layer answers `stackTrace` without touching
/// the VM's internal `Frame` / value stack. Innermost frame first. A caller
/// frame's `pc` is its return address (the op after the call), so its line is
/// the call site's — a one-line approximation that's fine for a call stack.
///
/// @param reason  DAP stop reason (`"breakpoint"`).
/// @param frames  the live frame stack.
/// @param count   number of live frames (`frame_count[0]`).
/// @param bc_mod  the running module — for fn names + the per-op `debug` table.
/// @return        a `PauseCtx` snapshot safe to hand across the module boundary.
build_pause_ctx :: fn(reason: string, frames: Frame[], count: usize, bc_mod: bc.BytecodeModule) -> PauseCtx {
    projected: PauseFrame[] = []
    i: i64 = i64(count) - 1
    for i >= 0 {
        f :: frames[usize(i)]
        fn_body :: bc_mod.functions[usize(f.function_index)]
        file := ""
        line := 0
        if usize(f.pc) < fn_body.debug.len() {
            dbg :: fn_body.debug[usize(f.pc)]
            if dbg != null {
                file = dbg.file
                line = dbg.line
            }
        }
        projected.push(PauseFrame {
            .function_name = fn_body.name,
            .file          = file,
            .line          = line,
            .locals        = project_locals(f, fn_body, bc_mod),
        })
        i = i - 1
    }
    return PauseCtx { .reason = reason, .frames = projected }
}

// Max nesting the Variables projection descends (also the cycle guard) and max
// array elements projected per level — bounds the eager snapshot.
DEBUG_MAX_DEPTH: i32: 5
DEBUG_MAX_ELEMS: usize: 64

// Render a frame's params + declared locals for the Variables view. Slots
// `[0..params)` are params (no source names in `BcSignature` → `arg0`, `arg1`,
// …) ; `locals[k]` lives at slot `params + k`. Accurate when the target is
// compiled `optimize = false` (no slot coalescing) — the DAP compile's mode.
project_locals :: fn(f: Frame, fn_body: bc.BcFunction, bc_mod: bc.BytecodeModule) -> PauseVar[] {
    param_count :: fn_body.signature.params.len()
    total_slots :: param_count + fn_body.locals.len()
    // Per-slot [first, last] touch pc — a slot's live window. A local shows only
    // when the current pc is inside it (`optimize = false` gives each source
    // local its own slot, so the window ≈ its lexical scope). This hides
    // not-yet-declared locals and the `v` of already-finished sibling loops.
    first: i32[] = []
    last: i32[] = []
    for _ in 0..<total_slots { first.push(-1)  last.push(-1) }
    for pc in 0..<fn_body.body.len() {
        s :: slot_touched_by(fn_body.body[pc])
        if s >= 0 && usize(s) < total_slots {
            if first[usize(s)] < 0 { first[usize(s)] = i32(pc) }
            last[usize(s)] = i32(pc)
        }
    }

    out: PauseVar[] = []
    // Params live the whole frame — always shown, named from the signature
    // (`param_names`, empty on name-less paths → `arg<i>`).
    for p in 0..<param_count {
        if p < f.slots.len() {
            out.push(project_var(param_display_name(fn_body.signature, p), slot_val(f, p), bc_mod, 0))
        }
    }
    for k in 0..<fn_body.locals.len() {
        name :: fn_body.locals[k].name
        slot :: param_count + k
        // Hide compiler-synthesised temps (`$…` / `__…` / `if_res`) and locals
        // outside their live window at the current pc.
        if slot < f.slots.len() && is_source_local(name) && slot_in_scope(first, last, slot, f.pc) {
            out.push(project_var(name, slot_val(f, slot), bc_mod, 0))
        }
    }
    return out
}

// The local slot an op reads or writes, or -1 when it touches none.
slot_touched_by :: fn(op: bc.Op) -> i32 {
    if op is bc.LocalGet   as g  { return g.slot }
    if op is bc.LocalSet   as s  { return s.slot }
    if op is bc.LocalTee   as t  { return t.slot }
    if op is bc.LocalField as lf { return lf.slot }
    return -1
}

// True when `slot`'s live window (`[first, last]` touch pc) contains `pc`.
slot_in_scope :: fn(first: i32[], last: i32[], slot: usize, pc: i32) -> bool {
    if first[slot] < 0 { return false }
    return first[slot] <= pc && pc <= last[slot]
}

// Source parameter name for slot `p`, or `arg<p>` when the signature carries no
// names (imports / synth wrappers / `.virt` reload).
param_display_name :: fn(sig: bc.BcSignature, p: usize) -> string {
    if p < sig.param_names.len() && sig.param_names[p] != "" { return sig.param_names[p] }
    return "arg${p}"
}

// Project a `Value` to a (possibly nested) `PauseVar` : its display string plus,
// for an array / struct within the depth budget, its elements / fields as
// children. Depth-bounded (which also breaks cycles) ; arrays cap at
// `DEBUG_MAX_ELEMS`.
project_var :: fn(name: string, v: Value, bc_mod: bc.BytecodeModule, depth: i32) -> PauseVar {
    children: PauseVar[] = []
    if depth < DEBUG_MAX_DEPTH {
        if v is ArrayVal as a {
            shown :: if a.length > DEBUG_MAX_ELEMS { DEBUG_MAX_ELEMS } else { a.length }
            for i in 0..<shown {
                children.push(project_var("[${i}]", a.elements[a.offset + i], bc_mod, depth + 1))
            }
        } else if v is StructVal as s {
            children = project_struct_fields(s, bc_mod, depth)
        }
    }
    return PauseVar { .name = name, .value = display_value(v), .children = children }
}

// Project a struct's fields, naming each from the module type table's
// `BcStruct.fields` (falling back to `field<i>` if the entry isn't a struct or
// is shorter than the value's field list).
project_struct_fields :: fn(s: StructVal, bc_mod: bc.BytecodeModule, depth: i32) -> PauseVar[] {
    out: PauseVar[] = []
    names: string[] = []
    if usize(s.type_id) < bc_mod.types.len() {
        entry :: bc_mod.types[usize(s.type_id)]
        if entry is bc.BcStruct as bs {
            for fld in bs.fields { names.push(fld.name) }
        }
    }
    for i in 0..<s.fields.len() {
        fname :: if i < names.len() { names[i] } else { "field${i}" }
        out.push(project_var(fname, s.fields[i], bc_mod, depth + 1))
    }
    return out
}

/// Bounds-check a `function_index` against `functions`. Used by
/// `Call`, `FnRef`, `MakeClosure`, and `CallIndirect` to surface the
/// same Trap shape on a malformed reference rather than indexing into
/// the array and letting the host runtime trap.
///
/// @param function_index  candidate index into `functions`.
/// @param functions       the running module's function table.
/// @param at_pc           pc of the op doing the lookup.
/// @param op_label        op-name prefix for the diagnostic message
///                        (`"call"`, `"fn.ref"`, `"make_closure"`,
///                        `"call.indirect"`).
/// @return                `null` on success, `Trap` if out of range.
/// @error                 `function_index < 0` or `>= functions.len()`.
validate_fn_index :: fn(function_index: i32, functions: bc.BcFunction[], at_pc: i32, op_label: string) -> Trap | null {
    if function_index < 0 || usize(function_index) >= functions.len() {
        return Trap { .message = "${op_label} function ${function_index} out of range at pc=${at_pc}" }
    }
    return null
}

/// Final stage of a direct or indirect call : build the callee frame,
/// advance the caller's pc / sp, push the new frame, and trap if the
/// frame stack overflows. Shared by `Call` (`env = null`) and
/// `CallIndirect` (`env` from the popped `FnVal`).
///
/// @param frame           current top frame, mutated in place (sp / pc advanced).
/// @param frames          the frame stack (the callee frame is pushed here).
/// @param frame_count     1-element cursor — `[0]` is the logical top.
/// @param callee          the callee's `BcFunction`.
/// @param function_index  module-level index of the callee.
/// @param arg_base        caller-stack offset of the first arg.
/// @param env             closure env for the callee, or `null`.
/// @return                `null` on success ; `Trap` on frame-stack overflow.
/// @error                 `frame_count[0] > MAX_FRAME_DEPTH` after push.
dispatch_call_into :: fn(frame: Frame, frames: Frame[], frame_count: usize[], callee: bc.BcFunction, function_index: i32, arg_base: usize, env: Value | null) -> Trap | null {
    frame.sp = arg_base
    frame.pc = frame.pc + 1
    push_callee_frame(frames, frame_count, function_index, callee, frame, arg_base, env)
    if frame_count[0] > usize(MAX_FRAME_DEPTH) {
        return Trap { .message = "call stack overflow (depth > ${MAX_FRAME_DEPTH}) at function '${callee.name}'" }
    }
    return null
}

/// Build a new `Frame` for a callee. User args are copied straight from
/// `args_source[args_offset ..]` into `slots` — typically `args_source`
/// is the caller's stack and `args_offset` is its post-pop cursor. When
/// `env` is non-`null` (closures from `make_closure`), it's bound to
/// `slot 0` *before* the user args, so the lifted-closure body sees its
/// extra leading `env` parameter in the expected position. Locals
/// (`local_count` of them) follow, zero-initialised. `env` is mandatory
/// — pass `null` explicitly for direct calls and plain `fn.ref` calls.
///
/// @param function_index  module-level index of the callee (recorded on
///                        the frame so the executor can look up the body).
/// @param callee          the callee's `BcFunction` (read for the
///                        slot counts).
/// @param args_source     the array to read params from.
/// @param args_offset     start offset of the params within `args_source`.
/// @param env             closure env — bound to `slot 0` when non-`null` ;
///                        pass `null` for direct / plain `fn.ref` calls.
/// @return                a fresh `Frame` ready to be pushed.
/// Push a callee frame, REUSING the arrays of the frame parked at `cursor`
/// when there is one (`frames` is grow-only : `pop_frame` only decrements, so
/// the slot's six columns survive and can be refilled in place). This keeps a
/// call from allocating six fresh arrays ; only a callee needing more slots
/// than the parked frame grows them. Locals are re-zeroed explicitly (the
/// parked frame's tail is stale) ; the stack columns are logically emptied by
/// `sp = 0` and overwritten on push.
push_callee_frame :: fn(frames: Frame[], cursor: usize[], function_index: i32, callee: bc.BcFunction, caller: Frame, arg_base: usize, env: Value | null) -> void {
    if cursor[0] == frames.len() {
        frames.push(build_callee_frame(function_index, callee, caller, arg_base, env))
        cursor[0] = cursor[0] + 1
        return
    }
    param_count :: callee.signature.params.len()
    total :: param_count + callee.locals.len()
    f :: frames[cursor[0]]
    f.function_index = function_index
    f.sp = 0
    f.pc = 0
    f.defer_count = 0
    if f.slot_payload.len() < total {
        for _ in f.slot_payload.len()..<total {
            f.slots.push(NULL_VALUE)
            f.slot_payload.push(0)
            f.slot_tag.push(StackTag.Null)
        }
    }
    env_off: usize = 0
    if !(env is null) {
        slot_set(f, 0, env)
        env_off = 1
    }
    for i in 0..<(param_count - env_off) {
        f.slot_payload[env_off + i] = caller.payload[arg_base + i]
        f.slot_tag[env_off + i]     = caller.tag[arg_base + i]
        f.slots[env_off + i]        = caller.stack[arg_base + i]
    }
    for i in param_count..<total {
        f.slot_payload[i] = 0
        f.slot_tag[i] = StackTag.Null
        f.slots[i] = NULL_VALUE
    }
    // Release every ref the pool would otherwise PIN. The columns are grow-only
    // and sized to the widest callee ever seen at this depth, so without this a
    // narrow frame reusing the slot keeps the wide one's object graph alive for
    // the rest of the run (the "retention bounded by stack depth" note at the
    // top of the file was written before pooling — pooling extends the lifetime
    // to `exec_entry`'s return). Slots above the live region, the whole operand
    // stack (sp = 0 here, so none of it is live), and the drained defers.
    for i in total..<f.slots.len() {
        f.slots[i] = NULL_VALUE
        f.slot_tag[i] = StackTag.Null
    }
    for i in 0..<f.stack.len() {
        f.stack[i] = NULL_VALUE
        f.tag[i] = StackTag.Null
    }
    for i in 0..<f.defers.len() {
        f.defers[i] = NULL_VALUE
    }
    cursor[0] = cursor[0] + 1
}

build_callee_frame :: fn(function_index: i32, callee: bc.BcFunction, caller: Frame, arg_base: usize, env: Value | null) -> Frame {
    // Copy the caller's SoA stack columns straight into the callee's slot
    // columns : no boxing, no materialisation, no per-slot decompose. Args
    // occupy `caller[arg_base ..]` ; `env` (closures) takes slot 0 ahead of them.
    total :: callee.signature.params.len() + callee.locals.len()
    slots: Value[] = []
    slot_payload: i64[] = []
    slot_tag: StackTag[] = []
    for _ in 0..<total {
        slots.push(NULL_VALUE)
        slot_payload.push(0)
        slot_tag.push(StackTag.Null)
    }
    result :: Frame {
        .function_index = function_index,
        .slots          = slots,
        .stack          = [],
        .payload        = [],
        .tag            = [],
        .slot_payload   = slot_payload,
        .slot_tag       = slot_tag,
        .sp             = 0,
        .pc             = 0,
        .defers         = [],
        .defer_count    = 0,
    }
    env_off: usize = 0
    if !(env is null) {
        slot_set(result, 0, env)
        env_off = 1
    }
    user_arg_count :: callee.signature.params.len() - env_off
    for i in 0..<user_arg_count {
        src :: arg_base + i
        dst :: env_off + i
        slot_payload[dst] = caller.payload[src]
        slot_tag[dst]     = caller.tag[src]
        slots[dst]        = caller.stack[src]
    }
    return result
}

/// Entry frame : args come from a host-built `Value[]` (argv), not a caller
/// stack, so they are decomposed one-off through `slot_set`.
build_entry_frame :: fn(function_index: i32, callee: bc.BcFunction, args: Value[]) -> Frame {
    total :: callee.signature.params.len() + callee.locals.len()
    slots: Value[] = []
    slot_payload: i64[] = []
    slot_tag: StackTag[] = []
    for _ in 0..<total {
        slots.push(NULL_VALUE)
        slot_payload.push(0)
        slot_tag.push(StackTag.Null)
    }
    result :: Frame {
        .function_index = function_index,
        .slots          = slots,
        .stack          = [],
        .payload        = [],
        .tag            = [],
        .slot_payload   = slot_payload,
        .slot_tag       = slot_tag,
        .sp             = 0,
        .pc             = 0,
        .defers         = [],
        .defer_count    = 0,
    }
    for i in 0..<callee.signature.params.len() {
        slot_set(result, i, args[i])
    }
    return result
}

/// Materialise a `ConstOp` carried inside a fused op (e.g. `ReturnLit`)
/// as a runtime `Value`. `StringConst` looks the index up in
/// `strings` ; other variants are pure value lifts.
///
/// @param c        the literal-producing op to materialise.
/// @param strings  the running module's string pool.
/// @param pc       pc of the carrier op (recorded in the Trap message).
/// @return         a freshly-built `Value` on success, or a `Trap`.
/// @error          `StringConst` index out of range.
const_op_value :: fn(c: bc.ConstOp, strings: string[], pc: i32) -> Value | Trap {
    match c {
        is bc.I32Const  as v -> { return I32Val { .value = v.value } }
        is bc.I64Const  as v -> { return I64Val { .value = v.value } }
        is bc.F64Const  as v -> { return F64Val { .value = v.value } }
        is bc.BoolConst as v -> { return BoolVal { .value = v.value } }
        is bc.CharConst as v -> { return CharVal { .value = v.value } }
        is bc.NullConst      -> { return NullVal {} }
        is bc.StringConst as v -> {
            if v.index < 0 || usize(v.index) >= strings.len() {
                return Trap { .message = "return.lit string.const index ${v.index} out of range at pc=${pc}" }
            }
            return StringVal { .value = strings[v.index] }
        }
    }
}

/// Tail logic shared by `Return` and `ReturnLit` : pop the current
/// frame and either surface an i32 result to the host (when the popped
/// frame was main) or push the return value onto the caller's stack.
///
/// @param return_value  the value to publish (ignored when `has_value`
///                      is false).
/// @param has_value     whether the callee has a value to return — `false`
///                      collapses the main case to "exit with 0" and
///                      skips the caller push.
/// @param at_pc         pc of the return op (recorded in the Trap when
///                      the main-result isn't an i32).
/// @param frames        the frame stack ; mutated via the caller's slot.
/// @param frame_count   1-element cursor — `[0]` is the logical top.
/// @param main_label    short label used in the i32-unwrap Trap (e.g.
///                      `"return from main"`, `"return.lit from main"`).
/// @param capture       when non-null, a 1-cell box the entry frame's raw
///                      return `Value` is published into (the i32 coercion is
///                      then skipped). Used by `exec_fn_value` for the comptime
///                      VM fallback ; `null` for the ordinary main / test path.
/// @return              `Ok` / `Trap` when the callee was main and the
///                      executor should stop ; `null` when execution
///                      should continue with the caller frame.
/// @error               main returned a non-i32 value.
finalise_return :: fn(return_value: Value, has_value: bool, at_pc: i32, frames: Frame[], frame_count: usize[], main_label: string, capture: Value[] | null) -> VmResult | null {
    pop_frame(frame_count)
    if frame_count[0] == 0 {
        // Value-capturing entry (`exec_fn_value`, comptime VM fallback) : publish
        // the raw return `Value` and skip the i32 coercion the main / exit-code
        // path requires — a comptime fn typically returns a non-i32 (array, …),
        // which `read_i32` would Trap on.
        if capture != null {
            if has_value { capture[0] = return_value }
            return Ok { .value = 0 }
        }
        if has_value {
            unwrapped :: read_i32(return_value, at_pc, main_label)
            if unwrapped is Trap { return unwrapped }
            return Ok { .value = unwrapped.value }
        }
        return Ok { .value = 0 }
    }
    if has_value {
        new_top :: frame_count[0] - 1
        caller :: frames[new_top]
        push_val(caller, caller.sp, return_value)
        caller.sp = caller.sp + 1
    }
    return null
}

/// `==` / `!=` (`negate` true). The emitter routes `ref` / `any` / `null`
/// equality through `i32.eq`, treating the boxed identity bits as a 32-bit
/// word — but a `null` operand can't be read as an i32. Compare those by
/// null-identity (`null == null`, `null != anything-non-null`) ; everything
/// else falls back to the numeric i32 path.
apply_eq_binop :: fn(frame: Frame, op_label: string, negate: bool) -> Trap | null {
    lt :: frame.tag[frame.sp - 2]
    rt :: frame.tag[frame.sp - 1]
    eq: bool = false
    if lt == StackTag.Null || rt == StackTag.Null {
        eq = lt == StackTag.Null && rt == StackTag.Null
    } else if is_i32_tag(lt) && is_i32_tag(rt) {
        // Fast path : both operands already sit unboxed in the payload column.
        eq = i32(frame.payload[frame.sp - 2]) == i32(frame.payload[frame.sp - 1])
    } else {
        // Anything else (a Ref, a bool, a mismatch) — go through the boxed path
        // so the diagnostic stays identical to the pre-SoA VM.
        left  :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, op_label)
        right :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, op_label)
        if left  is Trap { return left  }
        if right is Trap { return right }
        eq = left.value == right.value
    }
    frame.payload[frame.sp - 2] = if (if negate { !eq } else { eq }) { 1 } else { 0 }
    frame.tag[frame.sp - 2] = StackTag.Bool
    frame.sp = frame.sp - 1
    frame.pc = frame.pc + 1
    return null
}

/// Build the argv argument for a `fn(argv: string[]) -> i32` entry point.
/// `host_argv` carries the forwarded CLI args (argv[0] = program path, then
/// the program's own args) — set by `run_virt` from the `--` separator so the
/// compiler can run itself through the VM. When empty, fall back to a single
/// synthetic path element. Returns an empty arg list when
/// `main` takes no parameters.
///
/// @param parameter_count  the entry fn's declared parameter count.
/// @param host_argv        forwarded CLI argv, or empty for the synthetic path.
/// @return                 the `Value[]` to seed the main frame's slots.
/// Primitive kind ("string" / "char" / "i32" / …) of `types[type_id]`,
/// or "" when the slot isn't a primitive. Used by the virtual.call intrinsic
/// fallback to rebuild a host mangle.
primitive_kind_at :: fn(types: bc.BcType[], type_id: i32) -> string {
    if type_id < 0 || usize(type_id) >= types.len() { return "" }
    t :: types[usize(type_id)]
    if t is bc.BcPrimitive as p { return bc.val_type_name(p.val) }
    return ""
}

/// Build the host import mangle for an `@intrinsic` primitive impl member from
/// the receiver kind + a `"Trait.method"` vtable key — e.g.
/// `("string", "Hash.hash")` → `"std_core$string$Hash$hash"`. The mangle
/// grammar itself lives in `bytecode/intrinsic_manifest::primitive_member_mangle` ;
/// this only splits the vtable key. Returns "" when the kind is empty or the
/// key has no `.`.
intrinsic_host_mangle :: fn(kind: string, vtable_key: string) -> string {
    if kind == "" { return "" }
    dot :: vtable_key.index_of('.', 0)
    if dot < 0 { return "" }
    kb :: vtable_key.bytes()
    trait_name :: kb[0..<usize(dot)].bytes_to_string()
    method :: kb[usize(dot) + 1..<kb.len()].bytes_to_string()
    return bc.primitive_member_mangle(kind, trait_name, method)
}

build_main_args :: fn(parameter_count: usize, host_argv: string[], string_array_type_id: i32) -> Value[] {
    out: Value[] = []
    if parameter_count != 1 { return out }
    argv :: if host_argv.len() == 0 { ["<vader-vm>"] } else { host_argv }
    out.push(string_array_to_value(argv, string_array_type_id))
    return out
}

/// Stack-machine interpreter, frame-based to support direct Vader-side
/// calls. One outer-loop iteration dispatches one op on the top frame ;
/// the op's effect mutates the top frame's stack / slots / sp / pc and
/// (for `Call` / `Return`) pushes or pops the frame stack itself.
///
/// @param state   the runtime state wrapping a parsed `BytecodeModule` —
///                `main_index` must point at a valid entry in `bc.functions`.
/// @return        `Ok(value)` when `main` returns an i32 ; `Trap(message)`
///                on any VM-level error (malformed bytecode, type
///                mismatch, division by zero, call-stack overflow, etc).
/// @error         missing or out-of-range `main_index` ; type mismatch
///                in any op ; div / mod by zero ; unknown host import ;
///                call to a non-existent function index ; call stack
///                deeper than `MAX_FRAME_DEPTH`.
/// Run `main`. Thin wrapper over `exec_entry`.
export exec :: fn(state: VmState, host_argv: string[]) -> VmResult = exec_entry(state, state.main_index, host_argv, null, false, null)

/// Run the fn named `mangled` as the entry — used by `vader test` to run each
/// `@test` fn in isolation. A `Trap` (e.g. a failed `assert`) is the test
/// failure ; `Ok` is a pass. The fn must take no arguments.
///
/// @param state    the prepared VM state.
/// @param mangled  the target fn's mangled name.
/// @return         the run outcome, or a `Trap` when no such fn exists.
export exec_fn :: fn(state: VmState, mangled: string) -> VmResult {
    idx :: state.fn_index_by_name[mangled]
    if !(idx is null) {
        no_args: string[] = []
        return exec_entry(state, idx, no_args, null, false, null)
    }
    return Trap { .message = "exec_fn: no function named '${mangled}'" }
}

/// Run the no-arg fn named `mangled` and return its full `Value` — the
/// primitive the VM-backed comptime fallback needs (the callee typically
/// returns an array / struct / wide int, which `exec_fn`'s i32 `VmResult`
/// cannot carry). Threads a 1-cell capture box through `exec_entry` ;
/// `finalise_return` publishes the entry frame's raw return value into it.
///
/// The capture box is a live local across the run, so it (and the captured
/// value once written) stays a GC root through any collection inside the loop.
///
/// @param state    the prepared VM state.
/// @param mangled  the target fn's mangled name. Must take no arguments.
/// @return         `ValueOk { value }` carrying the return value, or `Trap`
///                 (no such fn, or a VM-level error during the run).
export exec_fn_value :: fn(state: VmState, mangled: string) -> ValueResult {
    idx :: state.fn_index_by_name[mangled]
    if !(idx is null) {
        no_args: string[] = []
        capture: Value[] = [zero_value()]
        outcome :: exec_entry(state, idx, no_args, capture, true, null)
        if outcome is Trap { return outcome }
        return ValueOk { .value = capture[0] }
    }
    return Trap { .message = "exec_fn_value: no function named '${mangled}'" }
}

// Mask an integer `Value` to a narrow ValType's width (`u8` / `u16` / `i8` /
// `i16`), mirroring the truncation a native narrow-storage slot applies. The VM
// stores every integer as a wide `I32Val` / `I64Val` with no width tag, and the
// bytecode's arith ops are width-aliased to the I32/I64 family (`op_select.vader`),
// so a sub-32-bit result (`u8 200 + 100` → 300) keeps the wide value. Native
// truncates for free via the C `uint8_t` local / field / return type ; this is
// the VM's equivalent, applied at the store boundaries (`local.set` / `Return` /
// slot store). Non-narrow ValTypes return `v` unchanged — `i32` / `i64` (and the
// unsigned `u32` / `u64`, read back through the unsigned view) already wrap at
// their width via native `i32` / `i64` overflow.
narrow_mask :: fn(v: Value, vt: bc.ValType) -> Value {
    // Only the sub-32-bit widths need masking ; i32/i64 (and the unsigned u32/u64
    // read back through the unsigned view) already wrap at their width.
    if !is_narrow_valtype(vt) { return v }
    bits: i64 = if vt == bc.ValType.U8 || vt == bc.ValType.I8 { 8 } else { 16 }
    // A narrow slot only ever holds an int (carried as I32Val / I64Val).
    raw: i64 = 0
    if v is I32Val as i32v {
        raw = i64(i32v.value)
    } else if v is I64Val as i64v {
        raw = i64v.value
    } else {
        return v
    }
    m :: raw & ((i64(1) << bits) - i64(1))
    signed :: vt == bc.ValType.I8 || vt == bc.ValType.I16
    out: i64 = m
    if signed && (m & (i64(1) << (bits - i64(1)))) != i64(0) {
        // top bit set ⇒ sign-extend
        out = m - (i64(1) << bits)
    }
    return I32Val { .value = i32(out) }
}

// Declared ValType of a local slot. Params occupy the low slots
// (`signature.params`), then the fn body's additional locals (`BcFunction` doc :
// slot of `locals[i]` is `params.len() + i`). Backs the `local.set` narrow-mask.
slot_valtype :: fn(body: bc.BcFunction, slot: i32) -> bc.ValType {
    np :: body.signature.params.len()
    s :: usize(slot)
    if s < np { return body.signature.params[s] }
    li :: s - np
    if li < body.locals.len() { return body.locals[li].val }
    return bc.ValType.I32     // defensive : unknown slot ⇒ no masking
}

// True when `vt` is a sub-32-bit width whose stored VM value must be truncated
// to that width (`narrow_mask`). Single source of truth for "narrow" : both
// `narrow_mask`'s fast-out and the per-frame `cur_has_narrow` gate consult it.
is_narrow_valtype :: fn(vt: bc.ValType) = vt == bc.ValType.U8 || vt == bc.ValType.I8 || vt == bc.ValType.U16 || vt == bc.ValType.I16

// True when any of `body`'s param / local slots is a narrow width. Computed once
// per frame entry (on the interpreter loop's body reload) and cached in
// `cur_has_narrow`, so the hot `local.set` / `local.tee` path skips
// `slot_valtype` + `narrow_mask` entirely for the common all-wide function.
fn_has_narrow_slot :: fn(body: bc.BcFunction) -> bool {
    for pvt in body.signature.params {
        if is_narrow_valtype(pvt) { return true }
    }
    for lo in body.locals {
        if is_narrow_valtype(lo.val) { return true }
    }
    return false
}

// ValType of a struct field's declared type (`BcField.type_index` → type table).
// A non-primitive field returns `Ref` (never narrow), so `narrow_mask` no-ops.
// Backs the `struct.new` narrow-field mask : a struct literal builds its fields
// straight from the stack (`build_struct`) with no intervening narrow `local.set`.
field_valtype :: fn(types: bc.BcType[], type_index: i32) -> bc.ValType {
    if type_index < 0 || usize(type_index) >= types.len() { return bc.ValType.Ref }
    t :: types[usize(type_index)]
    if t is bc.BcPrimitive as p { return p.val }
    return bc.ValType.Ref
}

/// Core interpreter loop, entered at `entry_index`. `exec` / `exec_fn` pick the
/// entry (main vs a named `@test`).
export exec_entry :: fn(state: VmState, entry_index: i32, host_argv: string[], capture: Value[] | null, is_comptime: bool, debug: DebugController | null) -> VmResult {
    if entry_index < 0 || usize(entry_index) >= state.bc.functions.len() {
        return Trap { .message = "no entry function (index=${entry_index})" }
    }

    frames: Frame[] = []
    frame_count: usize[] = [0]
    // 1-element box for the GC-collection counter — the Vader VM has no
    // arena, but `std/runtime.collect` / `collections` snippet tests just
    // need the counter to be present + monotonic. `dispatch_import`
    // bumps it on every `collect` call and reads it on every `collections`
    // query. Boxed because Vader has no module-level mutables.
    // Increments monotonically within this invocation only — the box is
    // discarded when `exec` returns, so cross-call persistence is not
    // implied. Snippet tests check `after - before == N` within one run.
    gc_state: usize[] = [0]

    // Async scheduler state, mirroring the C runtime's (invisible to the VM).
    // Index 0 = the virtual clock `now` ; indices 1.. = pending wake deadlines.
    // `dispatch_import` arms `sched_arm` (push) / `sched_park` (pop nearest +
    // advance now). Boxed for the same reason as `gc_state` ; per-invocation.
    sched_state: usize[] = [0]

    // The `string[]` ArrayType index — stamped onto every host-produced
    // string array (argv, `read_dir`, `split`) so `is string[]` narrows
    // (type_matches does exact-type_id equality on arrays). Computed once;
    // the scan is linear in the type table.
    string_array_type_id :: state.string_array_type_id
    // The `u8[]` ArrayType index — stamped onto the array `bytes` materialises
    // (the VM's copy fallback for the native zero-copy view). Same rationale.
    u8_array_type_id :: state.u8_array_type_id
    // The `std/io$IOError` struct index — stamped onto host io error values
    // so they carry a real type identity (narrowing + vtable dispatch).
    io_error_type_id :: state.io_error_type_id

    main_function :: state.bc.functions[usize(entry_index)]
    // If `main` is declared `fn(argv: string[]) -> i32`, supply its argv.
    // Built in a helper because inlining it pushed `exec` (the giant op-
    // dispatch fn) past the bytecode emitter's per-function buffer limit —
    // a latent emit bug (array-index-OOB in emit at scale). The split is also
    // cleaner; the underlying limit still needs a real fix.
    main_args :: build_main_args(main_function.signature.params.len(), host_argv, string_array_type_id)
    main_frame :: build_entry_frame(entry_index, main_function, main_args)
    push_frame(frames, frame_count, main_frame)

    // Hoist the per-frame fetches out of the per-op hot path. `frame` / `body`
    // / `op_count` change only when the active frame changes — i.e. on a call
    // (push, top grows) or a return / fall-off (pop, top shrinks). The loop
    // reloads them solely when `top` differs from the last-loaded `cur_top`,
    // saving three array reads (`frames[top]`, `state.bc.functions[…]`,
    // `body.body.len()`) on every other op. `frame` stays a tracked GC root
    // across iterations, so a collection that relocates the Frame keeps the
    // cached reference valid (the `frames` slot is updated in lock-step).
    //
    // INVARIANT this caching depends on: an op arm must NEVER replace
    // `frames[top]` with a fresh Frame object while `top` is unchanged —
    // doing so would leave the cached `frame` aliasing the old object. Every
    // arm therefore mutates `frame` IN PLACE (`frame.sp` / `frame.pc` / …)
    // rather than rebuilding-and-storing. Reassigning the frame stack is only
    // legal via `push_frame` / `pop_frame` (which change `top` → trigger a
    // reload here).
    init_top :: frame_count[0] - 1
    frame := frames[init_top]
    body := state.bc.functions[usize(frame.function_index)]
    op_count := body.body.len()
    cur_top := init_top
    // Narrow-mask fast path : most functions have only wide (i32/i64/ref) slots,
    // so `local.set` / `local.tee` can skip `slot_valtype` + `narrow_mask`
    // altogether. Recomputed alongside `body` whenever the active frame changes.
    fn_narrow_tbl :: state.fn_narrow
    cur_has_narrow := fn_narrow_tbl[usize(frame.function_index)]
    // The pooled frame's `slots` array is grow-only and sized to the WIDEST
    // callee ever seen at this depth, so `slots.len()` is not this callee's slot
    // count — bounding `local.*` against it lets an out-of-range slot read the
    // previous frame's stale data. Bound against the signature instead.
    cur_slot_count := body.signature.params.len() + body.locals.len()
    // Monotonic synthetic object-handle source for `object_new` (diagnostics
    // only — object identity is the `ObjVal` reference itself, never a machine
    // address). A 1-cell array so element mutation survives the `::` binding.
    obj_handles :: [0]

    // Comptime runs (`is_comptime`) are step-bounded so a non-terminating
    // `@comptime` loop errors instead of hanging the build. Normal runs (main /
    // tests) are unbounded — the increment is gated behind `is_comptime` so they
    // pay only one predictable branch per op.
    steps: i64 = 0

    // Debugger stepping state — only touched when `debug != null`.
    //   last_line       : the "fire once per line" gate (stop at the FIRST op of
    //                     a line, not every op) ; `-1` = no line seen yet.
    //   step_mode       : how to resume after the last stop (Continue = only
    //                     breakpoints ; Step* also stop at the next line).
    //   step_base_depth : frame depth when the current step began — Over/Out
    //                     compare against it.
    last_line: i32 = -1
    step_mode: StepMode = StepMode.Continue
    step_base_depth: i32 = 0

    // Panic-unwind (mirror of the C runtime's defer-on-trap) — on a trap, the
    // op captures it in `pending` (non-null ⇒ unwinding) + points
    // `unwind_target` at the frame where it fired, then `continue`s. The
    // loop-top handler drains that frame's defers (as thunks that run normally
    // above it), pops it, walks down to the caller, and surfaces `pending` once
    // the stack empties. A trap during a thunk (double-panic) short-circuits
    // back out with the original `pending`.
    //
    // Only traps that surface INLINE in this loop drain here: `panic()`
    // (call.import), `unreachable`, and array get/set bounds. A trap returned
    // from a helper (e.g. div/mod-by-zero) aborts without draining on the VM —
    // the native C backend drains those too (it walks its global defer stack),
    // so that gap is a VM-only residual.
    pending: Trap | null = null
    unwind_target: usize = 0

    for frame_count[0] > 0 {
        top :: frame_count[0] - 1
        if is_comptime {
            steps += 1
            if steps > COMPTIME_STEP_BUDGET {
                return Trap { .message = "comptime evaluation exceeded ${COMPTIME_STEP_BUDGET} steps (non-terminating @comptime?)" }
            }
        }
        if top != cur_top {
            frame = frames[top]
            body = state.bc.functions[usize(frame.function_index)]
            op_count = body.body.len()
            cur_has_narrow = fn_narrow_tbl[usize(frame.function_index)]
            cur_slot_count = body.signature.params.len() + body.locals.len()
            cur_top = top
        }

        // Panic unwind : while the top frame is the one being torn down, run
        // its remaining defers (each pushed as a thunk frame that executes
        // normally above it — `top > unwind_target` falls through to dispatch),
        // then pop it and drop the watermark to the caller. When the stack
        // empties, the captured trap escapes.
        if pending != null && top == unwind_target {
            if frame.defer_count > 0 {
                idx :: frame.defer_count - 1
                closure_val :: frame.defers[idx]
                frame.defer_count = idx
                thunk :: read_fn(closure_val, frame.pc, "panic unwind defer")
                if thunk is Trap { return pending }
                thunk_check :: validate_fn_index(thunk.function_index, state.bc.functions, frame.pc, "panic unwind defer")
                if thunk_check is Trap { return pending }
                thunk_fn :: state.bc.functions[usize(thunk.function_index)]
                if thunk_fn.signature.params.len() != 1 { return pending }
                push_frame(frames, frame_count, build_callee_frame(thunk.function_index, thunk_fn, frame, frame.sp, thunk.env))
                if frame_count[0] > usize(MAX_FRAME_DEPTH) { return pending }
            } else {
                pop_frame(frame_count)
                if frame_count[0] == 0 { return pending }
                unwind_target = frame_count[0] - 1
            }
            continue
        }

        // Fell off the end of the body without an explicit `return`.
        // Treat like `return` with no value on the stack — pops the
        // frame and surfaces 0 to the caller (or to the host if main).
        if frame.pc >= i32(op_count) {
            pop_frame(frame_count)
            if frame_count[0] == 0 { return Ok { .value = 0 } }
            continue
        }

        // Debugger stop check — gated on `debug != null` so normal runs pay one
        // pointer compare per op (like `is_comptime`). On the FIRST op of a new
        // source line (`last_line` gate), stop if a breakpoint sits there OR the
        // active step's condition is met ; hand the paused call stack to
        // `on_pause` (which drives the DAP conversation) and apply the returned
        // `StepMode` for the next stop.
        if debug != null {
            dbg :: body.debug[usize(frame.pc)]
            if dbg != null {
                cur_file :: dbg.file
                cur_line :: dbg.line
                if cur_line != last_line {
                    last_line = cur_line
                    depth :: i32(frame_count[0])
                    hit_bp :: line_has_breakpoint(debug, cur_file, cur_line)
                    hit_step :: step_should_stop(step_mode, step_base_depth, depth)
                    if hit_bp || hit_step {
                        reason :: if hit_bp { "breakpoint" } else { "step" }
                        pause_ctx :: build_pause_ctx(reason, frames, frame_count[0], state.bc)
                        step_mode = debug.on_pause(pause_ctx)
                        step_base_depth = depth
                    }
                }
            }
        }

        instr :: body.body[frame.pc]
        match instr {
            is bc.I32Const -> {
                stack_ensure(frame, frame.sp)
                frame.payload[frame.sp] = i64(instr.value)
                frame.tag[frame.sp] = StackTag.I32
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.LocalGet -> {
                if instr.slot < 0 || usize(instr.slot) >= cur_slot_count {
                    return Trap { .message = "local.get slot ${instr.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                stack_ensure(frame, frame.sp)
                sidx :: usize(instr.slot)
                st :: frame.slot_tag[sidx]
                frame.payload[frame.sp] = frame.slot_payload[sidx]
                frame.tag[frame.sp] = st
                if st == StackTag.Ref { frame.stack[frame.sp] = frame.slots[sidx] }
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.LocalSet -> {
                if frame.sp == 0 {
                    return Trap { .message = "local.set on empty stack at pc=${frame.pc} in '${body.name}'" }
                }
                if instr.slot < 0 || usize(instr.slot) >= cur_slot_count {
                    return Trap { .message = "local.set slot ${instr.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                sidx :: usize(instr.slot)
                if cur_has_narrow {
                    slot_set(frame, sidx, narrow_mask(peek_val(frame, frame.sp - 1), slot_valtype(body, instr.slot)))
                } else {
                    st :: frame.tag[frame.sp - 1]
                    frame.slot_payload[sidx] = frame.payload[frame.sp - 1]
                    frame.slot_tag[sidx] = st
                    if st == StackTag.Ref { frame.slots[sidx] = frame.stack[frame.sp - 1] }
                }
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.LocalTee -> {
                if frame.sp == 0 {
                    return Trap { .message = "local.tee on empty stack at pc=${frame.pc} in '${body.name}'" }
                }
                if instr.slot < 0 || usize(instr.slot) >= cur_slot_count {
                    return Trap { .message = "local.tee slot ${instr.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                // Tee stores AND leaves the value on the stack ; when the slot is
                // narrow the expression value is the truncated one, so mask both.
                // The all-wide fast path (`cur_has_narrow` false) skips the mask.
                sidx :: usize(instr.slot)
                if cur_has_narrow {
                    masked_tee :: narrow_mask(peek_val(frame, frame.sp - 1), slot_valtype(body, instr.slot))
                    push_val(frame, frame.sp - 1, masked_tee)
                    slot_set(frame, sidx, masked_tee)
                } else {
                    st :: frame.tag[frame.sp - 1]
                    frame.slot_payload[sidx] = frame.payload[frame.sp - 1]
                    frame.slot_tag[sidx] = st
                    if st == StackTag.Ref { frame.slots[sidx] = frame.stack[frame.sp - 1] }
                }
                frame.pc = frame.pc + 1
            }
            is bc.StringConst -> {
                if instr.index < 0 || usize(instr.index) >= state.bc.strings.len() {
                    return Trap { .message = "string.const index ${instr.index} out of range at pc=${frame.pc}" }
                }
                push_val(frame, frame.sp, StringVal { .value = state.bc.strings[instr.index] })
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.CallImport -> {
                if instr.index < 0 || usize(instr.index) >= state.bc.imports.len() {
                    return Trap { .message = "call.import ${instr.index} out of range at pc=${frame.pc}" }
                }
                info :: state.bc.imports[instr.index]
                arg_count :: info.signature.params.len()
                if frame.sp < arg_count {
                    return Trap { .message = "call.import '${info.mangled_name}' needs ${arg_count} arg(s) but stack has ${frame.sp} at pc=${frame.pc}" }
                }
                arg_base :: frame.sp - arg_count
                dispatch_outcome :: dispatch_import(info, peek_range(frame, arg_base, frame.sp), 0, gc_state, sched_state, frame.pc, string_array_type_id, u8_array_type_id, io_error_type_id, is_comptime, debug)
                if dispatch_outcome is Trap {
                    // User-reachable (e.g. `panic()`) — run pending defers first.
                    if pending != null { return pending }
                    pending = dispatch_outcome
                    unwind_target = frame_count[0] - 1
                    continue
                }
                new_sp := arg_base
                if info.signature.result != bc.ValType.Void {
                    push_val(frame, new_sp, dispatch_outcome.value)
                    new_sp += 1
                }
                frame.sp = new_sp
                frame.pc = frame.pc + 1
            }
            is bc.Call -> {
                index_check :: validate_fn_index(instr.function_index, state.bc.functions, frame.pc, "call")
                if index_check is Trap { return index_check }
                callee :: state.bc.functions[usize(instr.function_index)]
                callee_arity :: callee.signature.params.len()
                if frame.sp < callee_arity {
                    return Trap { .message = "call to '${callee.name}' needs ${callee_arity} arg(s) but stack has ${frame.sp} at pc=${frame.pc} in '${body.name}'" }
                }
                arg_base :: frame.sp - callee_arity
                dispatched :: dispatch_call_into(frame, frames, frame_count, callee, instr.function_index, arg_base, null)
                if dispatched is Trap { return dispatched }
            }
            is bc.FnRef -> {
                index_check :: validate_fn_index(instr.function_index, state.bc.functions, frame.pc, "fn.ref")
                if index_check is Trap { return index_check }
                push_val(frame, frame.sp, FnVal { .function_index = instr.function_index, .env = null })
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.MakeClosure -> {
                index_check :: validate_fn_index(instr.function_index, state.bc.functions, frame.pc, "make_closure")
                if index_check is Trap { return index_check }
                if frame.sp == 0 {
                    return Trap { .message = "make_closure needs env on stack at pc=${frame.pc}" }
                }
                env_value :: peek_val(frame, frame.sp - 1)
                push_val(frame, frame.sp - 1, FnVal { .function_index = instr.function_index, .env = env_value })
                frame.pc = frame.pc + 1
            }
            is bc.VirtualCall -> {
                if frame.sp < usize(instr.parameter_count) {
                    return Trap { .message = "virtual.call '${instr.vtable_key}' needs ${instr.parameter_count} arg(s) but stack has ${frame.sp} at pc=${frame.pc}" }
                }
                // UFCS layout: receiver is on TOP of the stack, explicit
                // args sit below it in source order. To match the callee's
                // `(self, ...args)` signature we move the receiver to the
                // bottom of the args region by shifting the explicit args
                // up one slot.
                receiver_top :: frame.sp - 1
                arg_base :: frame.sp - usize(instr.parameter_count)
                receiver :: peek_val(frame, receiver_top)
                receiver_type_id :: receiver_type_id_of(state, receiver)
                if receiver_type_id < 0 {
                    return Trap { .message = "virtual.call '${instr.vtable_key}' : receiver tag ${describe_value_tag(receiver)} has no type id at pc=${frame.pc}" }
                }
                callee_fn :: lookup_vtable(state.bc.vtables, instr.vtable_key, receiver_type_id)
                if callee_fn < 0 {
                    // Intrinsic primitive impl fallback : an `@intrinsic`
                    // impl member on a primitive (e.g. `string implements
                    // Hash`) is host-provided and may carry no vtable row in
                    // a Vader-emitted module (the lowerer surfaces it as an
                    // import only when a DIRECT call references it ; virtual
                    // dispatch doesn't). Reconstruct the host mangle
                    // `std_core$<kind>$<Trait>$<method>` from the receiver's
                    // primitive kind + the vtable key and route through the
                    // host dispatcher, which already implements these.
                    recv_kind :: primitive_kind_at(state.bc.types, receiver_type_id)
                    host_mangle :: intrinsic_host_mangle(recv_kind, instr.vtable_key)
                    if recv_kind != "" && host_mangle != "" {
                        shift2 := receiver_top
                        for shift2 > arg_base {
                            push_val(frame, shift2, peek_val(frame, shift2 - 1))
                            shift2 -= 1
                        }
                        push_val(frame, arg_base, receiver)
                        // Synthesise a minimal `BcImport` so `dispatch_import`'s
                        // host arms (which key on `mangled_name` + read the
                        // signature's arity / non-Void result) fire as they do
                        // for a real `call.import`. `params` carries one `Any`
                        // slot per arg purely for the arity read ; `result` is a
                        // non-Void placeholder so the result gets pushed back.
                        synth_params: bc.ValType[] = []
                        for _ in 0..<usize(instr.parameter_count) { synth_params.push(bc.ValType.Any) }
                        synth_info :: bc.BcImport {
                            .extern_name  = "",
                            .mangled_name = host_mangle,
                            .signature    = bc.BcSignature {
                                .params      = synth_params,
                                .result      = bc.ValType.Any,
                                .param_types = [],
                                .result_type = 0,
                                .param_names = [],
                            },
                            .is_extern    = false,
                        }
                        host_outcome :: dispatch_import(synth_info, peek_range(frame, arg_base, frame.sp), 0, gc_state, sched_state, frame.pc, string_array_type_id, u8_array_type_id, io_error_type_id, is_comptime, debug)
                        if host_outcome is Trap { return host_outcome }
                        if host_outcome is HostOk as hok {
                            push_val(frame, arg_base, hok.value)
                            frame.sp = arg_base + 1
                            frame.pc = frame.pc + 1
                            continue
                        }
                    }
                    return Trap { .message = "virtual.call '${instr.vtable_key}' : no impl for type ${receiver_type_id} at pc=${frame.pc}" }
                }
                index_check :: validate_fn_index(callee_fn, state.bc.functions, frame.pc, "virtual.call '${instr.vtable_key}'")
                if index_check is Trap { return index_check }
                callee :: state.bc.functions[usize(callee_fn)]
                // The callee's signature has `(receiver, …user args)` so its
                // param count should equal the instr's parameter_count.
                callee_arity :: callee.signature.params.len()
                if callee_arity != usize(instr.parameter_count) {
                    return Trap { .message = "virtual.call '${instr.vtable_key}' : impl '${callee.name}' expects ${callee_arity} param(s) but call site supplied ${instr.parameter_count} at pc=${frame.pc}" }
                }
                shift_index := receiver_top
                for shift_index > arg_base {
                    push_val(frame, shift_index, peek_val(frame, shift_index - 1))
                    shift_index -= 1
                }
                push_val(frame, arg_base, receiver)
                dispatched :: dispatch_call_into(frame, frames, frame_count, callee, callee_fn, arg_base, null)
                if dispatched is Trap { return dispatched }
            }
            is bc.CallIndirect -> {
                // Resolve user-visible param count via the FnType in the
                // type table. When the popped FnVal carries an env, the
                // lifted fn's first slot is bound to `env` and the user
                // args fill `slot 1..N+1` ; otherwise the user args fill
                // `slot 0..N`.
                if instr.type_id < 0 || usize(instr.type_id) >= state.bc.types.len() {
                    return Trap { .message = "call.indirect type ${instr.type_id} out of range at pc=${frame.pc}" }
                }
                fn_type_decl :: state.bc.types[usize(instr.type_id)]
                if !(fn_type_decl is bc.BcFn) {
                    return Trap { .message = "call.indirect type ${instr.type_id} is not a fn type at pc=${frame.pc}" }
                }
                indirect_arity :: fn_type_decl.params.len()
                if frame.sp < 1 + indirect_arity {
                    return Trap { .message = "call.indirect needs ${indirect_arity} arg(s) + fn-ref but stack has ${frame.sp} at pc=${frame.pc} in '${body.name}'" }
                }
                fn_unwrap :: read_fn(peek_val(frame, frame.sp - 1), frame.pc, "call.indirect receiver")
                if fn_unwrap is Trap { return fn_unwrap }
                callee_index_check :: validate_fn_index(fn_unwrap.function_index, state.bc.functions, frame.pc, "call.indirect")
                if callee_index_check is Trap { return callee_index_check }
                callee :: state.bc.functions[usize(fn_unwrap.function_index)]
                env_present :: !(fn_unwrap.env is null)
                expected_callee_arity :: if env_present { indirect_arity + 1 } else { indirect_arity }
                callee_arity :: callee.signature.params.len()
                if callee_arity != expected_callee_arity {
                    return Trap { .message = "call.indirect arity mismatch at pc=${frame.pc}: caller supplied ${expected_callee_arity}${if env_present { " (incl. env)" } else { "" }} but '${callee.name}' declares ${callee_arity} param(s)" }
                }
                arg_base :: frame.sp - 1 - indirect_arity
                dispatched :: dispatch_call_into(frame, frames, frame_count, callee, fn_unwrap.function_index, arg_base, fn_unwrap.env)
                if dispatched is Trap { return dispatched }
            }
            is bc.StructNew -> {
                outcome :: build_struct(state.bc.types, instr.type_id, frame)
                if outcome is Trap { return outcome }
            }
            is bc.StructGet -> {
                if frame.sp == 0 {
                    return Trap { .message = "struct.get on empty stack at pc=${frame.pc}" }
                }
                field_value :: read_struct_field(peek_val(frame, frame.sp - 1), instr.field_index, frame.pc, "struct.get")
                if field_value is Trap { return field_value }
                push_val(frame, frame.sp - 1, field_value)
                frame.pc = frame.pc + 1
            }
            is bc.StructSet -> {
                if frame.sp < 2 {
                    return Trap { .message = "struct.set needs receiver + value on stack at pc=${frame.pc}" }
                }
                struct_unwrap :: read_struct(peek_val(frame, frame.sp - 2), frame.pc, "struct.set receiver")
                if struct_unwrap is Trap { return struct_unwrap }
                if instr.field_index < 0 || usize(instr.field_index) >= struct_unwrap.fields.len() {
                    return Trap { .message = "struct.set field ${instr.field_index} out of range (struct has ${struct_unwrap.fields.len()} fields) at pc=${frame.pc}" }
                }
                struct_unwrap.fields[usize(instr.field_index)] = peek_val(frame, frame.sp - 1)
                frame.sp = frame.sp - 2
                frame.pc = frame.pc + 1
            }
            is bc.LocalField -> {
                if instr.slot < 0 || usize(instr.slot) >= cur_slot_count {
                    return Trap { .message = "local.field slot ${instr.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                field_value :: read_struct_field(slot_val(frame, usize(instr.slot)), instr.field_index, frame.pc, "local.field")
                if field_value is Trap { return field_value }
                push_val(frame, frame.sp, field_value)
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.ArrayNew -> {
                outcome :: build_array(instr.type_id, instr.length, frame)
                if outcome is Trap { return outcome }
            }
            is bc.ArrayPush -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.push needs array + value on stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 2), frame.pc, "array.push receiver")
                if array_unwrap is Trap { return array_unwrap }
                // A7 unified view : push on a view detaches into a fresh
                // backing buffer so tail slots held by sibling views aren't
                // clobbered. Owning arrays push in place.
                if is_array_view(array_unwrap) {
                    fresh: Value[] = []
                    for j in 0..<array_unwrap.length {
                        fresh.push(array_unwrap.elements[array_unwrap.offset + j])
                    }
                    array_unwrap.elements = fresh
                    array_unwrap.offset = 0
                }
                array_unwrap.elements.push(peek_val(frame, frame.sp - 1))
                array_unwrap.length = array_unwrap.length + 1
                frame.sp = frame.sp - 2
                frame.pc = frame.pc + 1
            }
            is bc.ArrayGet -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.get needs array + index on stack at pc=${frame.pc}" }
                }
                index_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "array.get index")
                if index_unwrap is Trap { return index_unwrap }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 2), frame.pc, "array.get receiver")
                if array_unwrap is Trap { return array_unwrap }
                if index_unwrap.value < 0 || usize(index_unwrap.value) >= array_unwrap.length {
                    if pending != null { return pending }
                    pending = Trap { .message = "array.get index ${index_unwrap.value} out of bounds (len=${array_unwrap.length}) at pc=${frame.pc}" }
                    unwind_target = frame_count[0] - 1
                    continue
                }
                push_val(frame, frame.sp - 2, array_unwrap.elements[array_unwrap.offset + usize(index_unwrap.value)])
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.ArraySet -> {
                if frame.sp < 3 {
                    return Trap { .message = "array.set needs array + index + value on stack at pc=${frame.pc}" }
                }
                index_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "array.set index")
                if index_unwrap is Trap { return index_unwrap }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 3), frame.pc, "array.set receiver")
                if array_unwrap is Trap { return array_unwrap }
                if index_unwrap.value < 0 || usize(index_unwrap.value) >= array_unwrap.length {
                    if pending != null { return pending }
                    pending = Trap { .message = "array.set index ${index_unwrap.value} out of bounds (len=${array_unwrap.length}) at pc=${frame.pc}" }
                    unwind_target = frame_count[0] - 1
                    continue
                }
                // A7 deliberate aliasing : writes through a view alias the
                // parent's backing buffer (Go-style). Users opt out by
                // materializing a fresh array (via push-detach today ;
                // `arr[r].clone()` once T[] Clone lands).
                array_unwrap.elements[array_unwrap.offset + usize(index_unwrap.value)] = peek_val(frame, frame.sp - 1)
                frame.sp = frame.sp - 3
                frame.pc = frame.pc + 1
            }
            is bc.ArrayLen -> {
                if frame.sp == 0 {
                    return Trap { .message = "array.len on empty stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 1), frame.pc, "array.len receiver")
                if array_unwrap is Trap { return array_unwrap }
                push_val(frame, frame.sp - 1, I32Val { .value = i32(array_unwrap.length) })
                frame.pc = frame.pc + 1
            }
            is bc.ArraySlice -> {
                if frame.sp < 3 {
                    return Trap { .message = "array.slice needs array + lo + hi on stack at pc=${frame.pc}" }
                }
                hi_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "array.slice hi")
                if hi_unwrap is Trap { return hi_unwrap }
                lo_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "array.slice lo")
                if lo_unwrap is Trap { return lo_unwrap }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 3), frame.pc, "array.slice receiver")
                if array_unwrap is Trap { return array_unwrap }
                len :: array_unwrap.length
                lo_clamped: usize = if lo_unwrap.value < 0 { 0 } else { usize(lo_unwrap.value) }
                if lo_clamped > len { lo_clamped = len }
                hi_clamped: usize = if hi_unwrap.value < 0 { 0 } else { usize(hi_unwrap.value) }
                if hi_clamped < lo_clamped { hi_clamped = lo_clamped }
                if hi_clamped > len { hi_clamped = len }
                // A7 unified view : share `elements`, adjust bounds. Writes
                // through the view will alias the parent (see ArraySet).
                push_val(frame, frame.sp - 3, ArrayVal {
                    .type_id  = instr.type_id,
                    .elements = array_unwrap.elements,
                    .offset   = array_unwrap.offset + lo_clamped,
                    .length   = hi_clamped - lo_clamped,
                })
                frame.sp = frame.sp - 2
                frame.pc = frame.pc + 1
            }
            is bc.ArrayRepeat -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.repeat needs array + count on stack at pc=${frame.pc}" }
                }
                count_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "array.repeat count")
                if count_unwrap is Trap { return count_unwrap }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 2), frame.pc, "array.repeat receiver")
                if array_unwrap is Trap { return array_unwrap }
                count: usize = if count_unwrap.value < 0 { 0 } else { usize(count_unwrap.value) }
                // No capacity concept in the VM (capacity is a native-only perf
                // hint) : `[] * n` yields a length-0 array, `[v] * n` n copies.
                repeated: Value[] = []
                for _ in 0..<count {
                    for j in 0..<array_unwrap.length {
                        repeated.push(array_unwrap.elements[array_unwrap.offset + j])
                    }
                }
                push_val(frame, frame.sp - 2, ArrayVal {
                    .type_id  = array_unwrap.type_id,
                    .elements = repeated,
                    .offset   = 0,
                    .length   = repeated.len(),
                })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.ArrayPushAll -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.push_all needs dst + src on stack at pc=${frame.pc}" }
                }
                src_unwrap :: read_array(peek_val(frame, frame.sp - 1), frame.pc, "array.push_all source")
                if src_unwrap is Trap { return src_unwrap }
                dst_unwrap :: read_array(peek_val(frame, frame.sp - 2), frame.pc, "array.push_all receiver")
                if dst_unwrap is Trap { return dst_unwrap }
                // Detach a view before growing (mirror of array.push).
                if is_array_view(dst_unwrap) {
                    fresh: Value[] = []
                    for j in 0..<dst_unwrap.length {
                        fresh.push(dst_unwrap.elements[dst_unwrap.offset + j])
                    }
                    dst_unwrap.elements = fresh
                    dst_unwrap.offset = 0
                }
                // `src_unwrap.length` is the range bound, evaluated once, so
                // `push_all(x, x)` (src aliases dst) doubles correctly.
                add :: src_unwrap.length
                for j in 0..<add {
                    dst_unwrap.elements.push(src_unwrap.elements[src_unwrap.offset + j])
                }
                dst_unwrap.length = dst_unwrap.length + add
                frame.sp = frame.sp - 2
                frame.pc = frame.pc + 1
            }
            is bc.ArrayCopy -> {
                if frame.sp < 5 {
                    return Trap { .message = "array.copy needs src + src_start + dst + dst_start + len on stack at pc=${frame.pc}" }
                }
                len_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "array.copy len")
                if len_unwrap is Trap { return len_unwrap }
                dst_start_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "array.copy dst_start")
                if dst_start_unwrap is Trap { return dst_start_unwrap }
                dst_unwrap :: read_array(peek_val(frame, frame.sp - 3), frame.pc, "array.copy dst")
                if dst_unwrap is Trap { return dst_unwrap }
                src_start_unwrap :: read_i32(peek_val(frame, frame.sp - 4), frame.pc, "array.copy src_start")
                if src_start_unwrap is Trap { return src_start_unwrap }
                src_unwrap :: read_array(peek_val(frame, frame.sp - 5), frame.pc, "array.copy src")
                if src_unwrap is Trap { return src_unwrap }
                n:  usize = if len_unwrap.value < 0 { 0 } else { usize(len_unwrap.value) }
                ss: usize = if src_start_unwrap.value < 0 { 0 } else { usize(src_start_unwrap.value) }
                ds: usize = if dst_start_unwrap.value < 0 { 0 } else { usize(dst_start_unwrap.value) }
                if ss + n > src_unwrap.length {
                    return Trap { .message = "array.copy source range out of bounds at pc=${frame.pc}" }
                }
                if ds + n > dst_unwrap.length {
                    return Trap { .message = "array.copy destination range out of bounds (dst must already be long enough) at pc=${frame.pc}" }
                }
                // Overlap-safe : snapshot the source window before writing.
                window: Value[] = []
                for j in 0..<n {
                    window.push(src_unwrap.elements[src_unwrap.offset + ss + j])
                }
                for j in 0..<n {
                    dst_unwrap.elements[dst_unwrap.offset + ds + j] = window[j]
                }
                frame.sp = frame.sp - 5
                frame.pc = frame.pc + 1
            }
            is bc.ArrayRemoveLast -> {
                if frame.sp == 0 {
                    return Trap { .message = "array.remove_last on empty stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 1), frame.pc, "array.remove_last receiver")
                if array_unwrap is Trap { return array_unwrap }
                if array_unwrap.length == 0 {
                    push_val(frame, frame.sp - 1, NullVal {})
                } else {
                    last :: array_unwrap.elements[array_unwrap.offset + array_unwrap.length - 1]
                    array_unwrap.length = array_unwrap.length - 1
                    push_val(frame, frame.sp - 1, last)
                }
                frame.pc = frame.pc + 1
            }
            is bc.ArrayClear -> {
                if frame.sp == 0 {
                    return Trap { .message = "array.clear on empty stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(peek_val(frame, frame.sp - 1), frame.pc, "array.clear receiver")
                if array_unwrap is Trap { return array_unwrap }
                // Reset to a fresh empty backing : the VM tracks logical length
                // via `elements.len()` on push, so reusing the old backing would
                // resurrect cleared elements on the next push.
                array_unwrap.elements = []
                array_unwrap.offset = 0
                array_unwrap.length = 0
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.DataConst -> {
                if instr.pool_index < 0 || usize(instr.pool_index) >= state.data_pool.len() {
                    return Trap { .message = "data.const pool_index ${instr.pool_index} out of range at pc=${frame.pc}" }
                }
                entry :: state.data_pool[usize(instr.pool_index)]
                // Re-stamp the call-site's type_id onto a fresh header sharing
                // the pool entry's `elements` ; mirrors `.rodata` sharing in
                // the native runtime.
                push_val(frame, frame.sp, ArrayVal { .type_id = instr.type_id, .elements = entry.elements, .offset = 0, .length = entry.elements.len() })
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.RefCast -> {
                frame.pc = frame.pc + 1
            }
            is bc.Box -> {
                // No-op : VM values carry coarse tags (`I64Val` matches any
                // `is`-of-an-I64-width type), so the box-tag refinement the
                // C-emit needs is irrelevant here — just bump pc, like RefCast.
                frame.pc = frame.pc + 1
            }
            is bc.Unreachable as u -> {
                if pending != null { return pending }
                pending = Trap { .message = "reached unreachable: ${u.reason}" }
                unwind_target = frame_count[0] - 1
                continue
            }
            is bc.Convert -> {
                if frame.sp == 0 {
                    return Trap { .message = "convert on empty stack at pc=${frame.pc} in '${body.name}'" }
                }
                v :: peek_val(frame, frame.sp - 1)
                converted :: convert_value(v, instr.target, instr.from_name, frame.pc)
                if converted is Trap {
                    return Trap { .message = "${converted.message} (got ${describe_value_tag(v)}) in '${body.name}'" }
                }
                push_val(frame, frame.sp - 1, converted)
                frame.pc = frame.pc + 1
            }
            is bc.SizeOfType -> {
                if frame.sp == 0 {
                    return Trap { .message = "intrinsic size_of.type on empty stack at pc=${frame.pc}" }
                }
                top_val :: peek_val(frame, frame.sp - 1)
                if !(top_val is TypeVal) {
                    return Trap { .message = "intrinsic size_of.type: expected type value, got ${describe_value_tag(top_val)} at pc=${frame.pc}" }
                }
                type_id :: top_val.type_id
                if type_id < 0 || usize(type_id) >= state.bc.types.len() {
                    return Trap { .message = "intrinsic size_of.type: type ${type_id} out of range at pc=${frame.pc}" }
                }
                size :: bc.size_of_bc_type(state.bc.types[usize(type_id)])
                push_val(frame, frame.sp - 1, I64Val { .value = i64(size) })
                frame.pc = frame.pc + 1
            }
            is bc.I32Add -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.add") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.add") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) + i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Sub -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.sub") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.sub") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) - i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Mul -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.mul") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.mul") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) * i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Div -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.div") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.div") }
                if i32(frame.payload[frame.sp - 1]) == 0 { return Trap { .message = "i32.div by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) / i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Mod -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.mod") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.mod") }
                if i32(frame.payload[frame.sp - 1]) == 0 { return Trap { .message = "i32.mod by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) % i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Eq -> {
                outcome :: apply_eq_binop(frame, "i32.eq", false)
                if outcome is Trap { return outcome }
            }
            is bc.I32Ne -> {
                outcome :: apply_eq_binop(frame, "i32.ne", true)
                if outcome is Trap { return outcome }
            }
            is bc.I32Lt -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.lt") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.lt") }
                frame.payload[frame.sp - 2] = if i32(frame.payload[frame.sp - 2]) < i32(frame.payload[frame.sp - 1]) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Le -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.le") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.le") }
                frame.payload[frame.sp - 2] = if i32(frame.payload[frame.sp - 2]) <= i32(frame.payload[frame.sp - 1]) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Gt -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.gt") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.gt") }
                frame.payload[frame.sp - 2] = if i32(frame.payload[frame.sp - 2]) > i32(frame.payload[frame.sp - 1]) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Ge -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.ge") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.ge") }
                frame.payload[frame.sp - 2] = if i32(frame.payload[frame.sp - 2]) >= i32(frame.payload[frame.sp - 1]) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Neg -> {
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.neg") }
                frame.payload[frame.sp - 1] = i64(-i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 1] = StackTag.I32
                frame.pc = frame.pc + 1
            }
            is bc.I32BitNot -> {
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.bitnot") }
                frame.payload[frame.sp - 1] = i64(~i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 1] = StackTag.I32
                frame.pc = frame.pc + 1
            }
            is bc.I32BitAnd -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.bitand") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.bitand") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) & i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32BitOr -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.bitor") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.bitor") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) | i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32BitXor -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.bitxor") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.bitxor") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) ^ i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Shl -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.shl") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.shl") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) << i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32Shr -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.shr") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.shr") }
                frame.payload[frame.sp - 2] = i64(i32(frame.payload[frame.sp - 2]) >> i32(frame.payload[frame.sp - 1]))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I32ShrU -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i32.shru") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i32.shru") }
                // Logical shift : reinterpret the i32 as u32 before the
                // shift so the sign bit isn't replicated, then reinterpret
                // the result back as i32. Mirrors `>>>` in JS / `>>` on
                // unsigned C types.
                frame.payload[frame.sp - 2] = i64(i32(u32(i32(frame.payload[frame.sp - 2])) >> u32(i32(frame.payload[frame.sp - 1]))))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            // Unsigned 32-bit divide / modulo / compare. The i32-tagged
            // operands carry a u32 bit pattern ; reinterpret via `u32(...)`
            // so the result respects unsigned semantics (zero-fill, no
            // sign-extension) before re-tagging back to i32.
            is bc.U32Div -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.div") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.div") }
                if i32(frame.payload[frame.sp - 1]) == 0 { return Trap { .message = "u32.div by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = i64(i32(u32(i32(frame.payload[frame.sp - 2])) / u32(i32(frame.payload[frame.sp - 1]))))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.U32Mod -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.mod") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.mod") }
                if i32(frame.payload[frame.sp - 1]) == 0 { return Trap { .message = "u32.rem by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = i64(i32(u32(i32(frame.payload[frame.sp - 2])) % u32(i32(frame.payload[frame.sp - 1]))))
                frame.tag[frame.sp - 2] = StackTag.I32
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.U32Lt -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.lt") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.lt") }
                frame.payload[frame.sp - 2] = if u32(i32(frame.payload[frame.sp - 2])) < u32(i32(frame.payload[frame.sp - 1])) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.U32Le -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.le") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.le") }
                frame.payload[frame.sp - 2] = if u32(i32(frame.payload[frame.sp - 2])) <= u32(i32(frame.payload[frame.sp - 1])) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.U32Gt -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.gt") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.gt") }
                frame.payload[frame.sp - 2] = if u32(i32(frame.payload[frame.sp - 2])) > u32(i32(frame.payload[frame.sp - 1])) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.U32Ge -> {
                if !is_i32_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "u32.ge") }
                if !is_i32_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "u32.ge") }
                frame.payload[frame.sp - 2] = if u32(i32(frame.payload[frame.sp - 2])) >= u32(i32(frame.payload[frame.sp - 1])) { 1 } else { 0 }
                frame.tag[frame.sp - 2] = StackTag.Bool
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.F64Const -> {
                stack_ensure(frame, frame.sp)
                frame.payload[frame.sp] = i64((instr.value).to_bits())
                frame.tag[frame.sp] = StackTag.F64
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Const -> {
                stack_ensure(frame, frame.sp)
                frame.payload[frame.sp] = instr.value
                frame.tag[frame.sp] = StackTag.I64
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Add -> {
                if !is_i64_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i64.add") }
                if !is_i64_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i64.add") }
                frame.payload[frame.sp - 2] = frame.payload[frame.sp - 2] + frame.payload[frame.sp - 1]
                frame.tag[frame.sp - 2] = StackTag.I64
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Sub -> {
                if !is_i64_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i64.sub") }
                if !is_i64_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i64.sub") }
                frame.payload[frame.sp - 2] = frame.payload[frame.sp - 2] - frame.payload[frame.sp - 1]
                frame.tag[frame.sp - 2] = StackTag.I64
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Mul -> {
                if !is_i64_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i64.mul") }
                if !is_i64_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i64.mul") }
                frame.payload[frame.sp - 2] = frame.payload[frame.sp - 2] * frame.payload[frame.sp - 1]
                frame.tag[frame.sp - 2] = StackTag.I64
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Div -> {
                if !is_i64_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i64.div") }
                if !is_i64_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i64.div") }
                if frame.payload[frame.sp - 1] == 0 { return Trap { .message = "i64.div by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = frame.payload[frame.sp - 2] / frame.payload[frame.sp - 1]
                frame.tag[frame.sp - 2] = StackTag.I64
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Mod -> {
                if !is_i64_tag(frame.tag[frame.sp - 2]) { return arith_tag_trap(frame, 2, "i64.mod") }
                if !is_i64_tag(frame.tag[frame.sp - 1]) { return arith_tag_trap(frame, 1, "i64.mod") }
                if frame.payload[frame.sp - 1] == 0 { return Trap { .message = "i64.rem by zero at pc=${frame.pc}" } }
                frame.payload[frame.sp - 2] = frame.payload[frame.sp - 2] % frame.payload[frame.sp - 1]
                frame.tag[frame.sp - 2] = StackTag.I64
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.I64Neg -> {
