                if frame.sp == 0 { return Trap { .message = "<int>.to_char on empty stack at pc=${frame.pc}" } }
                source :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "<int>.to_char")
                if source is Trap { return source }
                push_val(frame, frame.sp - 1, CharVal { .value = char(u32(source.value)) })
                frame.pc = frame.pc + 1
            }
            is bc.CharToInt -> {
                if frame.sp == 0 { return Trap { .message = "char.to_<int> on empty stack at pc=${frame.pc}" } }
                source :: read_char(peek_val(frame, frame.sp - 1), frame.pc, "char.to_<int>")
                if source is Trap { return source }
                push_val(frame, frame.sp - 1, I32Val { .value = i32(u32(source.value)) })
                frame.pc = frame.pc + 1
            }
            is bc.StringSliceCodepoints -> {
                if frame.sp < 3 { return Trap { .message = "string.slice_codepoints needs string + lo + hi on stack at pc=${frame.pc}" } }
                s_box  :: read_string(peek_val(frame, frame.sp - 3), frame.pc, "string.slice_codepoints receiver")
                lo_box :: read_i32   (peek_val(frame, frame.sp - 2), frame.pc, "string.slice_codepoints lo")
                hi_box :: read_i32   (peek_val(frame, frame.sp - 1), frame.pc, "string.slice_codepoints hi")
                if s_box  is Trap { return s_box  }
                if lo_box is Trap { return lo_box }
                if hi_box is Trap { return hi_box }
                s :: s_box.value
                // Walk UTF-8 to compute byte offsets for codepoint
                // indices `lo` and `hi`, clamping to the codepoint
                // count so out-of-bounds ranges produce a clamped
                // substring rather than trapping.
                lo_cp :: usize(lo_box.value)
                hi_cp :: usize(hi_box.value)
                sb :: s.bytes()
                n_bytes :: sb.len()
                cursor: usize = 0
                seen:   usize = 0
                byte_lo: usize = n_bytes
                byte_hi: usize = n_bytes
                for cursor < n_bytes {
                    if seen == lo_cp { byte_lo = cursor }
                    if seen == hi_cp { byte_hi = cursor }
                    [_c, width] :: sb.utf8_decode_len(cursor)
                    cursor = cursor + width
                    seen   = seen + 1
                }
                if seen <= lo_cp { byte_lo = n_bytes }
                if seen <= hi_cp { byte_hi = n_bytes }
                if byte_hi < byte_lo { byte_hi = byte_lo }
                push_val(frame, frame.sp - 3, StringVal { .value = sb[byte_lo..<byte_hi].bytes_to_string() })
                frame.sp = frame.sp - 2
                frame.pc = frame.pc + 1
            }
            is bc.RefEq -> {
                if frame.sp < 2 { return Trap { .message = "ref.eq needs 2 values on stack at pc=${frame.pc}" } }
                outcome :: value_ref_eq(peek_val(frame, frame.sp - 2), peek_val(frame, frame.sp - 1), frame.pc, "ref.eq")
                if outcome is Trap { return outcome }
                push_val(frame, frame.sp - 2, BoolVal { .value = outcome })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.RefNe -> {
                if frame.sp < 2 { return Trap { .message = "ref.ne needs 2 values on stack at pc=${frame.pc}" } }
                outcome :: value_ref_eq(peek_val(frame, frame.sp - 2), peek_val(frame, frame.sp - 1), frame.pc, "ref.ne")
                if outcome is Trap { return outcome }
                push_val(frame, frame.sp - 2, BoolVal { .value = !outcome })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.Drop -> {
                if frame.sp == 0 { return Trap { .message = "drop on empty stack at pc=${frame.pc} in '${body.name}'" } }
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.TypeCheck -> {
                if frame.sp == 0 { return Trap { .message = "type_check on empty stack at pc=${frame.pc}" } }
                if instr.type_id < 0 || usize(instr.type_id) >= state.bc.types.len() {
                    return Trap { .message = "type_check type ${instr.type_id} out of range at pc=${frame.pc}" }
                }
                matched :: type_matches(state, peek_val(frame, frame.sp - 1), instr.type_id)
                push_val(frame, frame.sp - 1, BoolVal { .value = matched })
                frame.pc = frame.pc + 1
            }
            is bc.TypeConst -> {
                if instr.type_id < 0 || usize(instr.type_id) >= state.bc.types.len() {
                    return Trap { .message = "type.const type ${instr.type_id} out of range at pc=${frame.pc}" }
                }
                push_val(frame, frame.sp, TypeVal { .type_id = instr.type_id })
                frame.sp = frame.sp + 1
                frame.pc = frame.pc + 1
            }
            is bc.DeferPush -> {
                if frame.sp == 0 {
                    return Trap { .message = "defer.push on empty stack at pc=${frame.pc}" }
                }
                closure :: peek_val(frame, frame.sp - 1)
                push_value(frame.defers, frame.defer_count, closure)
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
                frame.defer_count = frame.defer_count + 1
            }
            is bc.DeferPopExec as instr -> {
                if instr.count <= 0 {
                    frame.pc = frame.pc + 1
                    continue
                }
                pop_n :: usize(instr.count)
                if frame.defer_count < pop_n {
                    return Trap { .message = "defer.pop_exec underflow (count=${instr.count}, have=${frame.defer_count}) at pc=${frame.pc}" }
                }
                old_defer_count :: frame.defer_count
                new_defer_count :: old_defer_count - pop_n
                // Shrink the caller's defer-list in place now ; its pc is
                // advanced AFTER the drain (below) so trap messages still
                // report the defer.pop_exec pc. The dispatch loop runs the
                // pushed callees in LIFO and then resumes the caller at pc+1.
                frame.defer_count = new_defer_count
                // Push N callee frames in oldest-first order so the most
                // recently pushed defer (top of frame stack) executes first.
                // Bound on the captured `old_defer_count` — `frame.defer_count`
                // has already been shrunk to `new_defer_count` above.
                for drain_index in new_defer_count..<old_defer_count {
                    closure_val :: frame.defers[drain_index]
                    fn_unwrap :: read_fn(closure_val, frame.pc, "defer.pop_exec entry")
                    if fn_unwrap is Trap { return fn_unwrap }
                    callee_index_check :: validate_fn_index(fn_unwrap.function_index, state.bc.functions, frame.pc, "defer.pop_exec")
                    if callee_index_check is Trap { return callee_index_check }
                    callee :: state.bc.functions[usize(fn_unwrap.function_index)]
                    if callee.signature.params.len() != 1 {
                        return Trap { .message = "defer thunk '${callee.name}' must take exactly one env param at pc=${frame.pc}" }
                    }
                    callee_frame :: build_callee_frame(fn_unwrap.function_index, callee, frame, frame.sp, fn_unwrap.env)
                    push_frame(frames, frame_count, callee_frame)
                    if frame_count[0] > usize(MAX_FRAME_DEPTH) {
                        return Trap { .message = "call stack overflow (depth > ${MAX_FRAME_DEPTH}) at function '${callee.name}' during defer drain" }
                    }
                }
                frame.pc = frame.pc + 1
            }
            is bc.Block -> { frame.pc = frame.pc + 1 }
            is bc.Loop  -> { frame.pc = frame.pc + 1 }
            is bc.If -> {
                if frame.sp == 0 { return Trap { .message = "if on empty stack at pc=${frame.pc} in '${body.name}'" } }
                cond :: frame.payload[frame.sp - 1] != 0
                new_sp :: frame.sp - 1
                if cond {
                    frame.sp = new_sp
                    frame.pc = frame.pc + 1
                } else {
                    target :: body.jump_table[frame.pc]
                    if target < 0 {
                        return Trap { .message = "if has no jump target at pc=${frame.pc} (bad bytecode)" }
                    }
                    frame.sp = new_sp
                    frame.pc = target
                }
            }
            is bc.Else -> {
                target :: body.jump_table[frame.pc]
                if target < 0 {
                    return Trap { .message = "else has no jump target at pc=${frame.pc} (bad bytecode)" }
                }
                frame.pc = target
            }
            is bc.End -> { frame.pc = frame.pc + 1 }
            is bc.Branch -> {
                target :: body.jump_table[frame.pc]
                if target < 0 {
                    return Trap { .message = "br has no jump target at pc=${frame.pc} (bad bytecode)" }
                }
                frame.pc = target
            }
            is bc.BranchIf -> {
                if frame.sp == 0 { return Trap { .message = "br_if on empty stack at pc=${frame.pc} in '${body.name}'" } }
                cond :: frame.payload[frame.sp - 1] != 0
                new_sp :: frame.sp - 1
                if cond {
                    target :: body.jump_table[frame.pc]
                    if target < 0 {
                        return Trap { .message = "br_if has no jump target at pc=${frame.pc} (bad bytecode)" }
                    }
                    frame.sp = new_sp
                    frame.pc = target
                } else {
                    frame.sp = new_sp
                    frame.pc = frame.pc + 1
                }
            }
            is bc.Return -> {
                has_value :: frame.sp > 0
                return_value: Value = I32Val { .value = 0 }
                // Narrow return type ⇒ truncate to width, like a C `uint8_t` return.
                if has_value { return_value = narrow_mask(peek_val(frame, frame.sp - 1), body.signature.result) }
                outcome :: finalise_return(return_value, has_value, frame.pc, frames, frame_count, "return from main", capture)
                if !(outcome is null) { return outcome }
            }
            is bc.ReturnLit -> {
                raw_ret :: const_op_value(instr.value, state.bc.strings, frame.pc)
                if raw_ret is Trap { return raw_ret }
                return_value :: narrow_mask(raw_ret, body.signature.result)
                outcome :: finalise_return(return_value, true, frame.pc, frames, frame_count, "return.lit from main", capture)
                if !(outcome is null) { return outcome }
            }
            // ---- memory opcodes (Target ABI) — inert until S3 -----------
            is bc.ObjectNew -> {
                outcome :: build_object(instr.type_id, frame, obj_handles)
                if outcome is Trap { return outcome }
            }
            is bc.LoadU8 -> {
                raw :: load_bytes_op(frame, 1, "load_u8")
                if raw is Trap { return raw }
                push_val(frame, frame.sp - 2, I32Val { .value = i32(raw) })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.LoadI32 -> {
                raw :: load_bytes_op(frame, 4, "load_i32")
                if raw is Trap { return raw }
                push_val(frame, frame.sp - 2, I32Val { .value = i32(raw) })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.LoadI64 -> {
                raw :: load_bytes_op(frame, 8, "load_i64")
                if raw is Trap { return raw }
                push_val(frame, frame.sp - 2, I64Val { .value = i64(raw) })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.LoadF64 -> {
                raw :: load_bytes_op(frame, 8, "load_f64")
                if raw is Trap { return raw }
                push_val(frame, frame.sp - 2, F64Val { .value = (u64(raw)).from_bits() })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.StoreU8 -> {
                if frame.sp < 3 { return Trap { .message = "store_u8 needs object + offset + value on stack at pc=${frame.pc}" } }
                val_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "store_u8 value")
                if val_unwrap is Trap { return val_unwrap }
                outcome :: store_bytes_op(frame, 1, u64(u8(val_unwrap.value)), "store_u8")
                if outcome is Trap { return outcome }
            }
            is bc.StoreI32 -> {
                if frame.sp < 3 { return Trap { .message = "store_i32 needs object + offset + value on stack at pc=${frame.pc}" } }
                val_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "store_i32 value")
                if val_unwrap is Trap { return val_unwrap }
                outcome :: store_bytes_op(frame, 4, u64(u32(val_unwrap.value)), "store_i32")
                if outcome is Trap { return outcome }
            }
            is bc.StoreI64 -> {
                if frame.sp < 3 { return Trap { .message = "store_i64 needs object + offset + value on stack at pc=${frame.pc}" } }
                val_unwrap :: read_i64(peek_val(frame, frame.sp - 1), frame.pc, "store_i64 value")
                if val_unwrap is Trap { return val_unwrap }
                outcome :: store_bytes_op(frame, 8, u64(val_unwrap.value), "store_i64")
                if outcome is Trap { return outcome }
            }
            is bc.StoreF64 -> {
                if frame.sp < 3 { return Trap { .message = "store_f64 needs object + offset + value on stack at pc=${frame.pc}" } }
                val_unwrap :: read_f64(peek_val(frame, frame.sp - 1), frame.pc, "store_f64 value")
                if val_unwrap is Trap { return val_unwrap }
                outcome :: store_bytes_op(frame, 8, (val_unwrap.value).to_bits(), "store_f64")
                if outcome is Trap { return outcome }
            }
            // Slot ops — the VM stores every element as a uniform `Value` in
            // `slots` (no byte packing), so the native width-typed primitive
            // slot ops (`load_slot_*` / `store_slot_*`) and the boxed
            // `load_slot` / `store_slot` all route through the same logic ; the
            // `…U8` / `…I32` / `…I64` / `…F64` width distinction is a native-only
            // (byte-layout) concern the boxed-Value VM doesn't model.
            is bc.LoadSlot     -> { if do_load_slot(frame)  is Trap as t { return t } }
            is bc.LoadSlotU8   -> { if do_load_slot(frame)  is Trap as t { return t } }
            is bc.LoadSlotI32  -> { if do_load_slot(frame)  is Trap as t { return t } }
            is bc.LoadSlotI64  -> { if do_load_slot(frame)  is Trap as t { return t } }
            is bc.LoadSlotF64  -> { if do_load_slot(frame)  is Trap as t { return t } }
            is bc.StoreSlot    -> { if do_store_slot(frame) is Trap as t { return t } }
            is bc.StoreSlotU8  -> { if do_store_slot(frame) is Trap as t { return t } }
            is bc.StoreSlotI32 -> { if do_store_slot(frame) is Trap as t { return t } }
            is bc.StoreSlotI64 -> { if do_store_slot(frame) is Trap as t { return t } }
            is bc.StoreSlotF64 -> { if do_store_slot(frame) is Trap as t { return t } }
            is bc.MemoryCopy -> {
                outcome :: do_memory_copy(frame)
                if outcome is Trap { return outcome }
            }
            is bc.BufferToString -> {
                // Pop buffer + len ; intern the leading `len` bytes verbatim as a
                // string (same semantics as `bytes_to_string` over a `u8[]`).
                if frame.sp < 2 { return Trap { .message = "buffer_to_string needs object + len on stack at pc=${frame.pc}" } }
                len_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "buffer_to_string len")
                if len_unwrap is Trap { return len_unwrap }
                obj_unwrap :: read_obj(peek_val(frame, frame.sp - 2), frame.pc, "buffer_to_string receiver")
                if obj_unwrap is Trap { return obj_unwrap }
                // width 0 ⇒ checks `0 <= len <= bytes_len`, returns the usize len.
                n :: check_byte_range(len_unwrap.value, 0, obj_unwrap.bytes.len(), "buffer_to_string", frame.pc)
                if n is Trap { return n }
                push_val(frame, frame.sp - 2, StringVal { .value = obj_unwrap.bytes[0..<n].bytes_to_string() })
                frame.sp = frame.sp - 1
                frame.pc = frame.pc + 1
            }
            is bc.BufferWriteString -> {
                // Pop buffer + off + string ; memcpy the string's bytes into the
                // buffer at `off` (the parts-model `to_string` assembly step).
                if frame.sp < 3 { return Trap { .message = "buffer_write_string needs object + off + string on stack at pc=${frame.pc}" } }
                str_unwrap :: read_string(peek_val(frame, frame.sp - 1), frame.pc, "buffer_write_string source")
                if str_unwrap is Trap { return str_unwrap }
                off_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "buffer_write_string off")
                if off_unwrap is Trap { return off_unwrap }
                obj_unwrap :: read_obj(peek_val(frame, frame.sp - 3), frame.pc, "buffer_write_string receiver")
                if obj_unwrap is Trap { return obj_unwrap }
                if off_unwrap.value < 0 { return Trap { .message = "buffer_write_string negative offset at pc=${frame.pc}" } }
                src_bytes :: str_unwrap.value.bytes()
                off :: usize(off_unwrap.value)
                if off + src_bytes.len() > obj_unwrap.bytes.len() {
                    return Trap { .message = "buffer_write_string range [${off}, ${off + src_bytes.len()}) exceeds ${obj_unwrap.bytes.len()} at pc=${frame.pc}" }
                }
                for i in 0..<src_bytes.len() {
                    obj_unwrap.bytes[off + i] = src_bytes[i]
                }
                frame.sp = frame.sp - 3
                frame.pc = frame.pc + 1
            }
            is bc.F64ToBits -> {
                // Bit-reinterpret the TOS f64 as its raw u64 bits (held in an
                // I64Val — same 64 bits) via the runtime `@extern` (see the
                // module-top note : the VM can't use the intrinsic itself).
                if frame.sp < 1 { return Trap { .message = "f64_to_bits needs a value on the stack at pc=${frame.pc}" } }
                fv :: read_f64(peek_val(frame, frame.sp - 1), frame.pc, "f64_to_bits")
                if fv is Trap { return fv }
                push_val(frame, frame.sp - 1, I64Val { .value = i64((fv.value).to_bits()) })
                frame.pc = frame.pc + 1
            }
            is bc.BitsToF64 -> {
                // Inverse : reinterpret the TOS u64 bit pattern (in an I64Val) as
                // an f64, via the runtime `@extern`.
                if frame.sp < 1 { return Trap { .message = "bits_to_f64 needs a value on the stack at pc=${frame.pc}" } }
                iv :: read_i64(peek_val(frame, frame.sp - 1), frame.pc, "bits_to_f64")
                if iv is Trap { return iv }
                push_val(frame, frame.sp - 1, F64Val { .value = (u64(iv.value)).from_bits() })
                frame.pc = frame.pc + 1
            }
            is bc.F32ToBits -> {
                // f32→u32 bits. The VM holds f32 in an F64Val (exact, since f32
                // widens losslessly), so narrow back to f32 before the cast; the
                // u32 result rides in an I32Val.
                if frame.sp < 1 { return Trap { .message = "f32_to_bits needs a value on the stack at pc=${frame.pc}" } }
                fv :: read_f64(peek_val(frame, frame.sp - 1), frame.pc, "f32_to_bits")
                if fv is Trap { return fv }
                push_val(frame, frame.sp - 1, I32Val { .value = i32((f32(fv.value)).to_bits()) })
                frame.pc = frame.pc + 1
            }
            is bc.BitsToF32 -> {
                // Inverse : reinterpret the TOS u32 bit pattern (in an I32Val) as
                // an f32, widened back into an F64Val for VM storage.
                if frame.sp < 1 { return Trap { .message = "bits_to_f32 needs a value on the stack at pc=${frame.pc}" } }
                iv :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "bits_to_f32")
                if iv is Trap { return iv }
                push_val(frame, frame.sp - 1, F64Val { .value = f64((u32(iv.value)).from_bits()) })
                frame.pc = frame.pc + 1
            }
        }
    }
    // Frame stack drained without an explicit main-return — surface 0.
    return Ok { .value = 0 }
}

/// Build an `ArrayVal` of `type_id` with `length` initial elements
/// popped from the stack. If `length == 0`, allocates an empty
/// grow-only array ready for `array.push`.
///
/// @param type_id  index into `Module.types` — informational, not
///                 validated against `ArrayType` (the bytecode pipeline
///                 already guarantees consistency).
/// @param length   initial element count to consume from the stack.
/// @param frame    current top frame, mutated in place (sp/pc advanced).
/// @return         `null` on success, or a `Trap` if the stack is too short.
/// @error          stack underflow when `frame.sp < length`.
build_array :: fn(type_id: i32, length: i32, frame: Frame) -> Trap | null {
    if length < 0 {
        return Trap { .message = "array.new length ${length} is negative at pc=${frame.pc}" }
    }
    needed :: usize(length)
    if frame.sp < needed {
        return Trap { .message = "array.new type ${type_id} needs ${needed} initial element(s) but stack has ${frame.sp} at pc=${frame.pc}" }
    }
    arg_base :: frame.sp - needed
    elements: Value[] = []
    for element_index in 0..<needed {
        elements.push(peek_val(frame, arg_base + element_index))
    }
    new_array :: ArrayVal { .type_id = type_id, .elements = elements, .offset = 0, .length = elements.len() }
    push_val(frame, arg_base, new_array)
    frame.sp = arg_base + 1
    frame.pc = frame.pc + 1
    return null
}

/// Body of the `StructNew` arm — the .virt text format emits two
/// variants (`struct.new` and `struct.new_stack`) but the VM treats
/// them identically (the heap/stack split is a codegen concern).
/// Pops `field_count` values from `frame.stack` (in field-declaration
/// order), wraps them in a `StructVal`, and pushes the result.
///
/// @param types    the running module's type table.
/// @param type_id  the struct type's ordinal in `types`.
/// @param frame    current top frame, mutated in place (sp / pc advanced).
/// @return         `null` on success, or a `Trap` describing the failure.
/// @error          `type_id` out of range ; type-table entry isn't a
///                 `BcStruct` ; stack carries fewer than `field_count`
///                 values.
build_struct :: fn(types: bc.BcType[], type_id: i32, frame: Frame) -> Trap | null {
    if type_id < 0 || usize(type_id) >= types.len() {
        return Trap { .message = "struct.new type ${type_id} out of range at pc=${frame.pc}" }
    }
    type_decl :: types[usize(type_id)]
    if !(type_decl is bc.BcStruct) {
        return Trap { .message = "struct.new type ${type_id} is not a struct at pc=${frame.pc}" }
    }
    field_count :: type_decl.fields.len()
    if frame.sp < field_count {
        return Trap { .message = "struct.new type ${type_id} needs ${field_count} field value(s) but stack has ${frame.sp} at pc=${frame.pc}" }
    }
    arg_base :: frame.sp - field_count
    fields: Value[] = []
    for field_index in 0..<field_count {
        // Narrow-typed field ⇒ truncate to width, mirroring a C narrow struct
        // field ; the literal's field value comes straight off the stack with no
        // intervening narrow `local.set` to mask it (see narrow-int-width plan).
        fvt :: field_valtype(types, type_decl.fields[field_index].type_index)
        fields.push(narrow_mask(peek_val(frame, arg_base + field_index), fvt))
    }
    new_struct :: StructVal { .type_id = type_id, .fields = fields }
    push_val(frame, arg_base, new_struct)
    frame.sp = arg_base + 1
    frame.pc = frame.pc + 1
    return null
}

// ---- memory opcodes (Target ABI) — VM byte-heap helpers (decision D8) ----
//
// Inert until S3 (nothing emits these yet). The VM backs a REAL byte-
// addressed heap : `ObjVal.bytes` is the raw inline payload (byte offsets),
// `ObjVal.slots` the boxed reference fields (slot indices). Each accessor
// re-derives from the obj on the stack — no base cached across an op (G1,
// trivially held here since every access hits `obj.bytes` / `obj.slots`
// fresh). The C backend's emitted arms carry the real G1/G2 discipline ; S2b
// proves it on a bespoke fixture.

/// Body of the `object_new` arm. Pops `size` (usize) and pushes a zero-filled
/// `ObjVal` of that byte length. `type_id` is the inline immediate (D2).
/// `handle_cell[0]` is the monotonic synthetic-handle source (diagnostics).
///
/// @param type_id      the object's type-table ordinal (Buffer = the
///                     `VADER_TYPE_INDEX_BUFFER` sentinel, D3).
/// @param frame        current top frame, mutated in place (size popped, obj
///                     pushed in its place — net stack effect 0).
/// @param handle_cell  1-cell carrier for the monotonic handle counter.
/// @return             `null` on success, or a `Trap` on stack underflow /
///                     negative size.
/// @error              empty stack ; negative size.
build_object :: fn(type_id: i32, frame: Frame, handle_cell: i32[]) -> Trap | null {
    if frame.sp < 1 {
        return Trap { .message = "object_new needs size on stack at pc=${frame.pc}" }
    }
    size_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "object_new size")
    if size_unwrap is Trap { return size_unwrap }
    if size_unwrap.value < 0 {
        return Trap { .message = "object_new size ${size_unwrap.value} is negative at pc=${frame.pc}" }
    }
    bytes: u8[] = []
    for _ in 0..<usize(size_unwrap.value) {
        bytes.push(0)
    }
    handle_cell[0] = handle_cell[0] + 1
    push_val(frame, frame.sp - 1, ObjVal { .handle = handle_cell[0], .type_id = type_id, .bytes = bytes, .slots = [] })
    frame.pc = frame.pc + 1
    return null
}

/// Shared front-half of the typed/byte loads (`load_u8` / `load_i32` /
/// `load_i64`). Validates `obj, off` on the stack and bounds, then returns the
/// `width` little-endian bytes at `off` as a zero-extended u64 — the caller
/// wraps it in the right `Value` and advances the stack/pc.
///
/// @param frame  current top frame ; not mutated here (the arm overwrites
///               `stack[sp-2]` and drops one slot).
/// @param width  byte width to read (1 / 4 / 8).
/// @param label  op label for trap messages.
/// @return       the raw value, or a `Trap` on underflow / bad obj / OOB.
/// @error        fewer than 2 stack slots ; non-object receiver ; negative or
///               out-of-range offset.
/// Validate a byte-region access for the typed load/store ops: the offset must
/// be non-negative and `[off, off + width)` must fall within `bytes_len`.
/// Centralises the bounds logic + trap wording shared by `load_bytes_op` and
/// `store_bytes_op` so the two stay in lockstep.
///
/// @param off        the raw signed offset popped off the stack.
/// @param width      byte width of the access (1 / 4 / 8).
/// @param bytes_len  length of the object's inline byte region.
/// @param label      op label for trap messages.
/// @param pc         current program counter, for trap provenance.
/// @return           the validated `usize` offset.
/// @error            negative offset ; range past the byte length.
check_byte_range :: fn(off: i32, width: usize, bytes_len: usize, label: string, pc: i32) -> usize | Trap {
    if off < 0 {
        return Trap { .message = "${label} offset ${off} is negative at pc=${pc}" }
    }
    o :: usize(off)
    if o + width > bytes_len {
        return Trap { .message = "${label} offset ${o} (+${width}) exceeds object byte length ${bytes_len} at pc=${pc}" }
    }
    return o
}

load_bytes_op :: fn(frame: Frame, width: usize, label: string) -> u64 | Trap {
    if frame.sp < 2 {
        return Trap { .message = "${label} needs object + offset on stack at pc=${frame.pc}" }
    }
    off_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "${label} offset")
    if off_unwrap is Trap { return off_unwrap }
    obj_unwrap :: read_obj(peek_val(frame, frame.sp - 2), frame.pc, "${label} receiver")
    if obj_unwrap is Trap { return obj_unwrap }
    off :: check_byte_range(off_unwrap.value, width, obj_unwrap.bytes.len(), label, frame.pc)
    if off is Trap { return off }
    return read_le(obj_unwrap.bytes, off, width)
}

/// Shared body of the typed/byte stores (`store_u8` / `store_i32` /
/// `store_i64`). The caller has already read the value off `stack[sp-1]` into
/// `value` (the raw bit pattern) and guaranteed `sp >= 3`. Validates `obj`
/// (sp-3) and `off` (sp-2), bounds-checks, writes `width` little-endian bytes,
/// then drops the three operands and advances pc.
///
/// @param frame  current top frame, mutated in place.
/// @param width  byte width to write (1 / 4 / 8).
/// @param value  the raw bit pattern whose low `width` bytes are stored.
/// @param label  op label for trap messages.
/// @return       `null` on success, or a `Trap` on bad obj / OOB offset.
/// @error        non-object receiver ; negative or out-of-range offset.
store_bytes_op :: fn(frame: Frame, width: usize, value: u64, label: string) -> Trap | null {
    off_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "${label} offset")
    if off_unwrap is Trap { return off_unwrap }
    obj_unwrap :: read_obj(peek_val(frame, frame.sp - 3), frame.pc, "${label} receiver")
    if obj_unwrap is Trap { return obj_unwrap }
    off :: check_byte_range(off_unwrap.value, width, obj_unwrap.bytes.len(), label, frame.pc)
    if off is Trap { return off }
    write_le(obj_unwrap.bytes, off, width, value)
    frame.sp = frame.sp - 3
    frame.pc = frame.pc + 1
    return null
}

/// Body of the `load_slot` family. Pops `arr, index` and pushes the element at
/// `arr.offset + index`. `arr` is a `T[]` (`ArrayVal`) — the slot `@intrinsic`s
/// are impl'd on `T[]`, so the operand is the array, mirroring native (which
/// derefs `->buf` + `->offset`). The VM stores every element as a uniform
/// `Value`, so this serves the boxed `load_slot` and each width-typed primitive
/// `load_slot_*` alike (the native byte-width distinction is native-only).
/// @param frame  current top frame, mutated in place (1 operand dropped).
/// @return       `null` on success, or a `Trap` on underflow / non-array / OOB.
do_load_slot :: fn(frame: Frame) -> Trap | null {
    if frame.sp < 2 { return Trap { .message = "load_slot needs array + index on stack at pc=${frame.pc}" } }
    idx_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "load_slot index")
    if idx_unwrap is Trap { return idx_unwrap }
    arr :: read_array(peek_val(frame, frame.sp - 2), frame.pc, "load_slot receiver")
    if arr is Trap { return arr }
    if idx_unwrap.value < 0 || usize(idx_unwrap.value) >= arr.length {
        return Trap { .message = "load_slot index ${idx_unwrap.value} out of bounds (len=${arr.length}) at pc=${frame.pc}" }
    }
    push_val(frame, frame.sp - 2, arr.elements[arr.offset + usize(idx_unwrap.value)])
    frame.sp = frame.sp - 1
    frame.pc = frame.pc + 1
    return null
}

/// Body of the `store_slot` family. Pops `arr, index, value` and writes `value`
/// at `arr.offset + index` (bounds-checked against `length` — the array.vader
/// impl checks before calling, this is the oracle's defensive mirror). `arr` is
/// a `T[]` (`ArrayVal`). Serves the boxed `store_slot` and each primitive
/// `store_slot_*`. In the C backend the boxed `store_slot` fires
/// `VADER_WRITE_BARRIER(arr->buf)` (G2) ; in the VM the host GC traces
/// `elements` directly so the barrier is implicit. (`push`'s grow-append is a
/// separate path — S5 inc 3.)
/// @param frame  current top frame, mutated in place (3 operands dropped).
/// @return       `null` on success, or a `Trap` on underflow / non-array / OOB.
do_store_slot :: fn(frame: Frame) -> Trap | null {
    if frame.sp < 3 { return Trap { .message = "store_slot needs array + index + value on stack at pc=${frame.pc}" } }
    value :: peek_val(frame, frame.sp - 1)
    idx_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "store_slot index")
    if idx_unwrap is Trap { return idx_unwrap }
    arr :: read_array(peek_val(frame, frame.sp - 3), frame.pc, "store_slot receiver")
    if arr is Trap { return arr }
    if idx_unwrap.value < 0 || usize(idx_unwrap.value) >= arr.length {
        return Trap { .message = "store_slot index ${idx_unwrap.value} out of bounds (len=${arr.length}) at pc=${frame.pc}" }
    }
    arr.elements[arr.offset + usize(idx_unwrap.value)] = value
    frame.sp = frame.sp - 3
    frame.pc = frame.pc + 1
    return null
}

/// Body of the `memory_copy` arm. Pops `dst, dst_off, src, src_off, n` and
/// copies `n` bytes src→dst (raw byte regions). Bounds-checks both ends and
/// copies through a snapshot, so an overlapping self-copy stays well-defined
/// in the oracle (native lowers to `memcpy` and the lowerer guarantees no
/// overlap — the snapshot only hardens the VM reference impl).
///
/// @param frame  current top frame, mutated in place (5 operands dropped).
/// @return       `null` on success, or a `Trap` on underflow / bad obj / OOB.
/// @error        fewer than 5 stack slots ; non-object dst/src ; negative
///               length/offset ; source or dest range past the byte length.
do_memory_copy :: fn(frame: Frame) -> Trap | null {
    if frame.sp < 5 {
        return Trap { .message = "memory_copy needs dst + dst_off + src + src_off + n on stack at pc=${frame.pc}" }
    }
    n_unwrap :: read_i32(peek_val(frame, frame.sp - 1), frame.pc, "memory_copy n")
    if n_unwrap is Trap { return n_unwrap }
    src_off_unwrap :: read_i32(peek_val(frame, frame.sp - 2), frame.pc, "memory_copy src_off")
    if src_off_unwrap is Trap { return src_off_unwrap }
    src_unwrap :: read_obj(peek_val(frame, frame.sp - 3), frame.pc, "memory_copy src")
    if src_unwrap is Trap { return src_unwrap }
    dst_off_unwrap :: read_i32(peek_val(frame, frame.sp - 4), frame.pc, "memory_copy dst_off")
    if dst_off_unwrap is Trap { return dst_off_unwrap }
    dst_unwrap :: read_obj(peek_val(frame, frame.sp - 5), frame.pc, "memory_copy dst")
    if dst_unwrap is Trap { return dst_unwrap }
    if n_unwrap.value < 0 || src_off_unwrap.value < 0 || dst_off_unwrap.value < 0 {
        return Trap { .message = "memory_copy negative length/offset at pc=${frame.pc}" }
    }
    n :: usize(n_unwrap.value)
    src_off :: usize(src_off_unwrap.value)
    dst_off :: usize(dst_off_unwrap.value)
    if src_off + n > src_unwrap.bytes.len() {
        return Trap { .message = "memory_copy source range [${src_off}, ${src_off + n}) exceeds ${src_unwrap.bytes.len()} at pc=${frame.pc}" }
    }
    if dst_off + n > dst_unwrap.bytes.len() {
        return Trap { .message = "memory_copy dest range [${dst_off}, ${dst_off + n}) exceeds ${dst_unwrap.bytes.len()} at pc=${frame.pc}" }
    }
    snapshot: u8[] = []
    for i in 0..<n {
        snapshot.push(src_unwrap.bytes[src_off + i])
    }
    for i in 0..<n {
        dst_unwrap.bytes[dst_off + i] = snapshot[i]
    }
    frame.sp = frame.sp - 5
    frame.pc = frame.pc + 1
    return null
}

// ---- entry --------------------------------------------------------------

/// CLI entry — read a `.virt` text dump from `path`, parse it, run it,
/// and return an exit code. Diagnostics go to stderr.
///
/// @param path  filesystem path to the `.virt` file.
/// @return      the i32 the program's `main` returned (or `0` if it
///              fell through without an explicit `return`) ; `1` when
///              the file can't be read or the VM trapped — the error
///              message goes to stderr in both cases.
/// @error       missing file ; any VM trap surfaced by `exec`.
export run_virt :: fn(path: string, host_argv: string[]) -> i32 {
    source :: read_file_string(path)
    if source is IOError {
        eprintln("vader run: cannot read ${path}")
        return 1
    }
    return match exec(prepare(parse_virt_bc(source)), host_argv) {
        is Ok   as o -> o.value
        is Trap as t -> {
            eprintln("vader vm: ${t.message}")
            1
        }
    }
}
