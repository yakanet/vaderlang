// vader/vm/exec — stack-machine interpreter for the .virt bytecode.
//
// Reads a parsed `Module` (see `parser.vader`) and runs its `main`
// function. The op set grows sprint by sprint (docs/SELFHOST_VM.md) ;
// the value stack is `Value[]` (tagged union), promoted from the raw
// `i32[]` of sprints 1-2 so strings and host calls can flow through.
//
// Sprint 4 introduces explicit `Frame` records and a frame stack —
// each Vader-side `call N` pushes a callee frame, `return` pops it
// and pushes the return value onto the caller's stack. Locals live
// in the frame's `slots` array (params at the bottom, then declared
// locals) ; the value stack is per-frame.
//
// VM-level errors (stack underflow, malformed bytecode, unsupported
// op, host-import dispatch miss) come back as a `Trap` variant of
// `VmResult` with a labelled message — the runtime's generic
// "array index out of bounds" would otherwise mask compiler / parser
// bugs.

import "std/io" { read_file, eprintln, println }
import "std/string_builder" { StringBuilder, new_builder, append }
import "vader/vm/op" { Op, I32Const, LocalGet, LocalSet, LocalTee, StringConst, CallImport, Call, FnRef, CallIndirect, StructNew, StructGet, StructSet, ArrayNew, ArrayPush, ArrayGet, ArraySet, ArrayLen, RefCast, Convert, BuilderNew, BuilderAppendStr, BuilderAppendDisplay, BuilderFinish, I32Add, I32Sub, I32Mul, I32Div, I32Mod, I32Eq, I32Ne, I32Lt, I32Le, I32Gt, I32Ge, Block, Loop, If, Else, End, Branch, BranchIf, Return, ImportInfo, BytecodeFunction, Module, TypeDecl, StructType, ArrayType, FnType, Value, I32Val, StringVal, StructVal, ArrayVal, BuilderVal, FnVal, display_value }
import "vader/vm/parser" { parse_virt }

/// Tagged outcome of an `exec` call. `Ok` carries the program's i32
/// return value ; `Trap` carries a debug-friendly message so the host
/// can surface it instead of a generic runtime abort.
export VmResult :: Ok | Trap
export Ok   :: struct { value: i32 }
export Trap :: struct { message: string }

// Mangled host-import names. Lifted to module-scope so the dispatch
// chain reads as identifier comparisons rather than raw-string
// literals — also avoids re-allocating the strings per op execution.
// Raw form (`r"..."`) bypasses Vader's `$<ident>` interpolation
// syntax, which would otherwise try to resolve `println` etc. as
// inline expressions.
STDIO_PRINTLN  :: r"std_io$println"
STDIO_PRINT    :: r"std_io$print"
STDIO_EPRINTLN :: r"std_io$eprintln"

// Maximum frame depth — guards against runaway recursion (the
// callee-frame allocation could otherwise grow unbounded). Picked
// well above what hand-written snippets need ; large enough that
// genuine recursive workloads pass, small enough to surface a Trap
// before the host runs out of memory.
MAX_FRAME_DEPTH :: 1024

/// A single call frame on the VM's frame stack. `slots[0..parameter_count]`
/// hold the params bound at `Call` time, followed by `local_count` zero-
/// initialised locals. `stack` is per-frame ; `sp` is the logical top
/// cursor (the array is grow-only, see `push_value`). `pc` indexes into
/// the function's `ops` array.
///
/// `slots` and `stack` use the inlined `(I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[]`
/// shape (rather than `Value[]`) as a work-around for TODO §3.8 — the
/// `Value` alias doesn't expand correctly in `Alias[]` array slots when
/// the alias was imported from another module (cross-module `: Value`
/// scalars work fine ; only the array case is broken).
Frame :: struct {
    function_index: i32
    slots:          (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[]
    stack:          (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[]
    sp:             usize
    pc:             i32
}

/// Default-zero `Value`, used to size each frame's locals at fn entry.
///
/// @return  a fresh `I32Val { .value = 0 }`.
zero_value :: fn() -> Value { return I32Val { .value = 0 } }

/// Push `value` at the cursor position, growing the backing array
/// when needed (Vader has `push` but not capacity-managed insert).
///
/// @param stack   the grow-only value stack (mutated in place).
/// @param cursor  logical top index — `cursor == stack.len()` means a
///                fresh slot is needed, otherwise an existing one is
///                overwritten (cheaper than `push`).
/// @param value   the value to write.
push_value :: fn(stack: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[], cursor: usize, value: Value) -> void {
    if cursor == stack.len() { stack.push(value) }
    else                     { stack[cursor] = value }
}

/// Append `new_frame` at `cursor[0]`, growing `frames` if needed. The
/// `frames` array is grow-only — `pop_frame` only decrements the cursor,
/// the underlying slot is reused on the next push. Same cursor pattern
/// used elsewhere in the VM (scope stack, pending branches).
///
/// @param frames     the grow-only frame stack (mutated in place).
/// @param cursor     1-element box — `[0]` is the logical top index.
/// @param new_frame  the callee frame to push.
push_frame :: fn(frames: Frame[], cursor: usize[], new_frame: Frame) -> void {
    if cursor[0] == frames.len() { frames.push(new_frame) }
    else                         { frames[cursor[0]] = new_frame }
    cursor[0] += 1
}

/// Decrement the frame cursor by 1. The released slot stays in
/// `frames` (carrying its now-unreferenced `slots` / `stack` arrays
/// until the next push overwrites it).
///
/// @param cursor  1-element box — `[0]` is the logical top index.
pop_frame :: fn(cursor: usize[]) -> void {
    cursor[0] -= 1
}

/// Build a new `Frame` for a callee. Params are copied straight from
/// `args_source[args_offset .. args_offset + parameter_count]` into
/// `slots[0..parameter_count]` — typically `args_source` is the caller's
/// stack and `args_offset` is its post-pop cursor. Locals (`local_count`
/// of them) follow, zero-initialised.
///
/// @param function_index  module-level index of the callee (recorded on
///                        the frame so the executor can look up the body).
/// @param callee          the callee's `BytecodeFunction` (read for the
///                        slot counts).
/// @param args_source     the array to read params from.
/// @param args_offset     start offset of the params within `args_source`.
/// @return                a fresh `Frame` ready to be pushed.
build_callee_frame :: fn(function_index: i32, callee: BytecodeFunction, args_source: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[], args_offset: usize) -> Frame {
    slots: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[] = []
    parameter_index: usize = 0
    for parameter_index < callee.parameter_count {
        slots.push(args_source[args_offset + parameter_index])
        parameter_index += 1
    }
    local_index: usize = 0
    for local_index < callee.local_count {
        slots.push(zero_value())
        local_index += 1
    }
    return Frame {
        .function_index = function_index,
        .slots          = slots,
        .stack          = [],
        .sp             = 0,
        .pc             = 0,
    }
}

/// Return a copy of `frame` with `sp` / `pc` updated. The slots and
/// stack arrays are shared (Vader arrays are reference-typed), so
/// mutations through `frame.stack[...]` / `frame.slots[...]` are
/// visible after the write-back.
///
/// @param frame  the frame to update.
/// @param sp     new value stack cursor.
/// @param pc     new program counter (next op index).
/// @return       a fresh `Frame` carrying the new sp/pc, with the same
///               slots / stack array references.
with_sp_pc :: fn(frame: Frame, sp: usize, pc: i32) -> Frame {
    return Frame {
        .function_index = frame.function_index,
        .slots          = frame.slots,
        .stack          = frame.stack,
        .sp             = sp,
        .pc             = pc,
    }
}

/// Apply a pure i32-to-i32 binary op (Add/Sub/Mul) on top-of-stack.
/// Pops two i32 from `frame.stack`, runs `op`, writes the result, and
/// advances pc + sp.
///
/// @param frame      current top frame.
/// @param top        index of `frame` within `frames` (for the write-back).
/// @param frames     the frame stack (mutated via `frames[top] = ...`).
/// @param op_label   short label used in the Trap message on type mismatch.
/// @param op         the i32 binary op to apply to (left, right).
/// @return           `null` on success, or a `Trap` if either operand
///                   isn't an i32 (caller surfaces it).
/// @error            type mismatch on the left or right operand.
apply_arith_binop :: fn(frame: Frame, top: usize, frames: Frame[], op_label: string, op: fn(i32, i32) -> i32) -> Trap | null {
    left  :: read_i32(frame.stack[frame.sp - 2], frame.pc, op_label)
    right :: read_i32(frame.stack[frame.sp - 1], frame.pc, op_label)
    if left  is Trap { return left  }
    if right is Trap { return right }
    frame.stack[frame.sp - 2] = I32Val { .value = op(left.value, right.value) }
    frames[top] = with_sp_pc(frame, frame.sp - 1, frame.pc + 1)
    return null
}

/// Variant of `apply_arith_binop` that traps when the right operand
/// is zero — used by `i32.div` and `i32.mod` so division-by-zero
/// surfaces a labelled Trap rather than a host-level abort.
///
/// @param frame      current top frame.
/// @param top        index of `frame` within `frames`.
/// @param frames     the frame stack (mutated via `frames[top] = ...`).
/// @param op_label   short label used in Trap messages.
/// @param op         the i32 binary op (`div` or `mod`).
/// @return           `null` on success, or a `Trap` on type mismatch /
///                   division by zero.
/// @error            type mismatch ; right operand equal to zero.
apply_div_mod_binop :: fn(frame: Frame, top: usize, frames: Frame[], op_label: string, op: fn(i32, i32) -> i32) -> Trap | null {
    left  :: read_i32(frame.stack[frame.sp - 2], frame.pc, op_label)
    right :: read_i32(frame.stack[frame.sp - 1], frame.pc, op_label)
    if left  is Trap { return left  }
    if right is Trap { return right }
    if right.value == 0 { return Trap { .message = "${op_label} by zero at pc=${frame.pc}" } }
    frame.stack[frame.sp - 2] = I32Val { .value = op(left.value, right.value) }
    frames[top] = with_sp_pc(frame, frame.sp - 1, frame.pc + 1)
    return null
}

/// Apply an i32 comparison (Eq/Ne/Lt/Le/Gt/Ge) on top-of-stack. The
/// boolean result is pushed back as an i32 `1` / `0` (matching the
/// wasm-style stack-machine convention).
///
/// @param frame      current top frame.
/// @param top        index of `frame` within `frames`.
/// @param frames     the frame stack (mutated via `frames[top] = ...`).
/// @param op_label   short label used in the Trap message on type mismatch.
/// @param cmp        the i32 comparison predicate.
/// @return           `null` on success, or a `Trap` on type mismatch.
/// @error            type mismatch on either operand.
apply_cmp_binop :: fn(frame: Frame, top: usize, frames: Frame[], op_label: string, cmp: fn(i32, i32) -> bool) -> Trap | null {
    left  :: read_i32(frame.stack[frame.sp - 2], frame.pc, op_label)
    right :: read_i32(frame.stack[frame.sp - 1], frame.pc, op_label)
    if left  is Trap { return left  }
    if right is Trap { return right }
    result :: if cmp(left.value, right.value) { 1 } else { 0 }
    frame.stack[frame.sp - 2] = I32Val { .value = result }
    frames[top] = with_sp_pc(frame, frame.sp - 1, frame.pc + 1)
    return null
}

/// Stack-machine interpreter, frame-based to support direct Vader-side
/// calls. One outer-loop iteration dispatches one op on the top frame ;
/// the op's effect mutates the top frame's stack / slots / sp / pc and
/// (for `Call` / `Return`) pushes or pops the frame stack itself.
///
/// @param module  a parsed `.virt` module — `main_index` must point at
///                a valid entry in `functions`.
/// @return        `Ok(value)` when `main` returns an i32 ; `Trap(message)`
///                on any VM-level error (malformed bytecode, type
///                mismatch, division by zero, call-stack overflow, etc).
/// @error         missing or out-of-range `main_index` ; type mismatch
///                in any op ; div / mod by zero ; unknown host import ;
///                call to a non-existent function index ; call stack
///                deeper than `MAX_FRAME_DEPTH`.
export exec :: fn(module: Module) -> VmResult {
    if module.main_index < 0 || usize(module.main_index) >= module.functions.len() {
        return Trap { .message = "module has no entry function (main_index=${module.main_index})" }
    }

    frames: Frame[] = []
    frame_count: usize[] = [0]

    main_function :: module.functions[usize(module.main_index)]
    main_frame :: build_callee_frame(module.main_index, main_function, [], 0)
    push_frame(frames, frame_count, main_frame)

    for frame_count[0] > 0 {
        top :: frame_count[0] - 1
        frame :: frames[top]
        body :: module.functions[usize(frame.function_index)]
        op_count :: body.ops.len()

        // Fell off the end of the body without an explicit `return`.
        // Treat like `return` with no value on the stack — pops the
        // frame and surfaces 0 to the caller (or to the host if main).
        if frame.pc >= i32(op_count) {
            pop_frame(frame_count)
            if frame_count[0] == 0 { return Ok { .value = 0 } }
            continue
        }

        op :: body.ops[frame.pc]
        match op {
            is I32Const -> {
                push_value(frame.stack, frame.sp, I32Val { .value = op.value })
                frames[top] = with_sp_pc(frame, frame.sp + 1, frame.pc + 1)
            }
            is LocalGet -> {
                if op.slot < 0 || usize(op.slot) >= frame.slots.len() {
                    return Trap { .message = "local.get slot ${op.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                push_value(frame.stack, frame.sp, frame.slots[op.slot])
                frames[top] = with_sp_pc(frame, frame.sp + 1, frame.pc + 1)
            }
            is LocalSet -> {
                if frame.sp == 0 {
                    return Trap { .message = "local.set on empty stack at pc=${frame.pc} in '${body.name}'" }
                }
                if op.slot < 0 || usize(op.slot) >= frame.slots.len() {
                    return Trap { .message = "local.set slot ${op.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                frame.slots[op.slot] = frame.stack[frame.sp - 1]
                frames[top] = with_sp_pc(frame, frame.sp - 1, frame.pc + 1)
            }
            is LocalTee -> {
                if frame.sp == 0 {
                    return Trap { .message = "local.tee on empty stack at pc=${frame.pc} in '${body.name}'" }
                }
                if op.slot < 0 || usize(op.slot) >= frame.slots.len() {
                    return Trap { .message = "local.tee slot ${op.slot} out of range at pc=${frame.pc} in '${body.name}'" }
                }
                frame.slots[op.slot] = frame.stack[frame.sp - 1]
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is StringConst -> {
                if op.index < 0 || usize(op.index) >= module.strings.len() {
                    return Trap { .message = "string.const index ${op.index} out of range at pc=${frame.pc}" }
                }
                push_value(frame.stack, frame.sp, StringVal { .value = module.strings[op.index] })
                frames[top] = with_sp_pc(frame, frame.sp + 1, frame.pc + 1)
            }
            is CallImport -> {
                if op.index < 0 || usize(op.index) >= module.imports.len() {
                    return Trap { .message = "call.import ${op.index} out of range at pc=${frame.pc}" }
                }
                info :: module.imports[op.index]
                if frame.sp < info.parameter_count {
                    return Trap { .message = "call.import '${info.mangled}' needs ${info.parameter_count} arg(s) but stack has ${frame.sp} at pc=${frame.pc}" }
                }
                arg_base :: frame.sp - info.parameter_count
                dispatch_outcome :: dispatch_import(info, frame.stack, arg_base, frame.pc)
                if dispatch_outcome is Trap {
                    return dispatch_outcome
                }
                new_sp := arg_base
                if info.has_return {
                    push_value(frame.stack, new_sp, dispatch_outcome.value)
                    new_sp += 1
                }
                frames[top] = with_sp_pc(frame, new_sp, frame.pc + 1)
            }
            is Call -> {
                if op.function_index < 0 || usize(op.function_index) >= module.functions.len() {
                    return Trap { .message = "call to function ${op.function_index} out of range at pc=${frame.pc}" }
                }
                callee :: module.functions[usize(op.function_index)]
                if frame.sp < callee.parameter_count {
                    return Trap { .message = "call to '${callee.name}' needs ${callee.parameter_count} arg(s) but stack has ${frame.sp} at pc=${frame.pc}" }
                }
                arg_base :: frame.sp - callee.parameter_count
                // Build the callee frame *before* writing back the caller :
                // `build_callee_frame` reads from `frame.stack[arg_base..]`,
                // which stays valid since arrays are reference-typed and the
                // sp shrink below is purely cursor-level.
                callee_frame :: build_callee_frame(op.function_index, callee, frame.stack, arg_base)
                frames[top] = with_sp_pc(frame, arg_base, frame.pc + 1)
                push_frame(frames, frame_count, callee_frame)
                if frame_count[0] > usize(MAX_FRAME_DEPTH) {
                    return Trap { .message = "call stack overflow (depth > ${MAX_FRAME_DEPTH}) at function '${callee.name}'" }
                }
            }
            is FnRef -> {
                if op.function_index < 0 || usize(op.function_index) >= module.functions.len() {
                    return Trap { .message = "fn.ref function ${op.function_index} out of range at pc=${frame.pc}" }
                }
                push_value(frame.stack, frame.sp, FnVal { .function_index = op.function_index })
                frames[top] = with_sp_pc(frame, frame.sp + 1, frame.pc + 1)
            }
            is CallIndirect -> {
                // Resolve param count via the FnType in the type table —
                // the `call.indirect` op carries the type_id, not the count
                // directly (mirrors `src/vm/exec.ts` which does the same lookup).
                if op.type_id < 0 || usize(op.type_id) >= module.types.len() {
                    return Trap { .message = "call.indirect type ${op.type_id} out of range at pc=${frame.pc}" }
                }
                fn_type_decl :: module.types[usize(op.type_id)]
                if !(fn_type_decl is FnType) {
                    return Trap { .message = "call.indirect type ${op.type_id} is not a fn type at pc=${frame.pc}" }
                }
                indirect_arity :: fn_type_decl.parameter_type_ids.len()
                // Stack layout : [args..., fn_ref]. Pop fn_ref first, then
                // read the arg block beneath it.
                if frame.sp < 1 + indirect_arity {
                    return Trap { .message = "call.indirect needs ${indirect_arity} arg(s) + fn-ref but stack has ${frame.sp} at pc=${frame.pc}" }
                }
                fn_unwrap :: read_fn(frame.stack[frame.sp - 1], frame.pc, "call.indirect receiver")
                if fn_unwrap is Trap { return fn_unwrap }
                if fn_unwrap.function_index < 0 || usize(fn_unwrap.function_index) >= module.functions.len() {
                    return Trap { .message = "call.indirect to function ${fn_unwrap.function_index} out of range at pc=${frame.pc}" }
                }
                callee :: module.functions[usize(fn_unwrap.function_index)]
                if callee.parameter_count != indirect_arity {
                    return Trap { .message = "call.indirect to '${callee.name}' expects ${callee.parameter_count} param(s) but FnType declares ${indirect_arity} at pc=${frame.pc}" }
                }
                arg_base :: frame.sp - 1 - indirect_arity
                callee_frame :: build_callee_frame(fn_unwrap.function_index, callee, frame.stack, arg_base)
                frames[top] = with_sp_pc(frame, arg_base, frame.pc + 1)
                push_frame(frames, frame_count, callee_frame)
                if frame_count[0] > usize(MAX_FRAME_DEPTH) {
                    return Trap { .message = "call stack overflow (depth > ${MAX_FRAME_DEPTH}) at function '${callee.name}'" }
                }
            }
            is StructNew -> {
                outcome :: build_struct(module, op.type_id, frame)
                if outcome is Trap { return outcome }
                frames[top] = outcome
            }
            is StructGet -> {
                if frame.sp == 0 {
                    return Trap { .message = "struct.get on empty stack at pc=${frame.pc}" }
                }
                struct_unwrap :: read_struct(frame.stack[frame.sp - 1], frame.pc, "struct.get receiver")
                if struct_unwrap is Trap { return struct_unwrap }
                if op.field_index < 0 || usize(op.field_index) >= struct_unwrap.fields.len() {
                    return Trap { .message = "struct.get field ${op.field_index} out of range (struct has ${struct_unwrap.fields.len()} fields) at pc=${frame.pc}" }
                }
                frame.stack[frame.sp - 1] = struct_unwrap.fields[usize(op.field_index)]
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is StructSet -> {
                if frame.sp < 2 {
                    return Trap { .message = "struct.set needs receiver + value on stack at pc=${frame.pc}" }
                }
                struct_unwrap :: read_struct(frame.stack[frame.sp - 2], frame.pc, "struct.set receiver")
                if struct_unwrap is Trap { return struct_unwrap }
                if op.field_index < 0 || usize(op.field_index) >= struct_unwrap.fields.len() {
                    return Trap { .message = "struct.set field ${op.field_index} out of range (struct has ${struct_unwrap.fields.len()} fields) at pc=${frame.pc}" }
                }
                struct_unwrap.fields[usize(op.field_index)] = frame.stack[frame.sp - 1]
                frames[top] = with_sp_pc(frame, frame.sp - 2, frame.pc + 1)
            }
            is ArrayNew -> {
                outcome :: build_array(op.type_id, op.length, frame)
                if outcome is Trap { return outcome }
                frames[top] = outcome
            }
            is ArrayPush -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.push needs array + value on stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(frame.stack[frame.sp - 2], frame.pc, "array.push receiver")
                if array_unwrap is Trap { return array_unwrap }
                array_unwrap.elements.push(frame.stack[frame.sp - 1])
                frames[top] = with_sp_pc(frame, frame.sp - 2, frame.pc + 1)
            }
            is ArrayGet -> {
                if frame.sp < 2 {
                    return Trap { .message = "array.get needs array + index on stack at pc=${frame.pc}" }
                }
                index_unwrap :: read_i32(frame.stack[frame.sp - 1], frame.pc, "array.get index")
                if index_unwrap is Trap { return index_unwrap }
                array_unwrap :: read_array(frame.stack[frame.sp - 2], frame.pc, "array.get receiver")
                if array_unwrap is Trap { return array_unwrap }
                if index_unwrap.value < 0 || usize(index_unwrap.value) >= array_unwrap.elements.len() {
                    return Trap { .message = "array.get index ${index_unwrap.value} out of bounds (len=${array_unwrap.elements.len()}) at pc=${frame.pc}" }
                }
                frame.stack[frame.sp - 2] = array_unwrap.elements[usize(index_unwrap.value)]
                frames[top] = with_sp_pc(frame, frame.sp - 1, frame.pc + 1)
            }
            is ArraySet -> {
                if frame.sp < 3 {
                    return Trap { .message = "array.set needs array + index + value on stack at pc=${frame.pc}" }
                }
                index_unwrap :: read_i32(frame.stack[frame.sp - 2], frame.pc, "array.set index")
                if index_unwrap is Trap { return index_unwrap }
                array_unwrap :: read_array(frame.stack[frame.sp - 3], frame.pc, "array.set receiver")
                if array_unwrap is Trap { return array_unwrap }
                if index_unwrap.value < 0 || usize(index_unwrap.value) >= array_unwrap.elements.len() {
                    return Trap { .message = "array.set index ${index_unwrap.value} out of bounds (len=${array_unwrap.elements.len()}) at pc=${frame.pc}" }
                }
                array_unwrap.elements[usize(index_unwrap.value)] = frame.stack[frame.sp - 1]
                frames[top] = with_sp_pc(frame, frame.sp - 3, frame.pc + 1)
            }
            is ArrayLen -> {
                if frame.sp == 0 {
                    return Trap { .message = "array.len on empty stack at pc=${frame.pc}" }
                }
                array_unwrap :: read_array(frame.stack[frame.sp - 1], frame.pc, "array.len receiver")
                if array_unwrap is Trap { return array_unwrap }
                frame.stack[frame.sp - 1] = I32Val { .value = i32(array_unwrap.elements.len()) }
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is RefCast -> {
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is Convert -> {
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is BuilderNew -> {
                push_value(frame.stack, frame.sp, BuilderVal { .parts = [] })
                frames[top] = with_sp_pc(frame, frame.sp + 1, frame.pc + 1)
            }
            is BuilderAppendStr -> {
                if frame.sp < 2 {
                    return Trap { .message = "intrinsic builder.append_str needs builder + string on stack at pc=${frame.pc}" }
                }
                str_unwrap :: read_string(frame.stack[frame.sp - 1], frame.pc, "intrinsic builder.append_str string")
                if str_unwrap is Trap { return str_unwrap }
                builder_unwrap :: read_builder(frame.stack[frame.sp - 2], frame.pc, "intrinsic builder.append_str receiver")
                if builder_unwrap is Trap { return builder_unwrap }
                builder_unwrap.parts.push(str_unwrap.value)
                frames[top] = with_sp_pc(frame, frame.sp - 2, frame.pc + 1)
            }
            is BuilderAppendDisplay -> {
                if frame.sp < 2 {
                    return Trap { .message = "intrinsic builder.append_display needs builder + value on stack at pc=${frame.pc}" }
                }
                builder_unwrap :: read_builder(frame.stack[frame.sp - 2], frame.pc, "intrinsic builder.append_display receiver")
                if builder_unwrap is Trap { return builder_unwrap }
                builder_unwrap.parts.push(display_value(frame.stack[frame.sp - 1]))
                frames[top] = with_sp_pc(frame, frame.sp - 2, frame.pc + 1)
            }
            is BuilderFinish -> {
                if frame.sp == 0 {
                    return Trap { .message = "intrinsic builder.finish on empty stack at pc=${frame.pc}" }
                }
                builder_unwrap :: read_builder(frame.stack[frame.sp - 1], frame.pc, "intrinsic builder.finish receiver")
                if builder_unwrap is Trap { return builder_unwrap }
                // Reuse `builder.parts` by reference inside a transient
                // `StringBuilder` — its `@intrinsic Display::to_string`
                // flushes the parts in one pass with one allocation, no
                // intermediate copy.
                flushing :: StringBuilder { .parts = builder_unwrap.parts }
                frame.stack[frame.sp - 1] = StringVal { .value = "${flushing}" }
                frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1)
            }
            is I32Add -> {
                outcome :: apply_arith_binop(frame, top, frames, "i32.add", (a, b) -> a + b)
                if outcome is Trap { return outcome }
            }
            is I32Sub -> {
                outcome :: apply_arith_binop(frame, top, frames, "i32.sub", (a, b) -> a - b)
                if outcome is Trap { return outcome }
            }
            is I32Mul -> {
                outcome :: apply_arith_binop(frame, top, frames, "i32.mul", (a, b) -> a * b)
                if outcome is Trap { return outcome }
            }
            is I32Div -> {
                outcome :: apply_div_mod_binop(frame, top, frames, "i32.div", (a, b) -> a / b)
                if outcome is Trap { return outcome }
            }
            is I32Mod -> {
                outcome :: apply_div_mod_binop(frame, top, frames, "i32.mod", (a, b) -> a % b)
                if outcome is Trap { return outcome }
            }
            is I32Eq -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.eq", (a, b) -> a == b)
                if outcome is Trap { return outcome }
            }
            is I32Ne -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.ne", (a, b) -> a != b)
                if outcome is Trap { return outcome }
            }
            is I32Lt -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.lt", (a, b) -> a < b)
                if outcome is Trap { return outcome }
            }
            is I32Le -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.le", (a, b) -> a <= b)
                if outcome is Trap { return outcome }
            }
            is I32Gt -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.gt", (a, b) -> a > b)
                if outcome is Trap { return outcome }
            }
            is I32Ge -> {
                outcome :: apply_cmp_binop(frame, top, frames, "i32.ge", (a, b) -> a >= b)
                if outcome is Trap { return outcome }
            }
            is Block -> { frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1) }
            is Loop  -> { frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1) }
            is If -> {
                if frame.sp == 0 { return Trap { .message = "if on empty stack at pc=${frame.pc} in '${body.name}'" } }
                cond :: read_i32(frame.stack[frame.sp - 1], frame.pc, "if condition")
                if cond is Trap { return cond }
                new_sp :: frame.sp - 1
                if cond.value != 0 {
                    frames[top] = with_sp_pc(frame, new_sp, frame.pc + 1)
                } else {
                    target :: body.jump_table[frame.pc]
                    if target < 0 {
                        return Trap { .message = "if has no jump target at pc=${frame.pc} (bad bytecode)" }
                    }
                    frames[top] = with_sp_pc(frame, new_sp, target)
                }
            }
            is Else -> {
                target :: body.jump_table[frame.pc]
                if target < 0 {
                    return Trap { .message = "else has no jump target at pc=${frame.pc} (bad bytecode)" }
                }
                frames[top] = with_sp_pc(frame, frame.sp, target)
            }
            is End -> { frames[top] = with_sp_pc(frame, frame.sp, frame.pc + 1) }
            is Branch -> {
                target :: body.jump_table[frame.pc]
                if target < 0 {
                    return Trap { .message = "br has no jump target at pc=${frame.pc} (bad bytecode)" }
                }
                frames[top] = with_sp_pc(frame, frame.sp, target)
            }
            is BranchIf -> {
                if frame.sp == 0 { return Trap { .message = "br_if on empty stack at pc=${frame.pc} in '${body.name}'" } }
                cond :: read_i32(frame.stack[frame.sp - 1], frame.pc, "br_if condition")
                if cond is Trap { return cond }
                new_sp :: frame.sp - 1
                if cond.value != 0 {
                    target :: body.jump_table[frame.pc]
                    if target < 0 {
                        return Trap { .message = "br_if has no jump target at pc=${frame.pc} (bad bytecode)" }
                    }
                    frames[top] = with_sp_pc(frame, new_sp, target)
                } else {
                    frames[top] = with_sp_pc(frame, new_sp, frame.pc + 1)
                }
            }
            is Return -> {
                has_value :: frame.sp > 0
                return_value: Value = I32Val { .value = 0 }
                if has_value { return_value = frame.stack[frame.sp - 1] }
                pop_frame(frame_count)
                if frame_count[0] == 0 {
                    // Returning from main — surface the i32 to the host.
                    if has_value {
                        unwrapped :: read_i32(return_value, frame.pc, "return from main")
                        if unwrapped is Trap { return unwrapped }
                        return Ok { .value = unwrapped.value }
                    }
                    return Ok { .value = 0 }
                }
                // Push return value onto caller's stack (if any).
                if has_value {
                    new_top :: frame_count[0] - 1
                    caller :: frames[new_top]
                    push_value(caller.stack, caller.sp, return_value)
                    frames[new_top] = with_sp_pc(caller, caller.sp + 1, caller.pc)
                }
            }
        }
    }
    // Frame stack drained without an explicit main-return — surface 0.
    return Ok { .value = 0 }
}

/// Unwrap an `i32` from a `Value` or return a `Trap` describing the
/// expected slot when the tag mismatches.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read (for the Trap message).
/// @param label   short context label (`"i32.add left"`, `"if condition"`)
///                so the surfaced message is actionable.
/// @return        the `I32Val` payload on success, or a `Trap` on
///                type mismatch.
/// @error         the value's tag is `StringVal`, not `I32Val`.
read_i32 :: fn(v: Value, at_pc: i32, label: string) -> I32Val | Trap {
    if v is I32Val { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected i32, got ${describe_value_tag(v)}" }
}

/// Unwrap a `StructVal` from a `Value`, mirroring `read_i32`. Used by
/// the struct-op arms to recover the receiver on top of the stack.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read.
/// @param label   short context label (`"struct.get receiver"`).
/// @return        the `StructVal` payload on success, or a `Trap` on
///                type mismatch.
/// @error         the value's tag isn't `StructVal`.
read_struct :: fn(v: Value, at_pc: i32, label: string) -> StructVal | Trap {
    if v is StructVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected struct, got ${describe_value_tag(v)}" }
}

/// Unwrap an `ArrayVal` from a `Value`, mirroring `read_struct`. Used
/// by the array-op arms (`array.push`, `array.get`, `array.set`,
/// `array.len`) to recover the receiver from the stack.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read.
/// @param label   short context label (`"array.get receiver"`).
/// @return        the `ArrayVal` payload on success, or a `Trap` on
///                type mismatch.
/// @error         the value's tag isn't `ArrayVal`.
read_array :: fn(v: Value, at_pc: i32, label: string) -> ArrayVal | Trap {
    if v is ArrayVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected array, got ${describe_value_tag(v)}" }
}

/// Short human-readable name of the value's variant — used by every
/// `read_*` helper's mismatch Trap so messages don't fan out per pair
/// of expected/actual tags. Exhaustive `match` so the compiler catches
/// any future `Value` variant added without updating this fn.
///
/// @param v  the tagged value.
/// @return   `"i32"` / `"string"` / `"struct"` / `"array"` / `"builder"` / `"fn"`.
describe_value_tag :: fn(v: Value) = match v {
    is I32Val     -> "i32"
    is StringVal  -> "string"
    is StructVal  -> "struct"
    is ArrayVal   -> "array"
    is BuilderVal -> "builder"
    is FnVal      -> "fn"
}

/// Unwrap a `FnVal` from a `Value`, mirroring `read_builder` etc. Used
/// by the `CallIndirect` arm to recover the function reference on top
/// of the stack.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read.
/// @param label   short context label (e.g. `"call.indirect receiver"`).
/// @return        the `FnVal` payload on success, or a `Trap` on type
///                mismatch.
/// @error         the value's tag isn't `FnVal`.
read_fn :: fn(v: Value, at_pc: i32, label: string) -> FnVal | Trap {
    if v is FnVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected fn, got ${describe_value_tag(v)}" }
}

/// Unwrap a `BuilderVal` from a `Value`, mirroring `read_struct` /
/// `read_array`. Used by the builder-intrinsic arms to recover the
/// receiver from the stack.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read.
/// @param label   short context label (e.g. `"intrinsic builder.append_str receiver"`).
/// @return        the `BuilderVal` payload on success, or a `Trap` on
///                type mismatch.
/// @error         the value's tag isn't `BuilderVal`.
read_builder :: fn(v: Value, at_pc: i32, label: string) -> BuilderVal | Trap {
    if v is BuilderVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected builder, got ${describe_value_tag(v)}" }
}

/// Build an `ArrayVal` of `type_id` with `length` initial elements
/// popped from the stack. If `length == 0`, allocates an empty
/// grow-only array ready for `array.push`.
///
/// @param type_id  index into `Module.types` — informational, not
///                 validated against `ArrayType` (the bytecode pipeline
///                 already guarantees consistency).
/// @param length   initial element count to consume from the stack.
/// @param frame    current top frame.
/// @return         a fresh `Frame` (sp/pc advanced) on success, or a
///                 `Trap` if the stack is too short.
/// @error          stack underflow when `frame.sp < length`.
build_array :: fn(type_id: i32, length: i32, frame: Frame) -> Frame | Trap {
    if length < 0 {
        return Trap { .message = "array.new length ${length} is negative at pc=${frame.pc}" }
    }
    needed :: usize(length)
    if frame.sp < needed {
        return Trap { .message = "array.new type ${type_id} needs ${needed} initial element(s) but stack has ${frame.sp} at pc=${frame.pc}" }
    }
    arg_base :: frame.sp - needed
    elements: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[] = []
    element_index: usize = 0
    for element_index < needed {
        elements.push(frame.stack[arg_base + element_index])
        element_index += 1
    }
    new_array :: ArrayVal { .type_id = type_id, .elements = elements }
    push_value(frame.stack, arg_base, new_array)
    return with_sp_pc(frame, arg_base + 1, frame.pc + 1)
}

/// Body of the `StructNew` arm — the .virt text format emits two
/// variants (`struct.new` and `struct.new_stack`) but the VM treats
/// them identically (the heap/stack split is a codegen concern).
/// Pops `field_count` values from `frame.stack` (in field-declaration
/// order), wraps them in a `StructVal`, and pushes the result.
///
/// @param module   the running module (used to look up `types`).
/// @param type_id  the struct type's ordinal in `module.types`.
/// @param frame    current top frame.
/// @return         a fresh `Frame` (sp / pc advanced) on success, or a
///                 `Trap` describing the failure.
/// @error          `type_id` out of range ; type-table entry isn't a
///                 `StructType` ; stack carries fewer than `field_count`
///                 values.
build_struct :: fn(module: Module, type_id: i32, frame: Frame) -> Frame | Trap {
    if type_id < 0 || usize(type_id) >= module.types.len() {
        return Trap { .message = "struct.new type ${type_id} out of range at pc=${frame.pc}" }
    }
    type_decl :: module.types[usize(type_id)]
    if !(type_decl is StructType) {
        return Trap { .message = "struct.new type ${type_id} is not a struct at pc=${frame.pc}" }
    }
    field_count :: type_decl.field_count
    if frame.sp < field_count {
        return Trap { .message = "struct.new type ${type_id} needs ${field_count} field value(s) but stack has ${frame.sp} at pc=${frame.pc}" }
    }
    arg_base :: frame.sp - field_count
    fields: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[] = []
    field_index: usize = 0
    for field_index < field_count {
        fields.push(frame.stack[arg_base + field_index])
        field_index += 1
    }
    new_struct :: StructVal { .type_id = type_id, .fields = fields }
    push_value(frame.stack, arg_base, new_struct)
    return with_sp_pc(frame, arg_base + 1, frame.pc + 1)
}

/// Unwrap a `string` from a `Value`, mirroring `read_i32`. Used by the
/// host dispatcher to recover the `string` payload of a `println`-style
/// argument.
///
/// @param v       the tagged value to inspect.
/// @param at_pc   pc of the op doing the read.
/// @param label   short context label (`"println"`, `"eprintln"`).
/// @return        the `StringVal` payload on success, or a `Trap` on
///                type mismatch.
/// @error         the value's tag is `I32Val`, not `StringVal`.
read_string :: fn(v: Value, at_pc: i32, label: string) -> StringVal | Trap {
    if v is StringVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected string, got ${describe_value_tag(v)}" }
}

/// Outcome of a successful host call. `value` is unused when the
/// import has `has_return == false` — the exec checks the import's
/// signature before pushing.
export HostCallResult :: HostOk | Trap
export HostOk :: struct { value: Value }

/// Sprint 3 host surface — only the three plain string-printer imports
/// that show up in `vm_hello` and its near siblings. Each new import
/// added later (e.g. `read_line`, `read_file`, the integer / float
/// `print` formatters) lands as a new arm here.
///
/// @param info      the import descriptor (used for `mangled` dispatch).
/// @param stack     the caller's value stack — args live at and above
///                  `arg_base`.
/// @param arg_base  index of the first arg within `stack`.
/// @param at_pc     pc of the `call.import` op (for the Trap message).
/// @return          `HostOk(value)` carrying a zero-Value for void
///                  imports, or `Trap` for unknown imports or arg-type
///                  mismatches.
/// @error           unknown `mangled` name ; argument type mismatch.
dispatch_import :: fn(info: ImportInfo, stack: (I32Val | StringVal | StructVal | ArrayVal | BuilderVal | FnVal)[], arg_base: usize, at_pc: i32) -> HostCallResult {
    if info.mangled == STDIO_PRINTLN {
        arg :: read_string(stack[arg_base], at_pc, "println")
        if arg is Trap { return arg }
        println(arg.value)
        return HostOk { .value = zero_value() }
    }
    if info.mangled == STDIO_PRINT {
        arg :: read_string(stack[arg_base], at_pc, "print")
        if arg is Trap { return arg }
        // TODO route to stdout w/o newline (sprint 4+ wires std/io.print exactly)
        println(arg.value)
        return HostOk { .value = zero_value() }
    }
    if info.mangled == STDIO_EPRINTLN {
        arg :: read_string(stack[arg_base], at_pc, "eprintln")
        if arg is Trap { return arg }
        eprintln(arg.value)
        return HostOk { .value = zero_value() }
    }
    return Trap { .message = "unbound host import '${info.mangled}' at pc=${at_pc}" }
}

// ---- entry --------------------------------------------------------------

/// CLI entry — read a `.virt` text dump from `path`, parse it, run it,
/// and return an exit code. Diagnostics go to stderr.
///
/// @param path  filesystem path to the `.virt` file.
/// @return      the i32 the program's `main` returned (or `0` if it
///              fell through without an explicit `return`) ; `1` when
///              the file can't be read or the VM trapped — the error
///              message goes to stderr in both cases.
/// @error       missing file ; any VM trap surfaced by `exec`.
export run_virt :: fn(path: string) -> i32 {
    source :: read_file(path)
    if source is Error {
        eprintln("vader run: cannot read ${path}")
        return 1
    }
    return match exec(parse_virt(source)) {
        is Ok   as o -> o.value
        is Trap as t -> {
            eprintln("vader vm: ${t.message}")
            1
        }
    }
}
