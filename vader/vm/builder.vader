// ---- i64 ----------------------------------------------------------------

export i64_add :: fn(self: FunctionBuilder) -> void = push_op(self, I64Add {})
export i64_sub :: fn(self: FunctionBuilder) -> void = push_op(self, I64Sub {})
export i64_mul :: fn(self: FunctionBuilder) -> void = push_op(self, I64Mul {})
export i64_div :: fn(self: FunctionBuilder) -> void = push_op(self, I64Div {})
export i64_mod :: fn(self: FunctionBuilder) -> void = push_op(self, I64Mod {})
export i64_neg :: fn(self: FunctionBuilder) -> void = push_op(self, I64Neg {})
export i64_eq :: fn(self: FunctionBuilder) -> void = push_op(self, I64Eq {})
export i64_ne :: fn(self: FunctionBuilder) -> void = push_op(self, I64Ne {})
export i64_lt :: fn(self: FunctionBuilder) -> void = push_op(self, I64Lt {})
export i64_le :: fn(self: FunctionBuilder) -> void = push_op(self, I64Le {})
export i64_gt :: fn(self: FunctionBuilder) -> void = push_op(self, I64Gt {})
export i64_ge :: fn(self: FunctionBuilder) -> void = push_op(self, I64Ge {})
