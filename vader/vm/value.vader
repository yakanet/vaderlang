// vader/vm/value — `Value` projections + type-matching helpers shared
// across the executor and the host-import dispatcher.
//
// Every `read_*` here unwraps the matching `op.*Val` variant or surfaces
// a `Trap` with a labelled mismatch message ; `type_matches` and its
// friends answer the runtime `is T` / `ref Trait` patterns by walking
// `Module.types` and `Module.impls` / `Module.vtables`.
//
// `VmResult` / `Ok` / `Trap` also live here (rather than in exec.vader)
// so the per-Value helpers can return `… | Trap` without forming an
// import cycle with the executor.

module "vader/vm"

import "std/string" { starts_with, byte_at, byte_len, byte_slice }

/// Tagged outcome of an `exec` call. `Ok` carries the program's i32
/// return value ; `Trap` carries a debug-friendly message so the host
/// can surface it instead of a generic runtime abort.
export VmResult :: Ok | Trap
export Ok   :: struct { value: i32 }
export Trap :: struct { message: string }

/// Default-zero `Value`, used to size each frame's locals at fn entry.
export zero_value :: fn() -> Value { return I32Val { .value = 0 } }

/// Box a `string[]` as an `ArrayVal` of `StringVal`.
///
/// `type_id` must be the module's `string[]` `ArrayType` index (see
/// `find_string_array_type_id`) — `type_matches` does an exact `type_id`
/// equality check on arrays (value.vader:298), so a host-built array
/// tagged 0 never narrows to `is string[]` in a union (e.g. the
/// `string[] | Error` return of `read_dir` / `split`). Bound-checks still use
/// `elements.len()`, not the type table.
/// @param items    the strings to box.
/// @param type_id  the module's `string[]` ArrayType index, or 0 when the
///                 module has no such entry (the value is then never
///                 matched against `string[]` so the tag is moot).
/// @return         an `ArrayVal` whose elements are `StringVal`s of `items`.
export string_array_to_value :: fn(items: string[], type_id: i32) -> ArrayVal {
    elements: Value[] = []
    for s in items { elements.push(StringVal { .value = s }) }
    return ArrayVal { .type_id = type_id, .elements = elements, .offset = usize(0), .length = elements.len() }
}

/// Locate the module's `string[]` `ArrayType` index — the type id a
/// host-produced string array must carry so `is string[]` narrows.
/// Mirrors `findStringArrayTypeIndex` in `src/vm/host.ts`. Returns 0 when
/// no `string` primitive or no `string[]` array entry exists (the caller's
/// `type_check` then fails loudly rather than masking the miss). Compute
/// once per run — the scan is linear in the type-table size.
/// @param module  the running module.
/// @return        the `string[]` ArrayType index, or 0 when absent.
export find_string_array_type_id :: fn(module: Module) -> i32 {
    string_idx: i32 = -1
    for i in 0..<module.types.len() {
        t :: module.types[i]
        if t is PrimitiveType as p {
            if p.kind == "string" { string_idx = i32(i) }
        }
    }
    if string_idx < 0 { return 0 }
    for j in 0..<module.types.len() {
        t :: module.types[j]
        if t is ArrayType as a {
            if a.element_type_id == string_idx { return i32(j) }
        }
    }
    return 0
}

/// Size in bytes of an `TypeDecl` — backs `@size_of(t)` runtime path.
/// Primitives use their native widths ; everything else fits in a 16-byte
/// box at the typed boundary (struct/array/fn refs, unions, opaque refs).
export size_of_bc_type :: fn(t: TypeDecl) -> usize = match t {
    is PrimitiveType as p -> size_of_primitive(p.kind)
    is StructType         -> usize(16)
    is ArrayType          -> usize(16)
    is RefType            -> usize(16)
    is FnType             -> usize(16)
    is UnionType          -> usize(16)
}

size_of_primitive :: fn(kind: string) -> usize {
    if kind == "i8"     { return usize(1) }
    if kind == "u8"     { return usize(1) }
    if kind == "bool"   { return usize(1) }
    if kind == "i16"    { return usize(2) }
    if kind == "u16"    { return usize(2) }
    if kind == "i32"    { return usize(4) }
    if kind == "u32"    { return usize(4) }
    if kind == "f32"    { return usize(4) }
    if kind == "char"   { return usize(4) }
    if kind == "i64"    { return usize(8) }
    if kind == "u64"    { return usize(8) }
    if kind == "f64"    { return usize(8) }
    if kind == "isize"  { return usize(8) }
    if kind == "usize"  { return usize(8) }
    if kind == "string" { return usize(16) }
    return usize(0)
}

/// Short human-readable name of the value's variant — used by every
/// `read_*` helper's mismatch Trap so messages don't fan out per pair
/// of expected/actual tags. Exhaustive `match` so the compiler catches
/// any future `Value` variant added without updating this fn.
///
/// @param v  the tagged value.
/// @return   `"i32"` / `"i64"` / `"f64"` / `"string"` / `"struct"` / `"array"`
///           / `"builder"` / `"fn"` / `"null"` / `"bool"` / `"char"` / `"error"`
///           / `"type"`.
export describe_value_tag :: fn(v: Value) = match v {
    is I32Val     -> "i32"
    is I64Val     -> "i64"
    is F64Val     -> "f64"
    is StringVal  -> "string"
    is StructVal  -> "struct"
    is ArrayVal   -> "array"
    is BuilderVal -> "builder"
    is FnVal      -> "fn"
    is NullVal    -> "null"
    is BoolVal    -> "bool"
    is CharVal    -> "char"
    is ErrorVal   -> "error"
    is TypeVal    -> "type"
}

/// Unwrap an `F64Val` from a `Value`. Integer values are NOT auto-
/// promoted — Vader bytecode uses explicit `.to_f64` conversions for that.
export read_f64 :: fn(v: Value, at_pc: i32, label: string) -> F64Val | Trap {
    if v is F64Val { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected f64, got ${describe_value_tag(v)}" }
}

/// Re-tag `v` to the storage class implied by `target`. Re-tagging a value
/// already at the target storage is a no-op fast path — avoids the box
/// reallocation when `mask32(u32 x)` (hot in SHA-256 / MD5) hits an
/// already-I32Val.
export convert_value :: fn(v: Value, target: ConvertTarget, at_pc: i32) -> Value | Trap {
    if target == .I32 {
        if v is I32Val { return v }
        n :: read_numeric_as_i64(v, at_pc)
        if n is Trap { return n }
        return I32Val { .value = i32(n) }
    }
    if target == .I64 {
        if v is I64Val { return v }
        n :: read_numeric_as_i64(v, at_pc)
        if n is Trap { return n }
        return I64Val { .value = n }
    }
    if target == .F64 {
        if v is F64Val { return v }
        n :: read_numeric_as_f64(v, at_pc)
        if n is Trap { return n }
        return F64Val { .value = n }
    }
    if v is CharVal { return v }
    n :: read_numeric_as_i64(v, at_pc)
    if n is Trap { return n }
    return CharVal { .value = char(u32(n)) }
}

read_numeric_as_i64 :: fn(v: Value, at_pc: i32) -> i64 | Trap {
    return match v {
        is I64Val  as i -> i.value
        is I32Val  as i -> i64(i.value)
        is F64Val  as f -> i64(f.value)
        is CharVal as c -> i64(u32(c.value))
        is BoolVal as b -> if b.value { i64(1) } else { i64(0) }
        _ -> Trap { .message = "convert at pc=${at_pc}: cannot read ${describe_value_tag(v)} as numeric" }
    }
}

// `I32Val`/`I64Val` ahead of `F64Val` : `int → f64` is the common case
// (e.g. `unit_f64`'s `f64(next_u64() >> 12)`), already-f64 is rare.
read_numeric_as_f64 :: fn(v: Value, at_pc: i32) -> f64 | Trap {
    return match v {
        is I32Val  as i -> f64(i.value)
        is I64Val  as i -> f64(i.value)
        is F64Val  as f -> f.value
        is CharVal as c -> f64(u32(c.value))
        _ -> Trap { .message = "convert at pc=${at_pc}: cannot read ${describe_value_tag(v)} as f64" }
    }
}

/// Unwrap an `i32` from a `Value`. Accepts `CharVal` (codepoint) and
/// `I64Val` (truncating to the bottom 32 bits) transparently — both no-op
/// `Convert` carriers and width-narrowing consumers (array.get index,
/// `int.to_char`) need the i32 view of those tags.
export read_i32 :: fn(v: Value, at_pc: i32, label: string) -> I32Val | Trap {
    return match v {
        is I32Val  as i -> i
        is CharVal as c -> I32Val { .value = i32(u32(c.value)) }
        is I64Val  as i -> I32Val { .value = i32(i.value) }
        _ -> Trap { .message = "${label} at pc=${at_pc}: expected i32, got ${describe_value_tag(v)}" }
    }
}

/// Unwrap an `I64Val` from a `Value`. `I32Val` arrivals widen
/// transparently so mixed-width ops (e.g. an `i32.const N` flowing into
/// `i64.add`) just work.
export read_i64 :: fn(v: Value, at_pc: i32, label: string) -> I64Val | Trap {
    return match v {
        is I64Val as i -> i
        is I32Val as i -> I64Val { .value = i64(i.value) }
        _                 -> Trap { .message = "${label} at pc=${at_pc}: expected i64, got ${describe_value_tag(v)}" }
    }
}

/// Unwrap a `StructVal` from a `Value`. Used by the struct-op arms
/// to recover the receiver on top of the stack.
export read_struct :: fn(v: Value, at_pc: i32, label: string) -> StructVal | Trap {
    if v is StructVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected struct, got ${describe_value_tag(v)}" }
}

/// Unwrap `v` as a struct then read its `field_index`-th field. Combines
/// the struct-tag check and the bounds check used by every field-read op
/// (`struct.get`, `local.field`).
///
/// @param v            the candidate `Value` (typically off the stack
///                     or out of `frame.slots`).
/// @param field_index  index into `StructVal.fields`. Must be `>= 0` and
///                     `<` the unwrapped struct's field count.
/// @param at_pc        pc of the op (recorded in the Trap message).
/// @param label        short label used as the Trap-message prefix
///                     (e.g. `"struct.get"`, `"local.field"`).
/// @return             the requested field value on success, or a `Trap`.
/// @error              `v` isn't a struct, or `field_index` is out of range.
export read_struct_field :: fn(v: Value, field_index: i32, at_pc: i32, label: string) -> Value | Trap {
    struct_unwrap :: read_struct(v, at_pc, "${label} receiver")
    if struct_unwrap is Trap { return struct_unwrap }
    if field_index < 0 || usize(field_index) >= struct_unwrap.fields.len() {
        return Trap { .message = "${label} field ${field_index} out of range (struct has ${struct_unwrap.fields.len()} fields) at pc=${at_pc}" }
    }
    return struct_unwrap.fields[usize(field_index)]
}

/// Unwrap an `ArrayVal` from a `Value`. Used by the array-op arms
/// (`array.push` / `array.get` / `array.set` / `array.len`).
export read_array :: fn(v: Value, at_pc: i32, label: string) -> ArrayVal | Trap {
    if v is ArrayVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected array, got ${describe_value_tag(v)}" }
}

/// True iff `a` is a view onto a buffer it doesn't own — `elements` is
/// shared with another `ArrayVal`. Used by `array.push` to decide
/// whether to detach into a fresh buffer before extending.
export is_array_view :: fn(a: ArrayVal) -> bool {
    return a.offset != usize(0) || a.offset + a.length < a.elements.len()
}

/// Unwrap a `BoolVal` from a `Value`. Used by the boolean op arms.
export read_bool :: fn(v: Value, at_pc: i32, label: string) -> BoolVal | Trap {
    if v is BoolVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected bool, got ${describe_value_tag(v)}" }
}

/// Unwrap a `CharVal` from a `Value`. `i32.to_char` / `u32.to_char`
/// lower to a no-op `Convert` so the source integer passes through ;
/// re-wrap as `CharVal` so consumers see the codepoint with the
/// expected tag. `I64Val` arrivals come from `u32.const N` (the parser
/// promotes to I64Const to preserve the full unsigned range) and need a
/// truncated reinterpretation.
export read_char :: fn(v: Value, at_pc: i32, label: string) -> CharVal | Trap {
    return match v {
        is CharVal as c -> c
        is I32Val  as i -> CharVal { .value = char(u32(i.value)) }
        is I64Val  as i -> CharVal { .value = char(u32(i32(i.value))) }
        _ -> Trap { .message = "${label} at pc=${at_pc}: expected char, got ${describe_value_tag(v)}" }
    }
}

/// Read a truthy condition (`if` / `br_if`). Accepts both legacy numeric
/// form (`I32Val` — non-zero is true) and modern bool form
/// (`BoolVal`). Other variants Trap.
export read_truthy :: fn(v: Value, at_pc: i32, label: string) -> bool | Trap {
    if v is BoolVal { return v.value }
    if v is I32Val  { return v.value != 0 }
    return Trap { .message = "${label} at pc=${at_pc}: expected bool or i32, got ${describe_value_tag(v)}" }
}

/// Unwrap a `FnVal` from a `Value`. Used by the `CallIndirect` arm
/// to recover the function reference on top of the stack.
export read_fn :: fn(v: Value, at_pc: i32, label: string) -> FnVal | Trap {
    if v is FnVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected fn, got ${describe_value_tag(v)}" }
}

/// Unwrap a `BuilderVal` from a `Value`. Used by the builder-
/// intrinsic arms to recover the receiver from the stack.
export read_builder :: fn(v: Value, at_pc: i32, label: string) -> BuilderVal | Trap {
    if v is BuilderVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected builder, got ${describe_value_tag(v)}" }
}

/// Unwrap a `string` from a `Value`. Used by the host dispatcher to
/// recover the `string` payload of a `println`-style argument.
export read_string :: fn(v: Value, at_pc: i32, label: string) -> StringVal | Trap {
    if v is StringVal { return v }
    return Trap { .message = "${label} at pc=${at_pc}: expected string, got ${describe_value_tag(v)}" }
}

/// Structural equality for `ref.eq` / `ref.ne`. Restricted to primitives
/// (`I32Val` / `BoolVal` / `CharVal` / `StringVal`) and `NullVal` ; heap-
/// allocated variants Trap because the lowerer only emits `ref.eq` against
/// null or between freshly-built sentinels.
export value_ref_eq :: fn(a: Value, b: Value, at_pc: i32, label: string) -> bool | Trap {
    return match a {
        is NullVal         -> b is NullVal
        is I32Val    as ai -> match b { is I32Val    as bi -> ai.value == bi.value, _ -> false }
        is BoolVal   as ab -> match b { is BoolVal   as bb -> ab.value == bb.value, _ -> false }
        is CharVal   as ac -> match b { is CharVal   as bc -> ac.value == bc.value, _ -> false }
        is StringVal as ax -> match b { is StringVal as bx -> ax.value == bx.value, _ -> false }
        _                  -> Trap { .message = "${label} on ${describe_value_tag(a)} not supported at pc=${at_pc} (only null + primitive operands)" }
    }
}

/// Type-check : does `v`'s runtime tag match `module.types[type_id]` ?
/// Mirrors `typeMatches` + `matchTo` in `src/vm/exec.ts`. Returns `false`
/// for `FnType` (placeholder until ref/trait dispatch lands).
export type_matches :: fn(module: Module, v: Value, type_id: i32) -> bool {
    if type_id < 0 || usize(type_id) >= module.types.len() { return false }
    type_decl :: module.types[usize(type_id)]
    return match type_decl {
        is PrimitiveType as p -> primitive_matches(v, p.kind)
        is StructType         -> match v {
            is StructVal as s -> s.type_id == type_id || struct_siblings_match(module, s.type_id, type_id)
            _                 -> false
        }
        is ArrayType          -> match v {
            is ArrayVal as a  -> a.type_id == type_id
            _                 -> false
        }
        is UnionType     as u -> union_matches(module, v, u.variant_type_ids)
        is RefType       as r -> ref_type_matches(module, v, r.trait_name)
        is FnType             -> false
    }
}

/// Erasure-aware sibling check : returns true when both struct types
/// come from the same generic source declaration. Post-path-γ a value
/// may carry a sibling shape's tag (e.g. `Yield(Any)` runtime flowing
/// into a match arm typed `is Yield(i32)`). We approximate the TS
/// `symbolId`-based grouping by comparing mangled-name prefixes up to
/// the first `__` (which separates the source name from the type-arg
/// suffix).
///
/// @param module   the running module (struct names live in `types`).
/// @param value_type_id   actual tag of the runtime value.
/// @param target_type_id  static type the value is being matched against.
/// @return         `true` when both refer to struct types whose names
///                 share the same pre-`__` prefix ; `false` otherwise.
struct_siblings_match :: fn(module: Module, value_type_id: i32, target_type_id: i32) -> bool {
    if value_type_id == target_type_id { return true }
    if value_type_id < 0 || usize(value_type_id) >= module.types.len() { return false }
    if target_type_id < 0 || usize(target_type_id) >= module.types.len() { return false }
    value_name :: struct_name_at(module, value_type_id)
    target_name :: struct_name_at(module, target_type_id)
    if value_name == "" || target_name == "" { return false }
    value_prefix :: prefix_before_double_underscore(value_name)
    if value_prefix == "" { return false }
    return value_prefix == prefix_before_double_underscore(target_name)
}

/// Return the mangled name of the struct type at `type_id`, or `""` when
/// `type_id` doesn't point to a `StructType`.
struct_name_at :: fn(module: Module, type_id: i32) -> string = match module.types[usize(type_id)] {
    is StructType as s -> s.name
    _ -> ""
}

/// Slice `s` up to the first `__` byte pair occurring *after* the last
/// `$`. That's the type-arg separator the lowerer emits for
/// monomorphised generics (`std_core$Yield__Any`,
/// `std_iter$MapIterator__i32__i32`). For non-generic structs there is
/// no such `__`, and we return the empty string to signal "no sibling
/// family" — using the full mangled name would false-match other
/// non-generic structs declared in a path whose folder name contains
/// `__` (e.g. `tests_snippets_if_is_narrow__main_vader$Cat` vs `$Dog`).
prefix_before_double_underscore :: fn(s: string) -> string {
    n :: s.byte_len()
    if n < 2 { return "" }
    last_dollar: i32 = -1
    i: usize = 0
    for i < n {
        if s.byte_at(i) == b'$' { last_dollar = i32(i) }
        i += 1
    }
    start: usize = if last_dollar < 0 { 0 } else { usize(last_dollar) + 1 }
    j: usize = start
    for j + 1 < n {
        if s.byte_at(j) == b'_' && s.byte_at(j + 1) == b'_' {
            return s.byte_slice(0, j)
        }
        j += 1
    }
    return ""
}

/// Match a value against a `ref Trait` type. Mirrors `matchTo`'s
/// `case "ref"` arm in `src/vm/exec.ts` — `is Error` routes to
/// `ErrorVal` + impl-table check, `ref _` (empty trait name) accepts any
/// heap variant, other trait names resolve through the impl table.
export ref_type_matches :: fn(module: Module, v: Value, trait_name: string) -> bool {
    if trait_name == "Error" {
        if v is ErrorVal { return true }
        return match v {
            is StructVal as s -> trait_implemented_by(module, "Error", s.type_id)
            _                    -> false
        }
    }
    if trait_name == "" {
        return match v {
            is StructVal  -> true
            is ArrayVal   -> true
            is BuilderVal -> true
            is FnVal      -> true
            _                -> false
        }
    }
    return match v {
        is StructVal as s -> trait_implemented_by(module, trait_name, s.type_id)
        _                    -> false
    }
}

/// True iff `type_id` is registered as an implementer of `trait_name`.
/// Consults `module.impls` first (populated from `impl TYPE_ID TRAIT`
/// directives in the .virt) — that source survives DCE because the
/// writer emits one entry per implTable pair regardless of whether the
/// method bodies are reachable. Falls back to scanning `module.vtables`
/// for legacy modules whose .virt predates the directive.
export trait_implemented_by :: fn(module: Module, trait_name: string, type_id: i32) -> bool {
    i: usize = 0
    for i < module.impls.len() {
        if module.impls[i].type_id == type_id && module.impls[i].trait_name == trait_name {
            return true
        }
        i += 1
    }
    prefix :: "${trait_name}."
    j: usize = 0
    for j < module.vtables.len() {
        if module.vtables[j].key.starts_with(prefix) {
            k: usize = 0
            for k < module.vtables[j].entries.len() {
                if module.vtables[j].entries[k].type_id == type_id { return true }
                k += 1
            }
        }
        j += 1
    }
    return false
}

/// Receiver `type_id` extraction for `virtual.call`. Struct / Array
/// receivers carry their type_id directly ; primitives need a module-
/// level lookup via the type table to find the `PrimitiveType` entry
/// matching the value's runtime tag. Returns `-1` when nothing matches
/// (caller traps).
export receiver_type_id_of :: fn(module: Module, v: Value) -> i32 {
    return match v {
        is StructVal as s -> s.type_id
        is ArrayVal  as a -> a.type_id
        _                    -> primitive_type_id(module, v)
    }
}

/// Find the `PrimitiveType` entry in `module.types` whose `kind` matches
/// `v`'s runtime tag. Used by `receiver_type_id_of` to dispatch trait
/// methods implemented on primitives (e.g. `i32 implements Doubler`).
export primitive_type_id :: fn(module: Module, v: Value) -> i32 {
    tag :: describe_value_tag(v)
    i: usize = 0
    for i < module.types.len() {
        match module.types[i] {
            is PrimitiveType as p -> { if p.kind == tag { return i32(i) } }
            _                        -> { }
        }
        i += 1
    }
    return -1
}

/// Look up the function index in the vtable for `key` by receiver
/// `type_id`. Returns `-1` when either the key or the type_id is missing.
export lookup_vtable :: fn(vtables: Vtable[], key: string, type_id: i32) -> i32 {
    i: usize = 0
    for i < vtables.len() {
        if vtables[i].key == key {
            j: usize = 0
            for j < vtables[i].entries.len() {
                entry :: vtables[i].entries[j]
                if entry.type_id == type_id { return entry.function_index }
                j += 1
            }
            return -1
        }
        i += 1
    }
    return -1
}

/// Match a value against a `PrimitiveType.kind` string. Direct kinds
/// (`i32` / `string` / `bool` / `null` / `char`) lookup reuses
/// `describe_value_tag`. Width-suffixed integer kinds (i8 / i64 / u32 / …)
/// collapse onto `I32Val` — **latent miscompile risk** : a snippet
/// `if x is i64 { … }` against an `I32Val` matches and runs with i32
/// semantics. Sprint 5d / per-width values will replace the alias collapse.
export primitive_matches :: fn(v: Value, kind: string) -> bool {
    if kind == describe_value_tag(v) { return true }
    if is_integer_alias(kind) { return v is I32Val }
    return false
}

/// Width-suffixed integer kinds that currently alias to `I32Val`.
export is_integer_alias :: fn(kind: string) -> bool {
    if kind == "i8"  { return true }
    if kind == "i16" { return true }
    if kind == "i64" { return true }
    if kind == "isize" { return true }
    if kind == "u8"  { return true }
    if kind == "u16" { return true }
    if kind == "u32" { return true }
    if kind == "u64" { return true }
    if kind == "usize" { return true }
    return false
}

/// Match a value against a union's set of variant type ids by recursing
/// through `type_matches` on each.
export union_matches :: fn(module: Module, v: Value, variant_type_ids: i32[]) -> bool {
    i: usize = 0
    for i < variant_type_ids.len() {
        if type_matches(module, v, variant_type_ids[i]) { return true }
        i += 1
    }
    return false
}
