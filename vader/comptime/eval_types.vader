// vader/comptime/eval_types ‚Äî shared types + helpers for the evaluator.
//
// Lives in its own file so per-variant evaluators (`eval_lit`,
// `eval_binary`, `eval_ident`) can import `EvalResult` / `ComptimeContext`
// without depending on the dispatcher (`eval.vader`). Avoids the import
// cycle that would otherwise form when the dispatcher imports the
// per-variant modules and they each import back for these shapes.

module "vader/comptime"

import "std/collections"
import "vader/diagnostics"
import "vader/parser"
import "vader/typecheck"

/// Context threaded through the recursive evaluator.
/// @field typed     owning typed program ‚Äî gives the resolver lookup
///                  (`resolved.idents` / `resolved.symbols`) plus the
///                  decl type tables.
/// @field bindings  `Symbol.id ‚Üí ComptimeValue` for already-evaluated
///                  `@comptime` decls in the current module ; built up
///                  as `evaluate_module_decls` walks the topo-sorted
///                  order.
export ComptimeContext :: struct {
    typed:    TypedProgram
    bindings: MutableMap<i32, ComptimeValue>
    /// Current evaluator nesting depth. Bounds the tree-walk recursion so a
    /// cyclic / non-terminating comptime expression reports C4001 instead of
    /// overflowing the C stack (which silently corrupts memory). Mutated by
    /// `evaluate_expr` ; shared across operand recursion so it tracks the live
    /// level.
    depth:    i64 = 0
}

/// Result of evaluating one expression. Three states :
///   - `value=Some, diag=null`    : evaluated to a concrete value.
///   - `value=null, diag=Some`    : an error fired (cycle / unsupported
///                                  shape / type mismatch / sandbox).
///   - `value=null, diag=null`    : intentional skip ‚Äî caller drops
///                                  the decl from `comptime_decls`.
export EvalResult :: struct {
    value: ComptimeValue | null
    diag:  Diagnostic | null
    /// True when the tree-walk gave up on a shape the embedded VM can handle
    /// (loop / mutation / statement-bodied callee). The decl-level driver in
    /// `check.vader` records the decl for the `comptime_vm` VM pass and
    /// suppresses `diag` rather than reporting C4001. Set only by `vm_required`.
    vm_required: bool = false
}

/// Build an `EvalResult` carrying a value.
export ok :: fn(value: ComptimeValue) -> EvalResult {
    return EvalResult { .value = value, .diag = null }
}

/// Build an `EvalResult` carrying a diagnostic.
export fail :: fn(diag: Diagnostic) -> EvalResult {
    return EvalResult { .value = null, .diag = diag }
}

/// Build a `C4001 cannot-evaluate` diagnostic at `span` with `kind_label`
/// describing the unsupported expression. Standardised helper so every
/// "needs the VM" call site uses the same wording.
export vm_required :: fn(span: Span, kind_label: string) -> EvalResult {
    return EvalResult {
        .value       = null,
        .diag        = comptime_error(.CannotEvaluate, span, kind_label),
        .vm_required = true,
    }
}
