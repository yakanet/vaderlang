// vader/comptime/eval — tree-walk expression dispatcher.
//
// Per-variant `match` over `AST.Expr` routing each kind to its
// dedicated evaluator (`eval_lit`, `eval_binary`, `eval_ident`).
// Handles the subset of comptime expressions the lowerer + bytecode
// emitter port haven't unlocked yet. Anything outside that subset
// surfaces `C4001`.

module "vader/comptime"

import "vader/diagnostics" { Span }
AST :: import "vader/parser"

/// Tree-walk dispatcher. Returns whatever the per-variant helper
/// reports ; unrecognised variants surface as C4001.
/// @param expr     the expression to evaluate.
/// @param context  the comptime evaluator context.
/// @return         the evaluation result.
// @partial: the tree-walk MVP evaluates a subset of Expr kinds; every other
// variant is intentionally routed to `vm_required`.
/// Hard ceiling on the evaluator's nesting depth. A cyclic / non-terminating
/// comptime expression (e.g. a const whose value resolves back to itself) would
/// otherwise recurse until the C stack overflows — silently corrupting memory
/// (it surfaced as a bogus lexer "unterminated string" far from the real fault).
/// Well above any legitimate comptime expression, well below the native stack
/// capacity (which overflows a few thousand evaluator frames in), so the bound
/// trips on cycles before the C stack does.
COMPTIME_MAX_EVAL_DEPTH: i64: 2000

export evaluate_expr :: fn(expr: AST.Expr, context: ComptimeContext) -> EvalResult {
    // Depth guard — `context` is shared across operand recursion
    // (`evaluate_binary_expr` passes it straight through), so `depth` tracks the
    // live nesting level. Check the ceiling BEFORE incrementing, so the
    // rejecting path never touches `depth` ; the accepted path restores it by
    // hand before its single return. This is deliberately not a `defer` : a
    // `defer` here would capture `context` and lift to a fresh closure + env
    // struct on every call — an allocation on the evaluator's hottest path. (It
    // was also long a silent no-op : capturing `defer`s dropped their body, so
    // `depth` never decremented and accumulated into a per-module evaluation
    // counter — std/core reached ~1465. That codegen gap is fixed now, but
    // manual restore stays for the allocation reason.)
    if context.depth >= COMPTIME_MAX_EVAL_DEPTH {
        return vm_required(span_of(expr),
            "a cyclic or non-terminating comptime expression (exceeded ${COMPTIME_MAX_EVAL_DEPTH} nested levels)")
    }
    context.depth = context.depth + 1
    result :: @partial match expr {
        is AST.IntLitExpr    as x -> evaluate_int_lit(x)
        is AST.FloatLitExpr  as x -> evaluate_float_lit(x)
        is AST.BoolLitExpr   as x -> evaluate_bool_lit(x)
        is AST.CharLitExpr   as x -> evaluate_char_lit(x)
        is AST.NullLitExpr   as x -> evaluate_null_lit(x)
        is AST.StringLitExpr as x -> evaluate_string_lit(x, context, evaluate_expr)
        is AST.IdentExpr     as x -> evaluate_ident(x, context)
        is AST.BinaryExpr        as x -> evaluate_binary_expr(x, context, evaluate_expr)
        is AST.UnaryExpr         as x -> evaluate_unary_expr(x, context, evaluate_expr)
        is AST.IntrinsicCallExpr as x -> evaluate_intrinsic_call(x, context)
        is AST.CallExpr          as x -> evaluate_call_expr(x, context)
        is AST.SeqLitExpr        as x -> evaluate_seq_lit(x, context, evaluate_expr)
        _                             -> vm_required(span_of(expr), expr_kind_label(expr))
    }
    context.depth = context.depth - 1
    return result
}

/// Recover the span of any expression variant for diagnostic emission.
/// Every Expr variant carries a `span` field, so the match list mirrors
/// the AST.Expr union exactly.
export span_of :: fn(expr: AST.Expr) -> Span = match expr {
    is AST.IntLitExpr        as x -> x.span
    is AST.FloatLitExpr      as x -> x.span
    is AST.BoolLitExpr       as x -> x.span
    is AST.NullLitExpr       as x -> x.span
    is AST.CharLitExpr       as x -> x.span
    is AST.StringLitExpr     as x -> x.span
    is AST.IdentExpr         as x -> x.span
    is AST.CallExpr          as x -> x.span
    is AST.FieldExpr         as x -> x.span
    is AST.IndexExpr         as x -> x.span
    is AST.UnaryExpr         as x -> x.span
    is AST.BinaryExpr        as x -> x.span
    is AST.IfExpr            as x -> x.span
    is AST.MatchExpr         as x -> x.span
    is AST.BlockExpr         as x -> x.span
    is AST.LambdaExpr        as x -> x.span
    is AST.StructLitExpr     as x -> x.span
    is AST.SeqLitExpr        as x -> x.span
    is AST.RangeExpr         as x -> x.span
    is AST.AwaitExpr         as x -> x.span
    is AST.CastExpr          as x -> x.span
    is AST.GenericInstExpr   as x -> x.span
    is AST.IntrinsicCallExpr as x -> x.span
    is AST.DotVariantExpr    as x -> x.span
    is AST.FnTypeExpr        as x -> x.span
    is AST.ArrayTypeExpr     as x -> x.span
}

// Human-readable label for unsupported variants. Surfaces in the C4001
// detail so the user sees `expression cannot be evaluated at compile time
// : MatchExpr` rather than a generic catch-all message.
// @partial: human label only for the unsupported-variant set; the generic
// "Expr" fallback is intentional.
expr_kind_label :: fn(expr: AST.Expr) -> string = @partial match expr {
    is AST.CallExpr          -> "CallExpr"
    is AST.FieldExpr         -> "FieldExpr"
    is AST.IndexExpr         -> "IndexExpr"
    is AST.IfExpr            -> "IfExpr"
    is AST.MatchExpr         -> "MatchExpr"
    is AST.BlockExpr         -> "BlockExpr"
    is AST.LambdaExpr        -> "LambdaExpr"
    is AST.StructLitExpr     -> "StructLitExpr"
    is AST.SeqLitExpr        -> "SeqLitExpr"
    is AST.RangeExpr         -> "RangeExpr"
    is AST.CastExpr          -> "CastExpr"
    is AST.GenericInstExpr   -> "GenericInstExpr"
    is AST.IntrinsicCallExpr -> "IntrinsicCallExpr"
    is AST.DotVariantExpr    -> "DotVariantExpr"
    is AST.FnTypeExpr        -> "FnTypeExpr"
    is AST.ArrayTypeExpr     -> "ArrayTypeExpr"
    _                        -> "Expr"
}

// ---- tests ----------------------------------------------------------------

import "std/collections" { MutableMap }
import "std/testing"
import "vader/typecheck" { empty_typed_program }
import "vader/diagnostics" { empty_span }

@test test_evaluate_int_literal :: fn() -> void {
    expr :: AST.IntLitExpr { .span = empty_span(), .id = 0, .value = 42 }
    context :: empty_context()
    result :: evaluate_expr(expr, context)
    match result.value {
        is null -> { assert_eq("expected a value", "got null") }
        _       -> { assert_eq(display_value(result.value), "42_i32") }
    }
}

@test test_evaluate_unsupported_emits_c4001 :: fn() -> void {
    // `CallExpr` falls through to vm_required at this MVP.
    callee :: AST.IdentExpr { .span = empty_span(), .id = 0, .name = "f", .implicit_dot = false, .is_type_param_intro = false }
    expr :: AST.CallExpr { .span = empty_span(), .id = 0, .callee = callee, .args = [] }
    context :: empty_context()
    result :: evaluate_expr(expr, context)
    match result.diag {
        is null -> { assert_eq("expected C4001 diag", "got null") }
        _       -> {}
    }
}

// Recursion guard : a cyclic / non-terminating comptime expression must report
// C4001 instead of overflowing the C stack (which silently corrupts memory).
// Pre-loading `depth` to the ceiling exercises the guard without a real
// 2000-deep recursion (which could overflow the test runner's own stack).
@test test_evaluate_recursion_guard_trips_at_ceiling :: fn() -> void {
    expr :: AST.IntLitExpr { .span = empty_span(), .id = 0, .value = 1 }
    over :: empty_context()
    over.depth = COMPTIME_MAX_EVAL_DEPTH
    result :: evaluate_expr(expr, over)
    match result.diag {
        is null -> { assert_eq("expected recursion-guard C4001", "got null") }
        _       -> {}
    }
}

@test test_evaluate_below_ceiling_still_evaluates :: fn() -> void {
    expr :: AST.IntLitExpr { .span = empty_span(), .id = 0, .value = 7 }
    under :: empty_context()
    under.depth = COMPTIME_MAX_EVAL_DEPTH - 2
    result :: evaluate_expr(expr, under)
    match result.value {
        is null -> { assert_eq("expected a value below the ceiling", "got null") }
        _       -> { assert_eq(display_value(result.value), "7_i32") }
    }
}

empty_context :: fn() -> ComptimeContext {
    return ComptimeContext {
        .typed    = empty_typed_program(),
        .bindings = MutableMap<i32, ComptimeValue> {},
    }
}
