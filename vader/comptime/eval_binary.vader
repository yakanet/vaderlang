// vader/comptime/eval_binary — binary + unary operator evaluation.
//
// Per-operator dispatch over `BinaryOp` / `UnaryOp` for the operand
// shapes the tree-walk MVP supports (Int, Float, Bool, String for `+`
// concat). Type mismatches surface as `C4007` ; the operators the VM
// would otherwise handle (`Is`, `In`, `NotIn`) fall back to `C4001`.

module "vader/comptime"

import "vader/diagnostics"
import "vader/types"
AST :: import "vader/parser"

/// Evaluate a `BinaryExpr`. Recurses into both operands ; combines
/// per `op`. Short-circuits on operand failure (the operand's error
/// propagates up). `Is` / `In` / `NotIn` need the typechecker's
/// narrowing tables — fall back to C4001.
/// @param expr        the binary expression node.
/// @param context     the evaluator context.
/// @param recurse     dispatcher callback (`eval.evaluate_expr`) ;
///                    passed in to avoid the eval ↔ eval_binary import
///                    cycle.
/// @return            the combined value or a diagnostic.
export evaluate_binary_expr :: fn(
    expr: AST.BinaryExpr, context: ComptimeContext,
    recurse: fn(AST.Expr, ComptimeContext) -> EvalResult,
) -> EvalResult {
    left_result :: recurse(expr.left, context)
    if left_result.value is null { return left_result }
    right_result :: recurse(expr.right, context)
    if right_result.value is null { return right_result }
    // Width of the node's resolved type — drives the fixed-width wrap so a
    // comptime fold matches the runtime's i32 / i64 wrapping instead of the
    // unbounded-i64 tree-walk (audit CT1). Empty string ⇒ unknown / non-integer:
    // never truncate (wide dtoa / crypto tables must keep full 64-bit precision).
    rname :: resolved_int_name(context, expr.id)
    // The shift amount is masked to the width first : native `<<` on `int32_t`
    // masks to 5 bits (int64_t to 6), so `1 << 33` runs as `1 << 1`. Without
    // this the i64 tree-walk shift would compute `1 << 33` then wrap to 0.
    right_value :: if expr.op == .Shl || expr.op == .Shr {
        mask_shift_amount(right_result.value, rname)
    } else {
        right_result.value
    }
    combined :: combine_binary(expr, left_result.value, right_value)
    return normalize_int_result(combined, rname)
}

combine_binary :: fn(expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue) -> EvalResult = match expr.op {
    .Add    -> arithmetic_or_concat(expr, left, right, op_add)
    .Sub    -> arithmetic(expr, left, right, op_sub)
    .Mul    -> arithmetic(expr, left, right, op_mul)
    .Div    -> int_div_check(expr, left, right, op_div)
    .Mod    -> int_mod_check(expr, left, right, op_mod)
    .Shl    -> arithmetic_int(expr, left, right, op_shl)
    .Shr    -> arithmetic_int(expr, left, right, op_shr)
    .BitAnd -> arithmetic_int(expr, left, right, op_bit_and)
    .BitOr  -> arithmetic_int(expr, left, right, op_bit_or)
    .BitXor -> arithmetic_int(expr, left, right, op_bit_xor)
    .And    -> bool_op(expr, left, right, op_and)
    .Or     -> bool_op(expr, left, right, op_or)
    .Eq     -> compare(expr, left, right, .Eq)
    .Neq    -> compare(expr, left, right, .Neq)
    .Lt     -> compare(expr, left, right, .Lt)
    .Lte    -> compare(expr, left, right, .Lte)
    .Gt     -> compare(expr, left, right, .Gt)
    .Gte    -> compare(expr, left, right, .Gte)
    .Is     -> vm_required(expr.span, "BinaryOp.Is")
    .In     -> vm_required(expr.span, "BinaryOp.In")
    .NotIn  -> vm_required(expr.span, "BinaryOp.NotIn")
}

/// Evaluate a `UnaryExpr` (`-x`, `!x`, `~x`).
/// @param expr     the unary expression node.
/// @param context  the evaluator context.
/// @param recurse  dispatcher callback ; see `evaluate_binary_expr`.
/// @return         the result value or a diagnostic.
export evaluate_unary_expr :: fn(
    expr: AST.UnaryExpr, context: ComptimeContext,
    recurse: fn(AST.Expr, ComptimeContext) -> EvalResult,
) -> EvalResult {
    inner :: recurse(expr.operand, context)
    if inner.value is null { return inner }
    rname :: resolved_int_name(context, expr.id)
    combined :: match expr.op {
        .Neg    -> unary_neg(expr, inner.value)
        .Not    -> unary_not(expr, inner.value)
        .BitNot -> unary_bit_not(expr, inner.value)
    }
    return normalize_int_result(combined, rname)
}

// ---- integer-width normalisation (audit CT1) ------------------------------

// Re-wrap an integer result to the node's resolved width so a comptime fold
// matches the runtime's fixed-width arithmetic. Non-integer results (bool from
// comparisons, string from concat) pass through, as do unknown / 64-bit widths
// — a missing or `i64`/`u64`/`isize`/`usize` width is NEVER truncated.
normalize_int_result :: fn(r: EvalResult, rname: string) -> EvalResult {
    if r.value is IntValue as iv { return ok(int_val_typed(wrap_to_width(iv.value, rname), iv.type_name)) }
    return r
}

// Wrap an i64 to the given primitive width. Every sub-64 width is stored (like
// the runtime) in a 32-bit slot, so `i8`..`u32` all wrap at 32 bits with sign
// extension ; the 64-bit widths and any unrecognised name stay full-width.
wrap_to_width :: fn(v: i64, type_name: string) -> i64 = match type_name {
    "i8" | "u8" | "i16" | "u16" | "i32" | "u32" -> sign_extend_32(v)
    _                                           -> v
}

// Truncate to the low 32 bits, then sign-extend bit 31 into the upper half so
// the stored i64 carries the same value the runtime's signed 32-bit slot would.
sign_extend_32 :: fn(v: i64) -> i64 {
    low :: v & 0xFFFF_FFFF
    if (low & 0x8000_0000) != 0 { return low - 0x1_0000_0000 }
    return low
}

// Mask a shift's right operand to the result width (5 bits for a 32-bit type,
// 6 for a 64-bit / unknown one) — mirrors the hardware shift the backends emit.
mask_shift_amount :: fn(rhs: ComptimeValue, rname: string) -> ComptimeValue {
    if rhs is IntValue as iv { return int_val_typed(iv.value & shift_amount_mask(rname), iv.type_name) }
    return rhs
}

shift_amount_mask :: fn(rname: string) -> i64 = match rname {
    "i8" | "u8" | "i16" | "u16" | "i32" | "u32" -> 31
    _                                           -> 63
}

// Primitive name of the node's resolved type, or "" when the typechecker left
// no entry / the type isn't a bare primitive (both ⇒ don't wrap).
resolved_int_name :: fn(context: ComptimeContext, expr_id: usize) -> string {
    t :: context.typed.expr_types[expr_id]
    if t is PrimitiveType as p { return p.name }
    // A free int the typechecker never pinned to a concrete width (nested inside
    // a comparison / shift, so no slot narrowed it) defaults to `i32` — SPEC
    // "Default integer", exactly what the runtime does, so it wraps at 32 bits.
    if t is FreeIntType { return "i32" }
    return ""
}

// ---- arithmetic helpers ---------------------------------------------------

// `Add` accepts strings (concat) in addition to numeric pairs, hence
// the dedicated wrapper. Other arith ops go through `arithmetic` which
// rejects strings with `C4007`.
arithmetic_or_concat :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    int_op: fn(i64, i64) -> i64,
) -> EvalResult {
    if left is StringValue as ls {
        if right is StringValue as rs { return ok(string_val("${ls.value}${rs.value}")) }
        return type_mismatch(expr, "string + non-string")
    }
    return arithmetic(expr, left, right, int_op)
}

arithmetic :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    int_op: fn(i64, i64) -> i64,
) -> EvalResult {
    match left {
        is IntValue as li -> {
            match right {
                is IntValue as ri -> { return ok(int_val_typed(int_op(li.value, ri.value), li.type_name)) }
                _ -> {}
            }
        }
        is FloatValue as lf -> {
            match right {
                is FloatValue as rf -> { return ok(float_val_typed(float_arith(expr.op, lf.value, rf.value), lf.type_name)) }
                _ -> {}
            }
        }
        _ -> {}
    }
    return type_mismatch(expr, "operand kinds disagree for arithmetic op")
}

arithmetic_int :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    int_op: fn(i64, i64) -> i64,
) -> EvalResult {
    match left {
        is IntValue as li -> {
            match right {
                is IntValue as ri -> { return ok(int_val_typed(int_op(li.value, ri.value), li.type_name)) }
                _ -> {}
            }
        }
        _ -> {}
    }
    return type_mismatch(expr, "operand kinds disagree for bit / mod / shift op")
}

// Short-circuit before the C-level division — `idiv` by 0 traps with
// SIGFPE on x86_64, which is host-platform UB the evaluator can't
// otherwise observe.
int_div_check :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    int_op: fn(i64, i64) -> i64,
) -> EvalResult {
    if right is IntValue as ri {
        if ri.value == 0 { return division_by_zero(expr, "/") }
    }
    return arithmetic(expr, left, right, int_op)
}

int_mod_check :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    int_op: fn(i64, i64) -> i64,
) -> EvalResult {
    if right is IntValue as ri {
        if ri.value == 0 { return division_by_zero(expr, "%") }
    }
    return arithmetic_int(expr, left, right, int_op)
}

bool_op :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue,
    op: fn(bool, bool) -> bool,
) -> EvalResult {
    match left {
        is BoolValue as lb -> {
            match right {
                is BoolValue as rb -> {
                    if op(lb.value, rb.value) { return ok(VAL_TRUE) }
                    return ok(VAL_FALSE)
                }
                _ -> {}
            }
        }
        _ -> {}
    }
    return type_mismatch(expr, "logical operator requires bool operands")
}

// ---- comparison helpers ---------------------------------------------------

CompareOp :: enum(u8) { Eq, Neq, Lt, Lte, Gt, Gte }

compare :: fn(
    expr: AST.BinaryExpr, left: ComptimeValue, right: ComptimeValue, op: CompareOp,
) -> EvalResult {
    match left {
        is IntValue as li -> {
            match right {
                is IntValue as ri -> { return ok(bool_value(int_compare(li.value, ri.value, op))) }
                _ -> {}
            }
        }
        is FloatValue as lf -> {
            match right {
                is FloatValue as rf -> { return ok(bool_value(float_compare(lf.value, rf.value, op))) }
                _ -> {}
            }
        }
        is BoolValue as lb -> {
            match right {
                is BoolValue as rb -> { return equality_only(expr, lb.value == rb.value, op, "bool") }
                _ -> {}
            }
        }
        is StringValue as ls -> {
            match right {
                is StringValue as rs -> { return equality_only(expr, ls.value == rs.value, op, "string") }
                _ -> {}
            }
        }
        _ -> {}
    }
    return type_mismatch(expr, "comparison operand kinds disagree")
}

// `string` / `bool` support only equality at comptime : neither implements
// `Comparable`, so `<` / `<=` / `>` / `>=` are unordered. At runtime the very
// same expression lowers to `i32.lt` and traps ("expected i32, got string") —
// baking any bool here would diverge from that trapping behaviour, so refuse
// loudly rather than silently return `false` (the old degraded fallback).
equality_only :: fn(expr: AST.BinaryExpr, eq: bool, op: CompareOp, kind: string) -> EvalResult {
    if op == .Eq  { return ok(bool_value(eq)) }
    if op == .Neq { return ok(bool_value(!eq)) }
    return type_mismatch(expr, "`${kind}` values are not ordered (no Comparable impl); only == and != are valid at comptime")
}

int_compare :: fn(left: i64, right: i64, op: CompareOp) -> bool = match op {
    .Eq  -> left == right
    .Neq -> left != right
    .Lt  -> left < right
    .Lte -> left <= right
    .Gt  -> left > right
    .Gte -> left >= right
}

float_compare :: fn(left: f64, right: f64, op: CompareOp) -> bool = match op {
    .Eq  -> left == right
    .Neq -> left != right
    .Lt  -> left < right
    .Lte -> left <= right
    .Gt  -> left > right
    .Gte -> left >= right
}

bool_value :: fn(b: bool) -> ComptimeValue {
    if b { return VAL_TRUE }
    return VAL_FALSE
}

// ---- unary helpers --------------------------------------------------------

unary_neg :: fn(expr: AST.UnaryExpr, inner: ComptimeValue) -> EvalResult {
    // @partial: only Int / Float negate; every other value kind is a type mismatch.
    @partial match inner {
        is IntValue   as i -> { return ok(int_val_typed(-i.value, i.type_name)) }
        is FloatValue as f -> { return ok(float_val_typed(-f.value, f.type_name)) }
        _                  -> { return unary_type_mismatch(expr, "`-` requires numeric") }
    }
}

unary_not :: fn(expr: AST.UnaryExpr, inner: ComptimeValue) -> EvalResult {
    if inner is BoolValue as b {
        if b.value { return ok(VAL_FALSE) }
        return ok(VAL_TRUE)
    }
    return unary_type_mismatch(expr, "`!` requires bool")
}

unary_bit_not :: fn(expr: AST.UnaryExpr, inner: ComptimeValue) -> EvalResult {
    if inner is IntValue as i { return ok(int_val_typed(bit_not_i64(i.value), i.type_name)) }
    return unary_type_mismatch(expr, "`~` requires int")
}

// Vader doesn't expose `~` as a builtin yet ; emulate via `xor` with -1.
bit_not_i64 :: fn(value: i64) -> i64 { return value ^ -1 }

// ---- error helpers --------------------------------------------------------

type_mismatch :: fn(expr: AST.BinaryExpr, detail: string) -> EvalResult {
    return fail(comptime_error(.TypeMismatch, expr.span, detail))
}

division_by_zero :: fn(expr: AST.BinaryExpr, op_sym: string) -> EvalResult {
    return fail(comptime_error(.DivisionByZero, expr.span, op_sym))
}

unary_type_mismatch :: fn(expr: AST.UnaryExpr, detail: string) -> EvalResult {
    return fail(comptime_error(.TypeMismatch, expr.span, detail))
}

// ---- per-op closures ------------------------------------------------------

op_add     :: fn(left: i64, right: i64) -> i64 { return left + right }
op_sub     :: fn(left: i64, right: i64) -> i64 { return left - right }
op_mul     :: fn(left: i64, right: i64) -> i64 { return left * right }
op_div     :: fn(left: i64, right: i64) -> i64 { return left / right }
op_mod     :: fn(left: i64, right: i64) -> i64 { return left % right }
op_shl     :: fn(left: i64, right: i64) -> i64 { return left << right }
op_shr     :: fn(left: i64, right: i64) -> i64 { return left >> right }
op_bit_and :: fn(left: i64, right: i64) -> i64 { return left & right }
op_bit_or  :: fn(left: i64, right: i64) -> i64 { return left | right }
op_bit_xor :: fn(left: i64, right: i64) -> i64 { return left ^ right }
op_and     :: fn(left: bool, right: bool) -> bool { return left && right }
op_or      :: fn(left: bool, right: bool) -> bool { return left || right }

// Float arithmetic dispatches inline since the i64 closure won't fit.
// @partial: float arithmetic supports only Add/Sub/Mul/Div; other BinaryOps
// are dispatched elsewhere and default to 0.0.
float_arith :: fn(op: AST.BinaryOp, left: f64, right: f64) -> f64 = @partial match op {
    .Add -> left + right
    .Sub -> left - right
    .Mul -> left * right
    .Div -> left / right
    _    -> 0.0
}
