// vader/comptime/intrinsic — comptime evaluator for `@<name>(args)` calls.
//
// Minimal Phase 5 scope : `@size_of`, `@align_of`, `@type_name`,
// `@type_kind`. Every other intrinsic falls back to `C4001` ; richer
// coverage (`@field`, `@fields`, `@file`, `@env`, …) lands when the
// downstream consumer (lowerer / bytecode emit) is ported and the
// missing infrastructure can be validated end-to-end.

module "vader/comptime"

import "vader/typecheck" { type_from_expr }
import "vader/types" {
    Type, PrimitiveType, StructType, EnumType, TraitType, ArrayType, TupleType,
    FnType, TypeParamType, TypeMetaType, UnionType, UnresolvedType, AnyType, DistinctType,
    SelfType, FreeIntType, FreeCharType, FreeFloatType, NeverType, display_type,
}
import "vader/diagnostics" { Diagnostic, comptime_error }
import "vader/diagnostics" { ComptimeCode }
AST :: import "vader/parser"

/// Dispatch a `@<name>(args)` call to the matching evaluator. Returns
/// `vm_required` for unknown intrinsics so the caller skips the decl.
/// @param expr     the intrinsic call node.
/// @param context  the evaluator context — used for `type_from_expr`.
/// @return         the evaluated value or a `C4xxx` diagnostic.
export evaluate_intrinsic_call :: fn(
    expr: AST.IntrinsicCallExpr, context: ComptimeContext,
) -> EvalResult {
    if expr.name == "size_of"   { return intrinsic_size_of(expr, context) }
    if expr.name == "align_of"  { return intrinsic_align_of(expr, context) }
    if expr.name == "type_name" { return intrinsic_type_name(expr, context) }
    if expr.name == "type_kind" { return intrinsic_type_kind(expr, context) }
    if expr.name == "field_count"   { return intrinsic_field_count(expr, context) }
    if expr.name == "variant_count" { return intrinsic_variant_count(expr, context) }
    if expr.name == "field_index"   { return intrinsic_field_index(expr, context) }
    return vm_required(expr.span, "@${expr.name}")
}

// `@field_count(T)` — fields on a Struct, elements on a Tuple, 0 otherwise.
intrinsic_field_count :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 { return arg_count_error(expr, "field_count", 1) }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "field_count: argument is not a type") }
    return ok(int_val_typed(type_field_count(arg_type, context), "usize"))
}

type_field_count :: fn(t: Type, context: ComptimeContext) -> i64 {
    if t is StructType as s {
        decl :: context.typed.struct_decls[s.symbol.id]
        if decl is AST.StructDecl as d { return i64(d.fields.len()) }
        return 0
    }
    if t is TupleType as p { return i64(p.elements.len()) }
    return 0
}

// `@variant_count(T)` — variants on a Union or Enum, 0 otherwise.
intrinsic_variant_count :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 { return arg_count_error(expr, "variant_count", 1) }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "variant_count: argument is not a type") }
    return ok(int_val_typed(type_variant_count(arg_type), "usize"))
}

type_variant_count :: fn(t: Type) -> i64 {
    if t is UnionType as u { return i64(u.variants.len()) }
    if t is EnumType as e { return i64(e.indices.len()) }
    return 0
}

// `@field_index(T, "name")` — 0-based position of `name` in struct `T`'s field
// list. `T` must be a struct and `name` a static string literal naming a field.
intrinsic_field_index :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 2 { return arg_count_error(expr, "field_index", 2) }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "field_index: first argument is not a type") }
    name :: static_string_arg(expr.args[1])
    if name == null { return arg_error(expr, "field_index: field name must be a static string literal") }
    if arg_type is StructType as st {
        decl :: context.typed.struct_decls[st.symbol.id]
        if decl is AST.StructDecl as d {
            for i in 0..<d.fields.len() {
                if d.fields[i].name == name { return ok(int_val_typed(i64(i), "usize")) }
            }
            return arg_error(expr, "field_index: `${display_type(arg_type)}` has no field named `${name}`")
        }
        return arg_error(expr, "field_index: struct declaration for `${display_type(arg_type)}` not found")
    }
    return arg_error(expr, "field_index: `${display_type(arg_type)}` is not a struct")
}

// Extract a single-part string literal's text, or null when the arg isn't a
// static string literal.
static_string_arg :: fn(e: AST.Expr) -> string | null {
    if e is AST.StringLitExpr as s {
        if s.parts.len() == 1 {
            if s.parts[0] is AST.StringLitText as t { return t.value }
        }
    }
    return null
}

intrinsic_size_of :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 {
        return arg_count_error(expr, "size_of", 1)
    }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "size_of: argument is not a type") }
    return ok(int_val_typed(byte_size(arg_type), "usize"))
}

intrinsic_align_of :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 {
        return arg_count_error(expr, "align_of", 1)
    }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "align_of: argument is not a type") }
    return ok(int_val_typed(byte_align(arg_type), "usize"))
}

intrinsic_type_name :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 {
        return arg_count_error(expr, "type_name", 1)
    }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "type_name: argument is not a type") }
    return ok(string_val(display_type(arg_type)))
}

intrinsic_type_kind :: fn(expr: AST.IntrinsicCallExpr, context: ComptimeContext) -> EvalResult {
    if expr.args.len() != 1 {
        return arg_count_error(expr, "type_kind", 1)
    }
    arg_type :: resolve_type_arg(expr.args[0], context)
    if arg_type == null { return arg_error(expr, "type_kind: argument is not a type") }
    return ok(string_val(type_kind_label(arg_type)))
}

// ---- helpers --------------------------------------------------------------

// Resolve `expr` (a type-position expression like `i32` or `MutableMap(K, V)`)
// to a `Type`. Returns null when resolution fails — the caller surfaces
// C4011 with a friendly message.
resolve_type_arg :: fn(expr: AST.Expr, context: ComptimeContext) -> Type | null {
    raw :: type_from_expr(expr, context.typed.resolved, diag_sink())
    if raw is UnresolvedType { return null }
    return raw
}

// Primitive byte sizes match `intrinsic_assert`'s expectations
// (`@size_of(i32) == 4`, `@size_of(string) == 16`, …). Composite
// reference types (struct / enum / array / tuple / union / trait /
// fn / any) report as `vader_box_t` width (16 bytes — tag + payload).
// Comptime-only / unsized types (TypeMeta / TypeParam / Self /
// Unresolved / Free* / Never / void) report 0.
// @partial: representable types have a fixed size; abstract types (TypeParam/Self/Unresolved/…) → 0.
export byte_size :: fn(t: Type) -> i64 = @partial match t {
    is PrimitiveType as p -> primitive_size(p.name)
    is DistinctType as d -> byte_size(d.backing)
    is StructType | EnumType | ArrayType | TupleType | UnionType | TraitType | FnType | AnyType -> 16
    _ -> 0
}

// @partial: representable types have a fixed alignment; abstract types → 0.
export byte_align :: fn(t: Type) -> i64 = @partial match t {
    is PrimitiveType as p -> primitive_align(p.name)
    is DistinctType as d -> byte_align(d.backing)
    is StructType | EnumType | ArrayType | TupleType | UnionType | TraitType | FnType | AnyType -> 8
    _ -> 0
}

primitive_size :: fn(name: string) -> i64 {
    if name == "i8"     { return 1 }
    if name == "u8"     { return 1 }
    if name == "bool"   { return 1 }
    if name == "i16"    { return 2 }
    if name == "u16"    { return 2 }
    if name == "i32"    { return 4 }
    if name == "u32"    { return 4 }
    if name == "char"   { return 4 }
    if name == "f32"    { return 4 }
    if name == "i64"    { return 8 }
    if name == "u64"    { return 8 }
    if name == "f64"    { return 8 }
    if name == "isize"  { return 8 }
    if name == "usize"  { return 8 }
    if name == "string" { return 16 }
    return 0
}

primitive_align :: fn(name: string) -> i64 {
    // 64-bit targets : alignment == size for every primitive we expose.
    return primitive_size(name)
}

// Stable `@type_kind(T)` discriminator. EXHAUSTIVE over `Type` (no `_`) and
// kept in lock-step — same arms, same strings — with
// `vader/lower/lower_intrinsic.vader::kind_string_of_type` and the stable set
// in SPEC §14 (`@type_kind`). The non-user-facing variants (TypeParam, Self,
// Unresolved, Free*, Never) report "unknown". Listing every variant trips
// T3013 at BOTH sites on a new Type kind, so the two can't silently diverge.
type_kind_label :: fn(t: Type) -> string = match t {
    is PrimitiveType  -> "primitive"
    is DistinctType as d -> type_kind_label(d.backing)
    is StructType     -> "struct"
    is EnumType       -> "enum"
    is UnionType      -> "union"
    is ArrayType      -> "array"
    is TupleType      -> "tuple"
    is FnType         -> "fn"
    is TraitType      -> "trait"
    is TypeMetaType   -> "type"
    is TypeParamType  -> "unknown"
    is SelfType       -> "unknown"
    is UnresolvedType -> "unknown"
    is FreeIntType    -> "unknown"
    is FreeCharType   -> "unknown"
    is FreeFloatType  -> "unknown"
    is NeverType      -> "unknown"
    is AnyType        -> "any"
}

arg_count_error :: fn(expr: AST.IntrinsicCallExpr, name: string, expected: usize) -> EvalResult {
    return fail(comptime_error(.FeatureNotSupported, expr.span,
        "@${name} expects ${expected} argument(s), got ${expr.args.len()}"))
}

arg_error :: fn(expr: AST.IntrinsicCallExpr, detail: string) -> EvalResult {
    return fail(comptime_error(.FeatureNotSupported, expr.span, detail))
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_primitive_size_table :: fn() -> void {
    assert_eq(primitive_size("i32"), 4)
    assert_eq(primitive_size("i64"), 8)
    assert_eq(primitive_size("string"), 16)
    assert_eq(primitive_size("unknown_type"), 0)
}

@test test_type_kind_label :: fn() -> void {
    int_type :: type_for_primitive("i32")
    assert_eq(type_kind_label(int_type), "primitive")
}

import "vader/types" { mk_primitive }

type_for_primitive :: fn(name: string) -> Type { return mk_primitive(name) }
