// vader/comptime/assert — `@assert(cond)` decl evaluation.
//
// Mirror of TS's per-`AssertDecl` walker in
// `src/comptime/evaluate.ts` (lines 86-110). Each top-level `@assert`
// has its `condition` evaluated through the same tree-walker the
// `@comptime const` decls use ; a `Bool(false)` result fires `C4004`.
// Asserts that fall back to `C4002` (need-VM) are skipped silently —
// the build can't validate them yet but the diagnostic surfaces at
// the call site of `evaluate_expr` for visibility.

import "vader/diagnostics/diagnostic" { Diagnostic, comptime_error }
import "vader/diagnostics/codes" { ComptimeCode }
import "vader/typecheck/typed_ast" { TypedProgram }
import "vader/comptime/eval_types" { ComptimeContext }
import "vader/comptime/eval" { evaluate_expr }
import "vader/comptime/value" { ComptimeValue, BoolValue }
import "std/collections" { MutableMap }
AST :: import "vader/parser/ast"

/// Walk `decls` for `AssertDecl`s, evaluate each via the tree-walker,
/// and emit `C4004` when the condition is statically `false`. Used by
/// `evaluate_project` after every module's `@comptime const`s have
/// been baked so assert conditions can reference them.
/// @param decls    the module's top-level decls.
/// @param typed    the module's typed program (for the evaluator ctx).
/// @param diags    diagnostics emitted by the walker.
export evaluate_assert_decls :: fn(
    decls: AST.Decl[], typed: TypedProgram, diags: Diagnostic[],
) -> void {
    context :: ComptimeContext {
        .typed    = typed,
        .bindings = MutableMap(i32, ComptimeValue) { .buckets = [], .size = 0 },
    }
    for decl in decls {
        match decl {
            is AST.AssertDecl as assert_decl -> {
                result :: evaluate_expr(assert_decl.condition, context)
                match result.diag {
                    is null -> {}
                    _       -> { diags.push(result.diag) }
                }
                match result.value {
                    is BoolValue as b -> {
                        if !b.value {
                            diags.push(comptime_error(.AssertFailed, assert_decl.span, assert_message(assert_decl)))
                        }
                    }
                    _ -> {}
                }
            }
            _ -> {}
        }
    }
}

assert_message :: fn(decl: AST.AssertDecl) -> string {
    match decl.message {
        is null -> { return "" }
        is string -> { return decl.message }
    }
}
