// vader/comptime/eval_lit — literal-expression evaluators.
//
// Per-variant `evaluate_<kind>_lit` for every AST literal expression.
// Each returns an `EvalResult` carrying the canonicalised
// `ComptimeValue` ; type-name suffixes round-trip through the value
// (`42_i64` keeps its `i64` tag).

module "vader/comptime"

import "std/string_builder" { StringBuilder, append, append_char }
import "vader/diagnostics" { comptime_error }
import "vader/diagnostics" { ComptimeCode }
AST :: import "vader/parser"

/// Evaluate an `IntLitExpr`. The parser stores the unsigned magnitude
/// (negatives wrap a `UnaryExpr.Neg` around a positive lit), and the
/// suffix (`i32`, `usize`, …) drives the value's `type_name`. Default
/// is `i32` to match the typechecker's free-int defaulting.
/// @param literal  the literal node.
/// @return         the wrapped int value.
export evaluate_int_lit :: fn(literal: AST.IntLitExpr) -> EvalResult = ok(int_val(i64(literal.value)))

/// Evaluate a `FloatLitExpr` — always a free `f64` value (no suffix form).
/// @param literal  the literal node.
/// @return         the wrapped float value.
export evaluate_float_lit :: fn(literal: AST.FloatLitExpr) -> EvalResult = ok(float_val(literal.value))

/// Evaluate a `BoolLitExpr` (`true` / `false`).
export evaluate_bool_lit :: fn(literal: AST.BoolLitExpr) -> EvalResult {
    if literal.value { return ok(VAL_TRUE) }
    return ok(VAL_FALSE)
}

/// Evaluate a `NullLitExpr` (`null` literal).
export evaluate_null_lit :: fn(_: AST.NullLitExpr) -> EvalResult {
    return ok(VAL_NULL)
}

/// Evaluate a `CharLitExpr` ; carries the codepoint as `u32`.
export evaluate_char_lit :: fn(literal: AST.CharLitExpr) -> EvalResult {
    return ok(CharValue { .value = literal.value })
}

/// Evaluate a `StringLitExpr`. Plain text segments concat directly ;
/// interpolation segments recurse through `evaluate_expr` and render
/// via `display_value`. Falls back to `C4001` when an interp segment
/// itself doesn't reduce to a concrete value.
/// @param literal  the literal node.
/// @param context  the evaluator context.
/// @param recurse  dispatcher callback ; passed in to avoid the
///                 eval ↔ eval_lit import cycle.
/// @return         the concatenated string value, or C4001 when an
///                 interpolation segment can't be evaluated.
export evaluate_string_lit :: fn(
    literal: AST.StringLitExpr, context: ComptimeContext,
    recurse: fn(AST.Expr, ComptimeContext) -> EvalResult,
) -> EvalResult {
    sb := StringBuilder {}
    for part in literal.parts {
        match part {
            is AST.StringLitText as text -> { sb.append(text.value) }
            is AST.StringLitInterp as interp -> {
                inner :: recurse(interp.expr, context)
                if inner.value is null { return inner }
                sb.append(interp_value(inner.value))
            }
        }
    }
    return ok(string_val(sb.to_string()))
}

// Render a comptime value as the user-facing `Display` form would —
// strings stay quote-less, integers drop the `_i32` suffix. Used by
// string-interpolation segments so `"x=${42}"` resolves to `"x=42"`
// rather than `"x=42_i32"`.
interp_value :: fn(v: ComptimeValue) -> string = match v {
    is IntValue    as x -> "${x.value}"
    is FloatValue  as x -> "${x.value}"
    is BoolValue   as x -> "${x.value}"
    is StringValue as x -> x.value
    is CharValue   as x -> "${x.value}"
    is NullValue        -> "null"
    is VoidValue        -> ""
    is ArrayValue       -> display_value(v)
    is StructValue      -> display_value(v)
    is TypeValue        -> display_value(v)
}

