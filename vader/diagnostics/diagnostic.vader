// vader/diagnostics/diagnostic — structured diagnostic shape consumed by the
// terminal renderer and (eventually) the LSP. Mirrors `src/diagnostics/`
// shapes (Severity / Position / Span / Diagnostic) so a Vader-driven LSP
// emits the same JSON schema as the TS compiler.

import "std/string" { len }
import "vader/diagnostics/codes" { LexerCode, ParserCode, info, parser_info, CodeInfo }

Severity :: enum {
    Error,
    Warning,
    Info,
    Hint,
}

// Source position. Offset/line/column are JS-string code-unit accurate, which
// matches UTF-8 bytes for ASCII source. The LSP boundary translates to UTF-16
// column counts when needed.
Position :: struct {
    file: string
    offset: i32
    line: i32
    column: i32
}

// Half-open span [start, end) in source.
Span :: struct {
    start: Position
    end: Position
}

Diagnostic :: struct {
    severity: Severity
    // Resolved at construction time so the renderer doesn't need to dispatch
    // on a union-of-enums (which the runtime can't pattern-match cleanly).
    code:     CodeInfo
    // Optional detail appended to the canonical message at render time.
    detail:   string
    primary:  Span
}

// Generic constructor — most callers will use the typed `error` /
// `parser_error` shortcuts below.
make :: fn(severity: Severity, code: CodeInfo, primary: Span, detail: string) =
    Diagnostic { .severity = severity, .code = code, .detail = detail, .primary = primary }

// Lexer-side shortcut : `error(.UnexpectedCharacter, span, "x")`.
error :: fn(code: LexerCode, primary: Span, detail: string) =
    make(.Error, info(code), primary, detail)

// Parser-side shortcut : `parser_error(.ExpectedToken, span, "...")`.
parser_error :: fn(code: ParserCode, primary: Span, detail: string) =
    make(.Error, parser_info(code), primary, detail)

// Render a diagnostic as a single-line `error[CODE]: message at file:line:col`.
// Used for terminal output today; the LSP will go via the JSON shape directly
// without this helper.
render :: fn(d: Diagnostic) -> string {
    severity :: match d.severity {
        .Error   -> "error"
        .Warning -> "warning"
        .Info    -> "info"
        .Hint    -> "hint"
    }
    p :: d.primary.start
    detail: string = ""
    if d.detail.len() > 0 {
        detail = ": ${d.detail}"
    }
    return "${severity}[${d.code.id}]: ${d.code.message}${detail} at ${p.file}:${p.line}:${p.column}"
}
