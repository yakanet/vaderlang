// Unlabeled `continue` inside two nested loops — both TS and Vader emit
// W0004 (ambiguous loop jump : which loop does it target?). The jump is
// guarded by an `if`, the common real-world shape ; both compilers track
// loop nesting through the `if` block (TS threads `fn.loopDepth` through
// expressions ; Vader reads the walk-global `TypedProgram.loop_depth`).

module "snippet"

main :: fn() -> i32 {
    n := 0
    for i in 0..<3 {
        for j in 0..<3 {
            if i + j == 2 { continue }
            n = n + 1
        }
    }
    return n
}
