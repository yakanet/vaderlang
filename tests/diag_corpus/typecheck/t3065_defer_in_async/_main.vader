module "snippet"

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

val :: fn() -> Async<i64> = Ready<i64> { .v = 1 }

// `defer` inside an async coroutine is rejected in v1 (T3065) — unwind across a
// suspension isn't supported yet. `work` awaits, so it is inferred async.
export work :: fn() -> Async<i64> {
    defer { }
    v :: await val()
    return v
}
