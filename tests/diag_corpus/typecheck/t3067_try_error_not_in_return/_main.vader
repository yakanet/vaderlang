module "snippet"

// `expr?` lowers to an implicit `return <error>`, so the enclosing fn's return
// type must be able to carry the error. Here `bad` returns plain `i32` (no Error
// variant), so propagating `fallible`'s `Boom` is rejected — T3067 — instead of
// silently returning the error struct into a numeric slot (a runtime miscompile).

Boom :: struct {}
Boom implements Error { message :: fn(self) -> string = "boom" }

fallible :: fn() -> i32 | Boom { return Boom {} }

export bad :: fn() -> i32 {
    x :: fallible()?
    return x
}
