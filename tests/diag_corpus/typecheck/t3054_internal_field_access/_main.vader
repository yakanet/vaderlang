// T3054 : a struct field marked `@internal` is accessed from outside its
// declaring module. `MutableSet.inner` (and the backing `MutableMap.size`) are
// `@internal` to `std/collections` — the only cross-module surface is the
// public API (`add` / `len` / `in`). Reaching into `.inner.size` from
// `module "snippet"` must be rejected: one T3054 for `.inner` (MutableSet) and
// one for `.size` (the MutableMap it yields).
module "snippet"

import "std/collections" { MutableSet }

main :: fn() -> i32 {
    s := MutableSet<i32> {}
    s.add(1)
    return i32(s.inner.size)
}
