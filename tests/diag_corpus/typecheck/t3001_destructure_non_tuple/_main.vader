// A `[a, b]` destructure of a value that is neither a tuple nor an array is a
// type error (T3001) — unless its type implements `Into<[...]>` of matching
// arity. `Point` implements no such coercion, so destructuring it errors.
// (A struct that DOES implement it — e.g. `Entry` — destructures fine; see
// the `map_kv_destructure` snippet.)
module "snippet"

Point :: struct {
    x: i32
    y: i32
}

main :: fn() -> i32 {
    points: Point[] = [Point { .x = 1, .y = 2 }]
    for [a, b] in points {
    }
    return 0
}
