// Soundness guard : `.Banana` is a variant of `Fruit`, not of the expected
// `Color`. The typer must reject it (T3027), not silently accept a junk
// ordinal. See TODO "Typer accepts an enum literal from the wrong enum".
module "snippet"

Color :: enum { Red, Green, Blue }
@allow_unused
Fruit :: enum { Apple, Banana, Cherry }

take_color :: fn(c: Color) -> i32 {
    if c == Color.Red { return 1 }
    return 0
}

main :: fn() -> i32 {
    return take_color(.Banana)
}
