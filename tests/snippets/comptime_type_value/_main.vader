// A TypeMeta-typed ident in value position emits a `type.const N` op ;
// the VM carries the result as a TypeValue. No native reader exists yet
// — the snapshot golden validates the bytecode shape.

import "std/io" { println }

@comptime alias_int :: i32

main :: fn() -> i32 {
    accept_type(alias_int)
    accept_type(i64)
    println("ok")
    return 0
}

accept_type :: fn(t: type) -> void {
}
