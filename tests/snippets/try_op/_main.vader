import "std/io" { println, read_file }

// Exercise the `?` operator end-to-end: read_file returns string!, the
// `?` propagates an Error; on the happy path we receive the file content.
read_or_default :: fn(path: string) -> string! {
    return read_file(path)?
}

show :: fn(res: string | Error) -> void {
    match res {
        is string -> println(res)
        is Error  -> println("err: this file does not exists")
    }
}

main :: fn() -> i32 {
    show(read_or_default("./tests/snippets/try_op/data.txt"))
    show(read_or_default("./does_not_exist.txt"))
    return 0
}
