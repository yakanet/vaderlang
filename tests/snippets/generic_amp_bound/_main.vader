// Layer 3.B : `&` for trait composition in bounds.
// `[T: Add & Sub]` reads as « T satisfies both Add *and* Sub » — same
// operator as type-intersection, parsed at a tighter precedence than `|`
// (the union operator). The bound parses to `BinaryExpr(bitand, Add, Sub)`,
// matching the value-side Pratt precedence (`amp` BP 60 > `pipe` BP 40).
//
// Layer 7e enforces these bounds at call sites — the concrete type-arg
// must implement every composed trait, otherwise T3006 fires. `string`
// is the only stdlib primitive that explicitly `implements Add` (concat),
// so the snippet uses it for the `Add`-bounded case ; `bar` uses
// `Hash & Eq` which `i32` and `string` satisfy.

needs_add :: fn[T: Add](x: T) -> T = x

bar :: fn[K: Hash & Eq, V](key: K, value: V) -> V = value

main :: fn() -> i32 {
    s :: needs_add("hello")
    b :: bar(1, 2)
    return b
}
