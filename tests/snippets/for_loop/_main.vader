mixed_loops :: fn(start: i32) -> i32 {
    n := 0

    // while-style: skip odd values via continue
    i := start
    for i < 10 {
        i = i + 1
        if (i % 2 != 0) {
            continue
        }
        n = n + 1
    }

    // infinite loop: break out after 5 iterations
    j := 0
    for {
        if (j >= 5) {
            break
        }
        j = j + 1
        n = n + 1
    }

    return n
}
