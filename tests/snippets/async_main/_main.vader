// Implicit `@async main`: `main` awaits, so it is inferred async; the compiler
// keeps its `i32` return and inlines the run-driver (no manual `.resume()`).
module "snippet"

import "std/io"

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

greeting :: fn() -> Async<string> = Ready<string> { .v = "world" }

main :: fn() -> i32 {
    who :: await greeting()
    println("hello, ${who}")
    return 0
}
