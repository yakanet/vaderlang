// Generic type aliases via the LHS-angle head `Name<T> :: <body>` form.
// `Name<T>` between the ident and `::` is the unambiguous head ; the body
// is parsed as a regular expression and resolved as a type at use sites
// like `Maybe<i32>`. Mirrors the non-generic implicit alias `Foo :: i32 | u32`
// — `type` is no longer a keyword in Vader.

module "snippet"

import "std/io" { println }

export Maybe<T> :: T | null

export Pair<A, B> :: A | B

main :: fn() -> i32 {
    x: Maybe<i32> = 42
    y: Maybe<i32> = null

    match x {
        is null -> println("x is null")
        is i32  -> println("x = ${x}")
    }
    match y {
        is null -> println("y is null")
        is i32  -> println("y = ${y}")
    }

    p: Pair<i32, string> = "hello"
    match p {
        is i32    -> println("pair int   = ${p}")
        is string -> println("pair str   = ${p}")
    }

    return 0
}
