// `T implements Into(T)` is forbidden by SPEC §X *Type coercion* — identity
// coercion would shadow simple assignment. T3039 fires at the impl site.
// # compile errors

module "snippet"

Foo :: struct { value: i32 }

Foo implements Into<Foo> {
    into :: fn(self) -> Foo { return self }
}

main :: fn() -> i32 { return 0 }
