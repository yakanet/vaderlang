// A basic async coroutine. Async-ness is inferred from `await` and expressed by
// the `Async<T>` return type — no `@async` decorator. `main` awaits directly;
// the compiler drives it via the inline run-driver (implicit @async main).
module "snippet"

import "std/io"

// The v1 primitive awaitable: an immediately-ready future (a leaf).
Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

// A factory: no `await`, returns an awaitable directly (not a coroutine).
double :: fn(x: i32) -> Async<i32> = Ready<i32> { .v = x + x }

// A coroutine: it awaits, so it is async and must return `Async<T>`.
add_one :: fn(x: i32) -> Async<i32> {
    d :: await double(x)
    return d + 1
}

main :: fn() -> i32 {
    v :: await add_one(20)
    println("${v}")
    return 0
}
