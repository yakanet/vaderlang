module "snippet"

import "std/io" { println }

// Arity 3 and 4 tuples — confirms field access via `.0` / `.1` / `.2` /
// `.3` and the lowering's anonymous-struct synthesis works beyond the
// pair case the original tuple snippets cover.
main :: fn() -> i32 {
    triple: [i32, string, bool] = [1, "x", true]
    println("${triple.0} ${triple.1} ${triple.2}")
    quad: [i32, string, bool, f64] = [9, "q", false, 3.14]
    println("${quad.0} ${quad.1} ${quad.2} ${quad.3}")
    return 0
}
