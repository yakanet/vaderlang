import "std/io" { println }
import "std/runtime" { gc_collect, gc_collections }
import "std/collections" { MutableList, add, get, len }

// Force a collection mid-program with a populated MutableList(i32) on the
// shadow stack. Without Phase 2.6 the buf would dangle after the swap and
// the post-GC reads would observe garbage.

main :: fn() -> i32 {
    list := MutableList(i32) { .data = [], .size = 0 }
    i := 0
    for i < 200 {
        list.add(i)
        i = i + 1
    }

    before := gc_collections()
    gc_collect()
    after := gc_collections()

    diff := after - before
    if diff != 1 {
        println("expected 1 collection, got ${diff}")
        return 1
    }

    sum := 0
    j := 0
    for j < 200 {
        sum = sum + list.get(usize(j))
        j = j + 1
    }

    expected :: 200 * 199 / 2
    if sum != expected {
        println("sum mismatch: got ${sum}, expected ${expected}")
        return 2
    }

    println("ok: 200 array elements survived GC; sum=${sum}")
    return 0
}
