module "snippet"

import "std/io"
import "std/collections"

// `for [k, v] in m` over a `MutableMap` destructures the yielded
// `Entry<K, V>` into key / value. The parser desugars the form to
// `for e in m { let [k, v] := e ; <body> }`, so the work is in the
// `let [k, v] := e` destructure : `Entry` is a 3-field struct, not a
// tuple, and coerces to `[K, V]` via `Entry implements Into<[K, V]>`.
main :: fn() -> i32 {
    m := MutableMap<string, i32> {}
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3

    sum: i32 = 0
    for [k, v] in m {
        println("${k}=${v}")
        sum = sum + v
    }
    println("sum=${sum}")
    return 0
}
