# CFG

## snippet

fn snippet$add(%0: i32, %1: i32) -> i32
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 $add_2: i32
  bb0:
    %2 = binop 0 %0 %1 :i32
    return %2

fn snippet$square(%0: i32) -> i32
  locals:
    %0 x: i32 (param x)
    %1 $mul_1: i32
  bb0:
    %1 = binop 2 %0 %0 :i32
    return %1

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $k_1: i32
    %2 $call_2: i32
    %3 s: i32 (local s)
    %4 $call_4: i32
  bb0:
    %0 = const int(3) :i32
    %1 = const int(4) :i32
    %2 = call add(%0, %1) :i32
    %3 = move %2
    %4 = call square(%3) :i32
    return %4
