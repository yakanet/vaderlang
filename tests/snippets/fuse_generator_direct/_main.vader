// A directly-consumed `@generator` inlines into the for-in (Couche 2/4): the
// generator body becomes the fused loop, each `yield e` becomes the consumer's
// loop-var binding + body. `main`'s loops carry NO g$State / boxed Iterator /
// `next()` — a flat index loop (see the lower snapshot). The standalone
// `__gen_state_N$next` state machines still emit (the escaping-value fallback),
// dead here since every use is inlined. The lower snapshot is the guard.
module "snippet"

import "std/io"

// map shape.
doubled :: fn(xs: i32[]) -> Iterator<i32> {
    for x in xs { yield x * 2 }
}

// filter shape (yield inside an if).
evens :: fn(xs: i32[]) -> Iterator<i32> {
    for x in xs { if x % 2 == 0 { yield x } }
}

// flatten shape (nested loops, resume mid-inner-loop when boxed — here fully inlined).
flatten :: fn(xss: i32[][]) -> Iterator<i32> {
    for row in xss {
        for x in row { yield x }
    }
}

main :: fn() -> i32 {
    for v in doubled([1, 2, 3]) { println("d ${v}") }
    for v in evens([1, 2, 3, 4, 5, 6]) { println("e ${v}") }
    for v in flatten([[1, 2], [3], [4, 5]]) { println("f ${v}") }
    return 0
}
