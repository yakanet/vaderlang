module "snippet"

import "std/io" { println }
import "std/string" { byte_len, len, decode_codepoint }
import "std/utf8" { codepoint_byte_len }

main :: fn() -> i32 {
    // len vs byte_len: codepoints, not bytes.
    println("ascii  cp=${len("vader")} bytes=${byte_len("vader")}")
    println("mixed  cp=${len("héllo")} bytes=${byte_len("héllo")}")
    println("cjk    cp=${len("你好嗎？")} bytes=${byte_len("你好嗎？")}")
    println("emoji  cp=${len("a\u{1F600}b")} bytes=${byte_len("a\u{1F600}b")}")
    println("empty  cp=${len("")} bytes=${byte_len("")}")

    // decode_codepoint walks one sequence at a time. Manual iteration mimics
    // what `chars()` does internally, demonstrating the [char, i32] return.
    s :: "你好"
    n :: byte_len(s)
    i: usize = 0
    for i < n {
        [c, w] :: decode_codepoint(s, i)
        println("at ${i}: '${c}' (${w} bytes)")
        i = i + w
    }

    // codepoint_byte_len is callable directly when only the width is needed.
    println("'a' width=${codepoint_byte_len('a')}")
    println("'é' width=${codepoint_byte_len('é')}")
    println("'你' width=${codepoint_byte_len('你')}")
    println("emoji width=${codepoint_byte_len('\u{1F600}')}")
    return 0
}
