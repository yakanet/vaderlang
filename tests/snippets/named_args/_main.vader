module "snippet"

// Regression guard: named arguments (#1) and default parameter values (#2),
// full coverage — direct calls + reordering, default fill, overload-by-name,
// and UFCS methods. The typechecker normalises each call's args into parameter
// order in place (filling omitted trailing params from their defaults), so the
// lowerer needs no special handling. `main`'s return value is a checksum that
// only lands on 210 when every form resolves correctly.

greet :: fn(name: string, prefix: string = "Hello") -> string {
    return "${prefix}, ${name}"
}

combine :: fn(a: i32, b: i32, c: i32) -> i32 {
    return a * 100 + b * 10 + c
}

// Overloaded by arity — resolved by the (named) arg count.
pick :: fn(a: i32) -> i32 { return a }
pick :: fn(a: i32, b: i32) -> i32 { return a * 10 + b }

Box :: struct { v: i32 }

// Free fn usable on Box via UFCS (self + named + default).
scale :: fn(self: Box, by: i32, plus: i32 = 0) -> i32 {
    return self.v * by + plus
}

export main :: fn() -> i32 {
    g1 :: greet("Alice")                  // default          → "Hello, Alice" (12)
    g2 :: greet("Eve", prefix = "Hey")    // named            → "Hey, Eve"     (8)
    r :: combine(c = 3, a = 1, b = 2)     // reordered        → 123
    p :: pick(b = 4, a = 5)               // overload-by-name → 54
    b :: Box { .v = 6 }
    u :: b.scale(plus = 1, by = 2)        // UFCS named + default → 6*2 + 1 = 13
    return i32(g1.len() + g2.len()) + r + p + u   // 20 + 123 + 54 + 13 = 210
}
