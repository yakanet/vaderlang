module "snippet"

// Regression guard: named arguments (#1) and default parameter values (#2).
// The typechecker normalises each call's args into parameter order in place,
// filling omitted trailing params from their defaults, so the lowerer needs no
// special handling. `main`'s return value is a checksum that only lands on 150
// when every form below resolves correctly.

greet :: fn(name: string, prefix: string = "Hello") -> string {
    return "${prefix}, ${name}"
}

// Three params, to exercise reordering by name.
combine :: fn(a: i32, b: i32, c: i32) -> i32 {
    return a * 100 + b * 10 + c
}

export main :: fn() -> i32 {
    g1 :: greet("Alice")                  // default     → "Hello, Alice" (12)
    g2 :: greet("Bob", "Hi")              // positional   → "Hi, Bob"      (7)
    g3 :: greet("Eve", prefix = "Hey")    // named        → "Hey, Eve"     (8)
    r :: combine(c = 3, a = 1, b = 2)     // reordered    → 123
    return i32(g1.len() + g2.len() + g3.len()) + r   // 27 + 123 = 150
}
