// Two ANF edge cases: an `await` as the trailing (implicit-return) expression —
// must fold into the completion return — and two awaits in one expression,
// hoisted left-to-right.
module "snippet"

import "std/io"

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

a :: fn() -> Async<i32> = Ready<i32> { .v = 3 }
b :: fn() -> Async<i32> = Ready<i32> { .v = 4 }

// `await a()` is the trailing expression — no `return` keyword.
trailing :: fn() -> Async<i32> {
    await a()
}

// Two awaits in one expression: (3) + (4) * 10 = 43.
combine :: fn() -> Async<i32> {
    return (await a()) + (await b()) * 10
}

drive :: fn(f: Async<i32>) -> i32 {
    r :: f.resume()
    if r is Suspended { return -1 }
    return r
}

main :: fn() -> i32 {
    println("trailing = ${drive(trailing())}")
    println("combine = ${drive(combine())}")
    return 0
}
