module "snippet"

import "std/io"

// Nested tuple destructuring : the outer let binds `pair` (inner tuple)
// to two leaves, and `flag` to the bool slot.
make_record :: fn() -> [[i32, string], bool] {
    return [[7, "seven"], true]
}

main :: fn() -> i32 {
    [[id, label], active] := make_record()
    println("id=${id}")
    println("label=${label}")
    println("active=${active}")
    return 0
}
