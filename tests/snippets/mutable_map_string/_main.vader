module "snippet"

import "std/io" { println }
import "std/collections" { MutableMap, len }

main :: fn() -> i32 {
    m := MutableMap(string, i32) { .buckets = [], .size = 0 }

    m["hello"] = 1
    m["world"] = 2
    m["vader"] = 42
    println("size = ${m.len()}")

    v1 :: m["hello"]
    match v1 {
        is null -> { println("hello: missing") }
        is i32  -> { println("hello = ${v1}") }
    }

    v2 :: m["world"]
    match v2 {
        is null -> { println("world: missing") }
        is i32  -> { println("world = ${v2}") }
    }

    v3 :: m["vader"]
    match v3 {
        is null -> { println("vader: missing") }
        is i32  -> { println("vader = ${v3}") }
    }

    println("has hello? ${"hello" in m}")
    println("has missing? ${"missing" in m}")

    // Update existing key
    m["hello"] = 99
    v1b :: m["hello"]
    match v1b {
        is null -> { println("hello: missing") }
        is i32  -> { println("hello updated = ${v1b}") }
    }

    return 0
}
