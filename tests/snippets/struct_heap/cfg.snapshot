# CFG

## snippet

fn snippet$make(%0: i32, %1: i32) -> Point
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 $struct_2: Point
  bb0:
    %2 = struct_new Point(%0, %1)
    return %2

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $k_1: i32
    %2 $call_2: Point
    %3 p: Point (local p)
    %4 $field_4: i32
    %5 $field_5: i32
    %6 $add_6: i32
  bb0:
    %0 = const int(3) :i32
    %1 = const int(4) :i32
    %2 = call make(%0, %1) :Point
    %3 = move %2
    %4 = field_get %3.x :i32
    %5 = field_get %3.y :i32
    %6 = binop add %4 %5 :i32
    return %6
