module "snippet"

import "std/io" { println }
import "std/string" { as_string, trim, to_upper, to_lower, starts_with, ends_with, split }

main :: fn() -> i32 {
    s := "  Hello, World!  "
    println("${s.bytes().len()}")
    println(s.trim())
    println("hello".to_upper())
    println("VADER".to_lower())
    println("${"foobar".contains("oba")}")
    println("${"foobar".starts_with("foo")}")
    println("${"foobar".ends_with("bar")}")
    println("hello world".bytes()[6..<11].as_string())
    println("${"hello"[1]}")
    println("${"你好嗎？"[0]}")
    println("${"你好嗎？"[1]}")
    println("${"你好嗎？"[3]}")
    parts := "a,b,c".split(",")
    println(parts[0])
    println(parts[1])
    println(parts[2])
    return 0
}
