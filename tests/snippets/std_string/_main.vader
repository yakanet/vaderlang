import "std/io" { println }
import "std/string" { len, trim, to_upper, to_lower, contains, starts_with, ends_with, slice, char_at, split }

main :: fn() -> i32 {
    s := "  Hello, World!  "
    println("${len(s)}")
    println(trim(s))
    println(to_upper("hello"))
    println(to_lower("VADER"))
    println("${contains("foobar", "oba")}")
    println("${starts_with("foobar", "foo")}")
    println("${ends_with("foobar", "bar")}")
    println(slice("hello world", 6, 11))
    println("${char_at("hello", 1)}")
    println("${char_at("你好嗎？", 0)}")
    println("${char_at("你好嗎？", 1)}")
    println("${char_at("你好嗎？", 3)}")
    parts := split("a,b,c", ",")
    println(parts[0])
    println(parts[1])
    println(parts[2])
    return 0
}
