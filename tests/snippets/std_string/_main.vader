import "std/io" { println }
import "std/string" { len, trim, to_upper, to_lower, contains, starts_with, ends_with, slice, char_at, split }

main :: fn() -> i32 {
    s := "  Hello, World!  "
    println("${len(s)}")
    println(s.trim())
    println("hello".to_upper())
    println("VADER".to_lower())
    println("${"foobar".contains("oba")}")
    println("${"foobar".starts_with("foo")}")
    println("${"foobar".ends_with("bar")}")
    println("hello world".slice(6, 11))
    println("${"hello".char_at(1)}")
    println("${"你好嗎？".char_at(0)}")
    println("${"你好嗎？".char_at(1)}")
    println("${"你好嗎？".char_at(3)}")
    parts := "a,b,c".split(",")
    println(parts[0])
    println(parts[1])
    println(parts[2])
    return 0
}
