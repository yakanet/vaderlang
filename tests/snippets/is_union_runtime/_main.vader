// `x is A | B` as a boolean test in expression / `if` position — the
// or-pattern union form. The runtime ORs the per-variant tag checks
// (`emit_type_check` on native, `union_matches` in the VM), so it reports real
// membership rather than always-false. This is the form
// `vader/c_emit/walker.vader::is_cache_safe` relies on ; the retired W0003
// warning used to (wrongly) flag it as "always returns false at runtime".

module "snippet"

import "std/io"

Cat  :: struct { name:  string }
Dog  :: struct { sound: string }
Fish :: struct { fins:  i32 }

// `is Cat | Dog` is true for a Cat or Dog value, false for a Fish.
is_pet :: fn(v: Cat | Dog | Fish) -> bool = v is Cat | Dog

main :: fn() -> i32 {
    println("${is_pet(Cat { .name = "felix" })}")
    println("${is_pet(Dog { .sound = "woof" })}")
    println("${is_pet(Fish { .fins = 4 })}")
    return 0
}
