// lower-desugar-3 regression : a top-level const initialised by a block that
// declares locals and returns a capturing lambda. Closure analysis must visit
// ConstDecl values (not just fn/impl bodies), else the captured cell (`base`)
// is never promoted and the lambda miscompiles (VM `convert on empty stack` /
// native `unreachable in __lambda_1`).
module "snippet"

import "std/io"

make_adder :: {
    base :: 10
    (n: i32) -> base + n
}

main :: fn() -> i32 {
    add :: make_adder
    println("${add(5)}")    // 15
    println("${add(90)}")   // 100
    return 0
}
