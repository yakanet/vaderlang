// Scalar locals (C-emit T1b coverage) — exercises local.set / local.tee,
// the prelude (local + temp declarations), operand materialisation, and
// i32 add / sub / mul. A library (no main) ; verified by C byte-parity
// against the TS emitter.

module "snippet"

// `local.tee` : the increment is teed into `total` and reused.
export tee_reuse :: fn(x: i32) -> i32 {
    total := x + 1
    return total + total
}

// `local.set` + i32 mul / sub : `sum` is materialised, then folded into
// the final expression.
export fold_chain :: fn(a: i32, b: i32) -> i32 {
    sum := a + b
    return sum * 2 - a
}
