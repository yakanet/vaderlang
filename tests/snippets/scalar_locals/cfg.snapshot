# CFG

## snippet

fn snippet$tee_reuse(%0: i32) -> i32
  locals:
    %0 x: i32 (param x)
    %1 $k_1: i32
    %2 $add_2: i32
    %3 total: i32 (local total)
    %4 $add_4: i32
  bb0:
    %1 = const int(1) :i32
    %2 = binop 0 %0 %1 :i32
    %3 = move %2
    %4 = binop 0 %3 %3 :i32
    return %4

fn snippet$fold_chain(%0: i32, %1: i32) -> i32
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 $add_2: i32
    %3 sum: i32 (local sum)
    %4 $k_4: i32
    %5 $mul_5: i32
    %6 $sub_6: i32
  bb0:
    %2 = binop 0 %0 %1 :i32
    %3 = move %2
    %4 = const int(2) :i32
    %5 = binop 2 %3 %4 :i32
    %6 = binop 1 %5 %0 :i32
    return %6
