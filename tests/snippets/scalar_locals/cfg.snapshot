# CFG

## snippet

fn snippet$tee_reuse(%0: i32) -> i32
  locals:
    %0 x: i32 (param x)
    %1 $k_1: i32
    %2 total: i32 (local total)
    %3 $add_4: i32
  bb0:
    %1 = const int(1) :i32
    %2 = binop add %0 %1 :i32
    %3 = binop add %2 %2 :i32
    return %3

fn snippet$fold_chain(%0: i32, %1: i32) -> i32
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 sum: i32 (local sum)
    %3 $k_4: i32
    %4 $mul_5: i32
    %5 $sub_6: i32
  bb0:
    %2 = binop add %0 %1 :i32
    %3 = const int(2) :i32
    %4 = binop mul %2 %3 :i32
    %5 = binop sub %4 %0 :i32
    return %5
