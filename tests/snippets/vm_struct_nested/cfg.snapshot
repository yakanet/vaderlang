# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $struct_1: Inner
    %2 $k_2: i32
    %3 $struct_3: Inner
    %4 o: Outer (local o)
    %5 $field_6: Inner
    %6 $field_7: i32
    %7 $field_8: Inner
    %8 $field_9: i32
    %9 $add_10: i32
  bb0:
    %0 = const int(10) :i32
    %1 = struct_new[stack] Inner(%0)
    %2 = const int(32) :i32
    %3 = struct_new[stack] Inner(%2)
    %4 = struct_new[stack] Outer(%1, %3)
    %5 = field_get %4.lhs :Inner
    %6 = field_get %5.v :i32
    %7 = field_get %4.rhs :Inner
    %8 = field_get %7.v :i32
    %9 = binop add %6 %8 :i32
    return %9
