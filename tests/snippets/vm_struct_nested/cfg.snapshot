# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $struct_1: Inner
    %2 $k_2: i32
    %3 $struct_3: Inner
    %4 $struct_4: Outer
    %5 o: Outer (local o)
    %6 $field_6: Inner
    %7 $field_7: i32
    %8 $field_8: Inner
    %9 $field_9: i32
    %10 $add_10: i32
  bb0:
    %0 = const int(10) :i32
    %1 = struct_new Inner(%0)
    %2 = const int(32) :i32
    %3 = struct_new Inner(%2)
    %4 = struct_new Outer(%1, %3)
    %5 = move %4
    %6 = field_get %5.lhs :Inner
    %7 = field_get %6.v :i32
    %8 = field_get %5.rhs :Inner
    %9 = field_get %8.v :i32
    %10 = binop 0 %7 %9 :i32
