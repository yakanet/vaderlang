// MutableMap and MutableSet operator sugar — Index, IndexSet, Contains.
// `m[k]`, `m[k] = v`, `k in m` dispatch through the trait impls in
// `std/collections` ; no manual `put` / `get` / `contains_key` import needed.

module "snippet"

import "std/io"
import "std/collections"

main :: fn() -> i32 {
    m := MutableMap<string, i32> {}
    m["a"] = 10
    m["b"] = 20
    m["a"] = 99   // overwrite

    // Index read returns `V | null`.
    match m["a"] {
        is i32 as v -> println("a=${v}")
        is null     -> println("a missing")
    }
    match m["c"] {
        is i32  -> println("c found?!")
        is null -> println("c missing")
    }

    // Contains via `in` / `!in`.
    if "a" in m  { println("a in m") }
    if "z" !in m { println("z not in m") }

    // MutableSet — only Contains, no Index/IndexSet.
    s := MutableSet<i32> {}
    s.add(1)
    s.add(2)
    if 1 in s  { println("1 in s") }
    if 3 !in s { println("3 not in s") }

    return 0
}
