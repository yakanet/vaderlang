# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $call_1: i32
    %2 a: i32 (local a)
    %3 $k_3: i32
    %4 $call_4: i32
    %5 b: i32 (local b)
    %6 $k_6: i32
    %7 $call_7: i32
    %8 c: i32 (local c)
    %9 $add_9: i32
    %10 $add_10: i32
  bb0:
    %0 = const int(7) :i32
    %1 = call snippet$snippet$double__i32(%0) :i32
    %2 = move %1
    %3 = const int(8) :i32
    %4 = call snippet$snippet$triple__i32(%3) :i32
    %5 = move %4
    %6 = const int(2) :i32
    %7 = call snippet$snippet$double__i32(%6) :i32
    %8 = move %7
    %9 = binop 0 %2 %5 :i32
    %10 = binop 0 %9 %8 :i32
    return %10

fn snippet$snippet$double__i32(%0: i32) -> i32
  locals:
    %0 x: i32 (param x)
    %1 $call_1: i32
  bb0:
    %1 = call std_core$i32$Add$add(%0, %0) :i32
    return %1

fn snippet$snippet$triple__i32(%0: i32) -> i32
  locals:
    %0 x: i32 (param x)
    %1 $call_1: i32
    %2 $call_2: i32
  bb0:
    %1 = call std_core$i32$Add$add(%0, %0) :i32
    %2 = call std_core$i32$Add$add(%1, %0) :i32
    return %2
