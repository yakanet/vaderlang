module "snippet"

import "std/io" { println }

// Comptime tuple values — the comptime VM materialises a Tuple result
// into a `ComptimeValue.struct` (with synthetic `_0`, `_1`, … field
// names) and the lowerer re-emits it as a `LoweredStructLit` at every
// inline site, just like a regular struct const. Typed top-level const
// uses the Odin-style `name : Type : value` form so the seq-literal
// inference picks Tuple rather than the homogeneous-Array default.

@comptime
DIM : [i32, i32] : [10, 20]

@comptime
ORIGIN : [f64, f64, string] : [0.0, 0.0, "origin"]

main :: fn() -> i32 {
    println("dim ${DIM.0}x${DIM.1}")
    println("origin (${ORIGIN.0}, ${ORIGIN.1}) = ${ORIGIN.2}")
    return DIM.0
}
