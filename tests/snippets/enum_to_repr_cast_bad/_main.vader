// Casting an enum to anything other than its declared repr is rejected.
// The user chains an explicit second cast for widening / narrowing.

export Day :: enum(u8) { Mon, Tue }

export main :: fn() -> i32 {
    x :: i32(Day.Mon)     // T3010 : repr u8, target i32
    y :: f32(Day.Tue)     // T3010 : repr u8, target f32
    z :: char(Day.Mon)    // T3010 : repr u8, target char
    return x
}
