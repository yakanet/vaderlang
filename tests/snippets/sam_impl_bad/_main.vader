// Multi-method trait : la forme courte (arrow ou bloc anonyme) ne s'applique
// pas — il faut décliner toutes les méthodes via la forme classique.

module "snippet"

export TwoFns :: trait {
    first  :: fn(self) -> i32
    second :: fn(self) -> i32
}

i32 implements TwoFns -> 0

i32 implements TwoFns {
    self + 1
}

main :: fn() -> i32 { return 0 }
