// Transitive monomorphisation through nested generic calls.
// Each level passes its type-param down to the next ; the comptime
// InstanceRegistry's worklist must materialise every callee at every
// concrete instantiation reached by the call chain.

module "snippet"

import "std/io"

Box :: struct<T> { value: T }

inner :: fn<T>(x: T) -> T { return x }

middle :: fn<T>(x: T) -> Box<T> {
    return Box<T> { .value = inner(x) }
}

outer :: fn<T>(x: T) -> Box<Box<T>> {
    return Box<Box<T>> { .value = middle(x) }
}

main :: fn() -> i32 {
    a :: outer(42)
    b :: outer("ok")
    println("${a.value.value}")
    println("${b.value.value}")
    return 0
}
