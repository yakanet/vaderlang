# CFG

## snippet

fn snippet$pick(%0: bool) -> null | string
  locals:
    %0 c: bool (param c)
    %1 if_res: null
    %2 x: null (local x)
    %3 $k_5: null
    %4 $eq_6: bool
    %5 $k_7: string
    %6 $k_8: null
  bb0:
    cond_branch %0 ? bb1 : bb2
  bb1:
    %1 = const null :null
    branch -> bb3
  bb2:
    %1 = const null :null
    branch -> bb3
  bb3:
    %2 = move %1
    %3 = const null :null
    %4 = binop eq %2 %3 :bool
    cond_branch %4 ? bb4 : bb5
  bb4:
    %5 = const string(#0) :string
    return %5
  bb5:
    %6 = const null :null
    return %6

fn snippet$main() -> i32
  locals:
    %0 $k_0: bool
    %1 $call_1: null | string
    %2 __scrut_0: null | string (synthetic __scrut_0)
    %3 $type_check_3: bool
    %4 $k_4: string
    %5 $type_check_5: bool
    %6 $k_6: string
    %7 $k_7: i32
  bb0:
    %0 = const bool(true) :bool
    %1 = call pick(%0) :null | string
    %2 = move %1
    %3 = type_check %2 is string
    cond_branch %3 ? bb1 : bb2
  bb1:
    %4 = const string(#1) :string
    call println(%4) :void
    branch -> bb3
  bb2:
    %5 = type_check %2 is null
    cond_branch %5 ? bb4 : bb5
  bb3:
    %7 = const int(0) :i32
    return %7
  bb4:
    %6 = const string(#2) :string
    call println(%6) :void
    branch -> bb6
  bb5:
    unreachable ; non-exhaustive match (T3013 should have caught this)
  bb6:
    branch -> bb3
