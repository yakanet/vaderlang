# CFG

## snippet

fn snippet$classify(%0: i32) -> string
  locals:
    %0 n: i32 (param n)
    %1 $k_1: i32
    %2 $gt_2: bool
    %3 if_res: string
    %4 $k_5: i32
    %5 $lt_6: bool
    %6 if_res: string
  bb0:
    %1 = const int(0) :i32
    %2 = binop gt %0 %1 :bool
    cond_branch %2 ? bb1 : bb2
  bb1:
    %3 = const string(#0) :string
    branch -> bb3
  bb2:
    %4 = const int(0) :i32
    %5 = binop lt %0 %4 :bool
    cond_branch %5 ? bb4 : bb5
  bb3:
    return %3
  bb4:
    %6 = const string(#1) :string
    branch -> bb6
  bb5:
    %6 = const string(#2) :string
    branch -> bb6
  bb6:
    %3 = move %6
    branch -> bb3
