# Lower

## snippet
  fn snippet$classify(n: i32) -> string
    return
      if :string
        cond:
          gt :bool
            l:
              n :i32
            r:
              int(0) :i32
        then:
          ~>
            "positive" :string
        else:
          ~>
            if :string
              cond:
                lt :bool
                  l:
                    n :i32
                  r:
                    int(0) :i32
              then:
                ~>
                  "negative" :string
              else:
                ~>
                  "zero" :string
