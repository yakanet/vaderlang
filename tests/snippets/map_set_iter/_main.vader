import "std/io" { println }
import "std/collections" { MutableMap, MutableSet, iter, add }

main :: fn() -> i32 {
    // MutableMap iter — sum every value, expect 6.
    m := MutableMap(string, i32) { .buckets = [], .size = 0 }
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3
    total := 0
    for entry in m.iter() {
        total = total + entry.value
    }
    println("map_sum=${total}")

    // MutableSet iter — sum every member, expect 60.
    s := MutableSet(i32) { .inner = MutableMap(i32, bool) { .buckets = [], .size = 0 } }
    s.add(10)
    s.add(20)
    s.add(30)
    sum := 0
    for v in s.iter() {
        sum = sum + v
    }
    println("set_sum=${sum}")
    return 0
}
