module "snippet"

import "std/io" { println }
import "std/collections" { MutableMap, MutableSet, add }

main :: fn() -> i32 {
    // MutableMap — `for entry in m` desugars via the Into(Iterator(...))
    // impl on MutableMap. Sum every value, expect 6.
    m := MutableMap<string, i32> {}
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3
    total := 0
    for entry in m {
        total = total + entry.value
    }
    println("map_sum=${total}")

    // MutableSet — same desugar. Sum every member, expect 60.
    s := MutableSet<i32> { .inner = MutableMap<i32, bool> {} }
    s.add(10)
    s.add(20)
    s.add(30)
    sum := 0
    for v in s {
        sum = sum + v
    }
    println("set_sum=${sum}")
    return 0
}
