// std/base64 — RFC 4648 vectors, padding shapes, roundtrip, and the
// two error paths (bad length, bad character).

module "snippet"

import "std/io" { println }
import "std/base64" { encode, decode, Base64Error }

show_decode :: fn(label: string, input: string) -> void {
    out :: decode(input)
    if out is Base64Error {
        println("${label}=ERR:${out.message()}")
    } else {
        println("${label}=${out.bytes_to_string()}")
    }
}

main :: fn() -> i32 {
    // RFC 4648 §10 vectors
    println("enc-f=${encode("f".bytes())}")
    println("enc-fo=${encode("fo".bytes())}")
    println("enc-foo=${encode("foo".bytes())}")
    println("enc-foob=${encode("foob".bytes())}")
    println("enc-fooba=${encode("fooba".bytes())}")
    println("enc-foobar=${encode("foobar".bytes())}")

    show_decode("dec-f",      "Zg==")
    show_decode("dec-fo",     "Zm8=")
    show_decode("dec-foo",    "Zm9v")
    show_decode("dec-foob",   "Zm9vYg==")
    show_decode("dec-fooba",  "Zm9vYmE=")
    show_decode("dec-foobar", "Zm9vYmFy")

    // Roundtrip
    inputs :: ["hello world", "", "a", "ab", "The quick brown fox"]
    for s in inputs {
        decoded :: decode(encode(s.bytes()))
        if decoded is Base64Error {
            println("roundtrip-${s}=ERR")
        } else {
            println("roundtrip-${s}=${decoded.bytes_to_string() == s}")
        }
    }

    // Error paths
    show_decode("bad-length",  "abc")
    show_decode("bad-char",    "ab!d")

    return 0
}
