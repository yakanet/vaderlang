import "std/io" { println }

// A simple countdown iterator: yields n-1, n-2, ..., 0 then null.
export Countdown :: struct {
    current: i32
}

Countdown implements Iterator(i32) {
    next :: fn(self) -> Yield(i32) | null {
        if (self.current <= 0) {
            return null
        }
        v :: self.current
        self.current = self.current - 1
        return Yield(i32) { .value = v }
    }
}

main :: fn() -> i32 {
    it := Countdown { .current = 5 }
    for x in it {
        println("${x}")
    }
    return 0
}
