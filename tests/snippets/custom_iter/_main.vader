import "std/io" { println }

// A simple countdown iterator: yields n-1, n-2, ..., 0 then Done.
Countdown :: struct {
    current: i32
}

Countdown implements Iterator(i32) {
    fn step(self) -> Done | Yielded(i32) {
        if (self.current <= 0) {
            return Done {}
        }
        v :: self.current
        self.current = self.current - 1
        return Yielded(i32) { .value = v }
    }
}

main :: fn() -> i32 {
    it := Countdown { .current = 5 }
    for x in it {
        println("${x}")
    }
    return 0
}
