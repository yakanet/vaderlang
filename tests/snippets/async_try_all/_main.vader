// `try_all(xs)`: concurrent join of FALLIBLE awaitables. Like `all`, every child
// runs (no cancellation in v1) — but the result is scanned in INPUT order for
// the first error. Here the "orders" service (index 1) is down, so `try_all`
// surfaces that error even though the others succeeded. The second join, where
// every fetch succeeds, comes back as the boxed `(i32 | Outage)[]` in input order.
module "snippet"

import "std/io"
import "std/async"

Outage :: struct { service: string }
Outage implements Error { message :: fn(self) -> string = "down: ${self.service}" }

fetch :: fn(service: string, ms: i64, up: bool) -> Async<i32 | Outage> {
    await sleep(ms)
    if !up { return Outage { .service = service } }
    return i32(ms) * 100
}

main :: fn() -> i32 {
    // one child fails → the first error, by input order, wins.
    bad :: await try_all<i32, Outage>([
        fetch("users", 3, true),
        fetch("orders", 1, false),
        fetch("carts", 2, true),
    ])
    if bad is Error as e { println("failed: ${e.message()}") }

    // every child succeeds → results in input order.
    good :: await try_all<i32, Outage>([fetch("users", 3, true), fetch("orders", 1, true)])
    if good is Error as e {
        println("unexpected: ${e.message()}")
    } else {
        for v in good {
            if v is Outage { println("?") } else { println("ok ${v}") }
        }
    }
    return 0
}
