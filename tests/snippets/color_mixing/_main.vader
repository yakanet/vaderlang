// tests/snippets/color_mixing — distinct newtypes over a struct and a tuple.
//
// A distinct newtype can wrap a COMPOSITE backing (a struct or a tuple), not
// just a primitive. It stays nominal — carrying its own trait impls (operator
// overloads) — while the STRUCTURAL ops forward to the backing:
//   - struct-backed  (`Color :: Rgb`)     : `Color { … }` construction, `c.r`
//     field access, and a nominal `Add` impl that blends two colors.
//   - tuple-backed   (`Coord :: [i32, i32]`) : `[x, y]` literal, `p.0` / `p.1`
//     positional access, `[x, y] :: p` destructure.
//
// Expected: prints "100 0 100", "3 4", "7".

module "snippet"

import "std/io"

// ---- struct-backed newtype ------------------------------------------------

Rgb :: struct {
    r: i32
    g: i32
    b: i32
}

// `Color` is a distinct newtype over `Rgb` : it forwards field access to the
// backing struct but owns its own `+` (channel-wise average → a blend).
Color :: Rgb

Color implements Add<Color, Color> {
    add :: fn(self, other: Color) -> Color = Color {
        .r = (self.r + other.r) / 2,
        .g = (self.g + other.g) / 2,
        .b = (self.b + other.b) / 2,
    }
}

// ---- tuple-backed newtype -------------------------------------------------

// `Coord` is a distinct newtype over the tuple `[i32, i32]` — a screen pixel
// position. Positional access and destructure forward to the backing tuple.
Coord :: [i32, i32]

// Composition : a tuple-alias element may itself be a newtype (`Color`). The
// alias predicate recognises `Color` as a type through `alias_types`, not just
// its `SymbolKind`.
Swatch :: [Color, i32]

main :: fn() -> i32 {
    red  :: Color { .r = 200, .g = 0, .b = 0 }
    blue :: Color { .r = 0, .g = 0, .b = 200 }
    mixed :: red + blue                       // Color::add → channel-wise blend
    println("${mixed.r} ${mixed.g} ${mixed.b}")   // 100 0 100

    p: Coord = [3, 4]
    println("${p.0} ${p.1}")                  // 3 4
    [x, y] :: p                               // tuple-backed destructure
    println("${x + y}")                       // 7

    s: Swatch = [red, 5]                      // newtype nested in a tuple-alias
    println("${s.0.r} x${s.1}")               // 200 x5
    return 0
}
