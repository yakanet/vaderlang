// Trait method with two args (Self + other) — checks the substitution flows
// to BOTH params, not just the receiver. Hand-rolled equality check via the
// `Eq` trait method on a TypeParam-typed pair.

both_equal :: fn(a: $T, b: T, c: T) -> i32 where T: Eq {
    n := 0
    if a.equals(b) {
        n = n + 1
    }
    if a.equals(c) {
        n = n + 10
    }
    if b.equals(c) {
        n = n + 100
    }
    return n
}

main :: fn() -> i32 {
    // 1 == 1 (n=1), 1 != 2, 1 != 2  →  1
    n1 := both_equal(1, 1, 2)
    // 5 == 5 (n=1), 5 == 5 (n=10), 5 == 5 (n=100)  →  111
    n2 := both_equal(5, 5, 5)
    // 100 != 200, 100 == 100 (n=10), 200 != 100  →  10
    n3 := both_equal(100, 200, 100)
    return n1 + n2 + n3
}
