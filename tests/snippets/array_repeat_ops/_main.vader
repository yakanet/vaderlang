// tests/snippets/array_repeat_ops — array construction + bulk-mutation ops.
//
// Exercises the five new array primitives end to end (typer + lowering →
// `array.repeat` / `array.push_all` / `array.copy` / `array.remove_last` /
// `array.clear` ops → C runtime + VM):
//   - `[v] * n`  fill, `[a, b] * n` multi-element repeat
//   - `[] * n`   reserve (length 0, capacity n) then push
//   - `push_all` bulk append
//   - `copy_to`  positional overwrite, including an overlapping same-array copy
//   - `remove_last` on a non-empty and an empty array (`T | null`)
//   - `clear`    then reuse
//
// Each independent check adds 1 to `pass` ; the exit code is the number of
// checks that held (12 when everything works). A pass-count keeps the result a
// stable u8 and pinpoints which group regressed.

module "snippet"

main :: fn() -> i32 {
    pass: i32 = 0

    // `[v] * n` — fill.
    zeros := [0] * 3
    if zeros.len() == 3 && zeros[0] == 0 && zeros[2] == 0 { pass = pass + 1 }

    ones := [1] * 4
    if ones.len() == 4 && ones[0] == 1 && ones[3] == 1 { pass = pass + 1 }

    // `[a, b] * n` — multi-element repeat → [7, 9, 7, 9].
    ab := [7, 9] * 2
    if ab.len() == 4 && ab[0] == 7 && ab[1] == 9 && ab[2] == 7 && ab[3] == 9 { pass = pass + 1 }

    // `[] * n` — reserve n slots, length 0 (the preallocation case).
    buf: i32[] = [] * 8
    if buf.len() == 0 { pass = pass + 1 }
    for i in 0..<5 { buf.push(i) }
    if buf.len() == 5 && buf[0] == 0 && buf[4] == 4 { pass = pass + 1 }

    // `push_all` — bulk append.
    a := [1, 2, 3]
    extra := [4, 5]
    a.push_all(extra)
    if a.len() == 5 && a[2] == 3 && a[3] == 4 && a[4] == 5 { pass = pass + 1 }

    // `push_all` of an array onto itself (aliased src == dst doubles).
    dup := [8, 9]
    dup.push_all(dup)
    if dup.len() == 4 && dup[0] == 8 && dup[1] == 9 && dup[2] == 8 && dup[3] == 9 { pass = pass + 1 }

    // `copy_to` — positional overwrite into an existing region.
    dst := [0] * 5
    src := [11, 22, 33]
    src.copy_to(0, dst, 1, 3)
    if dst[0] == 0 && dst[1] == 11 && dst[2] == 22 && dst[3] == 33 && dst[4] == 0 { pass = pass + 1 }

    // `copy_to` overlapping the same array (shift [0..3) right into [1..4)).
    ov := [1, 2, 3, 4]
    ov.copy_to(0, ov, 1, 3)
    if ov[0] == 1 && ov[1] == 1 && ov[2] == 2 && ov[3] == 3 { pass = pass + 1 }

    // `remove_last` — non-empty returns the element, shrinks the array.
    st := [100, 200]
    last :: st.remove_last()
    if last != null && last == 200 && st.len() == 1 && st[0] == 100 { pass = pass + 1 }

    // `remove_last` — empty returns null.
    drained: i32[] = []
    gone :: drained.remove_last()
    if gone == null { pass = pass + 1 }

    // `clear` then reuse.
    c := [1, 2, 3, 4]
    c.clear()
    c.push(42)
    if c.len() == 1 && c[0] == 42 { pass = pass + 1 }

    return pass
}
