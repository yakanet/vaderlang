// Angle-bracket generic declarations : type-param heads `fn<T>` / `struct<T>`,
// the only accepted form (SPEC §"Type parameters" — no bracket or paren form).

// Generic fn
module "snippet"

identity :: fn<T>(x: T) -> T = x

// Generic fn, multiple type-params
swap :: fn<A, B>(a: A, b: B) -> B = b

// Generic struct
Pair :: struct<A, B> {
    first: A
    second: B
}

main :: fn() -> i32 {
    a :: identity(10)
    b :: swap(1, 2)
    p := Pair<i32, i32> { .first = 30, .second = 0 }
    return a + b + p.first
}
