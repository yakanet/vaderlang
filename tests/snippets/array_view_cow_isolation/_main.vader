// A7 — mutation of a view never leaks to its parent. The runtime's
// `vader_array_t` representation shares the backing buffer when an
// array is sliced (zero-copy view), but a write through the view
// triggers Copy-on-Write : the view's `buf` is detached into a fresh
// allocation before the store. The parent's slot remains untouched.
//
// VM TS + Vader VM already implemented this via array.slice's copy
// semantics. The C runtime had Go-style aliasing until the A7 fix on
// `vader_array_set` ; this snippet exercises both ends so the three
// targets agree on the no-aliasing contract.

module "snippet"

import "std/io" { println }

main :: fn() -> i32 {
    arr := [10, 20, 30, 40, 50]
    view := arr[1..<4]               // view = [20, 30, 40]
    view[1] = 99                     // detaches ; arr stays [10, 20, 30, 40, 50]

    println("arr[0]=${arr[0]}")
    println("arr[1]=${arr[1]}")
    println("arr[2]=${arr[2]}")
    println("arr[3]=${arr[3]}")
    println("arr[4]=${arr[4]}")
    println("view[0]=${view[0]}")
    println("view[1]=${view[1]}")
    println("view[2]=${view[2]}")
    return 0
}
