// Two awaits of DIFFERENT types (i32 then string) in one coroutine, plus the
// resume-after-done contract. No `@async`: async-ness is inferred from `await`,
// typed via the `Async<T>` return.
module "snippet"

import "std/io" { println }

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

make_num :: fn() -> Async<i32> = Ready<i32> { .v = 7 }
make_str :: fn() -> Async<string> = Ready<string> { .v = "hi" }

mix :: fn() -> Async<string> {
    n :: await make_num()
    s :: await make_str()
    return "${s}:${n}"
}

main :: fn() -> i32 {
    frame :: mix()
    r :: frame.resume()
    if r is Suspended { println("parked?!") return 1 }
    println("mix = ${r}")
    again :: frame.resume()
    if again is Suspended { println("after-done = Suspended") } else { println("after-done = ${again}") }
    return 0
}
