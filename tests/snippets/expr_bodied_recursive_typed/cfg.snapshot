# CFG

## snippet

fn snippet$fact(%0: i32) -> i32
  locals:
    %0 n: i32 (param n)
    %1 $k_1: i32
    %2 $lte_2: bool
    %3 if_res: i32
    %4 $k_5: i32
    %5 $sub_6: i32
    %6 $call_7: i32
  bb0:
    %1 = const int(1) :i32
    %2 = binop lte %0 %1 :bool
    cond_branch %2 ? bb1 : bb2
  bb1:
    %3 = const int(1) :i32
    branch -> bb3
  bb2:
    %4 = const int(1) :i32
    %5 = binop sub %0 %4 :i32
    %6 = call fact(%5) :i32
    %3 = binop mul %0 %6 :i32
    branch -> bb3
  bb3:
    return %3

fn snippet$fib(%0: i32) -> i32
  locals:
    %0 n: i32 (param n)
    %1 $k_1: i32
    %2 $lt_2: bool
    %3 if_res: i32
    %4 $k_4: i32
    %5 $sub_5: i32
    %6 $call_6: i32
    %7 $k_7: i32
    %8 $sub_8: i32
    %9 $call_9: i32
  bb0:
    %1 = const int(2) :i32
    %2 = binop lt %0 %1 :bool
    cond_branch %2 ? bb1 : bb2
  bb1:
    %3 = move %0
    branch -> bb3
  bb2:
    %4 = const int(1) :i32
    %5 = binop sub %0 %4 :i32
    %6 = call fib(%5) :i32
    %7 = const int(2) :i32
    %8 = binop sub %0 %7 :i32
    %9 = call fib(%8) :i32
    %3 = binop add %6 %9 :i32
    branch -> bb3
  bb3:
    return %3

fn snippet$main() -> i32
  locals:
    %0 $intrinsic_0: ?
    %1 __sb_0: ? (synthetic __sb_0)
    %2 $k_2: string
    %3 $k_3: i32
    %4 $call_4: i32
    %5 $k_5: string
    %6 $k_6: i32
    %7 $call_7: i32
    %8 $intrinsic_8: string
    %9 $k_9: i32
  bb0:
    %0 = intrinsic builder.new()
    %1 = move %0
    %2 = const string(#0) :string
    intrinsic builder.append_str(%1, %2)
    %3 = const int(5) :i32
    %4 = call fact(%3) :i32
    intrinsic builder.append_display(%1, %4)
    %5 = const string(#1) :string
    intrinsic builder.append_str(%1, %5)
    %6 = const int(10) :i32
    %7 = call fib(%6) :i32
    intrinsic builder.append_display(%1, %7)
    %8 = intrinsic builder.finish(%1)
    call println(%8) :void
    %9 = const int(0) :i32
    return %9
