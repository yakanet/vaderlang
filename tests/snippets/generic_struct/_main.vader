import "std/io" { println }

export Stack :: struct($T) {
    data: T[]
    size: i32
}

export Stackable :: trait($T) {
    fn push(self, value: T) -> void
    fn pop(self) -> T
    fn len(self) -> i32
    fn is_empty(self) -> bool
}

Stack($T) implements Stackable(T) {
    fn push(self, value: T) -> void {
        self.data.push(value)
        self.size = self.size + 1
    }
    fn pop(self) -> T {
        self.size = self.size - 1
        return self.data[self.size]
    }
    fn len(self) -> i32 {
        return self.size
    }
    fn is_empty(self) -> bool {
        return self.size == 0
    }
}

main :: fn() -> i32 {
    s := Stack(i32) { .data = [], .size = 0 }
    s.push(10)
    s.push(20)
    s.push(30)
    println("len = ${s.len()}")
    println("pop = ${s.pop()}")
    println("len = ${s.len()}")
    return 0
}
