module "snippet"

import "std/io" { println }

export Stack :: struct<T> {
    data: T[]
    size: i32
}

export Stackable :: trait<T> {
    push     :: fn(self, value: T) -> void
    pop      :: fn(self) -> T
    len      :: fn(self) -> i32
    is_empty :: fn(self) -> bool
}

Stack<T> implements Stackable<T> {
    push :: fn(self, value: T) -> void {
        self.data.push(value)
        self.size = self.size + 1
    }
    pop :: fn(self) -> T {
        self.size = self.size - 1
        return self.data[self.size]
    }
    len :: fn(self) -> i32 {
        return self.size
    }
    is_empty :: fn(self) -> bool {
        return self.size == 0
    }
}

main :: fn() -> i32 {
    s := Stack<i32> { .data = [], .size = 0 }
    s.push(10)
    s.push(20)
    s.push(30)
    println("len = ${s.len()}")
    println("pop = ${s.pop()}")
    println("len = ${s.len()}")
    return 0
}
