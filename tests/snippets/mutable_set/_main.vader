module "snippet"

import "std/io"
import "std/collections"

main :: fn() -> i32 {
    s := MutableSet<i32> {}
    println("new? ${s.add(10)}")
    println("new? ${s.add(20)}")
    println("new? ${s.add(10)}")  // duplicate
    println("len = ${s.len()}")
    println("has 10? ${10 in s}")
    println("has 30? ${30 in s}")
    return 0
}
