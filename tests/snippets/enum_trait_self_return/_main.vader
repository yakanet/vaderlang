// Trait method returning `Self`, implemented by an enum, with an
// expression-bodied impl method that needs the trait's return type
// (Self → forType, here Direction) propagated as the body's expected type
// so the dot-shorthand arms (`.West`, `.South`, ...) can resolve.

import "std/io" { println }

Direction :: enum { North, East, South, West }

Turnable :: trait {
    turn_left  :: fn(self) -> Self
    turn_right :: fn(self) -> Self
}

Direction implements Turnable {
    turn_left :: fn(self) = match self {
        .North -> .West
        .West  -> .South
        .South -> .East
        .East  -> .North
    }

    turn_right :: fn(self) = match self {
        .North -> .East
        .East  -> .South
        .South -> .West
        .West  -> .North
    }
}

Direction implements Display {
    to_string :: fn(self) = match self {
        .North -> "N"
        .East  -> "E"
        .South -> "S"
        .West  -> "W"
    }
}

main :: fn() -> i32 {
    d :: Direction.North
    println(d.to_string())
    println(d.turn_left().to_string())
    println(d.turn_right().to_string())
    return 0
}
