# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 $k_1: i32
    %2 p: Point (local p)
    %3 $field_4: i32
    %4 $k_5: i32
    %5 $add_6: i32
    %6 $field_7: i32
    %7 $field_8: i32
    %8 $add_9: i32
  bb0:
    %0 = const int(3) :i32
    %1 = const int(4) :i32
    %2 = struct_new[stack] Point(%0, %1)
    %3 = field_get %2.x :i32
    %4 = const int(10) :i32
