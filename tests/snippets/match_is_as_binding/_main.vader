module "snippet"

import "std/io" { println }

// Regression: `is T as p` in a match arm used to make `p` a fresh synthetic
// symbol unrelated to the resolver's binding symbol — the body's `p.x` would
// fail to find a slot and lower to `unreachable`. Now the resolver records
// the binding in `patternBindings`, the lowerer reuses it, and the
// type-checker narrows the binding to the variant type.
P :: struct { x: i32 }
Q :: struct { y: string }

show :: fn(a: P | Q | null) -> string {
    return match a {
        is null -> "null"
        is P as p -> "P.x = ${p.x}"
        is Q as q -> "Q.y = ${q.y}"
    }
}

main :: fn() -> i32 {
    println(show(P { .x = 42 }))
    println(show(Q { .y = "hello" }))
    println(show(null))
    return 0
}
