// `!is` operator — syntactic sugar that parses to `Not(BinaryExpr.Is)`.
// The narrower already flips then/else on a `Not` wrapper, so flow-narrowing
// works the same as the longer `!(x is T)` form. Tested across:
//   - struct union narrowing in the then-branch (else sees the complement)
//   - primitive union narrowing
//   - `!is null` against a `T | null`
//   - `!is` used in a plain boolean position (no narrowing required)

module "snippet"

import "std/io"

Cat :: struct { name: string }
Dog :: struct { sound: string }
@allow_unused
Pig :: struct { weight: i32 }

// Direct `!is` flipping the then/else split.
describe :: fn(p: Cat | Dog) -> string {
    if p !is Cat {
        return "dog says ${p.sound}"
    }
    return "cat ${p.name}"
}

// Primitive union narrowed via `!is`.
stringify :: fn(v: i32 | string) -> string {
    if v !is string {
        return "int ${v}"
    }
    return "str ${v}"
}

// `T | null` checked with `!is null` — narrows away the null variant.
unwrap_or :: fn(value: Cat | null, fallback: string) -> string {
    if value !is null {
        return "cat ${value.name}"
    }
    return fallback
}

// `!is` as a plain boolean — narrowing isn't required here, just the
// `bool` typing of the negated check.
is_not_dog :: fn(p: Cat | Dog) -> bool {
    return p !is Dog
}

main :: fn() -> i32 {
    println(describe(Cat { .name = "felix" }))
    println(describe(Dog { .sound = "woof" }))
    println(stringify(42))
    println(stringify("hello"))
    println(unwrap_or(Cat { .name = "garfield" }, "nothing"))
    println(unwrap_or(null, "nothing"))
    cat :: Cat { .name = "felix" }
    dog :: Dog { .sound = "woof" }
    if is_not_dog(cat) { println("cat is not a dog") }
    if is_not_dog(dog) { println("dog is dog (should not print)") }
    return 0
}
