module "snippet"

import "std/io"

// Two lambda arguments where the SECOND one is what binds `T`. The deferred
// lambda pass used to run once, in source order, so the first lambda was
// checked while `T` was still unbound: its `[]` typed erased, and the call was
// keyed on a dangling `T` (GATE B1 panic). The pass runs to a fixpoint now, and
// unification refuses the two bindings that say nothing — `T := ?` and the
// self-referential `T := T` — so the round that follows can still learn the
// real one.
zip_with :: fn<T>(make: fn() -> T[], probe: fn(T) -> usize) -> usize {
    rows :: make()
    total: usize = 0
    for r in rows {
        total += probe(r)
    }
    return total
}

main :: fn() -> i32 {
    // The first lambda carries no element type; only the second binds `T`.
    empty :: zip_with(() -> [], (s: string) -> s.len())

    // Same shape with elements, so the result also proves the binding is right.
    filled_in :: zip_with(() -> ["ab", "cde"], (s: string) -> s.len())

    println("empty=${empty} filled=${filled_in}")
    return 0
}
