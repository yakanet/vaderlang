module "snippet"

import "std/io"

main :: fn() -> i32 {
    path :: "${temp_dir()}/vader_io_roundtrip.txt"

    // Ignore the null | Error result — the side effect (file written) is what we test.
    write_file_string(path, "hello from vader")

    println("exists: ${exists(path)}")

    contents :: read_file_string(path)
    match contents {
        is string -> println("read: ${contents}")
        is Error  -> println("read failed")
    }

    return 0
}
