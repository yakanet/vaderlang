// Tests that `match val { is Trait -> … }` correctly dispatches on user structs
// that implement a trait (via `T implements Trait { … }`), including generic
// monomorphised structs.  This exercises the VM impl-table path.

Printable :: trait {
    fn label(self) -> string
}

Dog :: struct {
    name: string
}

Cat :: struct {
    name: string
}

// Dog implements Printable; Cat does not.
Dog implements Printable {
    fn label(self) -> string { return self.name }
}

// Generic struct whose monomorphisation also implements the trait.
Wrapper :: struct($T) {
    inner: $T
}

Wrapper(i32) implements Printable {
    fn label(self) -> string { return "wrapped" }
}

describe :: fn(items: Dog | Cat) -> i32 {
    match items {
        is Printable -> 1
        _ -> 0
    }
}

describe_wrapper :: fn(w: Wrapper(i32) | Cat) -> i32 {
    match w {
        is Printable -> 1
        _ -> 0
    }
}

main :: fn() -> i32 {
    d := Dog { .name = "Rex" }
    c := Cat { .name = "Whiskers" }
    w := Wrapper(i32) { .inner = 42 }

    dog_result := describe(d)       // Dog implements Printable → 1
    cat_result := describe(c)       // Cat does not → 0

    wc: Wrapper(i32) | Cat = w
    wrap_result := describe_wrapper(wc)  // Wrapper(i32) implements Printable → 1

    cc: Wrapper(i32) | Cat = c
    cat_wrap_result := describe_wrapper(cc)  // Cat does not → 0

    // 1 + 0 + 1 + 0 = 2, but encode distinctly: 1*1 + 0*2 + 1*4 + 0*8 = 5
    return dog_result + cat_result * 2 + wrap_result * 4 + cat_wrap_result * 8
}
