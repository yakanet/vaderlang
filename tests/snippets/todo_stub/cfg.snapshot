# CFG

## snippet

fn snippet$run_mode(%0: string) -> void
  locals:
    %0 mode: string (param mode)
    %1 $k_1: string
    %2 $eq_2: bool
    %3 $k_3: string
    %4 $intrinsic_4: ?
    %5 __sb_0: ? (synthetic __sb_0)
    %6 $k_6: string
    %7 $intrinsic_7: string
  bb0:
    %1 = const string(#0) :string
    %2 = binop eq %0 %1 :bool
    cond_branch %2 ? bb1 : bb2
  bb1:
    %3 = const string(#1) :string
    call println(%3) :void
    return
  bb2:
    %4 = intrinsic builder.new()
    %5 = move %4
    intrinsic builder.append_display(%5, %0)
    %6 = const string(#2) :string
    intrinsic builder.append_str(%5, %6)
    %7 = intrinsic builder.finish(%5)
    call todo(%7) :void
    return

fn snippet$main() -> i32
  locals:
    %0 $k_0: string
    %1 $k_1: i32
  bb0:
    %0 = const string(#0) :string
    call run_mode(%0) :void
    %1 = const int(0) :i32
    return %1
