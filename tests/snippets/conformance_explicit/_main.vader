// Layer 8c — explicit conformance, no structural inference. A struct
// with a method matching a trait's signature does NOT satisfy the
// trait without an explicit `implements` line. T3006 fires at the
// generic call site.

module "snippet"

Vec3 :: struct { x: i32, y: i32, z: i32 }

// Vec3 has an `add` method (UFCS-callable free fn) but NO
// `Vec3 implements Add` line — should not satisfy the `Add` bound.
add :: fn(self: Vec3, other: Vec3) -> Vec3 {
    return Vec3 { .x = self.x + other.x, .y = self.y + other.y, .z = self.z + other.z }
}

double :: fn<T: Add>(x: T) -> T {
    return x.add(x)
}

main :: fn() -> i32 {
    v :: Vec3 { .x = 1, .y = 2, .z = 3 }
    d :: double(v)
    return 0
}
