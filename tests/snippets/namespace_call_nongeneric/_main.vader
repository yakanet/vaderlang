module "snippet"

str :: import "std/string"
import "std/io" { println }

// `str.trim(...)` is a namespaced call to a NON-generic stdlib fn. The lowerer
// must resolve the member to its real symbol (not a bare id=0 placeholder) and
// harvest it, else emit can't reserve the callee. Guards the namespaced free-fn
// resolution fix in lower_expr.vader::resolve_namespace_member.
main :: fn() -> i32 {
    println(str.trim("  hi  "))
    return 0
}
