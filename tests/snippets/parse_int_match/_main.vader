module "snippet"

import "std/io"
import "std/string"

// Regression: parse_int / parse_float used to box their success with the
// `string` type's BcType index, so `match r { is i32 -> ... }` would never
// fire on the native target. They now use the correct primitive type tag
// via `primTagOrTrap`.
main :: fn() -> i32 {
    match parse_int("42") {
        is i32 -> println("int ok")
        is ParseError -> println("int err")
    }
    match parse_int("nope") {
        is i32 -> println("int ok")
        is ParseError -> println("int err")
    }
    match parse_float("3.14") {
        is f64 -> println("float ok")
        is ParseError -> println("float err")
    }
    match parse_float("nope") {
        is f64 -> println("float ok")
        is ParseError -> println("float err")
    }
    return 0
}
