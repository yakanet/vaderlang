export Point :: struct {
    x: f64
    y: f64
}

export List :: struct[T] {
    items: T[]
    len: u32
}

// `($N: i32)` is a comptime *value* parameter (not a type) — kept in
// the legacy paren form for now ; bracketed comptime-value params are
// post-MVP.
export Buffer :: struct($N: i32) {
    data: u8[]
}
