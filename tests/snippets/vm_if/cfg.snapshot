# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 n: i32 (local n)
    %1 $k_2: i32
    %2 $gt_3: bool
    %3 $k_4: i32
    %4 $k_5: i32
  bb0:
    %0 = const int(5) :i32
    %1 = const int(3) :i32
    %2 = binop gt %0 %1 :bool
    cond_branch %2 ? bb1 : bb2
  bb1:
    %3 = const int(1) :i32
    return %3
  bb2:
    %4 = const int(0) :i32
    return %4
