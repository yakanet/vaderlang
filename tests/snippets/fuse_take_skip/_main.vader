// `take(n)` / `skip(n)` fuse into the flat loop (Couche 2): a pre-loop counter
// + a `break`/`continue` guard, no TakeIterator/SkipIterator struct, no next().
// The lower snapshot is the regression guard (0 iterator structs).
module "snippet"

import "std/io" { println }
import "std/iter" { take, skip }

main :: fn() -> i32 {
    for v in [10, 20, 30, 40, 50].take(3) { println("t ${v}") }
    for v in [10, 20, 30, 40, 50].skip(2) { println("s ${v}") }
    for v in [10, 20, 30, 40, 50].skip(1).take(2) { println("st ${v}") }
    return 0
}
