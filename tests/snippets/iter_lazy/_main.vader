module "snippet"

import "std/io" { println }
import "std/iter" { MappedIterator, FilterIterator, TakeIterator, SkipIterator }

main :: fn() -> i32 {
    // Lazy map : square 0..<5 → 0, 1, 4, 9, 16. Sum via for-in.
    sq :: fn(x: i32) -> i32 { return x * x }
    mi := MappedIterator<i32, i32> { .source = 0..<5, .f = sq }
    total := 0
    for v in mi {
        total = total + v
    }
    println("map_sum=${total}")

    // Lazy filter : keep evens of 0..<10 → 0, 2, 4, 6, 8.
    is_even :: fn(x: i32) -> bool { return x % 2 == 0 }
    fi := FilterIterator<i32> { .source = 0..<10, .pred = is_even }
    even_count := 0
    even_sum := 0
    for v in fi {
        even_count = even_count + 1
        even_sum = even_sum + v
    }
    println("evens count=${even_count} sum=${even_sum}")

    // Lazy take : first 3 of 0..<100 → 0, 1, 2.
    ti := TakeIterator<i32> { .source = 0..<100, .remaining = usize(3) }
    take_sum := 0
    for v in ti {
        take_sum = take_sum + v
    }
    println("take_sum=${take_sum}")

    // Lazy skip : skip 7 of 0..<10 → 7, 8, 9.
    si := SkipIterator<i32> { .source = 0..<10, .remaining = usize(7) }
    skip_count := 0
    skip_first := -1
    for v in si {
        if skip_first < 0 { skip_first = v }
        skip_count = skip_count + 1
    }
    println("skip count=${skip_count} first=${skip_first}")

    return 0
}
