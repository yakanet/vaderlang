# CFG

## snippet

fn snippet$main() -> i32
  locals:
    %0 $k_0: i32
    %1 a: i32 (local a)
    %2 $k_2: i32
    %3 b: i32 (local b)
    %4 $mul_4: i32
    %5 $k_5: i32
    %6 $add_6: i32
    %7 $k_7: i32
    %8 $sub_8: i32
  bb0:
    %0 = const int(7) :i32
    %1 = move %0
    %2 = const int(5) :i32
    %3 = move %2
    %4 = binop 2 %1 %3 :i32
    %5 = const int(3) :i32
    %6 = binop 0 %4 %5 :i32
    %7 = const int(2) :i32
    %8 = binop 1 %6 %7 :i32
    return %8
