// `await` in a conditional branch — the flow-sensitive ANF hoists it INTO the
// taken branch. The false branch takes no await.
module "snippet"

import "std/io" { println }

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

fetch :: fn() -> Async<i32> = Ready<i32> { .v = 7 }

pick :: fn(flag: bool) -> Async<i32> {
    r: i32 = 0
    if flag {
        r = await fetch()
    } else {
        r = 100
    }
    return r + 1
}

drive :: fn(f: Async<i32>) -> i32 {
    r :: f.resume()
    if r is Suspended { return -1 }
    return r
}

main :: fn() -> i32 {
    println("true -> ${drive(pick(true))}")
    println("false -> ${drive(pick(false))}")
    return 0
}
