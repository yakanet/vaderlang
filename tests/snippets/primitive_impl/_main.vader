module "snippet"

import "std/io"

// A user-defined trait implemented on a primitive type. Re-impl'ing a
// prelude trait (`Display`, `Hash`, …) on `i32` is a coherence error
// (R2030 — see `vader/typecheck/orchestrate.vader::check_impl_coherence`),
// so this exercises impl-on-primitive through the snippet's own trait.
Describe :: trait {
    describe :: fn(self) -> string
}

i32 implements Describe {
    describe :: fn(self) -> string {
        return "the answer is ${self}"
    }
}

main :: fn() -> i32 {
    x: i32 = 42
    println(x.describe())
    return 0
}
