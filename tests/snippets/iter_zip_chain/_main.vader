module "snippet"

import "std/io" { println }
import "std/iter" { zip, chain, enumerate, flat_map }

main :: fn() -> i32 {
    // count + collect on arrays — eager forms, no laziness yet.
    nums :: [10, 20, 30]
    println("count=${nums.len()}")
    cloned :: nums.clone()
    println("clone[0]=${cloned[0]}")

    // zip — parallel arrays paired into tuples, stops at shorter length.
    keys :: ["a", "b", "c", "d"]
    vals :: [1, 2, 3]
    for [k, v] in zip(keys, vals) {
        println("${k}=${v}")
    }

    // chain — concatenate two streams, consumed directly (fuses to two loops).
    head :: [1, 2, 3]
    tail :: [4, 5]
    for x in chain(head, tail) {
        println("j=${x}")
    }

    // enumerate — index + value pairs.
    fruits :: ["apple", "banana", "cherry"]
    for [i, f] in fruits.enumerate() {
        println("${i}: ${f}")
    }

    // flat_map — each input expands to a sub-array.
    bursts :: flat_map([1, 2, 3], (x: i32) -> [x, x * 10])
    for n in bursts {
        println("b=${n}")
    }

    return 0
}
