// `std/process.spawn` invokes an external program synchronously, returning
// exit status + captured stdout/stderr in a `ProcessResult`. Used by the
// self-host build pipeline to drive `cc` from inside a Vader compiler.

module "snippet"

import "std/io" { println }
import "std/process" { spawn, ProcessResult, ProcessError }

main :: fn() -> i32 {
    r :: spawn(["/bin/echo", "ok"])
    match r {
        is ProcessResult -> {
            println("exit=${r.exit}")
            println("out=${r.stdout}")
        }
        is ProcessError -> println("err: ${r.message()}")
    }
    return 0
}
