module "snippet"

import "std/io" { println }
import "std/string_builder" { StringBuilder, append, append_char }

main :: fn() -> i32 {
    // Basic usage via StringBuilder {}
    sb := StringBuilder {}
    sb.append("Hello")
    sb.append(", ")
    sb.append("World")
    sb.append_char('!')
    println(sb.to_string())

    // Build from parts
    sb2 := StringBuilder {}
    sb2.append("foo")
    sb2.append("bar")
    sb2.append("baz")
    println(sb2.to_string())

    // Empty builder
    sb3 := StringBuilder {}
    println("empty='${sb3.to_string()}'")

    // Unicode char
    sb4 := StringBuilder {}
    sb4.append_char('€')
    sb4.append_char(')')
    println(sb4.to_string())

    // Build with numbers via string interp
    n := 42
    sb5 := StringBuilder {}
    sb5.append("n=")
    sb5.append("${n}")
    println(sb5.to_string())

    return 0
}
