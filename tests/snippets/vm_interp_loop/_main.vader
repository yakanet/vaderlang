// Sprint 4 (b3) acceptance: string interpolation inside a loop + i32 calc.
// Prints `i=0 sum=0` ... `i=4 sum=10`, returns sum=10.

module "snippet"

import "std/io"

main :: fn() -> i32 {
    sum := 0
    i := 0
    for i < 5 {
        sum += i
        println("i=${i} sum=${sum}")
        i += 1
    }
    return sum
}
