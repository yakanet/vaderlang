// Void async: a coroutine returning `Async<void>` (normalized to `null`
// internally). Covers fall-off completion and a nested void await.
module "snippet"

import "std/io" { println }

Ready :: struct<T> { v: T }
Ready<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended { return self.v }
}

fetch :: fn() -> Async<i32> = Ready<i32> { .v = 7 }

log_it :: fn() -> Async<void> {
    x :: await fetch()
    println("logged ${x}")
}

wrap :: fn() -> Async<void> {
    await log_it()
    println("wrapped")
}

main :: fn() -> i32 {
    r :: wrap().resume()
    if r is Suspended { println("parked?!") return 1 }
    println("complete")
    return 0
}
