module "snippet"

import "std/io"
import "std/string"
import "std/char"

export is_non_id :: fn(c: char) -> bool {
    if c >= '0' && c <= '9' { return false }
    if c >= 'a' && c <= 'z' { return false }
    if c >= 'A' && c <= 'Z' { return false }
    if c == '_' { return false }
    return true
}

main :: fn() -> i32 {
    println(trim_suffix("foo.vader", ".vader"))
    println(trim_suffix("foo.bar", ".vader"))
    println(trim_prefix("std/io", "std/"))
    println(trim_prefix("foo", "std/"))

    println(replace_chars_where("std::io.print!", is_non_id, "_"))

    parts := split_where("  hello  world\tfoo\n bar  ", is_white_char)
    println("count=${parts.len()}")
    n := parts.len()
    i: usize = 0
    for i < n {
        println(parts[i])
        i = i + 1
    }
    return 0
}
