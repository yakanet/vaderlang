// A `continue i` (targeting the OUTER loop by its iteration variable) across a
// `yield` in an ESCAPING generator. It must advance the outer loop; a regression
// once targeted the innermost loop and spun forever. Companion to
// generator_label_break. See loop-jump-by-variable.md.
module "snippet"

import "std/io" { println }

gen :: fn() -> Iterator<i32> {
    for i in 0..<3 {
        for j in 0..<3 {
            if j == 1 { continue i }
            yield i * 10 + j
        }
    }
}

main :: fn() -> i32 {
    it :: gen()
    for v in it { println("${v}") }
    return 0
}
