// Regression for CR-e : a `defer` in a scope that exits via `expr?`
// error-propagation must still run. The synthetic propagating return used to
// skip the defer drain (unlike a source `return`). Observed here via a struct
// field the defer sets — main returns 0 iff the defer ran on the `?` error path
// (exit 1 = the bug). Both backends must exit 0.

module "snippet"

import "std/io" { println }

Err  :: struct { code: i32 }
Err implements Error {
    message :: fn(self) -> string = "err:${self.code}"
}
Flag :: struct { hit: bool }

might_fail :: fn() -> i32 | Err = Err { .code = 7 }

run :: fn(f: Flag) -> i32 | Err {
    defer { f.hit = true }
    x :: might_fail()?
    return x
}

main :: fn() -> i32 {
    f :: Flag { .hit = false }
    r :: run(f)
    match r {
        is Err as e -> println("propagated ${e.message()}")
        is i32 as n -> println("ok ${n}")
    }
    if f.hit { return 0 }
    return 1
}
