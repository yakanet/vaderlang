// Expression-bodied fn with an explicit return type. Allowed since
// 2026-05-08 — the annotation is required for recursive expression-bodied
// fns (the inferrer can't bind the return type from a recursive call
// site alone) and is otherwise a free way to pin a public signature.

module "snippet"

export square :: fn(x: i32) -> i32 = x * x

main :: fn() -> i32 {
    return 0
}
