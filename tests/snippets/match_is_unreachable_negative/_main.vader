// Negative test for T3040 : `is T` against a scrutinee whose static
// type can never produce a runtime value of T is rejected at compile
// time. Three flavours exercised :
//   - `is null` on a non-nullable scrutinee.
//   - `is X` on a union that doesn't include X.
//   - `is T` in an `if e is T` expression (not just match arms).
//
// The whole-file diagnostic count is the regression contract — any
// future change that silently drops one of these checks will need to
// update the snapshot.

module "snippet"

@allow_unused
Cat  :: struct { name: string }
@allow_unused
Dog  :: struct { name: string }
@allow_unused
Bird :: struct { song: string }
@allow_unused
Pet  :: Cat | Dog

@allow_unused
m1 :: fn(p: Pet) -> bool {
    return match p {
        is null -> false
        _       -> true
    }
}

@allow_unused
m2 :: fn(p: Pet) -> bool {
    return match p {
        is Bird -> false
        _       -> true
    }
}

@allow_unused
m3 :: fn(n: i32) -> bool {
    return match n {
        is null -> false
        _       -> true
    }
}

@allow_unused
m4 :: fn(p: Pet) -> bool {
    if p is null { return false }
    return true
}

main :: fn() -> i32 {
    return 0
}
