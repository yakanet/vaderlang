// User-declared trait + impl + generic fn dispatching via where-clause.
// Verifies non-stdlib traits flow through the same machinery as built-ins.

export Tagger :: trait {
    fn tag(self) -> i32
}

i32 implements Tagger {
    fn tag(self) -> i32 { return self * 10 }
}

export apply_tag :: fn[T](x: T) -> i32 where T: Tagger {
    return x.tag() + x.tag()
}

main :: fn() -> i32 {
    return apply_tag(7)
}
