// std/time — exercise the deterministic surface (Duration arithmetic
// and ISO 8601 round-trip) plus a non-deterministic monotonic check
// whose output is normalised to "true"/"false" so the snapshot stays
// stable across runs. Wall-clock / monotonic readouts themselves are
// never printed verbatim.

import "std/io" { println }
import "std/time" {
    Instant, Monotonic, Duration,
    nanos, micros, millis, seconds,
    now, monotonic, since, format,
    add, sub, plus, minus,
    format_iso8601, parse_iso8601,
    TimeError
}

main :: fn() -> i32 {
    // Duration constructors + format auto-unit
    println(nanos(i64(500)).format())             // 500 ns
    println(nanos(i64(1500)).format())            // 1 µs
    println(micros(i64(42)).format())             // 42 µs
    println(millis(i64(7)).format())              // 7 ms
    println(seconds(i64(3)).format())             // 3 s
    println(nanos(i64(-250)).format())            // -250 ns

    // Duration arithmetic
    a :: millis(i64(100))
    b :: millis(i64(50))
    println("plus=${a.plus(b).format()}")          // plus=150 ms
    println("minus=${a.minus(b).format()}")        // minus=50 ms

    // Instant arithmetic
    epoch :: Instant { .ns_since_epoch = i64(0) }
    later :: epoch.add(seconds(i64(60)))
    delta :: later.sub(epoch)
    println("delta=${delta.format()}")             // delta=60 s

    // ISO 8601 round-trip
    println(format_iso8601(epoch))                 // 1970-01-01T00:00:00.000Z

    iso :: "2026-05-15T12:34:56.789Z"
    parsed :: parse_iso8601(iso)
    match parsed {
        is Instant -> println(format_iso8601(parsed))  // 2026-05-15T12:34:56.789Z
        is Error   -> println("parse failed")
    }

    // Pre-epoch round-trip — negative ns_since_epoch.
    pre :: parse_iso8601("1900-01-01T00:00:00.000Z")
    match pre {
        is Instant -> println(format_iso8601(pre))     // 1900-01-01T00:00:00.000Z
        is Error   -> println("pre failed")
    }

    // Parser rejects malformed input.
    bad :: parse_iso8601("not a timestamp")
    match bad {
        is Error   -> println("bad ok")
        is Instant -> println("bad nope")
    }

    // Monotonic non-decreasing check — normalise to bool so the
    // snapshot doesn't depend on the actual elapsed time.
    start :: monotonic()
    spin: i32 = 0
    for spin < 1000 {
        spin = spin + 1
    }
    e :: start.since()
    println("monotonic>=0=${e.ns >= i64(0)}")      // monotonic>=0=true

    return 0
}
