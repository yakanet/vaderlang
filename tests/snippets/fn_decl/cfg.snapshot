# CFG

## snippet

fn snippet$add(%0: i32, %1: i32) -> i32
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 $add_2: i32
  bb0:
    %2 = binop 0 %0 %1 :i32
    return %2

fn snippet$greet(%0: string, %1: string) -> string
  locals:
    %0 name: string (param name)
    %1 prefix: string (param prefix)
  bb0:
    return %1
