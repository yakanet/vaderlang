module "snippet"

import "std/io"

main :: fn() -> i32 {
    arr :: [10, 20, 30, 40, 50]

    [first, ...rest] := arr
    println("first=${first} rest.len=${rest.len()}")
    for x in rest { println("  ${x}") }

    [a, b, ...tail] := arr
    println("a=${a} b=${b} tail.len=${tail.len()}")

    // wildcards combine with rest
    [_, _, _, ...short] := arr
    println("short.len=${short.len()}")
    for x in short { println("  ${x}") }

    // const-binding form (`::`) destructures the same way
    [c_first, ...c_rest] :: arr
    println("c_first=${c_first} c_rest.len=${c_rest.len()}")

    // rest captures an empty tail when the leading bindings consume every slot
    [only, ...empty] :: [99]
    println("only=${only} empty.len=${empty.len()}")

    return 0
}
