# CFG

## snippet

fn snippet$mul(%0: i32, %1: i32) -> i32
  locals:
    %0 a: i32 (param a)
    %1 b: i32 (param b)
    %2 $mul_2: i32
  bb0:
    %2 = binop 2 %0 %1 :i32
    return %2

fn snippet$main() -> i32
  locals:
    %0 $fn_ref_0: fn(i32, i32) -> i32
    %1 $struct_1: Op
    %2 o: Op (local o)
    %3 $field_3: fn(i32, i32) -> i32
    %4 $k_4: i32
    %5 $k_5: i32
    %6 $call_ind_6: i32
  bb0:
    %0 = fn_ref mul :fn(i32, i32) -> i32
    %1 = struct_new Op(%0)
    %2 = move %1
    %3 = field_get %2.op :fn(i32, i32) -> i32
    %4 = const int(4) :i32
    %5 = const int(5) :i32
    %6 = call_indirect %3(%4, %5) :i32
    return %6
