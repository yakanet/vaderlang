# Lower

## snippet
  struct snippet$Op { op: fn(i32, i32) -> i32 }
  fn snippet$mul(a: i32, b: i32) -> i32
    return
      mul :i32
        l:
          a :i32
        r:
          b :i32
  fn snippet$main() -> i32
    let o: Op =
      Op {
        op: mul :fn(i32, i32) -> i32
      }
    return
      call :i32
        callee:
          .op :fn(i32, i32) -> i32
            o :Op
        arg0:
          int(4) :i32
        arg1:
          int(5) :i32
