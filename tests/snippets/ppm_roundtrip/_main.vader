module "snippet"

import "std/io" { println, write_file_bytes, read_file_bytes, temp_dir }
import "std/images/ppm" { Ppm, PpmError, encode, decode }

// End-to-end: build a Ppm, encode to P6 bytes, persist via the byte-oriented
// file I/O, read it back, decode, and confirm the raster survived — including
// bytes >= 0x80 (the whole point of lossless `*_bytes` I/O vs the string path).
main :: fn() -> i32 {
    path :: "${temp_dir()}/vader_ppm_roundtrip.ppm"
    px: u8[] = [0x00, 0x80, 0xff, 0x10, 0x20, 0x30, 0xc3, 0x28, 0xa9, 0x7f, 0x01, 0xfe]
    img :: Ppm { .width = 2, .height = 2, .maxval = 255, .pixels = px }

    enc :: encode(img)
    if enc is PpmError {
        println("encode failed")
        return 1
    }
    wr :: write_file_bytes(path, enc)
    if wr is Error {
        println("write failed")
        return 1
    }
    raw :: read_file_bytes(path)
    if raw is Error {
        println("read failed")
        return 1
    }
    dec :: decode(raw)
    if dec is PpmError {
        println("decode failed")
        return 1
    }

    ok := dec.width == u32(2) && dec.height == u32(2)
        && dec.maxval == u32(255) && dec.pixels.len() == usize(12)
    for i in 0..<dec.pixels.len() {
        if dec.pixels[i] != px[i] { ok = false }
    }
    println("${dec}")
    if ok { println("OK") } else { println("MISMATCH") }
    return 0
}
