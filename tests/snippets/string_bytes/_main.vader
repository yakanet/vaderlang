module "snippet"

import "std/io" { println }

main :: fn() -> i32 {
    // ASCII path : each codepoint is one byte, sum == codepoint sum.
    println("-- ascii --")
    sum: u32 = u32(0)
    for b in "vader".bytes() {
        sum = sum + u32(b)
    }
    println("sum=${sum}")

    // Multi-byte UTF-8 : surface the raw bytes (3 bytes per CJK glyph).
    println("-- multibyte --")
    for b in "你".bytes() {
        println("${b}")
    }

    // Pinpoint access (BOM detection style — first 3 bytes of a BOM-prefixed
    // string match 0xEF 0xBB 0xBF).
    bom :: "\u{FEFF}data"
    bb :: bom.bytes()
    println("-- bom --")
    println("b0=${bb[0]} b1=${bb[1]} b2=${bb[2]}")
    println("after bom: ${bb[3]}=${"d".bytes()[0]}")

    // Empty string : zero iterations.
    println("-- empty --")
    for b in "".bytes() {
        println("never")
    }
    println("done bytes=${"".bytes().len()}")

    // bytes() returns const u8[], so the array supports random access and
    // .len() like any other array. On native this is a zero-copy view over
    // the interned bytes ; on the VM a materialised copy. Same values.
    println("-- u8[] surface --")
    bs :: "abc".bytes()
    println("len=${bs.len()} bs[0]=${bs[0]} bs[1]=${bs[1]} bs[2]=${bs[2]}")

    // Slicing the view stays a (native zero-copy) view over the same bytes.
    println("-- slice --")
    sl :: "abcde".bytes()[usize(1)..<usize(4)]
    println("sl.len=${sl.len()} sl0=${sl[0]} sl1=${sl[1]} sl2=${sl[2]}")

    return 0
}
