// `Range[char]` exercises both `Contains[char]` and `Iterator[char]`.
// `c in 'a'..='z'` is the natural surface for character class checks
// (replaces the verbose `c >= 'a' && c <= 'z'` chain). `for c in 'a'..='z'`
// also works — the Iterator impl advances the cursor via the u32
// round-trip `char(u32(self.cursor) + u32(1))` since char has no
// dedicated `+ i32` operator.

import "std/io" { println }

is_digit :: fn(c: char) -> bool {
    return c in '0'..='9'
}

is_lower :: fn(c: char) -> bool {
    return c in 'a'..='z'
}

is_alpha :: fn(c: char) -> bool {
    return c in 'a'..='z' || c in 'A'..='Z'
}

main :: fn() -> i32 {
    if is_digit('5')   { println("5 is digit") }
    if !is_digit('a')  { println("a is not digit") }
    if is_digit('0')   { println("0 is digit") }
    if is_digit('9')   { println("9 is digit") }
    if !is_digit(':')  { println(": is not digit") }

    if is_lower('m')   { println("m is lower") }
    if !is_lower('M')  { println("M is not lower") }

    if is_alpha('z')   { println("z is alpha") }
    if is_alpha('Z')   { println("Z is alpha") }
    if !is_alpha('5')  { println("5 is not alpha") }

    // for-in over a char range — Iterator[char] dispatch.
    n := 0
    for c in 'a'..='e' {
        n = n + 1
    }
    println("a..=e count = ${n}")

    // exclusive range
    m := 0
    for c in '0'..<'5' {
        m = m + 1
    }
    println("0..<5 count = ${m}")

    return 0
}
