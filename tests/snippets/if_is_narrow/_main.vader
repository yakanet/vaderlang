// Flow-narrowing on `if x is T { ... }` over arbitrary unions.
// Mirrors what `match` already does inside arm bodies, with three forms :
//   - direct `if x is T { use(x) }` narrows x to T in the then-branch
//   - `if !(x is T) { ... }` flips then/else
//   - a divergent guard (`if x is T { return }`) propagates the complement
//     narrowing to subsequent statements

module "snippet"

import "std/io"

Cat :: struct { name: string }
Dog :: struct { sound: string }
Pig :: struct { weight: i32 }

direct :: fn(p: Cat | Dog) -> string {
    if p is Cat {
        return "cat ${p.name}"
    }
    // else-branch sees p: Dog
    return "dog says ${p.sound}"
}

negated :: fn(p: Cat | Dog) -> string {
    if !(p is Cat) {
        return "dog says ${p.sound}"
    }
    return "cat ${p.name}"
}

cascade :: fn(p: Cat | Dog | Pig) -> string {
    if p is Cat { return "cat ${p.name}" }
    if p is Dog { return "dog says ${p.sound}" }
    // post-stmt narrowing : p is Pig here
    return "pig of ${p.weight} kg"
}

primitive_is :: fn(v: i32 | string) -> string {
    if v is i32 { return "int ${v}" }
    return "str ${v}"
}

main :: fn() -> i32 {
    println(direct(Cat { .name = "felix" }))
    println(direct(Dog { .sound = "woof" }))
    println(negated(Cat { .name = "garfield" }))
    println(negated(Dog { .sound = "bark" }))
    println(cascade(Pig { .weight = 200 }))
    println(primitive_is(42))
    println(primitive_is("hello"))
    return 0
}
