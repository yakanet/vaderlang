fn snippet$direct(%0: Cat | Dog) -> string
  locals:
    %0 p: Cat | Dog (param p)
    %1 $type_check_1: bool
    %2 $intrinsic_2: ?
    %3 __sb_0: ? (synthetic __sb_0)
    %4 $k_4: string
    %5 $cast_5: Cat
    %6 $field_6: string
    %7 $intrinsic_7: string
    %8 $intrinsic_8: ?
    %9 __sb_1: ? (synthetic __sb_1)
    %10 $k_10: string
    %11 $cast_11: Dog
    %12 $field_12: string
    %13 $intrinsic_13: string
  bb0:
    %1 = type_check %0 is Cat
    cond_branch %1 ? bb1 : bb2
  bb1:
    %2 = intrinsic builder.new()
    %3 = move %2
    %4 = const string(#0) :string
    intrinsic builder.append_str(%3, %4)
    %5 = cast %0 :Cat
    %6 = field_get %5.name :string
    intrinsic builder.append_display(%3, %6)
    %7 = intrinsic builder.finish(%3)
    return %7
  bb2:
    %8 = intrinsic builder.new()
    %9 = move %8
    %10 = const string(#1) :string
    intrinsic builder.append_str(%9, %10)
    %11 = cast %0 :Dog
    %12 = field_get %11.sound :string
    intrinsic builder.append_display(%9, %12)
    %13 = intrinsic builder.finish(%9)
    return %13

