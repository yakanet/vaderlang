import "std/io" { eprintln }
import "vader/lsp/transport" { read_frame }

main :: fn() -> i32 {
    f :: read_frame()
    match f {
        is Error -> {
            eprintln("read_frame error")
            return 1
        }
        is string as body -> {
            n :: body.byte_len()
            eprintln("got frame: ${n} bytes")
            return 0
        }
    }
    return 0
}
