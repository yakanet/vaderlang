// std/json — recursive-descent JSON parse + stringify.
//
// `JsonValue` is the tagged union of every JSON shape. `parse` returns
// `JsonValue | JsonError` so failures propagate via `?`.
// `stringify` and `stringify_pretty` build a string via std/string_builder.
//
// Numbers are stored as `f64` for MVP — fine for the compiler's use cases
// (manifests, diagnostics) but loses precision past 2^53. Cf. TODO §3.4
// for the post-MVP compile-time-generated parser à la kotlinx-serialization.

module "std/json"

import "std/string" { decode_char_at, codepoint_byte_len, parse_float, pad_start, chars }
import "std/char" { is_digit, is_white_char }
import "std/iter" { zip }
import "std/string_builder" { StringBuilder, new_builder, append, append_char, append_repeated }
import "std/collections" { MutableMap, len, keys, values }
import "std/numbers" { hex_digit_value, to_hex, to_compact_str }

// ---- value tree -----------------------------------------------------------

/// Tagged union covering every JSON shape (`null`, `true`/`false`, numbers,
/// strings, arrays, objects). Discriminated via `is JsonString` etc. in
/// `match`. Numbers carry an `f64` ; precision past 2^53 is lost (MVP
/// limitation — cf. TODO §3.4).
export JsonValue :: JsonString | JsonNumber | JsonBool | JsonNull | JsonArray | JsonObject

/// JSON string variant — UTF-8 decoded, escape-resolved.
export JsonString :: struct { value: string }

/// JSON number variant — `f64`. Integer-valued numbers round-trip
/// through `to_compact_str` for cleaner output.
export JsonNumber :: struct { value: f64 }

/// JSON `true`/`false`.
export JsonBool :: struct { value: bool }

/// JSON `null`. No payload.
export JsonNull :: struct {}

/// JSON array — ordered list of `JsonValue`s.
export JsonArray :: struct { items: JsonValue[] }

/// JSON object — string-keyed map of `JsonValue`s. Insertion order is
/// preserved by the parser ; lookup is O(1) average via `MutableMap`.
export JsonObject :: struct { entries: MutableMap<string, JsonValue> }

// ---- error ----------------------------------------------------------------

/// Error raised by `parse` when the input isn't valid JSON. `pos` is the
/// byte offset of the offending character.
export JsonError :: struct {
    msg: string
    pos: usize
}

JsonError implements Error {
    message :: fn(self) -> string { return self.msg }
}

// ---- parser ---------------------------------------------------------------

Parser :: struct {
    src: string
    // Byte view of `src`, held once so the scan never re-fetches it.
    bytes: const u8[]
    pos: usize
    eof: usize
}

new_parser :: fn(s: string) -> Parser {
    return Parser { .src = s, .bytes = s.bytes(), .pos = 0, .eof = s.bytes().len() }
}

at_end :: fn(p: Parser) -> bool {
    return p.pos >= p.eof
}

peek_byte :: fn(p: Parser) -> char {
    if p.pos >= p.eof {
        return '\0'
    }
    return p.bytes.decode_char_at(p.pos)
}

advance :: fn(p: Parser) -> void {
    p.pos = p.pos + 1
}

skip_ws :: fn(p: Parser) -> void {
    for !at_end(p) {
        if is_white_char(peek_byte(p)) {
            advance(p)
        } else {
            return
        }
    }
}

fail :: fn(p: Parser, msg: string) -> JsonError {
    return JsonError { .msg = msg, .pos = p.pos }
}

expect_byte :: fn(p: Parser, expected: char) -> JsonError | null {
    if at_end(p) {
        return fail(p, "unexpected end of input")
    }
    if peek_byte(p) != expected {
        return fail(p, "unexpected character")
    }
    advance(p)
    return null
}

match_keyword :: fn(p: Parser, kw: string) -> bool {
    kb :: kw.bytes()
    n :: kb.len()
    if p.pos + n > p.eof {
        return false
    }
    // Byte-level keyword match (JSON keywords `true`/`false`/`null` are ASCII).
    for i in 0..<n {
        if p.bytes[p.pos + i] != kb[i] {
            return false
        }
    }
    p.pos = p.pos + n
    return true
}

// ---- parse value dispatch -------------------------------------------------

parse_value :: fn(p: Parser) -> JsonValue | JsonError {
    skip_ws(p)
    if at_end(p) {
        return fail(p, "unexpected end of input")
    }
    c := peek_byte(p)
    if c == '"' {
        s := parse_string(p)?
        return JsonString { .value = s }
    }
    if c == '{' {
        return parse_object(p)?
    }
    if c == '[' {
        return parse_array(p)?
    }
    if c == 't' || c == 'f' {
        return parse_bool(p)?
    }
    if c == 'n' {
        return parse_null(p)?
    }
    if c == '-' || is_digit(c) {
        return parse_number(p)?
    }
    return fail(p, "unexpected character")
}

// ---- literal-keyword parsers ---------------------------------------------

parse_null :: fn(p: Parser) -> JsonNull | JsonError {
    if !match_keyword(p, "null") {
        return fail(p, "expected `null`")
    }
    return JsonNull {}
}

parse_bool :: fn(p: Parser) -> JsonBool | JsonError {
    if match_keyword(p, "true") {
        return JsonBool { .value = true }
    }
    if match_keyword(p, "false") {
        return JsonBool { .value = false }
    }
    return fail(p, "expected `true` or `false`")
}

// ---- number parser --------------------------------------------------------

parse_number :: fn(p: Parser) -> JsonNumber | JsonError {
    start := p.pos
    if peek_byte(p) == '-' {
        advance(p)
    }
    if at_end(p) || !is_digit(peek_byte(p)) {
        return fail(p, "expected digit")
    }
    for !at_end(p) && is_digit(peek_byte(p)) {
        advance(p)
    }
    if !at_end(p) && peek_byte(p) == '.' {
        advance(p)
        if at_end(p) || !is_digit(peek_byte(p)) {
            return fail(p, "expected digit after `.`")
        }
        for !at_end(p) && is_digit(peek_byte(p)) {
            advance(p)
        }
    }
    if !at_end(p) && (peek_byte(p) == 'e' || peek_byte(p) == 'E') {
        advance(p)
        if !at_end(p) && (peek_byte(p) == '+' || peek_byte(p) == '-') {
            advance(p)
        }
        if at_end(p) || !is_digit(peek_byte(p)) {
            return fail(p, "expected digit in exponent")
        }
        for !at_end(p) && is_digit(peek_byte(p)) {
            advance(p)
        }
    }
    raw := p.bytes[start..<p.pos].bytes_to_string()
    parsed := raw.parse_float()
    match parsed {
        is f64 -> {
            // Bind to a typed local so the C emit unboxes the union value
            // (the trailing-match form keeps the box on the stack).
            n: f64 = parsed
            return JsonNumber { .value = n }
        }
        is Error -> { return fail(p, "invalid number") }
    }
}

// ---- string parser --------------------------------------------------------

/// Consume the next `"..."` JSON string. Looks for the closing `"` or
/// the first escape byte ; if no escape is hit, returns a zero-copy
/// slice of the source so multi-byte UTF-8 sequences survive intact
/// (the byte scan never decodes them).
///
/// @param p  the parser (advanced past the closing quote on success).
/// @return   the decoded string body.
/// @error    `JsonError` on unterminated input or a bad escape.
parse_string :: fn(p: Parser) -> string | JsonError {
    expect_byte(p, '"')?
    start :: p.pos
    for scan in p.pos..<p.eof {
        b :: p.bytes[scan]
        if b == '"' {
            p.pos = scan + 1
            return p.bytes[start..<scan].bytes_to_string()
        }
        if b == '\\' {
            sb :: new_builder()
            sb.append(p.bytes[start..<scan].bytes_to_string())
            p.pos = scan
            return parse_string_with_escapes(p, sb)
        }
    }
    return fail(p, "unterminated string")
}

/// Slow path of `parse_string` — invoked once the scanner sees a `\` byte.
/// `sb` already carries the literal prefix that preceded the escape ;
/// `p.pos` points at the `\`. The byte-walk + escape decode loop runs
/// here, appending each decoded escape onto `sb`. Future work : the per-
/// byte `peek_byte` calls still go through codepoint decoding via
/// `string[i]` — only the `\uXXXX` escape value needs that path ; the
/// rest could byte-scan like the fast path.
///
/// @param p   the parser (advanced past the closing quote on success).
/// @param sb  the builder seeded with the pre-escape literal prefix.
/// @return    the decoded string body.
/// @error     `JsonError` on unterminated input or a bad escape.
parse_string_with_escapes :: fn(p: Parser, sb: StringBuilder) -> string | JsonError {
    for !at_end(p) {
        c := peek_byte(p)
        if c == '"' {
            advance(p)
            return sb.to_string()
        }
        if c == '\\' {
            advance(p)
            if at_end(p) {
                return fail(p, "unterminated escape")
            }
            esc := peek_byte(p)
            advance(p)
            if esc == '"' {
                sb.append_char('"')
            } else if esc == '\\' {
                sb.append_char('\\')
            } else if esc == '/' {
                sb.append_char('/')
            } else if esc == 'n' {
                sb.append_char('\n')
            } else if esc == 't' {
                sb.append_char('\t')
            } else if esc == 'r' {
                sb.append_char('\r')
            } else if esc == 'b' {
                sb.append_char(char(u32(8)))
            } else if esc == 'f' {
                sb.append_char(char(u32(12)))
            } else if esc == 'u' {
                if p.pos + 4 > p.eof {
                    return fail(p, "incomplete \\u escape")
                }
                cp := 0
                for k in usize(0)..<4 {
                    d := hex_digit_value(p.bytes.decode_char_at(p.pos + k))
                    if d < 0 {
                        return fail(p, "invalid hex digit in \\u escape")
                    }
                    cp = cp * 16 + d
                }
                p.pos = p.pos + 4
                sb.append_char(char(cp))
            } else {
                return fail(p, "unknown escape")
            }
        } else {
            // Raw (non-escape) character. `peek_byte` decoded the whole
            // codepoint, so step the cursor by its UTF-8 width — `advance`
            // moves a single byte, which would strand the cursor on a
            // continuation byte and decode the rest of a multi-byte
            // sequence (`é`, `你`, …) as `U+FFFD`, corrupting the string.
            sb.append_char(c)
            p.pos = p.pos + codepoint_byte_len(c)
        }
    }
    return fail(p, "unterminated string")
}

// ---- array parser ---------------------------------------------------------

parse_array :: fn(p: Parser) -> JsonArray | JsonError {
    expect_byte(p, '[')?
    items: JsonValue[] = []
    skip_ws(p)
    if !at_end(p) && peek_byte(p) == ']' {
        advance(p)
        return JsonArray { .items = items }
    }
    for !at_end(p) {
        v := parse_value(p)?
        items.push(v)
        skip_ws(p)
        if at_end(p) {
            return fail(p, "unterminated array")
        }
        c := peek_byte(p)
        if c == ',' {
            advance(p)
            skip_ws(p)
            continue
        }
        if c == ']' {
            advance(p)
            return JsonArray { .items = items }
        }
        return fail(p, "expected `,` or `]`")
    }
    return fail(p, "unterminated array")
}

// ---- object parser --------------------------------------------------------

parse_object :: fn(p: Parser) -> JsonObject | JsonError {
    expect_byte(p, '{')?
    entries := MutableMap<string, JsonValue> {}
    skip_ws(p)
    if !at_end(p) && peek_byte(p) == '}' {
        advance(p)
        return JsonObject { .entries = entries }
    }
    for !at_end(p) {
        skip_ws(p)
        key := parse_string(p)?
        skip_ws(p)
        expect_byte(p, ':')?
        value := parse_value(p)?
        entries[key] = value
        skip_ws(p)
        if at_end(p) {
            return fail(p, "unterminated object")
        }
        c := peek_byte(p)
        if c == ',' {
            advance(p)
            continue
        }
        if c == '}' {
            advance(p)
            return JsonObject { .entries = entries }
        }
        return fail(p, "expected `,` or `}`")
    }
    return fail(p, "unterminated object")
}

// ---- public parse ---------------------------------------------------------

/// Parse a complete JSON document. The input must contain exactly one
/// JSON value optionally surrounded by whitespace ; trailing non-whitespace
/// is an error.
/// @param input  the JSON text.
/// @return       the parsed `JsonValue` on success.
/// @error        `JsonError` carrying a short message and the byte offset
///               of the offending character.
export parse :: fn(input: string) -> JsonValue | JsonError {
    p := new_parser(input)
    v := parse_value(p)?
    skip_ws(p)
    if !at_end(p) {
        return fail(p, "trailing characters after JSON value")
    }
    return v
}

// ---- stringify ------------------------------------------------------------

write_string :: fn(sb: StringBuilder, s: string) -> void {
    sb.append_char('"')
    for c in s.chars() {
        cp := i32(c)
        if c == '"' { sb.append("\\\"") } else
        if c == '\\' { sb.append("\\\\") } else
        if c == '\n' { sb.append("\\n") } else
        if c == '\t' { sb.append("\\t") } else
        if c == '\r' { sb.append("\\r") } else
        if cp < 0x20 {
            sb.append("\\u")
            sb.append(u64(cp).to_hex().pad_start(4, '0'))
        } else {
            sb.append_char(c)
        }
    }
    sb.append_char('"')
}

// Strip the trailing `.0` from integer-valued floats so `42.0` round-trips
// as `42`. Vader stores every JsonNumber as `f64` (the parser doesn't keep
// an int/float distinction), so preserving `.0` would carry no information
// — emit the canonical short form, matching JS `JSON.stringify`, Go
// `encoding/json`, and RFC 8785 (JCS).
write_number :: fn(sb: StringBuilder, v: f64) -> void = sb.append(v.to_compact_str())

write_value :: fn(sb: StringBuilder, v: JsonValue, indent: i32, depth: i32) -> void {
    match v {
        is JsonNull   -> { sb.append("null") }
        is JsonBool   -> {
            if v.value {
                sb.append("true")
            } else {
                sb.append("false")
            }
        }
        is JsonNumber -> { write_number(sb, v.value) }
        is JsonString -> { write_string(sb, v.value) }
        is JsonArray  -> { write_array(sb, v, indent, depth) }
        is JsonObject -> { write_object(sb, v, indent, depth) }
    }
}

write_indent :: fn(sb: StringBuilder, indent: i32, depth: i32) -> void {
    if indent <= 0 {
        return
    }
    sb.append_char('\n')
    sb.append_repeated(' ', indent * depth)
}

write_array :: fn(sb: StringBuilder, a: JsonArray, indent: i32, depth: i32) -> void {
    if a.items.len() == 0 {
        sb.append("[]")
        return
    }
    sb.append_char('[')
    first := true
    for item in a.items {
        if !first {
            sb.append_char(',')
        }
        write_indent(sb, indent, depth + 1)
        write_value(sb, item, indent, depth + 1)
        first = false
    }
    write_indent(sb, indent, depth)
    sb.append_char(']')
}

write_object :: fn(sb: StringBuilder, o: JsonObject, indent: i32, depth: i32) -> void {
    if o.entries.len() == 0 {
        sb.append("{}")
        return
    }
    sb.append_char('{')
    // Snapshot keys + values in parallel so we walk the buckets once and
    // skip the per-entry hash lookup.
    ks := o.entries.keys()
    vs := o.entries.values()
    first := true
    for [k, v] in zip(ks, vs) {
        if !first {
            sb.append_char(',')
        }
        write_indent(sb, indent, depth + 1)
        write_string(sb, k)
        sb.append(":")
        if indent > 0 {
            sb.append_char(' ')
        }
        write_value(sb, v, indent, depth + 1)
        first = false
    }
    write_indent(sb, indent, depth)
    sb.append_char('}')
}

/// Serialise `v` to a compact JSON string — no spaces, no newlines, the
/// smallest valid encoding. For pretty-printed output with indentation
/// use `stringify_pretty`.
/// @param v   the value to serialise.
/// @return    a JSON document string.
export stringify :: fn(v: JsonValue) -> string {
    sb := new_builder()
    write_value(sb, v, 0, 0)
    return sb.to_string()
}

/// Serialise `v` with indentation. `indent` is the number of spaces per
/// nesting level ; pass 2 for human-readable output, 0 for the same
/// effect as `stringify`.
/// @param v       the value to serialise.
/// @param indent  spaces per nesting level (0 → no spaces / no newlines).
/// @return        a JSON document string.
export stringify_pretty :: fn(v: JsonValue, indent: i32) -> string {
    sb := new_builder()
    write_value(sb, v, indent, 0)
    return sb.to_string()
}

// ---- tests ----------------------------------------------------------------

import "std/testing" { assert, assert_eq, fail as test_fail }

/// Parse `src` and assert it produced a `JsonString` whose value matches
/// `expected`.
///
/// @param src       the JSON document to parse.
/// @param expected  the expected decoded string body.
expect_string :: fn(src: string, expected: string) -> void {
    parsed :: parse(src)
    if parsed is JsonString {
        assert_eq(parsed.value, expected)
    } else {
        test_fail("expected JsonString")
    }
}

/// Parse `src` and assert it produced a `JsonError`.
///
/// @param src  the malformed JSON document.
expect_error :: fn(src: string) -> void {
    parsed :: parse(src)
    if parsed !is JsonError {
        test_fail("expected JsonError")
    }
}

@test test_string_empty :: fn() -> void {
    expect_string("\"\"", "")
}

@test test_string_plain :: fn() -> void {
    expect_string("\"hello\"",      "hello")
    expect_string("\"hello world\"", "hello world")
    expect_string("\"x\"",          "x")
}

@test test_string_unicode_passthrough :: fn() -> void {
    // Multi-byte UTF-8 bytes flow through unchanged ; the parser walks
    // bytes, not codepoints, so `é` and the snowman survive intact.
    expect_string("\"café\"",   "café")
    expect_string("\"☃\"",      "☃")
}

@test test_string_escape_simple :: fn() -> void {
    expect_string("\"a\\nb\"",  "a\nb")
    expect_string("\"a\\tb\"",  "a\tb")
    expect_string("\"a\\rb\"",  "a\rb")
    expect_string("\"a\\\"b\"", "a\"b")
    expect_string("\"a\\\\b\"", "a\\b")
    expect_string("\"a\\/b\"",  "a/b")
}

@test test_string_escape_unicode :: fn() -> void {
    expect_string("\"\\u0041\"",      "A")
    expect_string("\"\\u00e9\"",      "é")
    expect_string("\"a\\u00e9b\"",    "aéb")
}

@test test_string_escape_at_boundary :: fn() -> void {
    // Boundary cases for the fast path's "first backslash" scan : the
    // empty-prefix case (escape at byte 0) and the empty-tail case
    // (escape just before the closing quote) both must hand off to the
    // slow path correctly.
    expect_string("\"\\nfoo\"", "\nfoo")
    expect_string("\"foo\\n\"", "foo\n")
    expect_string("\"\\n\"",    "\n")
}

@test test_string_multibyte_after_escape :: fn() -> void {
    // Regression : `test_string_unicode_passthrough` only covers raw
    // multi-byte chars on the fast (no-escape) path. Once any escape
    // appears, the rest of the string runs through the slow path, which
    // used to step the cursor a single byte per character — stranding it
    // on the continuation byte of a multi-byte codepoint and decoding the
    // tail as `U+FFFD`. So `'é'` round-tripped to TWO codepoints (the LSP
    // surfaced this as L0005 on every accented char in an opened file).
    // A raw multi-byte codepoint after an escape must survive whole.
    expect_string("\"\\tcafé\"",     "\tcafé")
    expect_string("\"a\\né☃b\"",     "a\né☃b")
    expect_string("\"\\u0041café\"", "Acafé")
    // Escape AFTER the multi-byte char too — the cursor must be aligned
    // when it reaches the escape.
    expect_string("\"café\\tx\"",    "café\tx")
}

@test test_string_errors :: fn() -> void {
    expect_error("\"unterminated")
    expect_error("\"\\")
    expect_error("\"\\q\"")
    expect_error("\"\\u00\"")
}

@test test_object_string_keys :: fn() -> void {
    // Object keys go through the same `parse_string` path — exercise an
    // input where one key is escape-free (fast path) and one carries an
    // escape (slow path).
    parsed :: parse("{\"key\": 1, \"k\\ny\": 2}")
    if parsed is JsonObject {
        assert_eq(parsed.entries.len(), 2)
    } else {
        test_fail("expected JsonObject")
    }
}

@test test_array_of_strings :: fn() -> void {
    parsed :: parse("[\"a\", \"b\\nc\", \"\"]")
    if parsed is JsonArray {
        assert_eq(parsed.items.len(), 3) 
    } else {
        test_fail("expected JsonArray") 
    }
    
}
