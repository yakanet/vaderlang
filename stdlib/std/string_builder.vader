// std/builder — efficient string construction.
//
// Concatenating strings with `+` allocates each time. StringBuilder accumulates
// parts into an internal `[string]` buffer and flushes once via the
// `Display.to_string` host intrinsic — a single pass with one allocation
// sized from the total length, instead of the O(N²) of repeated `+`.
//
// Usage:
//   sb := new_builder()
//   sb.append("Hello")
//   sb.append_char('!')
//   result := sb.to_string()  // "Hello!"

/// Amortised-O(1) string accumulator. Pushes UTF-8 parts onto an internal
/// `[string]` buffer ; flushed in one allocation by `Display::to_string`
/// (called automatically through `${sb}` interpolation).
export StringBuilder :: struct {
    parts: string[]
}

/// Create an empty builder. Callers typically chain through UFCS :
/// `sb := new_builder() ; sb.append("…")`.
/// @return  a fresh `StringBuilder` with no parts.
export new_builder :: fn() -> StringBuilder {
    return StringBuilder { .parts = [] }
}

/// Append a string slice. The slice's backing memory is referenced — not
/// copied — until the builder is finalised.
/// @param self  builder receiver.
/// @param s     UTF-8 string to append.
export append :: fn(self: StringBuilder, s: string) -> void {
    self.parts.push(s)
}

/// Append a single Unicode codepoint, UTF-8-encoded.
/// @param self  builder receiver.
/// @param c     codepoint to encode (`u32(c)` ≤ `0x10FFFF`).
export append_char :: fn(self: StringBuilder, c: char) -> void {
    self.parts.push("${c}")
}

/// Append `count` copies of `c` to the builder. Generalises pretty-printer
/// indentation, table padding, divider lines, and any other "write N
/// copies" pattern — symmetric with `std/string.pad_end(s, width, fill)`
/// but writes directly into the builder without an intermediate string
/// allocation. Negative or zero counts are a no-op.
///
/// Examples :
///   `sb.append_repeated(' ', level * 2)   // indentation`
///   `sb.append_repeated('-', 40)           // divider line`
///
/// @param self   builder receiver.
/// @param c      codepoint to repeat.
/// @param count  number of copies to append (≤ 0 → no-op).
export append_repeated :: fn(self: StringBuilder, c: char, count: i32) -> void {
    for _ in 0..<count {
        self.append_char(c)
    }
}

// Display — flushes the buffer into one string. Host-provided ; the runtime
// extracts `.parts` from the receiver and concatenates in a single allocation.
// `${sb}` interpolation and `sb.to_string()` both resolve here.
@intrinsic StringBuilder implements Display
