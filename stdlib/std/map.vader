// std/map — generic key/value map.
//
// MVP : linear-search implementation. O(n) per put/get/contains_key. Works
// for any key type that supports `==` (all primitives, structs that implement
// Eq via the upcoming trait-dispatch on $K, but currently relies on the
// language's structural equality).
//
// Post-MVP : chaining hash map with `Hash + Eq` constraint. The current
// compiler doesn't yet resolve trait methods on bounded type parameters, so
// `key.hash()` / `key.equals(other)` fail at typecheck inside a generic body.
// Once that lands, this module promotes to a chaining HashMap (cf. Bucket
// scaffold below, kept for reference).
//
// Construction example :
//   m := MutableMap(string, i32) { .keys = [], .values = [], .size = 0 }
//   m.put("answer", 42)
//   v := m.get("answer")   // V | null

// Bucket — kept as a stub for the future chaining HashMap implementation.
private Bucket :: struct($K, $V) {
    key:   K
    value: V
    next:  Bucket(K, V) | null
}

// Map (read-only) — TODO post-MVP. Same layout as MutableMap; API will be a
// subset (no put/remove). Declared here so user code can reference it.
Map :: struct($K, $V) {
    keys:   [K]
    values: [V]
    size:   usize
}

MutableMap :: struct($K, $V) {
    keys:   [K]
    values: [V]
    size:   usize
}

Entry :: struct($K, $V) {
    key:   K
    value: V
}

// ===========================================================================
// Operations
// ===========================================================================

put :: fn(self: MutableMap($K, $V), key: K, value: V) -> void {
    for i in 0..<i32(self.size) {
        if self.keys[i] == key {
            self.values[i] = value
            return
        }
    }
    self.keys.push(key)
    self.values.push(value)
    self.size = self.size + 1
}

get :: fn(self: MutableMap($K, $V), key: K) -> V | null {
    for i in 0..<i32(self.size) {
        if self.keys[i] == key {
            return self.values[i]
        }
    }
    return null
}

contains_key :: fn(self: MutableMap($K, $V), key: K) -> bool {
    for i in 0..<i32(self.size) {
        if self.keys[i] == key { return true }
    }
    return false
}

len :: fn(self: MutableMap($K, $V)) -> usize { return self.size }

is_empty :: fn(self: MutableMap($K, $V)) -> bool { return self.size == 0 }
