// std/math — basic numeric operations and constants.

// Constants.
pi :: 3.141592653589793
e  :: 2.718281828459045

// Float operations.
sqrt  :: fn(x: f64) -> f64
pow   :: fn(x: f64, n: f64) -> f64
floor :: fn(x: f64) -> f64
ceil  :: fn(x: f64) -> f64
round :: fn(x: f64) -> f64

// Trigonometry.
sin :: fn(x: f64) -> f64
cos :: fn(x: f64) -> f64
tan :: fn(x: f64) -> f64
