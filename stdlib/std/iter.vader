// std/iter — iterator combinators on top of `Iterator(T)` (defined in std/core).
//
// MVP scope (this file):
//   - Consumers : `count(it)`, `collect(it)` operate on Iterator($T) — the
//     `for x in it` form is the lowerer's existing entry point for trait
//     dispatch on the iterator's `step`.
//   - Closure-driven combinators (`map`, `filter`, `fold`, `take`, `skip`,
//     `sum`) operate on `[T]` directly. A generic `Iterator($T)` form is
//     blocked on direct trait-method dispatch on a `$T : Iterator` type
//     parameter, which the lowerer doesn't yet expose outside `for x in it`.
//     Callers can bridge with `collect(it)` to materialise an array first.

// count — total number of items the iterator yields.
export count :: fn(it: Iterator($T)) -> i32 {
    n := 0
    for x in it {
        n = n + 1
    }
    return n
}

// collect — drain the iterator into a freshly-allocated array.
export collect :: fn(it: Iterator($T)) -> T[] {
    out: T[] = []
    for x in it {
        out.push(x)
    }
    return out
}

// map — apply `f` to every element, returning a fresh array of the results.
export map :: fn(arr: $T[], f: fn(T) -> $U) -> U[] {
    out: U[] = []
    for x in arr {
        out.push(f(x))
    }
    return out
}

// filter — keep only the elements for which `pred` returns true.
export filter :: fn(arr: $T[], pred: fn(T) -> bool) -> T[] {
    out: T[] = []
    for x in arr {
        if pred(x) {
            out.push(x)
        }
    }
    return out
}

// fold — left-reduce the array with seed `init`.
export fold :: fn(arr: $T[], init: $U, f: fn(U, T) -> U) -> U {
    acc := init
    for x in arr {
        acc = f(acc, x)
    }
    return acc
}

// sum — sum the elements of an `[i32]`. A generic Sum-trait variant is
// deferred until either trait-method dispatch on `$T : Add + Default` works
// or we expose a `T()` zero-init form.
export sum :: fn(arr: i32[]) -> i32 {
    s := 0
    for x in arr {
        s = s + x
    }
    return s
}

// take — copy at most `n` items from the array into a fresh array.
export take :: fn(arr: $T[], n: i32) -> T[] {
    out: T[] = []
    i := 0
    for x in arr {
        if i >= n {
            return out
        }
        out.push(x)
        i = i + 1
    }
    return out
}

// skip — drop the first `n` items, return the remaining ones as an array.
export skip :: fn(arr: $T[], n: i32) -> T[] {
    out: T[] = []
    i := 0
    for x in arr {
        if i >= n {
            out.push(x)
        }
        i = i + 1
    }
    return out
}

// slice — copy `arr[start..<end]` into a fresh array. Bounds are clamped
// (start to [0, len], end to [start, len]), so out-of-range indices yield a
// shorter result rather than panicking. Negative indices are not supported.
export slice :: fn(arr: $T[], start: i32, end: i32) -> T[] {
    out: T[] = []
    len := arr.len()
    lo := start
    if lo < 0 { lo = 0 }
    if lo > len { lo = len }
    hi := end
    if hi < lo { hi = lo }
    if hi > len { hi = len }
    i := lo
    for i < hi {
        out.push(arr[i])
        i = i + 1
    }
    return out
}
