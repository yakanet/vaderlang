// std/iter — array-based eager combinators + lazy iterator chains.
//
// Two shapes coexist :
//
//   1. **Eager** : functions like `map` / `filter` / `take` / `skip` /
//      `fold` / `sum` take a `T[]` array, allocate a fresh result array
//      (or fold to a single value), and return immediately. Best for
//      one-shot transformations where the result lives anyway.
//
//   2. **Lazy** : the `*Iterator` structs at the bottom of this file
//      (`MapIterator`, `FilterIterator`, `TakeIterator`, `SkipIterator`)
//      wrap a source `Iterator(T)` and produce one element at a time via
//      their `Iterator(U)` impl. Useful when chaining transformations
//      without materialising intermediate arrays. Construct directly
//      with the struct literal :
//
//          mi :: MapIterator(i32, i32) {
//              .source = 0..<10,
//              .f      = fn(x: i32) -> i32 { return x * x },
//          }
//          for sq in mi { /* … */ }
//
//      No `lazy_map(it, f)` constructor helper — generic-fn inference on
//      a trait-typed parameter (`fn[T](it: Iterator(T))`) doesn't unify
//      `T` from the concrete arg today, so the explicit type-args on the
//      struct literal carry the substitution instead. The trade-off is
//      one extra `(T, U)` per call site ; the upside is zero new compiler
//      support beyond what already works (struct lit with a trait-typed
//      field auto-boxes the source).

/// Number of items in the array. Trivial wrapper over `arr.len()` ;
/// exposed for symmetry with the future Iterator-driven `count(it)`.
export count :: fn[T](arr: T[]) -> usize {
    return arr.len()
}

/// Clone `arr` into a fresh allocation. Elements are NOT recursively
/// cloned — for reference types the new array shares element references
/// with the input. Symmetric with the future Iterator-driven `collect(it)`.
/// @param arr  source array.
/// @return     a fresh array with the same elements in the same order.
export collect :: fn[T](arr: T[]) -> T[] {
    out: T[] = []
    for x in arr {
        out.push(x)
    }
    return out
}

/// Apply `f` to every element, returning a fresh array of the results.
/// Stable (preserves input order).
/// @param arr  source array.
/// @param f    mapper applied to each element.
/// @return     a new array with `f` applied per element.
export map :: fn[T, U](arr: T[], f: fn(T) -> U) -> U[] {
    out: U[] = []
    for x in arr {
        out.push(f(x))
    }
    return out
}

/// Keep only the elements for which `pred` returns `true`. Stable.
/// @param arr   source array.
/// @param pred  predicate invoked on each element ; truthy → kept.
/// @return      a fresh array of the kept elements.
export filter :: fn[T](arr: T[], pred: fn(T) -> bool) -> T[] {
    out: T[] = []
    for x in arr {
        if pred(x) {
            out.push(x)
        }
    }
    return out
}

/// Left-fold the array with seed `init`. `f(acc, x)` is called for every
/// element in order ; the final accumulator is returned.
/// @param arr   source array.
/// @param init  initial accumulator value.
/// @param f     reducer ; takes the running accumulator and the next
///              element.
/// @return      the accumulator after consuming the entire array.
export fold :: fn[T, U](arr: T[], init: U, f: fn(U, T) -> U) -> U {
    acc := init
    for x in arr {
        acc = f(acc, x)
    }
    return acc
}

/// Sum the elements of an `[i32]`. A generic `Sum`-trait variant is
/// deferred until trait-method dispatch on `$T: Add + Default` works
/// or a `T()` zero-init form is exposed.
export sum :: fn(arr: i32[]) -> i32 {
    s := 0
    for x in arr {
        s = s + x
    }
    return s
}

/// Copy at most the first `n` items into a fresh array. Stops early when
/// the source has fewer than `n` elements.
/// @param arr  source array.
/// @param n    upper bound on the result length.
export take :: fn[T](arr: T[], n: usize) -> T[] {
    out: T[] = []
    i: usize = 0
    for x in arr {
        if i >= n {
            return out
        }
        out.push(x)
        i = i + 1
    }
    return out
}

/// Drop the first `n` items, return the remainder as a fresh array.
/// `n >= arr.len()` yields an empty array.
/// @param arr  source array.
/// @param n    number of leading items to skip.
export skip :: fn[T](arr: T[], n: usize) -> T[] {
    out: T[] = []
    i: usize = 0
    for x in arr {
        if i >= n {
            out.push(x)
        }
        i = i + 1
    }
    return out
}

/// Copy `arr[start..<end]` into a fresh array. Bounds are clamped (start
/// to `[0, len]`, end to `[start, len]`) so out-of-range indices yield a
/// shorter result rather than panicking. `start` / `end` are unsigned —
/// reverse them or use `0` to skip from the front.
/// @param arr    source array.
/// @param start  inclusive lower bound (clamped to `[0, len]`).
/// @param end    exclusive upper bound (clamped to `[start, len]`).
export slice :: fn[T](arr: T[], start: usize, end: usize) -> T[] {
    out: T[] = []
    len := arr.len()
    lo := start
    if lo > len { lo = len }
    hi := end
    if hi < lo { hi = lo }
    if hi > len { hi = len }
    for i in lo..<hi {
        out.push(arr[i])
    }
    return out
}

/// Pair elements of `a` and `b` into tuples, stopping at the shorter of
/// the two. Mirrors Python `zip` ; useful for stepping parallel arrays
/// (e.g. keys + values from a map).
/// @param a  left source array.
/// @param b  right source array.
/// @return   `[a[0], b[0]], [a[1], b[1]], …` capped at `min(len(a), len(b))`.
export zip :: fn[T, U](a: T[], b: U[]) -> [T, U][] {
    out: [T, U][] = []
    n :: a.len()
    m :: b.len()
    k :: if n < m { n } else { m }
    for i in 0..<k {
        out.push([a[i], b[i]])
    }
    return out
}

/// Concatenate `a` followed by `b` into a fresh array. Useful when
/// building a flat stream out of two homogeneous sources.
/// @param a  first source array.
/// @param b  second source array, appended after `a`.
/// @return   a fresh array of `a.len() + b.len()` elements.
export chain :: fn[T](a: T[], b: T[]) -> T[] {
    out: T[] = []
    for x in a { out.push(x) }
    for x in b { out.push(x) }
    return out
}

/// Pair each element with its index, starting at 0. Returns `[usize, T]`
/// tuples so callers can `for [i, x] in arr.enumerate() { … }`.
/// @param arr  source array.
/// @return     `[[0, arr[0]], [1, arr[1]], …]`.
export enumerate :: fn[T](arr: T[]) -> [usize, T][] {
    out: [usize, T][] = []
    i: usize = 0
    for x in arr {
        out.push([i, x])
        i = i + 1
    }
    return out
}

/// Apply `f` to each element and concatenate the resulting arrays.
/// Useful when each input expands to zero-or-more outputs (parsing,
/// tree flattening).
/// @param arr  source array.
/// @param f    mapper from one element to an array of outputs.
/// @return     concatenation of `f(arr[0]) ++ f(arr[1]) ++ …`.
export flat_map :: fn[T, U](arr: T[], f: fn(T) -> U[]) -> U[] {
    out: U[] = []
    for x in arr {
        for y in f(x) {
            out.push(y)
        }
    }
    return out
}

// ============================================================================
// Lazy iterator chains
// ============================================================================
//
// Each combinator below is a struct that *wraps* a source `Iterator(T)` and
// implements `Iterator(U)` itself. Chained transformations stay lazy : an
// element only flows through the chain when the downstream consumer calls
// `next()` (or `for x in chain {…}` does).
//
// Construction goes through the struct literal — see the module header for
// the rationale (no fn helper because of a generic-inference limitation on
// trait-typed parameters).

/// Lazy map. `next()` pulls one item from `source`, transforms it via `f`,
/// and yields it. Stops when the source is exhausted.
/// Construct as `MapIterator(T, U) { .source = it, .f = mapper }`.
export MapIterator :: struct[T, U] {
    source: Iterator(T)
    f:      fn(T) -> U
}

MapIterator[T, U] implements Iterator[U] {
    next :: fn(self) -> Done | Yielded(U) {
        match self.source.next() {
            is Done            -> { return Done {} }
            is Yielded(T) as y -> { return Yielded(U) { .value = self.f(y.value) } }
        }
        return Done {}
    }
}

/// Lazy filter. `next()` pulls items from `source` until `pred` returns
/// `true` ; that one is yielded, the next call resumes the search.
/// Construct as `FilterIterator(T) { .source = it, .pred = predicate }`.
export FilterIterator :: struct[T] {
    source: Iterator(T)
    pred:   fn(T) -> bool
}

FilterIterator[T] implements Iterator[T] {
    next :: fn(self) -> Done | Yielded(T) {
        finished := false
        for !finished {
            match self.source.next() {
                is Done            -> { finished = true }
                is Yielded(T) as y -> {
                    if self.pred(y.value) {
                        return Yielded(T) { .value = y.value }
                    }
                }
            }
        }
        return Done {}
    }
}

/// Lazy take. Yields the first `remaining` items from `source` and then
/// stops. `remaining` counts down across calls — once it hits zero the
/// iterator returns `Done` even if `source` still has items.
/// Construct as `TakeIterator(T) { .source = it, .remaining = n }`.
export TakeIterator :: struct[T] {
    source:    Iterator(T)
    remaining: usize
}

TakeIterator[T] implements Iterator[T] {
    next :: fn(self) -> Done | Yielded(T) {
        if self.remaining == 0 { return Done {} }
        match self.source.next() {
            is Done            -> { return Done {} }
            is Yielded(T) as y -> {
                self.remaining = self.remaining - 1
                return Yielded(T) { .value = y.value }
            }
        }
        return Done {}
    }
}

/// Lazy skip. Drops the first `remaining` items from `source` on the first
/// `next()` call, then forwards every subsequent item. After the prefix is
/// consumed `remaining` stays at zero so the steady state is a pass-through.
/// Construct as `SkipIterator(T) { .source = it, .remaining = n }`.
export SkipIterator :: struct[T] {
    source:    Iterator(T)
    remaining: usize
}

SkipIterator[T] implements Iterator[T] {
    next :: fn(self) -> Done | Yielded(T) {
        for self.remaining > 0 {
            match self.source.next() {
                is Done       -> {
                    self.remaining = 0
                    return Done {}
                }
                is Yielded(T) -> {
                    self.remaining = self.remaining - 1
                }
            }
        }
        match self.source.next() {
            is Done            -> { return Done {} }
            is Yielded(T) as y -> { return Yielded(T) { .value = y.value } }
        }
        return Done {}
    }
}
