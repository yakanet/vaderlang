// std/iter — array-based eager combinators + lazy iterator chains.
//
// Two shapes coexist :
//
//   1. **Eager** : functions like `map` / `filter` / `take` / `skip` /
//      `fold` / `sum` take a `T[]` array, allocate a fresh result array
//      (or fold to a single value), and return immediately. Best for
//      one-shot transformations where the result lives anyway.
//
//   2. **Lazy** : the `*Iterator` structs at the bottom of this file
//      (`MapIterator`, `FilterIterator`, `TakeIterator`, `SkipIterator`)
//      wrap a source `Iterator(T)` and produce one element at a time via
//      their `Iterator(U)` impl. Useful when chaining transformations
//      without materialising intermediate arrays. Construct directly
//      with the struct literal :
//
//          mi :: MapIterator(i32, i32) {
//              .source = 0..<10,
//              .f      = fn(x: i32) -> i32 { return x * x },
//          }
//          for sq in mi { /* … */ }
//
//      No `lazy_map(it, f)` constructor helper — generic-fn inference on
//      a trait-typed parameter (`fn[T](it: Iterator(T))`) doesn't unify
//      `T` from the concrete arg today, so the explicit type-args on the
//      struct literal carry the substitution instead. The trade-off is
//      one extra `(T, U)` per call site ; the upside is zero new compiler
//      support beyond what already works (struct lit with a trait-typed
//      field auto-boxes the source).

/// Number of items in the array. Trivial wrapper over `arr.len()` ;
/// exposed for symmetry with the future Iterator-driven `count(it)`.
export count :: fn[T](arr: T[]) -> usize {
    return arr.len()
}

/// Clone `arr` into a fresh allocation. Elements are NOT recursively
/// cloned — for reference types the new array shares element references
/// with the input. Symmetric with the future Iterator-driven `collect(it)`.
/// @param arr  source array.
/// @return     a fresh array with the same elements in the same order.
export collect :: fn[T](arr: T[]) -> T[] {
    out: T[] = []
    for x in arr {
        out.push(x)
    }
    return out
}

/// Drain `it` into a fresh array. Pair with the lazy combinators
/// (`it.filter(p).map(f).collect()`) when a snapshot is required ;
/// `for x in it` consumes directly without the intermediate array.
export collect :: fn[T](it: Iterator(T)) -> T[] {
    out: T[] = []
    for x in it {
        out.push(x)
    }
    return out
}

/// Apply `f` to every element, returning a fresh array of the results.
/// Stable (preserves input order).
/// @param arr  source array.
/// @param f    mapper applied to each element.
/// @return     a new array with `f` applied per element.
export map :: fn[T, U](arr: T[], f: fn(T) -> U) -> U[] {
    out: U[] = []
    for x in arr {
        out.push(f(x))
    }
    return out
}

/// Keep only the elements for which `pred` returns `true`. Stable.
/// @param arr   source array.
/// @param pred  predicate invoked on each element ; truthy → kept.
/// @return      a fresh array of the kept elements.
export filter :: fn[T](arr: T[], pred: fn(T) -> bool) -> T[] {
    out: T[] = []
    for x in arr {
        if pred(x) {
            out.push(x)
        }
    }
    return out
}

// Eager iterator `filter` removed — the lazy fluent overload below
// (`filter :: fn[T](self: Iterator(T), ...) -> FilterIterator(T)`)
// is the new default. Drain to an array with `.collect()` when needed.

/// Left-fold the array with seed `init`. `f(acc, x)` is called for every
/// element in order ; the final accumulator is returned.
/// @param arr   source array.
/// @param init  initial accumulator value.
/// @param f     reducer ; takes the running accumulator and the next
///              element.
/// @return      the accumulator after consuming the entire array.
export fold :: fn[T, U](arr: T[], init: U, f: fn(U, T) -> U) -> U {
    acc := init
    for x in arr {
        acc = f(acc, x)
    }
    return acc
}

/// Sum the elements of an `[i32]`. A generic `Sum`-trait variant is
/// deferred until trait-method dispatch on `$T: Add + Default` works
/// or a `T()` zero-init form is exposed.
export sum :: fn(arr: i32[]) -> i32 {
    s := 0
    for x in arr {
        s = s + x
    }
    return s
}

/// Copy at most the first `n` items into a fresh array. Stops early when
/// the source has fewer than `n` elements.
/// @param arr  source array.
/// @param n    upper bound on the result length.
export take :: fn[T](arr: T[], n: usize) -> T[] {
    out: T[] = []
    i: usize = 0
    for x in arr {
        if i >= n {
            return out
        }
        out.push(x)
        i = i + 1
    }
    return out
}

/// Drop the first `n` items, return the remainder as a fresh array.
/// `n >= arr.len()` yields an empty array.
/// @param arr  source array.
/// @param n    number of leading items to skip.
export skip :: fn[T](arr: T[], n: usize) -> T[] {
    out: T[] = []
    i: usize = 0
    for x in arr {
        if i >= n {
            out.push(x)
        }
        i = i + 1
    }
    return out
}

/// `arr[start..<end)` as a zero-copy view — sharing the parent's buf on
/// native. Bounds clamped (start to `[0, len]`, end to `[start, len]`).
/// Pushing into the view detaches into a fresh buf, so the parent is
/// never mutated through the slice.
///
/// For a fresh mutable copy, use `arr.clone()` ; for a partial copy
/// chain `arr[lo..<hi].clone()`.
/// @param arr    source array.
/// @param start  inclusive lower bound (clamped to `[0, len]`).
/// @param end    exclusive upper bound (clamped to `[start, len]`).
export slice :: fn[T](arr: T[], start: usize, end: usize) -> T[] {
    return arr[start..<end]
}

/// `const T[]` overload — preserves the const-ness of the input through
/// the view. The result type is `const T[]` so mutation stays rejected
/// at typecheck on the slice just as on its parent.
export slice :: fn[T](arr: const T[], start: usize, end: usize) -> const T[] {
    return arr[start..<end]
}

/// Fresh mutable copy of `arr`. Accepts both `T[]` (by subtype) and
/// `const T[]` (by signature). The returned array is independent —
/// mutating it does not affect `arr`.
///
/// Use this when you need to escape `const T[]`'s immutability locally,
/// or to break aliasing between a slice view and its parent.
///
/// Naming overlaps with the `Clone` trait in `std/core` (currently
/// without implementors). When `T[] implements Clone` lands, this free
/// fn becomes the impl — `arr.clone()` resolves identically either way.
export clone :: fn[T](arr: const T[]) -> T[] {
    n :: arr.len()
    out: T[] = []
    i: usize = 0
    for i < n {
        out.push(arr[i])
        i = i + usize(1)
    }
    return out
}

/// Pair elements of `a` and `b` into tuples, stopping at the shorter of
/// the two. Mirrors Python `zip` ; useful for stepping parallel arrays
/// (e.g. keys + values from a map).
/// @param a  left source array.
/// @param b  right source array.
/// @return   `[a[0], b[0]], [a[1], b[1]], …` capped at `min(len(a), len(b))`.
export zip :: fn[T, U](a: T[], b: U[]) -> [T, U][] {
    out: [T, U][] = []
    n :: a.len()
    m :: b.len()
    k :: if n < m { n } else { m }
    for i in 0..<k {
        out.push([a[i], b[i]])
    }
    return out
}

/// Concatenate `a` followed by `b` into a fresh array. Useful when
/// building a flat stream out of two homogeneous sources.
/// @param a  first source array.
/// @param b  second source array, appended after `a`.
/// @return   a fresh array of `a.len() + b.len()` elements.
export chain :: fn[T](a: T[], b: T[]) -> T[] {
    out: T[] = []
    for x in a { out.push(x) }
    for x in b { out.push(x) }
    return out
}

/// Pair each element with its index, starting at 0. Returns `[usize, T]`
/// tuples so callers can `for [i, x] in arr.enumerate() { … }`.
/// @param arr  source array.
/// @return     `[[0, arr[0]], [1, arr[1]], …]`.
export enumerate :: fn[T](arr: T[]) -> [usize, T][] {
    out: [usize, T][] = []
    i: usize = 0
    for x in arr {
        out.push([i, x])
        i = i + 1
    }
    return out
}

/// Apply `f` to each element and concatenate the resulting arrays.
/// Useful when each input expands to zero-or-more outputs (parsing,
/// tree flattening).
/// @param arr  source array.
/// @param f    mapper from one element to an array of outputs.
/// @return     concatenation of `f(arr[0]) ++ f(arr[1]) ++ …`.
export flat_map :: fn[T, U](arr: T[], f: fn(T) -> U[]) -> U[] {
    out: U[] = []
    for x in arr {
        for y in f(x) {
            out.push(y)
        }
    }
    return out
}

// ---------------------------------------------------------------- short-circuit
//
// Each combinator takes an `Iterator(T)`. Raw arrays are accepted at the
// call site via the blanket `T[] implements[T] Into(Iterator(T))` impl in
// `std/core` — both direct (`any(arr, p)`) and UFCS (`arr.any(p)`) forms
// auto-coerce.

/// `true` as soon as any element satisfies `pred` ; `false` if none do.
/// Short-circuits — `pred` is not invoked past the first match.
/// @param it    source array or iterator.
/// @param pred  predicate invoked on each element until one returns `true`.
export any :: fn[T](it: Iterator(T), pred: fn(T) -> bool) -> bool {
    for x in it {
        if pred(x) {
            return true
        }
    }
    return false
}

/// `true` only when every element satisfies `pred`. Short-circuits on the
/// first `false`. Returns `true` on an empty source (vacuous truth).
/// @param it    source array or iterator.
/// @param pred  predicate invoked on each element until one returns `false`.
export all :: fn[T](it: Iterator(T), pred: fn(T) -> bool) -> bool {
    for x in it {
        if !pred(x) {
            return false
        }
    }
    return true
}

/// First element matching `pred`, or `null` if none does. Short-circuits.
/// Consumers narrow naturally : `match arr.find(p) { is T as hit -> … }`.
/// @param it    source array or iterator.
/// @param pred  predicate invoked on each element until one returns `true`.
export find :: fn[T](it: Iterator(T), pred: fn(T) -> bool) -> T | null {
    for x in it {
        if pred(x) {
            return x
        }
    }
    return null
}

/// Apply `f` to each element ; return the first non-null result. Combines
/// the transform and the search in one pass — useful for parsing chains
/// where the mapper itself decides whether an element qualifies.
/// @param it  source array or iterator.
/// @param f   mapper that returns `null` to skip the element or a value
///            to short-circuit on.
export find_map :: fn[T, U](it: Iterator(T), f: fn(T) -> U | null) -> U | null {
    for x in it {
        v :: f(x)
        if v != null {
            return v
        }
    }
    return null
}

// ============================================================================
// Lazy iterator chains
// ============================================================================
//
// Each combinator below is a struct that *wraps* a source `Iterator(T)` and
// implements `Iterator(U)` itself. Chained transformations stay lazy : an
// element only flows through the chain when the downstream consumer calls
// `next()` (or `for x in chain {…}` does).
//
// Two construction shapes : the struct literal (`MapIterator(T, U) { … }`)
// and the fluent free fns below. The fluent shape (`it.map(f).filter(p)`)
// reads like an Iterator pipeline and dispatches via UFCS through the
// first param's type — overload-resolved against the eager `T[]`-first-
// param siblings declared above. The lowerer's iter-chain fusion path
// recognises both shapes and folds them into a single counter loop when
// the chain bottoms at an inline range.

/// Fluent lazy `filter`. Distinct from the eager `T[]`-overload above —
/// the resolver picks this one when the receiver implements `Iterator(T)`
/// (Range, ArrayIterator, MutableMap, …).
export filter :: fn[T](self: Iterator(T), pred: fn(T) -> bool) -> FilterIterator(T) {
    return FilterIterator(T) { .source = self, .pred = pred }
}

/// Fluent lazy `map`. Mirror of `filter` for transforms ; element type
/// can change (`T` → `U`).
export map :: fn[T, U](self: Iterator(T), f: fn(T) -> U) -> MapIterator(T, U) {
    return MapIterator(T, U) { .source = self, .f = f }
}

/// Fluent lazy `take`. Yields the first `n` items from `self`, then ends.
export take :: fn[T](self: Iterator(T), n: usize) -> TakeIterator(T) {
    return TakeIterator(T) { .source = self, .remaining = n }
}

/// Fluent lazy `skip`. Drops the first `n` items from `self`, then forwards
/// every subsequent item.
export skip :: fn[T](self: Iterator(T), n: usize) -> SkipIterator(T) {
    return SkipIterator(T) { .source = self, .remaining = n }
}

/// Lazy map. `next()` pulls one item from `source`, transforms it via `f`,
/// and yields it. Stops when the source is exhausted.
/// Construct as `MapIterator(T, U) { .source = it, .f = mapper }`.
export MapIterator :: struct[T, U] {
    source: Iterator(T)
    f:      fn(T) -> U
}

MapIterator[T, U] implements Iterator[U] {
    next :: fn(self) -> Yield(U) | null {
        match self.source.next() {
            is null         -> { return null }
            is Yield(T) as y -> { return Yield(U) { .value = self.f(y.value) } }
        }
        return null
    }
}

/// Lazy filter. `next()` pulls items from `source` until `pred` returns
/// `true` ; that one is yielded, the next call resumes the search.
/// Construct as `FilterIterator(T) { .source = it, .pred = predicate }`.
export FilterIterator :: struct[T] {
    source: Iterator(T)
    pred:   fn(T) -> bool
}

FilterIterator[T] implements Iterator[T] {
    next :: fn(self) -> Yield(T) | null {
        finished := false
        for !finished {
            match self.source.next() {
                is null          -> { finished = true }
                is Yield(T) as y -> {
                    if self.pred(y.value) {
                        return Yield(T) { .value = y.value }
                    }
                }
            }
        }
        return null
    }
}

/// Lazy take. Yields the first `remaining` items from `source` and then
/// stops. `remaining` counts down across calls — once it hits zero the
/// iterator returns `null` even if `source` still has items.
/// Construct as `TakeIterator(T) { .source = it, .remaining = n }`.
export TakeIterator :: struct[T] {
    source:    Iterator(T)
    remaining: usize
}

TakeIterator[T] implements Iterator[T] {
    next :: fn(self) -> Yield(T) | null {
        if self.remaining == 0 { return null }
        match self.source.next() {
            is null          -> { return null }
            is Yield(T) as y -> {
                self.remaining = self.remaining - 1
                return Yield(T) { .value = y.value }
            }
        }
        return null
    }
}

/// Lazy skip. Drops the first `remaining` items from `source` on the first
/// `next()` call, then forwards every subsequent item. After the prefix is
/// consumed `remaining` stays at zero so the steady state is a pass-through.
/// Construct as `SkipIterator(T) { .source = it, .remaining = n }`.
export SkipIterator :: struct[T] {
    source:    Iterator(T)
    remaining: usize
}

SkipIterator[T] implements Iterator[T] {
    next :: fn(self) -> Yield(T) | null {
        for self.remaining > 0 {
            match self.source.next() {
                is null    -> {
                    self.remaining = 0
                    return null
                }
                is Yield(T) -> {
                    self.remaining = self.remaining - 1
                }
            }
        }
        match self.source.next() {
            is null          -> { return null }
            is Yield(T) as y -> { return Yield(T) { .value = y.value } }
        }
        return null
    }
}

// ---------------------------------------------------------------------- tests

import "std/testing" { assert, assert_eq, fail }

@test test_count :: fn() -> void {
    assert_eq([1, 2, 3].count(), usize(3))
    empty: i32[] = []
    assert_eq(empty.count(), usize(0))
}

@test test_sum :: fn() -> void {
    assert_eq(sum([1, 2, 3, 4]), 10)
    empty: i32[] = []
    assert_eq(sum(empty), 0)
}

@test test_map :: fn() -> void {
    out :: [1, 2, 3].map((x: i32) -> x * 2)
    assert_eq(out.count(), usize(3))
    assert_eq(out[usize(0)], 2)
    assert_eq(out[usize(1)], 4)
    assert_eq(out[usize(2)], 6)
}

@test test_filter :: fn() -> void {
    out :: [1, 2, 3, 4, 5].filter((x: i32) -> x % 2 == 0)
    assert_eq(out.count(), usize(2))
    assert_eq(out[usize(0)], 2)
    assert_eq(out[usize(1)], 4)
}

@test test_fold :: fn() -> void {
    total :: [1, 2, 3, 4].fold(0, (acc: i32, x: i32) -> acc + x)
    assert_eq(total, 10)
    product :: [2, 3, 4].fold(1, (acc: i32, x: i32) -> acc * x)
    assert_eq(product, 24)
}

@test test_take :: fn() -> void {
    out :: [1, 2, 3, 4, 5].take(usize(3))
    assert_eq(out.count(), usize(3))
    assert_eq(out[usize(2)], 3)
    assert_eq([1, 2].take(usize(10)).count(), usize(2))
}

@test test_skip :: fn() -> void {
    out :: [1, 2, 3, 4, 5].skip(usize(2))
    assert_eq(out.count(), usize(3))
    assert_eq(out[usize(0)], 3)
    assert_eq([1, 2].skip(usize(10)).count(), usize(0))
}

@test test_slice :: fn() -> void {
    out :: [1, 2, 3, 4, 5].slice(usize(1), usize(4))
    assert_eq(out.count(), usize(3))
    assert_eq(out[usize(0)], 2)
    assert_eq(out[usize(2)], 4)
}

@test test_chain :: fn() -> void {
    out :: chain([1, 2], [3, 4, 5])
    assert_eq(out.count(), usize(5))
    assert_eq(out[usize(0)], 1)
    assert_eq(out[usize(4)], 5)
}

@test test_enumerate :: fn() -> void {
    pairs :: ["a", "b", "c"].enumerate()
    assert_eq(pairs.count(), usize(3))
    [i0, s0] :: pairs[usize(0)]
    assert_eq(i0, usize(0))
    assert_eq(s0, "a")
    [i2, s2] :: pairs[usize(2)]
    assert_eq(i2, usize(2))
    assert_eq(s2, "c")
}

@test test_any :: fn() -> void {
    assert([1, 2, 3].any((x: i32) -> x == 2), "should find 2")
    assert(![1, 2, 3].any((x: i32) -> x == 9), "should not find 9")
    empty: i32[] = []
    assert(!empty.any((x: i32) -> true), "empty array is never any")
}

@test test_all :: fn() -> void {
    assert([2, 4, 6].all((x: i32) -> x % 2 == 0), "all even")
    assert(![2, 3, 6].all((x: i32) -> x % 2 == 0), "3 is odd")
    empty: i32[] = []
    assert(empty.all((x: i32) -> false), "empty array satisfies all (vacuous)")
}

@test test_find :: fn() -> void {
    match [1, 2, 3, 4].find((x: i32) -> x > 2) {
        is i32 as hit -> assert_eq(hit, 3)
        is null       -> fail("expected to find 3")
    }
    match [1, 2, 3].find((x: i32) -> x > 99) {
        is i32 -> fail("should not find anything")
        is null -> {}
    }
}

@test test_find_map :: fn() -> void {
    parse_positive :: fn(x: i32) -> i32 | null {
        if x > 0 { return x * 10 }
        return null
    }
    match [-1, -2, 3, 4].find_map(parse_positive) {
        is i32 as hit -> assert_eq(hit, 30)
        is null       -> fail("expected first positive")
    }
    match [-1, -2, -3].find_map(parse_positive) {
        is i32 -> fail("should not find anything")
        is null -> {}
    }
}
