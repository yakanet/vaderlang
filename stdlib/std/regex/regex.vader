// std/regex — Thompson NFA regex engine.
//
// MVP scope :
//   * Literal bytes, `.`, escapes (`\n` / `\t` / `\r` / `\\` / `\.` …).
//   * Char classes : `[abc]`, `[^abc]`, `[a-z]` plus the `\d` / `\D` /
//     `\w` / `\W` / `\s` / `\S` shorthands (ASCII-only).
//   * Quantifiers : `*`, `+`, `?`, `{n}`, `{n,}`, `{n,m}` — all greedy.
//   * Alternation `a|b`.
//   * Groups `(…)` — every group captures, addressable by index 1..N.
//   * Anchors `^`, `$` (whole-input, not multiline).
//
// Hors-scope (post-MVP) : non-greedy `*?`, named groups `(?<x>…)`,
// backrefs `\1`, lookaround `(?=…)` / `(?!…)`, Unicode properties.
//
// Algorithm : Thompson VM (Cox, "Regular Expression Matching: the
// Virtual Machine Approach"). Each compiled `Pattern` is an array of
// `Inst` ops ; matching runs a BFS over a `Thread` set, and `add_thread`
// deduplicates by pc within each step (the `seen` generation array), so a
// step holds at most one thread per instruction. That per-pc dedup is what
// makes the worst case O(n × m) (input length × program length) — no
// catastrophic backtracking — and what bounds the epsilon-closure recursion
// on cyclic programs like `(a*)*`. Captures use the `Save N` op writing the
// current input offset into the thread's `groups` array.
//
// Pure Vader, zero host imports — WASM-ready as-is.

module "std/regex"

import "std/string" { utf8_decode, utf8_decode_len, is_empty }
import "std/string_builder" { StringBuilder, append, append_char }

// =========================================================================
// Public surface
// =========================================================================

/// Compiled regex. Treat as opaque — the field layout may change.
export Pattern :: struct {
    @internal
    insts:       Inst[]
    @internal
    group_count: usize
}

/// A successful match. `start` and `end` are byte offsets into the
/// input string (`end` exclusive). `groups[0]` is always the whole
/// match ; `groups[i]` (1 ≤ i ≤ group_count) is the i-th capture, or
/// empty if the group never matched.
export Match :: struct {
    start:  usize
    end:    usize
    groups: string[]
}

/// Error returned by `compile` when the pattern doesn't parse.
export RegexError :: struct {
    msg:      string
    position: usize
}

RegexError implements Error {
    message :: fn(self) -> string { return "${self.msg} (at position ${self.position})" }
}

// =========================================================================
// Instruction set (Cox VM)
// =========================================================================

export Inst :: InstChar | InstAny | InstClass | InstMatch | InstJump | InstSplit | InstSave | InstAnchorStart | InstAnchorEnd

/// Match a single literal codepoint `c`. Advances input by one char.
export InstChar :: struct {
    c: char
}

/// Match any codepoint except `\n`.
export InstAny :: struct {}

/// Match any codepoint in `ranges`. Each `[lo, hi]` is inclusive ;
/// `negated == true` flips the membership test.
export InstClass :: struct {
    ranges:  CharRange[]
    negated: bool
}

CharRange :: struct {
    lo: char
    hi: char
}

/// Accept state.
export InstMatch :: struct {}

/// Unconditional jump to `target`.
export InstJump :: struct {
    target: usize
}

/// Non-deterministic split — spawn one thread at `a`, another at `b`.
export InstSplit :: struct {
    a: usize
    b: usize
}

/// Record the current input offset into `groups[slot]` (and advance pc).
/// Slot `0` / `1` = group 0 start/end (whole match) ;
/// `2 * i` / `2 * i + 1` = group `i` start/end.
export InstSave :: struct {
    slot: usize
}

/// `^` — match only at input position 0.
export InstAnchorStart :: struct {}
/// `$` — match only at input length.
export InstAnchorEnd :: struct {}

// =========================================================================
// Compile (parse + emit)
// =========================================================================

Parser :: struct {
    // Pattern bytes (held once at `compile`) — all parsing works on the
    // byte view, so the pattern's `string` is never re-fetched.
    bytes:          const u8[]
    cursor:         usize
    insts:          Inst[]
    next_group_id:  usize
    // Current group-nesting depth. Bumped on each `(` descent and capped at
    // MAX_GROUP_DEPTH so a pathological `(((…` can't overflow the parser's
    // mutual recursion (would crash `compile` instead of returning RegexError).
    depth:          usize
}

// Maximum `(...)` nesting the parser accepts. Well under the VM's 1024-frame
// limit, so a hostile pattern gets a clean RegexError, not a stack overflow.
MAX_GROUP_DEPTH: usize: 200

/// Compile a regex source string into a `Pattern`. Anchors `^`/`$`
/// inside the pattern bind to the input boundaries. The pattern is
/// implicitly anchored at the start during `matches` (whole input)
/// and unanchored during `find` / `find_all` / `replace_all`.
export compile :: fn(pattern: string) -> Pattern | RegexError {
    p := Parser {
        .bytes = pattern.bytes(),
        .cursor = 0,
        .insts = [],
        .next_group_id = 1,
        .depth = 0,
    }

    // Wrap the entire pattern in implicit group 0 so `groups[0]` is
    // the whole match.
    p.insts.push(InstSave { .slot = 0 })
    parse_outcome :: parse_alternation(p)
    if parse_outcome is RegexError { return parse_outcome }
    if p.cursor < p.bytes.len() {
        return RegexError { .msg = "unexpected character '${p.bytes.utf8_decode(p.cursor)}'", .position = p.cursor }
    }
    p.insts.push(InstSave { .slot = 1 })
    p.insts.push(InstMatch {})

    return Pattern { .insts = p.insts, .group_count = p.next_group_id - 1 }
}

parse_alternation :: fn(p: Parser) -> RegexError | null {
    branch_start :: p.insts.len()
    err1 :: parse_concat(p)
    if err1 is RegexError { return err1 }
    if p.cursor >= p.bytes.len() || p.bytes[p.cursor] != '|' {
        return null
    }

    // Flat `branches_buf` + `branch_offsets[i..i+1]` slice. A nested
    // `Inst[][]` would be more direct but the current code generator
    // doesn't handle indexing into one.
    branches_buf: Inst[] = []
    branch_offsets: usize[] = [0]
    branches_buf.push_all(extract_range(p.insts, branch_start, p.insts.len()))
    branch_offsets.push(branches_buf.len())
    p.insts = truncate_to(p.insts, branch_start)

    for p.cursor < p.bytes.len() && p.bytes[p.cursor] == '|' {
        p.cursor = p.cursor + 1
        next_start :: p.insts.len()
        err :: parse_concat(p)
        if err is RegexError { return err }
        branches_buf.push_all(extract_range(p.insts, next_start, p.insts.len()))
        branch_offsets.push(branches_buf.len())
        p.insts = truncate_to(p.insts, next_start)
    }

    // For N branches, emit a chain :
    //   Split L_0_body, S_1
    //   <b_0> ; Jump end
    //   S_1: Split L_1_body, S_2
    //   <b_1> ; Jump end
    //   ...
    //   S_{N-1}: <b_{N-1}>
    //   end:
    n :: branch_offsets.len() - 1
    end_jumps: usize[] = []
    for i in 0..<n - 1 {
        split_pos :: p.insts.len()
        p.insts.push(InstSplit { .a = 0, .b = 0 })
        body_pos :: p.insts.len()
        push_fragment_rebased(p.insts, branches_buf, branch_offsets[i], branch_offsets[i + 1], branch_start)
        jump_pos :: p.insts.len()
        p.insts.push(InstJump { .target = 0 })
        end_jumps.push(jump_pos)
        next_split_pos :: p.insts.len()
        p.insts[split_pos] = InstSplit { .a = body_pos, .b = next_split_pos }
    }
    last :: n - 1
    push_fragment_rebased(p.insts, branches_buf, branch_offsets[last], branch_offsets[last + 1], branch_start)
    end_pos :: p.insts.len()
    for k in 0..<end_jumps.len() {
        p.insts[end_jumps[k]] = InstJump { .target = end_pos }
    }
    return null
}

// Re-emit `src[lo..<hi]` — a self-contained fragment whose first
// instruction originally sat at absolute index `old_start` — at the end
// of `dst`, shifting every `Split` / `Jump` target by the displacement.
// Targets are absolute instruction indices, and the quantifier wrappers
// and the alternation both MOVE compiled fragments (a split gets
// inserted before them, or copies land further down) : re-emitting a
// composite fragment un-rebased (`(a|b)*`, `(a*)*`, `(a|b){2,3}`)
// self-loops or jumps into the wrong instruction.
// Whole-fragment form — the common case for the quantifier wrappers.
push_atom_rebased :: fn(dst: Inst[], atom: Inst[], old_start: usize) = push_fragment_rebased(dst, atom, 0, atom.len(), old_start)

push_fragment_rebased :: fn(dst: Inst[], src: Inst[], lo: usize, hi: usize, old_start: usize) -> void {
    shift :: dst.len() - old_start
    for i in lo..<hi {
        inst :: src[i]
        match inst {
            is InstSplit -> { dst.push(InstSplit { .a = inst.a + shift, .b = inst.b + shift }) }
            is InstJump  -> { dst.push(InstJump { .target = inst.target + shift }) }
            _ -> { dst.push(inst) }
        }
    }
}

parse_concat :: fn(p: Parser) -> RegexError | null {
    for p.cursor < p.bytes.len() {
        b :: p.bytes[p.cursor]
        if b == ')' || b == '|' { break }
        err :: parse_atom_with_quantifier(p)
        if err is RegexError { return err }
    }
    return null
}

parse_atom_with_quantifier :: fn(p: Parser) -> RegexError | null {
    atom_start :: p.insts.len()
    err :: parse_atom(p)
    if err is RegexError { return err }
    if p.cursor >= p.bytes.len() { return null }
    q :: p.bytes[p.cursor]
    if q == '*' {
        p.cursor = p.cursor + 1
        apply_star(p, atom_start)
        return null
    }
    if q == '+' {
        p.cursor = p.cursor + 1
        apply_plus(p, atom_start)
        return null
    }
    if q == '?' {
        p.cursor = p.cursor + 1
        apply_optional(p, atom_start)
        return null
    }
    if q == '{' { return apply_counted(p, atom_start) }
    return null
}

// Star (greedy) — wrap the atom in :
//   L1: Split L2, L3
//   L2: <atom>
//       Jump L1
//   L3:
apply_star :: fn(p: Parser, atom_start: usize) -> void {
    atom :: extract_range(p.insts, atom_start, p.insts.len())
    p.insts = truncate_to(p.insts, atom_start)
    split_pos :: p.insts.len()
    p.insts.push(InstSplit { .a = 0, .b = 0 })
    body_start :: p.insts.len()
    push_atom_rebased(p.insts, atom, atom_start)
    p.insts.push(InstJump { .target = split_pos })
    after :: p.insts.len()
    p.insts[split_pos] = InstSplit { .a = body_start, .b = after }
}

// Plus (greedy) — execute the atom once, then star-loop :
//   L1: <atom>
//       Split L1, L2
//   L2:
apply_plus :: fn(p: Parser, atom_start: usize) -> void {
    split_pos :: p.insts.len()
    p.insts.push(InstSplit { .a = 0, .b = 0 })
    after :: p.insts.len()
    p.insts[split_pos] = InstSplit { .a = atom_start, .b = after }
}

// Optional (greedy) :
//   Split L_atom, L_after
//   L_atom: <atom>
//   L_after:
apply_optional :: fn(p: Parser, atom_start: usize) -> void {
    atom :: extract_range(p.insts, atom_start, p.insts.len())
    p.insts = truncate_to(p.insts, atom_start)
    p.insts.push(InstSplit { .a = atom_start + 1, .b = 0 })
    push_atom_rebased(p.insts, atom, atom_start)
    after :: p.insts.len()
    // Patch the split's second target now that we know `after`.
    sp :: atom_start
    p.insts[sp] = InstSplit { .a = atom_start + 1, .b = after }
}

/// Largest count accepted in `{n}` / `{n,}` / `{n,m}`. Counted repeats
/// expand to physical instruction copies, so the ceiling bounds both
/// compile time and program size (RE2, the architectural sibling, uses
/// the same limit).
REPEAT_MAX: usize: 1000

/// Ceiling on the compiled program size. Nested counted repeats multiply
/// (`((a{1000}){1000}){1000}` passes the per-count check three times but
/// would materialise ~1e9 instructions) — checked after each counted
/// expansion.
PROGRAM_MAX: usize: 100_000

apply_counted :: fn(p: Parser, atom_start: usize) -> RegexError | null {
    if p.bytes[p.cursor] != '{' { return null }
    save_cursor :: p.cursor
    p.cursor = p.cursor + 1
    n_outcome :: parse_decimal_usize(p)
    if n_outcome is RegexError { return n_outcome }
    n :: n_outcome
    m: usize = n
    has_comma: bool = false
    has_upper: bool = false
    if p.cursor < p.bytes.len() && p.bytes[p.cursor] == ',' {
        p.cursor = p.cursor + 1
        has_comma = true
        if p.cursor < p.bytes.len() && p.bytes[p.cursor] != '}' {
            m_outcome :: parse_decimal_usize(p)
            if m_outcome is RegexError { return m_outcome }
            m = m_outcome
            has_upper = true
        }
    }
    if p.cursor >= p.bytes.len() || p.bytes[p.cursor] != '}' {
        return RegexError { .msg = "unterminated {n,m}", .position = save_cursor }
    }
    p.cursor = p.cursor + 1
    if has_upper && m < n {
        return RegexError { .msg = "invalid {n,m}: max is smaller than min", .position = save_cursor }
    }
    // Each count expands to physical copies of the atom, so an unchecked
    // count is a compile-time memory bomb (`a{999999999}`).
    if n > REPEAT_MAX || m > REPEAT_MAX {
        return RegexError { .msg = "repetition count exceeds ${REPEAT_MAX}", .position = save_cursor }
    }

    // Snapshot the atom we just emitted.
    atom :: extract_range(p.insts, atom_start, p.insts.len())
    p.insts = truncate_to(p.insts, atom_start)

    // Mandatory N copies.
    for _ in 0..<n {
        push_atom_rebased(p.insts, atom, atom_start)
    }

    if has_upper {
        // {n,m} : up to (m - n) optional copies. Each one : Split atom, after.
        diff :: m - n
        splits: usize[] = []
        for _ in 0..<diff {
            split_pos :: p.insts.len()
            splits.push(split_pos)
            p.insts.push(InstSplit { .a = 0, .b = 0 })
            push_atom_rebased(p.insts, atom, atom_start)
        }
        after :: p.insts.len()
        for k in 0..<splits.len() {
            sp :: splits[k]
            p.insts[sp] = InstSplit { .a = sp + 1, .b = after }
        }
    } else {
        if has_comma {
            // {n,} : star-style unbounded tail after the mandatory N.
            sp :: p.insts.len()
            p.insts.push(InstSplit { .a = 0, .b = 0 })
            body_start :: p.insts.len()
            push_atom_rebased(p.insts, atom, atom_start)
            p.insts.push(InstJump { .target = sp })
            after :: p.insts.len()
            p.insts[sp] = InstSplit { .a = body_start, .b = after }
        }
        // {n} : exactly n — nothing more to emit.
    }
    if p.insts.len() > PROGRAM_MAX {
        return RegexError { .msg = "compiled pattern exceeds ${PROGRAM_MAX} instructions", .position = save_cursor }
    }
    return null
}

parse_atom :: fn(p: Parser) -> RegexError | null {
    if p.cursor >= p.bytes.len() {
        return RegexError { .msg = "unexpected end of pattern", .position = p.cursor }
    }
    b :: p.bytes[p.cursor]
    if b == '(' {
        p.depth = p.depth + 1
        if p.depth > MAX_GROUP_DEPTH {
            return RegexError { .msg = "maximum group nesting depth (${MAX_GROUP_DEPTH}) exceeded", .position = p.cursor }
        }
        p.cursor = p.cursor + 1
        group_id :: p.next_group_id
        p.next_group_id = p.next_group_id + 1
        p.insts.push(InstSave { .slot = 2 * group_id })
        err :: parse_alternation(p)
        if err is RegexError { return err }
        if p.cursor >= p.bytes.len() || p.bytes[p.cursor] != ')' {
            return RegexError { .msg = "unterminated group", .position = p.cursor }
        }
        p.cursor = p.cursor + 1
        p.depth = p.depth - 1
        p.insts.push(InstSave { .slot = 2 * group_id + 1 })
        return null
    }
    if b == '.' {
        p.cursor = p.cursor + 1
        p.insts.push(InstAny {})
        return null
    }
    if b == '^' {
        p.cursor = p.cursor + 1
        p.insts.push(InstAnchorStart {})
        return null
    }
    if b == '$' {
        p.cursor = p.cursor + 1
        p.insts.push(InstAnchorEnd {})
        return null
    }
    if b == '[' {
        return parse_char_class(p)
    }
    if b == '\\' {
        return parse_escape(p)
    }
    // Otherwise : a literal byte. Decode the codepoint at this offset to
    // emit `InstChar` so the matcher and the pattern stay codepoint-aligned.
    [c, advance] :: p.bytes.utf8_decode_len(p.cursor)
    p.cursor = p.cursor + advance
    p.insts.push(InstChar { .c = c })
    return null
}

parse_escape :: fn(p: Parser) -> RegexError | null {
    p.cursor = p.cursor + 1
    if p.cursor >= p.bytes.len() {
        return RegexError { .msg = "trailing backslash", .position = p.cursor }
    }
    e :: p.bytes[p.cursor]
    p.cursor = p.cursor + 1
    if e == 'n' {
        p.insts.push(InstChar { .c = '\n' })
        return null
    }
    if e == 't' {
        p.insts.push(InstChar { .c = '\t' })
        return null
    }
    if e == 'r' {
        p.insts.push(InstChar { .c = '\r' })
        return null
    }
    if e == 'd' {
        p.insts.push(InstClass { .ranges = [CharRange { .lo = '0', .hi = '9' }], .negated = false })
        return null
    }
    if e == 'D' {
        p.insts.push(InstClass { .ranges = [CharRange { .lo = '0', .hi = '9' }], .negated = true })
        return null
    }
    if e == 'w' {
        p.insts.push(InstClass { .ranges = word_class_ranges(), .negated = false })
        return null
    }
    if e == 'W' {
        p.insts.push(InstClass { .ranges = word_class_ranges(), .negated = true })
        return null
    }
    if e == 's' {
        p.insts.push(InstClass { .ranges = space_class_ranges(), .negated = false })
        return null
    }
    if e == 'S' {
        p.insts.push(InstClass { .ranges = space_class_ranges(), .negated = true })
        return null
    }
    // Literal escape : the byte itself becomes the char.
    p.insts.push(InstChar { .c = char(u32(e)) })
    return null
}

parse_char_class :: fn(p: Parser) -> RegexError | null {
    start_pos :: p.cursor
    p.cursor = p.cursor + 1
    negated: bool = false
    if p.cursor < p.bytes.len() && p.bytes[p.cursor] == '^' {
        negated = true
        p.cursor = p.cursor + 1
    }
    ranges: CharRange[] = []
    for p.cursor < p.bytes.len() && p.bytes[p.cursor] != ']' {
        lo_c :: read_class_char(p)
        if lo_c is RegexError { return lo_c }
        is_range :: p.cursor < p.bytes.len() && p.bytes[p.cursor] == '-' && p.cursor + 1 < p.bytes.len() && p.bytes[p.cursor + 1] != ']'
        if is_range {
            p.cursor = p.cursor + 1
            hi_c :: read_class_char(p)
            if hi_c is RegexError { return hi_c }
            ranges.push(CharRange { .lo = lo_c, .hi = hi_c })
        } else {
            ranges.push(CharRange { .lo = lo_c, .hi = lo_c })
        }
    }
    if p.cursor >= p.bytes.len() {
        return RegexError { .msg = "unterminated character class", .position = start_pos }
    }
    p.cursor = p.cursor + 1
    p.insts.push(InstClass { .ranges = ranges, .negated = negated })
    return null
}

read_class_char :: fn(p: Parser) -> char | RegexError {
    if p.cursor >= p.bytes.len() {
        return RegexError { .msg = "unexpected end inside character class", .position = p.cursor }
    }
    b :: p.bytes[p.cursor]
    if b == '\\' {
        p.cursor = p.cursor + 1
        if p.cursor >= p.bytes.len() {
            return RegexError { .msg = "trailing backslash inside class", .position = p.cursor }
        }
        e :: p.bytes[p.cursor]
        p.cursor = p.cursor + 1
        if e == 'n' { return '\n' }
        if e == 't' { return '\t' }
        if e == 'r' { return '\r' }
        return char(u32(e))
    }
    [c, advance] :: p.bytes.utf8_decode_len(p.cursor)
    p.cursor = p.cursor + advance
    return c
}

parse_decimal_usize :: fn(p: Parser) -> usize | RegexError {
    if p.cursor >= p.bytes.len() || p.bytes[p.cursor] < '0' || p.bytes[p.cursor] > '9' {
        return RegexError { .msg = "expected digit", .position = p.cursor }
    }
    acc: usize = 0
    for p.cursor < p.bytes.len() && p.bytes[p.cursor] >= '0' && p.bytes[p.cursor] <= '9' {
        acc = acc * 10 + usize(p.bytes[p.cursor] - '0')
        p.cursor = p.cursor + 1
    }
    return acc
}

word_class_ranges :: fn() -> CharRange[] {
    return [
        CharRange { .lo = '0', .hi = '9' },
        CharRange { .lo = 'A', .hi = 'Z' },
        CharRange { .lo = 'a', .hi = 'z' },
        CharRange { .lo = '_', .hi = '_' },
    ]
}

space_class_ranges :: fn() -> CharRange[] {
    return [
        CharRange { .lo = ' ',  .hi = ' '  },
        CharRange { .lo = '\t', .hi = '\t' },
        CharRange { .lo = '\n', .hi = '\n' },
        CharRange { .lo = '\r', .hi = '\r' },
    ]
}

// Number of UTF-8 bytes occupied by the codepoint starting at `offset`.
// Width-only wrapper over the shared `utf8_decode_len` (std/string).
codepoint_byte_advance :: fn(bs: const u8[], offset: usize) -> usize {
    [c, width] :: bs.utf8_decode_len(offset)
    return width
}

// These wrap the built-in zero-copy slice + `push_all` intrinsic. The earlier
// hand-rolled element loops existed because the generic `std/iter.slice` /
// `iter.take` trap under monomorphization for `Inst[]` ; the built-in
// `arr[lo..<hi]` (ArraySlice op) and `dst.push_all(src)` (ArrayPushAll op) are
// intrinsics that see the concrete element type post-mono, so they don't.
// `push_all` itself is now a built-in array method — no local helper needed.
extract_range :: fn(arr: Inst[], start: usize, end: usize) -> Inst[] {
    view :: arr[start..<end]
    out: Inst[] = [] * view.len()
    out.push_all(view)
    return out
}

truncate_to :: fn(arr: Inst[], n: usize) = extract_range(arr, 0, n)

// =========================================================================
// Match / Search
// =========================================================================

/// True iff `input` is matched by `pattern` from offset 0 to its end
/// (anchored on both sides).
export matches :: fn(self: Pattern, input: string) = run_vm(self, input.bytes(), 0, true) is Match

/// Find the first match anywhere in `input` (leftmost). Returns `null`
/// when there's no match.
export find :: fn(self: Pattern, input: string) -> Match | null {
    ib :: input.bytes()
    start: usize = 0
    for start <= ib.len() {
        m :: run_at(self, ib, start)
        if m is Match { return m }
        if start == ib.len() { return null }
        start = start + codepoint_byte_advance(ib, start)
    }
    return null
}

/// All non-overlapping matches in `input`, left-to-right. Empty matches
/// advance by one codepoint to avoid an infinite loop.
export find_all :: fn(self: Pattern, input: string) -> Match[] {
    ib :: input.bytes()
    out: Match[] = []
    start: usize = 0
    for start <= ib.len() {
        m :: run_at(self, ib, start)
        if m is Match {
            out.push(m)
            if m.end == start {
                if start >= ib.len() { return out }
                start = start + codepoint_byte_advance(ib, start)
            } else {
                start = m.end
            }
        } else {
            if start >= ib.len() { return out }
            start = start + codepoint_byte_advance(ib, start)
        }
    }
    return out
}

/// Replace every non-overlapping match with `repl`. Supports `$0..$9`
/// backrefs inside `repl`.
export replace_all :: fn(self: Pattern, input: string, repl: string) -> string {
    ib :: input.bytes()
    rb :: repl.bytes()
    sb := StringBuilder {}
    cursor: usize = 0
    matches_found :: self.find_all(input)
    for i in 0..<matches_found.len() {
        m :: matches_found[i]
        // Append the gap before this match.
        sb.append(ib[cursor..<m.start].bytes_to_string())
        // Expand backrefs in the replacement.
        expand_replacement(sb, rb, m)
        cursor = m.end
    }
    if cursor < ib.len() {
        sb.append(ib[cursor..<ib.len()].bytes_to_string())
    }
    return sb.to_string()
}

expand_replacement :: fn(sb: StringBuilder, rb: const u8[], m: Match) -> void {
    n :: rb.len()
    i: usize = 0
    for i < n {
        b :: rb[i]
        if b == '$' && i + 1 < n {
            d :: rb[i + 1]
            if d >= '0' && d <= '9' {
                gi :: usize(d - '0')
                if gi < m.groups.len() {
                    sb.append(m.groups[gi])
                }
                i = i + 2
                continue
            }
        }
        [c, w] :: rb.utf8_decode_len(i)
        sb.append_char(c)
        i = i + w
    }
}

// =========================================================================
// Thompson VM execution
// =========================================================================

Thread :: struct {
    pc:     usize
    groups: usize[]
}

// Sentinel for "this slot was never written". `_u64` is mandatory :
// without it the literal defaults to a signed type and rounds through
// f64, so the sentinel collides with valid offsets on native.
SLOT_UNSET :: usize(0xFFFF_FFFF_FFFF_FFFF)

run_at :: fn(p: Pattern, input: const u8[], start: usize) = run_vm(p, input, start, false)

/// One Thompson-VM run from `start`. `full` selects full-match semantics :
/// an `InstMatch` only counts when the whole input is consumed, and a
/// shorter match does NOT cut lower-priority threads — `a|ab` must still
/// try `ab` after `a` matched a prefix (leftmost-first would otherwise
/// make `matches` depend on alternative order).
run_vm :: fn(p: Pattern, input: const u8[], start: usize, full: bool) -> Match | null {
    slots :: 2 * (p.group_count + 1)
    current: Thread[] = []
    next: Thread[] = []
    // Per-step pc dedup : `seen[pc] == gen` means pc already holds a
    // (higher-priority) thread this step. Kills the exponential thread
    // blowup on `(a+)+` AND bounds `add_thread`'s epsilon recursion on
    // cyclic programs (`(a*)*`).
    seen: usize[] = [0] * p.insts.len()
    gen: usize = 1

    seed_groups: usize[] = [SLOT_UNSET] * slots
    add_thread(current, 0, seed_groups, p, input, start, seen, gen)

    matched: Match | null = null
    pos := start
    for pos <= input.len() {
        c_at_pos: char = ' '
        bytes_consumed: usize = 0
        if pos < input.len() {
            [c, w] :: input.utf8_decode_len(pos)
            c_at_pos = c
            bytes_consumed = w
        }
        t_idx: usize = 0
        for t_idx < current.len() {
            t :: current[t_idx]
            inst :: p.insts[t.pc]
            match inst {
                is InstChar -> {
                    if pos < input.len() && c_at_pos == inst.c {
                        add_thread(next, t.pc + 1, t.groups, p, input, pos + bytes_consumed, seen, gen + 1)
                    }
                }
                is InstAny -> {
                    if pos < input.len() && c_at_pos != '\n' {
                        add_thread(next, t.pc + 1, t.groups, p, input, pos + bytes_consumed, seen, gen + 1)
                    }
                }
                is InstClass -> {
                    if pos < input.len() && class_matches(inst, c_at_pos) {
                        add_thread(next, t.pc + 1, t.groups, p, input, pos + bytes_consumed, seen, gen + 1)
                    }
                }
                is InstMatch -> {
                    // Full-match mode ignores a prefix match : it neither
                    // records nor cuts lower-priority threads — an
                    // alternative ordered later may still consume the
                    // whole input.
                    if !full || pos == input.len() {
                        matched = Match {
                            .start  = if t.groups.len() > 0 { resolve_slot(t.groups[0], start) } else { start },
                            .end    = if t.groups.len() > 1 { resolve_slot(t.groups[1], pos) } else { pos },
                            .groups = captured_groups(t, input),
                        }
                        // Higher-priority threads run first ; once one matches
                        // we discard lower-priority threads to mirror leftmost-
                        // first semantics.
                        current = truncate_threads(current, t_idx)
                        t_idx = current.len()
                        continue
                    }
                }
                is InstJump   -> {}    // Handled by add_thread's epsilon closure.
                is InstSplit  -> {}
                is InstSave   -> {}
                is InstAnchorStart -> {}
                is InstAnchorEnd   -> {}
            }
            t_idx = t_idx + 1
        }
        if pos == input.len() { break }
        current = next
        next = []
        gen = gen + 1
        // No live thread can ever spawn another — without this exit a
        // failed run walks the rest of the input doing nothing, and
        // `find` (one run per start) turns O(n^2)-with-empty-loops.
        if current.len() == 0 { break }
        pos = pos + bytes_consumed
    }
    return matched
}

class_matches :: fn(inst: InstClass, c: char) -> bool {
    n :: inst.ranges.len()
    for i in 0..<n {
        r :: inst.ranges[i]
        if c in r.lo..=r.hi {
            if inst.negated { return false }
            return true
        }
    }
    return inst.negated
}

// Compute epsilon-closure starting at `pc`, appending all reachable
// non-epsilon states into `out`. `seen[pc] == gen` marks pcs already
// claimed this step : threads run in priority order, so the first
// arrival wins and later (lower-priority) arrivals at the same pc are
// dropped. This is the Thompson-VM invariant that bounds the step to
// one thread per instruction and the recursion to one visit per pc.
//
// `groups` is shared copy-on-write : only `InstSave` writes to it, so
// only `InstSave` copies — every other epsilon edge passes the array
// through, and leaf threads may alias one another's `groups` (read-only
// once constructed).
// One entry of `add_thread`'s explicit DFS stack : the pc to visit and the
// (copy-on-write) capture array reaching it.
WorkItem :: struct {
    pc:     usize
    groups: usize[]
}

add_thread :: fn(out: Thread[], start_pc: usize, start_groups: usize[], p: Pattern, input: const u8[], pos: usize, seen: usize[], gen: usize) -> void {
    // Iterative epsilon-closure (was recursive). A long ACYCLIC epsilon chain —
    // e.g. the N chained `InstSplit` a `a?`×N pattern compiles to — recursed one
    // frame per link and blew the stack (VM trap at 1024 frames) even though
    // `seen[]` bounds the total visit count. An explicit LIFO stack removes the
    // depth limit. Children are pushed in REVERSE of the recursive visit order so
    // they pop in order, preserving thread priority (first arrival at a pc wins ;
    // later arrivals are dropped by `seen`).
    stack: WorkItem[] = [WorkItem { .pc = start_pc, .groups = start_groups }]
    for stack.len() > 0 {
        item :: stack[stack.len() - 1]
        stack.remove_last()
        pc :: item.pc
        groups :: item.groups
        if seen[pc] == gen { continue }
        seen[pc] = gen
        inst :: p.insts[pc]
        match inst {
            is InstJump -> { stack.push(WorkItem { .pc = inst.target, .groups = groups }) }
            is InstSplit -> {
                // Recursion visited `a` before `b` (a = higher priority) ; on a
                // LIFO stack push `b` first so `a` pops — and fully drains — first.
                stack.push(WorkItem { .pc = inst.b, .groups = groups })
                stack.push(WorkItem { .pc = inst.a, .groups = groups })
            }
            is InstSave -> {
                g: usize[] = []
                g.push_all(groups)
                g[inst.slot] = pos
                stack.push(WorkItem { .pc = pc + 1, .groups = g })
            }
            is InstAnchorStart -> {
                if pos == 0 { stack.push(WorkItem { .pc = pc + 1, .groups = groups }) }
            }
            is InstAnchorEnd -> {
                if pos == input.len() { stack.push(WorkItem { .pc = pc + 1, .groups = groups }) }
            }
            is InstChar | InstAny | InstClass | InstMatch -> {
                out.push(Thread { .pc = pc, .groups = groups })
            }
        }
    }
}

resolve_slot :: fn(slot_value: usize, fallback: usize) -> usize {
    if slot_value == SLOT_UNSET { return fallback }
    return slot_value
}

captured_groups :: fn(t: Thread, input: const u8[]) -> string[] {
    n_groups :: t.groups.len() / 2
    out: string[] = []
    for i in 0..<n_groups {
        lo_slot :: t.groups[2 * i]
        hi_slot :: t.groups[2 * i + 1]
        if lo_slot == SLOT_UNSET || hi_slot == SLOT_UNSET {
            out.push("")
        } else {
            out.push(input[lo_slot..<hi_slot].bytes_to_string())
        }
    }
    return out
}

truncate_threads :: fn(threads: Thread[], cutoff: usize) -> Thread[] {
    out: Thread[] = []
    for i in 0..<cutoff {
        out.push(threads[i])
    }
    return out
}

// ---------------------------------------------------------------------- tests

import "std/testing" { assert_eq, assert }

@test test_compile_simple :: fn() -> void {
    p :: compile("abc")
    match p {
        is Pattern    -> assert(p.matches("abc"), "abc should match abc")
        is RegexError -> assert(false, "compile abc failed")
    }
}

@test test_matches_literal :: fn() -> void {
    p :: compile("hello")
    match p {
        is Pattern -> {
            assert(p.matches("hello"), "hello matches hello")
            assert(!p.matches("hell"),  "hello does not match hell")
            assert(!p.matches("hellox"), "hello matches whole input, not prefix")
        }
        is RegexError -> assert(false, "compile hello failed")
    }
}

@test test_dot :: fn() -> void {
    p :: compile("a.c")
    match p {
        is Pattern -> {
            assert(p.matches("abc"), "a.c matches abc")
            assert(p.matches("a c"), "a.c matches a c")
            assert(!p.matches("ac"),  "a.c needs three chars")
        }
        is RegexError -> assert(false, "compile a.c failed")
    }
}

@test test_quantifiers :: fn() -> void {
    star :: compile("ab*c")
    match star {
        is Pattern -> {
            assert(star.matches("ac"),    "ab*c matches ac")
            assert(star.matches("abc"),   "ab*c matches abc")
            assert(star.matches("abbbc"), "ab*c matches abbbc")
        }
        is RegexError -> assert(false, "compile ab*c failed")
    }
    plus :: compile("ab+c")
    match plus {
        is Pattern -> {
            assert(!plus.matches("ac"),    "ab+c rejects ac")
            assert(plus.matches("abc"),    "ab+c matches abc")
            assert(plus.matches("abbbc"),  "ab+c matches abbbc")
        }
        is RegexError -> assert(false, "compile ab+c failed")
    }
    opt :: compile("ab?c")
    match opt {
        is Pattern -> {
            assert(opt.matches("ac"),  "ab?c matches ac")
            assert(opt.matches("abc"), "ab?c matches abc")
            assert(!opt.matches("abbc"), "ab?c rejects abbc")
        }
        is RegexError -> assert(false, "compile ab?c failed")
    }
}

@test test_char_class :: fn() -> void {
    p :: compile("[abc]+")
    match p {
        is Pattern -> {
            assert(p.matches("abccab"), "[abc]+ matches abccab")
            assert(!p.matches("abd"),   "[abc]+ rejects abd")
        }
        is RegexError -> assert(false, "compile [abc]+ failed")
    }
    neg :: compile("[^abc]+")
    match neg {
        is Pattern -> {
            assert(neg.matches("xyz"),  "[^abc]+ matches xyz")
            assert(!neg.matches("a"),   "[^abc]+ rejects a")
        }
        is RegexError -> assert(false, "compile [^abc]+ failed")
    }
    range :: compile("[a-z]+")
    match range {
        is Pattern -> {
            assert(range.matches("hello"), "[a-z]+ matches hello")
            assert(!range.matches("Hello"), "[a-z]+ rejects Hello (upper)")
        }
        is RegexError -> assert(false, "compile [a-z]+ failed")
    }
}

@test test_shorthand_classes :: fn() -> void {
    p :: compile("\\d+")
    match p {
        is Pattern -> {
            assert(p.matches("12345"), "\\d+ matches 12345")
            assert(!p.matches("12a"),  "\\d+ rejects 12a (whole)")
        }
        is RegexError -> assert(false, "compile \\d+ failed")
    }
}

@test test_find :: fn() -> void {
    p :: compile("\\d+")
    match p {
        is Pattern -> {
            r :: p.find("price: 42 USD")
            match r {
                is Match -> {
                    assert_eq(r.start, 7)
                    assert_eq(r.end,   9)
                    assert_eq(r.groups[0], "42")
                }
                is null -> assert(false, "\\d+ should find 42")
            }
        }
        is RegexError -> assert(false, "compile \\d+ failed")
    }
}

@test test_find_all :: fn() -> void {
    p :: compile("[a-z]+")
    match p {
        is Pattern -> {
            matches_found :: p.find_all("abc def ghi")
            assert_eq(matches_found.len(), 3)
            assert_eq(matches_found[0].groups[0], "abc")
            assert_eq(matches_found[1].groups[0], "def")
            assert_eq(matches_found[2].groups[0], "ghi")
        }
        is RegexError -> assert(false, "compile [a-z]+ failed")
    }
}

@test test_anchors :: fn() -> void {
    p :: compile("^foo")
    match p {
        is Pattern -> {
            assert(p.find("foo bar") is Match,  "^foo finds prefix")
            assert(p.find("bar foo") is null,   "^foo rejects suffix")
        }
        is RegexError -> assert(false, "compile ^foo failed")
    }
}

@test test_compile_error :: fn() -> void {
    bad :: compile("[abc")
    match bad {
        is Pattern    -> assert(false, "[abc should not compile")
        is RegexError -> assert(true,  "got error as expected")
    }
}

@test test_counted :: fn() -> void {
    p :: compile("a{3}")
    match p {
        is Pattern -> {
            assert(p.matches("aaa"),  "a{3} matches aaa")
            assert(!p.matches("aa"),  "a{3} rejects aa")
            assert(!p.matches("aaaa"), "a{3} anchored — rejects aaaa")
        }
        is RegexError -> assert(false, "compile a{3} failed")
    }
    rng :: compile("a{2,4}")
    match rng {
        is Pattern -> {
            assert(!rng.matches("a"),    "a{2,4} rejects a")
            assert(rng.matches("aa"),    "a{2,4} matches aa")
            assert(rng.matches("aaaa"),  "a{2,4} matches aaaa")
            assert(!rng.matches("aaaaa"), "a{2,4} rejects aaaaa")
        }
        is RegexError -> assert(false, "compile a{2,4} failed")
    }
}

@test test_replace_all :: fn() -> void {
    p :: compile("\\d+")
    match p {
        is Pattern -> {
            assert_eq(p.replace_all("a1b22c333", "X"), "aXbXcX")
        }
        is RegexError -> assert(false, "compile \\d+ failed")
    }
}

@test test_composite_atom_quantifiers :: fn() -> void {
    // Regression: quantifier wrappers and the alternation re-emit compiled
    // fragments at shifted positions ; their internal Split / Jump targets
    // must be rebased (`push_fragment_rebased`). Un-rebased, `(a|b)*`
    // self-looped into a wrong instruction and never consumed input.
    alt_star :: compile("(a|b)*")
    match alt_star {
        is Pattern -> {
            assert(alt_star.matches("abab"), "(a|b)* matches abab")
            assert(alt_star.matches(""),     "(a|b)* matches empty")
            assert(!alt_star.matches("abc"), "(a|b)* rejects abc")
        }
        is RegexError -> assert(false, "compile (a|b)* failed")
    }
    star_star :: compile("(a*)*")
    match star_star {
        is Pattern -> {
            assert(star_star.matches("aaa"), "(a*)* matches aaa")
            assert(star_star.matches(""),    "(a*)* matches empty (no epsilon blowup)")
        }
        is RegexError -> assert(false, "compile (a*)* failed")
    }
    alt_counted :: compile("(a|b){2,3}")
    match alt_counted {
        is Pattern -> {
            assert(alt_counted.matches("ab"),   "(a|b){2,3} matches ab")
            assert(alt_counted.matches("aba"),  "(a|b){2,3} matches aba")
            assert(!alt_counted.matches("a"),   "(a|b){2,3} rejects a")
        }
        is RegexError -> assert(false, "compile (a|b){2,3} failed")
    }
}

@test test_counted_bounds_rejected :: fn() -> void {
    // Regression: `{2,1}` underflowed `m - n` (usize) and expanded ~1.8e19
    // copies ; `{999999999}` was a compile-time memory bomb. Both must be
    // clean RegexErrors.
    inverted :: compile("a{2,1}")
    assert(inverted is RegexError, "a{2,1} is rejected")
    huge :: compile("a{999999999}")
    assert(huge is RegexError, "a{999999999} exceeds REPEAT_MAX")
    at_max :: compile("a{1000}")
    assert(at_max is Pattern, "a{1000} is exactly at the ceiling")
}

@test test_fullmatch_alternative_order :: fn() -> void {
    // Regression: `matches` used find semantics — the leftmost-first match
    // `a` cut the `ab` alternative and made the result depend on
    // alternative order. Full-match mode only accepts whole-input matches.
    first_short :: compile("a|ab")
    first_long  :: compile("ab|a")
    match first_short {
        is Pattern -> assert(first_short.matches("ab"), "a|ab full-matches ab")
        is RegexError -> assert(false, "compile a|ab failed")
    }
    match first_long {
        is Pattern -> assert(first_long.matches("ab"), "ab|a full-matches ab")
        is RegexError -> assert(false, "compile ab|a failed")
    }
}

@test test_pathological_patterns_terminate :: fn() -> void {
    // Regression: without per-pc thread dedup in `add_thread`, `(a+)+c`
    // was exponential (ReDoS) — this input took >20s at N=22. With the
    // dedup the whole run is O(n × m).
    redos :: compile("(a+)+c")
    match redos {
        is Pattern -> {
            assert(!redos.matches("aaaaaaaaaaaaaaaaaaaaaaaaaaaab"), "(a+)+c rejects a…b fast")
            assert(redos.matches("aaaaaaaaaaaaaaaaaaaaaaaaaaaac"),  "(a+)+c matches a…c")
        }
        is RegexError -> assert(false, "compile (a+)+c failed")
    }
}

@test test_deep_group_nesting_rejected :: fn() -> void {
    // A pathological `(((…` must return RegexError, not overflow the parser's
    // mutual recursion (CR-h). 300 exceeds MAX_GROUP_DEPTH (200).
    sb := StringBuilder {}
    for _ in 0..<300 { sb.append_char('(') }
    sb.append_char('a')
    for _ in 0..<300 { sb.append_char(')') }
    r :: compile(sb.to_string())
    assert(r is RegexError, "deeply-nested groups must return RegexError, not crash")
}

@test test_long_optional_chain_matches :: fn() -> void {
    // Regression for CR-i : a long acyclic epsilon chain (`a?`×N) overflowed
    // add_thread's recursion (VM trapped at 1024 frames). The iterative closure
    // handles it, and the push/remove_last worklist stays bounded (owner
    // buf->length shrink in the runtime — no capacity-doubling detach).
    sb := StringBuilder {}
    for _ in 0..<1500 { sb.append("a?") }
    match compile(sb.to_string()) {
        is Pattern as p -> {
            assert(p.matches(""), "a?x1500 matches the empty string")
            assert(p.matches("aaa"), "a?x1500 matches `aaa`")
        }
        is RegexError -> assert(false, "a?x1500 must compile")
    }
}
