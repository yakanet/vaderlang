// std/sort — comparator-based sort on `[T]` arrays.
//
// Stable, O(n log n). Returns a freshly-allocated sorted copy ; the input
// array is never mutated. Internally a top-down merge sort with an
// insertion-sort cutoff for sub-ranges of length ≤ 16 (avoids the merge
// overhead — same cutoff Java's TimSort uses by default).
//
// Why not trait-driven (`Comparable<T>`) ? Direct trait-method dispatch on a
// bounded type parameter (`$T : Comparable`) isn't yet wired in the lowerer
// (TODO §1.18b). Once it lands we'll add `sort_by_compare(arr)` that calls
// `Comparable::compare` internally.

module "std/sort"

import "std/iter"

/// Return a fresh array containing `arr`'s elements in sorted order. The
/// input is never mutated. Equal elements keep their input order, so the
/// sort is stable. Complexity O(n log n) (top-down merge sort with an
/// insertion-sort fallback below `INSERTION_CUTOFF` items).
///
/// @param arr      the input array. Untouched ; the returned array is a new allocation.
/// @param compare  strict predicate : `compare(a, b)` is `true` iff `a` must
///                 come strictly before `b` in the result. Reflexivity
///                 (`compare(x, x) == false`) is required for stability.
/// @return         a new array with the same elements in sorted order.
export sort :: fn<T>(arr: T[], compare: fn(T, T) -> bool) -> T[] {
    n :: arr.len()
    out :: arr.clone()
    if n < 2 { return out }
    // Scratch buffer pre-sized to n. Every merge overwrites these slots
    // before reading them, so the initial values are placeholders solely to
    // make `buf[i] = …` land in-bounds.
    buf :: arr.clone()
    merge_sort_range(out, buf, 0, n, compare)
    return out
}

INSERTION_CUTOFF :: usize(16)

// Recursive top-down merge sort over `arr[lo..hi)`. Below INSERTION_CUTOFF
// we hand off to insertion_sort_range — the constant factor of merge sort
// loses on tiny sub-arrays.
merge_sort_range :: fn<T>(arr: T[], buf: T[], lo: usize, hi: usize, compare: fn(T, T) -> bool) -> void {
    n :: hi - lo
    if n < 2 { return }
    if n <= INSERTION_CUTOFF {
        insertion_sort_range(arr, lo, hi, compare)
        return
    }
    mid :: lo + n / 2
    merge_sort_range(arr, buf, lo, mid, compare)
    merge_sort_range(arr, buf, mid, hi, compare)
    // Mirror arr[lo..hi) into buf, then merge back into arr[lo..hi). The
    // two halves are already sorted within themselves.
    for i in lo..<hi {
        buf[i] = arr[i]
    }
    a := lo
    b := mid
    for k in lo..<hi {
        if a >= mid {
            arr[k] = buf[b]
            b = b + 1
        } else if b >= hi {
            arr[k] = buf[a]
            a = a + 1
        } else if compare(buf[b], buf[a]) {
            // strict ordering : equal elements keep their original order, so
            // we only take from the right half when it strictly precedes the
            // left half — this is what makes the sort stable.
            arr[k] = buf[b]
            b = b + 1
        } else {
            arr[k] = buf[a]
            a = a + 1
        }
    }
}

insertion_sort_range :: fn<T>(arr: T[], lo: usize, hi: usize, compare: fn(T, T) -> bool) -> void {
    for i in (lo + 1)..<hi {
        x :: arr[i]
        j := i
        for j > lo && compare(x, arr[j - 1]) {
            arr[j] = arr[j - 1]
            j = j - 1
        }
        arr[j] = x
    }
}

// ---------------------------------------------------------------------- tests

import "std/testing"
import "std/string"

@test test_sort_i32_asc :: fn() -> void {
    out :: sort([3, 1, 4, 1, 5, 9, 2, 6, 5, 3], (a: i32, b: i32) -> a < b)
    assert_eq(out.len(), 10)
    assert_eq(out[0], 1)
    assert_eq(out[1], 1)
    assert_eq(out[9], 9)
}

@test test_sort_i32_desc :: fn() -> void {
    out :: sort([1, 2, 3, 4, 5], (a: i32, b: i32) -> a > b)
    assert_eq(out[0], 5)
    assert_eq(out[4], 1)
}

@test test_sort_empty :: fn() -> void {
    empty: i32[] = []
    out :: sort(empty, (a: i32, b: i32) -> a < b)
    assert_eq(out.len(), 0)
}

@test test_sort_single :: fn() -> void {
    out :: sort([42], (a: i32, b: i32) -> a < b)
    assert_eq(out.len(), 1)
    assert_eq(out[0], 42)
}

@test test_sort_preserves_input :: fn() -> void {
    src :: [3, 1, 2]
    _ :: sort(src, (a: i32, b: i32) -> a < b)
    // Input array should be unchanged (sort returns a new array).
    assert_eq(src[0], 3)
    assert_eq(src[1], 1)
    assert_eq(src[2], 2)
}

@test test_sort_strings :: fn() -> void {
    out :: sort(["banana", "apple", "cherry"], (a: string, b: string) -> a.compare_ascending(b))
    assert_eq(out[0], "apple")
    assert_eq(out[1], "banana")
    assert_eq(out[2], "cherry")
}
