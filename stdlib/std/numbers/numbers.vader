// std/numbers ‚Äî number formatting helpers.
//
// Lives outside std/core so we can use std/builder for efficient construction.
// UFCS-callable as `n.to_hex()` once `import "std/numbers"` is in scope.

module "std/numbers"

import "std/string" { chars, ends_with, is_empty, replace_chars_where, ParseError }
import "std/char" { is_digit }
import "std/string_builder" { StringBuilder, append_char }

/// True for an ASCII hex digit ‚Äî `0`..`9`, `a`..`f`, `A`..`F`.
/// @param c  codepoint to classify.
/// @return   `true` iff `c` is a valid hex digit.
export is_hex_digit :: fn(c: char) =
    c.is_digit() || c in 'a'..='f' || c in 'A'..='F'

/// True when `c` is a valid digit in `base`. Supported bases : 2, 8, 10, 16.
/// Unsupported bases fall through to base-10.
/// @param c     codepoint to classify.
/// @param base  the numeric base ; 2, 8, 10, or 16.
export is_digit_in_base :: fn(c: char, base: i32) -> bool {
    if base == 2 { return c == '0' || c == '1' }
    if base == 8 { return c in '0'..='7' }
    if base == 16 { return c.is_hex_digit() }
    return c.is_digit()
}

/// 0..15 for an ASCII hex digit, -1 for anything else. Case-insensitive.
/// @param c  codepoint to decode.
/// @return   the digit's numeric value, or `-1` if `c` isn't `0..9a..fA..F`.
export hex_digit_value :: fn(c: char) -> i32 {
    if c in '0'..='9' { return i32(u32(c) - '0') }
    if c in 'a'..='f' { return i32(u32(c) - 'a' + 10) }
    if c in 'A'..='F' { return i32(u32(c) - 'A' + 10) }
    return -1
}

/// Parse `s` as an `i64` in the given base. `s` must be pure digits in
/// that base ‚Äî no `0x`/`0b`/`0o` prefix, no `_` separators, no leading
/// sign. Empty input or any non-digit character yields an error.
/// @param s     the digits-only input.
/// @param base  one of 2 / 8 / 10 / 16.
/// @return      the parsed `i64`.
/// @error       `ParseError` on empty input or any out-of-base digit.
export parse_int_in_base :: fn(s: string, base: i32) -> i64 | ParseError {
    if s.is_empty() {
        return ParseError { .msg = "empty input" }
    }
    acc: i64 = 0
    b: i64 = i64(base)
    for c in s.chars() {
        d := hex_digit_value(c)
        if d < 0 || d >= base {
            return ParseError { .msg = "invalid digit" }
        }
        acc = acc * b + i64(d)
    }
    return acc
}

/// Parse an unsigned integer in the given base. Same input shape as
/// `parse_int_in_base` (digits only ‚Äî caller strips prefix / underscores).
/// Carries the full u64 range so literals up to `u64.MAX` round-trip
/// without losing top bits. No sign accepted ‚Äî the lexer wraps negative
/// literals in a `UnaryExpr.neg` over the unsigned magnitude.
/// @param s     the digits-only input.
/// @param base  one of 2 / 8 / 10 / 16.
/// @return      the parsed `u64`.
/// @error       `ParseError` on empty input, any out-of-base digit, or a
///              magnitude exceeding `u64.MAX` (carries `.msg = "overflow"`).
export parse_uint_in_base :: fn(s: string, base: i32) -> u64 | ParseError {
    if s.is_empty() {
        return ParseError { .msg = "empty input" }
    }
    acc: u64 = 0
    b: u64 = u64(base)
    u64_max: u64 = 0xFFFF_FFFF_FFFF_FFFF
    for c in s.chars() {
        d := hex_digit_value(c)
        if d < 0 || d >= base {
            return ParseError { .msg = "invalid digit" }
        }
        // Overflow guard : reject any literal whose value would wrap past
        // `u64.MAX`. Checked before the multiply-add so `acc` never wraps ;
        // `u64.MAX` itself still round-trips (equality is not an overflow).
        if acc > (u64_max - u64(d)) / b {
            return ParseError { .msg = "overflow" }
        }
        acc = acc * b + u64(d)
    }
    return acc
}

/// One lowercase hex digit for a nibble `0..15`. Shared with `std/crypto`, which
/// needs the lowercase form (`shasum` / `openssl` convention).
export hex_digit :: fn(n: u64) -> char {
    if n <= 9 {
        return char('0' + u32(n))
    }
    return char('a' + u32(n) - 10)
}

/// Hexadecimal stringification of a `u64` ‚Äî lowercase, no `0x` prefix, no
/// leading zeros (special-cases `0` to `"0"`). Pair with
/// `std/string.pad_start` for a fixed-width hex column.
///
/// UFCS-callable as `n.to_hex()`.
/// @param self  the integer to render.
/// @return      e.g. `255_u64.to_hex()` ‚Üí `"ff"`.
export to_hex :: fn(self: u64) -> string {
    if self == 0 {
        return "0"
    }
    // Build digits LSB-first into the buffer, then walk it backwards into the
    // builder so the output reads MSB-first.
    rev: char[] = []
    base: u64 = 16
    x := self
    for x > 0 {
        rev.push(hex_digit(x % base))
        x = x / base
    }
    sb := StringBuilder {}
    n :: rev.len()
    for k in 0..<n {
        sb.append_char(rev[n - 1 - k])
    }
    return sb.to_string()
}

/// Binary stringification of a `u64` ‚Äî no `0b` prefix, no leading zeros.
/// Pair with `std/string.pad_start` for a fixed-width bit column.
/// @param self  the integer to render.
/// @return      e.g. `5_u64.to_bin()` ‚Üí `"101"`.
export to_bin :: fn(self: u64) -> string {
    if self == 0 {
        return "0"
    }
    rev: char[] = []
    two: u64 = 2
    x := self
    for x > 0 {
        if x % two == 0 {
            rev.push('0')
        } else {
            rev.push('1')
        }
        x = x / two
    }
    sb := StringBuilder {}
    n :: rev.len()
    for k in 0..<n {
        sb.append_char(rev[n - 1 - k])
    }
    return sb.to_string()
}

/// Format a float in the most compact decimal form ‚Äî strips a trailing
/// `.0` from integer-valued floats so `10.0` becomes `"10"`. Otherwise
/// behaves like the default `Display` impl on `f64`. Matches
/// `JSON.stringify` semantics ; useful for snapshot-style output and any
/// wire format that prefers `42` over `42.0` for whole numbers.
///
/// Examples :
///   `(10.0).to_compact_str()    // "10"`
///   `(3.14).to_compact_str()    // "3.14"`
///   `(0.5).to_compact_str()     // "0.5"`
///
/// @param self  the float to render.
/// @return      the compact decimal representation.
export to_compact_str :: fn(self: f64) -> string {
    s :: "${self}"
    if s.ends_with(".0") {
        sb :: s.bytes()
        return sb[0..<sb.len() - 2].bytes_to_string()
    }
    return s
}

/// Strip the base prefix (`0x` / `0b` / `0o`) and every `_` digit separator
/// from a literal's source text. The result is a pure digit string ready for
/// `parse_int_in_base` / `parse_uint_in_base` / `parse_float`.
///
/// @param text    the original literal text (e.g. `"0xFF_FF"` / `"1_000"`).
/// @param base    the literal's base ‚Äî 10 leaves the leading bytes
///                untouched, anything else strips the two-byte `0x` /
///                `0b` / `0o` prefix.
/// @return        the digit-only payload, suitable for the base-aware
///                numeric parsers in this module.
/// @example
///   `strip_numeric_text("0xFF", 16)  // "FF"`
///   `strip_numeric_text("1_000", 10)  // "1000"`
export strip_numeric_text :: fn(text: string, base: i32) -> string {
    start: usize = if base == 10 { 0 } else { 2 }
    tb :: text.bytes()
    body :: tb[start..<tb.len()].bytes_to_string()
    // Fast path : no `_` to filter ‚Üí return the slice directly.
    if !body.contains("_") { return body }
    return body.replace_chars_where((c: char) -> c == '_', "")
}

// ---- tests ---------------------------------------------------------------

import "std/testing" { assert_eq }

@test test_strip_numeric_text :: fn() -> void {
    assert_eq(strip_numeric_text("0xFF",    16),  "FF")
    assert_eq(strip_numeric_text("0xFF_FF", 16),  "FFFF")   // hex with digit separator
    assert_eq(strip_numeric_text("0b1010",  2),   "1010")
    assert_eq(strip_numeric_text("1_000",   10),  "1000")
    assert_eq(strip_numeric_text("3.14",    10),  "3.14")
    assert_eq(strip_numeric_text("42",      10),  "42")     // fast path
}
