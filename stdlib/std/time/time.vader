// std/time — wall-clock and monotonic time, plus arithmetic and ISO 8601.
//
// The two clocks use distinct types so a wall-clock value can never
// be silently mixed with a monotonic one (their epochs are unrelated).
// For benchmarking use `Monotonic` ; for display / persistence use
// `Instant`.

module "std/time"

import "std/string" { pad_start }
import "std/math" { abs }

/// Wall-clock instant — nanoseconds since the Unix epoch (1970-01-01 UTC).
/// Suitable for formatting, persistence, and absolute-time comparisons.
/// NOT suitable for measuring elapsed time : the wall clock can jump
/// forwards or backwards (NTP corrections, manual clock adjustments,
/// daylight-saving when the OS exposes local time). Use `Monotonic` for
/// elapsed measurements.
export Instant :: i64

/// Monotonic instant — nanoseconds since an opaque, process-stable epoch.
/// Guaranteed never to decrease across observations within a single
/// process. Use for micro-benchmarks, timeouts, deadlines, and any
/// elapsed-time measurement. NOT comparable across processes ; NOT
/// convertible to wall-clock time.
export Monotonic :: i64

/// Signed time interval with nanosecond precision. May be negative
/// (e.g. `b - a` when `b < a`). Range : ±~292 years (i64 ns).
export Duration :: i64

// ---- intrinsics (module-private : the raw clock primitives ; callers use
//      `now()` / `monotonic()` / `StopWatch`, never the bare i64) -----------

// Wall-clock milliseconds since the Unix epoch (1970-01-01 UTC).
// Millisecond resolution everywhere — the wall clock is intentionally
// coarser than `monotonic_ns` so different host backends agree.
@intrinsic
now_unix_ms :: fn() -> i64

// Monotonic nanoseconds since an arbitrary, process-stable epoch.
// Resolution on the TS VM is ~5 µs (`performance.now()` is browser-
// throttled when run outside Bun/Node) ; ~10 ns on native.
@intrinsic
monotonic_ns :: fn() -> i64

// ---- Duration constructors -----------------------------------------------

/// Construct a Duration from a count of nanoseconds.
export nanos :: fn(n: i64) -> Duration = Duration(n)

/// Construct a Duration from a count of microseconds.
export micros :: fn(n: i64) -> Duration = Duration(n * 1000)

/// Construct a Duration from a count of milliseconds.
export millis :: fn(n: i64) -> Duration = Duration(n * 1_000_000)

/// Construct a Duration from a count of seconds.
export seconds :: fn(n: i64) -> Duration = Duration(n * 1_000_000_000)

// ---- clocks --------------------------------------------------------------

/// Current wall-clock time. Reads the host clock — successive calls may
/// observe non-monotonic jumps (NTP, manual adjustments).
export now :: fn() -> Instant = Instant(now_unix_ms() * 1_000_000)

/// Current monotonic instant. Never decreases across calls within a
/// single process.
export monotonic :: fn() -> Monotonic = Monotonic(monotonic_ns())

// ---- construction / readout (Unix epoch) ---------------------------------

/// Construct a wall-clock `Instant` from a Unix-epoch nanosecond count
/// (nanoseconds since 1970-01-01 UTC ; negative for pre-epoch instants).
/// The inverse of `to_unix_nanos`. Use for deterministic timestamps that
/// don't come from the host clock.
/// @param ns  nanoseconds since the Unix epoch.
export from_unix_nanos :: fn(ns: i64) -> Instant = Instant(ns)

/// Unix-epoch nanoseconds for this `Instant` (since 1970-01-01 UTC ;
/// negative for pre-epoch). The inverse of `from_unix_nanos`.
/// @param self  the instant to read.
export to_unix_nanos :: fn(self: Instant) -> i64 = i64(self)

// ---- arithmetic ----------------------------------------------------------

/// Elapsed time since `self`, measured against the current monotonic
/// clock. The contract is one-directional : `self` must come from
/// `monotonic()`. Returns a non-negative Duration in normal operation.
///
/// UFCS-callable as `start.since()`.
export since :: fn(self: Monotonic) -> Duration = Duration(monotonic_ns() - i64(self))

// `instant + duration` — shift an Instant forward (a negative Duration shifts
// back). Heterogeneous : right operand is a Duration, result is an Instant.
Instant implements Add<Duration, Instant> -> Instant(i64(self) + i64(other))

// `instant_a - instant_b` — signed elapsed time between two instants. The
// result type (`Out`) is a Duration, distinct from `Self`.
Instant implements Sub<Instant, Duration> -> Duration(i64(self) - i64(other))

// Human-readable form — the ISO 8601 UTC timestamp. Drives `"${instant}"`
// interpolation and `println(instant)`.
Instant implements Display -> format_iso8601(self)

// `monotonic + duration` — shift a Monotonic instant forward.
Monotonic implements Add<Duration, Monotonic> -> Monotonic(i64(self) + i64(other))

// `duration + duration` / `duration - duration` — homogeneous, so `Rhs`/`Out`
// both default to `Self` (Duration).
Duration implements Add -> Duration(i64(self) + i64(other))
Duration implements Sub -> Duration(i64(self) - i64(other))

// ---- Duration accessors --------------------------------------------------

/// Whole nanoseconds.
export to_nanos :: fn(self: Duration) -> i64 { return i64(self) }

/// Whole microseconds (truncated towards zero).
export to_micros :: fn(self: Duration) -> i64 { return i64(self) / 1000 }

/// Whole milliseconds (truncated towards zero).
export to_millis :: fn(self: Duration) -> i64 { return i64(self) / 1_000_000 }

/// Whole seconds (truncated towards zero).
export to_seconds :: fn(self: Duration) -> i64 { return i64(self) / 1_000_000_000 }

// ---- Duration formatting -------------------------------------------------

/// Format a Duration in the most readable unit (`ns`, `µs`, `ms`, or `s`)
/// such that the integer part is non-empty and < 1000. Picks the largest
/// unit that fits. Negative durations are formatted with a leading `-`.
///
/// Examples :
///   `nanos(500).format()`     // "500 ns"
///   `nanos(1500).format()`    // "1 µs"             (truncated)
///   `millis(42).format()`     // "42 ms"
///   `seconds(-3).format()`    // "-3 s"
export format :: fn(self: Duration) -> string {
    n :: i64(self)
    a :: abs(n)
    sign :: if n < 0 { "-" } else { "" }
    if a < 1000              { return "${sign}${a} ns" }
    if a < 1_000_000         { return "${sign}${a / 1000} µs" }
    if a < 1_000_000_000     { return "${sign}${a / 1_000_000} ms" }
    return "${sign}${a / 1_000_000_000} s"
}

// ---- ISO 8601 (Gregorian civil calendar) ---------------------------------
//
// Algorithm : Howard Hinnant's days_from_civil / civil_from_days.
//   - days_from_civil  : (y, m, d) -> serial day number (epoch 1970-01-01)
//   - civil_from_days  : serial day number -> (y, m, d)
//   Handles the full proleptic Gregorian range without lookup tables.

// Number of days in month `m` (1-12) of year `y`, honouring the Gregorian
// leap-year rule for February. Used to reject impossible dates (`2026-02-31`,
// `2026-04-31`) in `parse_iso8601`. Caller ensures `m` is in 1..12.
days_in_month :: fn(y: i64, m: i64) -> i64 {
    if m == 2 {
        leap :: (y % 4 == 0 && y % 100 != 0) || (y % 400 == 0)
        return if leap { 29 } else { 28 }
    }
    if m == 4 || m == 6 || m == 9 || m == 11 { return 30 }
    return 31
}

days_from_civil :: fn(y: i64, m: i64, d: i64) -> i64 {
    yy :: if m <= 2 { y - 1 } else { y }
    era :: if yy >= 0 { yy / 400 } else { (yy - 399) / 400 }
    yoe :: yy - era * 400
    moe :: if m > 2 { m - 3 } else { m + 9 }
    doy :: (153 * moe + 2) / 5 + d - 1
    doe :: yoe * 365 + yoe / 4 - yoe / 100 + doy
    return era * 146097 + doe - 719468
}

civil_from_days :: fn(z: i64) -> [i64, i64, i64] {
    zz :: z + 719468
    era :: if zz >= 0 { zz / 146097 } else { (zz - 146096) / 146097 }
    doe :: zz - era * 146097
    yoe :: (doe - doe / 1460 + doe / 36524 - doe / 146096) / 365
    yy  :: yoe + era * 400
    doy :: doe - (365 * yoe + yoe / 4 - yoe / 100)
    mp  :: (5 * doy + 2) / 153
    d   :: doy - (153 * mp + 2) / 5 + 1
    m   :: if mp < 10 { mp + 3 } else { mp - 9 }
    y   :: if m <= 2 { yy + 1 } else { yy }
    return [y, m, d]
}

/// Format an `Instant` as an ISO 8601 timestamp in UTC with millisecond
/// precision, e.g. `"2026-05-15T12:34:56.789Z"`. Years before 0001 or
/// after 9999 are still formatted but the year field widens beyond four
/// digits (no truncation).
///
/// Sub-millisecond nanosecond detail is intentionally dropped — the
/// MVP host clock only provides millisecond resolution for the wall
/// clock, and emitting trailing zero-noise would mislead the reader.
export format_iso8601 :: fn(self: Instant) -> string {
    total_ms :: i64(self) / 1_000_000
    ms_per_day :: i64(86_400_000)

    // Floor-divide towards negative infinity so pre-epoch instants land
    // on the correct civil day.
    days :: if total_ms >= 0 {
        total_ms / ms_per_day
    } else {
        (total_ms - ms_per_day + 1) / ms_per_day
    }
    time_ms_unsigned :: total_ms - days * ms_per_day

    [year, month, day] :: civil_from_days(days)

    hours :: time_ms_unsigned / 3_600_000
    remaining_after_hours :: time_ms_unsigned - hours * 3_600_000
    minutes :: remaining_after_hours / 60_000
    remaining_after_minutes :: remaining_after_hours - minutes * 60_000
    seconds_part :: remaining_after_minutes / 1000
    ms_part :: remaining_after_minutes - seconds_part * 1000

    return "${pad_start("${year}", 4, '0')}-${pad_start("${month}", 2, '0')}-${pad_start("${day}", 2, '0')}T${pad_start("${hours}", 2, '0')}:${pad_start("${minutes}", 2, '0')}:${pad_start("${seconds_part}", 2, '0')}.${pad_start("${ms_part}", 3, '0')}Z"
}

/// Error returned by `parse_iso8601` when the input doesn't conform to
/// the supported subset of ISO 8601.
export TimeError :: struct {
    msg: string
}

TimeError implements Error {
    message :: fn(self) -> string { return self.msg }
}

parse_digits :: fn(s: string, start: usize, count: usize) -> i64 | TimeError {
    sb :: s.bytes()
    if start + count > sb.len() {
        return TimeError { .msg = "unexpected end of input" }
    }
    acc: i64 = 0
    for i in 0..<count {
        b :: sb[start + i]
        if b < '0' || b > '9' {
            return TimeError { .msg = "expected digit" }
        }
        acc = acc * 10 + i64(b - '0')
    }
    return acc
}

expect_byte :: fn(s: string, offset: usize, expected: u8) -> null | TimeError {
    sb :: s.bytes()
    if offset >= sb.len() {
        return TimeError { .msg = "unexpected end of input" }
    }
    if sb[offset] != expected {
        return TimeError { .msg = "unexpected byte" }
    }
    return null
}

/// Parse an ISO 8601 wall-clock timestamp into an `Instant`. The
/// accepted shape is `YYYY-MM-DDTHH:MM:SS[.fff]Z` (UTC only ; the
/// trailing `Z` is required, fractional seconds are optional and
/// truncated to milliseconds when present). The mirror of
/// `format_iso8601`.
///
/// @param s  the timestamp to parse.
/// @return   the parsed `Instant`.
/// @error    `TimeError` when `s` doesn't fit the accepted shape.
export parse_iso8601 :: fn(s: string) -> Instant | TimeError {
    sb :: s.bytes()
    // Minimum is `1970-01-01T00:00:00Z` — 20 bytes.
    if sb.len() < 20 {
        return TimeError { .msg = "iso8601: too short" }
    }
    year   :: parse_digits(s, 0,  4)
    if year is TimeError as e { return e }
    if expect_byte(s, 4,  '-') is TimeError as e { return e }
    month  :: parse_digits(s, 5,  2)
    if month is TimeError as e { return e }
    if expect_byte(s, 7,  '-') is TimeError as e { return e }
    day    :: parse_digits(s, 8,  2)
    if day is TimeError as e { return e }
    if expect_byte(s, 10, 'T') is TimeError as e { return e }
    hours  :: parse_digits(s, 11, 2)
    if hours is TimeError as e { return e }
    if expect_byte(s, 13, ':') is TimeError as e { return e }
    minutes :: parse_digits(s, 14, 2)
    if minutes is TimeError as e { return e }
    if expect_byte(s, 16, ':') is TimeError as e { return e }
    seconds_part :: parse_digits(s, 17, 2)
    if seconds_part is TimeError as e { return e }

    // Fractional seconds : optional `.fff` block, then required `Z`.
    cursor: usize = 19
    ms_part: i64 = 0
    if cursor < sb.len() && sb[cursor] == '.' {
        cursor = cursor + 1
        // Consume up to 3 digits — truncate further fractional detail.
        consumed: usize = 0
        for consumed < 3 && cursor < sb.len() && sb[cursor] >= '0' && sb[cursor] <= '9' {
            ms_part = ms_part * 10 + i64(sb[cursor] - '0')
            cursor = cursor + 1
            consumed = consumed + 1
        }
        scale_loop :: 3 - consumed
        scale: i64 = 1
        for k in 0..<scale_loop {
            scale = scale * 10
        }
        ms_part = ms_part * scale
        // Drop any additional fractional digits the caller supplied.
        for cursor < sb.len() && sb[cursor] >= '0' && sb[cursor] <= '9' {
            cursor = cursor + 1
        }
    }
    if expect_byte(s, cursor, 'Z') is TimeError as e { return e }
    // `Z` must be the final byte — reject trailing garbage (`…Z…`), which the
    // per-field parse would otherwise silently ignore.
    if cursor + 1 != sb.len() {
        return TimeError { .msg = "iso8601: trailing characters after `Z`" }
    }

    if month < 1 || month > 12 {
        return TimeError { .msg = "iso8601: month out of range" }
    }
    if day < 1 || day > days_in_month(year, month) {
        return TimeError { .msg = "iso8601: day out of range for month" }
    }
    if hours > 23 || minutes > 59 || seconds_part > 60 {
        return TimeError { .msg = "iso8601: time field out of range" }
    }

    days :: days_from_civil(year, month, day)
    total_ms :: days * 86_400_000 +
                hours * 3_600_000 +
                minutes * 60_000 +
                seconds_part * 1000 +
                ms_part
    // An `Instant` is i64 nanoseconds since the epoch, so the representable
    // window is ~±292 years (≈ 1677..2262). Reject a date beyond it rather than
    // letting the ms→ns multiply overflow into a silently-wrapped instant.
    if total_ms > MAX_INSTANT_MS || total_ms < -MAX_INSTANT_MS {
        return TimeError { .msg = "iso8601: instant out of representable range" }
    }
    return Instant(total_ms * 1_000_000)
}

// Largest millisecond magnitude whose nanosecond value (`× 1_000_000`) still
// fits an i64 — i.e. `i64.MAX / 1_000_000`. Bounds `parse_iso8601`. Typed i64 :
// the value overflows the default i32 for a bare literal.
MAX_INSTANT_MS: i64: 9_223_372_036_854

// ---------------------------------------------------------------------- tests

import "std/testing" { assert_eq, assert }

@test test_duration_constructors :: fn() -> void {
    assert_eq(i64(nanos(500)), 500)
    assert_eq(i64(micros(2)), 2000)
    assert_eq(i64(millis(3)), 3_000_000)
    assert_eq(i64(seconds(4)), 4_000_000_000)
}

@test test_duration_arithmetic :: fn() -> void {
    a :: 100.millis()
    b :: 50.millis()
    assert_eq(i64(a + b), 150_000_000)
    assert_eq(i64(a - b), 50_000_000)
}

@test test_duration_format :: fn() -> void {
    assert_eq(nanos(500).format(),     "500 ns")
    assert_eq(nanos(1500).format(),    "1 µs")
    assert_eq(micros(42).format(),     "42 µs")
    assert_eq(millis(7).format(),      "7 ms")
    assert_eq(seconds(3).format(),     "3 s")
    assert_eq(nanos(-250).format(),    "-250 ns")
}

@test test_duration_accessors :: fn() -> void {
    d :: millis(1500)
    assert_eq(d.to_micros(), 1_500_000)
    assert_eq(d.to_millis(), 1500)
    assert_eq(d.to_seconds(), 1)
}

@test test_iso8601_epoch :: fn() -> void {
    s :: format_iso8601(Instant(0))
    assert_eq(s, "1970-01-01T00:00:00.000Z")
}

@test test_instant_display :: fn() -> void {
    // `Display` drives `"${…}"` interpolation — an Instant renders as ISO 8601.
    assert_eq("${Instant(0)}", "1970-01-01T00:00:00.000Z")
}

@test test_iso8601_known_timestamp :: fn() -> void {
    // 2026-05-15T12:34:56.789Z -> a specific number of ms.
    days :: days_from_civil(2026, 5, 15)
    total_ms :: days * 86_400_000 +
                12 * 3_600_000 +
                34 * 60_000 +
                56 * 1000 +
                789
    inst :: Instant(total_ms * 1_000_000)
    assert_eq(format_iso8601(inst), "2026-05-15T12:34:56.789Z")
}

@test test_iso8601_date_validation :: fn() -> void {
    // stdlib-domain-5 : reject an impossible day-of-month (leap-aware) and any
    // trailing characters after the required `Z`.
    assert(parse_iso8601("2026-02-31T00:00:00Z")  is TimeError, "Feb 31 rejected")
    assert(parse_iso8601("2026-04-31T00:00:00Z")  is TimeError, "Apr 31 rejected")
    assert(parse_iso8601("2026-02-29T00:00:00Z")  is TimeError, "Feb 29 in a non-leap year rejected")
    assert(parse_iso8601("2024-02-29T00:00:00Z")  is Instant,   "Feb 29 in a leap year accepted")
    assert(parse_iso8601("2000-02-29T00:00:00Z")  is Instant,   "Feb 29 in a 400-divisible year accepted")
    assert(parse_iso8601("2026-01-31T00:00:00Z")  is Instant,   "Jan 31 accepted")
    assert(parse_iso8601("2026-01-01T00:00:00Zx") is TimeError, "trailing chars after Z rejected")
}

@test test_iso8601_roundtrip :: fn() -> void {
    inputs :: ["1970-01-01T00:00:00.000Z",
               "2000-02-29T12:00:00.000Z",
               "2026-05-15T12:34:56.789Z",
               "1999-12-31T23:59:59.999Z"]
    for s in inputs {
        parsed :: parse_iso8601(s)
        match parsed {
            is Instant   -> assert_eq(format_iso8601(parsed), s)
            is TimeError -> assert(false, "unreachable")
        }
    }
}

@test test_iso8601_out_of_range :: fn() -> void {
    // Beyond the i64-ns window (~year 2262) : a TimeError, not a silently
    // wrapped negative instant. (`9999-…` used to reformat as a 1816 date.)
    assert(parse_iso8601("9999-12-31T23:59:59Z") is TimeError, "far-future rejected")
    // A representable far-future instant (just inside ~2262) still parses.
    assert(parse_iso8601("2200-01-01T00:00:00Z") is Instant, "year 2200 parses")
}

@test test_iso8601_parse_rejects_bad_input :: fn() -> void {
    bad :: parse_iso8601("not a timestamp")
    match bad {
        is TimeError -> assert(true, "expected error")
        is Instant   -> assert(false, "unreachable")
    }
}

@test test_monotonic_non_negative_elapsed :: fn() -> void {
    start :: monotonic()
    // Tiny busy-loop : we don't want to depend on the actual timing,
    // just that `since` returns a non-negative duration.
    for _ in 0..<1000 {}
    elapsed_dur :: start.since()
    assert(i64(elapsed_dur) >= 0, "monotonic clock ran backwards")
}

@test test_instant_arithmetic :: fn() -> void {
    epoch :: from_unix_nanos(0)
    later :: epoch + 60.seconds()
    delta :: later - epoch
    assert_eq(delta.to_seconds(), 60)
    assert_eq(delta.format(), "60 s")
}

@test test_instant_unix_nanos :: fn() -> void {
    // from_unix_nanos / to_unix_nanos round-trip, including a pre-epoch value.
    assert_eq(from_unix_nanos(1_700_000_000_000_000_000).to_unix_nanos(),
              1_700_000_000_000_000_000)
    assert_eq(from_unix_nanos(-500).to_unix_nanos(), i64(-500))
    // `now()` agrees with its own readout.
    assert(now().to_unix_nanos() >= 0, "now is non-negative")
}
