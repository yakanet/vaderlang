// std/io — synchronous blocking I/O.
//
// MVP scope: stdin/stdout/stderr, file read/write, existence check.
// No async, no networking, no streaming primitives.

// IOError — raised by every fallible operation in this module.
export IOError :: struct {
    msg: string
}

IOError implements Error {
    message :: fn(self) -> string { return self.msg }
}

// print / println — write to stdout. Accept anything implementing
// `Display` ; the lowerer coerces the argument through the matching
// `to_string` impl before reaching the host hook (no per-type wrapper
// monomorphisation, no virtual dispatch — see `lower/passes/display-coerce.ts`).
@intrinsic export print   :: fn(msg: Display) -> void
@intrinsic export println :: fn(msg: Display) -> void

// eprint / eprintln — same for stderr.
@intrinsic export eprint   :: fn(msg: Display) -> void
@intrinsic export eprintln :: fn(msg: Display) -> void

// read_line — block on stdin until newline.
@intrinsic export read_line :: fn() -> string!

// File operations.
@intrinsic export read_file  :: fn(path: string) -> string!
@intrinsic export write_file :: fn(path: string, content: string) -> void!
@intrinsic export exists     :: fn(path: string) -> bool
@intrinsic export is_dir     :: fn(path: string) -> bool
// `read_dir` lists immediate entries (relative names, no `.` / `..`) in
// OS-provided order. Caller joins against `path` if absolute paths are wanted.
@intrinsic export read_dir :: fn(path: string) -> string[]!
