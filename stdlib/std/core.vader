// std/core — auto-imported in every Vader program.
//
// Provides the core traits used throughout the language:
//   Display, Eq, Ord, Add, Sub, Mul, Div, Hash, Clone, Iterator, Iterable, Error
//
// And the base Error type used by !T sugar.

// Display — for compile-time string interpolation and println().
export Display :: trait {
    fn show(self) -> string
}

// Eq — for == and !=.
export Eq :: trait {
    fn equals(self, other: Self) -> bool
}

// Ord — for <, <=, >, >=.
export Ord :: trait {
    fn compare(self, other: Self) -> i32
}

// Hash — for Map / Set keys.
export Hash :: trait {
    fn hash(self) -> u64
}

// Clone — explicit deep copy. Free function `clone(x)` calls into this.
export Clone :: trait {
    fn clone(self) -> Self
}

// Arithmetic operator traits.
export Add :: trait { fn add(self, other: Self) -> Self }
export Sub :: trait { fn sub(self, other: Self) -> Self }
export Mul :: trait { fn mul(self, other: Self) -> Self }
export Div :: trait { fn div(self, other: Self) -> Self }

// Iterator step result. `Done` signals end-of-iteration; `Yielded(T)` carries
// the next value. Sum-type discriminator avoids the sentinel collision that
// `T | null` would have for lists whose element type itself includes `null`.
export Done    :: struct {}
export Yielded :: struct($T) { value: T }

// Iterator — pull-based. The lowerer dispatches `for x in iter` through the
// impl table; users never call `step` directly.
export Iterator :: trait($T) {
    fn step(self) -> Done | Yielded(T)
}

// Range — produced by `0..<n` / `0..=n`. `cursor` advances each iteration
// via implicit struct-ref mutation inside `step`.
export Range :: struct {
    start:     i32
    end:       i32
    inclusive: bool
    cursor:    i32
}

// Contains — `x in coll` desugars to `coll.contains(x)`. `x !in coll` desugars
// to `!coll.contains(x)`.
export Contains :: trait($T) {
    fn contains(self, value: T) -> bool
}

Range implements Contains(i32) {
    fn contains(self, value: i32) -> bool {
        if value < self.start {
            return false
        }
        if self.inclusive {
            return value <= self.end
        }
        return value < self.end
    }
}

Range implements Iterator(i32) {
    fn step(self) -> Done | Yielded(i32) {
        done :: if (self.inclusive) {
            self.cursor > self.end
        } else {
            self.cursor >= self.end
        }
        if (done) {
            return Done {}
        }
        v :: self.cursor
        self.cursor = self.cursor + 1
        return Yielded(i32) { .value = v }
    }
}

// ArrayIter — iterator over a `[T]`. The lowerer auto-wraps array exprs
// flowing into `for x in arr`, so callers rarely need to construct one. The
// `length` field is pre-computed at construction time so `step` can avoid
// calling a generic `len(arr)` (generic-fn dispatch is still deferred).
export ArrayIter :: struct($T) {
    arr:    [T]
    cursor: i32
    length: i32
}

ArrayIter($T) implements Iterator(T) {
    fn step(self) -> Done | Yielded(T) {
        if (self.cursor >= self.length) {
            return Done {}
        }
        v :: self.arr[self.cursor]
        self.cursor = self.cursor + 1
        return Yielded(T) { .value = v }
    }
}

// Error — base trait for any value usable in !T returns and the `?` operator.
export Error :: trait {
    fn message(self) -> string
}

// ===========================================================================
// Hash + Eq impls for primitive types.
// Required for using primitives as keys in Map / Set.
// ===========================================================================

i32   implements Hash -> u64(self)
u32   implements Hash -> u64(self)
usize implements Hash -> u64(self)

// String Hash — FNV-1a over the UTF-8 bytes; intrinsic provided by the host.
export hash_string :: fn(s: string) -> u64

string implements Hash -> hash_string(self)

// Number formatting (`to_hex`, `to_bin`) lives in `std/numbers` so it can use
// std/string_builder.

i32    implements Eq -> self == other
u32    implements Eq -> self == other
usize  implements Eq -> self == other
string implements Eq -> self == other
