// std/core — auto-imported in every Vader program.
//
// Layout :
//   1. Trait declarations (Display, Equals, Comparable, Hash, Clone,
//      arithmetic, indexing, containment, iteration, error)
//   2. Core struct definitions and their impls (Yield, Range,
//      ArrayIterator)
//   3. Primitive type impls (Equals, Hash, numeric arithmetic, string)
//
// The base `Error` trait powering the `!T` and `?` sugar lives in §1 ; the
// concrete error structs are user-defined.

// ============================================================================
// 1. Trait declarations
// ============================================================================

/// Convert a value to its canonical string form. Drives compile-time
/// string interpolation (`"${value}"`) and the `print` / `println` family
/// in `std/io`. Every primitive type ships an `@intrinsic` impl ; user
/// types opt in by declaring their own `to_string`.
export Display :: trait {
    to_string :: fn(self) -> string
}

/// Structural equality. Powers the `==` and `!=` operators (the latter
/// via the default `not_equals` derived from `equals`, Layer 8d — impls
/// that don't override `not_equals` inherit the negation).
export Equals :: trait {
    equals     :: fn(self, other: Self) -> bool
    not_equals :: fn(self, other: Self) -> bool { return !self.equals(other) }
}

/// Total ordering. Powers `<` / `<=` / `>` / `>=` via the four
/// `compare`-by-zero helpers ; impls only need to provide `compare` and
/// the rest follow (Layer 8d default-method injection).
///
/// `compare(a, b)` must return :
///   `< 0` when `a` is strictly less than `b`,
///   `= 0` when they're equal,
///   `> 0` when `a` is strictly greater than `b`.
export Comparable :: trait {
    compare :: fn(self, other: Self) -> i32
    lt  :: fn(self, other: Self) -> bool { return self.compare(other) <  0 }
    lte :: fn(self, other: Self) -> bool { return self.compare(other) <= 0 }
    gt  :: fn(self, other: Self) -> bool { return self.compare(other) >  0 }
    gte :: fn(self, other: Self) -> bool { return self.compare(other) >= 0 }
}

/// Hash codes for `MutableMap` / `MutableSet` keys. Must be consistent
/// with `Equals` — `a.equals(b) == true` implies `a.hash() == b.hash()`.
export Hash :: trait {
    hash :: fn(self) -> u64
}

/// Advance one position along a discrete sequence. Sole obligation : `step()`
/// returns the *next* value after `self`. Used by `Range[T : Step & Comparable]
/// implements Iterator[T]` so a single generic impl covers every integer
/// width plus `char` — concrete `+ 1` / codepoint-bump logic lives in each
/// primitive's `Step` impl instead of being repeated per `Range[T]` impl.
export Step :: trait {
    step :: fn(self) -> Self
}

/// Explicit deep copy. `clone(x)` (free function) dispatches into this
/// when `T: Clone` ; primitive types don't need it (value-typed by
/// default).
export Clone :: trait {
    clone :: fn(self) -> Self
}

/// Type-to-type conversion. Two surfaces :
///   - **Implicit** : when a value of type `S` flows into a slot
///     expecting `Target` and `S implements Into(Target)`, the compiler
///     inserts `value.into()` at the boundary. Sites : call args with a
///     typed parameter, `return` values, `let x: T = …`, and struct-
///     literal fields.
///   - **Explicit** : `Target(value)` — the same `Type(value)` syntax
///     that performs primitive numeric casts (`u32(x)`, `i64(x)`). When
///     `Target` is a user type, the compiler routes the call through
///     the matching `Into` impl instead of emitting a primitive cast.
///
/// Coercion is **not** transitive (`A → B → C` never auto-chains), the
/// target must be a concrete type (not a union, type-param or unresolved
/// type), and `T implements Into(T)` is forbidden (would shadow identity
/// assignments). See SPEC §11 *Type coercion* for the full rules.
export Into :: trait[Target] {
    into :: fn(self) -> Target
}

/// `+` dispatch. Numeric primitives use the built-in bytecode op directly ;
/// user types implement `Add` to opt into the operator form.
export Add :: trait { add :: fn(self, other: Self) -> Self }
/// `-` dispatch. See `Add`.
export Sub :: trait { sub :: fn(self, other: Self) -> Self }
/// `*` dispatch. See `Add`.
export Mul :: trait { mul :: fn(self, other: Self) -> Self }
/// `/` dispatch. See `Add`.
export Div :: trait { div :: fn(self, other: Self) -> Self }
/// `%` dispatch. See `Add`.
export Rem :: trait { rem :: fn(self, other: Self) -> Self }

/// Indexed read — `a[i]` dispatches through this when `a` isn't a built-in
/// array. `I` is the index type, `T` the element type.
export Index :: trait[I, T] {
    at :: fn(self, i: I) -> T
}
/// Indexed write — `a[i] = v`. Symmetric with `Index`.
export IndexSet :: trait[I, T] {
    set_at :: fn(self, i: I, v: T)
}

/// Membership test. `x in coll` desugars to `coll.contains(x)` ;
/// `x !in coll` desugars to `!coll.contains(x)`. Implemented by `Range`
/// (for the integer / char ranges), `MutableMap`, `MutableSet`, and any
/// user type that wants infix `in` support.
export Contains :: trait[T] {
    contains :: fn(self, value: T) -> bool
}

/// Pull-based iterator. The lowerer dispatches `for x in iter` through
/// the impl table — users never call `next` directly. `count` / `last` /
/// `is_empty` are default methods derived from `next` (Layer 8d) ; every
/// `Iterator` impl picks them up without re-implementing.
///
/// `next()` returns `null` when the iteration is exhausted, or `Yield(T)`
/// carrying the next value. Mirrors Rust's `Option<T>::Some` shape — the
/// `Yield` wrapper distinguishes "an iterator yielded a value" from "this
/// type is a nullable T at the type level" (relevant when T itself can be
/// `null`).
export Iterator :: trait[T] {
    next :: fn(self) -> Yield(T) | null

    // True iff the next `next()` call returns `null`. Drains exactly one
    // step ; a `false` result has *consumed* the first yielded item already
    // (the iterator is one step ahead from the caller's perspective).
    // Reflects the pull-based shape — there's no peek without an internal
    // buffer.
    is_empty :: fn(self) -> bool = match self.next() {
        is null     -> true
        is Yield(T) -> false
    }

    // Drain the iterator, returning the count of yielded items. Consumes
    // self ; the iterator is exhausted after this call.
    count :: fn(self) -> usize {
        total: usize = 0
        finished := false
        for !finished {
            match self.next() {
                is null     -> { finished = true }
                is Yield(T) -> { total = total + 1 }
            }
        }
        return total
    }

    // Drain the iterator, returning the last yielded item or `null` if it
    // was empty. Consumes self.
    last :: fn(self) -> T | null {
        result: T | null = null
        finished := false
        for !finished {
            match self.next() {
                is null          -> { finished = true }
                is Yield(T) as y -> { result = y.value }
            }
        }
        return result
    }
}

/// Base trait for every error type usable in `!T` returns and the `?`
/// operator. Any struct implementing `Error` participates in `T!`
/// (`T | Error`) unions ; `?` re-raises by matching the trait.
///
/// @return  short human-readable message — used by `Display`-style
///          renderers, never parsed.
export Error :: trait {
    message :: fn(self) -> string
}

// ============================================================================
// 2. Core struct definitions
// ============================================================================

/// `Iterator.next` continuation marker, carrying the next value.
/// The wrapper distinguishes "iterator yielded a value" from "T |  null"
/// at the source level, so a `T | null` element type doesn't collide
/// with the end-of-iteration sentinel.
///
/// At the runtime level the wrapper is transparent : for T = ref,
/// `Yield(T) | null` lowers to a single `void*` slot (T's obj_ptr or
/// NULL) ; for T = primitive, the value rides in `vader_box_t.payload`
/// with no wrapper allocation.
export Yield :: struct[T] { value: T }

/// Range produced by `0..<n` / `0..=n` and `'a'..='z'`. Generic over the
/// bound type so integer ranges (every signed / unsigned width plus
/// `usize` / `isize`) and char ranges share a single struct. The `cursor`
/// field is advanced by each `step` call via implicit struct-ref mutation.
export Range :: struct[T] {
    start:     T
    end:       T
    inclusive: bool
    cursor:    T
}

// Single bounded generic impl pair covering every integer width plus `char`.
// `T : Comparable & Step` lets the bodies dispatch `lt`/`lte`/`gt`/`gte`
// to T's `Comparable` impl and the advance step to T's `Step` impl —
// concrete `+ 1` / codepoint-bump logic lives in those per-primitive impls
// in this same file (search for `implements Step` and `implements
// Comparable`). The mono pass materialises one specialisation per concrete
// `Range[T]` instance the program uses ; the lowerer routes each method
// call to the right primitive impl statically.

Range[T] implements[T: Comparable & Step] Contains[T] {
    contains :: fn(self, value: T) -> bool {
        if value.lt(self.start) { return false }
        if self.inclusive       { return value.lte(self.end) }
        return value.lt(self.end)
    }
}

Range[T] implements[T: Comparable & Step] Iterator[T] {
    next :: fn(self) -> Yield(T) | null {
        done :: if (self.inclusive) { self.cursor.gt(self.end) }
                else                 { self.cursor.gte(self.end) }
        if (done) { return null }
        v :: self.cursor
        self.cursor = self.cursor.step()
        return Yield(T) { .value = v }
    }
}

/// Iterator over a `T[]`. The lowerer auto-wraps array exprs flowing into
/// `for x in arr`, so direct construction is rarely needed. `length` is
/// pre-computed at construction time so `step` avoids re-querying
/// `arr.len()` per iteration.
export ArrayIterator :: struct[T] {
    arr:    T[]
    cursor: usize
    length: usize
}

ArrayIterator[T] implements Iterator[T] {
    next :: fn(self) -> Yield(T) | null {
        if (self.cursor >= self.length) { return null }
        v :: self.arr[self.cursor]
        self.cursor = self.cursor + 1
        return Yield(T) { .value = v }
    }
}

// Blanket Into impls live here so the orphan rule passes — Into is owned
// by std/core, the source shapes (`T[]`, bounded `T`) aren't.

T[] implements[T] Into(Iterator(T)) {
    into :: fn(self) -> Iterator(T) {
        return ArrayIterator(T) { .arr = self, .cursor = usize(0), .length = self.len() }
    }
}

T implements[T: Display] Into(string) {
    into :: fn(self) -> string {
        return self.to_string()
    }
}

// ============================================================================
// 3. Primitive type impls
// ============================================================================
//
// `@intrinsic` impls route the call directly to the matching bytecode op
// via `OP_INTRINSIC_BY_MANGLED` (see `src/bytecode/emit.ts`) — no fn-call
// indirection, identical performance to the operator form. `s1 + s2` and
// `(s1).add(s2)` share a single runtime path.

// ---- Display --------------------------------------------------------------
//
// Every primitive type carries a host-provided `to_string` so any value
// flowing into a `string` slot (e.g. `print(value)`, `let s: string =
// value`) routes through the blanket `T implements[T: Display] Into(string)`
// declared above. `${x}` string interpolation bypasses the trait and
// goes through the dedicated `builder.append_display` intrinsic for
// performance.

@intrinsic i8     implements Display
@intrinsic i16    implements Display
@intrinsic i32    implements Display
@intrinsic i64    implements Display
@intrinsic isize  implements Display
@intrinsic u8     implements Display
@intrinsic u16    implements Display
@intrinsic u32    implements Display
@intrinsic u64    implements Display
@intrinsic usize  implements Display
@intrinsic f32    implements Display
@intrinsic f64    implements Display
@intrinsic bool   implements Display
@intrinsic char   implements Display
@intrinsic string implements Display

// ---- Equals ---------------------------------------------------------------

@intrinsic i8     implements Equals
@intrinsic i16    implements Equals
@intrinsic i32    implements Equals
@intrinsic i64    implements Equals
@intrinsic isize  implements Equals
@intrinsic u8     implements Equals
@intrinsic u16    implements Equals
@intrinsic u32    implements Equals
@intrinsic u64    implements Equals
@intrinsic usize  implements Equals
@intrinsic f32    implements Equals
@intrinsic f64    implements Equals
@intrinsic bool   implements Equals
@intrinsic char   implements Equals
@intrinsic string implements Equals

// ---- Hash -----------------------------------------------------------------
//
// Integer Hash impls cast through u64 ; `string` uses FNV-1a over the
// UTF-8 bytes (host-provided).

i8    implements Hash -> u64(self)
i16   implements Hash -> u64(self)
i32   implements Hash -> u64(self)
i64   implements Hash -> u64(self)
isize implements Hash -> u64(self)
u8    implements Hash -> u64(self)
u16   implements Hash -> u64(self)
u32   implements Hash -> u64(self)
u64   implements Hash -> u64(self)
usize implements Hash -> u64(self)
char  implements Hash -> u64(self)

@intrinsic string implements Hash

// ---- Comparable -----------------------------------------------------------
//
// Three-way `compare` for every integer width plus `char`. Floats are
// excluded — IEEE-754's NaN breaks total ordering, so an `Ord`-style trait
// is the right shape for f32/f64 and is deferred. `lt`/`lte`/`gt`/`gte`
// come from Comparable's default-method injection ; impls only provide
// `compare`.

i8    implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
i16   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
i32   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
i64   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
isize implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
u8    implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
u16   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
u32   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
u64   implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
usize implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }
char  implements Comparable -> if self < other { -1 } else if self > other { 1 } else { 0 }

// ---- Step -----------------------------------------------------------------
//
// Discrete-successor logic per primitive. Every integer width bumps by 1 ;
// `char` round-trips through u32 since it has no native `+ i32` op. Floats
// are intentionally excluded — there's no canonical `next float` semantics.

i8    implements Step -> self + 1
i16   implements Step -> self + 1
i32   implements Step -> self + 1
i64   implements Step -> self + 1
isize implements Step -> self + 1
u8    implements Step -> self + 1
u16   implements Step -> self + 1
u32   implements Step -> self + 1
u64   implements Step -> self + 1
usize implements Step -> self + 1
char  implements Step -> char(u32(self) + u32(1))

// ---- Numeric arithmetic ---------------------------------------------------
//
// Add/Sub/Mul/Div for every primitive numeric type. Makes `[T: Add]` and
// friends usable on every numeric primitive — `5 + 7` and `(5).add(7)`
// share one path.

@intrinsic i8 implements Add
@intrinsic i8 implements Sub
@intrinsic i8 implements Mul
@intrinsic i8 implements Div

@intrinsic i16 implements Add
@intrinsic i16 implements Sub
@intrinsic i16 implements Mul
@intrinsic i16 implements Div

@intrinsic i32 implements Add
@intrinsic i32 implements Sub
@intrinsic i32 implements Mul
@intrinsic i32 implements Div

@intrinsic i64 implements Add
@intrinsic i64 implements Sub
@intrinsic i64 implements Mul
@intrinsic i64 implements Div

@intrinsic isize implements Add
@intrinsic isize implements Sub
@intrinsic isize implements Mul
@intrinsic isize implements Div

@intrinsic u8 implements Add
@intrinsic u8 implements Sub
@intrinsic u8 implements Mul
@intrinsic u8 implements Div

@intrinsic u16 implements Add
@intrinsic u16 implements Sub
@intrinsic u16 implements Mul
@intrinsic u16 implements Div

@intrinsic u32 implements Add
@intrinsic u32 implements Sub
@intrinsic u32 implements Mul
@intrinsic u32 implements Div

@intrinsic u64 implements Add
@intrinsic u64 implements Sub
@intrinsic u64 implements Mul
@intrinsic u64 implements Div

@intrinsic usize implements Add
@intrinsic usize implements Sub
@intrinsic usize implements Mul
@intrinsic usize implements Div

@intrinsic f32 implements Add
@intrinsic f32 implements Sub
@intrinsic f32 implements Mul
@intrinsic f32 implements Div

@intrinsic f64 implements Add
@intrinsic f64 implements Sub
@intrinsic f64 implements Mul
@intrinsic f64 implements Div

// ---- String ---------------------------------------------------------------
//
// `Add` is wired here in std/core (auto-imported) so concat works without
// `import "std/string"`. `Index(usize, char)` returns the Unicode codepoint
// at byte offset `i` — strings are immutable so there's no `IndexSet` to
// pair with. Number formatting (`to_hex`, `to_bin`) lives in `std/numbers`
// so it can use `std/string_builder`.

@intrinsic string implements Add
@intrinsic string implements Index(usize, char)
