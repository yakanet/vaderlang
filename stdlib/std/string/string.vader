// std/string — string operations.
//
// All string operations treat strings as immutable UTF-8 byte sequences.
// Width-based helpers (`pad_start`, `pad_end`) measure width in bytes, not
// codepoints — accurate for ASCII, approximate for non-ASCII content.

module "std/string"

import "std/string_builder" { StringBuilder, new_builder, append, append_char }
import "std/math" { min }
import "std/utf8" { codepoint_byte_len }

/// Length in bytes. The string API is intentionally byte-indexed
/// (`slice`, `byte_at`, `contains` all operate on byte offsets ; `s[i]`
/// from `std/core` decodes the codepoint at byte offset `i`) — naming
/// this `byte_len` forces the reader to acknowledge the byte/codepoint
/// distinction and pick `count_chars` deliberately if they want the
/// codepoint count.
export byte_len :: fn(s: string) -> usize

/// True for the empty string. Equivalent to `s.byte_len() == 0` but
/// reads cleanly at call sites — emptiness is the same in byte and
/// codepoint views.
export is_empty :: fn(s: string) = s.byte_len() == 0

/// Substring `[start, end)` — exclusive upper bound, byte-indexed.
/// `start` and `end` should land on UTF-8 leading bytes ; landing mid-
/// codepoint produces a malformed-UTF-8 slice.
/// @param s      source string.
/// @param start  byte offset of the first char (inclusive).
/// @param end    byte offset just past the last char (exclusive).
export slice :: fn(s: string, start: usize, end: usize) -> string

/// True iff `sub` appears anywhere in `s`. Byte-wise scan. Module-
/// private — external callers go through `sub in s` (Contains trait
/// impl below) or UFCS `s.contains(sub)`. The decl stays here so the
/// trait impl body can delegate to the runtime intrinsic.
contains :: fn(s: string, sub: string) -> bool

/// True iff `s` starts with `prefix`. Byte-wise comparison.
export starts_with :: fn(s: string, prefix: string) -> bool

/// True iff `s` ends with `suffix`. Byte-wise comparison.
export ends_with :: fn(s: string, suffix: string) -> bool

/// Raw byte at offset `i`. Useful for ASCII fast paths and binary-format
/// scanning (BOM detection, magic bytes). For UTF-8-aware iteration use
/// `chars()`.
export byte_at :: fn(s: string, i: usize) -> u8

/// Iterator yielding raw bytes - the UTF-8 byte sequence as-is. Use for
/// ASCII data, binary protocols carried in strings, or when computing a
/// byte-level digest. For codepoint iteration use `chars()` instead.
export StringBytes :: struct {
    s:      string
    cursor: usize
    length: usize
}

StringBytes implements Iterator(u8) {
    next :: fn(self) -> Yield(u8) | null {
        if (self.cursor >= self.length) {
            return null
        }
        b :: self.s.byte_at(self.cursor)
        self.cursor = self.cursor + 1
        return Yield(u8) { .value = b }
    }
}

/// Iterate `s` byte-by-byte. Pair with `for b in s.bytes()` for raw byte
/// processing.
///
/// Example :
///   `sum: u32 = u32(0)`
///   `for b in "vader".bytes() { sum = sum + u32(b) }`
///
/// @param s  source string.
/// @return   a `StringBytes` iterator over its UTF-8 bytes.
export bytes :: fn(s: string) -> StringBytes {
    return StringBytes { .s = s, .cursor = usize(0), .length = s.byte_len() }
}

/// Iterator yielding Unicode codepoints — one per UTF-8 sequence,
/// regardless of whether the codepoint is encoded in 1, 2, 3, or 4
/// bytes. The cursor moves in bytes ; `length` is the byte length of the
/// source string, captured at construction so `step` doesn't recompute it.
export StringChars :: struct {
    s:      string
    cursor: usize
    length: usize
}

StringChars implements Iterator(char) {
    next :: fn(self) -> Yield(char) | null {
        if (self.cursor >= self.length) {
            return null
        }
        c :: self.s[self.cursor]
        self.cursor = self.cursor + codepoint_byte_len(c)
        return Yield(char) { .value = c }
    }
}

/// Iterate `s` codepoint-by-codepoint. `for c in s` desugars to this via
/// the `Into(Iterator(char))` impl below — call `s.chars()` explicitly
/// only when you need the iterator as a value. Byte-indexed `s[i]` loops
/// return U+FFFD on continuation bytes for non-ASCII content ; prefer
/// `for c in s` for Unicode-correct iteration.
///
/// Example :
///   `for c in "héllo" { println("${c}") }`
///
/// @param s  source string.
/// @return   a `StringChars` iterator over its codepoints.
export chars :: fn(s: string) -> StringChars {
    return StringChars { .s = s, .cursor = usize(0), .length = s.byte_len() }
}

// `for c in s` desugars to `for c in s.into()` via this impl — codepoints
// are the default unit. Byte iteration stays opt-in via `s.bytes()`.
string implements Into(Iterator(char)) {
    into :: fn(self) -> Iterator(char) {
        return StringChars { .s = self, .cursor = usize(0), .length = self.byte_len() }
    }
}

/// Lets `sub in s` desugar to `s.contains(sub)`. The Contains trait
/// (std/core) is what the `in` operator dispatches through ; without
/// this impl `in` on string falls back to "language feature unsupported"
/// at the lower stage. The trait method body delegates to the free
/// `contains` fn above (a byte-wise scan implemented by the runtime).
string implements Contains[string] {
    contains :: fn(self, sub: string) -> bool { return contains(self, sub) }
}

/// Decode the UTF-8 sequence at byte offset `i` into a codepoint and its
/// encoded byte length. Returns `[c, n]` where `c` is the codepoint and
/// `n` is the number of bytes consumed (1 to 4) — advance the caller's
/// cursor by `n` to land on the next leading byte.
///
/// Caller must ensure `i` points at a leading byte (cursor invariant
/// preserved by always advancing in `n`-byte steps from 0). For an offset
/// landing on a continuation byte, `s[i]` returns `U+FFFD` and `n = 3` —
/// incorrect for resync, so callers must not feed arbitrary offsets.
///
/// Bounds aren't checked : `i` must satisfy `0 <= i < s.byte_len()`.
///
/// Example :
///   `[c, n] := decode_codepoint("héllo", 1)   // c = 'é', n = 2`
///
/// @param s  source string.
/// @param i  byte offset of a UTF-8 leading byte.
/// @return   `[codepoint, byte_length]`.
export decode_codepoint :: fn(s: string, i: usize) -> [char, usize] {
    c :: s[i]
    return [c, codepoint_byte_len(c)]
}

/// Count the Unicode codepoints in `s` — what `byte_len()` would return
/// in a codepoint-indexed language. Walks the UTF-8 byte sequence
/// directly via leading-byte widths ; cheaper than `s.chars().count()`
/// because it avoids the per-step `Yield(char)` allocation.
///
/// Example :
///   `count_chars("héllo")    // 5  (byte_len() would return 6)`
///   `count_chars("你好")     // 2  (byte_len() would return 6)`
///   `count_chars("")         // 0`
///
/// @param s  source string.
/// @return   number of codepoints in `s`.
export count_chars :: fn(s: string) = s.chars().count()

/// Comparator suitable for `sort(arr, compare_ascending)` : returns `true`
/// when `a` lexicographically precedes `b` (byte-wise). Mirrors JS
/// `s1 < s2`. Will become `Comparable(string)::less` once trait-method
/// dispatch on bounded type parameters lands (TODO §1.18b).
/// @param a  left string.
/// @param b  right string.
/// @return   `true` iff `a` strictly precedes `b` ; equal strings → `false`.
export compare_ascending :: fn(a: string, b: string) -> bool {
    la :: a.byte_len()
    lb :: b.byte_len()
    n :: min(la, lb)
    for i in 0..<n {
        ca :: a[i]
        cb :: b[i]
        if ca < cb { return true }
        if ca > cb { return false }
    }
    return la < lb
}

/// Case-insensitive ASCII variant of `compare_ascending`. Matches
/// JavaScript's default `String.localeCompare()` ordering for the
/// ASCII subset (case-folded comparison ; ties broken by code point).
export compare_ascending_ci :: fn(a: string, b: string) -> bool {
    la :: a.byte_len()
    lb :: b.byte_len()
    n :: min(la, lb)
    for i in 0..<n {
        ca :: to_lower_byte(a.byte_at(i))
        cb :: to_lower_byte(b.byte_at(i))
        if ca < cb { return true }
        if ca > cb { return false }
    }
    if la != lb { return la < lb }
    // Equal folded — break ties by raw bytes so the order stays total.
    for i in 0..<n {
        ra :: a.byte_at(i)
        rb :: b.byte_at(i)
        if ra < rb { return true }
        if ra > rb { return false }
    }
    return false
}

to_lower_byte :: fn(c: u8) -> u8 {
    if c >= u8(0x41) && c <= u8(0x5A) { return c + u8(0x20) }
    return c
}

/// Byte-index of the LAST occurrence of `c` at or after `min_index`,
/// scanning from the right. Returns `-1` when not found. The signed
/// `isize` return type lets callers branch on `result < 0` ; `usize` would
/// have collapsed "absent" into "0" ambiguously.
/// @param s          source string.
/// Byte offset of the *last* occurrence of `c` in `s`. Walks `s`
/// codepoint-by-codepoint (UTF-8 safe — the byte cursor advances by
/// each codepoint's encoded width, so multi-byte sequences are never
/// sliced mid-stream), tracking the latest matching position. The
/// returned offset is a leading-byte index ; valid input to `slice`.
///
/// @param s          source string.
/// @param c          codepoint to find.
/// @param min_index  earliest leading-byte position to keep as a
///                   match (later matches still win). Pass `0` to
///                   accept every position.
/// @return           byte offset of the latest match, or `-1` if absent.
export last_index_of :: fn(s: string, c: char, min_index: isize) -> isize {
    n :: s.byte_len()
    last: isize = -1
    i: usize = 0
    for i < n {
        [cp, width] :: s.decode_codepoint(i)
        if isize(i) >= min_index && cp == c { last = isize(i) }
        i += width
    }
    return last
}

/// Byte offset of the *first* occurrence of `c` in `s`, starting at
/// the codepoint that begins at byte `from` (inclusive). UTF-8 safe —
/// see `last_index_of` for the iteration model. `from` should align
/// to a leading byte ; out-of-range values short-circuit to `-1`.
///
/// @param s     source string.
/// @param c     codepoint to find.
/// @param from  earliest leading-byte position considered.
/// @return      byte offset of the match, or `-1` if absent.
export index_of :: fn(s: string, c: char, from: usize) -> isize {
    n :: s.byte_len()
    i := from
    for i < n {
        [cp, width] :: s.decode_codepoint(i)
        if cp == c { return isize(i) }
        i += width
    }
    return -1
}

/// Split `s` on every occurrence of `sep`, returning the resulting
/// segments. Empty segments are preserved (between consecutive `sep`
/// runs and at the ends). For predicate-based splitting see
/// `split_where`.
/// @param s    source string.
/// @param sep  separator (matched byte-wise). Empty `sep` is undefined.
/// @return     array of segments ; never empty (at minimum, `[""]`).
export split :: fn(s: string, sep: string) -> string[]

/// Strip leading and trailing ASCII whitespace (`' '`, `'\t'`, `'\n'`,
/// `'\r'`). Unicode whitespace is not recognised in MVP.
export trim :: fn(s: string) -> string

/// ASCII-uppercase every letter (`a..z` → `A..Z`). Non-ASCII bytes pass
/// through unchanged.
export to_upper :: fn(s: string) -> string

/// ASCII-lowercase every letter (`A..Z` → `a..z`). Non-ASCII bytes pass
/// through unchanged.
export to_lower :: fn(s: string) -> string

/// Error raised by `parse_int` / `parse_float` on malformed input.
export ParseError :: struct {
    msg: string
}

ParseError implements Error {
    message :: fn(self) -> string { return self.msg }
}

/// Parse `s` as a base-10 `i32`. No prefix, no underscores, no leading
/// `+` sign ; a leading `-` is accepted.
/// @param s   the digits-only input.
/// @return    the parsed integer.
/// @error     `ParseError` on empty input, malformed digit, or overflow.
export parse_int :: fn(s: string) -> i32!

/// Parse `s` as an `f64`. Accepts mantissa + optional exponent.
/// @param s   the float input.
/// @return    the parsed float.
/// @error     `ParseError` on malformed input.
export parse_float :: fn(s: string) -> f64!

/// Pad `s` on the LEFT with copies of `fill` until its byte length
/// reaches `width`. Returns `s` unchanged when it's already at least
/// `width` bytes long. Width counts bytes ; accurate for ASCII,
/// approximate for non-ASCII content.
/// @param s      source string.
/// @param width  target byte length.
/// @param fill   pad character (ASCII recommended).
export pad_start :: fn(s: string, width: usize, fill: char) -> string {
    n := s.byte_len()
    if n >= width {
        return s
    }
    sb := new_builder()
    i := n
    for i < width {
        sb.append_char(fill)
        i = i + 1
    }
    sb.append(s)
    return sb.to_string()
}

/// Pad `s` on the RIGHT with copies of `fill` until its byte length
/// reaches `width`. Symmetric with `pad_start`.
export pad_end :: fn(s: string, width: usize, fill: char) -> string {
    n := s.byte_len()
    if n >= width {
        return s
    }
    sb := new_builder()
    sb.append(s)
    i := n
    for i < width {
        sb.append_char(fill)
        i = i + 1
    }
    return sb.to_string()
}

/// True for an ASCII whitespace codepoint — space, tab, newline, or
/// carriage return. Unicode whitespace is not recognised in MVP.
export is_white_char :: fn(c: char) = c == ' ' || c == '\t' || c == '\n' || c == '\r'

/// True for an ASCII decimal digit `0..9`. Base-aware predicates
/// (`is_hex_digit`, `is_digit_in_base`) live in `std/numbers`.
export is_digit :: fn(c: char) = c in '0'..='9'

/// True for an ASCII letter — `a..z` or `A..Z`. Locale-independent ;
/// Unicode letters are not recognised in MVP.
/// @param c  codepoint to classify.
/// @return   `true` iff `c` is an ASCII letter.
export is_alpha :: fn(c: char) = c in 'a'..='z' || c in 'A'..='Z'

/// True for an ASCII letter or decimal digit — `a..z`, `A..Z`, or `0..9`.
/// Composes `is_alpha` and `is_digit`.
/// @param c  codepoint to classify.
/// @return   `true` iff `c` is alphanumeric.
export is_alnum :: fn(c: char) = c.is_alpha() || c.is_digit()

/// Strip `suffix` if `s` ends with it ; otherwise return `s` unchanged.
/// Trims at most one occurrence.
export trim_suffix :: fn(s: string, suffix: string) -> string {
    if s.ends_with(suffix) {
        return s.slice(0, s.byte_len() - suffix.byte_len())
    }
    return s
}

/// Strip `prefix` if `s` starts with it ; otherwise return `s` unchanged.
/// Trims at most one occurrence.
export trim_prefix :: fn(s: string, prefix: string) -> string {
    if s.starts_with(prefix) {
        return s.slice(prefix.byte_len(), s.byte_len())
    }
    return s
}

/// Decode the common C-style escape sequences in `body` :
///   `\n` → LF, `\t` → TAB, `\r` → CR, `\"` → `"`, `\\` → `\`, `\0` → NUL.
/// A backslash at the very end of `body` is preserved verbatim. Strings
/// that don't contain a backslash skip the per-byte rebuild and return
/// the original slice unchanged.
///
/// @note Lenient. Unknown escapes (e.g. `\q`) drop the leading backslash
///       and pass the following byte through (`"a\\qb"` → `"aqb"`).
///       Mirrors the lexer / VM parser's behaviour ; callers that want
///       strict-mode rejection should validate beforehand.
///
/// @param body  the raw source bytes (without surrounding quotes).
/// @return      the decoded string.
/// @example
///   `decode_escapes(r"a\nb\tc")  // "a\nb\tc" (literal LF + TAB)`
///   `decode_escapes("plain")     // "plain"`
export decode_escapes :: fn(body: string) -> string {
    if !body.contains("\\") { return body }
    out :: new_builder()
    n :: body.byte_len()
    i: usize = 0
    for i < n {
        b :: body.byte_at(i)
        if b != b'\\' {
            out.append(body.slice(i, i + usize(1)))
            i += usize(1)
            continue
        }
        if i + usize(1) >= n {
            out.append(body.slice(i, i + usize(1)))
            i += usize(1)
            continue
        }
        next :: body.byte_at(i + usize(1))
        if      next == b'n'  { out.append("\n") }
        else if next == b't'  { out.append("\t") }
        else if next == b'r'  { out.append("\r") }
        else if next == b'"'  { out.append("\"") }
        else if next == b'\\' { out.append("\\") }
        else if next == b'0'  { out.append("\0") }
        else                     { out.append(body.slice(i + usize(1), i + usize(2))) }
        i += usize(2)
    }
    return out.to_string()
}

/// Replace every codepoint that satisfies `pred` with `replacement`.
/// Subsumes the regex pattern `replace(/[<class>]/g, "…")`.
/// @param s            source string.
/// @param pred         predicate over each codepoint.
/// @param replacement  string to substitute for each match.
/// @return             a fresh string.
export replace_chars_where :: fn(s: string, pred: fn(char) -> bool, replacement: string) -> string {
    sb := new_builder()
    for c in s.chars() {
        if pred(c) {
            sb.append(replacement)
        } else {
            sb.append_char(c)
        }
    }
    return sb.to_string()
}

/// Split `s` on runs of characters matching `pred`, dropping empty
/// segments. Mirrors `replace_chars_where(s, pred, ...)` — same predicate
/// convention, same pair-with-`is_*` ergonomics. For whitespace
/// splitting, pass `is_white_char` ; for word-boundary splitting
/// (alphanumeric runs), pass `c => !c.is_alnum()`. Empty inputs return
/// an empty array.
/// @param s     source string.
/// @param pred  predicate over each codepoint ; truthy → separator.
/// @return      non-empty segments (in source order).
/// @example
///    `"  hello\tworld  ".split_where(is_white_char) → ["hello", "world"]`
///    `"a,b,,c".split_where(c => c == ',') → ["a", "b", "c"]`
export split_where :: fn(s: string, pred: fn(char) -> bool) -> string[] {
    out: string[] = []
    sb := new_builder()
    has_pending := false
    for c in s.chars() {
        if pred(c) {
            if has_pending {
                out.push(sb.to_string())
                sb = new_builder()
                has_pending = false
            }
        } else {
            sb.append_char(c)
            has_pending = true
        }
    }
    if has_pending {
        out.push(sb.to_string())
    }
    return out
}

// ---------------------------------------------------------------------- tests

import "std/testing" { assert, assert_eq, assert_close }

@test test_byte_len :: fn() -> void {
    assert_eq(byte_len(""), usize(0))
    assert_eq(byte_len("abc"), usize(3))
    assert_eq(byte_len("héllo"), usize(6))
}

@test test_is_empty :: fn() -> void {
    assert(is_empty(""), "empty string should be empty")
    assert(!is_empty("x"), "non-empty string should not be empty")
}

@test test_slice :: fn() -> void {
    assert_eq(slice("hello", usize(0), usize(5)), "hello")
    assert_eq(slice("hello", usize(1), usize(4)), "ell")
    assert_eq(slice("hello", usize(0), usize(0)), "")
}

@test test_contains :: fn() -> void {
    assert("world" in "hello world", "contains world")
    assert("a" in "abc", "contains first char")
    assert(!("z" in "abc"), "does not contain z")
    assert("" in "anything", "every string contains empty")
}

@test test_starts_ends_with :: fn() -> void {
    assert(starts_with("hello", "hell"), "starts_with hell")
    assert(!starts_with("hello", "world"), "does not start_with world")
    assert(ends_with("hello", "llo"), "ends_with llo")
    assert(!ends_with("hello", "world"), "does not end_with world")
}

@test test_trim :: fn() -> void {
    assert_eq(trim("  hello  "), "hello")
    assert_eq(trim("\t\nhi\r\n"), "hi")
    assert_eq(trim("clean"), "clean")
    assert_eq(trim("   "), "")
}

@test test_case :: fn() -> void {
    assert_eq(to_upper("hello"), "HELLO")
    assert_eq(to_lower("HeLLo"), "hello")
    assert_eq(to_upper(""), "")
}

@test test_parse_int_ok :: fn() -> void {
    match parse_int("42") {
        is i32 as v -> assert_eq(v, 42)
        is Error -> assert(false, "expected ok i32")
    }
    match parse_int("-7") {
        is i32 as v -> assert_eq(v, -7)
        is Error -> assert(false, "expected ok i32")
    }
}

@test test_parse_int_err :: fn() -> void {
    match parse_int("abc") {
        is i32 -> assert(false, "expected err on abc")
        is Error -> {}
    }
}

@test test_parse_float :: fn() -> void {
    match parse_float("3.14") {
        is f64 as v -> assert_close(v, 3.14, 0.000001)
        is Error -> assert(false, "expected ok f64")
    }
}

@test test_pad :: fn() -> void {
    assert_eq(pad_start("42", usize(5), '0'), "00042")
    assert_eq(pad_end("hi", usize(5), '.'), "hi...")
    assert_eq(pad_start("already long", usize(3), 'x'), "already long")
}

@test test_char_predicates :: fn() -> void {
    assert(is_white_char(' '), "space is whitespace")
    assert(is_white_char('\t'), "tab is whitespace")
    assert(is_white_char('\n'), "newline is whitespace")
    assert(!is_white_char('a'), "letter is not whitespace")
    assert(is_digit('5'), "5 is a digit")
    assert(!is_digit('a'), "a is not a digit")
    assert(is_alpha('a'), "a is alpha")
    assert(is_alpha('Z'), "Z is alpha")
    assert(!is_alpha('5'), "5 is not alpha")
    assert(is_alnum('x'), "x is alnum")
    assert(is_alnum('7'), "7 is alnum")
    assert(!is_alnum(' '), "space is not alnum")
}

@test test_trim_prefix_suffix :: fn() -> void {
    assert_eq(trim_prefix("hello.world", "hello."), "world")
    assert_eq(trim_prefix("no-match", "xxx"), "no-match")
    assert_eq(trim_suffix("file.txt", ".txt"), "file")
    assert_eq(trim_suffix("no-match", "xxx"), "no-match")
}

@test test_count_chars :: fn() -> void {
    assert_eq(count_chars(""), usize(0))
    assert_eq(count_chars("abc"), usize(3))
    assert_eq(count_chars("héllo"), usize(5))
}

@test test_last_index_of :: fn() -> void {
    assert_eq(last_index_of("a/b/c", '/', isize(-1)), isize(3))
    assert_eq(last_index_of("none", '/', isize(-1)), isize(-1))
}

@test test_decode_escapes :: fn() -> void {
    assert_eq(decode_escapes(""),            "")
    assert_eq(decode_escapes("plain"),       "plain")
    assert_eq(decode_escapes("a\\nb"),       "a\nb")
    assert_eq(decode_escapes("a\\tb"),       "a\tb")
    assert_eq(decode_escapes("a\\rb"),       "a\rb")
    assert_eq(decode_escapes("a\\0b"),       "a\0b")
    assert_eq(decode_escapes("a\\\\b"),      "a\\b")
    assert_eq(decode_escapes("\\\"q\\\""),   "\"q\"")
    assert_eq(decode_escapes("a\\qb"),       "aqb")            // unknown escape : drop the backslash
    assert_eq(decode_escapes("trailing\\"),  "trailing\\")     // dangling backslash preserved
}
