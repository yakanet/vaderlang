// std/string — string operations.
//
// All string operations treat strings as immutable UTF-8 byte sequences.
// Width-based helpers (`pad_start`, `pad_end`) measure width in bytes, not
// codepoints — accurate for ASCII, approximate for non-ASCII content.

module "std/string"

import "std/string_builder" { StringBuilder, append, append_char }
import "std/math" { min }

// Length in bytes. Module-internal (NOT exported) — callers write
// `s.bytes().len()`, which the lowerer folds to an O(1) call of this host fn
// (see `src/lower/passes/fold-byte-len.ts` / `vader/lower/fold_byte_len.vader`).
// Kept as a bodyless host decl so the fold has a target; DCE roots it
// unconditionally as a bodyless host fn.
@intrinsic byte_len :: fn(s: string) -> usize

/// True for the empty string. Equivalent to `s.byte_len() == 0` but
/// reads cleanly at call sites — emptiness is the same in byte and
/// codepoint views.
export is_empty :: fn(s: string) -> bool = s.bytes().len() == 0

/// True iff `sub` appears anywhere in `s`. Byte-wise scan. Module-private —
/// callers go through `sub in s` (Contains impl below) or UFCS
/// `s.contains(sub)`. Named distinctly from the trait method (`contains`) to
/// avoid shadowing it inside the impl body.
byte_contains :: fn(s: string, sub: string) -> bool = byte_find(s, sub, 0) >= 0

/// True iff `s` starts with `prefix`. Byte-wise comparison.
export starts_with :: fn(s: string, prefix: string) -> bool {
    sb :: s.bytes()
    pb :: prefix.bytes()
    pl :: pb.len()
    if pl > sb.len() { return false }
    for i in 0..<pl {
        if sb[i] != pb[i] { return false }
    }
    return true
}

/// True iff `s` ends with `suffix`. Byte-wise comparison.
export ends_with :: fn(s: string, suffix: string) -> bool {
    sb :: s.bytes()
    fb :: suffix.bytes()
    sl :: fb.len()
    n  :: sb.len()
    if sl > n { return false }
    off :: n - sl
    for i in 0..<sl {
        if sb[off + i] != fb[i] { return false }
    }
    return true
}

// `bytes` (string→`const u8[]` view) moved to `std/core` (the prelude) in
// Target ABI S3 — it sits below `std/string_builder`, which now needs it, and
// `std/string` imports `std/string_builder`, so keeping `bytes` here would make
// the buffer-backed builder's dependency a cycle. It is ambient now ; callers
// drop it from their `import "std/string" { … }` lists.

/// Iterator yielding Unicode codepoints — one per UTF-8 sequence,
/// regardless of whether the codepoint is encoded in 1, 2, 3, or 4
/// bytes. The cursor moves in bytes ; `length` is the byte length of the
/// source string, captured at construction so `step` doesn't recompute it.
export StringChars :: struct {
    /// Byte view captured once at construction — `next` decodes a codepoint per
    /// step off this held view (one view alloc per loop, not one per codepoint).
    /// A borrowed view self-roots its owner atom through the GC (the array header
    /// carries the owner id ; `vader_atom_mark_heap` keeps it alive), so no
    /// separate string handle is needed.
    bytes:  const u8[]
    cursor: usize
    length: usize
}

StringChars implements Iterator<char> {
    next :: fn(self) -> Yield<char> | null {
        if (self.cursor >= self.length) {
            return null
        }
        [c, width] :: self.bytes.utf8_decode_len(self.cursor)
        self.cursor = self.cursor + width
        return Yield<char> { .value = c }
    }
}

/// Iterate `s` codepoint-by-codepoint. `for c in s` desugars to this via
/// the `Into(Iterator(char))` impl below — call `s.chars()` explicitly
/// only when you need the iterator as a value. Byte-indexed `s[i]` loops
/// return U+FFFD on continuation bytes for non-ASCII content ; prefer
/// `for c in s` for Unicode-correct iteration.
///
/// Example :
///   `for c in "héllo" { println("${c}") }`
///
/// @param s  source string.
/// @return   a `StringChars` iterator over its codepoints.
export chars :: fn(s: string) -> StringChars {
    bs :: s.bytes()
    return StringChars { .bytes = bs, .cursor = 0, .length = bs.len() }
}

// `for c in s` desugars to `for c in s.into()` via this impl — codepoints
// are the default unit. Byte iteration stays opt-in via `s.bytes()`.
string implements Into<Iterator<char>> {
    into :: fn(self) -> Iterator<char> {
        bs :: self.bytes()
        return StringChars { .bytes = bs, .cursor = 0, .length = bs.len() }
    }
}

/// Lets `sub in s` desugar to `s.contains(sub)`. The Contains trait
/// (std/core) is what the `in` operator dispatches through ; without this
/// impl `in` on string falls back to "language feature unsupported" at the
/// lower stage. The method delegates to the module-private `byte_contains`
/// (a byte-wise scan) — pure Vader, resolved on the self-host VM since the
/// for-in/impl-member materialisation gap (GATE B1) was fixed.
string implements Contains<string> {
    contains :: fn(self, sub: string) -> bool { return byte_contains(self, sub) }
}

// `len` (codepoint count) moved to `std/core` (the prelude) so `s.len()`
// resolves without importing `std/string`. It was the one string method the
// typer hardcoded as a primitive (`primitive_method_type`) while the lowerer
// could only reach it via free-fn UFCS over loaded modules — a mismatch that
// miscompiled `s.len()` to invalid C unless std/string happened to be loaded.
// Now a plain core free fn (byte-walk) ; callers drop it from their
// `import "std/string" { … }` lists. See the core/string/utf8 reorg plan :
// .claude/plans/core-string-utf8-reorg.md.

/// Comparator suitable for `sort(arr, compare_ascending)` : returns `true`
/// when `a` lexicographically precedes `b` (byte-wise). Mirrors JS
/// `s1 < s2`. Will become `Comparable(string)::less` once trait-method
/// dispatch on bounded type parameters lands (TODO §1.18b).
/// @param a  left string.
/// @param b  right string.
/// @return   `true` iff `a` strictly precedes `b` ; equal strings → `false`.
export compare_ascending :: fn(a: string, b: string) -> bool {
    la :: a.bytes().len()
    lb :: b.bytes().len()
    n :: min(la, lb)
    for i in 0..<n {
        ca :: a[i]
        cb :: b[i]
        if ca < cb { return true }
        if ca > cb { return false }
    }
    return la < lb
}

/// Case-insensitive ASCII variant of `compare_ascending`. Matches
/// JavaScript's default `String.localeCompare()` ordering for the
/// ASCII subset (case-folded comparison ; ties broken by code point).
export compare_ascending_ci :: fn(a: string, b: string) -> bool {
    ab :: a.bytes()
    bb :: b.bytes()
    la :: ab.len()
    lb :: bb.len()
    n :: min(la, lb)
    for i in 0..<n {
        ca :: to_lower_byte(ab[i])
        cb :: to_lower_byte(bb[i])
        if ca < cb { return true }
        if ca > cb { return false }
    }
    if la != lb { return la < lb }
    // Equal folded — break ties by raw bytes so the order stays total.
    for i in 0..<n {
        ra :: ab[i]
        rb :: bb[i]
        if ra < rb { return true }
        if ra > rb { return false }
    }
    return false
}

to_lower_byte :: fn(c: u8) -> u8 {
    if c >= 'A' && c <= 'Z' { return c + ('a' - 'A') }
    return c
}

// ASCII whitespace byte (space, tab, LF, CR) — the byte-level counterpart of
// `is_white_char`, used by the trim family.
is_white_byte :: fn(b: u8) = b == ' ' || b == '\t' || b == '\n' || b == '\r'

// True iff the `m` bytes of `subb` match `sb` starting at byte offset `off`.
// Takes byte views (not strings) so the caller holds them once across the scan.
bytes_match_at :: fn(sb: const u8[], off: usize, subb: const u8[], m: usize) -> bool {
    for j in 0..<m {
        if sb[off + j] != subb[j] { return false }
    }
    return true
}

// Byte-wise substring search — first offset >= `from` where `sub` occurs in
// `s`, or `-1`. Empty `sub` matches at `from`. Powers `contains` and `split`.
byte_find :: fn(s: string, sub: string, from: usize) -> isize {
    sb :: s.bytes()
    subb :: sub.bytes()
    n :: sb.len()
    m :: subb.len()
    if m == 0 { return isize(from) }
    if m > n { return -1 }
    last :: n - m
    i := from
    for i <= last {
        if bytes_match_at(sb, i, subb, m) { return isize(i) }
        i = i + 1
    }
    return -1
}

/// Byte offset of the *last* occurrence of `c` in `s` at or after
/// `min_index`. Walks codepoint-by-codepoint (UTF-8 safe — the byte
/// cursor advances by each codepoint's encoded width), tracking the
/// latest match. Returns `-1` when not found ; the signed `isize`
/// return type lets callers branch on `result < 0` instead of folding
/// "absent" into a zero offset.
/// @param s          source string.
/// @param c          codepoint to find.
/// @param min_index  earliest leading-byte position to keep as a
///                   match (later matches still win). Pass `0` to
///                   accept every position.
/// @return           byte offset of the latest match, or `-1` if absent.
export last_index_of :: fn(s: string, c: char, min_index: isize) -> isize {
    sb :: s.bytes()
    n :: sb.len()
    last: isize = -1
    i: usize = 0
    for i < n {
        [cp, width] :: sb.utf8_decode_len(i)
        if isize(i) >= min_index && cp == c { last = isize(i) }
        i += width
    }
    return last
}

/// Byte offset of the *first* occurrence of `c` in `s`, starting at
/// the codepoint that begins at byte `from` (inclusive). UTF-8 safe —
/// see `last_index_of` for the iteration model. `from` should align
/// to a leading byte ; out-of-range values short-circuit to `-1`.
///
/// @param s     source string.
/// @param c     codepoint to find.
/// @param from  earliest leading-byte position considered.
/// @return      byte offset of the match, or `-1` if absent.
export index_of :: fn(s: string, c: char, from: usize) -> isize {
    sb :: s.bytes()
    n :: sb.len()
    i := from
    for i < n {
        [cp, width] :: sb.utf8_decode_len(i)
        if cp == c { return isize(i) }
        i += width
    }
    return -1
}

/// Split `s` on every occurrence of `sep`, returning the resulting
/// segments. Empty segments are preserved (between consecutive `sep`
/// runs and at the ends). For predicate-based splitting see
/// `split_where`.
/// @param s    source string.
/// @param sep  separator (matched byte-wise). Empty `sep` yields one
///             single-byte segment per byte of `s`.
/// @return     array of segments ; never empty (at minimum, `[""]`).
export split :: fn(s: string, sep: string) -> string[] {
    out: string[] = []
    sb :: s.bytes()
    n :: sb.len()
    m :: sep.bytes().len()
    if m == 0 {
        for i in 0..< n {
            out.push(sb[i..<i + 1].bytes_to_string())
        }
        return out
    }
    start :usize = 0
    found := byte_find(s, sep, start)
    for found >= 0 {
        fpos :: usize(found)
        out.push(sb[start..<fpos].bytes_to_string())
        start = fpos + m
        found = byte_find(s, sep, start)
    }
    out.push(sb[start..<n].bytes_to_string())
    return out
}

/// Concatenate `parts`, inserting `sep` between consecutive elements.
/// The inverse of `split`: `join(split(s, sep), sep) == s`.
/// @param parts  segments to concatenate ; an empty array yields `""`.
/// @param sep    separator inserted between elements only (no leading
///               or trailing copy).
/// @return       the concatenation, or `""` when `parts` is empty.
export join :: fn(parts: string[], sep: string) -> string {
    sb :: StringBuilder {}
    for i in 0..<parts.len() {
        if i > 0 { sb.append(sep) }
        sb.append(parts[i])
    }
    return sb.to_string()
}

/// Replace the first occurrence of `old` in `s` with `new` (literal substring,
/// not a pattern — use `std/regex` for pattern replacement). Returns `s`
/// unchanged when `old` does not occur.
/// @param s    source string.
/// @param old  literal substring to find.
/// @param new  replacement for the first match.
/// @return     `s` with the first `old` replaced by `new`.
export replace :: fn(s: string, old: string, new: string) -> string {
    parts :: s.split(old)
    if parts.len() <= 1 { return s }
    rest: string[] = []
    for i in 1..<parts.len() { rest.push(parts[i]) }
    return parts[0] + new + rest.join(old)
}

/// Replace every occurrence of `old` in `s` with `new` (literal). Equivalent to
/// `s.split(old).join(new)`. Use `std/regex` for pattern replacement.
/// @param s    source string.
/// @param old  literal substring to replace.
/// @param new  replacement for each match.
/// @return     `s` with every `old` replaced by `new`.
export replace_all :: fn(s: string, old: string, new: string) = s.split(old).join(new)

/// Concatenate `n` copies of `s` ; `n == 0` yields the empty string.
/// @param s  the fragment to repeat.
/// @param n  how many copies.
/// @return   `s` repeated `n` times.
export repeat :: fn(s: string, n: usize) -> string {
    sb :: StringBuilder {}
    for _ in 0..<n { sb.append(s) }
    return sb.to_string()
}

/// True when codepoint `c` occurs in `s` — a `char`-presence predicate built on
/// `index_of`. For substring containment use `sub in s` (the `Contains` trait).
/// @param s  string to search.
/// @param c  codepoint to look for.
/// @return   whether `c` appears in `s`.
export find :: fn(s: string, c: char) = s.index_of(c, 0) >= 0

/// Strip leading and trailing ASCII whitespace (`' '`, `'\t'`, `'\n'`,
/// `'\r'`). Unicode whitespace is not recognised in MVP.
export trim :: fn(s: string) -> string {
    sb :: s.bytes()
    n :: sb.len()
    lo: usize = 0
    for lo < n && is_white_byte(sb[lo]) { lo = lo + 1 }
    hi := n
    for hi > lo && is_white_byte(sb[hi - 1]) { hi = hi - 1 }
    return sb[lo..<hi].bytes_to_string()
}

/// Strip leading ASCII whitespace (`' '`, `'\t'`, `'\n'`, `'\r'`) only ;
/// trailing whitespace is preserved. See `trim` for both ends.
/// @param s  source string.
/// @return   `s` with its leading whitespace removed.
export left_trim :: fn(s: string) -> string {
    sb :: s.bytes()
    n :: sb.len()
    lo: usize = 0
    for lo < n && is_white_byte(sb[lo]) { lo = lo + 1 }
    return sb[lo..<n].bytes_to_string()
}

/// Strip trailing ASCII whitespace (`' '`, `'\t'`, `'\n'`, `'\r'`) only ;
/// leading whitespace is preserved. See `trim` for both ends.
/// @param s  source string.
/// @return   `s` with its trailing whitespace removed.
export right_trim :: fn(s: string) -> string {
    sb :: s.bytes()
    hi := sb.len()
    for hi > 0 && is_white_byte(sb[hi - 1]) { hi = hi - 1 }
    return sb[0..<hi].bytes_to_string()
}

// Codepoint-level uppercase over ASCII + the Latin-1 Supplement letters
// (`a..z`, `à..ö`, `ø..þ`, `ÿ`). `×`/`÷` (0xD7/0xF7) are excluded by the range
// gaps ; `ß` has no single-codepoint uppercase and passes through. Scripts
// beyond Latin-1 pass through unchanged — no full Unicode case tables.
to_upper_cp :: fn(cp: u32) -> u32 {
    if cp >= 0x61 && cp <= 0x7A { return cp - 0x20 }   // a-z
    if cp >= 0xE0 && cp <= 0xF6 { return cp - 0x20 }   // à-ö
    if cp >= 0xF8 && cp <= 0xFE { return cp - 0x20 }   // ø-þ
    if cp == 0xFF               { return 0x178 }       // ÿ → Ÿ
    return cp
}

// Codepoint-level lowercase, the inverse of `to_upper_cp`.
to_lower_cp :: fn(cp: u32) -> u32 {
    if cp >= 0x41 && cp <= 0x5A { return cp + 0x20 }   // A-Z
    if cp >= 0xC0 && cp <= 0xD6 { return cp + 0x20 }   // À-Ö
    if cp >= 0xD8 && cp <= 0xDE { return cp + 0x20 }   // Ø-Þ
    if cp == 0x178              { return 0xFF }        // Ÿ → ÿ
    return cp
}

/// Uppercase `s` over ASCII and the Latin-1 Supplement (`a..z`, `à..þ`, `ÿ`).
/// UTF-8 aware — walks codepoints via a byte cursor (no `chars()` iterator),
/// re-emitting an unchanged codepoint's raw bytes and only re-encoding the
/// remapped ones. Codepoints outside those ranges (incl. `ß`, non-Latin
/// scripts) pass through unchanged ; no full Unicode case tables.
export to_upper :: fn(s: string) -> string {
    sb :: StringBuilder {}
    bs :: s.bytes()
    n  :: bs.len()
    i: usize = 0
    for i < n {
        [c, w] :: bs.utf8_decode_len(i)
        // Re-emitting an unchanged codepoint via `append_char` reproduces its
        // canonical UTF-8 bytes — identical to slicing them back out.
        sb.append_char(char(to_upper_cp(u32(c))))
        i = i + w
    }
    return sb.to_string()
}

/// Lowercase `s` over ASCII and the Latin-1 Supplement (`A..Z`, `À..Þ`, `Ÿ`).
/// UTF-8 aware — walks codepoints via a byte cursor (no `chars()` iterator),
/// re-emitting an unchanged codepoint's raw bytes and only re-encoding the
/// remapped ones. Codepoints outside those ranges pass through unchanged ;
/// no full Unicode case tables.
export to_lower :: fn(s: string) -> string {
    sb :: StringBuilder {}
    bs :: s.bytes()
    n  :: bs.len()
    i: usize = 0
    for i < n {
        [c, w] :: bs.utf8_decode_len(i)
        // See `to_upper` — `append_char` re-emits the canonical bytes.
        sb.append_char(char(to_lower_cp(u32(c))))
        i = i + w
    }
    return sb.to_string()
}

/// Error raised by `parse_int` on malformed input. Also the canonical
/// parse-error type imported by `std/numbers` and `std/semver`.
export ParseError :: struct {
    msg: string
}

ParseError implements Error {
    message :: fn(self) -> string { return self.msg }
}

/// Parse `s` as a base-10 `i32`. No prefix, no underscores, no leading
/// `+` sign ; a leading `-` is accepted.
///
/// Returns the explicit union `i32 | ParseError` : callers match the
/// concrete `is ParseError` (a plain field read) instead of `is Error`.
/// The existential `Error`-trait dispatch on a stdlib error value
/// mis-executes on the self-host VM ; the concrete-type match sidesteps it.
/// @param s   the digits-only input.
/// @return    the parsed integer, or `ParseError` on failure.
/// @error     `ParseError` on empty input, malformed digit, or overflow.
export parse_int :: fn(s: string) -> i32 | ParseError {
    bs :: s.bytes()
    n :: bs.len()
    if n == 0 { return ParseError { .msg = "parse_int: empty string" } }
    i: usize = 0
    neg := false
    if bs[0] == '-' {
        neg = true
        i = 1
    }
    if i >= n { return ParseError { .msg = "parse_int: no digits" } }
    // Accumulate in i64 so i32 overflow is detectable before truncation.
    acc: i64 = 0
    for i < n {
        b :: bs[i]
        if b < '0' || b > '9' {
            return ParseError { .msg = "parse_int: invalid digit" }
        }
        acc = acc * 10 + i64(b - '0')
        if neg {
            if acc > 2147483647 + 1 { return ParseError { .msg = "parse_int: overflow" } }
        } else {
            if acc > 2147483647 { return ParseError { .msg = "parse_int: overflow" } }
        }
        i = i + 1
    }
    if neg { return i32(-acc) }
    return i32(acc)
}

/// Parse `s` as an `f64` — sign, mantissa, optional exponent. Correctly rounded
/// : delegates to `std/core::parse_f64` (Eisel-Lemire fast path + an exact
/// big-int slow path), so the VM and native backends agree bit-for-bit — unlike
/// the old `strtod` host, whose VM twin diverged on subnormals / long fractions.
///
/// Returns the explicit union `f64 | ParseError` (concrete, like `parse_int`) :
/// the existential `Error`-trait dispatch mis-executes on the self-host VM, so
/// callers match `is ParseError`.
/// @param s   the float input.
/// @return    the parsed float.
/// @error     `ParseError` on malformed input.
export parse_float :: fn(s: string) -> f64 | ParseError {
    r :: parse_f64(s)
    if r == null { return ParseError { .msg = "parse_float: invalid float `${s}`" } }
    return r
}

/// Pad `s` on the LEFT with copies of `fill` until its byte length
/// reaches `width`. Returns `s` unchanged when it's already at least
/// `width` bytes long. Width counts bytes ; accurate for ASCII,
/// approximate for non-ASCII content.
/// @param s      source string.
/// @param width  target byte length.
/// @param fill   pad character (ASCII recommended).
export pad_start :: fn(s: string, width: usize, fill: char) -> string {
    n :: s.bytes().len()
    if n >= width {
        return s
    }
    sb := StringBuilder {}
    for i in n..<width {
        sb.append_char(fill)
    }
    sb.append(s)
    return sb.to_string()
}

/// Pad `s` on the RIGHT with copies of `fill` until its byte length
/// reaches `width`. Symmetric with `pad_start`.
export pad_end :: fn(s: string, width: usize, fill: char) -> string {
    n :: s.bytes().len()
    if n >= width {
        return s
    }
    sb := StringBuilder {}
    sb.append(s)
    for i in n..<width {
        sb.append_char(fill)
    }
    return sb.to_string()
}

// Char classification (`is_white_char`/`is_digit`/`is_alpha`/`is_alnum`) moved
// to `std/char` — `fn(char) -> bool` predicates belong with char classification,
// not the codepoint-string API. Callers `import "std/char"`. See the reorg plan.

/// Strip `suffix` if `s` ends with it ; otherwise return `s` unchanged.
/// Trims at most one occurrence.
export trim_suffix :: fn(s: string, suffix: string) -> string {
    if s.ends_with(suffix) {
        bs :: s.bytes()
        return bs[0..<bs.len() - suffix.bytes().len()].bytes_to_string()
    }
    return s
}

/// Strip `prefix` if `s` starts with it ; otherwise return `s` unchanged.
/// Trims at most one occurrence.
export trim_prefix :: fn(s: string, prefix: string) -> string {
    if s.starts_with(prefix) {
        bs :: s.bytes()
        return bs[prefix.bytes().len()..<bs.len()].bytes_to_string()
    }
    return s
}

/// Decode the common C-style escape sequences in `body` :
///   `\n` → LF, `\t` → TAB, `\r` → CR, `\"` → `"`, `\\` → `\`, `\0` → NUL.
/// A backslash at the very end of `body` is preserved verbatim. Strings
/// that don't contain a backslash skip the per-byte rebuild and return
/// the original slice unchanged.
///
/// @note Lenient. Unknown escapes (e.g. `\q`) drop the leading backslash
///       and pass the following byte through (`"a\\qb"` → `"aqb"`).
///       Mirrors the lexer / VM parser's behaviour ; callers that want
///       strict-mode rejection should validate beforehand.
///
/// @param body  the raw source bytes (without surrounding quotes).
/// @return      the decoded string.
/// @example
///   `decode_escapes(r"a\nb\tc")  // "a\nb\tc" (literal LF + TAB)`
///   `decode_escapes("plain")     // "plain"`
export decode_escapes :: fn(body: string) -> string {
    if !body.contains("\\") { return body }
    out :: StringBuilder {}
    bs :: body.bytes()
    n :: bs.len()
    i: usize = 0
    for i < n {
        b :: bs[i]
        if b != '\\' {
            // Not a backslash — copy the whole codepoint (it may be multibyte ;
            // a per-byte slice would split a UTF-8 sequence).
            [c, w] :: bs.utf8_decode_len(i)
            out.append_char(c)
            i += w
            continue
        }
        if i + 1 >= n {
            out.append("\\")
            i += 1
            continue
        }
        next :: bs[i + 1]
        if      next == 'n'  { out.append("\n") }
        else if next == 't'  { out.append("\t") }
        else if next == 'r'  { out.append("\r") }
        else if next == '"'  { out.append("\"") }
        else if next == '\\' { out.append("\\") }
        else if next == '0'  { out.append("\0") }
        else {
            // Unknown escape — drop the backslash, copy the following codepoint.
            [c, w] :: bs.utf8_decode_len(i + 1)
            out.append_char(c)
            i += 1 + w
            continue
        }
        i += 2
    }
    return out.to_string()
}

/// Replace every codepoint that satisfies `pred` with `replacement`.
/// Subsumes the regex pattern `replace(/[<class>]/g, "…")`.
/// @param s            source string.
/// @param pred         predicate over each codepoint.
/// @param replacement  string to substitute for each match.
/// @return             a fresh string.
export replace_chars_where :: fn(s: string, pred: fn(char) -> bool, replacement: string) -> string {
    sb := StringBuilder {}
    for c in s.chars() {
        if pred(c) {
            sb.append(replacement)
        } else {
            sb.append_char(c)
        }
    }
    return sb.to_string()
}

/// Split `s` on runs of characters matching `pred`, dropping empty
/// segments. Mirrors `replace_chars_where(s, pred, ...)` — same predicate
/// convention, same pair-with-`is_*` ergonomics. For whitespace
/// splitting, pass `is_white_char` ; for word-boundary splitting
/// (alphanumeric runs), pass `c => !c.is_alnum()`. Empty inputs return
/// an empty array.
/// @param s     source string.
/// @param pred  predicate over each codepoint ; truthy → separator.
/// @return      non-empty segments (in source order).
/// @example
///    `"  hello\tworld  ".split_where(is_white_char) → ["hello", "world"]`
///    `"a,b,,c".split_where(c => c == ',') → ["a", "b", "c"]`
export split_where :: fn(s: string, pred: fn(char) -> bool) -> string[] {
    out: string[] = []
    sb := StringBuilder {}
    has_pending := false
    for c in s.chars() {
        if pred(c) {
            if has_pending {
                out.push(sb.to_string())
                sb = StringBuilder {}
                has_pending = false
            }
        } else {
            sb.append_char(c)
            has_pending = true
        }
    }
    if has_pending {
        out.push(sb.to_string())
    }
    return out
}

// ---------------------------------------------------------------------- tests

import "std/testing" { assert, assert_eq, assert_close }

@test test_byte_len :: fn() -> void {
    assert_eq(byte_len(""), 0)
    assert_eq(byte_len("abc"), 3)
    assert_eq(byte_len("héllo"), 6)
}

@test test_is_empty :: fn() -> void {
    assert(is_empty(""), "empty string should be empty")
    assert(!is_empty("x"), "non-empty string should not be empty")
}

@test test_bytes :: fn() -> void {
    // ASCII : one byte per codepoint, indexing + len.
    bs :: "abc".bytes()
    assert_eq(bs.len(), 3)
    assert_eq(bs[0], 97)
    assert_eq(bs[1], 98)
    assert_eq(bs[2], 99)

    // Iteration matches a manual byte_at sum.
    sum: u32 = 0
    for b in "vader".bytes() { sum = sum + u32(b) }
    assert_eq(sum, 530)

    // Empty string : zero-length view.
    assert_eq("".bytes().len(), 0)

    // Multi-byte UTF-8 : surface the raw bytes (你 = E4 BD A0).
    cjk :: "你".bytes()
    assert_eq(cjk.len(), 3)
    assert_eq(cjk[0], 228)
    assert_eq(cjk[1], 189)
    assert_eq(cjk[2], 160)

    // Slicing a byte view stays a byte view over the same bytes.
    sl :: "abcde".bytes()[1..<4]
    assert_eq(sl.len(), 3)
    assert_eq(sl[0], 98)
    assert_eq(sl[1], 99)
    assert_eq(sl[2], 100)
}


@test test_contains :: fn() -> void {
    assert("world" in "hello world", "contains world")
    assert("a" in "abc", "contains first char")
    assert(!("z" in "abc"), "does not contain z")
    assert("" in "anything", "every string contains empty")
}

@test test_starts_ends_with :: fn() -> void {
    assert(starts_with("hello", "hell"), "starts_with hell")
    assert(!starts_with("hello", "world"), "does not start_with world")
    assert(ends_with("hello", "llo"), "ends_with llo")
    assert(!ends_with("hello", "world"), "does not end_with world")
}

@test test_trim :: fn() -> void {
    assert_eq(trim("  hello  "), "hello")
    assert_eq(trim("\t\nhi\r\n"), "hi")
    assert_eq(trim("clean"), "clean")
    assert_eq(trim("   "), "")
}

@test test_case :: fn() -> void {
    assert_eq(to_upper("hello"), "HELLO")
    assert_eq(to_lower("HeLLo"), "hello")
    assert_eq(to_upper(""), "")
}

@test test_case_utf8 :: fn() -> void {
    // Latin-1 Supplement letters fold both ways.
    assert_eq(to_upper("héllo"), "HÉLLO")
    assert_eq(to_lower("HÉLLO"), "héllo")
    assert_eq(to_upper("àéîõü ç"), "ÀÉÎÕÜ Ç")
    assert_eq(to_lower("ÀÉÎÕÜ Ç"), "àéîõü ç")
    // ß has no single-codepoint uppercase → unchanged ; CJK passes through.
    assert_eq(to_upper("ß"), "ß")
    assert_eq(to_upper("你好"), "你好")
}

@test test_parse_int_ok :: fn() -> void {
    match parse_int("42") {
        is i32 as v       -> assert_eq(v, 42)
        is ParseError     -> assert(false, "expected ok i32")
    }
    match parse_int("-7") {
        is i32 as v       -> assert_eq(v, -7)
        is ParseError     -> assert(false, "expected ok i32")
    }
}

@test test_parse_int_err :: fn() -> void {
    match parse_int("abc") {
        is i32        -> assert(false, "expected err on abc")
        is ParseError -> {}
    }
}

@test test_parse_int_bounds :: fn() -> void {
    match parse_int("2147483647") {
        is i32 as v   -> assert_eq(v, 2147483647)
        is ParseError -> assert(false, "max i32 should parse")
    }
    match parse_int("-2147483647") {
        is i32 as v   -> assert_eq(v, -2147483647)
        is ParseError -> assert(false, "negative should parse")
    }
    // i32::MIN parses (value not compared — the literal would overflow i32).
    match parse_int("-2147483648") {
        is i32        -> {}
        is ParseError -> assert(false, "min i32 should parse")
    }
    match parse_int("9999999999") {
        is i32        -> assert(false, "overflow should error")
        is ParseError -> {}
    }
}

@test test_left_right_trim :: fn() -> void {
    assert_eq(left_trim("  hi  "), "hi  ")
    assert_eq(right_trim("  hi  "), "  hi")
    assert_eq(left_trim("x"), "x")
    assert_eq(right_trim("x"), "x")
    assert_eq(left_trim("   "), "")
    assert_eq(right_trim("\t\nhi"), "\t\nhi")
}

@test test_split_edge :: fn() -> void {
    // Empty input → a single empty segment.
    parts_empty :: split("", ",")
    assert_eq(parts_empty.len(), 1)
    assert_eq(parts_empty[0], "")
    // Consecutive separators preserve empty segments.
    parts_mid :: split("a,,b", ",")
    assert_eq(parts_mid.len(), 3)
    assert_eq(parts_mid[1], "")
    // Empty separator → one segment per byte.
    parts_bytes :: split("abc", "")
    assert_eq(parts_bytes.len(), 3)
    assert_eq(parts_bytes[0], "a")
    // Multi-char separator.
    parts_multi :: split("a::b::c", "::")
    assert_eq(parts_multi.len(), 3)
    assert_eq(parts_multi[2], "c")
}

@test test_join :: fn() -> void {
    // Separator goes between elements only.
    assert_eq(["a", "b", "c"].join(", "), "a, b, c")
    // Empty array → empty string.
    empty: string[] = []
    assert_eq(empty.join(", "), "")
    // Single element → no separator.
    assert_eq(["solo"].join(", "), "solo")
    // Empty separator concatenates.
    assert_eq(["a", "b", "c"].join(""), "abc")
    // Empty segments are preserved.
    assert_eq(["", "x", ""].join("-"), "-x-")
    // Multi-char separator.
    assert_eq(["a", "b", "c"].join("::"), "a::b::c")
}

@test test_join_split_roundtrip :: fn() -> void {
    // join is the inverse of split when sep is non-empty.
    s :: "a::b::c"
    assert_eq(s.split("::").join("::"), s)
    s2 :: "x,,y"
    assert_eq(s2.split(",").join(","), s2)
    // Trailing/leading separators survive the round-trip.
    s3 :: ",lead,trail,"
    assert_eq(s3.split(",").join(","), s3)
}

@test test_parse_float :: fn() -> void {
    match parse_float("3.14") {
        is f64 as v -> assert_close(v, 3.14, 0.000001)
        is ParseError -> assert(false, "expected ok f64")
    }
}

@test test_pad :: fn() -> void {
    assert_eq(pad_start("42", 5, '0'), "00042")
    assert_eq(pad_end("hi", 5, '.'), "hi...")
    assert_eq(pad_start("already long", 3, 'x'), "already long")
}

@test test_trim_prefix_suffix :: fn() -> void {
    assert_eq(trim_prefix("hello.world", "hello."), "world")
    assert_eq(trim_prefix("no-match", "xxx"), "no-match")
    assert_eq(trim_suffix("file.txt", ".txt"), "file")
    assert_eq(trim_suffix("no-match", "xxx"), "no-match")
}

@test test_len :: fn() -> void {
    assert_eq(len(""), 0)
    assert_eq(len("abc"), 3)
    assert_eq(len("héllo"), 5)
}

@test test_last_index_of :: fn() -> void {
    assert_eq(last_index_of("a/b/c", '/', -1), 3)
    assert_eq(last_index_of("none", '/', -1), -1)
}

@test test_decode_escapes :: fn() -> void {
    assert_eq(decode_escapes(""),            "")
    assert_eq(decode_escapes("plain"),       "plain")
    assert_eq(decode_escapes("a\\nb"),       "a\nb")
    assert_eq(decode_escapes("a\\tb"),       "a\tb")
    assert_eq(decode_escapes("a\\rb"),       "a\rb")
    assert_eq(decode_escapes("a\\0b"),       "a\0b")
    assert_eq(decode_escapes("a\\\\b"),      "a\\b")
    assert_eq(decode_escapes("\\\"q\\\""),   "\"q\"")
    assert_eq(decode_escapes("a\\qb"),       "aqb")            // unknown escape : drop the backslash
    assert_eq(decode_escapes("trailing\\"),  "trailing\\")     // dangling backslash preserved
}
