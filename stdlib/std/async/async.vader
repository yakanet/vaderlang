// std/async — the cooperative async runtime : `sleep` + the entry run-driver.
//
// Single-threaded, timer-driven. The scheduler state (a virtual clock + a
// min-heap of wake deadlines) lives in the runtime (native C / VM host), reached
// through the `std/runtime` `sched_*` intrinsics — Vader has no mutable global.
//
// `sleep(ms)` is the v1 suspension source : a hand-written awaitable that arms a
// timer and parks until it fires. `run_async_main` is the program entry the
// compiler routes an `async main` through : it drives the root coroutine, and
// whenever every task is parked it `sched_park`s (blocks until the nearest
// timer) rather than spinning — then re-drives. A park with nothing armed is a
// deadlock. See `.claude/plans/async-await-structured-concurrency.md` §5.

module "std/async"

import "std/runtime"
import "std/abort"
import "std/collections" { MutableMap, MutableSet }

// ---- sleep ----------------------------------------------------------------

/// The awaitable backing `sleep` : arms a wake timer on its first `resume`, then
/// parks (returns `Suspended`) until the scheduler's clock reaches its deadline.
/// Completes with `null` (an async that yields no value — `await sleep(...)`
/// discards it).
///
/// Cancellation uses `Async`'s default no-op : v1 has no `sched_disarm`, so a
/// cancelled `Sleep` leaves its timer armed. The deadline still fires harmlessly
/// (nobody re-drives it), and a lingering timer can only DELAY deadlock
/// detection, never mask it — accepted v1 debt.
Sleep :: struct {
    ms:       i64
    deadline: i64 = 0
    armed:    bool = false
}

Sleep implements Async<null> {
    resume :: fn(self) -> null | Suspended {
        if !self.armed {
            self.armed = true
            self.deadline = sched_now() + self.ms
            sched_arm(self.deadline)
        }
        if sched_now() >= self.deadline { return null }
        return Suspended {}
    }
}

/// Suspend the current coroutine for at least `ms` virtual milliseconds. A
/// factory (it constructs the awaitable, it does not itself await), so it is an
/// ordinary function returning an `Async`, not a coroutine.
///
/// @param ms  the minimum delay, in milliseconds.
/// @return    an awaitable that completes once the delay elapses.
export sleep :: fn(ms: i64) -> Async<null> = Sleep { .ms = ms }

// ---- entry driver ---------------------------------------------------------

/// Drive an `async main`'s root frame to completion and return its exit code.
/// Compiler-invoked : when `main` awaits, the program entry calls this with
/// `main()`'s `Async<i32>` frame. Resumes the root ; whenever it parks, blocks
/// on the nearest armed timer (`sched_park`) and re-drives — never spins.
///
/// @param root  the `Async<i32>` frame produced by calling the async `main`.
/// @return      main's completed `i32` exit code.
/// @error       panics on a park with no timer armed — every task is suspended
///              with nothing left to wake it (a deadlock).
export run_async_main :: fn(root: Async<i32>) -> i32 = block_on(root)

/// Drive any awaitable to completion from synchronous code, returning its
/// result. Resumes `root` and, whenever it parks, blocks on the nearest armed
/// timer (`sched_park`) then re-drives — never spins. Needs no `async main`: it
/// works over the global scheduler state, so a plain sync caller (e.g. the CLI
/// spawning subprocesses) can fan out awaitables and join them here.
///
/// @param root  the awaitable to run to completion.
/// @return      its completed value.
/// @error       panics on a park with nothing armed to wake it (a deadlock).
export block_on :: fn<T>(root: Async<T>) -> T {
    for {
        r :: root.resume()
        if r is Suspended {
            if sched_park() == 1 {
                panic("async deadlock: a task is suspended with nothing left to wake it")
            }
        } else {
            return r
        }
    }
}

// ---- all ------------------------------------------------------------------

/// Concurrent join of a group of awaitables (Model A : one awaitable that drives
/// every child on each `resume`). Children make progress together — their timers
/// all sit on the one scheduler heap and fire in deadline order — and their
/// results are returned in INPUT order once every one completes. No cancellation
/// in v1, so `all` waits for every child (failure latency = the slowest child).
All :: struct<T> {
    children: Async<T>[]
    /// Completed results keyed by input index ; an index is present iff its
    /// child is done. `results.len() == children.len()` ⇒ all joined.
    results:  MutableMap<usize, T>
}

All<T> implements Async<T[]> {
    resume :: fn(self) -> T[] | Suspended {
        n :: self.children.len()
        for i in 0..<n {
            if i in self.results { continue }
            r :: self.children[i].resume()
            if r is Suspended { continue }
            self.results[i] = r
        }
        if self.results.len() != n { return Suspended {} }
        out: T[] = []
        for i in 0..<n {
            v :: self.results[i]
            if v != null { out.push(v) }
        }
        return out
    }
    // Tear down every child (a completed one is a no-op teardown). `all` owns its
    // children, so cancelling the join cancels the whole fan-out.
    cancel :: fn(self) -> void {
        for c in self.children { c.cancel() }
    }
}

/// Await a group of awaitables concurrently, yielding their results in input
/// order. `await all(xs)` completes when every element of `xs` has completed.
///
/// @param xs  the awaitables to join.
/// @return    an awaitable of the results, index-aligned with `xs`.
export all :: fn<T>(xs: Async<T>[]) -> Async<T[]> = All<T> { .children = xs, .results = MutableMap<usize, T> {} }

// ---- try_all (fallible join, first-error) ---------------------------------

/// The awaitable backing `try_all` — a hand-written driver (NOT a coroutine :
/// generic async coroutines are out of v1 scope). Wraps an `All<U | E>` to do
/// the concurrent join, then scans the joined array in input order for the first
/// error. Returns that array verbatim on success, so each element keeps its
/// original boxed form (no `U[]` rebuild).
TryAll :: struct<U, E> {
    inner: All<U | E>
}

TryAll<U, E> implements Async<(U | E)[] | Error> {
    resume :: fn(self) -> (U | E)[] | Error | Suspended {
        r :: self.inner.resume()
        if r is Suspended { return Suspended {} }
        for v in r {
            if v is Error as e { return e }   // first error, by input order
        }
        return r
    }
    // Delegate to the wrapped `All` — it owns the children.
    cancel :: fn(self) -> void = self.inner.cancel()
}

/// Concurrent join of FALLIBLE awaitables (children of type `U | E`). Runs every
/// child (like `all` — no cancellation in v1, so failure latency is the slowest
/// child), then — scanning in input order — completes with the FIRST error, or
/// the full results if none failed.
///
/// The successes come back as `(U | E)[]`, each element typed as the child union
/// — narrow per element at the use site if you need the raw `U`.
///
/// @param xs  the fallible awaitables to join.
/// @return    the results in input order, or the first `Error`.
export try_all :: fn<U, E>(xs: Async<U | E>[]) -> Async<(U | E)[] | Error> =
    TryAll<U, E> { .inner = All<U | E> { .children = xs, .results = MutableMap<usize, U | E> {} } }

// ---- race -----------------------------------------------------------------

/// The awaitable backing `race` : drives every child on each `resume` and, the
/// moment one settles (value OR error — `race` does not distinguish), cancels
/// all the others and completes with its result. Deterministic tie-break : the
/// lowest input index wins within a tick.
Race :: struct<T> {
    children: Async<T>[]
}

Race<T> implements Async<T> {
    resume :: fn(self) -> T | Suspended {
        n :: self.children.len()
        for i in 0..<n {
            r :: self.children[i].resume()
            if r is Suspended { continue }
            for j in 0..<n {
                if j != i { self.children[j].cancel() }
            }
            return r
        }
        return Suspended {}
    }
    cancel :: fn(self) -> void {
        for c in self.children { c.cancel() }
    }
}

/// Race a group of awaitables : complete with the FIRST to settle (value or
/// error), cancelling the losers so they leave no orphaned work. Unlike `all`,
/// the return type is a single `T` — the winner's result.
///
/// @param xs  the awaitables to race.
/// @return    an awaitable of the first to settle.
export race :: fn<T>(xs: Async<T>[]) -> Async<T> = Race<T> { .children = xs }

// ---- any ------------------------------------------------------------------

/// The awaitable backing `any` : like `race`, but a settled ERROR is not a win —
/// the child is retired and the others keep running. Completes with the FIRST
/// SUCCESS (cancelling the losers), or — if every child fails — the last error.
Any :: struct<U, E> {
    children: Async<U | E>[]
    /// Indices whose child has already settled as an error (skipped on re-drive).
    /// A pure set — the error value itself is kept in `last`.
    errors:   MutableSet<usize>
    /// The most recent error — returned if every child ends up failing.
    last:     (U | E) | null
}

Any<U, E> implements Async<U | E> {
    resume :: fn(self) -> (U | E) | Suspended {
        n :: self.children.len()
        for i in 0..<n {
            if i in self.errors { continue }
            r :: self.children[i].resume()
            if r is Suspended { continue }
            if r is Error {
                self.errors.add(i)
                self.last = r
                continue
            }
            for j in 0..<n {
                if j != i { self.children[j].cancel() }
            }
            return r
        }
        if self.errors.len() == n {
            l :: self.last
            if l != null { return l }
        }
        return Suspended {}
    }
    cancel :: fn(self) -> void {
        for c in self.children { c.cancel() }
    }
}

/// Await a group of FALLIBLE awaitables (children of type `U | E`), completing
/// with the FIRST success and cancelling the rest. If every child fails,
/// completes with the last error. The dual of `try_all` (first success vs first
/// error).
///
/// @param xs  the fallible awaitables to race for a success.
/// @return    the first successful result, or the last error if all fail.
export any :: fn<U, E>(xs: Async<U | E>[]) -> Async<U | E> =
    Any<U, E> { .children = xs, .errors = MutableSet<usize> {}, .last = null }

// ---- timeout --------------------------------------------------------------

/// Error completing a `timeout` when its deadline elapses before the awaited
/// value is ready.
export TimeoutError :: struct {
    /// The deadline that elapsed, in milliseconds.
    ms: i64
}

TimeoutError implements Error {
    message :: fn(self) -> string = "operation timed out after ${self.ms}ms"
}

/// The awaitable backing `timeout` : each `resume` drives the child first, then
/// (only if the child is not ready) the timer. Whoever settles first wins — the
/// child's value, or a `TimeoutError` once the timer fires — and the loser is
/// cancelled.
Timeout :: struct<T> {
    child: Async<T>
    timer: Async<null>
    ms:    i64
}

Timeout<T> implements Async<T | TimeoutError> {
    resume :: fn(self) -> T | TimeoutError | Suspended {
        rc :: self.child.resume()
        if rc is Suspended {
            rt :: self.timer.resume()
            if rt is Suspended { return Suspended {} }
            // Timer fired first — cancel the pending child, report the timeout.
            self.child.cancel()
            return TimeoutError { .ms = self.ms }
        }
        // Child completed first — cancel the timer (a no-op in v1), return it.
        self.timer.cancel()
        return rc
    }
    cancel :: fn(self) -> void {
        self.child.cancel()
        self.timer.cancel()
    }
}

/// Await `x`, but fail with a `TimeoutError` if it is not ready within `ms`
/// virtual milliseconds. The losing side (the child on timeout, the timer on
/// success) is cancelled.
///
/// @param ms  the deadline, in milliseconds.
/// @param x   the awaitable to bound.
/// @return    `x`'s result, or a `TimeoutError` if the deadline elapses first.
export timeout :: fn<T>(ms: i64, x: Async<T>) -> Async<T | TimeoutError> =
    Timeout<T> { .child = x, .timer = sleep(ms), .ms = ms }
