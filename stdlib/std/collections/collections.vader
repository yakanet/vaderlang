// std/collections — hash-based mutable collections.
//
// Java-inspired API : struct-literal construction + UFCS methods. Method
// names like `put` / `get` / `len` / `is_empty` are deliberately shared
// across the two collections; UFCS dispatch picks the right overload by
// receiver type (cf. SPEC §6 *Function overloading*).
//
// Sequence collections live in the language : `[T]` arrays support `push`,
// `len`, indexed access, mutation, and `for x in arr` — no `MutableList`
// wrapper is needed at MVP. Immutable `List<T>` (post-MVP) will pair with
// arrays once read-only views and `to_immutable` are designed.
//
// Construction examples :
//
//   m := MutableMap(string, i32) {}
//   m.put("answer", 42)
//
//   s := MutableSet(i32) {}
//   s.add(10)
//
// `MutableMap` is a COMPACT (open-addressed) hash map : dense parallel
// `ekeys` / `evals` arrays in insertion order, plus a sparse `i32` index
// (hash slot → entry position). No per-entry node, no `next` pointer, no
// nullable bucket array — ~3-4× less memory than a chained map, faster
// insert / iterate, and far faster string-key lookups (see
// `.claude/plans/compact-dict-mutablemap.md`). The index doubles + rehashes
// past a 0.75 load factor. `MutableSet` wraps it (each member a `T → true`).

// ===========================================================================
// MutableMap(K, V) — compact open-addressed hash map. Live entries live in two
// dense parallel arrays (`ekeys[i]` ↔ `evals[i]`) in insertion order; a sparse
// `index` of `i32` maps a hash slot to an entry position (1-based; 0 = empty,
// -1 = tombstone). Lookup hashes the key, probes the index (linear) skipping
// tombstones, and compares via `Equals`. Insert appends to the dense arrays
// (reusing a slot freed by `remove`); `remove` swaps the last entry into the
// hole and tombstones the index slot. The index doubles + rehashes past 0.75.
// ===========================================================================

module "std/collections"

MINIMAL_INDEX_COUNT :: usize(16)

EMPTY_SLOT :: i32(0)    // index slot holds no entry
TOMB_SLOT  :: i32(-1)   // index slot held an entry that was removed

// Yielded by `for [k, v] in m` — the parser desugars the `[...]` destructure
// over an `Entry` (a struct, not a tuple) through `Into<[K, V]>`, and the
// lowerer inlines the tuple-literal body so `k = e.key` / `v = e.value` bind
// with no per-iteration allocation. No `next` field — entries are not nodes.
Entry :: struct<K, V> {
    key:   K
    value: V
}

Entry<K, V> implements<K, V> Into<[K, V]> {
    into :: fn(self) -> [K, V] = [self.key, self.value]
}

/// Compact hash map keyed by any `K` that implements `Hash & Equals`. Entries
/// are stored in insertion order in dense `ekeys` / `evals`; a sparse `i32`
/// `index` resolves a key's hash to its entry position. `K`'s `hash()` is
/// queried on insert / lookup / rehash, `equals()` on probe comparisons.
export MutableMap :: struct<K: Hash & Equals, V> {
    /// Dense entry keys in insertion order. `ekeys[i]` pairs with `evals[i]`.
    /// `[size, ekeys.len())` are spare slots freed by `remove`, reused by `put`.
    ekeys: K[] = []
    /// Dense entry values, parallel to `ekeys`.
    evals: V[] = []
    /// Open-addressed hash table : slot → entry position + 1 ; `EMPTY_SLOT`
    /// (0) = free, `TOMB_SLOT` (-1) = tombstone. Length is a power of two,
    /// lazily allocated to `MINIMAL_INDEX_COUNT` on first insert.
    index: i32[] = []
    /// `index.len() - 1` — bitmask for the power-of-two slot count.
    mask:  usize = 0
    /// Live entry count.
    size:  usize = 0
    /// Tombstone count in `index`. Counted toward the load factor so a
    /// remove-heavy map rehashes (clearing tombstones) before the open-addressed
    /// probe runs out of `EMPTY` slots and loops forever.
    tombs: usize = 0
}

// Method signatures below declare just `[K, V]` (no bound repetition) — the
// `Hash & Equals` constraint is auto-inherited from the struct decl above by
// the typecheck `inherit-bounds` pass when the first param is `MutableMap(K, V)`.

slot_for :: fn(h: u64, mask: usize) -> usize = usize(h) & mask

// Lazy-initialise the index on first insert. No-op once allocated, so cheap to
// call from every mutating entry point. Mirrors the old `ensure_buckets`.
ensure_index :: fn<K, V>(self: MutableMap<K, V>) -> void {
    if self.index.len() == 0 {
        idx: i32[] = []
        for 0..<MINIMAL_INDEX_COUNT { idx.push(EMPTY_SLOT) }
        self.index = idx
        self.mask = MINIMAL_INDEX_COUNT - 1
    }
}

// Rebuild the index at `new_count` slots from the dense entries — re-probing
// each live key. Clears all tombstones. The dense `ekeys` / `evals` are never
// touched (entries don't move), so growth allocates no entries.
rehash :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, new_count: usize) -> void {
    fresh: i32[] = []
    for 0..<new_count { fresh.push(EMPTY_SLOT) }
    new_mask :: new_count - 1
    for e in 0..<self.size {
        s: usize = slot_for(self.ekeys[e].hash(), new_mask)
        for fresh[s] != EMPTY_SLOT { s = (s + 1) & new_mask }
        fresh[s] = i32(e + 1)
    }
    self.index = fresh
    self.mask = new_mask
    self.tombs = 0
}

// Write the (key, value) entry at logical position `self.size` — reusing a
// spare dense slot freed by a prior `remove`, or appending.
write_entry :: fn<K, V>(self: MutableMap<K, V>, key: K, value: V) -> void {
    if self.size < self.ekeys.len() {
        self.ekeys[self.size] = key
        self.evals[self.size] = value
    } else {
        self.ekeys.push(key)
        self.evals.push(value)
    }
}

/// Insert or overwrite `key → value`. Probes the index from `hash & mask` ; an
/// existing key has its value replaced in place, otherwise a fresh entry is
/// appended (reusing the first tombstone seen, if any).
/// @param self   the map receiver.
/// @param key    key with which `value` is associated.
/// @param value  the new value.
put :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, key: K, value: V) -> void {
    self.ensure_index()
    // Rehash when used slots (entries + tombstones) pass 0.75. Size the new
    // table to the LIVE entry count so a tombstone-heavy map compacts (clears
    // tombstones) instead of only ever doubling.
    if (self.size + self.tombs + 1) * 4 > (self.mask + 1) * 3 {
        new_count := MINIMAL_INDEX_COUNT
        for (self.size + 1) * 4 > new_count * 3 { new_count = new_count * 2 }
        self.rehash(new_count)
    }
    s: usize = slot_for(key.hash(), self.mask)
    first_tomb: i64 = -1
    for self.index[s] != EMPTY_SLOT {
        if self.index[s] == TOMB_SLOT {
            if first_tomb < 0 { first_tomb = i64(s) }
        } else {
            ei :: usize(self.index[s]) - 1
            if self.ekeys[ei].equals(key) { self.evals[ei] = value  return }
        }
        s = (s + 1) & self.mask
    }
    target :: if first_tomb >= 0 { usize(first_tomb) } else { s }
    if first_tomb >= 0 { self.tombs = self.tombs - 1 }   // reused a tombstone slot
    self.write_entry(key, value)
    self.index[target] = i32(self.size + 1)
    self.size = self.size + 1
}

/// Logically empty the map while KEEPING its backing arrays (`ekeys` / `evals` /
/// `index`) allocated, so a subsequent refill reuses them instead of allocating
/// a fresh map. For hot reuse loops — e.g. a dataflow fixpoint's scratch set
/// that would otherwise mint a new map every round. The dense entries past
/// `size` are stale but unreachable (`size = 0`), and `write_entry` overwrites
/// them from slot 0 on the next insert. O(index slots).
/// @param self  the map receiver.
export clear :: fn<K, V>(self: MutableMap<K, V>) -> void {
    self.size = 0
    self.tombs = 0
    for i in 0..<self.index.len() { self.index[i] = EMPTY_SLOT }
}

/// Look up `key`. Returns the stored value or `null` if absent.
/// @param self  the map receiver.
/// @param key   key to look up.
/// @return      `V` when present, `null` otherwise.
get :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, key: K) -> V | null {
    if self.index.len() == 0 { return null }
    s: usize = slot_for(key.hash(), self.mask)
    for self.index[s] != EMPTY_SLOT {
        if self.index[s] != TOMB_SLOT {
            ei :: usize(self.index[s]) - 1
            if self.ekeys[ei].equals(key) { return self.evals[ei] }
        }
        s = (s + 1) & self.mask
    }
    return null
}

/// True iff `key` has an entry in the map. Distinguishes "key absent" from
/// "key maps to a null-typed value" — `get` collapses both to `null`.
/// @param self  the map receiver.
/// @param key   key to test.
contains_key :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, key: K) -> bool {
    if self.index.len() == 0 { return false }
    s: usize = slot_for(key.hash(), self.mask)
    for self.index[s] != EMPTY_SLOT {
        if self.index[s] != TOMB_SLOT {
            ei :: usize(self.index[s]) - 1
            if self.ekeys[ei].equals(key) { return true }
        }
        s = (s + 1) & self.mask
    }
    return false
}

// Find the index slot whose stored value equals `want` (a 1-based entry pos),
// probing from `key`'s hash. Used by `remove` to re-point a swapped entry.
slot_holding :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, key: K, want: i32) -> usize {
    s: usize = slot_for(key.hash(), self.mask)
    for self.index[s] != EMPTY_SLOT {
        if self.index[s] == want { return s }
        s = (s + 1) & self.mask
    }
    return self.index.len()
}

/// Remove the entry for `key`, if present. The matching entry is overwritten by
/// the last dense entry (which is re-pointed in the index), the freed dense slot
/// becomes spare, and the key's index slot is tombstoned. A no-op when absent.
/// @param self  the map receiver.
/// @param key   key whose entry to drop.
/// @return      `true` when an entry was removed, `false` when `key` was absent.
export remove :: fn<K: Hash & Equals, V>(self: MutableMap<K, V>, key: K) -> bool {
    if self.index.len() == 0 { return false }
    s: usize = slot_for(key.hash(), self.mask)
    for self.index[s] != EMPTY_SLOT {
        if self.index[s] != TOMB_SLOT {
            ei :: usize(self.index[s]) - 1
            if self.ekeys[ei].equals(key) {
                last :: self.size - 1
                if ei != last {
                    moved_slot :: self.slot_holding(self.ekeys[last], i32(last + 1))
                    self.ekeys[ei] = self.ekeys[last]
                    self.evals[ei] = self.evals[last]
                    self.index[moved_slot] = i32(ei + 1)
                }
                self.index[s] = TOMB_SLOT
                self.tombs = self.tombs + 1
                self.size = self.size - 1
                return true
            }
        }
        s = (s + 1) & self.mask
    }
    return false
}

/// Number of `(key, value)` entries currently stored in `self`. O(1).
export len :: fn<K, V>(self: MutableMap<K, V>) -> usize { return self.size }

/// True iff no entries have been inserted (or all were removed). O(1).
export is_empty :: fn<K, V>(self: MutableMap<K, V>) -> bool { return self.size == 0 }

// Operator sugar — `m[key]` reads via Index, `m[key] = v` writes via
// IndexSet, `key in m` dispatches via Contains. K's `Hash & Equals` bound is
// auto-inherited from the struct decl ; the impl bodies reuse `get` / `put`
// / `contains_key` so all the dispatch machinery is shared.
MutableMap<K, V> implements Index<K, V | null> {
    at :: fn(self, key: K) -> V | null { return self.get(key) }
}

MutableMap<K, V> implements IndexSet<K, V> {
    set_at :: fn(self, key: K, v: V) { self.put(key, v) }
}

MutableMap<K, V> implements Contains<K> {
    contains :: fn(self, key: K) -> bool { return self.contains_key(key) }
}

/// Snapshot of every key in insertion order. Allocates a fresh `[K]`.
/// @param self  the map receiver.
/// @return      a new array of every stored key.
export keys :: fn<K, V>(self: MutableMap<K, V>) -> K[] {
    out: K[] = []
    for e in 0..<self.size { out.push(self.ekeys[e]) }
    return out
}

/// Snapshot of every value in insertion order, matching `keys()`. Allocates a
/// fresh `[V]`. Pairing keys and values index-by-index gives a stable view.
/// @param self  the map receiver.
/// @return      a new array of every stored value.
export values :: fn<K, V>(self: MutableMap<K, V>) -> V[] {
    out: V[] = []
    for e in 0..<self.size { out.push(self.evals[e]) }
    return out
}

/// Lazy iterator over a `MutableMap`'s entries, in insertion order. Walks the
/// dense entry arrays by index — no snapshot allocation. Mutating `self` while
/// a `MapIterator` is live yields undefined behaviour.
@specialize
export MapIterator :: struct<K: Hash & Equals, V> {
    src: MutableMap<K, V>
    pos: usize
}

// `for entry in m` works directly thanks to the `Into(Iterator(...))`
// impl below — no explicit `.iter()` call needed.

MutableMap<K, V> implements<K, V> Into<Iterator<Entry<K, V>>> {
    into :: fn(self) -> Iterator<Entry<K, V>> {
        return MapIterator<K, V> { .src = self, .pos = 0 }
    }
}

MapIterator<K, V> implements Iterator<Entry<K, V>> {
    next :: fn(self) -> Yield<Entry<K, V>> | null {
        if self.pos >= self.src.size { return null }
        e :: Entry<K, V> { .key = self.src.ekeys[self.pos], .value = self.src.evals[self.pos] }
        self.pos = self.pos + 1
        return Yield<Entry<K, V>> { .value = e }
    }
}

// ===========================================================================
// MutableSet(T) — hash-backed via a wrapping MutableMap. Each member is stored
// as a (T → true) entry, so lookups inherit the compact-map O(1) behaviour.
// `where T: Hash + Equals` mirrors MutableMap's own bound.
// ===========================================================================

/// Hash set keyed by any `T` that implements `Hash & Equals`. Backed by a
/// `MutableMap(T, bool)` — every member is stored as a `(T → true)` entry,
/// so lookups inherit the compact-map O(1)-average behaviour.
export MutableSet :: struct<T: Hash & Equals> {
    /// Backing map. Defaults empty so `MutableSet(T) {}` is a valid literal.
    inner: MutableMap<T, bool> = MutableMap<T, bool> {}
}

/// Insert `value`. Returns `true` if `value` was newly added, `false` if it
/// was already present (the set is unchanged in the latter case).
/// @param self   the set receiver.
/// @param value  the element to add.
/// @return       `true` on insertion, `false` on duplicate.
export add :: fn<T>(self: MutableSet<T>, value: T) -> bool {
    if value in self.inner { return false }
    self.inner[value] = true
    return true
}

/// True iff `value` is a member of the set. The UFCS entry point for
/// `set.contains(v)` (callers `import { contains }`) ; `v in set` instead
/// lowers to the `Contains` impl below. Same body, distinct dispatch paths —
/// like `MutableMap.contains_key` vs its `Contains` impl, but sharing the name.
export contains :: fn<T>(self: MutableSet<T>, value: T) -> bool = value in self.inner

/// Remove `value` from the set, if present. Delegates to the backing map's
/// `remove`. A no-op when `value` is not a member.
/// @param self   the set receiver.
/// @param value  the element to drop.
/// @return       `true` when `value` was removed, `false` when it was absent.
export remove :: fn<T>(self: MutableSet<T>, value: T) -> bool = self.inner.remove(value)

/// Number of members in the set. O(1).
export len :: fn<T>(self: MutableSet<T>) -> usize = self.inner.size

/// True iff no members have been added (or all were removed). O(1).
export is_empty :: fn<T>(self: MutableSet<T>) -> bool = self.inner.size == 0

/// Logically empty the set, keeping the backing arrays for reuse — for hot
/// reuse loops (e.g. a dataflow fixpoint's scratch set). Delegates to the
/// backing map's `clear`. O(index slots).
export clear :: fn<T>(self: MutableSet<T>) -> void = self.inner.clear()

// `value in set` / `value !in set` dispatch through Contains. No
// Index/IndexSet impl — sets have no value-at-key semantics, and `s.add(v)`
// reads more clearly than a hypothetical `s[v] = true`.
MutableSet<T> implements Contains<T> -> value in self.inner

/// Lazy iterator over a `MutableSet`'s members, in insertion order. Walks the
/// backing map's dense key array by index. Same undefined-behaviour caveat as
/// `MapIterator` on concurrent mutation.
@specialize
export SetIterator :: struct<T: Hash & Equals> {
    set: MutableSet<T>
    pos: usize
}

// `for v in s` works directly via the `Into(Iterator(...))` impl below —
// same pattern as `MutableMap`.

MutableSet<T> implements<T> Into<Iterator<T>> {
    into :: fn(self) -> Iterator<T> {
        return SetIterator<T> { .set = self, .pos = 0 }
    }
}

SetIterator<T> implements Iterator<T> {
    next :: fn(self) -> Yield<T> | null {
        if self.pos >= self.set.inner.size { return null }
        k :: self.set.inner.ekeys[self.pos]
        self.pos = self.pos + 1
        return Yield<T> { .value = k }
    }
}

// ---------------------------------------------------------------------- tests

import "std/testing" { assert, assert_eq }

@test test_map_put_get :: fn() -> void {
    m := MutableMap<string, i32> {}
    m["one"] = 1
    m["two"] = 2
    m["three"] = 3
    assert_eq(m.len(), 3)
    match m.get("two") {
        is i32 as v -> assert_eq(v, 2)
        is null -> assert(false, "expected key two")
    }
    match m.get("missing") {
        is i32 -> assert(false, "expected null on missing")
        is null -> {}
    }
}

@test test_map_overwrite :: fn() -> void {
    m := MutableMap<string, i32> {}
    m["k"] = 1
    m["k"] = 99
    assert_eq(m.len(), 1)
    match m.get("k") {
        is i32 as v -> assert_eq(v, 99)
        is null -> assert(false, "key k expected")
    }
}

@test test_map_contains_key :: fn() -> void {
    m := MutableMap<string, i32> {}
    m["k"] = 1
    assert(m.contains_key("k"), "should contain k")
    assert(!m.contains_key("nope"), "should not contain nope")
}

@test test_map_is_empty :: fn() -> void {
    m := MutableMap<string, i32> {}
    assert(m.is_empty(), "fresh map is empty")
    m["x"] = 1
    assert(!m.is_empty(), "after put no longer empty")
}

@test test_set_add_contains :: fn() -> void {
    s := MutableSet<i32> { .inner = MutableMap<i32, bool> {} }
    s.add(10)
    s.add(20)
    s.add(10)
    assert_eq(s.len(), 2)
    assert(s.contains(10), "should contain 10")
    assert(!s.contains(99), "should not contain 99")
}

@test test_map_remove :: fn() -> void {
    m := MutableMap<string, i32> {}
    m["a"] = 1
    m["b"] = 2
    assert(m.remove("a"), "removing present key returns true")
    assert_eq(m.len(), 1)
    assert(!m.contains_key("a"), "removed key gone")
    assert(m.contains_key("b"), "untouched key stays")
    assert(!m.remove("a"), "removing absent key returns false")
    assert_eq(m.len(), 1)
}

@test test_set_remove :: fn() -> void {
    s := MutableSet<i32> { .inner = MutableMap<i32, bool> {} }
    s.add(10)
    s.add(20)
    assert(s.remove(10), "removing present member returns true")
    assert_eq(s.len(), 1)
    assert(!s.contains(10), "removed member gone")
    assert(s.contains(20), "untouched member stays")
    assert(!s.remove(10), "removing absent member returns false")
}

@test test_map_iteration_order :: fn() -> void {
    m := MutableMap<i32, i32> {}
    for i in 0..<usize(50) { m[i32(i)] = i32(i) * 2 }
    seen := 0
    sum := 0
    for [k, v] in m {
        seen = seen + 1
        sum = sum + v
        assert_eq(v, k * 2)
    }
    assert_eq(seen, 50)
    assert_eq(sum, 2450)
}

@test test_map_remove_then_reinsert :: fn() -> void {
    m := MutableMap<i32, i32> {}
    for i in 0..<usize(100) { m[i32(i)] = i32(i) }
    for i in 0..<usize(100) { if i % 3 == 0 { m.remove(i32(i)) } }
    for i in 0..<usize(100) { if i % 3 == 0 { m[i32(i)] = i32(i) * 7 } }
    assert_eq(m.len(), 100)
    for i in 0..<usize(100) {
        expected :: if i % 3 == 0 { i32(i) * 7 } else { i32(i) }
        match m.get(i32(i)) {
            is i32 as v -> assert_eq(v, expected)
            is null -> assert(false, "key should be present")
        }
    }
}
