// std/list — generic mutable list.
//
// Java-inspired API : struct-literal construction + UFCS methods.
//
// Construction example :
//   list := MutableList(i32) { .data = [], .size = 0 }
//   list.add(10)
//
// Factory free functions (`new_mutable_list`, `MutableList.ofSize`) are
// post-MVP — they require explicit type-arg syntax that the parser doesn't
// expose yet (cf. TODO).
//
// `Map` / `Set` live in `std/map` and `std/set` respectively.
// Immutable `List` (read-only) is a struct stub — full ops post-MVP.

// ===========================================================================
// List (read-only) — TODO post-MVP. Same layout as MutableList; the API
// surface will be a strict subset (no add/set). Conversion via `to_list` will
// copy when implemented. Declared here so user code can reference the type
// in signatures even though no operations are exposed yet.
// ===========================================================================

List :: struct($T) {
    data: [T]
    size: usize
}

// ===========================================================================
// MutableList — backed by a built-in dynamic array `[T]`.
// ===========================================================================

MutableList :: struct($T) {
    data: [T]
    size: usize
}

// ---- ops (UFCS) ----

add :: fn(self: MutableList($T), value: T) -> void {
    self.data.push(value)
    self.size = self.size + 1
}

get :: fn(self: MutableList($T), index: usize) -> T {
    return self.data[index]
}

set :: fn(self: MutableList($T), index: usize, value: T) -> void {
    self.data[index] = value
}

len :: fn(self: MutableList($T)) -> usize {
    return self.size
}

is_empty :: fn(self: MutableList($T)) -> bool {
    return self.size == 0
}

// ---- iteration ----

private MutableListIter :: struct($T) {
    list:   MutableList(T)
    cursor: usize
}

MutableListIter($T) implements Iterator(T) {
    fn step(self) -> Done | Yielded(T) {
        if (self.cursor >= self.list.size) {
            return Done {}
        }
        v :: self.list.data[self.cursor]
        self.cursor = self.cursor + 1
        return Yielded(T) { .value = v }
    }
}

iter :: fn(self: MutableList($T)) -> MutableListIter(T) {
    return MutableListIter(T) { .list = self, .cursor = 0 }
}
