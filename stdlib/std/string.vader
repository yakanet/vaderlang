// std/string — string operations.
//
// All string operations treat strings as immutable UTF-8 byte sequences.
// Width-based helpers (`pad_start`, `pad_end`) measure width in bytes, not
// codepoints — accurate for ASCII, approximate for non-ASCII content.

import "std/string_builder" { StringBuilder, new_builder, append, append_char, to_string }

// Length in bytes.
export len :: fn(s: string) -> i32

// Substring extraction (bytes-based, exclusive end).
export slice :: fn(s: string, start: i32, end: i32) -> string

// Predicates.
export contains    :: fn(s: string, sub: string) -> bool
export starts_with :: fn(s: string, prefix: string) -> bool
export ends_with   :: fn(s: string, suffix: string) -> bool

// Character access (byte index → Unicode codepoint).
export char_at :: fn(s: string, i: i32) -> char

// Last byte-index of `c` at or after `min_index`, or -1 if not found.
export last_index_of :: fn(s: string, c: char, min_index: i32) -> i32 {
    i := s.len() - 1
    for i >= min_index {
        if s.char_at(i) == c {
            return i
        }
        i = i - 1
    }
    return -1
}

// Splitting and trimming.
export split :: fn(s: string, sep: string) -> [string]
export trim  :: fn(s: string) -> string

// Case conversion.
export to_upper :: fn(s: string) -> string
export to_lower :: fn(s: string) -> string

// Parsing.
export ParseError :: struct {
    msg: string
}

ParseError implements Error {
    fn message(self) -> string { return self.msg }
}

export parse_int   :: fn(s: string) -> i32!
export parse_float :: fn(s: string) -> f64!

// Pad `s` on the left with `fill` until its byte length reaches `width`.
// Returns `s` unchanged when it's already at least `width` bytes.
export pad_start :: fn(s: string, width: i32, fill: char) -> string {
    n := s.len()
    if n >= width {
        return s
    }
    sb := new_builder()
    i := n
    for i < width {
        sb.append_char(fill)
        i = i + 1
    }
    sb.append(s)
    return sb.to_string()
}

// Pad `s` on the right with `fill` until its byte length reaches `width`.
export pad_end :: fn(s: string, width: i32, fill: char) -> string {
    n := s.len()
    if n >= width {
        return s
    }
    sb := new_builder()
    sb.append(s)
    i := n
    for i < width {
        sb.append_char(fill)
        i = i + 1
    }
    return sb.to_string()
}

// True for ASCII whitespace: space, tab, newline, carriage return.
export is_whitechar :: fn(c: char) = c == ' ' || c == '\t' || c == '\n' || c == '\r'

// True for ASCII decimal digit `0..9`.
export is_digit :: fn(c: char) = c >= '0' && c <= '9'

// True for ASCII hex digit `0..9 a..f A..F`.
export is_hex_digit :: fn(c: char) =
    c.is_digit() || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')

// True for any digit in `base` (2 / 8 / 10 / 16). Caller is expected to
// pass a supported base ; unsupported bases fall through to base-10.
export is_digit_in_base :: fn(c: char, base: i32) -> bool {
    if base == 2 { return c == '0' || c == '1' }
    if base == 8 { return c >= '0' && c <= '7' }
    if base == 16 { return c.is_hex_digit() }
    return c.is_digit()
}

// Strip a `suffix` if `s` ends with it; otherwise return `s` unchanged.
export trim_suffix :: fn(s: string, suffix: string) -> string {
    if s.ends_with(suffix) {
        return s.slice(0, s.len() - suffix.len())
    }
    return s
}

// Strip a `prefix` if `s` starts with it; otherwise return `s` unchanged.
export trim_prefix :: fn(s: string, prefix: string) -> string {
    if s.starts_with(prefix) {
        return s.slice(prefix.len(), s.len())
    }
    return s
}

// Replace every char that satisfies `pred` with `replacement`. Subsumes
// the regex pattern `replace(/[<class>]/g, "<replacement>")`.
export replace_chars_where :: fn(s: string, pred: fn(char) -> bool, replacement: string) -> string {
    sb := new_builder()
    n := s.len()
    i := 0
    for i < n {
        c := s.char_at(i)
        if pred(c) {
            sb.append(replacement)
        } else {
            sb.append_char(c)
        }
        i = i + 1
    }
    return sb.to_string()
}

// Split on runs of whitespace, dropping empty segments.
export split_whitespace :: fn(s: string) -> [string] {
    out: [string] = []
    sb := new_builder()
    has_pending := false
    n := s.len()
    i := 0
    for i < n {
        c := s.char_at(i)
        if c.is_whitechar() {
            if has_pending {
                out.push(sb.to_string())
                sb = new_builder()
                has_pending = false
            }
        } else {
            sb.append_char(c)
            has_pending = true
        }
        i = i + 1
    }
    if has_pending {
        out.push(sb.to_string())
    }
    return out
}
