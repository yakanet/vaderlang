# Bench artifacts — native binaries + generated C/Go/class from `bench/run.ts`.
# Every workload lives in `bench/<name>/` with all its language sources
# colocated (`<name>.vader`, `.ts`, `.go`, `.java`) ; the compiled outputs land
# alongside as `bench/<name>/<name>` (Vader binary), `.c` (transient C),
# `<name>_go` (Go binary) and `<name>.class` (Java, incl. nested `$X.class`).
bench/*/*.c
bench/*/*_go
bench/*/*.class
bench/binary_trees/binary_trees
bench/iter_chain/iter_chain
bench/mandelbrot/mandelbrot
bench/map_iter/map_iter
bench/primes/primes
bench/string_builder/string_builder
bench/arr_rw/arr_rw
bench/arr_set/arr_set
bench/arr_push/arr_push
bench/str_concat/str_concat
bench/interp/interp
bench/hashmap/hashmap
bench/ackermann/ackermann
bench/wordcount/wordcount
bench/quicksort/quicksort
*.dSYM/

## POCs
poc/

# Snippet artefacts — left behind when a dev runs `vader build` directly on
# a `tests/snippets/<name>/_main.vader` to inspect the native output. The
# C emitter writes `_main.c` next to the source and the linker emits a
# `_main` binary ; `tests/native.test.ts` uses `native.c` / `native[.exe]`
# for its own runs and those are listed separately just below.
tests/snippets/*/_main
tests/snippets/*/_main.c
tests/snippets/*/native
tests/snippets/*/native.c
