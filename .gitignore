node_modules/
dist/
build/
*.wasm
*.tsbuildinfo

# Self-host CLI build artefacts (binary + generated C from `vader build vader/cli/main.vader`)
vader/cli/main
vader/cli/main.c
vader/cli/main.dSYM/
.DS_Store
.env
.env.*
!.env.example
*.log
coverage/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Bench artifacts — native binaries + generated C from `bench/run.ts`. Each
# bench source lives in `bench/<name>/<name>.vader` (post-Phase-7 module-system
# rollout) ; the C-emit + native-build outputs land alongside as
# `bench/<name>/<name>` (binary) and `bench/<name>/<name>.c` (transient C).
# Per-language ports stay flat under `bench/` (e.g. bench/primes.go,
# bench/primes_go, bench/primes.class).
bench/*/*.c
bench/binary_trees/binary_trees
bench/iter_chain/iter_chain
bench/mandelbrot/mandelbrot
bench/map_iter/map_iter
bench/primes/primes
bench/string_builder/string_builder
bench/poc_erasure/packed_inline_test/packed_inline_test
bench/poc_erasure/vtable_emit_test/vtable_emit_test
bench/poc_erasure/*/*.c
bench/*_go
bench/*.class
*.dSYM/

# Snippet artefacts — left behind when a dev runs `vader build` directly on
# a `tests/snippets/<name>/_main.vader` to inspect the native output. The
# C emitter writes `_main.c` next to the source and the linker emits a
# `_main` binary ; `tests/native.test.ts` uses `native.c` / `native[.exe]`
# for its own runs and those are listed separately just below.
tests/snippets/*/_main
tests/snippets/*/_main.c
tests/snippets/*/native
tests/snippets/*/native.c
