import "std/io" { println }

/**
 * Simple implementation of fibonacci numbers
 */
fibonacci :: fn(n: i32) -> i32 {
     a := 0
     b := 1
     for i in 0..<n {
         c :: a + b
         a = b
         b = c
     }
     return a
}

main :: fn() -> i32 {
    n :: 50
    println("fibonacci($n): ${fibonacci(n)}")
    return 0
}
