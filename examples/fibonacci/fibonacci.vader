module "main"

import "std/io"

/**
 * Simple implementation of fibonacci numbers
 */
export fibonacci :: fn(n: i32) -> u64 {
    a: u64 = 0
    b: u64 = 1
    for i in 0..<n {
        c :: a + b
        a = b
        b = c
    }
    return a
}

main :: fn() -> i32 {
    n :: 50
    defer println("Fibonacci numbers: $n")
    println("fibonacci($n): ${fibonacci(n)}")
    return 0
}
