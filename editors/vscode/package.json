{
  "name": "vader",
  "displayName": "Vader",
  "description": "Syntax highlighting for the Vader programming language",
  "version": "0.1.0",
  "publisher": "vaderlang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "sync": "cp ../common/vader.tmLanguage.json syntaxes/vader.tmLanguage.json && cp ../common/language-configuration.json language-configuration.json",
    "vscode:prepublish": "npm run sync"
  },
  "contributes": {
    "languages": [
      {
        "id": "vader",
        "aliases": [
          "Vader",
          "vader"
        ],
        "extensions": [
          ".vader"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vader",
        "scopeName": "source.vader",
        "path": "./syntaxes/vader.tmLanguage.json"
      }
    ]
  }
}
