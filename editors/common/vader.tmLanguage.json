{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vader",
  "scopeName": "source.vader",
  "fileTypes": ["vader"],
  "patterns": [
    { "include": "#shebang" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#decorators" },
    { "include": "#modules" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "shebang": {
      "match": "^#!.*$",
      "name": "comment.line.shebang.vader"
    },
    "comments": {
      "patterns": [
        {
          "comment": "VaderDoc — `///` line form. Pattern must come before the regular `//` rule.",
          "name": "comment.line.documentation.vader",
          "begin": "///",
          "end": "$",
          "patterns": [{ "include": "#vaderdoc-tags" }]
        },
        {
          "name": "comment.line.double-slash.vader",
          "match": "//.*$"
        },
        {
          "name": "comment.block.vader",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "vaderdoc-tags": {
      "patterns": [
        {
          "comment": "Tag with following name (e.g. `@param msg`). The tag itself carries multiple parent scopes so both engines pick it up : `keyword.control.documentation.vader` covers IntelliJ's TextMate mapping (which falls back to `keyword.control` for the IDE keyword color) ; VSCode themes typically style any `storage.type.*` or `keyword.*` scope distinctly inside a doc-comment block.",
          "match": "@(param)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.documentation.vader" },
            "2": { "name": "variable.parameter.documentation.vader" }
          }
        },
        {
          "comment": "Bare tag (`@return`, `@error`, `@example`).",
          "name": "keyword.control.documentation.vader",
          "match": "@(return|error|example)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.vader",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-escape" },
            { "include": "#string-interpolation" }
          ]
        },
        {
          "name": "string.quoted.raw.vader",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.quoted.double.vader",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escape" },
            { "include": "#string-interpolation" }
          ]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.unicode.vader",
          "match": "\\\\u\\{[0-9A-Fa-f]{1,6}\\}"
        },
        {
          "name": "constant.character.escape.vader",
          "match": "\\\\[ntr\\\\\"'$0]"
        }
      ]
    },
    "string-interpolation": {
      "name": "meta.embedded.expression.vader",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.vader" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.vader" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#identifiers" }
      ]
    },
    "chars": {
      "name": "string.quoted.single.vader",
      "match": "'(?:\\\\u\\{[0-9A-Fa-f]{1,6}\\}|\\\\[ntr\\\\'0]|[^\\\\'])'",
      "captures": {
        "0": { "name": "string.quoted.single.vader" }
      }
    },
    "decorators": {
      "patterns": [
        {
          "name": "storage.modifier.decorator.builtin.vader",
          "match": "@(comptime|file|export|test|extern)\\b"
        },
        {
          "name": "storage.modifier.decorator.vader",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "comment": "Soft keyword `module \"<name>\"` recognised only at the file prologue. The regex pins it to start-of-line so field-name uses (`.module = ...`, `module: T`) keep their identifier styling.",
          "match": "^\\s*(module)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.module.vader" },
            "2": { "name": "string.quoted.double.vader" }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "\\b(import)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.import.vader" },
            "2": { "name": "string.quoted.double.vader" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "Function declaration: name :: fn",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(::)\\s*(fn)\\b",
          "captures": {
            "1": { "name": "entity.name.function.vader" },
            "2": { "name": "keyword.operator.declaration.vader" },
            "3": { "name": "storage.type.function.vader" }
          }
        },
        {
          "comment": "Type declaration: Name :: struct|trait|enum",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(::)\\s*(struct|trait|enum)\\b",
          "captures": {
            "1": { "name": "entity.name.type.vader" },
            "2": { "name": "keyword.operator.declaration.vader" },
            "3": { "name": "storage.type.vader" }
          }
        },
        {
          "comment": "Generic type alias: Name[T] :: <body>",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(\\[)([^\\]]*)(\\])\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.type.vader" },
            "2": { "name": "punctuation.bracket.vader" },
            "3": { "name": "variable.parameter.type.vader" },
            "4": { "name": "punctuation.bracket.vader" },
            "5": { "name": "keyword.operator.declaration.vader" }
          }
        },
        {
          "comment": "Trait implementation: Type implements Trait",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s+(implements)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.vader" },
            "2": { "name": "keyword.other.implements.vader" },
            "3": { "name": "entity.name.type.trait.vader" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vader",
          "match": "\\b(if|else|match|for|in|return|yield|await|defer|break|continue|as)\\b"
        },
        {
          "name": "keyword.operator.expression.is.vader",
          "match": "\\b(is)\\b"
        },
        {
          "name": "keyword.operator.expression.in.vader",
          "match": "(?<![a-zA-Z0-9_])!in\\b"
        },
        {
          "name": "keyword.other.import.vader",
          "match": "\\b(import)\\b"
        },
        {
          "name": "storage.type.vader",
          "match": "\\b(fn|struct|trait|enum|impl)\\b"
        },
        {
          "name": "keyword.other.implements.vader",
          "match": "\\b(implements)\\b"
        },
        {
          "name": "storage.modifier.vader",
          "match": "\\b(export|const)\\b"
        },
        {
          "name": "variable.language.self.vader",
          "match": "\\b(self|Self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vader",
          "match": "\\b(bool|u8|u16|u32|u64|usize|i8|i16|i32|i64|f32|f64|char|string|void|rawptr|int|long|float|double|byte)\\b"
        },
        {
          "comment": "Generic type parameter: $T",
          "name": "variable.parameter.type.vader",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "comment": "Type names (UpperCamelCase identifiers)",
          "name": "entity.name.type.vader",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vader",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vader",
          "match": "\\b(null)\\b"
        },
        {
          "comment": "SCREAMING_SNAKE_CASE constants",
          "name": "variable.other.constant.vader",
          "match": "\\b[A-Z][A-Z0-9_]+\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "Hex literal with optional suffix",
          "name": "constant.numeric.hex.vader",
          "match": "\\b0[xX][0-9A-Fa-f][0-9A-Fa-f_]*(?:_?(?:i8|i16|i32|i64|u8|u16|u32|u64|usize))?\\b"
        },
        {
          "comment": "Binary literal",
          "name": "constant.numeric.binary.vader",
          "match": "\\b0[bB][01][01_]*(?:_?(?:i8|i16|i32|i64|u8|u16|u32|u64|usize))?\\b"
        },
        {
          "comment": "Octal literal",
          "name": "constant.numeric.octal.vader",
          "match": "\\b0[oO][0-7][0-7_]*(?:_?(?:i8|i16|i32|i64|u8|u16|u32|u64|usize))?\\b"
        },
        {
          "comment": "Float literal with exponent",
          "name": "constant.numeric.float.vader",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)?(?:_?(?:f32|f64))?\\b"
        },
        {
          "comment": "Float literal with exponent, no fractional",
          "name": "constant.numeric.float.vader",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9_]+(?:_?(?:f32|f64))?\\b"
        },
        {
          "comment": "Float with explicit f32/f64 suffix",
          "name": "constant.numeric.float.vader",
          "match": "\\b[0-9][0-9_]*_?(?:f32|f64)\\b"
        },
        {
          "comment": "Integer literal with optional suffix",
          "name": "constant.numeric.integer.vader",
          "match": "\\b[0-9][0-9_]*(?:_?(?:i8|i16|i32|i64|u8|u16|u32|u64|usize))?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.range.vader",
          "match": "\\.\\.<|\\.\\.="
        },
        {
          "name": "keyword.operator.declaration.vader",
          "match": "::|:="
        },
        {
          "name": "keyword.operator.arrow.vader",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.vader",
          "match": "==|!=|<=|>=|<(?![<=])|>(?![>=])"
        },
        {
          "name": "keyword.operator.logical.vader",
          "match": "&&|\\|\\||!(?!=)"
        },
        {
          "name": "keyword.operator.assignment.compound.vader",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.assignment.vader",
          "match": "="
        },
        {
          "name": "keyword.operator.bitwise.vader",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.vader",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.try.vader",
          "match": "\\?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function call: ident(",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.vader" }
          }
        },
        {
          "comment": "Method call: .ident(",
          "match": "\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.vader" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Field access (.field)",
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.member.vader" }
          }
        },
        {
          "name": "variable.other.vader",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
